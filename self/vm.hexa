// ═══════════════════════════════════════════════════════════
//  self/vm.hexa — HEXA bytecode VM written in HEXA
//  Phase 3 (P3) of self-hosting: execute bytecode from compiler.hexa
//  Stack-based VM with locals, call frames, and constant pool.
//
//  Opcodes match those emitted by self/compiler.hexa.
//  This is the scaffold — iteratively expanded to full coverage.
// ═══════════════════════════════════════════════════════════

// ── Shared structs (inlined until module system exists) ──

struct Instruction {
    op: string,
    operand: string
}

struct CompiledFn {
    name: string,
    arity: int,
    param_names: string,
    code: string,
    local_count: int
}

// ── Value representation (matches interpreter.hexa Val) ──

struct Val {
    tag: string,
    int_val: int,
    float_val: float,
    bool_val: bool,
    str_val: string,
    char_val: string,
    array_val: string,
    fn_name: string,
    fn_params: string,
    fn_body: string,
    struct_name: string,
    struct_fields: string
}

fn val_int(n) { return Val { tag: "int", int_val: n, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }
fn val_float(f) { return Val { tag: "float", int_val: 0, float_val: f, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }
fn val_bool(b) { return Val { tag: "bool", int_val: 0, float_val: 0.0, bool_val: b, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }
fn val_str(s) { return Val { tag: "str", int_val: 0, float_val: 0.0, bool_val: false, str_val: s, char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }
fn val_void() { return Val { tag: "void", int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }
fn val_array(a) { return Val { tag: "array", int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: a, fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }

// ── Store-based array (VM uses int_val as index into vm_array_store) ──

fn vm_val_array(items) {
    let idx = len(vm_array_store)
    vm_array_store = vm_array_store.push(items)
    return Val { tag: "array", int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn vm_get_array(v) {
    return vm_array_store[v.int_val]
}

fn vm_set_array(v, new_items) {
    vm_array_store[v.int_val] = new_items
}

// ── Store-based struct (VM uses int_val as index into vm_struct_store) ──

fn vm_val_struct(name, fields) {
    let idx = len(vm_struct_store)
    vm_struct_store = vm_struct_store.push(fields)
    return Val { tag: "struct", int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: name, struct_fields: "" }
}

fn vm_get_struct_fields(v) {
    return vm_struct_store[v.int_val]
}

fn vm_set_struct_fields(v, fields) {
    vm_struct_store[v.int_val] = fields
}

// ── Store-based closure ──

fn vm_val_closure(fname, captured) {
    let idx = len(vm_closure_store)
    vm_closure_store = vm_closure_store.push(captured)
    return Val { tag: "closure", int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: fname, fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

// ── Reference Counting (RC) Memory Management ───────────

// RC object store: parallel arrays
let mut rc_values = []      // the actual heap values
let mut rc_counts = []      // refcount per slot (0 = freed)
let mut rc_alive  = []      // true if slot is live

// Stats
let mut rc_total_allocs = 0
let mut rc_total_frees  = 0

// Allocate a value with refcount=1, return its handle (index)
fn rc_alloc(value) {
    // Try to reuse a freed slot
    let mut i = 0
    while i < len(rc_values) {
        if rc_alive[i] == false {
            rc_values[i] = value
            rc_counts[i] = 1
            rc_alive[i] = true
            rc_total_allocs = rc_total_allocs + 1
            return i
        }
        i = i + 1
    }
    // No free slot — append
    let idx = len(rc_values)
    rc_values = rc_values.push(value)
    rc_counts = rc_counts.push(1)
    rc_alive = rc_alive.push(true)
    rc_total_allocs = rc_total_allocs + 1
    return idx
}

// Increment refcount
fn rc_retain(h) {
    if h < 0 || h >= len(rc_values) { return }
    if rc_alive[h] == false { return }
    rc_counts[h] = rc_counts[h] + 1
}

// Decrement refcount; free when it reaches 0
fn rc_release(h) {
    if h < 0 || h >= len(rc_values) { return }
    if rc_alive[h] == false { return }
    rc_counts[h] = rc_counts[h] - 1
    if rc_counts[h] <= 0 {
        rc_alive[h] = false
        rc_values[h] = ""
        rc_counts[h] = 0
        rc_total_frees = rc_total_frees + 1
    }
}

// Get the underlying value by handle
fn rc_deref(h) {
    if h < 0 || h >= len(rc_values) { return "" }
    if rc_alive[h] == false { return "" }
    return rc_values[h]
}

// Get the current refcount for a handle
fn rc_refcount(h) {
    if h < 0 || h >= len(rc_values) { return 0 }
    if rc_alive[h] == false { return 0 }
    return rc_counts[h]
}

// Check if a handle is alive
fn rc_is_alive(h) {
    if h < 0 || h >= len(rc_values) { return false }
    return rc_alive[h]
}

// Return stats: [allocs, frees, live]
fn rc_stats() {
    let live = rc_total_allocs - rc_total_frees
    return [rc_total_allocs, rc_total_frees, live]
}

// Reset the entire RC heap (for testing / between VM runs)
fn rc_reset() {
    rc_values = []
    rc_counts = []
    rc_alive = []
    rc_total_allocs = 0
    rc_total_frees = 0
}

// ── Call frame ───────────────────────────────────────────

struct CallFrame {
    fn_name: string,
    code: string,
    ip: int,
    base_slot: int,
    local_count: int
}

// ── VM state ─────────────────────────────────────────────

let mut vm_stack = []          // operand stack: array of Val
let mut vm_frames = []         // call frame stack: array of CallFrame
let mut vm_globals = []        // global variables: [[name, val], ...]
let mut vm_constants = []      // constant pool: array of strings
let mut vm_functions = []      // compiled functions: array of CompiledFn
let mut vm_halted = false
let mut vm_error = ""
let mut vm_array_store = []   // external store for arrays of Val
let mut vm_struct_store = []  // external store for struct field maps [[k,v], ...]
let mut vm_closure_store = [] // external store for closure captured locals
let mut vm_catch_stack = []   // stack of catch handler addresses
let mut vm_break_flag = false
let mut vm_continue_flag = false
let mut vm_loop_starts = []   // stack of loop header IP addresses
let mut vm_loop_ends = []     // stack of loop end IP addresses

// ── Stack operations ─────────────────────────────────────

fn vm_push(val) {
    vm_stack = vm_stack.push(val)
}

fn vm_pop() {
    let top = vm_stack[len(vm_stack) - 1]
    // Rebuild stack without last element
    let mut new_stack = []
    let mut i = 0
    while i < len(vm_stack) - 1 {
        new_stack = new_stack.push(vm_stack[i])
        i = i + 1
    }
    vm_stack = new_stack
    return top
}

fn vm_peek() {
    return vm_stack[len(vm_stack) - 1]
}

fn vm_peek_at(offset) {
    return vm_stack[len(vm_stack) - 1 - offset]
}

// ── Global variable helpers ──────────────────────────────

fn vm_get_global(name) {
    let mut i = len(vm_globals) - 1
    while i >= 0 {
        if vm_globals[i][0] == name {
            return vm_globals[i][1]
        }
        i = i - 1
    }
    vm_error = "undefined global: " + name
    return val_void()
}

fn vm_set_global(name, val) {
    // Update existing or append
    let mut i = 0
    while i < len(vm_globals) {
        if vm_globals[i][0] == name {
            vm_globals[i] = [name, val]
            return
        }
        i = i + 1
    }
    vm_globals = vm_globals.push([name, val])
}

// ── Function registry lookup ─────────────────────────────

fn vm_find_fn(name) {
    let mut i = 0
    while i < len(vm_functions) {
        if vm_functions[i].name == name {
            return vm_functions[i]
        }
        i = i + 1
    }
    return ""
}

// ── Local variable access (frame-relative) ───────────────

fn vm_get_local(frame, slot) {
    return vm_stack[frame.base_slot + slot]
}

fn vm_set_local(frame, slot, val) {
    vm_stack[frame.base_slot + slot] = val
}

// ── Constant pool value parsing ──────────────────────────
// Constants are stored as strings in the pool; we parse into Val on load.

fn vm_parse_const(raw) {
    // Try bool
    if raw == "true" { return val_bool(true) }
    if raw == "false" { return val_bool(false) }
    // Try int (simple digit check)
    if len(raw) > 0 {
        let first = raw[0]
        if is_digit(first) || first == "-" {
            // Check for float (contains '.')
            if contains(raw, ".") {
                return val_float(to_float(raw))
            }
            return val_int(to_int(raw))
        }
    }
    // Default: treat as string
    return val_str(raw)
}

// ── Val arithmetic / comparison helpers ──────────────────

fn vm_val_to_string(v) {
    if v.tag == "int" { return to_string(v.int_val) }
    if v.tag == "float" { return to_string(v.float_val) }
    if v.tag == "bool" { return to_string(v.bool_val) }
    if v.tag == "str" { return v.str_val }
    if v.tag == "void" { return "void" }
    if v.tag == "array" { return "<array>" }
    return "<val>"
}

fn vm_val_is_truthy(v) {
    if v.tag == "bool" { return v.bool_val }
    if v.tag == "int" { return v.int_val != 0 }
    if v.tag == "str" { return len(v.str_val) > 0 }
    if v.tag == "void" { return false }
    return true
}

// ══════════════════════════════════════════════════════════
// Main execution loop
// ══════════════════════════════════════════════════════════

fn vm_run(code, constants, functions) {
    // Initialize VM state
    vm_stack = []
    vm_frames = []
    vm_globals = []
    vm_constants = constants
    vm_functions = functions
    vm_halted = false
    vm_error = ""
    vm_array_store = []
    vm_struct_store = []
    vm_closure_store = []
    vm_catch_stack = []
    vm_break_flag = false
    vm_continue_flag = false

    // Top-level frame
    let top_frame = CallFrame {
        fn_name: "<main>",
        code: code,
        ip: 0,
        base_slot: 0,
        local_count: 256
    }
    vm_frames = vm_frames.push(top_frame)

    // Reserve local slots on stack
    let mut i = 0
    while i < 256 {
        vm_push(val_void())
        i = i + 1
    }

    vm_dispatch()

    return vm_error == ""
}

// ── Alternate frame accessors (flat-array VM path) ──────

fn vm_get_ip() {
    return vm_frame_ips[vm_frame_count - 1]
}

fn vm_set_ip(new_ip) {
    vm_frame_ips[vm_frame_count - 1] = new_ip
}

fn vm_get_code() {
    return vm_frame_codes[vm_frame_count - 1]
}

fn vm_get_local(slot) {
    let base = vm_frame_bases[vm_frame_count - 1]
    return vm_locals[base + slot]
}

fn vm_set_local(slot, val) {
    let base = vm_frame_bases[vm_frame_count - 1]
    vm_locals[base + slot] = val
}

// ── Builtin dispatch ─────────────────────────────────────

fn vm_builtin(spec) {
    let parts = spec.split(":")
    let name = parts[0]
    let argc = to_int(parts[1])

    if name == "len" {
        let v = vm_pop()
        vm_push(len(v))
        return
    }
    if name == "to_string" {
        let v = vm_pop()
        vm_push(to_string(v))
        return
    }
    if name == "int" {
        let v = vm_pop()
        vm_push(to_int(v))
        return
    }
    if name == "float" {
        let v = vm_pop()
        vm_push(to_float(v))
        return
    }
    if name == "type_of" {
        let v = vm_pop()
        vm_push(type_of(v))
        return
    }
    if name == "format" {
        let mut args = []
        let mut i = 0
        while i < argc {
            args = args.push(vm_pop())
            i = i + 1
        }
        let mut rev = []
        let mut j = len(args) - 1
        while j >= 0 {
            rev = rev.push(args[j])
            j = j - 1
        }
        let mut result = ""
        let mut k = 0
        while k < len(rev) {
            if k > 0 { result = result + " " }
            result = result + vm_value_to_string(rev[k])
            k = k + 1
        }
        vm_push(result)
        return
    }
    if name == "abs" {
        let v = vm_pop()
        if v < 0 { vm_push(0 - v) } else { vm_push(v) }
        return
    }
    if name == "min" {
        let b = vm_pop()
        let a = vm_pop()
        if a < b { vm_push(a) } else { vm_push(b) }
        return
    }
    if name == "max" {
        let b = vm_pop()
        let a = vm_pop()
        if a > b { vm_push(a) } else { vm_push(b) }
        return
    }
    if name == "floor" {
        let v = vm_pop()
        vm_push(to_int(v))
        return
    }
    if name == "ceil" {
        let v = vm_pop()
        let i = to_int(v)
        let f = to_float(v)
        if f > to_float(i) { vm_push(i + 1) } else { vm_push(i) }
        return
    }
    if name == "round" {
        let v = vm_pop()
        vm_push(to_int(to_float(v) + 0.5))
        return
    }
    if name == "sqrt" {
        let v = vm_pop()
        vm_push(sqrt(to_float(v)))
        return
    }
    if name == "pow" {
        let b = vm_pop()
        let a = vm_pop()
        vm_push(pow(to_float(a), to_float(b)))
        return
    }
    if name == "log" || name == "ln" {
        let v = vm_pop()
        vm_push(ln(to_float(v)))
        return
    }
    if name == "sin" {
        let v = vm_pop()
        vm_push(sin(to_float(v)))
        return
    }
    if name == "cos" {
        let v = vm_pop()
        vm_push(cos(to_float(v)))
        return
    }
    if name == "tan" {
        let v = vm_pop()
        vm_push(tan(to_float(v)))
        return
    }
    if name == "exp" {
        let v = vm_pop()
        vm_push(exp(to_float(v)))
        return
    }
    if name == "clock" {
        vm_push(clock())
        return
    }
    if name == "is_alpha" {
        let v = vm_pop()
        vm_push(is_alpha(v))
        return
    }
    if name == "is_digit" {
        let v = vm_pop()
        vm_push(is_digit(v))
        return
    }
    if name == "is_alphanumeric" {
        let v = vm_pop()
        vm_push(is_alphanumeric(v))
        return
    }
    if name == "read_file" {
        let v = vm_pop()
        vm_push(read_file(v))
        return
    }
    // Unknown builtin
    vm_push("")
}

fn vm_dispatch() {
    while !vm_halted && vm_error == "" && len(vm_frames) > 0 {
        let fidx = len(vm_frames) - 1
        let frame = vm_frames[fidx]
        let code = frame.code

        if frame.ip >= len(code) {
            // End of code for this frame
            if len(vm_frames) <= 1 {
                vm_halted = true
                return
            }
            // Implicit void return
            let mut new_frames = []
            let mut j = 0
            while j < len(vm_frames) - 1 {
                new_frames = new_frames.push(vm_frames[j])
                j = j + 1
            }
            vm_frames = new_frames
            vm_push(val_void())
            return vm_dispatch()
        }

        let ins = code[frame.ip]
        let op = ins.op
        let operand = ins.operand

        // Advance IP
        vm_frames[fidx] = CallFrame {
            fn_name: frame.fn_name,
            code: frame.code,
            ip: frame.ip + 1,
            base_slot: frame.base_slot,
            local_count: frame.local_count
        }

        // ── Dispatch ────────────────────────────────────

        if op == "CONST" {
            let idx = to_int(operand)
            let val = vm_parse_const(vm_constants[idx])
            vm_push(val)
        }

        if op == "VOID" {
            vm_push(val_void())
        }

        if op == "POP" {
            vm_pop()
        }

        if op == "DUP" {
            let top = vm_peek()
            vm_push(top)
        }

        // ── Arithmetic ──────────────────────────────────

        if op == "ADD" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" {
                vm_push(val_int(a.int_val + b.int_val))
            }
            if a.tag == "float" && b.tag == "float" {
                vm_push(val_float(a.float_val + b.float_val))
            }
            if a.tag == "float" && b.tag == "int" {
                vm_push(val_float(a.float_val + to_float(b.int_val)))
            }
            if a.tag == "int" && b.tag == "float" {
                vm_push(val_float(to_float(a.int_val) + b.float_val))
            }
            if a.tag == "str" && b.tag == "str" {
                vm_push(val_str(a.str_val + b.str_val))
            }
            if a.tag == "str" && b.tag != "str" {
                vm_push(val_str(a.str_val + vm_val_to_string(b)))
            }
        }

        if op == "SUB" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" {
                vm_push(val_int(a.int_val - b.int_val))
            }
            if a.tag == "float" && b.tag == "float" {
                vm_push(val_float(a.float_val - b.float_val))
            }
            if a.tag == "float" && b.tag == "int" {
                vm_push(val_float(a.float_val - to_float(b.int_val)))
            }
            if a.tag == "int" && b.tag == "float" {
                vm_push(val_float(to_float(a.int_val) - b.float_val))
            }
        }

        if op == "MUL" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" {
                vm_push(val_int(a.int_val * b.int_val))
            }
            if a.tag == "float" && b.tag == "float" {
                vm_push(val_float(a.float_val * b.float_val))
            }
            if a.tag == "float" && b.tag == "int" {
                vm_push(val_float(a.float_val * to_float(b.int_val)))
            }
            if a.tag == "int" && b.tag == "float" {
                vm_push(val_float(to_float(a.int_val) * b.float_val))
            }
        }

        if op == "DIV" {
            let b = vm_pop()
            let a = vm_pop()
            if b.tag == "int" && b.int_val == 0 {
                vm_error = "division by zero"
                return
            }
            if b.tag == "float" && b.float_val == 0.0 {
                vm_error = "division by zero"
                return
            }
            if a.tag == "int" && b.tag == "int" {
                vm_push(val_int(a.int_val / b.int_val))
            }
            if a.tag == "float" && b.tag == "float" {
                vm_push(val_float(a.float_val / b.float_val))
            }
            if a.tag == "float" && b.tag == "int" {
                vm_push(val_float(a.float_val / to_float(b.int_val)))
            }
            if a.tag == "int" && b.tag == "float" {
                vm_push(val_float(to_float(a.int_val) / b.float_val))
            }
        }

        if op == "MOD" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" {
                vm_push(val_int(a.int_val % b.int_val))
            }
        }

        if op == "POW" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" {
                let mut acc = 1
                let mut e = b.int_val
                while e > 0 {
                    acc = acc * a.int_val
                    e = e - 1
                }
                vm_push(val_int(acc))
            }
            if a.tag == "float" {
                let base = a.float_val
                let mut accf = 1.0
                let mut ef = 0
                if b.tag == "int" { ef = b.int_val }
                if b.tag == "float" { ef = to_int(to_string(b.float_val)) }
                while ef > 0 {
                    accf = accf * base
                    ef = ef - 1
                }
                vm_push(val_float(accf))
            }
        }

        if op == "NEG" {
            let a = vm_pop()
            if a.tag == "int" { vm_push(val_int(0 - a.int_val)) }
            if a.tag == "float" { vm_push(val_float(0.0 - a.float_val)) }
        }

        if op == "NOT" {
            let a = vm_pop()
            vm_push(val_bool(!vm_val_is_truthy(a)))
        }

        if op == "BITNOT" {
            let a = vm_pop()
            if a.tag == "int" {
                vm_push(val_int(0 - a.int_val - 1))
            } else {
                vm_push(val_int(0))
            }
        }

        // ── Comparison ──────────────────────────────────

        if op == "EQ" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" { vm_push(val_bool(a.int_val == b.int_val)) }
            if a.tag == "str" && b.tag == "str" { vm_push(val_bool(a.str_val == b.str_val)) }
            if a.tag == "bool" && b.tag == "bool" { vm_push(val_bool(a.bool_val == b.bool_val)) }
            if a.tag == "float" && b.tag == "float" { vm_push(val_bool(a.float_val == b.float_val)) }
        }

        if op == "NE" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" { vm_push(val_bool(a.int_val != b.int_val)) }
            if a.tag == "str" && b.tag == "str" { vm_push(val_bool(a.str_val != b.str_val)) }
            if a.tag == "bool" && b.tag == "bool" { vm_push(val_bool(a.bool_val != b.bool_val)) }
        }

        if op == "LT" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" { vm_push(val_bool(a.int_val < b.int_val)) }
            if a.tag == "float" && b.tag == "float" { vm_push(val_bool(a.float_val < b.float_val)) }
        }

        if op == "GT" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" { vm_push(val_bool(a.int_val > b.int_val)) }
            if a.tag == "float" && b.tag == "float" { vm_push(val_bool(a.float_val > b.float_val)) }
        }

        if op == "LE" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" { vm_push(val_bool(a.int_val <= b.int_val)) }
            if a.tag == "float" && b.tag == "float" { vm_push(val_bool(a.float_val <= b.float_val)) }
        }

        if op == "GE" {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag == "int" && b.tag == "int" { vm_push(val_bool(a.int_val >= b.int_val)) }
            if a.tag == "float" && b.tag == "float" { vm_push(val_bool(a.float_val >= b.float_val)) }
        }

        // ── Logical ─────────────────────────────────────

        if op == "AND" {
            let b = vm_pop()
            let a = vm_pop()
            vm_push(val_bool(vm_val_is_truthy(a) && vm_val_is_truthy(b)))
        }

        if op == "OR" {
            let b = vm_pop()
            let a = vm_pop()
            vm_push(val_bool(vm_val_is_truthy(a) || vm_val_is_truthy(b)))
        }

        if op == "XOR" {
            // TODO: implement XOR properly
            let b = vm_pop()
            let a = vm_pop()
            let at = vm_val_is_truthy(a)
            let bt = vm_val_is_truthy(b)
            vm_push(val_bool((at || bt) && !(at && bt)))
        }

        // ── Local variable access ───────────────────────

        if op == "GET_LOCAL" {
            let slot = to_int(operand)
            let cur_frame = vm_frames[len(vm_frames) - 1]
            let val = vm_stack[cur_frame.base_slot + slot]
            vm_push(val)
        }

        if op == "SET_LOCAL" {
            let slot = to_int(operand)
            let cur_frame = vm_frames[len(vm_frames) - 1]
            let val = vm_peek()
            vm_stack[cur_frame.base_slot + slot] = val
            vm_pop()
        }

        // ── Global variable access ──────────────────────

        if op == "GET_GLOBAL" {
            let val = vm_get_global(operand)
            vm_push(val)
        }

        if op == "SET_GLOBAL" {
            let val = vm_pop()
            vm_set_global(operand, val)
        }

        // ── Control flow ────────────────────────────────

        if op == "JUMP" {
            let target = to_int(operand)
            let cur = vm_frames[len(vm_frames) - 1]
            vm_frames[len(vm_frames) - 1] = CallFrame {
                fn_name: cur.fn_name,
                code: cur.code,
                ip: target,
                base_slot: cur.base_slot,
                local_count: cur.local_count
            }
        }

        if op == "JUMP_IF_FALSE" {
            let cond = vm_pop()
            if !vm_val_is_truthy(cond) {
                let target = to_int(operand)
                let cur = vm_frames[len(vm_frames) - 1]
                vm_frames[len(vm_frames) - 1] = CallFrame {
                    fn_name: cur.fn_name,
                    code: cur.code,
                    ip: target,
                    base_slot: cur.base_slot,
                    local_count: cur.local_count
                }
            }
        }

        // ── I/O ─────────────────────────────────────────

        if op == "PRINT" {
            let argc = to_int(operand)
            let mut parts = []
            let mut k = 0
            while k < argc {
                parts = parts.push(vm_val_to_string(vm_pop()))
                k = k + 1
            }
            // Print in reverse order (args were pushed L-to-R, popped R-to-L)
            let mut out = ""
            let mut m = len(parts) - 1
            while m >= 0 {
                out = out + parts[m]
                m = m - 1
            }
            print(out)
        }

        if op == "PRINTLN" {
            let argc = to_int(operand)
            let mut parts = []
            let mut k = 0
            while k < argc {
                parts = parts.push(vm_val_to_string(vm_pop()))
                k = k + 1
            }
            let mut out = ""
            let mut m = len(parts) - 1
            while m >= 0 {
                if m < len(parts) - 1 { out = out + " " }
                out = out + parts[m]
                m = m - 1
            }
            println(out)
        }

        // ── Function calls ──────────────────────────────

        if op == "CALL" {
            // operand = "fname:argc"
            let mut ci = len(operand) - 1
            while ci >= 0 {
                if operand[ci..(ci + 1)] == ":" {
                    let fname = operand[0..ci]
                    let argc = to_int(operand[(ci + 1)..len(operand)])
                    let func = vm_find_fn(fname)
                    if func == "" {
                        vm_error = "undefined function: " + fname
                        return
                    }
                    // Collect arguments from stack
                    let mut args = []
                    let mut a = 0
                    while a < argc {
                        args = args.push(vm_pop())
                        a = a + 1
                    }
                    // Push new call frame
                    let new_base = len(vm_stack)
                    // Reserve local slots
                    let mut s = 0
                    while s < func.local_count {
                        vm_push(val_void())
                        s = s + 1
                    }
                    // Set parameters (in reverse, since popped R-to-L)
                    let mut p = 0
                    while p < argc && p < func.arity {
                        vm_stack[new_base + p] = args[argc - 1 - p]
                        p = p + 1
                    }
                    vm_frames = vm_frames.push(CallFrame {
                        fn_name: fname,
                        code: func.code,
                        ip: 0,
                        base_slot: new_base,
                        local_count: func.local_count
                    })
                    ci = -1
                }
                ci = ci - 1
            }
        }

        if op == "RETURN" {
            let ret_val = vm_pop()
            let cur_frame = vm_frames[len(vm_frames) - 1]
            // Pop frame
            let mut new_frames = []
            let mut fi = 0
            while fi < len(vm_frames) - 1 {
                new_frames = new_frames.push(vm_frames[fi])
                fi = fi + 1
            }
            vm_frames = new_frames
            // Pop locals from stack back to base_slot
            while len(vm_stack) > cur_frame.base_slot {
                vm_pop()
            }
            // Push return value
            vm_push(ret_val)
            if len(vm_frames) == 0 {
                vm_halted = true
                return
            }
        }

        // ── Assertions ──────────────────────────────────

        if op == "ASSERT" {
            let val = vm_pop()
            if !vm_val_is_truthy(val) {
                vm_error = "assertion failed"
                return
            }
        }

        // ── Stubs for remaining opcodes (TODO) ──────────

        if op == "INDEX" {
            let idx = vm_pop()
            let obj = vm_pop()
            if obj.tag == "array" {
                let items = vm_get_array(obj)
                if idx.tag == "int" && idx.int_val >= 0 && idx.int_val < len(items) {
                    vm_push(items[idx.int_val])
                } else {
                    vm_error = "array index out of bounds"
                    return
                }
            } else {
                if obj.tag == "str" && idx.tag == "int" {
                    let s = obj.str_val
                    if idx.int_val >= 0 && idx.int_val < len(s) {
                        vm_push(val_str(s[idx.int_val]))
                    } else {
                        vm_error = "string index out of bounds"
                        return
                    }
                } else {
                    vm_push(val_void())
                }
            }
        }

        if op == "INDEX_ASSIGN" {
            let idx = vm_pop()
            let obj = vm_pop()
            let val = vm_pop()
            if obj.tag == "array" && idx.tag == "int" {
                let items = vm_get_array(obj)
                let mut new_items = []
                let mut q = 0
                while q < len(items) {
                    if q == idx.int_val {
                        new_items = new_items.push(val)
                    } else {
                        new_items = new_items.push(items[q])
                    }
                    q = q + 1
                }
                vm_set_array(obj, new_items)
            }
        }

        if op == "GET_FIELD" {
            let obj = vm_pop()
            if obj.tag == "struct" {
                let fields = vm_get_struct_fields(obj)
                let mut q = 0
                let mut found = false
                while q < len(fields) {
                    if fields[q][0] == operand {
                        vm_push(fields[q][1])
                        found = true
                        q = len(fields)
                    }
                    q = q + 1
                }
                if !found { vm_push(val_void()) }
            } else {
                vm_push(val_void())
            }
        }

        if op == "SET_FIELD" {
            let obj = vm_pop()
            let val = vm_pop()
            if obj.tag == "struct" {
                let fields = vm_get_struct_fields(obj)
                let mut new_fields = []
                let mut q = 0
                let mut found = false
                while q < len(fields) {
                    if fields[q][0] == operand {
                        new_fields = new_fields.push([operand, val])
                        found = true
                    } else {
                        new_fields = new_fields.push(fields[q])
                    }
                    q = q + 1
                }
                if !found { new_fields = new_fields.push([operand, val]) }
                vm_set_struct_fields(obj, new_fields)
            }
        }

        if op == "MAKE_ARRAY" {
            let count = to_int(operand)
            let mut items = []
            let mut k = 0
            while k < count {
                items = items.push(val_void())
                k = k + 1
            }
            // Pop in reverse and place into items
            let mut p = count - 1
            while p >= 0 {
                items[p] = vm_pop()
                p = p - 1
            }
            vm_push(vm_val_array(items))
        }

        if op == "MAKE_RANGE" {
            let b = vm_pop()
            let a = vm_pop()
            let mut items = []
            if a.tag == "int" && b.tag == "int" {
                let mut k = a.int_val
                let end = b.int_val
                if operand == "inclusive" {
                    while k <= end {
                        items = items.push(val_int(k))
                        k = k + 1
                    }
                } else {
                    while k < end {
                        items = items.push(val_int(k))
                        k = k + 1
                    }
                }
            }
            vm_push(vm_val_array(items))
        }

        if op == "MAKE_STRUCT" {
            // operand = "Name:count"
            let mut ci = 0
            let mut sname = ""
            let mut count = 0
            while ci < len(operand) {
                if operand[ci..(ci + 1)] == ":" {
                    sname = operand[0..ci]
                    count = to_int(operand[(ci + 1)..len(operand)])
                    ci = len(operand)
                }
                ci = ci + 1
            }
            // Stack has alternating (name_const, value) pairs (count pairs)
            let mut fields = []
            let mut k = 0
            while k < count {
                fields = fields.push(["", val_void()])
                k = k + 1
            }
            let mut p = count - 1
            while p >= 0 {
                let v = vm_pop()
                let name_val = vm_pop()
                fields[p] = [vm_val_to_string(name_val), v]
                p = p - 1
            }
            vm_push(vm_val_struct(sname, fields))
        }

        if op == "BUILTIN" {
            // operand = "name:argc"
            let mut bi = 0
            let mut bname = ""
            let mut bargc = 0
            while bi < len(operand) {
                if operand[bi..(bi + 1)] == ":" {
                    bname = operand[0..bi]
                    bargc = to_int(operand[(bi + 1)..len(operand)])
                    bi = len(operand)
                }
                bi = bi + 1
            }
            // Collect args (popped reverse)
            let mut bargs = []
            let mut bk = 0
            while bk < bargc {
                bargs = bargs.push(val_void())
                bk = bk + 1
            }
            let mut bp = bargc - 1
            while bp >= 0 {
                bargs[bp] = vm_pop()
                bp = bp - 1
            }
            if bname == "len" {
                let v = bargs[0]
                if v.tag == "array" {
                    vm_push(val_int(len(vm_get_array(v))))
                } else {
                    if v.tag == "str" {
                        vm_push(val_int(len(v.str_val)))
                    } else {
                        vm_push(val_int(0))
                    }
                }
            }
            if bname == "to_string" {
                vm_push(val_str(vm_val_to_string(bargs[0])))
            }
            if bname == "type_of" {
                vm_push(val_str(bargs[0].tag))
            }
            if bname == "int" {
                let v = bargs[0]
                if v.tag == "str" { vm_push(val_int(to_int(v.str_val))) }
                if v.tag == "int" { vm_push(v) }
                if v.tag == "float" { vm_push(val_int(to_int(to_string(v.float_val)))) }
            }
            if bname == "float" {
                let v = bargs[0]
                if v.tag == "str" { vm_push(val_float(to_float(v.str_val))) }
                if v.tag == "int" { vm_push(val_float(to_float(v.int_val))) }
                if v.tag == "float" { vm_push(v) }
            }
            if bname == "format" {
                // Simple format: first arg is template; subsequent replace {} sequentially
                let tmpl = bargs[0]
                let mut out = ""
                if tmpl.tag == "str" {
                    let s = tmpl.str_val
                    let mut si = 0
                    let mut argi = 1
                    while si < len(s) {
                        if si + 1 < len(s) && s[si..(si + 1)] == "{" && s[(si + 1)..(si + 2)] == "}" {
                            if argi < bargc {
                                out = out + vm_val_to_string(bargs[argi])
                                argi = argi + 1
                            }
                            si = si + 2
                        } else {
                            out = out + s[si..(si + 1)]
                            si = si + 1
                        }
                    }
                }
                vm_push(val_str(out))
            }
            if bname == "is_alpha" || bname == "is_digit" || bname == "is_alphanumeric" {
                let v = bargs[0]
                let s = vm_val_to_string(v)
                if len(s) == 0 { vm_push(val_bool(false)) }
                if len(s) > 0 {
                    let c = s[0..1]
                    if bname == "is_digit" {
                        vm_push(val_bool(c == "0" || c == "1" || c == "2" || c == "3" || c == "4" || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"))
                    }
                    if bname == "is_alpha" {
                        let lo = c >= "a" && c <= "z"
                        let up = c >= "A" && c <= "Z"
                        vm_push(val_bool(lo || up))
                    }
                    if bname == "is_alphanumeric" {
                        let lo = c >= "a" && c <= "z"
                        let up = c >= "A" && c <= "Z"
                        let dg = c >= "0" && c <= "9"
                        vm_push(val_bool(lo || up || dg))
                    }
                }
            }
            if bname == "read_file" {
                let v = bargs[0]
                if v.tag == "str" {
                    vm_push(val_str(read_file(v.str_val)))
                } else {
                    vm_push(val_str(""))
                }
            }
        }

        if op == "CALL_METHOD" {
            // operand = "method:argc". Stack: [args..., receiver]
            let mut mi = 0
            let mut mname = ""
            let mut margc = 0
            while mi < len(operand) {
                if operand[mi..(mi + 1)] == ":" {
                    mname = operand[0..mi]
                    margc = to_int(operand[(mi + 1)..len(operand)])
                    mi = len(operand)
                }
                mi = mi + 1
            }
            // Compiler emits: c_compile_expr(receiver); args; CALL_METHOD
            // So stack top is last arg, below: args..., receiver
            let mut margs = []
            let mut mk = 0
            while mk < margc {
                margs = margs.push(val_void())
                mk = mk + 1
            }
            let mut mp = margc - 1
            while mp >= 0 {
                margs[mp] = vm_pop()
                mp = mp - 1
            }
            let recv = vm_pop()
            // Common method dispatch
            if mname == "push" && recv.tag == "array" {
                let items = vm_get_array(recv)
                let new_items = items.push(margs[0])
                let new_arr = vm_val_array(new_items)
                vm_push(new_arr)
            }
            if mname == "len" {
                if recv.tag == "array" { vm_push(val_int(len(vm_get_array(recv)))) }
                if recv.tag == "str" { vm_push(val_int(len(recv.str_val))) }
            }
            if mname == "to_string" {
                vm_push(val_str(vm_val_to_string(recv)))
            }
        }

        if op == "CALL_INDIRECT" {
            let argc = to_int(operand)
            // Collect args
            let mut iargs = []
            let mut ik = 0
            while ik < argc {
                iargs = iargs.push(val_void())
                ik = ik + 1
            }
            let mut ip2 = argc - 1
            while ip2 >= 0 {
                iargs[ip2] = vm_pop()
                ip2 = ip2 - 1
            }
            let callee = vm_pop()
            if callee.tag == "closure" {
                let func = vm_find_fn(callee.fn_name)
                if func == "" {
                    vm_error = "undefined closure target: " + callee.fn_name
                    return
                }
                let new_base = len(vm_stack)
                let mut s = 0
                while s < func.local_count {
                    vm_push(val_void())
                    s = s + 1
                }
                let mut p = 0
                while p < argc && p < func.arity {
                    vm_stack[new_base + p] = iargs[p]
                    p = p + 1
                }
                vm_frames = vm_frames.push(CallFrame {
                    fn_name: callee.fn_name,
                    code: func.code,
                    ip: 0,
                    base_slot: new_base,
                    local_count: func.local_count
                })
            } else {
                vm_push(val_void())
            }
        }

        if op == "CLOSURE" {
            // operand = lambda fn name; capture nothing for now
            vm_push(vm_val_closure(operand, []))
        }

        if op == "BREAK" {
            vm_break_flag = true
        }

        if op == "CONTINUE" {
            vm_continue_flag = true
        }

        if op == "THROW" {
            let val = vm_pop()
            if len(vm_catch_stack) > 0 {
                let target = vm_catch_stack[len(vm_catch_stack) - 1]
                let mut cs = []
                let mut ci2 = 0
                while ci2 < len(vm_catch_stack) - 1 {
                    cs = cs.push(vm_catch_stack[ci2])
                    ci2 = ci2 + 1
                }
                vm_catch_stack = cs
                let cur = vm_frames[len(vm_frames) - 1]
                vm_frames[len(vm_frames) - 1] = CallFrame {
                    fn_name: cur.fn_name,
                    code: cur.code,
                    ip: target,
                    base_slot: cur.base_slot,
                    local_count: cur.local_count
                }
                vm_push(val)
            } else {
                vm_error = "uncaught throw: " + vm_val_to_string(val)
                return
            }
        }

        if op == "TRY_BEGIN" {
            vm_catch_stack = vm_catch_stack.push(to_int(operand))
        }

        if op == "TRY_END" {
            if len(vm_catch_stack) > 0 {
                let mut cs = []
                let mut ci2 = 0
                while ci2 < len(vm_catch_stack) - 1 {
                    cs = cs.push(vm_catch_stack[ci2])
                    ci2 = ci2 + 1
                }
                vm_catch_stack = cs
            }
        }

        if op == "SPAWN" {
            // No real concurrency: execute synchronously (best-effort)
            vm_pop()
        }
    }
}

// ══════════════════════════════════════════════════════════
// Self-test: run a simple program through the VM
// ══════════════════════════════════════════════════════════
// Bytecode for: let x = 10; let y = 20; println(x + y)
//   CONST 0        (10)
//   SET_LOCAL 0    (x = 10)
//   CONST 1        (20)
//   SET_LOCAL 1    (y = 20)
//   GET_LOCAL 0
//   GET_LOCAL 1
//   ADD
//   PRINTLN 1

let test_constants = ["10", "20"]
let test_code = [
    Instruction { op: "CONST", operand: "0" },
    Instruction { op: "SET_LOCAL", operand: "0" },
    Instruction { op: "CONST", operand: "1" },
    Instruction { op: "SET_LOCAL", operand: "1" },
    Instruction { op: "GET_LOCAL", operand: "0" },
    Instruction { op: "GET_LOCAL", operand: "1" },
    Instruction { op: "ADD", operand: "" },
    Instruction { op: "PRINTLN", operand: "1" }
]
let test_functions = []

println("=== P3 VM self-test ===")
let ok = vm_run(test_code, test_constants, test_functions)
if ok {
    println("[PASS] VM self-test: 10 + 20 = 30")
} else {
    println("[FAIL] VM self-test error: " + vm_error)
}

// Test 2: arithmetic and assertion
let test2_constants = ["5", "3", "15", "true"]
let test2_code = [
    Instruction { op: "CONST", operand: "0" },
    Instruction { op: "CONST", operand: "1" },
    Instruction { op: "MUL", operand: "" },
    Instruction { op: "SET_LOCAL", operand: "0" },
    Instruction { op: "GET_LOCAL", operand: "0" },
    Instruction { op: "PRINTLN", operand: "1" },
    Instruction { op: "CONST", operand: "3" },
    Instruction { op: "ASSERT", operand: "" }
]

let ok2 = vm_run(test2_code, test2_constants, test_functions)
if ok2 {
    println("[PASS] VM arithmetic: 5 * 3 = 15")
} else {
    println("[FAIL] VM arithmetic error: " + vm_error)
}

// Test 3: string concatenation
let test3_constants = ["hello", " ", "world"]
let test3_code = [
    Instruction { op: "CONST", operand: "0" },
    Instruction { op: "CONST", operand: "1" },
    Instruction { op: "ADD", operand: "" },
    Instruction { op: "CONST", operand: "2" },
    Instruction { op: "ADD", operand: "" },
    Instruction { op: "PRINTLN", operand: "1" }
]

let ok3 = vm_run(test3_code, test3_constants, test_functions)
if ok3 {
    println("[PASS] VM string concat: hello world")
} else {
    println("[FAIL] VM string error: " + vm_error)
}

// Test 4: array construction + INDEX
let test4_constants = ["1", "2", "3", "0"]
let test4_code = [
    Instruction { op: "CONST", operand: "0" },
    Instruction { op: "CONST", operand: "1" },
    Instruction { op: "CONST", operand: "2" },
    Instruction { op: "MAKE_ARRAY", operand: "3" },
    Instruction { op: "CONST", operand: "3" },
    Instruction { op: "INDEX", operand: "" },
    Instruction { op: "PRINTLN", operand: "1" }
]
let ok4 = vm_run(test4_code, test4_constants, test_functions)
if ok4 {
    println("[PASS] VM array INDEX")
} else {
    println("[FAIL] VM array error: " + vm_error)
}

// Test 5: range + len builtin
let test5_constants = ["0", "5"]
let test5_code = [
    Instruction { op: "CONST", operand: "0" },
