#!hexa lax
// ═══════════════════════════════════════════════════════════
//  self/vm.hexa — HEXA bytecode VM written in HEXA
//  Phase 3 (P3) of self-hosting: execute bytecode from compiler.hexa
//  Stack-based VM with locals, call frames, and constant pool.
//
//  Opcodes match those emitted by self/compiler.hexa.
//  This is the scaffold — iteratively expanded to full coverage.
// ═══════════════════════════════════════════════════════════

// ── ROI-22: Numeric opcode IDs (string comparison → int comparison) ──

let OP_CONST          = 0
let OP_VOID           = 1
let OP_POP            = 2
let OP_DUP            = 3
let OP_ADD            = 4
let OP_SUB            = 5
let OP_MUL            = 6
let OP_DIV            = 7
let OP_MOD            = 8
let OP_POW            = 9
let OP_NEG            = 10
let OP_NOT            = 11
let OP_BITNOT         = 12
let OP_EQ             = 13
let OP_NE             = 14
let OP_LT             = 15
let OP_GT             = 16
let OP_LE             = 17
let OP_GE             = 18
let OP_AND            = 19
let OP_OR             = 20
let OP_XOR            = 21
let OP_GET_LOCAL      = 22
let OP_SET_LOCAL      = 23
let OP_GET_GLOBAL     = 24
let OP_SET_GLOBAL     = 25
let OP_JUMP           = 26
let OP_JUMP_IF_FALSE  = 27
let OP_PRINT          = 28
let OP_PRINTLN        = 29
let OP_CALL           = 30
let OP_RETURN         = 31
let OP_ASSERT         = 32
let OP_INDEX          = 33
let OP_INDEX_ASSIGN   = 34
let OP_GET_FIELD      = 35
let OP_SET_FIELD      = 36
let OP_MAKE_ARRAY     = 37
let OP_MAKE_RANGE     = 38
let OP_MAKE_STRUCT    = 39
let OP_BUILTIN        = 40
let OP_CALL_METHOD    = 41
let OP_CALL_INDIRECT  = 42
let OP_CLOSURE        = 43
let OP_BREAK          = 44
let OP_CONTINUE       = 45
let OP_THROW          = 46
let OP_TRY_BEGIN      = 47
let OP_TRY_END        = 48
let OP_SPAWN          = 49
let OP_UNKNOWN        = 99

// ── ROI-22: Numeric Val.tag IDs (string tag → int comparison) ──

let TAG_INT     = 0
let TAG_FLOAT   = 1
let TAG_BOOL    = 2
let TAG_STR     = 3
let TAG_VOID    = 4
let TAG_ARRAY   = 5
let TAG_STRUCT  = 6
let TAG_CLOSURE = 7

// ── ROI-22: String → numeric opcode conversion (called once per instruction) ──

fn opcode_to_id(s) {
    if s == "CONST"          { return OP_CONST }
    if s == "VOID"           { return OP_VOID }
    if s == "POP"            { return OP_POP }
    if s == "DUP"            { return OP_DUP }
    if s == "ADD"            { return OP_ADD }
    if s == "SUB"            { return OP_SUB }
    if s == "MUL"            { return OP_MUL }
    if s == "DIV"            { return OP_DIV }
    if s == "MOD"            { return OP_MOD }
    if s == "POW"            { return OP_POW }
    if s == "NEG"            { return OP_NEG }
    if s == "NOT"            { return OP_NOT }
    if s == "BITNOT"         { return OP_BITNOT }
    if s == "EQ"             { return OP_EQ }
    if s == "NE"             { return OP_NE }
    if s == "LT"             { return OP_LT }
    if s == "GT"             { return OP_GT }
    if s == "LE"             { return OP_LE }
    if s == "GE"             { return OP_GE }
    if s == "AND"            { return OP_AND }
    if s == "OR"             { return OP_OR }
    if s == "XOR"            { return OP_XOR }
    if s == "GET_LOCAL"      { return OP_GET_LOCAL }
    if s == "SET_LOCAL"      { return OP_SET_LOCAL }
    if s == "GET_GLOBAL"     { return OP_GET_GLOBAL }
    if s == "SET_GLOBAL"     { return OP_SET_GLOBAL }
    if s == "JUMP"           { return OP_JUMP }
    if s == "JUMP_IF_FALSE"  { return OP_JUMP_IF_FALSE }
    if s == "PRINT"          { return OP_PRINT }
    if s == "PRINTLN"        { return OP_PRINTLN }
    if s == "CALL"           { return OP_CALL }
    if s == "RETURN"         { return OP_RETURN }
    if s == "ASSERT"         { return OP_ASSERT }
    if s == "INDEX"          { return OP_INDEX }
    if s == "INDEX_ASSIGN"   { return OP_INDEX_ASSIGN }
    if s == "GET_FIELD"      { return OP_GET_FIELD }
    if s == "SET_FIELD"      { return OP_SET_FIELD }
    if s == "MAKE_ARRAY"     { return OP_MAKE_ARRAY }
    if s == "MAKE_RANGE"     { return OP_MAKE_RANGE }
    if s == "MAKE_STRUCT"    { return OP_MAKE_STRUCT }
    if s == "BUILTIN"        { return OP_BUILTIN }
    if s == "CALL_METHOD"    { return OP_CALL_METHOD }
    if s == "CALL_INDIRECT"  { return OP_CALL_INDIRECT }
    if s == "CLOSURE"        { return OP_CLOSURE }
    if s == "BREAK"          { return OP_BREAK }
    if s == "CONTINUE"       { return OP_CONTINUE }
    if s == "THROW"          { return OP_THROW }
    if s == "TRY_BEGIN"      { return OP_TRY_BEGIN }
    if s == "TRY_END"        { return OP_TRY_END }
    if s == "SPAWN"          { return OP_SPAWN }
    return OP_UNKNOWN
}

// ── ROI-22: String → numeric tag conversion ──

fn tag_to_id(s) {
    if s == "int"     { return TAG_INT }
    if s == "float"   { return TAG_FLOAT }
    if s == "bool"    { return TAG_BOOL }
    if s == "str"     { return TAG_STR }
    if s == "void"    { return TAG_VOID }
    if s == "array"   { return TAG_ARRAY }
    if s == "struct"  { return TAG_STRUCT }
    if s == "closure" { return TAG_CLOSURE }
    return TAG_VOID
}

// ── ROI-42: Shared empty-string constant (__E) ──
// Eliminates ~8 per-call "" allocations in every Val constructor.
// Ported from interpreter.hexa __E pattern.
let __E = ""

// ── Shared structs (inlined until module system exists) ──

struct Instruction {
    op: string,
    operand: string,
    op_id: int
}

struct CompiledFn {
    name: string,
    arity: int,
    param_names: string,
    code: string,
    local_count: int
}

// ── Value representation (matches interpreter.hexa Val) ──

struct Val {
    tag: string,
    tag_id: int,
    int_val: int,
    float_val: float,
    bool_val: bool,
    str_val: string,
    char_val: string,
    array_val: string,
    fn_name: string,
    fn_params: string,
    fn_body: string,
    struct_name: string,
    struct_fields: string
}

// ROI-42: Val constructors use __E (shared empty string) — eliminates 8 per-call "" allocs
fn val_int(n) { return Val { tag: "int", tag_id: TAG_INT, int_val: n, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E } }
fn val_float(f) { return Val { tag: "float", tag_id: TAG_FLOAT, int_val: 0, float_val: f, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E } }
fn val_bool(b) { return Val { tag: "bool", tag_id: TAG_BOOL, int_val: 0, float_val: 0.0, bool_val: b, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E } }
fn val_str(s) { return Val { tag: "str", tag_id: TAG_STR, int_val: 0, float_val: 0.0, bool_val: false, str_val: s, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E } }
fn val_void() { return Val { tag: "void", tag_id: TAG_VOID, int_val: 0, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E } }
fn val_array(a) { return Val { tag: "array", tag_id: TAG_ARRAY, int_val: 0, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: a, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E } }

// ── Store-based array (VM uses int_val as index into vm_array_store) ──

fn vm_val_array(items) {
    let idx = len(vm_array_store)
    vm_array_store.push(items)
    return Val { tag: "array", tag_id: TAG_ARRAY, int_val: idx, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

fn vm_get_array(v) {
    return vm_array_store[v.int_val]
}

fn vm_set_array(v, new_items) {
    vm_array_store[v.int_val] = new_items
}

// ── Store-based struct (VM uses int_val as index into vm_struct_store) ──

fn vm_val_struct(name, fields) {
    let idx = len(vm_struct_store)
    vm_struct_store.push(fields)
    return Val { tag: "struct", tag_id: TAG_STRUCT, int_val: idx, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: name, struct_fields: __E }
}

fn vm_get_struct_fields(v) {
    return vm_struct_store[v.int_val]
}

fn vm_set_struct_fields(v, fields) {
    vm_struct_store[v.int_val] = fields
}

// ── Store-based closure ──

fn vm_val_closure(fname, captured) {
    let idx = len(vm_closure_store)
    vm_closure_store.push(captured)
    return Val { tag: "closure", tag_id: TAG_CLOSURE, int_val: idx, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: fname, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

// ── Reference Counting (RC) Memory Management ───────────

// RC object store: parallel arrays
let mut rc_values = []      // the actual heap values
let mut rc_counts = []      // refcount per slot (0 = freed)
let mut rc_alive  = []      // true if slot is live

// ROI-25: free-list stack for O(1) freed-slot reuse
let mut rc_free_list = []   // stack of freed slot indices
let mut rc_free_top  = 0    // index pointer into rc_free_list

// Stats
let mut rc_total_allocs = 0
let mut rc_total_frees  = 0

// Allocate a value with refcount=1, return its handle (index)
// ROI-25: O(1) free-list pop instead of linear scan
fn rc_alloc(value) {
    // Pop from free-list if available
    if rc_free_top > 0 {
        rc_free_top = rc_free_top - 1
        let i = rc_free_list[rc_free_top]
        rc_values[i] = value
        rc_counts[i] = 1
        rc_alive[i] = true
        rc_total_allocs = rc_total_allocs + 1
        return i
    }
    // No free slot — append
    let idx = len(rc_values)
    rc_values.push(value)
    rc_counts.push(1)
    rc_alive.push(true)
    rc_total_allocs = rc_total_allocs + 1
    return idx
}

// Increment refcount
fn rc_retain(h) {
    if h < 0 || h >= len(rc_values) { return }
    if rc_alive[h] == false { return }
    rc_counts[h] = rc_counts[h] + 1
}

// Decrement refcount; free when it reaches 0
// ROI-25: push freed index onto free-list for O(1) reuse
fn rc_release(h) {
    if h < 0 || h >= len(rc_values) { return }
    if rc_alive[h] == false { return }
    rc_counts[h] = rc_counts[h] - 1
    if rc_counts[h] <= 0 {
        rc_alive[h] = false
        rc_values[h] = ""
        rc_counts[h] = 0
        rc_total_frees = rc_total_frees + 1
        // Push freed index onto free-list stack
        if rc_free_top >= len(rc_free_list) {
            rc_free_list.push(h)
        } else {
            rc_free_list[rc_free_top] = h
        }
        rc_free_top = rc_free_top + 1
    }
}

// Get the underlying value by handle
fn rc_deref(h) {
    if h < 0 || h >= len(rc_values) { return "" }
    if rc_alive[h] == false { return "" }
    return rc_values[h]
}

// Get the current refcount for a handle
fn rc_refcount(h) {
    if h < 0 || h >= len(rc_values) { return 0 }
    if rc_alive[h] == false { return 0 }
    return rc_counts[h]
}

// Check if a handle is alive
fn rc_is_alive(h) {
    if h < 0 || h >= len(rc_values) { return false }
    return rc_alive[h]
}

// Return stats: [allocs, frees, live]
fn rc_stats() {
    let live = rc_total_allocs - rc_total_frees
    return [rc_total_allocs, rc_total_frees, live]
}

// Reset the entire RC heap (for testing / between VM runs)
fn rc_reset() {
    rc_values = []
    rc_counts = []
    rc_alive = []
    rc_free_list = []
    rc_free_top = 0
    rc_total_allocs = 0
    rc_total_frees = 0
}

// ── Call frame ───────────────────────────────────────────

struct CallFrame {
    fn_name: string,
    code: string,
    ip: int,
    base_slot: int,
    local_count: int
}

// ── VM state ─────────────────────────────────────────────

let mut vm_stack = []          // operand stack: array of Val
let mut vm_stack_top = 0       // ROI-21: index pointer — push/pop are O(1) index bumps
let mut vm_frames = []         // call frame stack: array of CallFrame
let mut vm_frame_top = 0       // ROI-26: index pointer — push/pop are O(1) index bumps
let mut vm_globals = []        // global variables: [[name, val], ...]
let mut vm_constants = []      // constant pool: array of strings
let mut vm_functions = []      // compiled functions: array of CompiledFn
// ROI-27: 64-bucket hash caches for O(1) avg global/fn lookup
let mut vm_global_cache = []   // 64 buckets; each bucket is [[name, val], ...]
let mut vm_fn_cache = []       // 64 buckets; each bucket is [CompiledFn, ...]
let mut vm_halted = false
let mut vm_error = ""
let mut vm_array_store = []   // external store for arrays of Val
let mut vm_struct_store = []  // external store for struct field maps [[k,v], ...]
let mut vm_closure_store = [] // external store for closure captured locals
let mut vm_catch_stack = []   // stack of catch handler addresses
let mut vm_break_flag = false
let mut vm_continue_flag = false
let mut vm_loop_starts = []   // stack of loop header IP addresses
let mut vm_loop_ends = []     // stack of loop end IP addresses
// ROI-39: parallel ip array — avoids 5-field CallFrame rebuild on every instruction
let mut vm_ips = []            // ip per frame slot (parallel to vm_frames)

// ── ROI-26: Frame stack operations ──────────────────────

fn vm_frame_push(frame) {
    if vm_frame_top >= len(vm_frames) {
        let mut _grow_n = len(vm_frames)
        if _grow_n == 0 { _grow_n = 64 }
        while _grow_n > 0 {
            vm_frames.push(CallFrame { fn_name: __E, code: __E, ip: 0, base_slot: 0, local_count: 0 })
            // ROI-39: grow parallel ip array
            vm_ips.push(0)
            _grow_n = _grow_n - 1
        }
    }
    vm_frames[vm_frame_top] = frame
    // ROI-39: store ip in parallel array for O(1) mutation
    vm_ips[vm_frame_top] = frame.ip
    vm_frame_top = vm_frame_top + 1
}

fn vm_frame_pop() {
    vm_frame_top = vm_frame_top - 1
}

// ── Stack operations ─────────────────────────────────────

// ROI-21: O(1) pre-alloc buffer push — no array copy on hot path
fn vm_push(val) {
    if vm_stack_top >= len(vm_stack) {
        // Geometric grow (rare after init pre-alloc)
        let mut _grow_n = len(vm_stack)
        if _grow_n == 0 { _grow_n = 256 }
        while _grow_n > 0 {
            vm_stack.push(val_void())
            _grow_n = _grow_n - 1
        }
    }
    vm_stack[vm_stack_top] = val
    vm_stack_top = vm_stack_top + 1
}

// ROI-21: O(1) index decrement — no array rebuild
fn vm_pop() {
    vm_stack_top = vm_stack_top - 1
    return vm_stack[vm_stack_top]
}

fn vm_peek() {
    return vm_stack[vm_stack_top - 1]
}

fn vm_peek_at(offset) {
    return vm_stack[vm_stack_top - 1 - offset]
}

// ── ROI-27: 64-bucket hash helpers ──────────────────────

fn vm_hash64(key) {
    let mut h = 0
    let mut ci = 0
    let n = len(key)
    while ci < n {
        h = (h * 31 + char_code(key, ci)) % 64
        ci = ci + 1
    }
    let mut b = h
    while b < 0 { b = b + 64 }
    return b % 64
}

fn vm_init_caches() {
    let mut gc = []
    let mut fc = []
    let mut i = 0
    while i < 64 {
        gc.push([])
        fc.push([])
        i = i + 1
    }
    vm_global_cache = gc
    vm_fn_cache = fc
}

// ── Global variable helpers (ROI-27: hash-backed) ───────

fn vm_get_global(name) {
    let b = vm_hash64(name)
    let bucket = vm_global_cache[b]
    let mut i = len(bucket) - 1
    while i >= 0 {
        if bucket[i][0] == name {
            return bucket[i][1]
        }
        i = i - 1
    }
    vm_error = "undefined global: " + name
    return val_void()
}

fn vm_set_global(name, val) {
    let b = vm_hash64(name)
    let bucket = vm_global_cache[b]
    let mut i = 0
    while i < len(bucket) {
        if bucket[i][0] == name {
            bucket[i] = [name, val]
            vm_global_cache[b] = bucket
            return
        }
        i = i + 1
    }
    vm_global_cache[b] = bucket.push([name, val])
}

// ── Function registry lookup (ROI-27: hash-backed) ──────

fn vm_find_fn(name) {
    let b = vm_hash64(name)
    let bucket = vm_fn_cache[b]
    let mut i = 0
    while i < len(bucket) {
        if bucket[i].name == name {
            return bucket[i]
        }
        i = i + 1
    }
    return ""
}

fn vm_build_fn_cache() {
    let mut i = 0
    while i < len(vm_functions) {
        let f = vm_functions[i]
        let b = vm_hash64(f.name)
        vm_fn_cache[b] = vm_fn_cache[b].push(f)
        i = i + 1
    }
}

// ── Local variable access (frame-relative) ───────────────

fn vm_get_local(frame, slot) {
    return vm_stack[frame.base_slot + slot]
}

fn vm_set_local(frame, slot, val) {
    vm_stack[frame.base_slot + slot] = val
}

// ── Constant pool value parsing ──────────────────────────
// Constants are stored as strings in the pool; we parse into Val on load.

fn vm_parse_const(raw) {
    // Try bool
    if raw == "true" { return val_bool(true) }
    if raw == "false" { return val_bool(false) }
    // Try int (simple digit check)
    if len(raw) > 0 {
        let first = raw[0]
        if is_digit(first) || first == "-" {
            // Check for float (contains '.')
            if contains(raw, ".") {
                return val_float(to_float(raw))
            }
            return val_int(to_int(raw))
        }
    }
    // Default: treat as string
    return val_str(raw)
}

// ── Val arithmetic / comparison helpers ──────────────────

fn vm_val_to_string(v) {
    if v.tag_id == TAG_INT { return to_string(v.int_val) }
    if v.tag_id == TAG_FLOAT { return to_string(v.float_val) }
    if v.tag_id == TAG_BOOL { return to_string(v.bool_val) }
    if v.tag_id == TAG_STR { return v.str_val }
    if v.tag_id == TAG_VOID { return "void" }
    if v.tag_id == TAG_ARRAY { return "<array>" }
    return "<val>"
}

fn vm_val_is_truthy(v) {
    if v.tag_id == TAG_BOOL { return v.bool_val }
    if v.tag_id == TAG_INT { return v.int_val != 0 }
    if v.tag_id == TAG_STR { return len(v.str_val) > 0 }
    if v.tag_id == TAG_VOID { return false }
    return true
}

// ══════════════════════════════════════════════════════════
// Main execution loop
// ══════════════════════════════════════════════════════════

fn vm_run(code, constants, functions) {
    // Initialize VM state
    vm_stack = []
    vm_stack_top = 0  // ROI-21
    vm_frames = []
    vm_frame_top = 0  // ROI-26
    vm_globals = []
    vm_constants = constants
    vm_functions = functions
    vm_halted = false
    vm_error = ""
    vm_array_store = []
    vm_struct_store = []
    vm_closure_store = []
    vm_catch_stack = []
    vm_break_flag = false
    vm_continue_flag = false
    vm_ips = []  // ROI-39: reset parallel ip array

    // ROI-41: pre-convert opcode strings → numeric IDs (once per instruction, not per dispatch)
    let mut _pi = 0
    while _pi < len(code) {
        let _ins = code[_pi]
        code[_pi] = Instruction { op: _ins.op, operand: _ins.operand, op_id: opcode_to_id(_ins.op) }
        _pi = _pi + 1
    }
    // Pre-convert function code arrays too
    let mut _fi = 0
    while _fi < len(functions) {
        let _fn = functions[_fi]
        let _fc = _fn.code
        let mut _fj = 0
        while _fj < len(_fc) {
            let _fins = _fc[_fj]
            _fc[_fj] = Instruction { op: _fins.op, operand: _fins.operand, op_id: opcode_to_id(_fins.op) }
            _fj = _fj + 1
        }
        _fi = _fi + 1
    }

    // ROI-27: init hash caches + build fn cache
    vm_init_caches()
    vm_build_fn_cache()

    // Top-level frame — ROI-26: use vm_frame_push
    let top_frame = CallFrame {
        fn_name: "<main>",
        code: code,
        ip: 0,
        base_slot: 0,
        local_count: 256
    }
    vm_frame_push(top_frame)

    // Reserve local slots on stack
    let mut i = 0
    while i < 256 {
        vm_push(val_void())
        i = i + 1
    }

    vm_dispatch()

    return vm_error == ""
}

// ── Alternate frame accessors (flat-array VM path) ──────

fn vm_get_ip() {
    return vm_frame_ips[vm_frame_count - 1]
}

fn vm_set_ip(new_ip) {
    vm_frame_ips[vm_frame_count - 1] = new_ip
}

fn vm_get_code() {
    return vm_frame_codes[vm_frame_count - 1]
}

fn vm_get_local(slot) {
    let base = vm_frame_bases[vm_frame_count - 1]
    return vm_locals[base + slot]
}

fn vm_set_local(slot, val) {
    let base = vm_frame_bases[vm_frame_count - 1]
    vm_locals[base + slot] = val
}

// ── Builtin dispatch ─────────────────────────────────────

fn vm_builtin(spec) {
    let parts = spec.split(":")
    let name = parts[0]
    let argc = to_int(parts[1])

    if name == "len" {
        let v = vm_pop()
        vm_push(len(v))
        return
    }
    if name == "to_string" {
        let v = vm_pop()
        vm_push(to_string(v))
        return
    }
    if name == "int" {
        let v = vm_pop()
        vm_push(to_int(v))
        return
    }
    if name == "float" {
        let v = vm_pop()
        vm_push(to_float(v))
        return
    }
    if name == "type_of" {
        let v = vm_pop()
        vm_push(type_of(v))
        return
    }
    if name == "format" {
        let mut args = []
        let mut i = 0
        while i < argc {
            args.push(vm_pop())
            i = i + 1
        }
        let mut rev = []
        let mut j = len(args) - 1
        while j >= 0 {
            rev.push(args[j])
            j = j - 1
        }
        let mut buf = []
        let mut k = 0
        while k < len(rev) {
            if k > 0 { buf.push(" ") }
            buf.push(vm_value_to_string(rev[k]))
            k = k + 1
        }
        vm_push(buf.join(""))
        return
    }
    if name == "abs" {
        let v = vm_pop()
        if v < 0 { vm_push(0 - v) } else { vm_push(v) }
        return
    }
    if name == "min" {
        let b = vm_pop()
        let a = vm_pop()
        if a < b { vm_push(a) } else { vm_push(b) }
        return
    }
    if name == "max" {
        let b = vm_pop()
        let a = vm_pop()
        if a > b { vm_push(a) } else { vm_push(b) }
        return
    }
    if name == "floor" {
        let v = vm_pop()
        vm_push(to_int(v))
        return
    }
    if name == "ceil" {
        let v = vm_pop()
        let i = to_int(v)
        let f = to_float(v)
        if f > to_float(i) { vm_push(i + 1) } else { vm_push(i) }
        return
    }
    if name == "round" {
        let v = vm_pop()
        vm_push(to_int(to_float(v) + 0.5))
        return
    }
    if name == "sqrt" {
        let v = vm_pop()
        vm_push(sqrt(to_float(v)))
        return
    }
    if name == "pow" {
        let b = vm_pop()
        let a = vm_pop()
        vm_push(pow(to_float(a), to_float(b)))
        return
    }
    if name == "log" || name == "ln" {
        let v = vm_pop()
        vm_push(ln(to_float(v)))
        return
    }
    if name == "sin" {
        let v = vm_pop()
        vm_push(sin(to_float(v)))
        return
    }
    if name == "cos" {
        let v = vm_pop()
        vm_push(cos(to_float(v)))
        return
    }
    if name == "tan" {
        let v = vm_pop()
        vm_push(tan(to_float(v)))
        return
    }
    if name == "exp" {
        let v = vm_pop()
        vm_push(exp(to_float(v)))
        return
    }
    if name == "clock" {
        vm_push(clock())
        return
    }
    if name == "is_alpha" {
        let v = vm_pop()
        vm_push(is_alpha(v))
        return
    }
    if name == "is_digit" {
        let v = vm_pop()
        vm_push(is_digit(v))
        return
    }
    if name == "is_alphanumeric" {
        let v = vm_pop()
        vm_push(is_alphanumeric(v))
        return
    }
    if name == "read_file" {
        let v = vm_pop()
        vm_push(read_file(v))
        return
    }
    // Unknown builtin
    vm_push("")
}

fn vm_dispatch() {
    while !vm_halted && vm_error == "" && vm_frame_top > 0 {
        let fidx = vm_frame_top - 1
        let frame = vm_frames[fidx]
        let code = frame.code
        // ROI-39: read ip from parallel array (avoids stale frame.ip after jumps)
        let cur_ip = vm_ips[fidx]

        if cur_ip >= len(code) {
            // End of code for this frame
            if vm_frame_top <= 1 {
                vm_halted = true
                return
            }
            // Implicit void return — ROI-26: O(1) frame pop
            vm_frame_pop()
            vm_push(val_void())
            return vm_dispatch()
        }

        let ins = code[cur_ip]
        // ROI-41: use pre-converted numeric op_id (no per-instruction string comparison)
        let op = ins.op_id
        let operand = ins.operand

        // ROI-39: advance IP — O(1) int mutation instead of 5-field CallFrame rebuild
        vm_ips[fidx] = cur_ip + 1

        // ── Dispatch (ROI-22+40: numeric IDs + else-if chain) ──────

        if op == OP_CONST {
            let idx = to_int(operand)
            let val = vm_parse_const(vm_constants[idx])
            vm_push(val)
        } else if op == OP_VOID {
            vm_push(val_void())
        } else if op == OP_POP {
            vm_pop()
        } else if op == OP_DUP {
            let top = vm_peek()
            vm_push(top)

        // ── Arithmetic ──────────────────────────────────

        } else if op == OP_ADD {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT {
                vm_push(val_int(a.int_val + b.int_val))
            }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_FLOAT {
                vm_push(val_float(a.float_val + b.float_val))
            }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_INT {
                vm_push(val_float(a.float_val + to_float(b.int_val)))
            }
            if a.tag_id == TAG_INT && b.tag_id == TAG_FLOAT {
                vm_push(val_float(to_float(a.int_val) + b.float_val))
            }
            if a.tag_id == TAG_STR && b.tag_id == TAG_STR {
                vm_push(val_str(a.str_val + b.str_val))
            }
            if a.tag_id == TAG_STR && b.tag_id != TAG_STR {
                vm_push(val_str(a.str_val + vm_val_to_string(b)))
            }
        } else if op == OP_SUB {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT {
                vm_push(val_int(a.int_val - b.int_val))
            }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_FLOAT {
                vm_push(val_float(a.float_val - b.float_val))
            }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_INT {
                vm_push(val_float(a.float_val - to_float(b.int_val)))
            }
            if a.tag_id == TAG_INT && b.tag_id == TAG_FLOAT {
                vm_push(val_float(to_float(a.int_val) - b.float_val))
            }
        } else if op == OP_MUL {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT {
                vm_push(val_int(a.int_val * b.int_val))
            }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_FLOAT {
                vm_push(val_float(a.float_val * b.float_val))
            }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_INT {
                vm_push(val_float(a.float_val * to_float(b.int_val)))
            }
            if a.tag_id == TAG_INT && b.tag_id == TAG_FLOAT {
                vm_push(val_float(to_float(a.int_val) * b.float_val))
            }
        } else if op == OP_DIV {
            let b = vm_pop()
            let a = vm_pop()
            if b.tag_id == TAG_INT && b.int_val == 0 {
                vm_error = "division by zero"
                return
            }
            if b.tag_id == TAG_FLOAT && b.float_val == 0.0 {
                vm_error = "division by zero"
                return
            }
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT {
                vm_push(val_int(a.int_val / b.int_val))
            }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_FLOAT {
                vm_push(val_float(a.float_val / b.float_val))
            }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_INT {
                vm_push(val_float(a.float_val / to_float(b.int_val)))
            }
            if a.tag_id == TAG_INT && b.tag_id == TAG_FLOAT {
                vm_push(val_float(to_float(a.int_val) / b.float_val))
            }
        } else if op == OP_MOD {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT {
                vm_push(val_int(a.int_val % b.int_val))
            }
        } else if op == OP_POW {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT {
                let mut acc = 1
                let mut e = b.int_val
                while e > 0 {
                    acc = acc * a.int_val
                    e = e - 1
                }
                vm_push(val_int(acc))
            }
            if a.tag_id == TAG_FLOAT {
                let base = a.float_val
                let mut accf = 1.0
                let mut ef = 0
                if b.tag_id == TAG_INT { ef = b.int_val }
                if b.tag_id == TAG_FLOAT { ef = to_int(to_string(b.float_val)) }
                while ef > 0 {
                    accf = accf * base
                    ef = ef - 1
                }
                vm_push(val_float(accf))
            }
        } else if op == OP_NEG {
            let a = vm_pop()
            if a.tag_id == TAG_INT { vm_push(val_int(0 - a.int_val)) }
            if a.tag_id == TAG_FLOAT { vm_push(val_float(0.0 - a.float_val)) }
        } else if op == OP_NOT {
            let a = vm_pop()
            vm_push(val_bool(!vm_val_is_truthy(a)))
        } else if op == OP_BITNOT {
            let a = vm_pop()
            if a.tag_id == TAG_INT {
                vm_push(val_int(0 - a.int_val - 1))
            } else {
                vm_push(val_int(0))
            }

        // ── Comparison ──────────────────────────────────

        } else if op == OP_EQ {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT { vm_push(val_bool(a.int_val == b.int_val)) }
            if a.tag_id == TAG_STR && b.tag_id == TAG_STR { vm_push(val_bool(a.str_val == b.str_val)) }
            if a.tag_id == TAG_BOOL && b.tag_id == TAG_BOOL { vm_push(val_bool(a.bool_val == b.bool_val)) }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_FLOAT { vm_push(val_bool(a.float_val == b.float_val)) }
        } else if op == OP_NE {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT { vm_push(val_bool(a.int_val != b.int_val)) }
            if a.tag_id == TAG_STR && b.tag_id == TAG_STR { vm_push(val_bool(a.str_val != b.str_val)) }
            if a.tag_id == TAG_BOOL && b.tag_id == TAG_BOOL { vm_push(val_bool(a.bool_val != b.bool_val)) }
        } else if op == OP_LT {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT { vm_push(val_bool(a.int_val < b.int_val)) }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_FLOAT { vm_push(val_bool(a.float_val < b.float_val)) }
        } else if op == OP_GT {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT { vm_push(val_bool(a.int_val > b.int_val)) }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_FLOAT { vm_push(val_bool(a.float_val > b.float_val)) }
        } else if op == OP_LE {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT { vm_push(val_bool(a.int_val <= b.int_val)) }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_FLOAT { vm_push(val_bool(a.float_val <= b.float_val)) }
        } else if op == OP_GE {
            let b = vm_pop()
            let a = vm_pop()
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT { vm_push(val_bool(a.int_val >= b.int_val)) }
            if a.tag_id == TAG_FLOAT && b.tag_id == TAG_FLOAT { vm_push(val_bool(a.float_val >= b.float_val)) }

        // ── Logical ─────────────────────────────────────

        } else if op == OP_AND {
            let b = vm_pop()
            let a = vm_pop()
            vm_push(val_bool(vm_val_is_truthy(a) && vm_val_is_truthy(b)))
        } else if op == OP_OR {
            let b = vm_pop()
            let a = vm_pop()
            vm_push(val_bool(vm_val_is_truthy(a) || vm_val_is_truthy(b)))
        } else if op == OP_XOR {
            let b = vm_pop()
            let a = vm_pop()
            let at = vm_val_is_truthy(a)
            let bt = vm_val_is_truthy(b)
            vm_push(val_bool((at || bt) && !(at && bt)))

        // ── Local variable access ───────────────────────

        } else if op == OP_GET_LOCAL {
            let slot = to_int(operand)
            let cur_frame = vm_frames[vm_frame_top - 1]
            let val = vm_stack[cur_frame.base_slot + slot]
            vm_push(val)
        } else if op == OP_SET_LOCAL {
            let slot = to_int(operand)
            let cur_frame = vm_frames[vm_frame_top - 1]
            let val = vm_peek()
            vm_stack[cur_frame.base_slot + slot] = val
            vm_pop()

        // ── Global variable access ──────────────────────

        } else if op == OP_GET_GLOBAL {
            let val = vm_get_global(operand)
            vm_push(val)
        } else if op == OP_SET_GLOBAL {
            let val = vm_pop()
            vm_set_global(operand, val)

        // ── Control flow ────────────────────────────────

        // ROI-39: JUMP/JUMP_IF_FALSE — O(1) ip mutation instead of CallFrame rebuild
        } else if op == OP_JUMP {
            vm_ips[vm_frame_top - 1] = to_int(operand)
        } else if op == OP_JUMP_IF_FALSE {
            let cond = vm_pop()
            if !vm_val_is_truthy(cond) {
                vm_ips[vm_frame_top - 1] = to_int(operand)
            }

        // ── I/O ─────────────────────────────────────────

        } else if op == OP_PRINT {
            let argc = to_int(operand)
            let mut parts = []
            let mut k = 0
            while k < argc {
                parts.push(vm_val_to_string(vm_pop()))
                k = k + 1
            }
            // Print in reverse order (args were pushed L-to-R, popped R-to-L)
            let mut buf = []
            let mut m = len(parts) - 1
            while m >= 0 {
                buf.push(parts[m])
                m = m - 1
            }
            print(buf.join(""))
        } else if op == OP_PRINTLN {
            let argc = to_int(operand)
            let mut parts = []
            let mut k = 0
            while k < argc {
                parts.push(vm_val_to_string(vm_pop()))
                k = k + 1
            }
            let mut buf = []
            let mut m = len(parts) - 1
            while m >= 0 {
                if m < len(parts) - 1 { buf.push(" ") }
                buf.push(parts[m])
                m = m - 1
            }
            println(buf.join(""))

        // ── Function calls ──────────────────────────────

        } else if op == OP_CALL {
            // operand = "fname:argc"
            let mut ci = len(operand) - 1
            while ci >= 0 {
                if operand[ci..(ci + 1)] == ":" {
                    let fname = operand[0..ci]
                    let argc = to_int(operand[(ci + 1)..len(operand)])
                    let func = vm_find_fn(fname)
                    if func == "" {
                        vm_error = "undefined function: " + fname
                        return
                    }
                    // Collect arguments from stack
                    let mut args = []
                    let mut a = 0
                    while a < argc {
                        args.push(vm_pop())
                        a = a + 1
                    }
                    // Push new call frame
                    let new_base = vm_stack_top  // ROI-21
                    // Reserve local slots
                    let mut s = 0
                    while s < func.local_count {
                        vm_push(val_void())
                        s = s + 1
                    }
                    // Set parameters (in reverse, since popped R-to-L)
                    let mut p = 0
                    while p < argc && p < func.arity {
                        vm_stack[new_base + p] = args[argc - 1 - p]
                        p = p + 1
                    }
                    // ROI-26: O(1) frame push
                    vm_frame_push(CallFrame {
                        fn_name: fname,
                        code: func.code,
                        ip: 0,
                        base_slot: new_base,
                        local_count: func.local_count
                    })
                    ci = -1
                }
                ci = ci - 1
            }
        } else if op == OP_RETURN {
            let ret_val = vm_pop()
            let cur_frame = vm_frames[vm_frame_top - 1]
            // ROI-26: O(1) frame pop — index decrement
            vm_frame_pop()
            // ROI-21: O(1) bulk pop — reset stack top to frame base
            vm_stack_top = cur_frame.base_slot
            // Push return value
            vm_push(ret_val)
            if vm_frame_top == 0 {
                vm_halted = true
                return
            }

        // ── Assertions ──────────────────────────────────

        } else if op == OP_ASSERT {
            let val = vm_pop()
            if !vm_val_is_truthy(val) {
                vm_error = "assertion failed"
                return
            }

        // ── Remaining opcodes (INDEX, ...) ──────────────

        } else if op == OP_INDEX {
            let idx = vm_pop()
            let obj = vm_pop()
            if obj.tag_id == TAG_ARRAY {
                let items = vm_get_array(obj)
                if idx.tag_id == TAG_INT && idx.int_val >= 0 && idx.int_val < len(items) {
                    vm_push(items[idx.int_val])
                } else {
                    vm_error = "array index out of bounds"
                    return
                }
            } else {
                if obj.tag_id == TAG_STR && idx.tag_id == TAG_INT {
                    let s = obj.str_val
                    if idx.int_val >= 0 && idx.int_val < len(s) {
                        vm_push(val_str(s[idx.int_val]))
                    } else {
                        vm_error = "string index out of bounds"
                        return
                    }
                } else {
                    vm_push(val_void())
                }
            }

        // ROI-29: O(1) in-place mutation instead of O(N) copy loop
        } else if op == OP_INDEX_ASSIGN {
            let idx = vm_pop()
            let obj = vm_pop()
            let val = vm_pop()
            if obj.tag_id == TAG_ARRAY && idx.tag_id == TAG_INT {
                let items = vm_get_array(obj)
                items[idx.int_val] = val
                vm_set_array(obj, items)
            }
        } else if op == OP_GET_FIELD {
            let obj = vm_pop()
            if obj.tag_id == TAG_STRUCT {
                let fields = vm_get_struct_fields(obj)
                let mut q = 0
                let mut found = false
                while q < len(fields) {
                    if fields[q][0] == operand {
                        vm_push(fields[q][1])
                        found = true
                        q = len(fields)
                    }
                    q = q + 1
                }
                if !found { vm_push(val_void()) }
            } else {
                vm_push(val_void())
            }

        // ROI-29: O(1) in-place field mutation instead of O(N) copy loop
        } else if op == OP_SET_FIELD {
            let obj = vm_pop()
            let val = vm_pop()
            if obj.tag_id == TAG_STRUCT {
                let fields = vm_get_struct_fields(obj)
                let mut q = 0
                let mut found = false
                while q < len(fields) {
                    if fields[q][0] == operand {
                        fields[q] = [operand, val]
                        found = true
                        q = len(fields)
                    }
                    q = q + 1
                }
                if !found {
                    vm_set_struct_fields(obj, fields.push([operand, val]))
                } else {
                    vm_set_struct_fields(obj, fields)
                }
            }
        } else if op == OP_MAKE_ARRAY {
            let count = to_int(operand)
            let mut items = []
            let mut k = 0
            while k < count {
                items.push(val_void())
                k = k + 1
            }
            // Pop in reverse and place into items
            let mut p = count - 1
            while p >= 0 {
                items[p] = vm_pop()
                p = p - 1
            }
            vm_push(vm_val_array(items))
        } else if op == OP_MAKE_RANGE {
            let b = vm_pop()
            let a = vm_pop()
            let mut items = []
            if a.tag_id == TAG_INT && b.tag_id == TAG_INT {
                let mut k = a.int_val
                let end = b.int_val
                if operand == "inclusive" {
                    while k <= end {
                        items.push(val_int(k))
                        k = k + 1
                    }
                } else {
                    while k < end {
                        items.push(val_int(k))
                        k = k + 1
                    }
                }
            }
            vm_push(vm_val_array(items))
        } else if op == OP_MAKE_STRUCT {
            // operand = "Name:count"
            let mut ci = 0
            let mut sname = ""
            let mut count = 0
            while ci < len(operand) {
                if operand[ci..(ci + 1)] == ":" {
                    sname = operand[0..ci]
                    count = to_int(operand[(ci + 1)..len(operand)])
                    ci = len(operand)
                }
                ci = ci + 1
            }
            // Stack has alternating (name_const, value) pairs (count pairs)
            let mut fields = []
            let mut k = 0
            while k < count {
                fields.push(["", val_void()])
                k = k + 1
            }
            let mut p = count - 1
            while p >= 0 {
                let v = vm_pop()
                let name_val = vm_pop()
                fields[p] = [vm_val_to_string(name_val), v]
                p = p - 1
            }
            vm_push(vm_val_struct(sname, fields))
        } else if op == OP_BUILTIN {
            // operand = "name:argc"
            let mut bi = 0
            let mut bname = ""
            let mut bargc = 0
            while bi < len(operand) {
                if operand[bi..(bi + 1)] == ":" {
                    bname = operand[0..bi]
                    bargc = to_int(operand[(bi + 1)..len(operand)])
                    bi = len(operand)
                }
                bi = bi + 1
            }
            // Collect args (popped reverse)
            let mut bargs = []
            let mut bk = 0
            while bk < bargc {
                bargs.push(val_void())
                bk = bk + 1
            }
            let mut bp = bargc - 1
            while bp >= 0 {
                bargs[bp] = vm_pop()
                bp = bp - 1
            }
            if bname == "len" {
                let v = bargs[0]
                if v.tag_id == TAG_ARRAY {
                    vm_push(val_int(len(vm_get_array(v))))
                } else {
                    if v.tag_id == TAG_STR {
                        vm_push(val_int(len(v.str_val)))
                    } else {
                        vm_push(val_int(0))
                    }
                }
            }
            if bname == "to_string" {
                vm_push(val_str(vm_val_to_string(bargs[0])))
            }
            if bname == "type_of" {
                vm_push(val_str(bargs[0].tag))
            }
            if bname == "int" {
                let v = bargs[0]
                if v.tag_id == TAG_STR { vm_push(val_int(to_int(v.str_val))) }
                if v.tag_id == TAG_INT { vm_push(v) }
                if v.tag_id == TAG_FLOAT { vm_push(val_int(to_int(to_string(v.float_val)))) }
            }
            if bname == "float" {
                let v = bargs[0]
                if v.tag_id == TAG_STR { vm_push(val_float(to_float(v.str_val))) }
                if v.tag_id == TAG_INT { vm_push(val_float(to_float(v.int_val))) }
                if v.tag_id == TAG_FLOAT { vm_push(v) }
            }
            if bname == "format" {
                // Simple format: first arg is template; subsequent replace {} sequentially
                let tmpl = bargs[0]
                let mut buf = []
                if tmpl.tag_id == TAG_STR {
                    let s = tmpl.str_val
                    let mut si = 0
                    let mut argi = 1
                    while si < len(s) {
                        if si + 1 < len(s) && s[si..(si + 1)] == "{" && s[(si + 1)..(si + 2)] == "}" {
                            if argi < bargc {
                                buf.push(vm_val_to_string(bargs[argi]))
                                argi = argi + 1
                            }
                            si = si + 2
                        } else {
                            buf.push(s[si..(si + 1)])
                            si = si + 1
                        }
                    }
                }
                vm_push(val_str(buf.join("")))
            }
            if bname == "is_alpha" || bname == "is_digit" || bname == "is_alphanumeric" {
                let v = bargs[0]
                let s = vm_val_to_string(v)
                if len(s) == 0 { vm_push(val_bool(false)) }
                if len(s) > 0 {
                    let c = s[0..1]
                    if bname == "is_digit" {
                        vm_push(val_bool(c == "0" || c == "1" || c == "2" || c == "3" || c == "4" || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"))
                    }
                    if bname == "is_alpha" {
                        let lo = c >= "a" && c <= "z"
                        let up = c >= "A" && c <= "Z"
                        vm_push(val_bool(lo || up))
                    }
                    if bname == "is_alphanumeric" {
                        let lo = c >= "a" && c <= "z"
                        let up = c >= "A" && c <= "Z"
                        let dg = c >= "0" && c <= "9"
                        vm_push(val_bool(lo || up || dg))
                    }
                }
            }
            if bname == "read_file" {
                let v = bargs[0]
                if v.tag_id == TAG_STR {
                    vm_push(val_str(read_file(v.str_val)))
                } else {
                    vm_push(val_str(""))
                }
            }
            // ── FFI builtins ────────────────────────────────
            // Wire host_ffi_open / host_ffi_sym / host_ffi_call_6 from
            // self/runtime.c so the VM can dispatch @link externs at runtime.
            // The VM runs inside hexa_v2 (native binary) which links runtime.c,
            // so these calls resolve directly to the C implementations.
            // hexa_host_ffi_unwrap in runtime.c handles ValStruct unwrapping
            // automatically, so we pass VM Val values through directly.
            if bname == "cstring" {
                // cstring(str) -> int (pointer to C string)
                let v = bargs[0]
                if v.tag_id == TAG_STR {
                    vm_push(val_int(cstring(v.str_val)))
                } else {
                    vm_push(val_int(0))
                }
            }
            if bname == "from_cstring" {
                // from_cstring(ptr: int) -> str
                let v = bargs[0]
                if v.tag_id == TAG_INT {
                    vm_push(val_str(from_cstring(v.int_val)))
                } else {
                    vm_push(val_str(""))
                }
            }
            if bname == "ffi_open" {
                // ffi_open(lib_name: str) -> int (dlopen handle)
                let lib = ""
                if bargs[0].tag_id == TAG_STR { lib = bargs[0].str_val }
                let h = host_ffi_open(lib)
                vm_push(val_int(h))
            }
            if bname == "ffi_sym" {
                // ffi_sym(handle: int, symbol: str) -> int (fn pointer)
                let hnd = 0
                if bargs[0].tag_id == TAG_INT { hnd = bargs[0].int_val }
                let sym = ""
                if bargs[1].tag_id == TAG_STR { sym = bargs[1].str_val }
                let fp = host_ffi_sym(hnd, sym)
                vm_push(val_int(fp))
            }
            if bname == "ffi_call" {
                // ffi_call(fn_ptr, nargs, float_mask, ret_kind, a0..a5)
                // Maps to host_ffi_call_6 (scalar fanout, up to 6 positional args).
                // Args beyond index 3 are positional FFI arguments (a0..a5).
                // ret_kind: 0=void, 1=int, 2=float, 3=bool, 4=pointer
                let fn_ptr_v = bargs[0]
                let nargs_v = bargs[1]
                let fmask_v = bargs[2]
                let rkind_v = bargs[3]
                // Extract ret_kind as int for result dispatch
                let mut rkind = 1
                if rkind_v.tag_id == TAG_INT { rkind = rkind_v.int_val }
                // Pad missing positional args with 0
                let mut pa0 = val_int(0)
                let mut pa1 = val_int(0)
                let mut pa2 = val_int(0)
                let mut pa3 = val_int(0)
                let mut pa4 = val_int(0)
                let mut pa5 = val_int(0)
                if bargc > 4 { pa0 = bargs[4] }
                if bargc > 5 { pa1 = bargs[5] }
                if bargc > 6 { pa2 = bargs[6] }
                if bargc > 7 { pa3 = bargs[7] }
                if bargc > 8 { pa4 = bargs[8] }
                if bargc > 9 { pa5 = bargs[9] }
                // host_ffi_call_6 returns a ValStruct; runtime.c unwraps each arg
                let result = host_ffi_call_6(fn_ptr_v, nargs_v, fmask_v, rkind_v, pa0, pa1, pa2, pa3, pa4, pa5)
                // Wrap result back into VM Val based on ret_kind
                if rkind == 0 {
                    vm_push(val_void())
                }
                if rkind == 1 || rkind == 4 {
                    vm_push(val_int(result.int_val))
                }
                if rkind == 2 {
                    vm_push(val_float(result.float_val))
                }
                if rkind == 3 {
                    vm_push(val_bool(result.bool_val))
                }
            }
        } else if op == OP_CALL_METHOD {
            // operand = "method:argc". Stack: [args..., receiver]
            let mut mi = 0
            let mut mname = ""
            let mut margc = 0
            while mi < len(operand) {
                if operand[mi..(mi + 1)] == ":" {
                    mname = operand[0..mi]
                    margc = to_int(operand[(mi + 1)..len(operand)])
                    mi = len(operand)
                }
                mi = mi + 1
            }
            // Compiler emits: c_compile_expr(receiver); args; CALL_METHOD
            // So stack top is last arg, below: args..., receiver
            let mut margs = []
            let mut mk = 0
            while mk < margc {
                margs.push(val_void())
                mk = mk + 1
            }
            let mut mp = margc - 1
            while mp >= 0 {
                margs[mp] = vm_pop()
                mp = mp - 1
            }
            let recv = vm_pop()
            // Common method dispatch
            // ROI-30: O(1) in-place push — mutate existing store slot, no copy/alloc
            if mname == "push" && recv.tag_id == TAG_ARRAY {
                let items = vm_get_array(recv)
                let new_items = items.push(margs[0])
                vm_set_array(recv, new_items)
                vm_push(recv)
            }
            if mname == "len" {
                if recv.tag_id == TAG_ARRAY { vm_push(val_int(len(vm_get_array(recv)))) }
                if recv.tag_id == TAG_STR { vm_push(val_int(len(recv.str_val))) }
            }
            if mname == "to_string" {
                vm_push(val_str(vm_val_to_string(recv)))
            }
        } else if op == OP_CALL_INDIRECT {
            let argc = to_int(operand)
            // Collect args
            let mut iargs = []
            let mut ik = 0
            while ik < argc {
                iargs.push(val_void())
                ik = ik + 1
            }
            let mut ip2 = argc - 1
            while ip2 >= 0 {
                iargs[ip2] = vm_pop()
                ip2 = ip2 - 1
            }
            let callee = vm_pop()
            if callee.tag_id == TAG_CLOSURE {
                let func = vm_find_fn(callee.fn_name)
                if func == "" {
                    vm_error = "undefined closure target: " + callee.fn_name
                    return
                }
                let new_base = vm_stack_top  // ROI-21
                let mut s = 0
                while s < func.local_count {
                    vm_push(val_void())
                    s = s + 1
                }
                let mut p = 0
                while p < argc && p < func.arity {
                    vm_stack[new_base + p] = iargs[p]
                    p = p + 1
                }
                // ROI-26: O(1) frame push
                vm_frame_push(CallFrame {
                    fn_name: callee.fn_name,
                    code: func.code,
                    ip: 0,
                    base_slot: new_base,
                    local_count: func.local_count
                })
            } else {
                vm_push(val_void())
            }
        } else if op == OP_CLOSURE {
            // operand = lambda fn name; capture nothing for now
            vm_push(vm_val_closure(operand, []))
        } else if op == OP_BREAK {
            vm_break_flag = true

        } else if op == OP_CONTINUE {
            vm_continue_flag = true
        } else if op == OP_THROW {
            let val = vm_pop()
            if len(vm_catch_stack) > 0 {
                let target = vm_catch_stack[len(vm_catch_stack) - 1]
                let mut cs = []
                let mut ci2 = 0
                while ci2 < len(vm_catch_stack) - 1 {
                    cs.push(vm_catch_stack[ci2])
                    ci2 = ci2 + 1
                }
                vm_catch_stack = cs
                // ROI-39: O(1) ip mutation for catch handler
                vm_ips[vm_frame_top - 1] = target
                vm_push(val)
            } else {
                vm_error = "uncaught throw: " + vm_val_to_string(val)
                return
            }
        } else if op == OP_TRY_BEGIN {
            vm_catch_stack.push(to_int(operand))
        } else if op == OP_TRY_END {
            if len(vm_catch_stack) > 0 {
                let mut cs = []
                let mut ci2 = 0
                while ci2 < len(vm_catch_stack) - 1 {
                    cs.push(vm_catch_stack[ci2])
                    ci2 = ci2 + 1
                }
                vm_catch_stack = cs
            }
        } else if op == OP_SPAWN {
            // Cooperative spawn: pop closure from stack and call it
            // immediately (run-to-completion). The result is pushed
            // back onto the stack as a resolved "future" value.
            // When real threads land, this will enqueue to a pool and
            // push a handle; OP_JOIN will block until resolved.
            let spawn_argc = to_int(operand)
            let mut spawn_args = []
            let mut sk = 0
            while sk < spawn_argc {
                spawn_args.push(val_void())
                sk = sk + 1
            }
            let mut sp2 = spawn_argc - 1
            while sp2 >= 0 {
                spawn_args[sp2] = vm_pop()
                sp2 = sp2 - 1
            }
            let spawn_callee = vm_pop()
            if spawn_callee.tag_id == TAG_CLOSURE {
                let spawn_fn = vm_find_fn(spawn_callee.fn_name)
                if spawn_fn == "" {
                    vm_error = "undefined spawn target: " + spawn_callee.fn_name
                    return
                }
                let spawn_base = vm_stack_top
                let mut ss = 0
                while ss < spawn_fn.local_count {
                    vm_push(val_void())
                    ss = ss + 1
                }
                let mut sp3 = 0
                while sp3 < spawn_argc && sp3 < spawn_fn.arity {
                    vm_stack[spawn_base + sp3] = spawn_args[sp3]
                    sp3 = sp3 + 1
                }
                vm_frame_push(CallFrame {
                    fn_name: spawn_callee.fn_name,
                    code: spawn_fn.code,
                    ip: 0,
                    base_slot: spawn_base,
                    local_count: spawn_fn.local_count
                })
            } else {
                // Not a closure — push void as the "result"
                vm_push(val_void())
            }
        } // end ROI-40 else-if dispatch chain
    }
}

// ══════════════════════════════════════════════════════════
// Self-test: run a simple program through the VM
// ══════════════════════════════════════════════════════════
// Bytecode for: let x = 10; let y = 20; println(x + y)
//   CONST 0        (10)
//   SET_LOCAL 0    (x = 10)
//   CONST 1        (20)
//   SET_LOCAL 1    (y = 20)
//   GET_LOCAL 0
//   GET_LOCAL 1
//   ADD
//   PRINTLN 1

let test_constants = ["10", "20"]
let test_code = [
    Instruction { op: "CONST", operand: "0", op_id: 0 },
    Instruction { op: "SET_LOCAL", operand: "0", op_id: 0 },
    Instruction { op: "CONST", operand: "1", op_id: 0 },
    Instruction { op: "SET_LOCAL", operand: "1", op_id: 0 },
    Instruction { op: "GET_LOCAL", operand: "0", op_id: 0 },
    Instruction { op: "GET_LOCAL", operand: "1", op_id: 0 },
    Instruction { op: "ADD", operand: "", op_id: 0 },
    Instruction { op: "PRINTLN", operand: "1", op_id: 0 }
]
let test_functions = []

println("=== P3 VM self-test ===")
let ok = vm_run(test_code, test_constants, test_functions)
if ok {
    println("[PASS] VM self-test: 10 + 20 = 30")
} else {
    println("[FAIL] VM self-test error: " + vm_error)
}

// Test 2: arithmetic and assertion
let test2_constants = ["5", "3", "15", "true"]
let test2_code = [
    Instruction { op: "CONST", operand: "0", op_id: 0 },
    Instruction { op: "CONST", operand: "1", op_id: 0 },
    Instruction { op: "MUL", operand: "", op_id: 0 },
    Instruction { op: "SET_LOCAL", operand: "0", op_id: 0 },
    Instruction { op: "GET_LOCAL", operand: "0", op_id: 0 },
    Instruction { op: "PRINTLN", operand: "1", op_id: 0 },
    Instruction { op: "CONST", operand: "3", op_id: 0 },
    Instruction { op: "ASSERT", operand: "", op_id: 0 }
]

let ok2 = vm_run(test2_code, test2_constants, test_functions)
if ok2 {
    println("[PASS] VM arithmetic: 5 * 3 = 15")
} else {
    println("[FAIL] VM arithmetic error: " + vm_error)
}

// Test 3: string concatenation
let test3_constants = ["hello", " ", "world"]
let test3_code = [
    Instruction { op: "CONST", operand: "0", op_id: 0 },
    Instruction { op: "CONST", operand: "1", op_id: 0 },
    Instruction { op: "ADD", operand: "", op_id: 0 },
    Instruction { op: "CONST", operand: "2", op_id: 0 },
    Instruction { op: "ADD", operand: "", op_id: 0 },
    Instruction { op: "PRINTLN", operand: "1", op_id: 0 }
]

let ok3 = vm_run(test3_code, test3_constants, test_functions)
if ok3 {
    println("[PASS] VM string concat: hello world")
} else {
    println("[FAIL] VM string error: " + vm_error)
}

