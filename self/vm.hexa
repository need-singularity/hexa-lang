// Test 7: function call (CALL)
let test7_constants = ["3", "4"]
let add_fn = CompiledFn {
    name: "add",
    arity: 2,
    param_names: ["a", "b"],
    code: [
        Instruction { op: "GET_LOCAL", operand: "0" },
        Instruction { op: "GET_LOCAL", operand: "1" },
        Instruction { op: "ADD", operand: "" },
        Instruction { op: "RETURN", operand: "" }
    ],
    local_count: 2
}
let test7_functions = [add_fn]
let test7_code = [
    Instruction { op: "CONST", operand: "0" },
    Instruction { op: "CONST", operand: "1" },
    Instruction { op: "CALL", operand: "add:2" },
    Instruction { op: "PRINTLN", operand: "1" }
]
let ok7 = vm_run(test7_code, test7_constants, test7_functions)
if ok7 {
    println("[PASS] VM function CALL: add(3, 4) = 7")
} else {
    println("[FAIL] VM call error: " + vm_error)
}

