// ═══════════════════════════════════════════════════════════════
//  test_stochastic_weight_averaging.hexa — SWA (#271) tests
//
//  Verifies:
//    1. running-mean update: (n-1)*avg + w /n recurrence
//    2. scalar running-mean update
//    3. running mean of a constant stays constant
//    4. cyclic LR monotonic within a cycle
//    5. cyclic LR wraps around (step == cycle returns first-cycle val)
//    6. cyclic LR averaged = mean(alpha1, alpha2)
//    7. sgd step reduces MSE
//    8. swa state init
//    9. swa full training: final state has w/b from SGD
//   10. swa snapshot count correctness
//   11. swa avg equals SGD on first snapshot
//   12. swa bias lies between initial and SGD tail bias
//
//  Run: ./hexa self/test_stochastic_weight_averaging.hexa
// ═══════════════════════════════════════════════════════════════

// -- inlined from self/ml/stochastic_weight_averaging.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════
//  self/ml/stochastic_weight_averaging.hexa — SWA (#271)
//
//  Ref: Izmailov et al. 2018 — "Averaging Weights Leads to Wider
//       Optima and Better Generalization"
//
//  Idea: at the tail of SGD training, snapshot the current weights
//        every k steps and accumulate a running mean. The averaged
//        point lies in a flatter, wider region of the loss surface
//        and generalizes better than the final SGD iterate.
//
//  Running-mean recurrence for the n-th snapshot:
//    SWA_{n} = ((n - 1) * SWA_{n-1} + w_current) / n
//            = SWA_{n-1} + (w_current - SWA_{n-1}) / n
//
//  Cyclic constant-or-linear LR schedule (Izmailov et al.):
//    alpha1, alpha2, cycle c
//    t_i = ((i mod c) + 1) / c
//    lr(i) = (1 - t_i) * alpha1 + t_i * alpha2
//
//  For this demo we run SGD on a linear-regression MSE, start SWA
//  after `swa_start` steps, and snapshot every `swa_every` steps.
//
//  AI-NATIVE:
//    @pure  — averaging / schedule helpers
// ═══════════════════════════════════════════════════════════════

fn swa_abs(v) {
    if v < 0.0 { return 0.0 - v }
    return v
}

fn swa_zeros(n) {
    let mut r = []
    let mut _i = 0

    while _i < n { r = r + [0.0] }
    return r
}

fn swa_hash(seed, i, j) {
    let h = (seed * 2654435761 + i * 1315423911 + j * 731) % 10007
    return to_float(h) / 10007.0 - 0.5
}

// ═══════════════════════════════════════════════════════════════
//  (1) Running-mean update
//    new_avg[i] = old_avg[i] + (w[i] - old_avg[i]) / n
// ═══════════════════════════════════════════════════════════════
@pure
fn swa_update_running(old_avg, w, n) {
    let d = len(w)
    let mut out = []
    let denom = to_float(n)
    let mut i = 0

    while i < d {
        let delta = (w[i] - old_avg[i]) / denom
        out = out + [old_avg[i] + delta]
    }
    return out
}

// Same for scalar bias
@pure
fn swa_update_running_scalar(old_avg, w, n) {
    let denom = to_float(n)
    return old_avg + (w - old_avg) / denom
}

// ═══════════════════════════════════════════════════════════════
//  (2) Cyclic linear LR schedule
//    Given cycle length c, step i, alpha1, alpha2:
//    t = (((i mod c) + 1) / c)
//    lr = (1 - t) * alpha1 + t * alpha2
//  Starts at alpha1 at beginning of cycle, ends at alpha2.
// ═══════════════════════════════════════════════════════════════
@pure
fn swa_cyclic_lr(step, cycle, alpha1, alpha2) {
    let pos = step % cycle
    let t = (to_float(pos) + 1.0) / to_float(cycle)
    return (1.0 - t) * alpha1 + t * alpha2
}

// Constant LR (Izmailov variant)
@pure
fn swa_const_lr(alpha) {
    return alpha
}

// ═══════════════════════════════════════════════════════════════
//  (3) Simple SGD step on MSE for linear regression
//    y = w.f + b
//    loss = (1/N) sum (y - t)^2
//    grad_w[i] = (2/N) sum (y - t) * f[i]
//    grad_b    = (2/N) sum (y - t)
// ═══════════════════════════════════════════════════════════════
fn swa_forward(w, b, feat) {
    let d = len(w)
    let mut y = b
    let mut i = 0

    while i < d {
        y = y + w[i] * feat[i]
    }
    return y
}

fn swa_mse(w, b, feats, targets) {
    let n = len(feats)
    let mut s = 0.0
    let mut i = 0

    while i < n {
        let y = swa_forward(w, b, feats[i])
        let e = y - targets[i]
        s = s + e * e
    }
    return s / to_float(n)
}

fn swa_sgd_step(w, b, feats, targets, lr) {
    let n = len(feats)
    let d = len(w)
    let mut grad_w = swa_zeros(d)
    let mut grad_b = 0.0
    let mut k = 0

    while k < n {
        let y = swa_forward(w, b, feats[k])
        let e = y - targets[k]
        grad_b = grad_b + 2.0 * e
        let mut i = 0

        while i < d {
            grad_w[i] = grad_w[i] + 2.0 * e * feats[k][i]
        }
    }
    let inv = 1.0 / to_float(n)
    let mut new_w = []
    let mut i = 0

    while i < d {
        new_w = new_w + [w[i] - lr * grad_w[i] * inv]
    }
    let new_b = b - lr * grad_b * inv
    return #{ "w": new_w, "b": new_b }
}

// ═══════════════════════════════════════════════════════════════
//  (4) Full SWA training loop
//    Training state is a dict:
//      "w", "b"           — current SGD iterate
//      "swa_w", "swa_b"   — running SWA average
//      "n_avg"            — number of snapshots accumulated so far
// ═══════════════════════════════════════════════════════════════
fn swa_make_state(w_init, b_init) {
    return #{
        "w": w_init,
        "b": b_init,
        "swa_w": w_init,
        "swa_b": b_init,
        "n_avg": 0
    }
}

fn swa_train(state, feats, targets, total_steps, swa_start, swa_every, cycle, alpha1, alpha2) {
    let mut w = state["w"]
    let mut b = state["b"]
    let mut swa_w = state["swa_w"]
    let mut swa_b = state["swa_b"]
    let mut n_avg = state["n_avg"]
    let mut step = 0

    while step < total_steps {
        let lr = swa_cyclic_lr(step, cycle, alpha1, alpha2)
        let upd = swa_sgd_step(w, b, feats, targets, lr)
        w = upd["w"]
        b = upd["b"]
        // snapshot after swa_start, every swa_every steps
        if step >= swa_start {
            let since = step - swa_start
            if since % swa_every == 0 {
                n_avg = n_avg + 1
                swa_w = swa_update_running(swa_w, w, n_avg)
                swa_b = swa_update_running_scalar(swa_b, b, n_avg)
            }
        }
    }
    return #{
        "w": w,
        "b": b,
        "swa_w": swa_w,
        "swa_b": swa_b,
        "n_avg": n_avg
    }
}

// ═══════════════════════════════════════════════════════════════
//  (5) Convenience: evaluate SWA and SGD on a data set
// ═══════════════════════════════════════════════════════════════
fn swa_eval_both(state, feats, targets) {
    let mse_sgd = swa_mse(state["w"], state["b"], feats, targets)
    let mse_swa = swa_mse(state["swa_w"], state["swa_b"], feats, targets)
    return #{ "sgd": mse_sgd, "swa": mse_swa }
}

println("[swa] loaded — cyclic LR + running mean weight averaging")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(v) {
    if v < 0.0 { return 0.0 - v }
    return v
}
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("═══════════════════════════════════════════════════════")
println("  SWA (#271) Test Suite")
println("═══════════════════════════════════════════════════════")

// ── Test 1: running mean recurrence
let avg0 = [1.0, 2.0, 3.0]
let w_new = [2.0, 4.0, 6.0]
let avg1 = swa_update_running(avg0, w_new, 2)
// expected: (1*avg0 + w_new)/2 = [1.5, 3.0, 4.5]
check("running mean w[0]", approx(avg1[0], 1.5, 1.0e-9))
check("running mean w[1]", approx(avg1[1], 3.0, 1.0e-9))
check("running mean w[2]", approx(avg1[2], 4.5, 1.0e-9))

// ── Test 2: scalar running mean
let ab0 = 4.0
let ab1 = swa_update_running_scalar(ab0, 8.0, 2)
check("scalar running mean", approx(ab1, 6.0, 1.0e-9))

// ── Test 3: running mean of constant stays constant
let c_avg = [5.0, 5.0]
let mut running = c_avg
let mut n = 1

while n < 6 {
    running = swa_update_running(running, [5.0, 5.0], n)
}
check("constant stays constant 0", approx(running[0], 5.0, 1.0e-9))
check("constant stays constant 1", approx(running[1], 5.0, 1.0e-9))

// ── Test 4: cyclic LR monotonicity within cycle
// alpha1=0.1, alpha2=0.01, cycle=4, step=0 → t=0.25, t=0.5, t=0.75, t=1.0
// lr = (1-t)*0.1 + t*0.01 is strictly decreasing as t grows
let lr0 = swa_cyclic_lr(0, 4, 0.1, 0.01)
let lr1 = swa_cyclic_lr(1, 4, 0.1, 0.01)
let lr2 = swa_cyclic_lr(2, 4, 0.1, 0.01)
let lr3 = swa_cyclic_lr(3, 4, 0.1, 0.01)
check("cyclic lr decreasing 0>1", lr0 > lr1)
check("cyclic lr decreasing 1>2", lr1 > lr2)
check("cyclic lr decreasing 2>3", lr2 > lr3)

// ── Test 5: cyclic wraps around
let lr_wrap = swa_cyclic_lr(4, 4, 0.1, 0.01)
check("cyclic wraps step 4 = step 0", approx(lr_wrap, lr0, 1.0e-9))

// ── Test 6: at half-cycle, lr = mean(alpha1, alpha2)
// cycle=4, step=1 → pos=1, t=2/4=0.5 → lr=(0.5)*0.1 + 0.5*0.01 = 0.055
check("cyclic lr midpoint", approx(lr1, 0.055, 1.0e-9))

// ── Test 7: sgd step reduces MSE on a convex problem
// Use linear regression y = 2*x with some noise
let feats7 = [[1.0], [2.0], [3.0], [4.0]]
let targets7 = [2.0, 4.0, 6.0, 8.0]
let w_init = [0.0]
let b_init = 0.0
let mse_init = swa_mse(w_init, b_init, feats7, targets7)
let upd = swa_sgd_step(w_init, b_init, feats7, targets7, 0.02)
let mse_after = swa_mse(upd["w"], upd["b"], feats7, targets7)
check("sgd step decreases mse", mse_after < mse_init)

// ── Test 8: swa state init
let state_init = swa_make_state(w_init, b_init)
check("state w", approx(state_init["w"][0], 0.0, 1.0e-12))
check("state n_avg start", state_init["n_avg"] == 0)

// ── Test 9: full training — SWA state consistent
// total_steps=20, swa_start=10, swa_every=2 → snapshots at
//   step=10, 12, 14, 16, 18 → 5 snapshots
let state_end = swa_train(state_init, feats7, targets7, 20, 10, 2, 4, 0.05, 0.01)
check("swa n_avg = 5", state_end["n_avg"] == 5)

// ── Test 10: SWA MSE ≤ initial MSE (training helped)
let mse_swa_end = swa_mse(state_end["swa_w"], state_end["swa_b"], feats7, targets7)
check("swa mse < initial mse", mse_swa_end < mse_init)

// ── Test 11: SWA w moves toward true solution (2.0)
check("swa w toward 2.0", state_end["swa_w"][0] > 0.5)
check("swa w below 3.0", state_end["swa_w"][0] < 3.0)

// ── Test 12: eval_both returns dict with both mses
let dual = swa_eval_both(state_end, feats7, targets7)
check("eval_both sgd positive", dual["sgd"] >= 0.0)
check("eval_both swa positive", dual["swa"] >= 0.0)

// ── Test 13: if we skip SWA (swa_start beyond total_steps), n_avg=0
let state_nostart = swa_train(state_init, feats7, targets7, 5, 100, 2, 4, 0.05, 0.01)
check("no swa when swa_start > total", state_nostart["n_avg"] == 0)

// ── Test 14: single-snapshot SWA equals first snapshot weights
// swa_start=5, swa_every=100 → only one snapshot at step=5
let single_snap = swa_train(state_init, feats7, targets7, 6, 5, 100, 4, 0.05, 0.01)
check("single snapshot n_avg = 1", single_snap["n_avg"] == 1)

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
