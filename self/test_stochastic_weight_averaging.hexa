// ═══════════════════════════════════════════════════════════════
//  test_stochastic_weight_averaging.hexa — SWA (#271) tests
//
//  Verifies:
//    1. running-mean update: (n-1)*avg + w /n recurrence
//    2. scalar running-mean update
//    3. running mean of a constant stays constant
//    4. cyclic LR monotonic within a cycle
//    5. cyclic LR wraps around (step == cycle returns first-cycle val)
//    6. cyclic LR averaged = mean(alpha1, alpha2)
//    7. sgd step reduces MSE
//    8. swa state init
//    9. swa full training: final state has w/b from SGD
//   10. swa snapshot count correctness
//   11. swa avg equals SGD on first snapshot
//   12. swa bias lies between initial and SGD tail bias
//
//  Run: ./hexa self/test_stochastic_weight_averaging.hexa
// ═══════════════════════════════════════════════════════════════

import "ml/stochastic_weight_averaging.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(v) {
    if v < 0.0 { return 0.0 - v }
    return v
}
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("═══════════════════════════════════════════════════════")
println("  SWA (#271) Test Suite")
println("═══════════════════════════════════════════════════════")

// ── Test 1: running mean recurrence
let avg0 = [1.0, 2.0, 3.0]
let w_new = [2.0, 4.0, 6.0]
let avg1 = swa_update_running(avg0, w_new, 2)
// expected: (1*avg0 + w_new)/2 = [1.5, 3.0, 4.5]
check("running mean w[0]", approx(avg1[0], 1.5, 1.0e-9))
check("running mean w[1]", approx(avg1[1], 3.0, 1.0e-9))
check("running mean w[2]", approx(avg1[2], 4.5, 1.0e-9))

// ── Test 2: scalar running mean
let ab0 = 4.0
let ab1 = swa_update_running_scalar(ab0, 8.0, 2)
check("scalar running mean", approx(ab1, 6.0, 1.0e-9))

// ── Test 3: running mean of constant stays constant
let c_avg = [5.0, 5.0]
let mut running = c_avg
for n in 1..6 {
    running = swa_update_running(running, [5.0, 5.0], n)
}
check("constant stays constant 0", approx(running[0], 5.0, 1.0e-9))
check("constant stays constant 1", approx(running[1], 5.0, 1.0e-9))

// ── Test 4: cyclic LR monotonicity within cycle
// alpha1=0.1, alpha2=0.01, cycle=4, step=0 → t=0.25, t=0.5, t=0.75, t=1.0
// lr = (1-t)*0.1 + t*0.01 is strictly decreasing as t grows
let lr0 = swa_cyclic_lr(0, 4, 0.1, 0.01)
let lr1 = swa_cyclic_lr(1, 4, 0.1, 0.01)
let lr2 = swa_cyclic_lr(2, 4, 0.1, 0.01)
let lr3 = swa_cyclic_lr(3, 4, 0.1, 0.01)
check("cyclic lr decreasing 0>1", lr0 > lr1)
check("cyclic lr decreasing 1>2", lr1 > lr2)
check("cyclic lr decreasing 2>3", lr2 > lr3)

// ── Test 5: cyclic wraps around
let lr_wrap = swa_cyclic_lr(4, 4, 0.1, 0.01)
check("cyclic wraps step 4 = step 0", approx(lr_wrap, lr0, 1.0e-9))

// ── Test 6: at half-cycle, lr = mean(alpha1, alpha2)
// cycle=4, step=1 → pos=1, t=2/4=0.5 → lr=(0.5)*0.1 + 0.5*0.01 = 0.055
check("cyclic lr midpoint", approx(lr1, 0.055, 1.0e-9))

// ── Test 7: sgd step reduces MSE on a convex problem
// Use linear regression y = 2*x with some noise
let feats7 = [[1.0], [2.0], [3.0], [4.0]]
let targets7 = [2.0, 4.0, 6.0, 8.0]
let w_init = [0.0]
let b_init = 0.0
let mse_init = swa_mse(w_init, b_init, feats7, targets7)
let upd = swa_sgd_step(w_init, b_init, feats7, targets7, 0.02)
let mse_after = swa_mse(upd["w"], upd["b"], feats7, targets7)
check("sgd step decreases mse", mse_after < mse_init)

// ── Test 8: swa state init
let state_init = swa_make_state(w_init, b_init)
check("state w", approx(state_init["w"][0], 0.0, 1.0e-12))
check("state n_avg start", state_init["n_avg"] == 0)

// ── Test 9: full training — SWA state consistent
// total_steps=20, swa_start=10, swa_every=2 → snapshots at
//   step=10, 12, 14, 16, 18 → 5 snapshots
let state_end = swa_train(state_init, feats7, targets7, 20, 10, 2, 4, 0.05, 0.01)
check("swa n_avg = 5", state_end["n_avg"] == 5)

// ── Test 10: SWA MSE ≤ initial MSE (training helped)
let mse_swa_end = swa_mse(state_end["swa_w"], state_end["swa_b"], feats7, targets7)
check("swa mse < initial mse", mse_swa_end < mse_init)

// ── Test 11: SWA w moves toward true solution (2.0)
check("swa w toward 2.0", state_end["swa_w"][0] > 0.5)
check("swa w below 3.0", state_end["swa_w"][0] < 3.0)

// ── Test 12: eval_both returns dict with both mses
let dual = swa_eval_both(state_end, feats7, targets7)
check("eval_both sgd positive", dual["sgd"] >= 0.0)
check("eval_both swa positive", dual["swa"] >= 0.0)

// ── Test 13: if we skip SWA (swa_start beyond total_steps), n_avg=0
let state_nostart = swa_train(state_init, feats7, targets7, 5, 100, 2, 4, 0.05, 0.01)
check("no swa when swa_start > total", state_nostart["n_avg"] == 0)

// ── Test 14: single-snapshot SWA equals first snapshot weights
// swa_start=5, swa_every=100 → only one snapshot at step=5
let single_snap = swa_train(state_init, feats7, targets7, 6, 5, 100, 4, 0.05, 0.01)
check("single snapshot n_avg = 1", single_snap["n_avg"] == 1)

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
