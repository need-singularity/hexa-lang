// ═══════════════════════════════════════════════════════════════════
//  test_bignum_mini_pure.hexa — coverage for self/runtime/bignum_mini_pure.hexa
//
//  Tests: bignum_from_int_pure, bignum_to_string_pure, bignum_add_pure,
//         bignum_sub_pure, bignum_mul_int_pure
//         (plus helpers bignum_is_zero_pure, bignum_cmp_pure)
//
//  (codegen import not wired for test files; inline the module body,
//   same pattern as test_bitops_pure.hexa / test_welford_pure.hexa.)
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from self/runtime/bignum_mini_pure.hexa ──

@pure
fn _bn_trim(limbs) {
    let mut n = len(limbs)
    while n > 1 {
        if limbs[n - 1] != 0 { return limbs.slice(0, n) }
        n = n - 1
    }
    if n == 0 { return [0] }
    return limbs.slice(0, 1)
}

@pure
fn bignum_is_zero_pure(limbs) {
    let n = len(limbs)
    if n == 0 { return true }
    let mut i = 0
    while i < n {
        if limbs[i] != 0 { return false }
        i = i + 1
    }
    return true
}

@pure
fn bignum_cmp_pure(a, b) {
    let la = len(a)
    let lb = len(b)
    let mut ha = la
    while ha > 0 {
        if a[ha - 1] != 0 { break }
        ha = ha - 1
    }
    let mut hb = lb
    while hb > 0 {
        if b[hb - 1] != 0 { break }
        hb = hb - 1
    }
    if ha < hb { return -1 }
    if ha > hb { return 1 }
    let mut i = ha
    while i > 0 {
        let ai = a[i - 1]
        let bi = b[i - 1]
        if ai < bi { return -1 }
        if ai > bi { return 1 }
        i = i - 1
    }
    return 0
}

@pure
fn bignum_from_int_pure(n) {
    if n < 0 { return nil }
    if n == 0 { return [0] }
    let mut out = []
    let mut x = n
    while x > 0 {
        out = out.push(x % 10)
        x = x / 10
    }
    return out
}

@pure
fn bignum_to_string_pure(limbs) {
    let trimmed = _bn_trim(limbs)
    let n = len(trimmed)
    if n == 0 { return "0" }
    let mut parts = []
    let mut i = n
    while i > 0 {
        let d = trimmed[i - 1]
        parts = parts.push(chr(48 + d))
        i = i - 1
    }
    return parts.join("")
}

@pure
fn bignum_add_pure(a, b) {
    let la = len(a)
    let lb = len(b)
    let n = if la > lb { la } else { lb }
    let mut out = []
    let mut carry = 0
    let mut i = 0
    while i < n {
        let ai = if i < la { a[i] } else { 0 }
        let bi = if i < lb { b[i] } else { 0 }
        let s = ai + bi + carry
        out = out.push(s % 10)
        carry = s / 10
        i = i + 1
    }
    while carry > 0 {
        out = out.push(carry % 10)
        carry = carry / 10
    }
    return _bn_trim(out)
}

@pure
fn bignum_sub_pure(a, b) {
    let cmp = bignum_cmp_pure(a, b)
    if cmp < 0 { return nil }
    if cmp == 0 { return [0] }
    let la = len(a)
    let lb = len(b)
    let mut out = []
    let mut br = 0
    let mut i = 0
    while i < la {
        let ai = a[i]
        let bi = if i < lb { b[i] } else { 0 }
        let raw = ai - bi - br
        if raw < 0 {
            out = out.push(raw + 10)
            br = 1
        } else {
            out = out.push(raw)
            br = 0
        }
        i = i + 1
    }
    return _bn_trim(out)
}

@pure
fn bignum_mul_int_pure(limbs, m) {
    if m < 0 { return nil }
    if m == 0 { return [0] }
    if bignum_is_zero_pure(limbs) { return [0] }
    let n = len(limbs)
    let mut out = []
    let mut carry = 0
    let mut i = 0
    while i < n {
        let prod = limbs[i] * m + carry
        out = out.push(prod % 10)
        carry = prod / 10
        i = i + 1
    }
    while carry > 0 {
        out = out.push(carry % 10)
        carry = carry / 10
    }
    return _bn_trim(out)
}

// ── test harness ────────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_nil(name, actual) {
    if type_of(actual) == "void" {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected nil, got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Bignum Mini Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── bignum_from_int_pure ────────────────────────────────────────────
println("--- bignum_from_int_pure ---")
check("from_int 0",     bignum_from_int_pure(0),     [0])
check("from_int 1",     bignum_from_int_pure(1),     [1])
check("from_int 9",     bignum_from_int_pure(9),     [9])
check("from_int 10",    bignum_from_int_pure(10),    [0, 1])
check("from_int 123",   bignum_from_int_pure(123),   [3, 2, 1])
check("from_int 1000",  bignum_from_int_pure(1000),  [0, 0, 0, 1])
check("from_int 99999", bignum_from_int_pure(99999), [9, 9, 9, 9, 9])
check_nil("from_int -1 nil", bignum_from_int_pure(-1))

// ── bignum_to_string_pure ───────────────────────────────────────────
println("")
println("--- bignum_to_string_pure ---")
check("to_string [0]",          bignum_to_string_pure([0]),          "0")
check("to_string [3,2,1]",      bignum_to_string_pure([3, 2, 1]),    "123")
check("to_string [0,0,0,1]",    bignum_to_string_pure([0, 0, 0, 1]), "1000")
check("to_string [1,0,8,9]",    bignum_to_string_pure([1, 0, 8, 9]), "9801")
// Non-canonical trailing zeros -> trimmed view
check("to_string [5,0,0]",      bignum_to_string_pure([5, 0, 0]),    "5")
check("to_string []",           bignum_to_string_pure([]),           "0")

// ── bignum_add_pure ─────────────────────────────────────────────────
println("")
println("--- bignum_add_pure ---")
check("add [9]+[1] carry",  bignum_add_pure([9], [1]),       [0, 1])
check("add [1,2,3]+[7,8,9]", bignum_add_pure([1, 2, 3], [7, 8, 9]), [8, 0, 3, 1])  // 321+987=1308
check("add 0+0",            bignum_add_pure([0], [0]),       [0])
check("add 0+123",          bignum_add_pure([0], [3, 2, 1]), [3, 2, 1])
check("add 999+1",          bignum_add_pure([9, 9, 9], [1]), [0, 0, 0, 1])
check("add 50+50",          bignum_add_pure([0, 5], [0, 5]), [0, 0, 1])

// ── bignum_sub_pure ─────────────────────────────────────────────────
println("")
println("--- bignum_sub_pure ---")
check("sub 10-1",   bignum_sub_pure([0, 1], [1]),           [9])
check("sub 100-1",  bignum_sub_pure([0, 0, 1], [1]),        [9, 9])
check("sub 1000-1", bignum_sub_pure([0, 0, 0, 1], [1]),     [9, 9, 9])
check("sub 500-123", bignum_sub_pure([0, 0, 5], [3, 2, 1]), [7, 7, 3])
check("sub a-a=0",  bignum_sub_pure([3, 2, 1], [3, 2, 1]),  [0])
check_nil("sub 1-2 nil", bignum_sub_pure([1], [2]))
check_nil("sub 99-100 nil", bignum_sub_pure([9, 9], [0, 0, 1]))

// ── bignum_mul_int_pure ─────────────────────────────────────────────
println("")
println("--- bignum_mul_int_pure ---")
check("mul_int [1,2,3]*2",  bignum_mul_int_pure([1, 2, 3], 2), [2, 4, 6])
check("mul_int [9,9]*9",    bignum_mul_int_pure([9, 9], 9),    [1, 9, 8])  // 99*9=891
check("mul_int anything*0", bignum_mul_int_pure([5, 5, 5], 0), [0])
check("mul_int [0]*7",      bignum_mul_int_pure([0], 7),       [0])
check("mul_int [1]*1000",   bignum_mul_int_pure([1], 1000),    [0, 0, 0, 1])
check_nil("mul_int neg nil", bignum_mul_int_pure([1, 2, 3], -1))

// ── cross / roundtrip ──────────────────────────────────────────────
println("")
println("--- roundtrip / composite ---")

// 99 * 99 = 9801 via repeated add: accumulate 99 ninety-nine times
// simpler: use mul_int 99 * 99 (mul_int takes small int)
check("mul 99*99=9801", bignum_mul_int_pure([9, 9], 99), [1, 0, 8, 9])
check("to_string 99*99", bignum_to_string_pure(bignum_mul_int_pure([9, 9], 99)), "9801")

// roundtrip: from_int(N) -> to_string = to_string(N) for a spread
check("rt 0",       bignum_to_string_pure(bignum_from_int_pure(0)),       "0")
check("rt 1",       bignum_to_string_pure(bignum_from_int_pure(1)),       "1")
check("rt 42",      bignum_to_string_pure(bignum_from_int_pure(42)),      "42")
check("rt 12345",   bignum_to_string_pure(bignum_from_int_pure(12345)),   "12345")
check("rt 1000000", bignum_to_string_pure(bignum_from_int_pure(1000000)), "1000000")
check("rt 123456789", bignum_to_string_pure(bignum_from_int_pure(123456789)), "123456789")

// factorial(20) = 2432902008176640000 — build via repeated mul_int
let mut fact = bignum_from_int_pure(1)
let mut k = 1
while k <= 20 {
    fact = bignum_mul_int_pure(fact, k)
    k = k + 1
}
check("20! = 2432902008176640000", bignum_to_string_pure(fact), "2432902008176640000")

// add associativity sample: (a+b)+c == a+(b+c)
let a_ = [7, 7, 7]       // 777
let b_ = [3, 2, 1]       // 123
let c_ = [9, 9]          // 99
let ab = bignum_add_pure(a_, b_)
let ab_c = bignum_add_pure(ab, c_)
let bc = bignum_add_pure(b_, c_)
let a_bc = bignum_add_pure(a_, bc)
check("assoc (a+b)+c == a+(b+c)", bignum_to_string_pure(ab_c), bignum_to_string_pure(a_bc))
check("777+123+99 = 999", bignum_to_string_pure(ab_c), "999")

// sub inverts add: (a + b) - b == a
let sum_ab = bignum_add_pure(a_, b_)
let back = bignum_sub_pure(sum_ab, b_)
check("sub inverts add", bignum_to_string_pure(back), bignum_to_string_pure(a_))

// is_zero spot-check
check("is_zero [0]",       to_string(bignum_is_zero_pure([0])),          "true")
check("is_zero []",        to_string(bignum_is_zero_pure([])),           "true")
check("is_zero [0,0,0]",   to_string(bignum_is_zero_pure([0, 0, 0])),    "true")
check("is_zero [1]",       to_string(bignum_is_zero_pure([1])),          "false")

// cmp spot-check
check("cmp 0 vs 0",        bignum_cmp_pure([0], [0]),       0)
check("cmp 1 vs 2",        bignum_cmp_pure([1], [2]),       -1)
check("cmp 10 vs 9",       bignum_cmp_pure([0, 1], [9]),    1)
check("cmp trailing zero", bignum_cmp_pure([5, 0], [5]),    0)

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
