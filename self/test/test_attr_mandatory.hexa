// self/test/test_attr_mandatory.hexa — Layer 3 (#4) future-verification
//
// When `self/parser.hexa::parse_fn_decl` gains the purity-gate check
// (see self/design/attr_mandatory_parser.md), this file becomes the
// canonical smoke-test:
//
//   case (a) naked `fn`          → expect PARSE ERROR
//   case (b) @pure fn            → expect PASS
//   case (c) @lax  fn            → expect PASS (grandfather)
//   case (d) @effect[io] fn      → expect PASS (typed effect)
//
// Until the gate lands, the parser ignores everything and all four cases
// PASS trivially. That is intentional — this file is a **future-
// verification** fixture; it encodes the target shape so the gate's
// landing PR only needs to flip the pass/fail expectation for case (a).
//
// RUN
//   hexa self/test/test_attr_mandatory.hexa
//
// GATE LANDS
//   Expect case (a) to fail parse with:
//     "naked `fn` forbidden — prepend @pure, @effect[kind], @impure, or @lax"
//   At that point, remove `_case_a_naked_fn_demo` below or wrap it in a
//   comment + negative-parse fixture file.

use "stdlib/io"

// ── case (b) — @pure fn — expect PASS ────────────────────────────────
@pure
fn _case_b_pure_double(x: int) -> int {
    return x * 2
}

// ── case (c) — @lax fn — expect PASS (grandfather escape hatch) ──────
@lax
fn _case_c_lax_legacy() -> int {
    // legacy fn not yet audited for purity; @lax grants temporary passage
    return 42
}

// ── case (d) — @effect[io] fn — expect PASS (typed effect) ───────────
@effect[io]
fn _case_d_effect_io_hello() {
    println("hello from @effect[io]")
}

// ── case (a) — naked `fn` — expect PARSE ERROR once gate lands ───────
// Today this compiles. Post-gate: parse error.
fn _case_a_naked_fn_demo() -> int {
    return 1
}

fn main() {
    // Invoke each to prove they produce AST + codegen + runtime.
    let b = _case_b_pure_double(21)
    _case_d_effect_io_hello()
    let c = _case_c_lax_legacy()
    let a = _case_a_naked_fn_demo()

    println("case (b) @pure       : " + to_string(b))       // 42
    println("case (c) @lax        : " + to_string(c))       // 42
    println("case (a) naked fn    : " + to_string(a))       // 1 (pre-gate)

    // Post-gate expected: parser refuses case (a) before we reach here.
    // Until then, all four cases round-trip cleanly.
    if b == 42 && c == 42 && a == 1 {
        println("test_attr_mandatory: PRE-GATE PASS (all 4 accepted)")
    } else {
        println("test_attr_mandatory: UNEXPECTED — values mismatch")
        exit(1)
    }
}
