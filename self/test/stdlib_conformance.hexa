// self/test/stdlib_conformance.hexa — Per-symbol stdlib conformance test.
//
// Closes hexa-lang upstream gap #6 (docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md §2.5).
//
// CONTRACT
//   Exercises every symbol declared in self/stdlib/conformance_manifest.json
//   with safe args. Emits a single sentinel line on stdout summarising
//   the verdict:
//
//   On full pass:
//       __STDLIB_PARITY__ PASS symbols=<N> mode=<MODE>
//
//   On any miss:
//       __STDLIB_PARITY__ FAIL missing=<SYMBOL> mode=<MODE>
//       (and exit code 7 — but per gap #5 do NOT trust $?, parse the line)
//
// RUN
//   hexa run self/test/stdlib_conformance.hexa
//
// SUCCESS RULE
//   Exit code 0 + stdout sentinel `__STDLIB_PARITY__ PASS symbols=<N>`.
//
// FAIL-LOUD VERIFICATION (manual)
//   To exercise the fail path without modifying stdlib, the
//   `_synthetic_miss` injector below can be enabled by setting env
//   HEXA_CONFORMANCE_INJECT_MISS=1; the test then forces an extra probe
//   that is guaranteed to fail and reports its symbol via the sentinel.
//   This documents the failure path without requiring force-removal of
//   a real symbol.

use "self/stdlib/conformance"

fn main() {
    // Per-symbol exercise — runs all probes, captures the verdict.
    let r = conformance_run()
    let miss = r[0]
    let total = r[1]
    let mode = conformance_active_mode()

    // Optional fail-loud injection (manual fail-path exercise).
    let inject = env_get("HEXA_CONFORMANCE_INJECT_MISS")
    if len(inject) > 0 && inject != "0" {
        // Synthetic miss: surface the would-be sentinel without touching
        // stdlib. Demonstrates the assertion path is wired.
        eprintln("__STDLIB_PARITY__ FAIL missing=__synthetic__ mode=" + mode)
        exit(7)
    }

    if miss != "" {
        // Real miss path. Report on stderr per the assertion contract,
        // and on stdout per the test sentinel contract — both lines are
        // identical so downstream parsers see one source of truth no
        // matter which channel they tail.
        let line = "__STDLIB_PARITY__ FAIL missing=" + miss + " mode=" + mode
        eprintln(line)
        println(line)
        exit(7)
    }

    println("__STDLIB_PARITY__ PASS symbols=" + to_string(total) + " mode=" + mode)
}
