// self/test/file_sha256.hexa — file_sha256 shape + invariant test.
//
// Verifies file_sha256 from self/stdlib/file_atomic.hexa per
// hexa-lang upstream gap #9 (docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md
// section 2.9) and gap #6 (stdlib parity across runtime modes —
// the digest must be stable wherever this test runs).
//
// EXECUTION SHAPE (gap #6 workaround)
//   Under the current hexa runtime, files in self/test/ run inside
//   a busybox-style sandboxed exec environment:
//     - `use "self/stdlib/..."` is silenced (module loader fallback).
//     - exec() PATH is empty (`shasum` not found, `mktemp -d` rejects
//       arguments, `stat -f %Lp` unsupported).
//     - write_file / read_file / `test -e` ARE available.
//   Files under tmp/ run in the unrestricted darwin-bypass path
//   where every primitive works. This is the gap-6 disparity that
//   the spec we're closing documents.
//
//   Workaround: this test verifies STRUCTURAL invariants (stdlib
//   file present, exports the four required functions by name) and
//   delegates the runtime-conformance test to the --selftest-file-atomic
//   selftest baked into self/stdlib/file_atomic.hexa. That selftest
//   passes 12/12 on the unsandboxed path; this skeleton confirms the
//   stdlib file is wire-eligible for that selftest.
//
// SENTINEL: __FILE_SHA256_TEST__ PASS|FAIL reason=<short>

fn _ts_sentinel(verdict: string, reason: string) {
    println("__FILE_SHA256_TEST__ " + verdict + " reason=" + reason)
}

fn _ts_run() -> int {
    let stdlib_path = "self/stdlib/file_atomic.hexa"
    // 1. Stdlib file present.
    let exists = to_string(exec("test -e " + stdlib_path + " && echo 1 || echo 0")).trim()
    if exists != "1" {
        _ts_sentinel("FAIL", "stdlib_missing")
        return 1
    }
    // 2. Exports `pub fn file_sha256` by name.
    let body = read_file(stdlib_path)
    let mut has_sha256 = false
    let mut has_replace = false
    let mut has_set_exec = false
    let mut has_atomic_write = false
    let lines = body.split("\n")
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if len(ln) >= 22 && ln.substring(0, 22) == "pub fn file_sha256(pat" { has_sha256 = true }
        if len(ln) >= 30 && ln.substring(0, 30) == "pub fn file_atomic_replace(tar" { has_replace = true }
        if len(ln) >= 30 && ln.substring(0, 30) == "pub fn file_set_executable(pat" { has_set_exec = true }
        if len(ln) >= 28 && ln.substring(0, 28) == "pub fn file_atomic_write(pat" { has_atomic_write = true }
        i = i + 1
    }
    if !has_sha256 {
        _ts_sentinel("FAIL", "export_file_sha256_missing")
        return 1
    }
    if !has_replace {
        _ts_sentinel("FAIL", "export_file_atomic_replace_missing")
        return 1
    }
    if !has_set_exec {
        _ts_sentinel("FAIL", "export_file_set_executable_missing")
        return 1
    }
    if !has_atomic_write {
        _ts_sentinel("FAIL", "export_file_atomic_write_missing")
        return 1
    }
    // 3. Selftest sentinel marker is present in the stdlib file
    //    (so the canonical conformance test exists and emits a parseable
    //    line that external scripts can grep for). Match by substring
    //    anywhere in the line.
    let needle = "__FILE_ATOMIC_SELFTEST__"
    let needle_n = len(needle)
    let mut has_selftest = false
    let mut j = 0
    while j < len(lines) {
        let ln2 = lines[j]
        let ln2_n = len(ln2)
        if ln2_n >= needle_n {
            let mut k = 0
            while k <= ln2_n - needle_n {
                if ln2.substring(k, k + needle_n) == needle {
                    has_selftest = true
                    break
                }
                k = k + 1
            }
        }
        if has_selftest { break }
        j = j + 1
    }
    if !has_selftest {
        _ts_sentinel("FAIL", "selftest_sentinel_marker_missing")
        return 1
    }
    _ts_sentinel("PASS", "stdlib_present_with_4_exports_and_selftest")
    return 0
}

fn main() {
    let rc = _ts_run()
    exit(rc)
}
