// self/test/test_module_gate.hexa — Layer 2 gate sanity test (#29)
// ─────────────────────────────────────────────────────────────────────────
// Two scenarios, run as a standalone .hexa (no hook wire-up yet):
//
//   PASS  — a real .hexa file under self/stdlib passes the gate.
//   FAIL  — a forged .py path is refused (exit(1) path, asserted indirectly
//           by spawning a child process).
//
// Note: we can't directly invoke the exit(1) branch in-process without
// terminating the test runner. The FAIL case is therefore verified by
// shelling out to the interpreter with a minimal probe script.

use "stdlib/module_gate"
use "self/core/law_io"

fn test_pass() {
    // law_io.hexa itself is the obvious admissible target — it's a
    // plain .hexa stdlib file and must pass the r7 extension ban.
    let p = "self/core/law_io.hexa"
    let ok = module_gate_check(p)
    if !ok {
        eprintln("FAIL: expected module_gate_check to accept " + p)
        exit(1)
    }
    println("PASS: " + p + " admitted")
}

fn test_fail_out_of_process() {
    // Write a micro-probe that attempts to gate a forged .py path.
    // Under a compliant module_gate this process exits with code 1
    // and prints a ❌ line to stderr — both are observable from here.
    let probe = "/tmp/hexa_module_gate_probe.hexa"
    let body = "use \"stdlib/module_gate\"\n" +
               "fn main() {\n" +
               "    module_gate_check(\"/tmp/forged_hostile.py\")\n" +
               "    println(\"UNREACHABLE\")\n" +
               "}\n"
    safe_write_file(probe, body)
    // Runtime exec returns the child's exit status. Non-zero = refusal
    // path fired. We don't capture stderr in this skeleton — that's
    // upgraded when module_gate is wired into the compiler proper.
    let status = exec("hexa " + probe + " 2>/dev/null")
    if status == 0 {
        eprintln("FAIL: forged .py path was NOT refused (gate leaked)")
        exec("rm -f '" + probe + "'")
        exit(1)
    }
    exec("rm -f '" + probe + "'")
    println("PASS: forged .py path refused (exit=" + to_string(status) + ")")
}

fn main() {
    test_pass()
    test_fail_out_of_process()
    println("✅ module_gate tests OK")
}
