// self/test/exit_propagation_nested.hexa
//
// Conformance test for upstream gap #5: `exit(N)` from a deeply-nested
// call site (≥4 frames deep, mixed void/typed shapes, with defer) MUST
// reach the OS so the parent shell sees `$? == N`.
//
// Verification:
//
//     HEXA_LOCAL=1 ~/.hx/bin/hexa self/test/exit_propagation_nested.hexa
//     echo "rc=$?"
//     # expected: rc=9
//
// Regression marker: pre-fix the defer-drain footer (`__fn_exit:` label
// + LIFO defer body emission) could hold the call stack open after an
// exit() — fflush+libc exit short-circuits the drain so the process
// terminates immediately. This test exercises the defer-on-the-stack
// shape to lock that behavior.

fn level4() -> void {
    eprintln("__EXIT_PROP_NESTED__ at level4 — exiting")
    exit(9)
}

fn level3() -> void {
    defer {
        // Should NOT print: exit() short-circuits defer drain.
        println("__EXIT_PROP_NESTED__ defer-3 ran (BUG)")
    }
    level4()
}

fn level2() -> string {
    level3()
    return "unreachable-level2"
}

fn level1() -> int {
    let s = level2()
    return len(s)
}

fn dispatch() -> void {
    let n = level1()
    println("__EXIT_PROP_NESTED__ UNREACHABLE n=" + to_string(n))
}

dispatch()
println("__EXIT_PROP_NESTED__ UNREACHABLE-AFTER-DISPATCH")
