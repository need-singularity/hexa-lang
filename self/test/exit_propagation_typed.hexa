// self/test/exit_propagation_typed.hexa
//
// Conformance test for upstream gap #5: `exit(N)` from inside a
// function with a non-void return type (here `-> string` and `-> int`)
// MUST reach the OS unconditionally, regardless of the implicit
// tail-return rewrite that codegen_c2 applies for typed fns.
//
// Verification:
//
//     HEXA_LOCAL=1 ~/.hx/bin/hexa self/test/exit_propagation_typed.hexa
//     echo "rc=$?"
//     # expected: rc=7
//
// Regression marker: pre-fix the typed-fn tail-return path could wrap
// the exit call in an arena-return, swallowing the OS termination.
// codegen_c2.hexa:1340 explicitly skips the tail-return rewrite when
// the trailing call is `exit(...)`; this test locks that behavior.

fn lookup(key: string) -> string {
    if key == "missing" {
        eprintln("__EXIT_PROP_TYPED__ FAIL reason=missing-key")
        exit(7)
    }
    return "value"
}

fn count_or_die(items: [string]) -> int {
    if len(items) == 0 {
        eprintln("__EXIT_PROP_TYPED__ FAIL reason=empty-items")
        exit(7)
    }
    return len(items)
}

fn caller() -> string {
    let v = lookup("missing")
    let n = count_or_die([])
    return v + ":" + to_string(n)
}

let result = caller()
println("__EXIT_PROP_TYPED__ UNREACHABLE result=" + result)
