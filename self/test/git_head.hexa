// @resolver-bypass(reason="local git probe — darwin-native exec to bare git binary")
// self/test/git_head.hexa — git stdlib gap-8 fixture: git_head
//
// Read-only test against the hexa-lang repo itself. Asserts:
//   · git_head returns ok=true
//   · sha is 40 chars hex
//   · sha matches what `git rev-parse HEAD` reports out-of-band
//
// Sentinel emitted on PASS:
//   __GIT_HEAD_TEST__ PASS sha=<40hex>
// On FAIL exit(1) with reason on stderr.

use "self/stdlib/git"
use "self/stdlib/shell_escape"

fn _is_hex40(s: string) -> bool {
    if len(s) != 40 { return false }
    let mut i = 0
    while i < 40 {
        let c = s.substring(i, i + 1)
        let is_dig = c >= "0" && c <= "9"
        let is_lc = c >= "a" && c <= "f"
        let is_uc = c >= "A" && c <= "F"
        if !is_dig && !is_lc && !is_uc { return false }
        i = i + 1
    }
    return true
}

fn _resolve_repo_root() -> string {
    // Walk up from cwd until we find a .git directory. Bounded depth 32.
    // We can't use file_exists on .git directly (it's a dir) — use
    // `test -d` via exec for honesty.
    let mut p = to_string(exec("pwd")).trim()
    let mut depth = 0
    while depth < 32 {
        if len(p) == 0 { break }
        let chk = exec_with_status("test -d " + shell_escape(p + "/.git"))
        if chk[1] == 0 { return p }
        if p == "/" { break }
        // strip last segment
        let mut last = -1
        let mut k = len(p) - 1
        while k >= 0 {
            if p.substring(k, k + 1) == "/" { last = k; break }
            k = k - 1
        }
        if last <= 0 {
            p = "/"
        } else {
            p = p.substring(0, last)
        }
        depth = depth + 1
    }
    return ""
}

fn main() {
    let repo = _resolve_repo_root()
    if len(repo) == 0 {
        eprintln("git_head test: cannot find a .git ancestor from cwd — skip")
        println("__GIT_HEAD_TEST__ SKIP reason=no_repo")
        return
    }

    let h = git_head(repo)
    if h["ok"] != true {
        eprintln("git_head test: git_head ok=false at " + repo)
        exit(1)
    }
    let sha = to_string(h["sha"])
    if !_is_hex40(sha) {
        eprintln("git_head test: sha not 40-hex: '" + sha + "'")
        exit(1)
    }

    // Cross-check against `git rev-parse HEAD` directly (out-of-band).
    let oob_pair = exec_with_status("git -C " + shell_escape(repo) + " rev-parse HEAD 2>/dev/null")
    if oob_pair[1] != 0 {
        eprintln("git_head test: oob rev-parse failed at " + repo)
        exit(1)
    }
    let oob_sha = to_string(oob_pair[0]).trim()
    if sha != oob_sha {
        eprintln("git_head test: typed=" + sha + " oob=" + oob_sha)
        exit(1)
    }

    println("__GIT_HEAD_TEST__ PASS sha=" + sha)
}

