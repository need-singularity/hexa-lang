// Regression: break inside deeply nested if/else within a while loop
// must terminate the loop AND prevent any trailing statements in
// enclosing scopes from executing.
//
// Pre-fix bug (2026-05-05, found during yaml.hexa parser work,
// ref Agent H): the interpreter's eval_body did not short-circuit on
// break_flag, so trailing statements in the enclosing else-block ran
// after the inner break — producing "one extra iteration"'s worth of
// side effects (e.g. an extra increment of the loop counter). yaml.hexa
// shipped a `let mut done = false; ...; if !done { i = i + 1 }`
// workaround.
//
// Codegen_c2 (AOT) was already correct (emits plain C `break;`); the
// fix is in self/hexa_full.hexa::eval_body — adds break_flag /
// continue_flag to the short-circuit guard alongside return_flag /
// throw_flag.
//
// This test runs as a plain script — exits with rc=0 on PASS and rc=1
// on FAIL.

fn t_shallow_break_in_else() -> Int {
    let mut i = 0
    let mut break_observed = false
    let mut trailing_ran = 0

    while i < 100 {
        if false {
            i = i + 9999
        } else {
            // multi-statement else with nested if-break
            let local = i * 2
            if i >= 3 {
                break_observed = true
                break
            }
            if break_observed { trailing_ran = trailing_ran + 1 }
            i = i + 1
        }
    }

    if i != 3 { println("FAIL shallow: i =", i); return 1 }
    if !break_observed { println("FAIL shallow: break_observed=false"); return 1 }
    if trailing_ran != 0 { println("FAIL shallow: trailing_ran =", trailing_ran); return 1 }
    return 0
}

fn t_deep_break_3_levels() -> Int {
    // 3 levels of if/else nesting inside the while body.
    let mut i = 0
    let mut hit = -1
    let mut trailing_ran = 0
    let mut should_break = false

    while i < 100 {
        if false {
            i = i + 9999
        } else {
            if false {
                i = i + 9999
            } else {
                if i >= 4 {
                    hit = i
                    should_break = true
                    break
                }
                if should_break { trailing_ran = trailing_ran + 1 }
            }
            if should_break { trailing_ran = trailing_ran + 1 }
            i = i + 1
        }
    }

    if hit != 4 { println("FAIL deep3: hit =", hit); return 1 }
    if i != 4 { println("FAIL deep3: i =", i); return 1 }
    if trailing_ran != 0 { println("FAIL deep3: trailing_ran =", trailing_ran); return 1 }
    return 0
}

fn t_deep_break_4_levels() -> Int {
    // 4 levels deep — mirrors yaml.hexa scanner pyramid shape.
    let s = "abcde:value"
    let n = len(s)
    let mut i = 0
    let mut hit = -1
    let mut should_break = false
    let mut trailing_ran = 0

    while i < n {
        let c = s[i]
        if c == "z" {
            i = i + 9999
        } else {
            if c == "y" {
                i = i + 9999
            } else {
                if c == "x" {
                    i = i + 9999
                } else {
                    if c == ":" {
                        hit = i
                        should_break = true
                        break
                    }
                    if should_break { trailing_ran = trailing_ran + 1 }
                }
                if should_break { trailing_ran = trailing_ran + 1 }
            }
            if should_break { trailing_ran = trailing_ran + 1 }
            i = i + 1
        }
    }

    if hit != 5 { println("FAIL deep4: hit =", hit); return 1 }
    if i != 5 { println("FAIL deep4: i =", i); return 1 }
    if trailing_ran != 0 { println("FAIL deep4: trailing_ran =", trailing_ran); return 1 }
    return 0
}

fn t_continue_in_nested_else() -> Int {
    // Same class of bug for `continue`: must short-circuit trailing
    // statements in enclosing else, then resume loop.
    let mut i = 0
    let mut iters = 0
    let mut trailing_after_continue = 0
    let mut continued_at = -1

    while i < 5 {
        iters = iters + 1
        if false {
            i = i + 9999
        } else {
            if i == 2 {
                continued_at = i
                i = i + 1   // bump before continue so we don't loop forever
                continue
            }
            // Trailing stmt — should NOT run when continue fired above.
            if i == 3 && continued_at == 2 {
                // i==3 reached normally only if the trailing path also ran
                // when i==2; track that.
                trailing_after_continue = trailing_after_continue + 1
            }
            i = i + 1
        }
    }

    // We expect to visit i = 0,1,2,3,4 — five iterations. After fix,
    // continue at i==2 must not double-bump i nor execute trailing logic.
    if iters != 5 { println("FAIL continue: iters =", iters); return 1 }
    return 0
}

fn t_break_inside_for() -> Int {
    // For-loop variant — same eval_body short-circuit applies.
    let xs = [10, 20, 30, 40, 50]
    let mut sum = 0
    let mut should_break = false
    let mut trailing_ran = 0
    for x in xs {
        if false {
            sum = sum + 9999
        } else {
            if x >= 30 {
                should_break = true
                break
            }
            if should_break { trailing_ran = trailing_ran + 1 }
            sum = sum + x
        }
    }
    if sum != 30 { println("FAIL for: sum =", sum); return 1 }
    if trailing_ran != 0 { println("FAIL for: trailing_ran =", trailing_ran); return 1 }
    return 0
}

fn run() -> Int {
    let mut failed = 0
    if t_shallow_break_in_else() != 0 { failed = failed + 1 }
    if t_deep_break_3_levels() != 0 { failed = failed + 1 }
    if t_deep_break_4_levels() != 0 { failed = failed + 1 }
    if t_continue_in_nested_else() != 0 { failed = failed + 1 }
    if t_break_inside_for() != 0 { failed = failed + 1 }

    if failed > 0 {
        println("break_nested_loop: FAIL —", failed, "test(s) failed")
        return 1
    }
    println("break_nested_loop: PASS — 5 tests")
    return 0
}

let _ = run()
