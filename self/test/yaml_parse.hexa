// self/test/yaml_parse.hexa — yaml_parse_safe contract test.
//
// Closes hexa-lang upstream gap #3 (per
//   docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md §2.2).
//
// EXECUTION SHAPE (gap #6 workaround)
//   self/test/* runs in a busybox-shell sandbox where
//   `use "self/stdlib/..."` is silenced and macOS-native binaries are
//   not exec-able. So this test verifies STRUCTURAL invariants of the
//   yaml stdlib file and delegates runtime conformance to the
//   --selftest baked into self/stdlib/yaml.hexa, run separately by
//   the caller (raw 91 honest disclosure).
//
//   The runtime selftest covers parse / emit / mutate / fixture
//   byte-eq end-to-end. This test verifies the stdlib's API surface +
//   shape contract so regressions surface before the runtime test
//   even runs.
//
// SENTINEL: __YAML_PARSE_TEST__ PASS|FAIL reason=<short>

fn _tr_sentinel(verdict: string, reason: string) {
    println("__YAML_PARSE_TEST__ " + verdict + " reason=" + reason)
}

fn _tr_run() -> int {
    let stdlib_path = "self/stdlib/yaml.hexa"

    let exists = to_string(exec("test -e " + stdlib_path + " && echo 1 || echo 0")).trim()
    if exists != "1" {
        _tr_sentinel("FAIL", "stdlib_missing")
        return 1
    }

    let body = read_file(stdlib_path)

    // 1. Public API surface (gap #3 contract).
    if !body.contains("fn yaml_parse_safe(text)") {
        _tr_sentinel("FAIL", "missing_yaml_parse_safe")
        return 1
    }
    if !body.contains("fn yaml_parse_or_throw(text)") {
        _tr_sentinel("FAIL", "missing_yaml_parse_or_throw")
        return 1
    }

    // 2. [bool, value] tuple shape (mirrors json_parse_safe).
    if !body.contains("return [false, void]") {
        _tr_sentinel("FAIL", "tuple_false_void_missing")
        return 1
    }
    if !body.contains("return [true, void]") && !body.contains("return [true, v]") {
        _tr_sentinel("FAIL", "tuple_true_value_missing")
        return 1
    }

    // 3. yaml 1.1 alias quirks (yes/no/on/off) NOT translated to bool.
    if body.contains("if s == \"yes\" { return true }") {
        _tr_sentinel("FAIL", "yaml_1_1_yes_quirk_leaked")
        return 1
    }
    if body.contains("if s == \"on\" { return true }") {
        _tr_sentinel("FAIL", "yaml_1_1_on_quirk_leaked")
        return 1
    }
    if body.contains("if s == \"no\" { return false }") {
        _tr_sentinel("FAIL", "yaml_1_1_no_quirk_leaked")
        return 1
    }

    // 4. yaml 1.2 core schema scalars present.
    if !body.contains("if s == \"true\" { return true }") {
        _tr_sentinel("FAIL", "true_scalar_missing")
        return 1
    }
    if !body.contains("if s == \"null\" { return void }") {
        _tr_sentinel("FAIL", "null_scalar_missing")
        return 1
    }

    // 5. Selftest entry points present (caller-invoked).
    if !body.contains("__YAML_SELFTEST__") {
        _tr_sentinel("FAIL", "selftest_sentinel_missing")
        return 1
    }
    if !body.contains("--selftest") {
        _tr_sentinel("FAIL", "selftest_argv_handler_missing")
        return 1
    }

    // 6. Real-world fixture readable.
    let fixture = "/Users/ghost/core/hive/spec/sync_registry.spec.yaml"
    let fx_check = to_string(exec("test -e " + fixture + " && echo 1 || echo 0")).trim()
    if fx_check != "1" {
        _tr_sentinel("FAIL", "fixture_missing")
        return 1
    }
    let fx = read_file(fixture)
    if len(fx) == 0 {
        _tr_sentinel("FAIL", "fixture_empty")
        return 1
    }
    if !fx.contains("repos:") || !fx.contains("name: hive") {
        _tr_sentinel("FAIL", "fixture_shape_drift")
        return 1
    }

    _tr_sentinel("PASS", "api_surface_tuple_shape_yaml_1_1_disabled_yaml_1_2_present_selftest_present_fixture_readable")
    return 0
}

fn main() {
    let rc = _tr_run()
    exit(rc)
}
