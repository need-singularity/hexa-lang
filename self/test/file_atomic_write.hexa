// self/test/file_atomic_write.hexa — atomic write contract test.
//
// Verifies file_atomic_write per hexa-lang upstream gap #9
// (docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md
// section 2.9).
//
// EXECUTION SHAPE (gap #6 workaround)
//   See self/test/file_sha256.hexa for the sandbox-disparity note.
//   self/test/* runs in a busybox-shell sandbox; `use` is silenced,
//   most external binaries (shasum, mktemp -d) are unavailable. So
//   this test verifies STRUCTURAL invariants of the stdlib file and
//   delegates runtime conformance to --selftest-file-atomic in
//   self/stdlib/file_atomic.hexa (T6, T7, T8 cover this primitive).
//
// Runtime selftest covers (in the stdlib --selftest-file-atomic):
//   - First write succeeds and content matches.
//   - Re-write replaces atomically; mid-write readers never see
//     partial content (rename(2) atomic on same FS).
//   - No orphan temp files left in the parent directory after
//     successful rename.
//
// SENTINEL: __FILE_ATOMIC_WRITE_TEST__ PASS|FAIL reason=<short>

fn _tw_sentinel(verdict: string, reason: string) {
    println("__FILE_ATOMIC_WRITE_TEST__ " + verdict + " reason=" + reason)
}

fn _tw_contains(haystack: string, needle: string) -> bool {
    let nh = len(haystack)
    let nn = len(needle)
    if nn == 0 { return true }
    if nh < nn { return false }
    let mut i = 0
    while i <= nh - nn {
        if haystack.substring(i, i + nn) == needle {
            return true
        }
        i = i + 1
    }
    return false
}

fn _tw_run() -> int {
    let stdlib_path = "self/stdlib/file_atomic.hexa"

    let exists = to_string(exec("test -e " + stdlib_path + " && echo 1 || echo 0")).trim()
    if exists != "1" {
        _tw_sentinel("FAIL", "stdlib_missing")
        return 1
    }

    let body = read_file(stdlib_path)

    // 1. Signature.
    if !_tw_contains(body, "pub fn file_atomic_write(path: string, content: string) -> array") {
        _tw_sentinel("FAIL", "signature_mismatch")
        return 1
    }

    // 2. Same-parent-dir temp file (the same-FS guarantee from
    //    rename(2) atomicity comes from staging the temp adjacent
    //    to the target).
    if !_tw_contains(body, "_fa_dirname(path)") {
        _tw_sentinel("FAIL", "dirname_staging_missing")
        return 1
    }
    if !_tw_contains(body, ".faw.") {
        _tw_sentinel("FAIL", "tmp_marker_missing")
        return 1
    }

    // 3. rename via mv.
    if !_tw_contains(body, "mv -f ") {
        _tw_sentinel("FAIL", "rename_call_missing")
        return 1
    }

    // 4. Post-condition verified.
    if !_tw_contains(body, "post-mv missing: ") {
        _tw_sentinel("FAIL", "post_condition_check_missing")
        return 1
    }

    // 5. Selftest covers write contract.
    if !_tw_contains(body, "file_atomic_write contract") {
        _tw_sentinel("FAIL", "selftest_write_section_missing")
        return 1
    }

    _tw_sentinel("PASS", "shape_signature_same_dir_temp_atomic_rename_postcheck_selftest_present")
    return 0
}

fn main() {
    let rc = _tw_run()
    exit(rc)
}
