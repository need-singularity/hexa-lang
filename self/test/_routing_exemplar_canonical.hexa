// self/test/_routing_exemplar_canonical.hexa
// ─────────────────────────────────────────────────────────────────────
// Exemplar fixture for docs/test_routing_2026_05_05.ai.md §4.
//
// Purpose:
//   Demonstrate the canonical "dual-surface" pattern — a single .hexa
//   test file that runs identically on:
//     surface A (default) — docker-landing into the hexa-exec container
//     surface B           — bare-Mac via HEXA_LOCAL=1, or by adding
//                           @resolver-bypass(reason="…") to this header.
//
// Run:
//   hexa run self/test/_routing_exemplar_canonical.hexa
//   HEXA_LOCAL=1 hexa run self/test/_routing_exemplar_canonical.hexa
//
// Sentinel:
//   __ROUTING_EXEMPLAR__ PASS surface=<A|B>      (exit 0)
//   __ROUTING_EXEMPLAR__ FAIL reason=<…>          (exit 1)
//
// Authoring rules this fixture obeys (see §3.1 of the routing doc):
//   1. uses ONLY busybox-intersection commands
//      (no shasum, no `stat -f`, no BSD `mktemp -t`).
//   2. imports stdlib via the form that resolves on both surfaces.
//   3. reads its routing-mode signature from env, does not assume it.
//   4. emits a unique sentinel line on PASS for parent-runner grep.
// ─────────────────────────────────────────────────────────────────────

use "stdlib/io"

// busybox-intersection self-check: every binary used here exists on
// both surfaces. The test prints one line per check; the final
// sentinel summarizes pass/fail.

fn detect_surface() {
    // The container sets HEXA_RESOLVER_IN_CONTAINER=1; bare-Mac does not.
    // (See tool/docs/resolver_bypass.md §"Container-side environment contract".)
    let in_container = env_var("HEXA_RESOLVER_IN_CONTAINER")
    if in_container == "1" { return "A" }
    return "B"
}

fn busybox_safe_check(tag, cmd, want_substr) {
    // exec() captures stdout; both `sh` and the subset of coreutils
    // used in `cmd` must exist on both surfaces. That's the contract.
    let got = exec(cmd).trim()
    if want_substr == "" {
        // Tag-only existence check — pass if the command produced ANY
        // output. Suitable for `uname -s`, `pwd`, etc.
        if len(got) > 0 {
            println("  PASS " + tag + " -> \"" + got + "\"")
            return true
        }
        println("  FAIL " + tag + " -> empty output")
        return false
    }
    if got.contains(want_substr) {
        println("  PASS " + tag + " contains \"" + want_substr + "\"")
        return true
    }
    println("  FAIL " + tag + " got=\"" + got + "\" want_substr=\"" + want_substr + "\"")
    return false
}

fn main() -> void {
    let surface = detect_surface()
    println("── routing exemplar — surface=" + surface + " ──")

    let mut pass = 0
    let mut fail = 0

    // ── 1. uname exists on both. busybox uname supports -s; BSD uname does too.
    if busybox_safe_check("uname_s", "uname -s 2>/dev/null", "") { pass = pass + 1 } else { fail = fail + 1 }

    // ── 2. echo / printf are universal.
    if busybox_safe_check("printf", "printf 'ok'", "ok") { pass = pass + 1 } else { fail = fail + 1 }

    // ── 3. wc -c works on both (reads stdin byte count).
    if busybox_safe_check("wc_c", "printf 'abc' | wc -c | tr -d ' '", "3") { pass = pass + 1 } else { fail = fail + 1 }

    // ── 4. mktemp without -t template (the busybox + BSD intersection
    //      for directory creation is `mktemp -d`).
    let tmpdir = exec("mktemp -d 2>/dev/null").trim()
    if len(tmpdir) > 0 {
        println("  PASS mktemp_d -> " + tmpdir)
        exec("rmdir '" + tmpdir + "' 2>/dev/null")
        pass = pass + 1
    } else {
        println("  FAIL mktemp_d -> empty")
        fail = fail + 1
    }

    // ── 5. stdlib import resolved on this surface (stdlib/io was the
    //      `use` at top of file; a successful run-to-here proves the
    //      module loader resolved it via either HEXA_STDLIB_ROOT
    //      (container) or HEXA_LANG (bare-Mac).
    println("  PASS stdlib_import — `use \"stdlib/io\"` resolved on surface=" + surface)
    pass = pass + 1

    // ── env-signature dump (informational, not a check).
    let hl = env_var("HEXA_LANG")
    let sr = env_var("HEXA_STDLIB_ROOT")
    let nr = env_var("HEXA_RESOLVER_NO_REROUTE")
    let ic = env_var("HEXA_RESOLVER_IN_CONTAINER")
    println("  ENV HEXA_LANG=" + (if len(hl) > 0 { hl } else { "<unset>" }))
    println("  ENV HEXA_STDLIB_ROOT=" + (if len(sr) > 0 { sr } else { "<unset>" }))
    println("  ENV HEXA_RESOLVER_NO_REROUTE=" + (if len(nr) > 0 { nr } else { "<unset>" }))
    println("  ENV HEXA_RESOLVER_IN_CONTAINER=" + (if len(ic) > 0 { ic } else { "<unset>" }))

    if fail == 0 {
        println("__ROUTING_EXEMPLAR__ PASS surface=" + surface + " checks=" + to_string(pass))
        exit(0)
    } else {
        println("__ROUTING_EXEMPLAR__ FAIL surface=" + surface + " pass=" + to_string(pass) + " fail=" + to_string(fail))
        exit(1)
    }
}
