// self/test/yaml_emit.hexa — yaml_emit contract test.
//
// Closes part of hexa-lang upstream gap #3 (per
//   docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md §2.2).
//
// EXECUTION SHAPE (gap #6 workaround — same convention as yaml_parse.hexa)
//   self/test/* runs in a busybox-shell sandbox where
//   `use "self/stdlib/..."` is silenced. Structural verification only;
//   runtime conformance covered by the stdlib --selftest.
//
// Contract verified here:
//   - yaml_emit(value, opts) signature.
//   - Block-style dispatch covers map / array / scalar.
//   - Quote rule recognises yaml 1.2 reserved words (null/true/false).
//   - opts.indent default = 2 (yaml convention).
//
// SENTINEL: __YAML_EMIT_TEST__ PASS|FAIL reason=<short>

fn _tr_sentinel(verdict: string, reason: string) {
    println("__YAML_EMIT_TEST__ " + verdict + " reason=" + reason)
}

fn _tr_run() -> int {
    let stdlib_path = "self/stdlib/yaml.hexa"

    let exists = to_string(exec("test -e " + stdlib_path + " && echo 1 || echo 0")).trim()
    if exists != "1" {
        _tr_sentinel("FAIL", "stdlib_missing")
        return 1
    }
    let body = read_file(stdlib_path)

    // 1. Public emitter signature.
    if !body.contains("fn yaml_emit(value, opts)") {
        _tr_sentinel("FAIL", "missing_yaml_emit")
        return 1
    }

    // 2. Block-style dispatch covers all three leaf kinds.
    if !body.contains("fn _yml_emit_map(") {
        _tr_sentinel("FAIL", "missing_emit_map")
        return 1
    }
    if !body.contains("fn _yml_emit_list(") {
        _tr_sentinel("FAIL", "missing_emit_list")
        return 1
    }
    if !body.contains("fn _yml_emit_scalar(") {
        _tr_sentinel("FAIL", "missing_emit_scalar")
        return 1
    }

    // 3. Scalar quoting rule recognises yaml 1.2 reserved words.
    if !body.contains("fn _yml_scalar_needs_quotes(") {
        _tr_sentinel("FAIL", "missing_quote_decider")
        return 1
    }
    if !body.contains("if s == \"null\"") {
        _tr_sentinel("FAIL", "null_quote_rule_missing")
        return 1
    }
    if !body.contains("if s == \"true\"") {
        _tr_sentinel("FAIL", "true_quote_rule_missing")
        return 1
    }

    // 4. opts.indent default 2.
    if !body.contains("indent_step = 2") {
        _tr_sentinel("FAIL", "indent_default_drift")
        return 1
    }

    // 5. Double-quote escape table.
    if !body.contains("fn _yml_quote_dq(") {
        _tr_sentinel("FAIL", "missing_dq_emitter")
        return 1
    }
    let dq_idx = body.index_of("fn _yml_quote_dq(")
    if dq_idx < 0 {
        _tr_sentinel("FAIL", "dq_idx_lookup_failed")
        return 1
    }
    let dq_chunk = body.substring(dq_idx, dq_idx + 600)
    if !dq_chunk.contains("\\n") || !dq_chunk.contains("\\t") || !dq_chunk.contains("\\\\") {
        _tr_sentinel("FAIL", "dq_escape_table_drift")
        return 1
    }

    // 6. Block-list emitter shape (`- ` marker).
    if !body.contains("- ") {
        _tr_sentinel("FAIL", "list_item_marker_missing")
        return 1
    }

    _tr_sentinel("PASS", "emitter_dispatch_quote_rule_indent_default_dq_escapes_present")
    return 0
}

fn main() {
    let rc = _tr_run()
    exit(rc)
}
