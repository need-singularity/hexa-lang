// self/test/null_literal_compile_error.hexa — FIX-NULL regression test
// ─────────────────────────────────────────────────────────────────────────
// hexa has no `null` literal. Canonical idiom for void/undefined check:
//     if type_of(x) == "void" { ... }
//
// PRIOR (silent-fail): `if x == null { ... }` parsed as `x == <Ident null>`,
// env_lookup returned val_void(), comparison evaluated to false, body
// silently skipped. User saw zero diagnostic — gap-5 silent-stale class.
//
// FIX: parse_primary (self/parser.hexa + self/hexa_full.hexa) recognizes
// the `null` Ident and emits a Parse error pointing to the canonical
// idiom; entry-point check (self/hexa_full.hexa near interpret(_hx_ast))
// aborts with exit(1) when p_has_errors().
//
// This test verifies the fix end-to-end:
//   1. Spawn a probe .hexa containing `if x == null { ... }`.
//   2. Assert exit(1).
//   3. Assert stderr/stdout contains the canonical-idiom hint.
//   4. Assert the void-idiom equivalent still works (regression-free).

fn _exec_capture(cmd) {
    // exec() returns combined stdout (popen). We pipe stderr→stdout for
    // the purpose of asserting the diagnostic text appears anywhere.
    return exec(cmd + " 2>&1")
}

fn _exit_code(cmd) {
    // Use `cmd; echo __RC=$?` sentinel to capture exit code through
    // exec()'s stdout-only popen. Mirrors cmd_run's __HEXA_RC pattern.
    let out = exec(cmd + " 2>/dev/null; echo __RC=$?")
    let lines = out.split("\n")
    let mut i = len(lines) - 1
    while i >= 0 {
        let line = lines[i].trim()
        if line.starts_with("__RC=") {
            return to_int(line.substring(5, len(line)))
        }
        i = i - 1
    }
    return -1
}

fn _resolve_hexa() {
    // Prefer $HEXA_LANG/hexa, fall back to ./hexa, then PATH lookup.
    let hl = env_var("HEXA_LANG")
    if hl != "" {
        let p = hl + "/hexa"
        if file_exists(p) { return p }
    }
    if file_exists("./hexa") { return "./hexa" }
    let pwd = exec("pwd").trim()
    if pwd != "" {
        let p = pwd + "/hexa"
        if file_exists(p) { return p }
    }
    return "hexa"
}

fn test_null_literal_emits_parse_error() {
    let probe = "/tmp/hexa_null_literal_probe.hexa"
    let body = "fn check(x) {\n" +
               "  if x == null {\n" +
               "    return \"is_null\"\n" +
               "  }\n" +
               "  return \"not_null\"\n" +
               "}\n" +
               "fn main() {\n" +
               "  let r = check(\"hello\")\n" +
               "  println(r)\n" +
               "}\n"
    write_file(probe, body)
    let hexa = _resolve_hexa()
    // HEXA_LOCAL=1 bypasses the darwin shim's container routing — required
    // for in-tree dev runs where the hexa-exec container may not be live.
    let cmd = "HEXA_LOCAL=1 '" + hexa + "' run '" + probe + "'"
    let rc = _exit_code(cmd)
    if rc == 0 {
        eprintln("FAIL: expected non-zero exit on `if x == null` parse error, got 0")
        eprintln("      (silent-fail regressed — gap-5 forbid-silent-stale violated)")
        exit(1)
    }
    let out = _exec_capture(cmd)
    let want = "`null` is not a hexa literal"
    if !out.contains(want) {
        eprintln("FAIL: expected diagnostic to contain: " + want)
        eprintln("      got output:")
        eprintln(out)
        exit(1)
    }
    let want2 = "type_of(x) == \"void\""
    if !out.contains(want2) {
        eprintln("FAIL: expected diagnostic to point to canonical idiom: " + want2)
        eprintln("      got output:")
        eprintln(out)
        exit(1)
    }
    println("PASS: `if x == null` emits clear parse error with canonical-idiom hint (rc=" + to_string(rc) + ")")
}

fn test_void_idiom_still_works() {
    // Regression-guard: the canonical `type_of(x) == "void"` idiom must
    // continue to compile + run cleanly after the FIX-NULL parse-time
    // rejection. If this regressed, the fix would be too aggressive.
    let probe = "/tmp/hexa_void_idiom_probe.hexa"
    let body = "fn check(x) {\n" +
               "  if type_of(x) == \"void\" {\n" +
               "    return \"is_void\"\n" +
               "  }\n" +
               "  return \"not_void\"\n" +
               "}\n" +
               "fn main() {\n" +
               "  let r = check(\"hello\")\n" +
               "  println(r)\n" +
               "}\n"
    write_file(probe, body)
    let hexa = _resolve_hexa()
    let cmd = "HEXA_LOCAL=1 '" + hexa + "' run '" + probe + "'"
    let rc = _exit_code(cmd)
    if rc != 0 {
        eprintln("FAIL: void-idiom probe regressed — expected exit 0, got " + to_string(rc))
        let out = _exec_capture(cmd)
        eprintln(out)
        exit(1)
    }
    let out = _exec_capture(cmd)
    if !out.contains("not_void") {
        eprintln("FAIL: void-idiom probe ran but did not produce expected output 'not_void'")
        eprintln(out)
        exit(1)
    }
    println("PASS: canonical `type_of(x) == \"void\"` idiom still compiles+runs cleanly")
}

fn main() {
    println("== self/test/null_literal_compile_error ==")
    test_null_literal_emits_parse_error()
    test_void_idiom_still_works()
    println("ALL PASS")
}
