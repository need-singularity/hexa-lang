// @resolver-bypass(reason="local git probe — darwin-native exec + scratch git init")
// self/test/git_fast_forward.hexa — git stdlib gap-8 fixture: git_fast_forward
//
// Read-only test against an ISOLATED scratch repo. We do NOT touch the
// hexa-lang repo's working state — fast-forward is a write op. Instead:
//   1. mkdir + git init in /tmp
//   2. make 2 commits
//   3. point refs/remotes/origin/main at HEAD (no real remote needed)
//   4. call git_fast_forward(scratch, "origin", "main") → expect kind=noop
//   5. teardown
//
// Sentinel on PASS:
//   __GIT_FAST_FORWARD_TEST__ PASS kind=noop
//
// This satisfies the spec verify line:
//   "hexa run self/test/git_fast_forward.hexa → exit 0 + sentinel kind=noop"
// without needing the hexa-lang repo to have a remote tracking branch.

use "self/stdlib/git"
use "self/stdlib/shell_escape"

fn main() {
    let pid = to_string(exec("echo $$")).trim()
    let scratch = "/tmp/_hexa_git_ff_test_" + pid
    let _drop1 = exec("rm -rf " + shell_escape(scratch))
    let _mk1 = exec("mkdir -p " + shell_escape(scratch))

    let r = scratch + "/repo"
    let setup = "set -e; " +
        "mkdir -p " + shell_escape(r) + "; " +
        "cd " + shell_escape(r) + "; " +
        "git init -q -b main; " +
        "git config user.email gff-test@example.invalid; " +
        "git config user.name gff-test; " +
        "echo a > a.txt; git add a.txt; git commit -q -m c1; " +
        "echo b > b.txt; git add b.txt; git commit -q -m c2; " +
        "head_sha=$(git rev-parse HEAD); " +
        "git update-ref refs/remotes/origin/main $head_sha"
    let setup_pair = exec_with_status(setup + " 2>&1")
    if setup_pair[1] != 0 {
        eprintln("git_fast_forward test: scratch setup failed: " + to_string(setup_pair[0]))
        let _drop_err = exec("rm -rf " + shell_escape(scratch))
        exit(1)
    }

    let h = git_head(r)
    if h["ok"] != true {
        eprintln("git_fast_forward test: scratch repo git_head failed")
        let _drop_err2 = exec("rm -rf " + shell_escape(scratch))
        exit(1)
    }
    let head_sha = to_string(h["sha"])

    let ff = git_fast_forward(r, "origin", "main")
    let kind = to_string(ff["kind"])
    let before = to_string(ff["before"])
    let after = to_string(ff["after"])
    let ok = ff["ok"]

    let _drop2 = exec("rm -rf " + shell_escape(scratch))

    if kind != "noop" {
        eprintln("git_fast_forward test: expected kind=noop got kind=" + kind)
        exit(1)
    }
    if ok != true {
        eprintln("git_fast_forward test: expected ok=true got ok=" + to_string(ok))
        exit(1)
    }
    if before != head_sha || after != head_sha {
        eprintln("git_fast_forward test: before/after mismatch — head=" + head_sha + " before=" + before + " after=" + after)
        exit(1)
    }

    println("__GIT_FAST_FORWARD_TEST__ PASS kind=noop")
}

