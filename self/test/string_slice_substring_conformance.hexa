// string_slice_substring_conformance — hexa-lang upstream gap #2 lock
//
// Spec: docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md §2.1
// Symptom that drove this test: tool/raw_mk2_loader.hexa initially used
//   id_str.slice(0, dot_pos)
// which returned "" in Darwin AOT runtime; substring(0, dot_pos) worked.
// Same name, divergent behavior across compile modes = drift hazard.
//
// Decision (2026-05-05): canonical name is `substring(start, end)`.
// `slice` is a byte-identical alias delegating to substring at every layer:
//   - runtime.c hexa_str_slice → hexa_str_substring (one-line forward)
//   - interpreter self/hexa_full.hexa method=="slice" → s.substring(a,b)
//                                       method=="substring" clamps identically
//   - stdlib/string.hexa pub fn slice(s,a,b) → substring(s,a,b)
//
// Coverage matrix (mode × method × edge case):
//   modes:   default route (resolver may reroute) AND HEXA_RESOLVER_NO_REROUTE=1
//   methods: .substring(a,b)  .slice(a,b)  .slice(a)
//   edges:   empty range, full range, out-of-bound end, negative start,
//            start>=end, on multibyte UTF-8, empty string, single char
//
// EXPECTED: every line begins with PASS; final line is ALL PASS.

let mut __failed = 0

fn check(label, cond) {
    if cond {
        println("PASS " + label)
    } else {
        println("FAIL " + label)
        __failed = __failed + 1
    }
}

// ── 1. Identity: slice and substring produce identical bytes ────────────
let s = "resource.015"
let dot = s.index_of(".")
check("dot_pos=8", dot == 8)
check("substring_dom", s.substring(0, dot) == "resource")
check("slice_dom", s.slice(0, dot) == "resource")
check("substring_eq_slice_dom", s.substring(0, dot) == s.slice(0, dot))
check("substring_seq", s.substring(dot + 1, len(s)) == "015")
check("slice_seq", s.slice(dot + 1, len(s)) == "015")

// ── 2. Empty range ─────────────────────────────────────────────────────
check("substring_empty_eq", s.substring(3, 3) == "")
check("slice_empty_eq", s.slice(3, 3) == "")
check("substring_empty_inv", s.substring(5, 2) == "")
check("slice_empty_inv", s.slice(5, 2) == "")

// ── 3. Full range ──────────────────────────────────────────────────────
check("substring_full", s.substring(0, len(s)) == s)
check("slice_full", s.slice(0, len(s)) == s)

// ── 4. Out-of-bound end (must clamp, not crash) ───────────────────────
check("substring_oob_end", s.substring(0, 999) == s)
check("slice_oob_end", s.slice(0, 999) == s)
check("substring_oob_mid", s.substring(4, 999) == "urce.015")
check("slice_oob_mid", s.slice(4, 999) == "urce.015")

// ── 5. Negative start (must clamp to 0) ───────────────────────────────
check("substring_neg_start", s.substring(-3, 8) == "resource")
check("slice_neg_start", s.slice(-3, 8) == "resource")

// ── 6. start>=end edge ─────────────────────────────────────────────────
check("substring_eq_idx", s.substring(7, 7) == "")
check("slice_eq_idx", s.slice(7, 7) == "")
check("substring_gt_idx", s.substring(10, 5) == "")
check("slice_gt_idx", s.slice(10, 5) == "")

// ── 7. Empty string receiver ───────────────────────────────────────────
let empty = ""
check("substring_empty_recv", empty.substring(0, 0) == "")
check("slice_empty_recv", empty.slice(0, 0) == "")
check("substring_empty_oob", empty.substring(0, 5) == "")
check("slice_empty_oob", empty.slice(0, 5) == "")

// ── 8. Single character ────────────────────────────────────────────────
let one = "x"
check("substring_one_full", one.substring(0, 1) == "x")
check("slice_one_full", one.slice(0, 1) == "x")
check("substring_one_empty", one.substring(0, 0) == "")
check("slice_one_empty", one.slice(0, 0) == "")
check("substring_one_oob", one.substring(0, 99) == "x")
check("slice_one_oob", one.slice(0, 99) == "x")

// ── 9. Byte-indexed UTF-8 (multibyte boundaries) ──────────────────────
// "한" is 3 bytes in UTF-8 (e1 95 9c → wait actually "한" = ed 95 9c).
// Both methods use byte indices (matches len(), index_of()).
let ko = "한글hi"
check("ko_len=8", len(ko) == 8)
check("substring_ko_first_char", ko.substring(0, 3) == "한")
check("slice_ko_first_char", ko.slice(0, 3) == "한")
check("substring_ko_second", ko.substring(3, 6) == "글")
check("slice_ko_second", ko.slice(3, 6) == "글")
check("substring_ko_ascii_tail", ko.substring(6, 8) == "hi")
check("slice_ko_ascii_tail", ko.slice(6, 8) == "hi")

// ── 10. .slice(start) — single-arg form (interpreter convenience) ───
// AOT codegen emits 2-arg, but interpreter supports the one-arg form
// where end defaults to len(s). Test interpreter only-form via length:
// This works in interp; in AOT the codegen requires 2 args so we skip
// the literal one-arg call to keep the test runnable in both modes.
check("slice_two_arg_to_end", "hello".slice(2, len("hello")) == "llo")
check("substring_to_end_eq", "hello".substring(2, len("hello")) == "llo")

// ── 11. Symmetry property: substring(a,b) == slice(a,b) for all (a,b) ──
let probe = "abcdefghij"
let mut a = -2
while a <= 12 {
    let mut b = -2
    while b <= 12 {
        let lhs = probe.substring(a, b)
        let rhs = probe.slice(a, b)
        if lhs != rhs {
            println("FAIL symmetry a=" + to_string(a) + " b=" + to_string(b) + " sub=[" + lhs + "] slc=[" + rhs + "]")
            __failed = __failed + 1
        }
        b = b + 1
    }
    a = a + 1
}
println("PASS symmetry_sweep")

// ── 12. Loader-shape regression: domain extraction from rule-id ───────
// Direct reproduction of the bug observed in tool/raw_mk2_loader.hexa
// (hive repo). Both forms must produce identical 8-char domain prefix.
fn extract_domain_via_substring(id) {
    let p = id.index_of(".")
    if p < 1 { return "" }
    return id.substring(0, p)
}
fn extract_domain_via_slice(id) {
    let p = id.index_of(".")
    if p < 1 { return "" }
    return id.slice(0, p)
}
let ids = ["resource.015", "dispatch.001", "format-grammar.004", "ai-native.025"]
for id in ids {
    let viaA = extract_domain_via_substring(id)
    let viaB = extract_domain_via_slice(id)
    if viaA != viaB || viaA == "" {
        println("FAIL loader_shape id=" + id + " sub=[" + viaA + "] slc=[" + viaB + "]")
        __failed = __failed + 1
    }
}
println("PASS loader_shape_sweep")

// ── 13. Related drift: index_of, replace, split round-trip ─────────────
// These methods are in the same family; their stability is asserted here
// to catch regressions detected in the same gap-2 cleanup.
check("index_of_present", "resource.015".index_of(".") == 8)
check("index_of_absent", "noseparator".index_of(".") == -1)
check("index_of_at_zero", ".leading".index_of(".") == 0)
check("replace_simple", "a.b.c".replace(".", "/") == "a/b/c")
check("replace_no_match", "abc".replace(".", "/") == "abc")
check("replace_to_empty", "a.b".replace(".", "") == "ab")

let parts = "a,b,c,d".split(",")
check("split_count", len(parts) == 4)
check("split_first", parts[0] == "a")
check("split_last", parts[3] == "d")

let nodelim = "abc".split(",")
check("split_nodelim_count", len(nodelim) == 1)
check("split_nodelim_value", nodelim[0] == "abc")

// ── 14. Final summary line ─────────────────────────────────────────────
if __failed == 0 {
    println("ALL PASS")
} else {
    println("FAIL TOTAL=" + to_string(__failed))
    exit(1)
}
