// @resolver-bypass(reason="macos url handler test fixture — darwin-native exec to lsregister/uname/launchctl-shaped audit")
// self/test/macos_url_handler.hexa — fixture for the LaunchServices
// URL-scheme stdlib (self/stdlib/macos_url_handler.hexa).
// ─────────────────────────────────────────────────────────────────────
//
// Closes hexa-lang upstream gap #1 — subtask S-22.3 of the
// LSRegisterURL+app-bundler plan
// (hive/docs/lsregister_url_handler_plan_2026_05_05.ai.md §S-22.3).
//
// Strategy
//   We delegate the actual assertion work to the stdlib's own
//   `--selftest` dispatcher rather than `use`-importing the stdlib
//   here. Two reasons:
//     1. The stdlib selftest already covers 19 invariants — whitelist
//        validation, dump-parser, lsregister-binary resolution, and
//        every dry-run path. Re-asserting those here would just
//        duplicate test surface.
//     2. On the diag/orpheus-selftest-sigkill branch (commit 544d0064),
//        cmd_run's parent-death watchdog kills interp children whose
//        path contains `/test/` (which forces should_cache=false →
//        interp+module_loader path → watchdog SIGKILL race) before
//        their stdout drains, so a `use "self/stdlib/..."` test
//        fixture in self/test/ produces silent rc=0. Sub-process
//        delegation via `hexa run --selftest` bypasses that route
//        because the stdlib script itself qualifies for the AOT
//        cache (it's not under self/test/) and `--selftest` triggers
//        the metadata-only-argv darwin-bypass.
//
//   We additionally re-run a few read-only invariants here to prove
//   the test fixture itself is alive (not silently no-op'd by a
//   skipped subprocess). Those don't need the stdlib import — they
//   walk the lsregister CLI directly.
//
// Sentinels (raw#91 honest disclosure)
//   __MACOS_URL_HANDLER_TEST__ PASS    — stdlib selftest passed AND
//                                        local invariants held
//   __MACOS_URL_HANDLER_TEST__ SKIPPED reason=...
//                                        — host is non-Darwin
//   __MACOS_URL_HANDLER_TEST__ FAIL n=<int> fail=<int>
//                                        — at least one case violated;
//                                          stderr carries per-case
//                                          diagnostics

// ── Top-level test sequence ────────────────────────────────────────
//
// We run as a sequence of top-level statements (rather than a
// `fn main() { ... }` body) so the script is import-trivial and the
// AOT cache slot is identical across cold/warm runs.

let mut _t_fail = 0
let mut _t_n = 0

let _t_uname = to_string(exec("uname -s 2>/dev/null")).trim()
if _t_uname != "Darwin" {
    println("__MACOS_URL_HANDLER_TEST__ SKIPPED reason=not-darwin")
    exit(0)
}

// 1. The lsregister CLI must be locatable on this Darwin host. We use
//    the same resolution order as the stdlib: xcrun first, canonical
//    /System/Library path fallback. If neither resolves, the stdlib
//    can't talk to LaunchServices at all and the test is meaningless.
_t_n = _t_n + 1
let _t_via_xcrun = to_string(exec("xcrun --find lsregister 2>/dev/null")).trim()
let _t_canonical = "/System/Library/Frameworks/CoreServices.framework/Versions/A/Frameworks/LaunchServices.framework/Support/lsregister"
let _t_canon_chk = to_string(exec("test -x '" + _t_canonical + "' && echo 1 || echo 0")).trim()
if len(_t_via_xcrun) == 0 && _t_canon_chk != "1" {
    eprintln("FAIL 1 lsregister not resolvable via xcrun nor canonical path")
    _t_fail = _t_fail + 1
}

// 2. Sub-process delegation: invoke the stdlib selftest. We feed
//    --selftest so the metadata-only-argv darwin-bypass takes the
//    fast path. The stdlib emits __MACOS_URL_HANDLER__ PASS|FAIL on
//    its own stdout; we parse for PASS.
//
//    Resolution: the canonical script path is relative to the
//    hexa-lang repo root. Callers run this fixture from the repo
//    root (same as every other fixture in self/test/), so a relative
//    "self/stdlib/macos_url_handler.hexa" resolves correctly.
_t_n = _t_n + 1
let _t_stdlib_out = to_string(exec("hexa run self/stdlib/macos_url_handler.hexa --selftest 2>&1"))
if !_t_stdlib_out.contains("__MACOS_URL_HANDLER__ PASS") {
    eprintln("FAIL 2 stdlib selftest did not emit PASS sentinel; output:")
    eprintln(_t_stdlib_out)
    _t_fail = _t_fail + 1
}

// 3. lsregister -dump on a fresh shell run is non-empty. If LaunchServices
//    DB is empty we have a deeper problem; the stdlib's dump-parser
//    can't extract anything useful. We just probe size > 0.
_t_n = _t_n + 1
let _t_dump_size = to_string(exec(_t_canonical + " -dump 2>/dev/null | wc -c | tr -d ' '")).trim()
let _t_dump_n = to_int(_t_dump_size)
if _t_dump_n == 0 {
    eprintln("FAIL 3 lsregister -dump returned empty body — LaunchServices DB unreachable?")
    _t_fail = _t_fail + 1
}

// 4. Live-mode disclosure. If HEXA_LS_REGISTER_LIVE=1 was set, we
//    deliberately do NOT run the actual register call here — that
//    work belongs to S-22.4 (e2e verify with a real .app bundle
//    placed under /Applications). We just record that the harness
//    saw the env and would have run live had the bundle existed.
let _t_live_env = env_var("HEXA_LS_REGISTER_LIVE")
let _t_live_on = len(_t_live_env) > 0 && _t_live_env != "0"
if _t_live_on {
    eprintln("note: HEXA_LS_REGISTER_LIVE=1 detected — live e2e is " +
             "deferred to S-22.4 (verify_url_registration.hexa). " +
             "This fixture stays read-only.")
}

if _t_fail == 0 {
    println("__MACOS_URL_HANDLER_TEST__ PASS n=" + to_string(_t_n) + " fail=0")
} else {
    println("__MACOS_URL_HANDLER_TEST__ FAIL n=" + to_string(_t_n) + " fail=" + to_string(_t_fail))
    exit(1)
}
