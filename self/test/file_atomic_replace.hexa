// self/test/file_atomic_replace.hexa — atomic replace contract test.
//
// Verifies file_atomic_replace per hexa-lang upstream gap #9
// (docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md
// section 2.9). The replace primitive is what the path-patch handler
// uses to re-apply an idempotent patch over a redeployed binary
// (resource.016 forbids `chflags uchg` sealing — replace is the
// non-sealing alternative).
//
// EXECUTION SHAPE (gap #6 workaround)
//   See self/test/file_sha256.hexa for the full sandbox-disparity
//   note. TL;DR: self/test/* runs in a busybox-shell sandbox where
//   `use "self/stdlib/..."` is silenced and most binaries are not
//   on PATH. So this test verifies STRUCTURAL invariants of the
//   stdlib file and delegates runtime conformance to the
//   --selftest-file-atomic baked into self/stdlib/file_atomic.hexa.
//
//   The runtime selftest covers (T11, T12 in the stdlib selftest):
//     - target's pre-replace mode preserved post-replace
//     - target's post-replace sha256 == source's pre-replace sha256
//     - source consumed by rename(2) (not present after replace)
//     - first-time create (target absent) succeeds
//
// SENTINEL: __FILE_ATOMIC_REPLACE_TEST__ PASS|FAIL reason=<short>

fn _tr_sentinel(verdict: string, reason: string) {
    println("__FILE_ATOMIC_REPLACE_TEST__ " + verdict + " reason=" + reason)
}

fn _tr_contains(haystack: string, needle: string) -> bool {
    let nh = len(haystack)
    let nn = len(needle)
    if nn == 0 { return true }
    if nh < nn { return false }
    let mut i = 0
    while i <= nh - nn {
        if haystack.substring(i, i + nn) == needle {
            return true
        }
        i = i + 1
    }
    return false
}

fn _tr_run() -> int {
    let stdlib_path = "self/stdlib/file_atomic.hexa"

    // 1. Stdlib file present.
    let exists = to_string(exec("test -e " + stdlib_path + " && echo 1 || echo 0")).trim()
    if exists != "1" {
        _tr_sentinel("FAIL", "stdlib_missing")
        return 1
    }

    let body = read_file(stdlib_path)

    // 2. Exports `pub fn file_atomic_replace`.
    if !_tr_contains(body, "pub fn file_atomic_replace(target_path: string, source_path: string) -> array") {
        _tr_sentinel("FAIL", "signature_mismatch")
        return 1
    }

    // 3. Mode-preservation invariant is implemented (look for the
    //    capture-then-reapply sequence described in §2.9).
    if !_tr_contains(body, "_fa_get_mode(target_path)") {
        _tr_sentinel("FAIL", "mode_capture_missing")
        return 1
    }
    if !_tr_contains(body, "file_set_executable(target_path, orig_mode)") {
        _tr_sentinel("FAIL", "mode_reapply_missing")
        return 1
    }

    // 4. Atomic-rename is via `mv -f` (rename(2) on same FS).
    if !_tr_contains(body, "mv -f ") {
        _tr_sentinel("FAIL", "rename_call_missing")
        return 1
    }

    // 5. Post-condition is verified (raw 91 no_silent_errors).
    if !_tr_contains(body, "post-mv missing") {
        _tr_sentinel("FAIL", "post_condition_check_missing")
        return 1
    }

    // 6. Selftest covers replace specifically (T11 + T12 markers).
    if !_tr_contains(body, "file_atomic_replace contract") {
        _tr_sentinel("FAIL", "selftest_replace_section_missing")
        return 1
    }

    _tr_sentinel("PASS", "shape_signature_mode_capture_atomic_rename_postcheck_selftest_present")
    return 0
}

fn main() {
    let rc = _tr_run()
    exit(rc)
}
