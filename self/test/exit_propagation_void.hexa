// self/test/exit_propagation_void.hexa
//
// Conformance test for hexa-lang upstream gap #5 (per
// docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md §2.4):
// `exit(N)` from inside a function declared `-> void` MUST reach the
// OS so that the parent shell sees `$? == N`.
//
// Verification (run from a parent shell):
//
//     HEXA_LOCAL=1 ~/.hx/bin/hexa self/test/exit_propagation_void.hexa
//     echo "rc=$?"
//     # expected: rc=4
//
// Regression marker: pre-fix the AOT runtime emitted rc=0 for this
// shape because void-fn exit was treated as control-flow rather than
// process termination. Codegen sites of interest:
//   self/codegen_c2.hexa:3802 — `exit` builtin → `hexa_exit(code)`
//   self/runtime.c:6285       — `hexa_exit` → fflush + libc exit(c)
//   self/codegen_c2.hexa:1340 — implicit-tail-return _skip-list
//                                (exit is excluded from tail rewrite)

fn op_handler(host: string) -> void {
    if host == "" {
        eprintln("__EXIT_PROP_VOID__ FAIL reason=missing-host")
        exit(4)
    }
    println("__EXIT_PROP_VOID__ unreachable-print")
    exit(0)
}

fn dispatch(verb: string, host: string) -> void {
    if verb == "status" {
        op_handler(host)
    } else {
        eprintln("__EXIT_PROP_VOID__ FAIL reason=unknown-verb")
        exit(5)
    }
}

dispatch("status", "")
println("__EXIT_PROP_VOID__ UNREACHABLE-AFTER-DISPATCH")
