// @resolver-bypass(reason="local git probe — darwin-native exec to bare git binary")
// self/test/git_status.hexa — git stdlib gap-8 fixture: git_status
//
// Read-only test against the hexa-lang repo itself. Asserts:
//   · git_status returns a value with all 5 expected keys
//   · head_sha is non-empty 40-hex
//   · ahead == 0 (we never push from a test fixture)
//   · behind == 0 (we don't fetch in tests; if upstream is configured
//                  and behind, this assertion is honest about the
//                  precondition: clean tree + caught up. We SKIP if
//                  the precondition fails to keep the test deterministic
//                  across developer machines.)
//
// Sentinel on PASS:
//   __GIT_STATUS_TEST__ PASS head_sha=<sha> ahead=0 behind=0 dirty=<bool> diverged=<bool>
// SKIP if dirty (tree has uncommitted changes) — keeps the fixture
// usable on a working repo without requiring a clean checkout.

use "self/stdlib/git"
use "self/stdlib/shell_escape"

fn _resolve_repo_root() -> string {
    let mut p = to_string(exec("pwd")).trim()
    let mut depth = 0
    while depth < 32 {
        if len(p) == 0 { break }
        let chk = exec_with_status("test -d " + shell_escape(p + "/.git"))
        if chk[1] == 0 { return p }
        if p == "/" { break }
        let mut last = -1
        let mut k = len(p) - 1
        while k >= 0 {
            if p.substring(k, k + 1) == "/" { last = k; break }
            k = k - 1
        }
        if last <= 0 { p = "/" } else { p = p.substring(0, last) }
        depth = depth + 1
    }
    return ""
}

fn main() {
    let repo = _resolve_repo_root()
    if len(repo) == 0 {
        println("__GIT_STATUS_TEST__ SKIP reason=no_repo")
        return
    }

    let st = git_status(repo)
    let head_sha = to_string(st["head_sha"])
    let ahead = st["ahead"]
    let behind = st["behind"]
    let diverged = st["diverged"]
    let dirty = st["dirty"]

    if len(head_sha) == 0 {
        eprintln("git_status test: empty head_sha at " + repo)
        exit(1)
    }
    if len(head_sha) != 40 {
        eprintln("git_status test: head_sha not 40 chars: '" + head_sha + "'")
        exit(1)
    }

    // dirty tree → SKIP rather than fail. Constraint from spec:
    // "ahead=0 + behind=0 (clean working tree assumption — skip if dirty)".
    if dirty == true {
        println("__GIT_STATUS_TEST__ SKIP reason=dirty head_sha=" + head_sha)
        return
    }

    if ahead != 0 {
        eprintln("git_status test: expected ahead=0 got " + to_string(ahead))
        exit(1)
    }
    if behind != 0 {
        eprintln("git_status test: expected behind=0 got " + to_string(behind))
        exit(1)
    }
    if diverged == true {
        eprintln("git_status test: unexpected diverged=true")
        exit(1)
    }

    println("__GIT_STATUS_TEST__ PASS head_sha=" + head_sha + " ahead=0 behind=0 dirty=false diverged=false")
}

