// ═══════════════════════════════════════════════════════════════
//  test_darts_nas.hexa — DARTS NAS (#277) tests
//
//  Verifies:
//    1. softmax sums to 1 over logits
//    2. softmax equal at zero logits
//    3. softmax_backward zero when grad is uniform (invariant)
//    4. cell init: alpha zeros, K=2, d ok
//    5. forward at init = 0.5*(op0 + op1)
//    6. MSE positive on random init
//    7. train_step_w reduces loss
//    8. train_step_alpha modifies alpha
//    9. alpha_k softmax still sums to 1 post update
//   10. bilevel search reduces both train and val loss
//   11. linear target ⇒ alpha prefers linear op
//   12. selected_op returns 0 or 1
//   13. arch weights sum to 1
//
//  Run: ./hexa self/test_darts_nas.hexa
// ═══════════════════════════════════════════════════════════════

// -- inlined from self/ml/darts_nas.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════
//  self/ml/darts_nas.hexa — DARTS NAS (#277)
//
//  Ref: Liu et al. 2019 — "DARTS: Differentiable Architecture
//       Search"
//
//  Key ideas:
//    1. Relax the discrete search space (choose one op per edge)
//       to a continuous mixture via a softmax over architecture
//       parameters alpha.
//         o_bar(feat) = sum_k softmax(alpha)_k * op_k(feat)
//    2. Bilevel optimization:
//         outer: minimize L_val(w*(alpha), alpha)  over alpha
//         inner: minimize L_train(w, alpha)        over w
//       In practice alternate single-step updates:
//         w     <- w     - lr_w   * grad_w   L_train
//         alpha <- alpha - lr_a * grad_a L_val  (first-order approx)
//    3. At the end of search, discretize: keep argmax_k alpha_k
//       on each edge → the "searched" architecture.
//
//  Demo search space (kept tiny to run cheaply):
//    - Input: feature vector x ∈ R^d
//    - Two candidate ops on a single edge:
//         op0: linear W0 @ x + b0         (scalar out)
//         op1: tanh(W1 @ x + b1)          (scalar out)
//    - Mixed output:
//         y = s0 * op0(x) + s1 * op1(x)
//       where (s0, s1) = softmax(alpha)
//    - Loss: MSE against a target scalar
//    - Known ground truth regression: target = W*.x + b*
//      → the "linear" op should win if the true function is linear
//
//  This is faithful to DARTS algorithmically on a tiny search
//  space: real DARTS has 8 operations on 14 edges, bilevel opt, and
//  cell-level topology.
//
//  AI-NATIVE:
//    @pure  — forward / softmax / loss
// ═══════════════════════════════════════════════════════════════

fn dn_abs(v) {
    if v < 0.0 { return 0.0 - v }
    return v
}

fn dn_zeros(n) {
    let mut r = []
    for _i in 0..n { r = r + [0.0] }
    return r
}

fn dn_hash(seed, i, j) {
    let h = (seed * 2654435761 + i * 1315423911 + j * 731) % 10007
    return to_float(h) / 10007.0 - 0.5
}

@pure
fn dn_tanh(v) {
    let mut u = v
    if u > 20.0 { u = 20.0 }
    if u < (0.0 - 20.0) { u = 0.0 - 20.0 }
    let e2 = exp(2.0 * u)
    return (e2 - 1.0) / (e2 + 1.0)
}

// softmax over K logits (stable)
@pure
fn dn_softmax(logits) {
    let n = len(logits)
    let mut m = logits[0]
    for i in 1..n {
        if logits[i] > m { m = logits[i] }
    }
    let mut exps = []
    let mut s = 0.0
    for i in 0..n {
        let e = exp(logits[i] - m)
        exps = exps + [e]
        s = s + e
    }
    let mut out = []
    for i in 0..n { out = out + [exps[i] / s] }
    return out
}

// derivative of softmax with respect to logits:
//   dsoftmax_i/dalpha_j = s_i * (delta_ij - s_j)
// Given grad w.r.t. probs g, the back-prop to alpha is:
//   grad_alpha_j = sum_i g_i * s_i * (delta_ij - s_j)
//                = s_j * (g_j - sum_i g_i * s_i)
@pure
fn dn_softmax_backward(s, g) {
    let K = len(s)
    let mut dot = 0.0
    for i in 0..K { dot = dot + g[i] * s[i] }
    let mut out = []
    for j in 0..K {
        out = out + [s[j] * (g[j] - dot)]
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  (1) Cell with K candidate ops on a single edge.
//
//    cell = {
//      "alpha": [K],
//      "W":     [K x d]  (one vector per op)
//      "b":     [K]
//      "d":     int
//      "K":     int
//    }
//  Both ops share the same in-dim d; op0 is linear, op1 is tanh.
// ═══════════════════════════════════════════════════════════════
fn dn_make_cell(in_dim, seed) {
    let K = 2
    let mut W = []
    let mut b = []
    for k in 0..K {
        let mut row = dn_zeros(in_dim)
        for j in 0..in_dim {
            row[j] = 0.5 * dn_hash(seed + k * 11, 0, j)
        }
        W = W + [row]
        b = b + [0.1 * dn_hash(seed + k * 23, 1, 0)]
    }
    // initialise alpha near zero → softmax ≈ uniform
    let alpha = [0.0, 0.0]
    return #{
        "alpha": alpha,
        "W": W,
        "b": b,
        "d": in_dim,
        "K": K
    }
}

// op0: linear W0 @ feat + b0
@pure
fn dn_op_linear(W_row, b, feat) {
    let d = len(feat)
    let mut s = b
    for j in 0..d {
        s = s + W_row[j] * feat[j]
    }
    return s
}

// op1: tanh(W1 @ feat + b1)
@pure
fn dn_op_tanh(W_row, b, feat) {
    return dn_tanh(dn_op_linear(W_row, b, feat))
}

// Forward: mixed output = sum_k s_k * op_k(feat)
@pure
fn dn_forward(cell, feat) {
    let s = dn_softmax(cell["alpha"])
    let W = cell["W"]
    let b = cell["b"]
    let op0 = dn_op_linear(W[0], b[0], feat)
    let op1 = dn_op_tanh(W[1], b[1], feat)
    return s[0] * op0 + s[1] * op1
}

// ═══════════════════════════════════════════════════════════════
//  (2) Loss: MSE against scalar target
// ═══════════════════════════════════════════════════════════════
@pure
fn dn_mse(cell, feats, targets) {
    let n = len(feats)
    let mut s = 0.0
    for k in 0..n {
        let y = dn_forward(cell, feats[k])
        let e = y - targets[k]
        s = s + e * e
    }
    return s / to_float(n)
}

// ═══════════════════════════════════════════════════════════════
//  (3) Inner-loop: update op weights W, b with grad of MSE
//
//  For the mixed output y = s0*op0 + s1*op1,
//    d y / d W_k[j] = s_k * d op_k / d W_k[j]
//  For linear op0: d op0 / d W0[j] = feat[j]
//  For tanh  op1: d op1 / d W1[j] = (1 - tanh(W1@feat+b1)^2) * feat[j]
//
//  Loss per sample: L = (y - target)^2, dL/dy = 2*(y - target)
// ═══════════════════════════════════════════════════════════════
fn dn_train_step_w(cell, feats, targets, lr) {
    let d = cell["d"]
    let K = cell["K"]
    let alpha = cell["alpha"]
    let W = cell["W"]
    let b = cell["b"]
    let s = dn_softmax(alpha)
    let n = len(feats)
    // accumulate gradients
    let mut gW0 = dn_zeros(d)
    let mut gW1 = dn_zeros(d)
    let mut gb0 = 0.0
    let mut gb1 = 0.0
    for k in 0..n {
        let op0 = dn_op_linear(W[0], b[0], feats[k])
        let lin1 = dn_op_linear(W[1], b[1], feats[k])
        let op1 = dn_tanh(lin1)
        let y = s[0] * op0 + s[1] * op1
        let e = y - targets[k]
        let dy = 2.0 * e
        // op0 grads
        let d_op0 = s[0] * dy
        gb0 = gb0 + d_op0
        for j in 0..d {
            gW0[j] = gW0[j] + d_op0 * feats[k][j]
        }
        // op1 grads (chain through tanh)
        let dtanh = 1.0 - op1 * op1
        let d_op1 = s[1] * dy * dtanh
        gb1 = gb1 + d_op1
        for j in 0..d {
            gW1[j] = gW1[j] + d_op1 * feats[k][j]
        }
    }
    let inv = 1.0 / to_float(n)
    let mut new_W0 = dn_zeros(d)
    let mut new_W1 = dn_zeros(d)
    for j in 0..d {
        new_W0[j] = W[0][j] - lr * gW0[j] * inv
        new_W1[j] = W[1][j] - lr * gW1[j] * inv
    }
    let new_b0 = b[0] - lr * gb0 * inv
    let new_b1 = b[1] - lr * gb1 * inv
    let new_W = [new_W0, new_W1]
    let new_b = [new_b0, new_b1]
    return #{
        "alpha": alpha,
        "W": new_W,
        "b": new_b,
        "d": d,
        "K": K
    }
}

// ═══════════════════════════════════════════════════════════════
//  (4) Outer-loop: update architecture parameters alpha with grad
//                 of VAL MSE (first-order DARTS approximation)
//
//  y = sum_k s_k * o_k    where s_k = softmax(alpha)_k
//  dL/dy = 2*(y - target)
//  dL/ds_k = dL/dy * o_k
//  grad_alpha_j = sum_k dL/ds_k * d s_k / d alpha_j
//               = s_j * (dL/ds_j - sum_k dL/ds_k * s_k)
// ═══════════════════════════════════════════════════════════════
fn dn_train_step_alpha(cell, feats, targets, lr_a) {
    let alpha = cell["alpha"]
    let W = cell["W"]
    let b = cell["b"]
    let K = cell["K"]
    let d = cell["d"]
    let s = dn_softmax(alpha)
    let n = len(feats)
    let mut grad_s = dn_zeros(K)
    for k in 0..n {
        let op0 = dn_op_linear(W[0], b[0], feats[k])
        let op1 = dn_op_tanh(W[1], b[1], feats[k])
        let y = s[0] * op0 + s[1] * op1
        let e = y - targets[k]
        let dy = 2.0 * e
        grad_s[0] = grad_s[0] + dy * op0
        grad_s[1] = grad_s[1] + dy * op1
    }
    let inv = 1.0 / to_float(n)
    let mut g_s_norm = []
    for k in 0..K { g_s_norm = g_s_norm + [grad_s[k] * inv] }
    let g_alpha = dn_softmax_backward(s, g_s_norm)
    let mut new_alpha = dn_zeros(K)
    for k in 0..K {
        new_alpha[k] = alpha[k] - lr_a * g_alpha[k]
    }
    return #{
        "alpha": new_alpha,
        "W": W,
        "b": b,
        "d": d,
        "K": K
    }
}

// ═══════════════════════════════════════════════════════════════
//  (5) Bilevel search loop
//
//  Alternates:
//    1. Inner step: update W on training set
//    2. Outer step: update alpha on validation set
//  For total_steps.
// ═══════════════════════════════════════════════════════════════
fn dn_search(cell, train_feats, train_targets, val_feats, val_targets,
             total_steps, lr_w, lr_a) {
    let mut cur = cell
    for _t in 0..total_steps {
        cur = dn_train_step_w(cur, train_feats, train_targets, lr_w)
        cur = dn_train_step_alpha(cur, val_feats, val_targets, lr_a)
    }
    return cur
}

// ═══════════════════════════════════════════════════════════════
//  (6) Discretization: argmax over alpha → chosen op index
// ═══════════════════════════════════════════════════════════════
fn dn_selected_op(cell) {
    let alpha = cell["alpha"]
    let K = len(alpha)
    let mut best = 0
    let mut bv = alpha[0]
    for k in 1..K {
        if alpha[k] > bv { bv = alpha[k]; best = k }
    }
    return best
}

// Get softmax weights of the final alphas
@pure
fn dn_arch_weights(cell) {
    return dn_softmax(cell["alpha"])
}

println("[darts_nas] loaded — K-op mixed edge, bilevel w/alpha SGD, argmax discretize")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(v) {
    if v < 0.0 { return 0.0 - v }
    return v
}
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("═══════════════════════════════════════════════════════")
println("  DARTS NAS (#277) Test Suite")
println("═══════════════════════════════════════════════════════")

// ── Test 1: softmax sum to 1
let s1 = dn_softmax([1.0, 2.0, 0.5])
let sum1 = s1[0] + s1[1] + s1[2]
check("softmax sums to 1", approx(sum1, 1.0, 1.0e-9))

// ── Test 2: softmax at zero logits is uniform
let s2 = dn_softmax([0.0, 0.0])
check("zero logits uniform 0", approx(s2[0], 0.5, 1.0e-9))
check("zero logits uniform 1", approx(s2[1], 0.5, 1.0e-9))

// ── Test 3: softmax_backward uniform grad zero
let g_uniform = [1.0, 1.0]
let back = dn_softmax_backward([0.5, 0.5], g_uniform)
check("sm_back uniform grad 0", approx(back[0], 0.0, 1.0e-9))
check("sm_back uniform grad 1", approx(back[1], 0.0, 1.0e-9))

// ── Test 4: cell init
let cell = dn_make_cell(3, 42)
check("cell K = 2", cell["K"] == 2)
check("cell d = 3", cell["d"] == 3)
check("cell alpha[0] = 0", approx(cell["alpha"][0], 0.0, 1.0e-12))
check("cell alpha[1] = 0", approx(cell["alpha"][1], 0.0, 1.0e-12))
check("cell W rows", len(cell["W"]) == 2)
check("cell W[0] cols", len(cell["W"][0]) == 3)

// ── Test 5: at init forward = 0.5 * op0 + 0.5 * op1
let feat = [0.3, 0.0 - 0.2, 0.1]
let op0 = dn_op_linear(cell["W"][0], cell["b"][0], feat)
let op1 = dn_op_tanh(cell["W"][1], cell["b"][1], feat)
let y = dn_forward(cell, feat)
check("forward = 0.5*(op0+op1)", approx(y, 0.5 * (op0 + op1), 1.0e-9))

// ── Build a linear target: target = 1.0*f0 - 0.5*f1 + 0.2*f2 + 0.1
fn make_ds(n, seed) {
    let mut feats = []
    let mut targets = []
    let mut i = 0

    while i < n {
        let f0 = 2.0 * (to_float((seed + i * 37) % 100) / 100.0 - 0.5)
        let f1 = 2.0 * (to_float((seed + i * 71) % 100) / 100.0 - 0.5)
        let f2 = 2.0 * (to_float((seed + i * 23) % 100) / 100.0 - 0.5)
        let xv = [f0, f1, f2]
        feats = feats + [xv]
        let t = 1.0 * f0 - 0.5 * f1 + 0.2 * f2 + 0.1
        targets = targets + [t]
    }
    return #{ "feats": feats, "targets": targets }
}

let train = make_ds(16, 111)
let val = make_ds(8, 777)
let train_feats = train["feats"]
let train_targets = train["targets"]
let val_feats = val["feats"]
let val_targets = val["targets"]

// ── Test 6: initial MSE positive
let mse_init = dn_mse(cell, train_feats, train_targets)
check("init mse > 0", mse_init > 0.0)

// ── Test 7: train_step_w reduces loss
let cell_w1 = dn_train_step_w(cell, train_feats, train_targets, 0.2)
let mse_w1 = dn_mse(cell_w1, train_feats, train_targets)
check("w step reduces mse", mse_w1 < mse_init)

// ── Test 8: train_step_alpha modifies alpha
let cell_a1 = dn_train_step_alpha(cell_w1, val_feats, val_targets, 0.5)
let delta_alpha = fabs(cell_a1["alpha"][0] - cell_w1["alpha"][0])
        + fabs(cell_a1["alpha"][1] - cell_w1["alpha"][1])
check("alpha step changes alpha", delta_alpha > 1.0e-9)

// ── Test 9: arch_weights sums to 1 post update
let w9 = dn_arch_weights(cell_a1)
check("arch weights sum 1", approx(w9[0] + w9[1], 1.0, 1.0e-9))

// ── Test 10: bilevel search reduces val loss
let searched = dn_search(cell, train_feats, train_targets,
                         val_feats, val_targets,
                         40, 0.2, 0.3)
let mse_val_init = dn_mse(cell, val_feats, val_targets)
let mse_val_final = dn_mse(searched, val_feats, val_targets)
check("val mse reduced", mse_val_final < mse_val_init)

// ── Test 11: linear target ⇒ op0 (linear) preferred
let w_final = dn_arch_weights(searched)
check("linear op preferred", w_final[0] > w_final[1])

// ── Test 12: discretized op
let sel = dn_selected_op(searched)
check("selected op is linear (0)", sel == 0)

// ── Test 13: arch_weights at init uniform
let w_init = dn_arch_weights(cell)
check("init arch weights uniform", approx(w_init[0], 0.5, 1.0e-9))

// ── Test 14: softmax_backward handles non-uniform grad
// probs=[0.6, 0.4], grad=[2, 0] → derivative:
// g_dot_s = 2*0.6 + 0*0.4 = 1.2
// g0 = 0.6*(2 - 1.2) = 0.48
// g1 = 0.4*(0 - 1.2) = -0.48
let back2 = dn_softmax_backward([0.6, 0.4], [2.0, 0.0])
check("sm_back non-uniform 0", approx(back2[0], 0.48, 1.0e-9))
check("sm_back non-uniform 1", approx(back2[1], 0.0 - 0.48, 1.0e-9))

// ── Test 15: dn_mse on perfect match = 0
// make a fake cell with alpha → op0 dominating and W matching
let perfect_W = [[1.0, 0.0 - 0.5, 0.2], [0.0, 0.0, 0.0]]
let perfect_b = [0.1, 0.0]
// alpha very skewed → op0 probability ≈ 1
let perfect_alpha = [10.0, 0.0 - 10.0]
let perfect_cell = #{
    "alpha": perfect_alpha,
    "W": perfect_W,
    "b": perfect_b,
    "d": 3,
    "K": 2
}
let mse_perfect = dn_mse(perfect_cell, train_feats, train_targets)
check("perfect cell mse ~ 0", mse_perfect < 1.0e-4)

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
