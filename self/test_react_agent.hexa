// ===================================================================
//  test_react_agent.hexa — ReAct Agent (ML #116) tests
//
//  Tests (51 checks):
//    1.   react_registry creates empty registry
//    2.   react_register adds tool
//    3.   react_has_tool finds registered tool
//    4.   react_has_tool misses unknown tool
//    5.   react_lookup returns registered tool
//    6.   react_lookup returns empty for unknown
//    7.   react_list_tools returns names
//    8.   react_registry_size counts tools
//    9.   react_register no duplicates
//   10.   react_step_new builds step map
//   11.   react_step_is_finish detects finish
//   12.   react_step_is_finish false for non-finish
//   13.   react_trace_new creates empty trace
//   14.   react_trace_add appends step
//   15.   react_trace_len counts steps
//   16.   react_trace_last returns last step
//   17.   react_trace_thoughts extracts all thoughts
//   17b.  first thought correct
//   18.   react_trace_observations extracts all observations
//   19.   react_is_finish true for "finish"
//   20.   react_is_finish false for other
//   21.   react_parse_thought line format
//   22.   react_parse_thought tagged format
//   23.   react_parse_action tool + args
//   24.   react_parse_action tagged format
//   25.   react_parse_action no-args case
//   26.   react_execute calls exec_fn for known tool
//   27.   react_execute returns error for unknown tool
//   28.   react_execute returns args for finish
//   29.   react_format_prompt includes query
//   30.   react_format_prompt includes tool list
//   31.   react_run finishes on "finish" action
//   32.   react_run trace has correct step count
//   33.   react_run trace has answer
//   34.   react_run_simple finishes correctly + answer
//   35.   react_run_simple respects max_steps limit
//   36.   react_trace_to_string contains query + status
//   37.   react_trace_stats n_steps + has_answer + unique_tools
//   38.   react_trace_actions extracts action tools
//   39.   react_trace_set_answer updates answer + status
//   40.   react_format_tool_list lists all tools
//
//  Run: ./hexa self/test_react_agent.hexa
// ===================================================================

import "ml/react_agent.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ── Mock tools ─────────────────────────────────────────────────────

let search_tool = react_tool("search", "Web search engine",
    [define_param("query", "string", "Search query", true)])
let calc_tool = react_tool("calc", "Calculator",
    [define_param("expr", "string", "Math expression", true)])
let lookup_tool = react_tool("lookup", "Knowledge lookup",
    [define_param("topic", "string", "Topic to look up", true)])

// ── Mock executor ──────────────────────────────────────────────────

fn mock_exec(name, args) {
    if name == "search" { return "Result: found 42 documents" }
    if name == "calc" { return "Result: 7" }
    if name == "lookup" { return "Result: Tokyo population is 14M" }
    return "unknown"
}

// ===================================================================
//  1-4. Registry creation and lookup
// ===================================================================

let reg0 = react_registry()
check("1. empty registry", react_registry_size(reg0) == 0)

let reg1 = react_register(reg0, search_tool)
check("2. register adds tool", react_registry_size(reg1) == 1)

check("3. has_tool finds registered", react_has_tool(reg1, "search"))
check("4. has_tool misses unknown", react_has_tool(reg1, "missing") == false)

// ===================================================================
//  5-6. Lookup
// ===================================================================

let found = react_lookup(reg1, "search")
check("5. lookup returns tool", found["name"] == "search")

let not_found = react_lookup(reg1, "nope")
check("6. lookup empty for unknown", len(keys(not_found)) == 0)

// ===================================================================
//  7-9. List, size, no duplicates
// ===================================================================

let reg2 = react_register(reg1, calc_tool)
let reg3 = react_register(reg2, lookup_tool)
check("7. list_tools returns names", len(react_list_tools(reg3)) == 3)
check("8. registry_size counts", react_registry_size(reg3) == 3)

let reg_dup = react_register(reg3, search_tool)
check("9. no duplicate on re-register", react_registry_size(reg_dup) == 3)

// ===================================================================
//  10-12. Step creation
// ===================================================================

let step0 = react_step_new(0, "I should search", "search", "hexa lang", "found docs")
check("10. step_new builds map", step0["step"] == 0)
check("11. step_is_finish detects finish",
      react_step_is_finish(react_step_new(1, "done", "finish", "42", "42")))
check("12. step_is_finish false for non-finish", react_step_is_finish(step0) == false)

// ===================================================================
//  13-18. Trace operations
// ===================================================================

let trace0 = react_trace_new("What is 2+5?")
check("13. trace_new creates empty", react_trace_len(trace0) == 0)

let trace1 = react_trace_add(trace0, step0)
check("14. trace_add appends", react_trace_len(trace1) == 1)
check("15. trace_len correct", trace1["n_steps"] == 1)

let last = react_trace_last(trace1)
check("16. trace_last returns last step", last["thought"] == "I should search")

let step1 = react_step_new(1, "Now I calculate", "calc", "2+5", "7")
let trace2 = react_trace_add(trace1, step1)
let thoughts = react_trace_thoughts(trace2)
check("17. trace_thoughts extracts all", len(thoughts) == 2)
check("17b. first thought correct", thoughts[0] == "I should search")

let observations = react_trace_observations(trace2)
check("18. trace_observations extracts all", len(observations) == 2)

// ===================================================================
//  19-20. Finish detection
// ===================================================================

check("19. is_finish true", react_is_finish("finish"))
check("20. is_finish false", react_is_finish("search") == false)

// ===================================================================
//  21-25. Parsing thought and action
// ===================================================================

let text_line = "Thought: I need to search for info\nAction: search: hexa language"
check("21. parse_thought line format",
      react_parse_thought(text_line) == "I need to search for info")

let text_tagged = "<thought>I need to calculate</thought>"
check("22. parse_thought tagged format",
      react_parse_thought(text_tagged) == "I need to calculate")

let action1 = react_parse_action(text_line)
check("23. parse_action tool", action1["tool"] == "search")
check("23b. parse_action args", action1["args"] == "hexa language")

let text_action_tagged = "<action>calc: 2+5</action>"
let action2 = react_parse_action(text_action_tagged)
check("24. parse_action tagged", action2["tool"] == "calc")
check("24b. parse_action tagged args", action2["args"] == "2+5")

let text_no_args = "Action: finish"
let action3 = react_parse_action(text_no_args)
check("25. parse_action no-args", action3["tool"] == "finish")

// ===================================================================
//  26-28. Execute
// ===================================================================

check("26. execute known tool",
      react_execute(reg3, mock_exec, "search", "test") == "Result: found 42 documents")
check("27. execute unknown tool",
      react_execute(reg3, mock_exec, "nope", "x").contains("Error"))
check("28. execute finish returns args",
      react_execute(reg3, mock_exec, "finish", "the answer") == "the answer")

// ===================================================================
//  29-30. Format prompt
// ===================================================================

let prompt = react_format_prompt("What is 2+5?", trace0, reg3)
check("29. format_prompt includes query", prompt.contains("What is 2+5?"))
check("30. format_prompt includes tool list", prompt.contains("search"))

// ===================================================================
//  31-33. react_run with mock think/act that finishes in 2 steps
// ===================================================================

let mut mock_run_step = 0

fn mock_think(prompt) {
    if mock_run_step == 0 { return "I need to calculate 2+5" }
    return "I have the answer"
}

fn mock_act(prompt, thought) {
    if mock_run_step == 0 {
        mock_run_step = mock_run_step + 1
        return "calc: 2+5"
    }
    mock_run_step = mock_run_step + 1
    return "finish: 7"
}

let result_trace = react_run("What is 2+5?", reg3, mock_think, mock_act,
                             mock_exec, 10)
check("31. react_run finishes", result_trace["status"] == "finished")
check("32. react_run step count", result_trace["n_steps"] == 2)
check("33. react_run has answer", result_trace["answer"] == "7")

// ===================================================================
//  34. react_run_simple with single generate function
// ===================================================================

// Use a global mode flag to switch behavior for different tests
// (Hexa resolves fn callbacks by last-defined with matching arity)
let mut gen_mode = "simple"
let mut gen_counter = 0

fn unified_generate(prompt) {
    if gen_mode == "simple" {
        if gen_counter == 0 {
            gen_counter = gen_counter + 1
            return "Thought: Let me search first\nAction: search: hexa docs"
        }
        if gen_counter == 1 {
            gen_counter = gen_counter + 1
            return "Thought: Now I know\nAction: finish: hexa is a language"
        }
        return "Thought: done\nAction: finish: fallback"
    }
    // "loop" mode: never finish
    return "Thought: still thinking\nAction: search: more info"
}

let simple_trace = react_run_simple("What is hexa?", reg3, unified_generate,
                                    mock_exec, 10)
check("34. run_simple finishes", simple_trace["status"] == "finished")
check("34b. run_simple answer",
      simple_trace["answer"] == "hexa is a language")

// ===================================================================
//  35. Max steps limit
// ===================================================================

// Switch to loop mode so unified_generate never returns "finish"
gen_mode = "loop"

let reg_loop = react_register(react_register(react_registry(), search_tool), calc_tool)
let limited_trace = react_run_simple("infinite?", reg_loop, unified_generate,
                                     mock_exec, 3)
check("35. max_steps respected", limited_trace["status"] == "max_steps")
check("35b. max_steps count", limited_trace["n_steps"] == 3)

// ===================================================================
//  36. Trace to string
// ===================================================================

let trace_str = react_trace_to_string(result_trace)
check("36. trace_to_string contains query", trace_str.contains("What is 2+5?"))
check("36b. trace_to_string contains status", trace_str.contains("finished"))

// ===================================================================
//  37. Trace statistics
// ===================================================================

let stats = react_trace_stats(result_trace)
check("37. stats n_steps", stats["n_steps"] == 2)
check("37b. stats has_answer", stats["has_answer"] == true)
check("37c. stats unique_tools", stats["unique_tools"] == 2)

// ===================================================================
//  38. Trace actions
// ===================================================================

let actions = react_trace_actions(result_trace)
check("38. trace_actions extracts", len(actions) == 2)
check("38b. first action is calc", actions[0] == "calc")

// ===================================================================
//  39. Trace set answer
// ===================================================================

let updated = react_trace_set_answer(trace0, "42")
check("39. set_answer updates", updated["answer"] == "42")
check("39b. set_answer sets status", updated["status"] == "finished")

// ===================================================================
//  40. Format tool list
// ===================================================================

let tool_list = react_format_tool_list(reg3)
check("40. format_tool_list has search", tool_list.contains("search"))
check("40b. format_tool_list has calc", tool_list.contains("calc"))

// ===================================================================
//  Summary
// ===================================================================

println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
