// ===================================================================
//  self/ml/react_agent.hexa — ReAct Agent (ML #116)
//
//  Reason + Act interleaved loop (Yao et al., 2022).
//  Base module: self/ml/function_calling.hexa (tool definitions,
//  parse_tool_calls, format_tool_result).
//
//  Pipeline (per step):
//    1. Thought — generate reasoning text about current state
//    2. Action  — select tool + arguments from available tools
//    3. Observation — receive tool output
//    Repeat until "finish" action or max_steps reached.
//
//  Data structures (all #{} maps):
//    Step     = { step, thought, action_tool, action_args, observation }
//    Trace    = { steps: [Step], query, answer, status, n_steps }
//    Tool     = { name, description, parameters }  (from function_calling)
//    Registry = { tools: #{name -> Tool}, names: [name...] }
//
//  Public API:
//    react_tool(name, desc, params)       -> Tool map
//    react_registry()                     -> empty Registry
//    react_register(reg, tool)            -> Registry with tool added
//    react_lookup(reg, name)              -> Tool or empty #{}
//    react_has_tool(reg, name)            -> bool
//    react_list_tools(reg)                -> [name...]
//    react_step_new(idx, thought, tool, args, obs)  -> Step
//    react_trace_new(query)               -> empty Trace
//    react_trace_add(trace, step)         -> Trace with step appended
//    react_trace_len(trace)               -> int
//    react_trace_last(trace)              -> Step or empty #{}
//    react_trace_thoughts(trace)          -> [thought strings]
//    react_trace_observations(trace)      -> [observation strings]
//    react_is_finish(action_tool)         -> bool
//    react_format_prompt(query, trace, reg)  -> prompt string
//    react_parse_thought(text)            -> thought string
//    react_parse_action(text)             -> {tool, args} map
//    react_run(query, reg, think_fn, act_fn, exec_fn, max_steps)  -> Trace
//    react_run_simple(query, reg, generate_fn, exec_fn, max_steps) -> Trace
//
//  Conventions:
//    - Tag format: <thought>...</thought> <action>tool: args</action>
//    - "finish" as action tool name signals termination
//    - Uses #{} map literals, no {k:v} inside if blocks (HX3)
//    - No semicolons (P1)
//    - Flag-variable break pattern (no break inside if)
// ===================================================================

import "ml/function_calling.hexa"

// ===================================================================
//  String helpers (self-contained, prefix _ra_ to avoid collision)
// ===================================================================

fn _ra_index_of(s, needle, start) {
    let sn = len(s)
    let nn = len(needle)
    if nn == 0 { return start }
    if nn > sn { return 0 - 1 }
    let limit = sn - nn
    let mut i = start
    while i <= limit {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if s[i + j] != needle[j] {
                ok = false
                j = nn
            }
            j = j + 1
        }
        if ok { return i }
        i = i + 1
    }
    return 0 - 1
}

fn _ra_contains(s, needle) {
    return _ra_index_of(s, needle, 0) >= 0
}

fn _ra_extract_between(text, open_tag, close_tag) {
    let ot_len = len(open_tag)
    let start = _ra_index_of(text, open_tag, 0)
    if start < 0 { return "" }
    let content_start = start + ot_len
    let end = _ra_index_of(text, close_tag, content_start)
    if end < 0 { return "" }
    return text.substring(content_start, end).trim()
}

// ===================================================================
//  Tool definition (re-uses function_calling define_tool/define_param)
// ===================================================================

fn react_tool(name, description, params) {
    return define_tool(name, description, params)
}

// ===================================================================
//  Tool Registry — register / lookup / list
// ===================================================================

fn react_registry() {
    let reg = #{}
    reg["tools"] = #{}
    reg["names"] = []
    return reg
}

fn react_register(reg, tool) {
    let name = tool["name"]
    let tools = reg["tools"]
    tools[name] = tool
    let mut names = reg["names"]
    // avoid duplicate
    let mut found = false
    let mut i = 0
    while i < len(names) {
        if names[i] == name { found = true }
        i = i + 1
    }
    if found == false {
        names = names + [name]
    }
    let out = #{}
    out["tools"] = tools
    out["names"] = names
    return out
}

fn react_lookup(reg, name) {
    let tools = reg["tools"]
    if has_key(tools, name) {
        return tools[name]
    }
    let empty = #{}
    return empty
}

fn react_has_tool(reg, name) {
    return has_key(reg["tools"], name)
}

fn react_list_tools(reg) {
    return reg["names"]
}

fn react_registry_size(reg) {
    return len(reg["names"])
}

// Format registry tools as descriptive string for prompt
fn react_format_tool_list(reg) {
    let names = reg["names"]
    let tools = reg["tools"]
    let n = len(names)
    let mut parts = []
    let mut i = 0
    while i < n {
        let t = tools[names[i]]
        parts = parts + [t["name"] + " — " + t["description"]]
        i = i + 1
    }
    return parts.join("\n")
}

// ===================================================================
//  Step — a single (thought, action, observation) triple
// ===================================================================

fn react_step_new(idx, thought, action_tool, action_args, observation) {
    let s = #{}
    s["step"] = idx
    s["thought"] = thought
    s["action_tool"] = action_tool
    s["action_args"] = action_args
    s["observation"] = observation
    return s
}

fn react_step_is_finish(step) {
    return step["action_tool"] == "finish"
}

// ===================================================================
//  Trace — full history buffer
// ===================================================================

fn react_trace_new(query) {
    let t = #{}
    t["query"] = query
    t["steps"] = []
    t["answer"] = ""
    t["status"] = "running"
    t["n_steps"] = 0
    return t
}

fn react_trace_add(trace, step) {
    let mut steps = trace["steps"]
    steps = steps + [step]
    let out = #{}
    out["query"] = trace["query"]
    out["steps"] = steps
    out["n_steps"] = len(steps)
    out["answer"] = trace["answer"]
    out["status"] = trace["status"]
    return out
}

fn react_trace_len(trace) {
    return trace["n_steps"]
}

fn react_trace_last(trace) {
    let steps = trace["steps"]
    let n = len(steps)
    if n == 0 {
        let empty = #{}
        return empty
    }
    return steps[n - 1]
}

fn react_trace_thoughts(trace) {
    let steps = trace["steps"]
    let n = len(steps)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [steps[i]["thought"]]
        i = i + 1
    }
    return out
}

fn react_trace_observations(trace) {
    let steps = trace["steps"]
    let n = len(steps)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [steps[i]["observation"]]
        i = i + 1
    }
    return out
}

fn react_trace_actions(trace) {
    let steps = trace["steps"]
    let n = len(steps)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [steps[i]["action_tool"]]
        i = i + 1
    }
    return out
}

fn react_trace_set_answer(trace, answer) {
    let out = #{}
    out["query"] = trace["query"]
    out["steps"] = trace["steps"]
    out["n_steps"] = trace["n_steps"]
    out["answer"] = answer
    out["status"] = "finished"
    return out
}

fn react_trace_set_status(trace, status) {
    let out = #{}
    out["query"] = trace["query"]
    out["steps"] = trace["steps"]
    out["n_steps"] = trace["n_steps"]
    out["answer"] = trace["answer"]
    out["status"] = status
    return out
}

// ===================================================================
//  Finish detection — "finish" action means stop the loop
// ===================================================================

fn react_is_finish(action_tool) {
    return action_tool == "finish"
}

// ===================================================================
//  Prompt formatting — build the ReAct prompt from query + trace
// ===================================================================

fn react_format_prompt(query, trace, reg) {
    let mut prompt = "Answer the following question by reasoning step by step.\n"
    prompt = prompt + "Available tools:\n"
    prompt = prompt + react_format_tool_list(reg) + "\n\n"
    prompt = prompt + "Use this format:\n"
    prompt = prompt + "Thought: reasoning about what to do\n"
    prompt = prompt + "Action: tool_name: arguments\n"
    prompt = prompt + "Observation: tool output\n"
    prompt = prompt + "... (repeat as needed)\n"
    prompt = prompt + "Thought: I have the answer\n"
    prompt = prompt + "Action: finish: final answer\n\n"
    prompt = prompt + "Question: " + query + "\n\n"

    // Append existing trace
    let steps = trace["steps"]
    let n = len(steps)
    let mut i = 0
    while i < n {
        let s = steps[i]
        prompt = prompt + "Thought: " + s["thought"] + "\n"
        prompt = prompt + "Action: " + s["action_tool"] + ": " + s["action_args"] + "\n"
        prompt = prompt + "Observation: " + s["observation"] + "\n"
        i = i + 1
    }

    return prompt
}

// ===================================================================
//  Parse thought from generated text
//  Looks for "Thought: ..." or <thought>...</thought>
// ===================================================================

fn react_parse_thought(text) {
    // Try tagged format first
    let tagged = _ra_extract_between(text, "<thought>", "</thought>")
    if len(tagged) > 0 { return tagged }

    // Try "Thought: ..." line format
    let marker = "Thought: "
    let idx = _ra_index_of(text, marker, 0)
    if idx < 0 { return text.trim() }
    let start = idx + len(marker)
    let text_len = len(text)
    // find end of line
    let mut ei = start
    let mut found_nl = false
    while ei < text_len {
        if text[ei] == '\n' {
            found_nl = true
            ei = text_len
        } else {
            ei = ei + 1
        }
    }
    if found_nl {
        let nl_pos = _ra_index_of(text, "\n", start)
        if nl_pos >= 0 {
            return text.substring(start, nl_pos).trim()
        }
    }
    return text.substring(start, text_len).trim()
}

// ===================================================================
//  Parse action from generated text
//  Looks for "Action: tool_name: args" or <action>tool: args</action>
//  Returns map { tool, args }
// ===================================================================

fn react_parse_action(text) {
    let out = #{}
    out["tool"] = ""
    out["args"] = ""

    // Try tagged format
    let tagged = _ra_extract_between(text, "<action>", "</action>")
    let mut content = tagged
    if len(content) == 0 {
        // Try "Action: ..." line format
        let marker = "Action: "
        let idx = _ra_index_of(text, marker, 0)
        if idx < 0 { return out }
        let start = idx + len(marker)
        let text_len = len(text)
        let nl_pos = _ra_index_of(text, "\n", start)
        if nl_pos >= 0 {
            content = text.substring(start, nl_pos).trim()
        } else {
            content = text.substring(start, text_len).trim()
        }
    }

    if len(content) == 0 { return out }

    // Split on first ": " to get tool and args
    let colon_pos = _ra_index_of(content, ": ", 0)
    if colon_pos < 0 {
        // No args, just tool name
        out["tool"] = content.trim()
        out["args"] = ""
        return out
    }
    out["tool"] = content.substring(0, colon_pos).trim()
    out["args"] = content.substring(colon_pos + 2, len(content)).trim()
    return out
}

// ===================================================================
//  Execute action via registry + executor
//  exec_fn: fn(tool_name, args_str) -> observation string
// ===================================================================

fn react_execute(reg, exec_fn, tool_name, args_str) {
    if react_is_finish(tool_name) {
        return args_str
    }
    if react_has_tool(reg, tool_name) == false {
        return "Error: unknown tool '" + tool_name + "'"
    }
    return exec_fn(tool_name, args_str)
}

// ===================================================================
//  Single ReAct step — given think_fn and act_fn (separate)
//
//  think_fn(prompt) -> thought text
//  act_fn(prompt, thought) -> "tool_name: args" string
// ===================================================================

fn react_one_step(query, trace, reg, think_fn, act_fn, exec_fn, step_idx) {
    let prompt = react_format_prompt(query, trace, reg)

    // 1. Thought
    let thought = think_fn(prompt)

    // 2. Action
    let action_raw = act_fn(prompt, thought)
    let parsed = react_parse_action("Action: " + action_raw)
    let tool_name = parsed["tool"]
    let args_str = parsed["args"]

    // 3. Observation
    let observation = react_execute(reg, exec_fn, tool_name, args_str)

    return react_step_new(step_idx, thought, tool_name, args_str, observation)
}

// ===================================================================
//  ReAct loop — full orchestrator with separate think/act callbacks
//
//  think_fn(prompt) -> thought string
//  act_fn(prompt, thought) -> "tool_name: args" action string
//  exec_fn(tool_name, args_str) -> observation string
//  max_steps: hard limit to prevent infinite loops
//
//  Returns Trace with all steps + final answer
// ===================================================================

fn react_run(query, reg, think_fn, act_fn, exec_fn, max_steps) {
    let mut trace = react_trace_new(query)
    let mut step_idx = 0

    while step_idx < max_steps {
        let step = react_one_step(query, trace, reg, think_fn, act_fn,
                                  exec_fn, step_idx)
        trace = react_trace_add(trace, step)

        if react_is_finish(step["action_tool"]) {
            trace = react_trace_set_answer(trace, step["action_args"])
            trace = react_trace_set_status(trace, "finished")
            return trace
        }

        step_idx = step_idx + 1
    }

    // max_steps exceeded
    trace = react_trace_set_status(trace, "max_steps")
    return trace
}

// ===================================================================
//  Simplified ReAct loop — single generate_fn that returns both
//  thought and action in one shot.
//
//  generate_fn(prompt) -> text with "Thought: ...\nAction: tool: args"
//  exec_fn(tool_name, args_str) -> observation string
// ===================================================================

fn react_run_simple(query, reg, generate_fn, exec_fn, max_steps) {
    let mut trace = react_trace_new(query)
    let mut step_idx = 0

    while step_idx < max_steps {
        let prompt = react_format_prompt(query, trace, reg)
        let generated = generate_fn(prompt)

        let thought = react_parse_thought(generated)
        let action = react_parse_action(generated)
        let tool_name = action["tool"]
        let args_str = action["args"]

        let observation = react_execute(reg, exec_fn, tool_name, args_str)
        let step = react_step_new(step_idx, thought, tool_name, args_str,
                                  observation)
        trace = react_trace_add(trace, step)

        if react_is_finish(tool_name) {
            trace = react_trace_set_answer(trace, args_str)
            trace = react_trace_set_status(trace, "finished")
            return trace
        }

        step_idx = step_idx + 1
    }

    trace = react_trace_set_status(trace, "max_steps")
    return trace
}

// ===================================================================
//  Trace serialization — convert trace to readable string
// ===================================================================

fn react_trace_to_string(trace) {
    let mut out = "Query: " + trace["query"] + "\n"
    let steps = trace["steps"]
    let n = len(steps)
    let mut i = 0
    while i < n {
        let s = steps[i]
        out = out + "--- Step " + to_string(s["step"]) + " ---\n"
        out = out + "Thought: " + s["thought"] + "\n"
        out = out + "Action: " + s["action_tool"] + ": " + s["action_args"] + "\n"
        out = out + "Observation: " + s["observation"] + "\n"
        i = i + 1
    }
    out = out + "Status: " + trace["status"] + "\n"
    out = out + "Answer: " + trace["answer"] + "\n"
    return out
}

// ===================================================================
//  Trace statistics
// ===================================================================

fn react_trace_stats(trace) {
    let stats = #{}
    stats["n_steps"] = trace["n_steps"]
    stats["status"] = trace["status"]
    stats["has_answer"] = len(trace["answer"]) > 0

    // Count unique tools used
    let steps = trace["steps"]
    let n = len(steps)
    let mut tool_set = #{}
    let mut i = 0
    while i < n {
        let tname = steps[i]["action_tool"]
        tool_set[tname] = true
        i = i + 1
    }
    stats["unique_tools"] = len(keys(tool_set))

    // Total thought length
    let mut total_thought_len = 0
    i = 0
    while i < n {
        total_thought_len = total_thought_len + len(steps[i]["thought"])
        i = i + 1
    }
    stats["total_thought_len"] = total_thought_len

    return stats
}

println("[react_agent] module loaded")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ── Mock tools ─────────────────────────────────────────────────────

let search_tool = react_tool("search", "Web search engine",
    [define_param("query", "string", "Search query", true)])
let calc_tool = react_tool("calc", "Calculator",
    [define_param("expr", "string", "Math expression", true)])
let lookup_tool = react_tool("lookup", "Knowledge lookup",
    [define_param("topic", "string", "Topic to look up", true)])

// ── Mock executor ──────────────────────────────────────────────────

fn mock_exec(name, args) {
    if name == "search" { return "Result: found 42 documents" }
    if name == "calc" { return "Result: 7" }
    if name == "lookup" { return "Result: Tokyo population is 14M" }
    return "unknown"
}

// ===================================================================
//  1-4. Registry creation and lookup
// ===================================================================

let reg0 = react_registry()
check("1. empty registry", react_registry_size(reg0) == 0)

let reg1 = react_register(reg0, search_tool)
check("2. register adds tool", react_registry_size(reg1) == 1)

check("3. has_tool finds registered", react_has_tool(reg1, "search"))
check("4. has_tool misses unknown", react_has_tool(reg1, "missing") == false)

// ===================================================================
//  5-6. Lookup
// ===================================================================

let found = react_lookup(reg1, "search")
check("5. lookup returns tool", found["name"] == "search")

let not_found = react_lookup(reg1, "nope")
check("6. lookup empty for unknown", len(keys(not_found)) == 0)

// ===================================================================
//  7-9. List, size, no duplicates
// ===================================================================

let reg2 = react_register(reg1, calc_tool)
let reg3 = react_register(reg2, lookup_tool)
check("7. list_tools returns names", len(react_list_tools(reg3)) == 3)
check("8. registry_size counts", react_registry_size(reg3) == 3)

let reg_dup = react_register(reg3, search_tool)
check("9. no duplicate on re-register", react_registry_size(reg_dup) == 3)

// ===================================================================
//  10-12. Step creation
// ===================================================================

let step0 = react_step_new(0, "I should search", "search", "hexa lang", "found docs")
check("10. step_new builds map", step0["step"] == 0)
check("11. step_is_finish detects finish",
      react_step_is_finish(react_step_new(1, "done", "finish", "42", "42")))
check("12. step_is_finish false for non-finish", react_step_is_finish(step0) == false)

// ===================================================================
//  13-18. Trace operations
// ===================================================================

let trace0 = react_trace_new("What is 2+5?")
check("13. trace_new creates empty", react_trace_len(trace0) == 0)

let trace1 = react_trace_add(trace0, step0)
check("14. trace_add appends", react_trace_len(trace1) == 1)
check("15. trace_len correct", trace1["n_steps"] == 1)

let last = react_trace_last(trace1)
check("16. trace_last returns last step", last["thought"] == "I should search")

let step1 = react_step_new(1, "Now I calculate", "calc", "2+5", "7")
let trace2 = react_trace_add(trace1, step1)
let thoughts = react_trace_thoughts(trace2)
check("17. trace_thoughts extracts all", len(thoughts) == 2)
check("17b. first thought correct", thoughts[0] == "I should search")

let observations = react_trace_observations(trace2)
check("18. trace_observations extracts all", len(observations) == 2)

// ===================================================================
//  19-20. Finish detection
// ===================================================================

check("19. is_finish true", react_is_finish("finish"))
check("20. is_finish false", react_is_finish("search") == false)

// ===================================================================
//  21-25. Parsing thought and action
// ===================================================================

let text_line = "Thought: I need to search for info\nAction: search: hexa language"
check("21. parse_thought line format",
      react_parse_thought(text_line) == "I need to search for info")

let text_tagged = "<thought>I need to calculate</thought>"
check("22. parse_thought tagged format",
      react_parse_thought(text_tagged) == "I need to calculate")

let action1 = react_parse_action(text_line)
check("23. parse_action tool", action1["tool"] == "search")
check("23b. parse_action args", action1["args"] == "hexa language")

let text_action_tagged = "<action>calc: 2+5</action>"
let action2 = react_parse_action(text_action_tagged)
check("24. parse_action tagged", action2["tool"] == "calc")
check("24b. parse_action tagged args", action2["args"] == "2+5")

let text_no_args = "Action: finish"
let action3 = react_parse_action(text_no_args)
check("25. parse_action no-args", action3["tool"] == "finish")

// ===================================================================
//  26-28. Execute
// ===================================================================

check("26. execute known tool",
      react_execute(reg3, mock_exec, "search", "test") == "Result: found 42 documents")
check("27. execute unknown tool",
      react_execute(reg3, mock_exec, "nope", "x").contains("Error"))
check("28. execute finish returns args",
      react_execute(reg3, mock_exec, "finish", "the answer") == "the answer")

// ===================================================================
//  29-30. Format prompt
// ===================================================================

let prompt = react_format_prompt("What is 2+5?", trace0, reg3)
check("29. format_prompt includes query", prompt.contains("What is 2+5?"))
check("30. format_prompt includes tool list", prompt.contains("search"))

// ===================================================================
//  31-33. react_run with mock think/act that finishes in 2 steps
// ===================================================================

let mut mock_run_step = 0

fn mock_think(prompt) {
    if mock_run_step == 0 { return "I need to calculate 2+5" }
    return "I have the answer"
}

fn mock_act(prompt, thought) {
    if mock_run_step == 0 {
        mock_run_step = mock_run_step + 1
        return "calc: 2+5"
    }
    mock_run_step = mock_run_step + 1
    return "finish: 7"
}

let result_trace = react_run("What is 2+5?", reg3, mock_think, mock_act,
                             mock_exec, 10)
check("31. react_run finishes", result_trace["status"] == "finished")
check("32. react_run step count", result_trace["n_steps"] == 2)
check("33. react_run has answer", result_trace["answer"] == "7")

// ===================================================================
//  34. react_run_simple with single generate function
// ===================================================================

// Use a global mode flag to switch behavior for different tests
// (Hexa resolves fn callbacks by last-defined with matching arity)
let mut gen_mode = "simple"
let mut gen_counter = 0

fn unified_generate(prompt) {
    if gen_mode == "simple" {
        if gen_counter == 0 {
            gen_counter = gen_counter + 1
            return "Thought: Let me search first\nAction: search: hexa docs"
        }
        if gen_counter == 1 {
            gen_counter = gen_counter + 1
            return "Thought: Now I know\nAction: finish: hexa is a language"
        }
        return "Thought: done\nAction: finish: fallback"
    }
    // "loop" mode: never finish
    return "Thought: still thinking\nAction: search: more info"
}

let simple_trace = react_run_simple("What is hexa?", reg3, unified_generate,
                                    mock_exec, 10)
check("34. run_simple finishes", simple_trace["status"] == "finished")
check("34b. run_simple answer",
      simple_trace["answer"] == "hexa is a language")

// ===================================================================
//  35. Max steps limit
// ===================================================================

// Switch to loop mode so unified_generate never returns "finish"
gen_mode = "loop"

let reg_loop = react_register(react_register(react_registry(), search_tool), calc_tool)
let limited_trace = react_run_simple("infinite?", reg_loop, unified_generate,
                                     mock_exec, 3)
check("35. max_steps respected", limited_trace["status"] == "max_steps")
check("35b. max_steps count", limited_trace["n_steps"] == 3)

// ===================================================================
//  36. Trace to string
// ===================================================================

let trace_str = react_trace_to_string(result_trace)
check("36. trace_to_string contains query", trace_str.contains("What is 2+5?"))
check("36b. trace_to_string contains status", trace_str.contains("finished"))

// ===================================================================
//  37. Trace statistics
// ===================================================================

let stats = react_trace_stats(result_trace)
check("37. stats n_steps", stats["n_steps"] == 2)
check("37b. stats has_answer", stats["has_answer"] == true)
check("37c. stats unique_tools", stats["unique_tools"] == 2)

// ===================================================================
//  38. Trace actions
// ===================================================================

let actions = react_trace_actions(result_trace)
check("38. trace_actions extracts", len(actions) == 2)
check("38b. first action is calc", actions[0] == "calc")

// ===================================================================
//  39. Trace set answer
// ===================================================================

let updated = react_trace_set_answer(trace0, "42")
check("39. set_answer updates", updated["answer"] == "42")
check("39b. set_answer sets status", updated["status"] == "finished")

// ===================================================================
//  40. Format tool list
// ===================================================================

let tool_list = react_format_tool_list(reg3)
check("40. format_tool_list has search", tool_list.contains("search"))
check("40b. format_tool_list has calc", tool_list.contains("calc"))

// ===================================================================
//  Summary
// ===================================================================

println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
