// ═══════════════════════════════════════════════════════════
//  test_control_flow.hexa — Advanced Control Flow Tests
//  Tests: nested loops, break, continue, early return,
//         nested if-else, while patterns, loop with accumulator
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Advanced Control Flow Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Nested while loops ─────────────────────────────────

println("--- Nested While ---")

let mut sum_2d = 0
let mut i = 0
while i < 3 {
    let mut j = 0
    while j < 4 {
        sum_2d = sum_2d + 1
        j = j + 1
    }
    i = i + 1
}
check("nested while 3x4", sum_2d, 12)

// Multiplication table check
let mut prod = 0
let mut r = 1
while r <= 3 {
    let mut c = 1
    while c <= 3 {
        prod = prod + r * c
        c = c + 1
    }
    r = r + 1
}
// (1*1+1*2+1*3) + (2*1+2*2+2*3) + (3*1+3*2+3*3) = 6+12+18 = 36
check("mult table sum", prod, 36)

// ── 2. Break in while loop ────────────────────────────────

println("")
println("--- Break ---")

let mut break_val = 0
let mut bi = 0
while bi < 100 {
    if bi == 5 {
        break
    }
    break_val = break_val + bi
    bi = bi + 1
}
// 0+1+2+3+4 = 10
check("break at 5", break_val, 10)
check("break index", bi, 5)

// Break in nested loop (inner only)
let mut outer_count = 0
let mut oi = 0
while oi < 3 {
    let mut inner = 0
    let mut ij = 0
    while ij < 10 {
        if ij == 2 {
            break
        }
        inner = inner + 1
        ij = ij + 1
    }
    outer_count = outer_count + inner
    oi = oi + 1
}
check("break inner only", outer_count, 6)

// ── 3. Continue in while loop ─────────────────────────────

println("")
println("--- Continue ---")

let mut skip_sum = 0
let mut ci = 0
while ci < 10 {
    ci = ci + 1
    if ci % 2 == 0 {
        continue
    }
    skip_sum = skip_sum + ci
}
// 1+3+5+7+9 = 25
check("continue skip evens", skip_sum, 25)

let mut skip3_sum = 0
let mut si = 0
while si < 10 {
    si = si + 1
    if si % 3 == 0 {
        continue
    }
    skip3_sum = skip3_sum + si
}
// 1+2+4+5+7+8+10 = 37
check("continue skip mult3", skip3_sum, 37)

// ── 4. Early return ───────────────────────────────────────

println("")
println("--- Early Return ---")

fn find_first_even(arr) {
    for x in arr {
        if x % 2 == 0 {
            return x
        }
    }
    return -1
}
check("first even [1,3,4,6]", find_first_even([1, 3, 4, 6]), 4)
check("first even [1,3,5]", find_first_even([1, 3, 5]), -1)
check("first even [2,4,6]", find_first_even([2, 4, 6]), 2)
check("first even empty", find_first_even([]), -1)

fn find_index(arr, target) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == target {
            return i
        }
        i = i + 1
    }
    return -1
}
check("find_index found", find_index([10, 20, 30, 40], 30), 2)
check("find_index not found", find_index([10, 20, 30], 99), -1)
check("find_index first", find_index([5, 10, 15], 5), 0)

// ── 5. Nested if-else chains ──────────────────────────────

println("")
println("--- Nested If-Else ---")

fn grade(score) {
    if score >= 90 {
        return "A"
    } else {
        if score >= 80 {
            return "B"
        } else {
            if score >= 70 {
                return "C"
            } else {
                if score >= 60 {
                    return "D"
                } else {
                    return "F"
                }
            }
        }
    }
}
check("grade 95", grade(95), "A")
check("grade 85", grade(85), "B")
check("grade 75", grade(75), "C")
check("grade 65", grade(65), "D")
check("grade 50", grade(50), "F")

fn classify_num(n) {
    if n > 0 {
        if n % 2 == 0 {
            return "positive even"
        } else {
            return "positive odd"
        }
    } else {
        if n < 0 {
            return "negative"
        } else {
            return "zero"
        }
    }
}
check("classify 4", classify_num(4), "positive even")
check("classify 7", classify_num(7), "positive odd")
check("classify -3", classify_num(-3), "negative")
check("classify 0", classify_num(0), "zero")

// ── 6. If-expression as value ─────────────────────────────

println("")
println("--- If-Expression ---")

let v1 = if true { 42 } else { 0 }
check("if-expr true", v1, 42)

let v2 = if false { 42 } else { 99 }
check("if-expr false", v2, 99)

let v3 = if 5 > 3 { "yes" } else { "no" }
check("if-expr comparison", v3, "yes")

fn abs2(x) {
    return if x < 0 { 0 - x } else { x }
}
check("if-expr in return pos", abs2(7), 7)
check("if-expr in return neg", abs2(-3), 3)

// ── 7. For-in with break pattern ──────────────────────────

println("")
println("--- For-In Patterns ---")

let mut for_sum = 0
for x in [10, 20, 30, 40, 50] {
    for_sum = for_sum + x
}
check("for-in sum", for_sum, 150)

// Counting pattern
let mut count = 0
for x in [1, 2, 3, 4, 5, 6, 7, 8] {
    if x % 2 == 0 {
        count = count + 1
    }
}
check("for-in count evens", count, 4)

// ── 8. While with complex condition ───────────────────────

println("")
println("--- Complex While ---")

let mut a = 1
let mut b = 1
let mut fib_count = 2
while a + b < 100 {
    let tmp = a + b
    a = b
    b = tmp
    fib_count = fib_count + 1
}
check("fib count <100", fib_count, 11)
check("fib last", b, 89)

// Collatz conjecture for 27
fn collatz_steps(n) {
    let mut x = n
    let mut steps = 0
    while x != 1 {
        if x % 2 == 0 {
            x = x / 2
        } else {
            x = x * 3 + 1
        }
        steps = steps + 1
    }
    return steps
}
check("collatz(1)", collatz_steps(1), 0)
check("collatz(2)", collatz_steps(2), 1)
check("collatz(6)", collatz_steps(6), 8)

// ── 9. Additional break/continue patterns ─────────────────

println("")
println("--- Additional Break/Continue ---")

// Break on first match
let mut first_big = -1
let search_arr = [1, 3, 7, 12, 5, 20]
let mut si2 = 0
while si2 < len(search_arr) {
    if search_arr[si2] > 10 {
        first_big = search_arr[si2]
        break
    }
    si2 = si2 + 1
}
check("break first >10", first_big, 12)

// Continue to skip negatives
let mut pos_sum = 0
let mixed = [3, -1, 5, -2, 7, -4]
for val in mixed {
    if val < 0 { continue }
    pos_sum = pos_sum + val
}
check("continue skip neg sum", pos_sum, 15)

// Nested break
let mut outer_sum = 0
let mut oi2 = 0
while oi2 < 5 {
    let mut ij2 = 0
    while ij2 < 5 {
        if ij2 == 3 { break }
        outer_sum = outer_sum + 1
        ij2 = ij2 + 1
    }
    oi2 = oi2 + 1
}
check("nested break 5x3", outer_sum, 15)

// ── 10. For-in range patterns ─────────────────────────────

println("")
println("--- For-In Range ---")

let mut range_sum3 = 0
for i in 0..10 {
    range_sum3 = range_sum3 + i
}
check("range 0..10 sum", range_sum3, 45)

let mut range_sq_sum = 0
for i in 1..6 {
    range_sq_sum = range_sq_sum + i * i
}
check("range sq sum 1..6", range_sq_sum, 55)

let mut even_count = 0
for i in 0..20 {
    if i % 2 == 0 { even_count = even_count + 1 }
}
check("evens in 0..20", even_count, 10)

// ── 11. Complex conditions ────────────────────────────────

println("")
println("--- Complex Conditions ---")

fn fizzbuzz(n) {
    if n % 15 == 0 { return "fizzbuzz" }
    if n % 3 == 0 { return "fizz" }
    if n % 5 == 0 { return "buzz" }
    return to_string(n)
}
check("fizzbuzz 15", fizzbuzz(15), "fizzbuzz")
check("fizzbuzz 9", fizzbuzz(9), "fizz")
check("fizzbuzz 10", fizzbuzz(10), "buzz")
check("fizzbuzz 7", fizzbuzz(7), "7")
check("fizzbuzz 30", fizzbuzz(30), "fizzbuzz")

fn day_type(d) {
    if d == 0 || d == 6 { return "weekend" }
    return "weekday"
}
check("day 0 weekend", day_type(0), "weekend")
check("day 3 weekday", day_type(3), "weekday")
check("day 6 weekend", day_type(6), "weekend")

// ── 12. Accumulator patterns ──────────────────────────────

println("")
println("--- Accumulator Patterns ---")

// Running max
fn running_max(arr) {
    let mut m = arr[0]
    let mut i = 1
    while i < len(arr) {
        if arr[i] > m { m = arr[i] }
        i = i + 1
    }
    return m
}
check("running_max [3,7,2,9,1]", running_max([3, 7, 2, 9, 1]), 9)
check("running_max [1]", running_max([1]), 1)
check("running_max [-5,-2,-8]", running_max([-5, -2, -8]), -2)

// ═══════════════════════════════════════════════════════════
