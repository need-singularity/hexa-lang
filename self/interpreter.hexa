// ═══════════════════════════════════════════════════════════
//  self/interpreter.hexa — HEXA interpreter written in HEXA
//  Phase 2 of self-hosting: execute AST directly
//  Minimal core: variables, functions, arrays, strings, control flow
// ═══════════════════════════════════════════════════════════

// ── Value representation ─────────────────────────────────
// Values are represented as structs with a "type" discriminator.
// This avoids needing Rust's enum; instead we use tag + fields.

struct Val {
    tag: string,    // "int", "float", "bool", "str", "char", "void", "array", "fn", "struct", "builtin"
    int_val: int,
    float_val: float,
    bool_val: bool,
    str_val: string,
    char_val: string,
    array_val: string,  // stored as external ref
    fn_name: string,
    fn_params: string,
    fn_body: string,
    struct_name: string,
    struct_fields: string
}

fn val_int(n) { return Val { tag: "int", int_val: n, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }
fn val_float(f) { return Val { tag: "float", int_val: 0, float_val: f, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }
fn val_bool(b) { return Val { tag: "bool", int_val: 0, float_val: 0.0, bool_val: b, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }
fn val_str(s) { return Val { tag: "str", int_val: 0, float_val: 0.0, bool_val: false, str_val: s, char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }
fn val_void() { return Val { tag: "void", int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }

// ── Environment (scope-based variable storage) ───────────

let mut env_vars = []      // array of {name, value} pairs
let mut env_scopes = [0]   // scope boundary stack
let mut env_fns = []      // function registry: name -> {params, body}
let mut return_flag = false
let mut return_val = val_void()
let mut break_flag = false
let mut continue_flag = false
let mut throw_flag = false
let mut throw_val = val_void()
// Panic: unrecoverable abort. Propagates through all enclosing blocks like
// throw, but is NOT cleared by try/catch or recover — only program exit
// observes it (interpret() prints "panic: <msg>" to stderr and returns void).
let mut panic_flag = false
let mut panic_msg = ""
let mut call_stack = []    // stack trace: array of function names
// ── Sprint C: yield / eager generator buffer ─────────────
// Functions containing `yield` accumulate values into gen_buffer; upon
// return the accumulated array becomes the function's result. This is
// semantically correct for finite generators (no coroutines required).
// Each call frame saves/restores the outer buffer+flag so nested and
// non-generator calls are unaffected.
let mut gen_buffer = []
let mut gen_active = false

// ── @memo/@memoize/@cache runtime support ───────────────
// fn_attrs: maps function name -> comma-separated attr string
let mut fn_attrs = []      // [[name, attrs_str], ...]
// memo_cache: [[fn_name, [[key_str, result_val], ...]], ...]
let mut memo_cache = []

fn fn_attrs_set(name, attrs) {
    fn_attrs = fn_attrs.push([name, attrs])
}

fn fn_attrs_get(name) {
    let mut i = len(fn_attrs) - 1
    while i >= 0 {
        if fn_attrs[i][0] == name { return fn_attrs[i][1] }
        i = i - 1
    }
    return ""
}

fn has_memo_attr(name) {
    let attrs = fn_attrs_get(name)
    if attrs == "" { return false }
    // Check for memoize, memo, or cache in comma-separated attrs
    if attrs == "memoize" || attrs == "memo" || attrs == "cache" { return true }
    if contains(attrs, "memoize") { return true }
    if contains(attrs, "memo") { return true }
    if contains(attrs, "cache") { return true }
    return false
}

fn memo_key_for_args(name, args) {
    let mut key = name + "("
    let mut i = 0
    while i < len(args) {
        if i > 0 { key = key + "," }
        key = key + val_to_string(args[i])
        i = i + 1
    }
    key = key + ")"
    return key
}

fn memo_lookup(key) {
    let mut i = 0
    while i < len(memo_cache) {
        if memo_cache[i][0] == key { return memo_cache[i] }
        i = i + 1
    }
    return ""
}

fn memo_store(key, result) {
    memo_cache = memo_cache.push([key, result])
}

// ── Extern FFI storage ──────────────────────────────────
// Each entry: [hexa_name, c_symbol, ret_type, link_lib]
// c_symbol is from @symbol("name"); if empty, hexa_name is used for dlsym.
let mut extern_fns = []

// Look up the C symbol name for a hexa extern function.
// Returns the @symbol alias if set, otherwise the hexa name itself.
fn extern_c_symbol(hexa_name) {
    let mut i = len(extern_fns) - 1
    while i >= 0 {
        if extern_fns[i][0] == hexa_name {
            return extern_fns[i][1]
        }
        i = i - 1
    }
    return hexa_name
}

// Look up the link library for a hexa extern function.
fn extern_link_lib(hexa_name) {
    let mut i = len(extern_fns) - 1
    while i >= 0 {
        if extern_fns[i][0] == hexa_name {
            return extern_fns[i][3]
        }
        i = i - 1
    }
    return ""
}

// ── Impl block storage (struct method dispatch) ─────────
// Each entry: [target_name, methods_array]
// methods_array: each is a FnDecl node with .name, .params, .body
let mut impl_store = []

// ── Closure environment storage ─────────────────────────
// Closures capture a snapshot of env_vars at creation time
let mut closure_store = []

// ── Callback trampoline storage (G4) ───────────────────
// Pool of 16 callback slots for interpreter mode.
// Each slot: [in_use (0/1), fn_val]
let mut callback_slots = []
let mut callback_inited = false

fn callback_init() {
    if callback_inited { return 0 }
    callback_inited = true
    let mut i = 0
    while i < 16 {
        callback_slots = callback_slots.push([0, val_void()])
        i = i + 1
    }
    return 0
}

fn callback_slots_put(idx, entry) {
    let mut new_slots = []
    let mut i = 0
    while i < 16 {
        if i == idx {
            new_slots = new_slots.push(entry)
        } else {
            new_slots = new_slots.push(callback_slots[i])
        }
        i = i + 1
    }
    callback_slots = new_slots
}

fn callback_alloc(fn_val) {
    callback_init()
    let mut i = 0
    while i < 16 {
        if callback_slots[i][0] == 0 {
            callback_slots_put(i, [1, fn_val])
            return i
        }
        i = i + 1
    }
    println("callback pool exhausted (16 slots)")
    return -1
}

fn callback_release(slot) {
    callback_init()
    if slot >= 0 && slot < 16 {
        callback_slots_put(slot, [0, val_void()])
    }
}

fn callback_call(slot, args) {
    callback_init()
    if slot < 0 || slot >= 16 { return val_void() }
    if callback_slots[slot][0] == 0 { return val_void() }
    let fn_val = callback_slots[slot][1]
    if fn_val.tag == "fn" {
        return call_fn_val(fn_val, args)
    }
    return val_void()
}

fn env_push_scope() {
    env_scopes = env_scopes.push(len(env_vars))
}

fn env_pop_scope() {
    let boundary = env_scopes[len(env_scopes) - 1]
    // Remove the last scope marker
    let mut new_scopes = []
    for i in 0..len(env_scopes)-1 {
        new_scopes = new_scopes.push(env_scopes[i])
    }
    env_scopes = new_scopes
    // Truncate vars to boundary
    let mut new_vars = []
    for i in 0..boundary {
        new_vars = new_vars.push(env_vars[i])
    }
    env_vars = new_vars
}

fn env_define(name, value) {
    env_vars = env_vars.push([name, value])
}

fn env_lookup(name) {
    // Walk backwards for lexical scoping
    let i = len(env_vars) - 1
    while i >= 0 {
        if env_vars[i][0] == name {
            return env_vars[i][1]
        }
        i = i - 1
    }
    return val_void()
}

fn env_set(name, value) {
    let i = len(env_vars) - 1
    while i >= 0 {
        if env_vars[i][0] == name {
            env_vars[i] = [name, value]
            return true
        }
        i = i - 1
    }
    return false
}

// ── Core: eval_expr ──────────────────────────────────────

fn eval_expr_at(arr, idx) {
    let k = arr[idx].kind

    if k == "IntLit" { return val_int(to_int(arr[idx].value)) }
    if k == "FloatLit" { return val_float(to_float(arr[idx].value)) }
    if k == "BoolLit" { return val_bool(arr[idx].value == "true") }
    if k == "StringLit" { return val_str(arr[idx].value) }
    if k == "CharLit" { return val_str(arr[idx].value) }
    if k == "Ident" { return env_lookup(arr[idx].name) }
    // For complex nodes, we need to extract children
    // This is OK because arr[idx].left gives a reference, not a deep copy
    return eval_expr_inner(arr[idx])
}

fn eval_expr(node) {
    let _tmp_arr = [node]
    return eval_expr_at(_tmp_arr, 0)
}

fn eval_expr_inner(node) {
    let k = node.kind

    if k == "IntLit" { return val_int(to_int(node.value)) }
    if k == "FloatLit" { return val_float(to_float(node.value)) }
    if k == "BoolLit" { return val_bool(node.value == "true") }
    if k == "StringLit" { return val_str(node.value) }
    if k == "CharLit" { return val_str(node.value) }
    if k == "Ident" { return env_lookup(node.name) }

    if k == "BinOp" {
        let lv = eval_expr(node.left)
        let rv = eval_expr(node.right)
        return eval_binop(node.op, lv, rv)
    }

    if k == "UnaryOp" {
        let v = eval_expr(node.left)
        if node.op == "-" {
            if v.tag == "int" { return val_int(-v.int_val) }
            if v.tag == "float" { return val_float(-v.float_val) }
        }
        if node.op == "!" {
            return val_bool(!is_truthy(v))
        }
        // Bitwise NOT (ported from src/interpreter.rs eval_unary)
        if node.op == "~" {
            if v.tag == "int" { return val_int(~v.int_val) }
        }
        return v
    }

    if k == "Array" {
        let mut items = []
        for item in node.items {
            items = items.push(eval_expr(item))
        }
        return val_array(items)
    }

    if k == "Index" {
        // G13: array/string slicing — arr[start..end] or arr[start..=end]
        if type_of(node.right) != "string" && node.right.kind == "Range" {
            let arr_s = eval_expr(node.left)
            let s = eval_expr(node.right.left).int_val
            let e_raw = eval_expr(node.right.right).int_val
            // parser encodes inclusive/exclusive in node.value
            let inc = node.right.value == "inclusive"
            if arr_s.tag == "array" {
                let items = get_array(arr_s)
                let n = len(items)
                let mut e = e_raw
                if inc { e = e + 1 }
                if e > n { e = n }
                if s > e { return val_array([]) }
                let mut out = []
                let mut i = s
                while i < e {
                    out = out.push(items[i])
                    i = i + 1
                }
                return val_array(out)
            }
            if arr_s.tag == "str" {
                let chars = arr_s.str_val.chars()
                let n = len(chars)
                let mut e = e_raw
                if inc { e = e + 1 }
                if e > n { e = n }
                if s > e { return val_str("") }
                let mut out = ""
                let mut i = s
                while i < e {
                    out = out + to_string(chars[i])
                    i = i + 1
                }
                return val_str(out)
            }
            return val_void()
        }
        let arr = eval_expr(node.left)
        let idx = eval_expr(node.right)
        if arr.tag == "array" {
            let items = get_array(arr)
            return items[idx.int_val]
        }
        if arr.tag == "str" {
            let chars = arr.str_val.chars()
            return val_str(to_string(chars[idx.int_val]))
        }
        return val_void()
    }

    if k == "Call" {
        // Inline Call handling (avoid struct copy issue with eval_call)
        let mut call_args = []
        let raw_args = node.args
        if type_of(raw_args) == "array" {
            let mut _ai = 0
            while _ai < len(raw_args) {
                call_args = call_args.push(eval_expr_at(raw_args, _ai))
                _ai = _ai + 1
            }
        }
        let callee = node.left
        // Enum variant constructor call: Name::Variant(args...)
        if type_of(callee) != "string" && callee.kind == "EnumPath" {
            if len(call_args) == 0 {
                return val_enum(callee.name, callee.value, "")
            }
            if len(call_args) == 1 {
                return val_enum(callee.name, callee.value, call_args[0])
            }
            return val_enum(callee.name, callee.value, val_array(call_args))
        }
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let fname = callee.name
            let br = call_builtin(fname, call_args)
            if br.tag != "__not_builtin__" { return br }
            return call_user_fn(fname, call_args)
        }
        if type_of(callee) != "string" && callee.kind == "Field" {
            let obj = eval_expr(callee.left)
            let method = callee.name
            let result = call_method(obj, method, call_args)
            // In-place mutation: if receiver is a plain Ident and method is a mutator,
            // write the new array back into the variable slot.
            if type_of(callee.left) != "string" && callee.left.kind == "Ident" {
                if obj.tag == "array" && result.tag == "array" {
                    if method == "push" || method == "pop" {
                        env_set(callee.left.name, result)
                    }
                }
            }
            return result
        }
        let callee_val = eval_expr(callee)
        if callee_val.tag == "fn" { return call_fn_val(callee_val, call_args) }
        return val_void()
    }

    if k == "Field" {
        let obj = eval_expr(node.left)
        let field = node.name
        // Method call is handled in eval_call
        // Field access on struct
        if obj.tag == "struct" {
            let fields = get_struct_fields(obj)
            return fields[field]
        }
        return val_void()
    }

    if k == "IfExpr" {
        let cond = eval_expr(node.cond)
        if is_truthy(cond) {
            return eval_block(node.then_body)
        }
        if node.else_body != "" {
            return eval_block(node.else_body)
        }
        return val_void()
    }

    if k == "Lambda" {
        // Capture current environment for closure
        let mut captured = []
        let mut ci = 0
        while ci < len(env_vars) {
            captured = captured.push([env_vars[ci][0], env_vars[ci][1]])
            ci = ci + 1
        }
        return val_closure("__lambda__", node.params, node.left, captured)
    }

    if k == "MapLit" {
        let mut keys = []
        let mut values = []
        let entries = node.items
        let mut mi = 0
        while mi < len(entries) {
            let entry = entries[mi]
            keys = keys.push(eval_expr(entry.left))
            values = values.push(eval_expr(entry.right))
            mi = mi + 1
        }
        return val_map(keys, values)
    }

    if k == "Range" {
        let start = eval_expr(node.left)
        let end_val = eval_expr(node.right)
        let mut items = []
        let mut ri = start.int_val
        while ri < end_val.int_val {
            items = items.push(val_int(ri))
            ri = ri + 1
        }
        return val_array(items)
    }

    if k == "Assign" {
        let val = eval_expr(node.right)
        if node.left.kind == "Ident" {
            env_set(node.left.name, val)
        }
        if node.left.kind == "Index" {
            let arr = eval_expr(node.left.left)
            let idx = eval_expr(node.left.right)
            if arr.tag == "array" {
                let items = get_array(arr)
                let mut new_items = []
                let mut ai = 0
                while ai < len(items) {
                    if ai == idx.int_val {
                        new_items = new_items.push(val)
                    } else {
                        new_items = new_items.push(items[ai])
                    }
                    ai = ai + 1
                }
                // Update array store in-place
                array_store[arr.int_val] = new_items
            }
        }
        return val
    }

    if k == "TupleLit" {
        let mut items = []
        for item in node.items {
            items = items.push(eval_expr(item))
        }
        return val_array(items)
    }

    // ── StructInit: Name { field: val, ... } ────────────────
    if k == "StructInit" {
        let sname = node.name
        let field_inits = node.fields
        let mut field_map = #{}
        let mut si = 0
        while si < len(field_inits) {
            let fi = field_inits[si]
            let fname = fi.name
            let fval = eval_expr(fi.left)
            field_map[fname] = fval
            si = si + 1
        }
        return val_struct(sname, field_map)
    }

    // ── EnumPath: EnumName::Variant or EnumName::Variant(data) ──
    if k == "EnumPath" {
        let data = node.left
        let mut data_val = ""
        if type_of(data) != "string" || data != "" {
            data_val = eval_expr(data)
        }
        return val_enum(node.name, node.value, data_val)
    }

    // ── ThrowExpr: throw as expression (returns void, sets throw_flag) ──
    if k == "ThrowExpr" || k == "ThrowStmt" {
        let err = eval_expr(node.left)
        exec_throw(err)
        return val_void()
    }

    // ── MatchExpr: match expr { pattern -> body, ... } ──────
    if k == "MatchExpr" {
        let scrutinee = eval_expr(node.left)
        let arms = node.arms
        let mut mi = 0
        while mi < len(arms) {
            let arm = arms[mi]
            let pattern = arm.left
            let arm_body = arm.body
            let guard = arm.cond
            // Save env state before each arm — explicit snapshot ensures
            // pattern bindings never leak to the parent scope, even if
            // env_push/pop_scope is defeated by nested calls.
            let saved_env_vars = env_vars
            let saved_env_scopes = env_scopes
            env_push_scope()
            if match_pattern(pattern, scrutinee) {
                // Check guard clause if present
                let mut guard_ok = true
                if type_of(guard) != "string" || guard != "" {
                    let gv = eval_expr(guard)
                    guard_ok = is_truthy(gv)
                }
                if guard_ok {
                    let result = eval_body(arm_body)
                    env_pop_scope()
                    // Restore env to pre-match state to prevent leakage
                    env_vars = saved_env_vars
                    env_scopes = saved_env_scopes
                    if return_flag {
                        return return_val
                    }
                    return result
                }
            }
            env_pop_scope()
            // Restore env to pre-match state for failed arms too
            env_vars = saved_env_vars
            env_scopes = saved_env_scopes
            mi = mi + 1
        }
        return val_void()
    }

    return val_void()
}

// ── Binary operations ────────────────────────────────────

fn eval_binop(op, a, b) {
    // Int fast path
    if a.tag == "int" && b.tag == "int" {
        let x = a.int_val
        let y = b.int_val
        if op == "+" { return val_int(x + y) }
        if op == "-" { return val_int(x - y) }
        if op == "*" { return val_int(x * y) }
        if op == "/" {
            if y == 0 { println("runtime error: division by zero"); return val_void() }
            return val_int(x / y)
        }
        if op == "%" {
            if y == 0 { println("runtime error: division by zero"); return val_void() }
            return val_int(x % y)
        }
        if op == "**" { return val_int(pow(x, y)) }
        if op == "==" { return val_bool(x == y) }
        if op == "!=" { return val_bool(x != y) }
        if op == "<" { return val_bool(x < y) }
        if op == ">" { return val_bool(x > y) }
        if op == "<=" { return val_bool(x <= y) }
        if op == ">=" { return val_bool(x >= y) }
        if op == "&&" { return val_bool(x != 0 && y != 0) }
        if op == "||" { return val_bool(x != 0 || y != 0) }
        // Bitwise operations (ported from src/interpreter.rs eval_binary)
        if op == "&" {
            let r = x & y
            return val_int(r)
        }
        if op == "|" {
            // NOTE: x | y triggers parser lambda-ambiguity inside parens,
            // so we use the identity: x|y = (x+y) - (x&y)
            let r = (x + y) - (x & y)
            return val_int(r)
        }
        if op == "^" {
            let r = x ^ y
            return val_int(r)
        }
        if op == "<<" {
            // x << y = x * 2^y (avoiding << parser issues)
            let r = x * pow(2, y)
            return val_int(r)
        }
        if op == ">>" {
            // x >> y = x / 2^y (avoiding >> parser issues)
            let r = x / pow(2, y)
            return val_int(r)
        }
    }
    // String concatenation (str + anything)
    if a.tag == "str" && op == "+" {
        return val_str(a.str_val + val_to_string(b))
    }
    // Char + String / Char + Char concatenation
    if a.tag == "char" && op == "+" {
        return val_str(a.str_val + val_to_string(b))
    }
    // Float arithmetic (with int-to-float coercion)
    if (a.tag == "float" || b.tag == "float") {
        let x = to_float(a)
        let y = to_float(b)
        if op == "+" { return val_float(x + y) }
        if op == "-" { return val_float(x - y) }
        if op == "*" { return val_float(x * y) }
        if op == "/" {
            if y == 0.0 { println("runtime error: division by zero"); return val_void() }
            return val_float(x / y)
        }
        if op == "%" { return val_float(x % y) }
        if op == "**" { return val_float(pow(x, y)) }
        if op == "==" { return val_bool(x == y) }
        if op == "!=" { return val_bool(x != y) }
        if op == "<" { return val_bool(x < y) }
        if op == ">" { return val_bool(x > y) }
        if op == "<=" { return val_bool(x <= y) }
        if op == ">=" { return val_bool(x >= y) }
    }
    // Bool operations
    if a.tag == "bool" && b.tag == "bool" {
        if op == "==" { return val_bool(a.bool_val == b.bool_val) }
        if op == "!=" { return val_bool(a.bool_val != b.bool_val) }
        if op == "&&" { return val_bool(a.bool_val && b.bool_val) }
        if op == "||" { return val_bool(a.bool_val || b.bool_val) }
        if op == "^" { return val_bool(a.bool_val != b.bool_val) }
    }
    // String comparisons
    if a.tag == "str" && b.tag == "str" {
        if op == "==" { return val_bool(a.str_val == b.str_val) }
        if op == "!=" { return val_bool(a.str_val != b.str_val) }
    }
    // Char comparisons
    if a.tag == "char" && b.tag == "char" {
        if op == "==" { return val_bool(a.str_val == b.str_val) }
        if op == "!=" { return val_bool(a.str_val != b.str_val) }
        if op == "<" { return val_bool(a.str_val < b.str_val) }
        if op == ">" { return val_bool(a.str_val > b.str_val) }
        if op == "<=" { return val_bool(a.str_val <= b.str_val) }
        if op == ">=" { return val_bool(a.str_val >= b.str_val) }
    }
    // Array concatenation (ported from src/interpreter.rs)
    if a.tag == "array" && b.tag == "array" && op == "+" {
        let a_items = get_array(a)
        let b_items = get_array(b)
        let mut result = []
        for item in a_items { result = result.push(item) }
        for item in b_items { result = result.push(item) }
        return val_array(result)
    }
    // Array repetition: [1,2] * 3 => [1,2,1,2,1,2]
    if a.tag == "array" && b.tag == "int" && op == "*" {
        let items = get_array(a)
        let n = b.int_val
        let mut result = []
        let mut ri = 0
        while ri < n {
            for item in items { result = result.push(item) }
            ri = ri + 1
        }
        return val_array(result)
    }
    // Array equality
    if a.tag == "array" && b.tag == "array" {
        if op == "==" {
            let a_items = get_array(a)
            let b_items = get_array(b)
            if len(a_items) != len(b_items) { return val_bool(false) }
            let mut ei = 0
            while ei < len(a_items) {
                if !vals_equal(a_items[ei], b_items[ei]) { return val_bool(false) }
                ei = ei + 1
            }
            return val_bool(true)
        }
        if op == "!=" {
            let eq = eval_binop("==", a, b)
            return val_bool(!eq.bool_val)
        }
    }
    // Cross-type Eq/Ne: different value types are never equal
    if op == "==" { return val_bool(false) }
    if op == "!=" { return val_bool(true) }
    return val_void()
}

// ── Value equality (for pattern matching) ───────────────

fn vals_equal(a, b) {
    if a.tag != b.tag { return false }
    if a.tag == "int" { return a.int_val == b.int_val }
    if a.tag == "float" { return a.float_val == b.float_val }
    if a.tag == "bool" { return a.bool_val == b.bool_val }
    if a.tag == "str" { return a.str_val == b.str_val }
    if a.tag == "enum" { return a.struct_name == b.struct_name && a.int_val == b.int_val }
    if a.tag == "void" { return true }
    return false
}

// ── Pattern matching ────────────────────────────────────

fn match_pattern(pattern, value) {
    let pk = pattern.kind
    // Wildcard _ matches anything
    if pk == "Wildcard" { return true }
    // Integer literal pattern
    if pk == "IntLit" {
        if value.tag == "int" { return value.int_val == to_int(pattern.value) }
        return false
    }
    // String literal pattern
    if pk == "StringLit" {
        if value.tag == "str" { return value.str_val == pattern.value }
        return false
    }
    // Bool literal pattern
    if pk == "BoolLit" {
        if value.tag == "bool" { return value.bool_val == (pattern.value == "true") }
        return false
    }
    // Float literal pattern
    if pk == "FloatLit" {
        if value.tag == "float" { return value.float_val == to_float(pattern.value) }
        return false
    }
    // Negative literal pattern: -1, -3.14 etc.
    if pk == "UnaryOp" && pattern.op == "-" {
        let inner = pattern.left
        if inner.kind == "IntLit" {
            if value.tag == "int" { return value.int_val == -to_int(inner.value) }
            return false
        }
        if inner.kind == "FloatLit" {
            if value.tag == "float" { return value.float_val == -to_float(inner.value) }
            return false
        }
        return false
    }
    // EnumPath pattern: EnumName::Variant or EnumName::Variant(binding)
    if pk == "EnumPath" {
        if value.tag != "enum" { return false }
        // Match variant name
        let expected = pattern.name + "::" + pattern.value
        if value.struct_name != expected { return false }
        // If pattern has data binding, bind it
        let data_pattern = pattern.left
        let multi_pats = pattern.items
        if type_of(multi_pats) == "array" && len(multi_pats) > 0 {
            // Multi-field variant: value data must be array
            let data_val = get_enum_data(value)
            if data_val.tag != "array" { return false }
            let ditems = get_array(data_val)
            if len(ditems) != len(multi_pats) { return false }
            let mut mp = 0
            while mp < len(multi_pats) {
                let sub = multi_pats[mp]
                if type_of(sub) != "string" && sub.kind == "Ident" {
                    env_define(sub.name, ditems[mp])
                } else {
                    if !match_pattern(sub, ditems[mp]) { return false }
                }
                mp = mp + 1
            }
            return true
        }
        if type_of(data_pattern) != "string" || data_pattern != "" {
            let data_val = get_enum_data(value)
            // If data pattern is an Ident, bind it
            if data_pattern.kind == "Ident" {
                env_define(data_pattern.name, data_val)
            } else {
                // Literal data pattern — must match
                return match_pattern(data_pattern, data_val)
            }
        }
        return true
    }
    // Call pattern: Some(x), Ok(x), Err(x) — shorthand enum constructors
    if pk == "Call" {
        let callee = pattern.left
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let ctor = callee.name
            let mut enum_name = ""
            let mut variant_name = ""
            if ctor == "Some" { enum_name = "Option"; variant_name = "Some" }
            if ctor == "Ok" { enum_name = "Result"; variant_name = "Ok" }
            if ctor == "Err" { enum_name = "Result"; variant_name = "Err" }
            if enum_name != "" {
                // Must be an enum value matching this constructor
                if value.tag != "enum" { return false }
                let expected = enum_name + "::" + variant_name
                if value.struct_name != expected { return false }
                // Bind the data argument if present
                let call_args = pattern.args
                if type_of(call_args) == "array" && len(call_args) == 1 {
                    let data_val = get_enum_data(value)
                    let arg_pat = call_args[0]
                    if type_of(arg_pat) != "string" && arg_pat.kind == "Ident" {
                        env_define(arg_pat.name, data_val)
                        return true
                    }
                    // Nested pattern match on data
                    return match_pattern(arg_pat, data_val)
                }
                // No args — match variant with no data
                if type_of(call_args) != "array" || len(call_args) == 0 {
                    if get_enum_data(value).tag == "void" { return true }
                }
                return false
            }
        }
        // Not a known constructor — evaluate and compare
        let pattern_val = eval_expr(pattern)
        return vals_equal(pattern_val, value)
    }
    // Array/tuple pattern: [a, b, c]
    if pk == "Array" {
        if value.tag != "array" { return false }
        let items = get_array(value)
        let pats = pattern.items
        if type_of(pats) != "array" { return false }
        if len(pats) != len(items) { return false }
        let mut pi = 0
        while pi < len(pats) {
            if !match_pattern(pats[pi], items[pi]) { return false }
            pi = pi + 1
        }
        return true
    }
    // Identifier pattern: check for known enum constant, otherwise variable binding
    if pk == "Ident" {
        let name = pattern.name
        // Check if it's a known enum constant (e.g., None)
        let mut ei = len(env_vars) - 1
        while ei >= 0 {
            if env_vars[ei][0] == name {
                let existing = env_vars[ei][1]
                if existing.tag == "enum" {
                    // Compare enum values
                    return vals_equal(existing, value)
                }
                // Not an enum — treat as binding below
                ei = -1
            } else {
                ei = ei - 1
            }
        }
        // Bind as variable
        env_define(name, value)
        return true
    }
    // Fallback: evaluate pattern as expression and compare
    let pattern_val = eval_expr(pattern)
    return vals_equal(pattern_val, value)
}

// ── Error handling helpers ────────────────────────────────

fn exec_throw(err) {
    // Attach stack trace to all thrown values
    if err.tag == "str" {
        let mut keys = [val_str("message"), val_str("trace")]
        let mut values = [err, val_str(format_stack_trace())]
        throw_val = val_map(keys, values)
    } else if err.tag == "map" {
        // If already a map, add trace field if missing
        let keys = get_map_keys(err)
        let values = get_map_values(err)
        let mut has_trace = false
        let mut ki = 0
        while ki < len(keys) {
            if keys[ki].tag == "str" && keys[ki].str_val == "trace" {
                has_trace = true
            }
            ki = ki + 1
        }
        if !has_trace {
            let new_keys = keys.push(val_str("trace"))
            let new_vals = values.push(val_str(format_stack_trace()))
            throw_val = val_map(new_keys, new_vals)
        } else {
            throw_val = err
        }
    } else {
        throw_val = err
    }
    throw_flag = true
}

fn exec_try_catch(try_body, catch_var, catch_body) {
    // Save throw state
    let saved_throw = throw_flag
    throw_flag = false

    // Execute try body
    env_push_scope()
    let mut ti = 0
    while ti < len(try_body) {
        if return_flag || throw_flag || panic_flag { ti = len(try_body) } else {
            exec_stmt_at(try_body, ti)
            ti = ti + 1
        }
    }
    env_pop_scope()

    // Panic is not catchable — propagate immediately.
    if panic_flag { return val_void() }

    if throw_flag {
        // Error was thrown — execute catch body
        let err = throw_val
        throw_flag = false
        throw_val = val_void()
        env_push_scope()
        env_define(catch_var, err)
        let mut ci = 0
        while ci < len(catch_body) {
            if return_flag || throw_flag || panic_flag { ci = len(catch_body) } else {
                exec_stmt_at(catch_body, ci)
                ci = ci + 1
            }
        }
        env_pop_scope()
    } else {
        throw_flag = saved_throw
    }
    return val_void()
}

// ── Core: exec_stmt ──────────────────────────────────────

fn exec_stmt(node) {
    let _tmp = [node]
    return exec_stmt_at(_tmp, 0)
}

fn exec_stmt_at(stmts, idx) {
    let node = stmts[idx]
    let k = node.kind

    if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "StaticStmt" {
        let val = val_void()
        let init = node.left
        if type_of(init) != "string" || init != "" {
            val = eval_expr(init)
        }
        env_define(node.name, val)
        return val_void()
    }

    if k == "AssignStmt" {
        let val = eval_expr(node.right)
        if node.left.kind == "Ident" {
            env_set(node.left.name, val)
        }
        return val_void()
    }

    if k == "ExprStmt" {
        let expr = node.left
        if type_of(expr) == "string" { return val_void() }
        return eval_expr(expr)
    }

    if k == "ReturnStmt" {
        if node.left != "" {
            return_val = eval_expr(node.left)
        } else {
            return_val = val_void()
        }
        return_flag = true
        return val_void()
    }

    // Sprint C: yield <expr> — append to current gen_buffer and mark
    // this call frame as a generator. Does not set return_flag, so
    // execution continues and further yields may append more values.
    if k == "YieldStmt" {
        let yv = val_void()
        if node.left != "" {
            yv = eval_expr(node.left)
        }
        gen_buffer = gen_buffer.push(yv)
        gen_active = true
        return val_void()
    }

    if k == "FnDecl" || k == "AsyncFnDecl" {
        env_fns = env_fns.push([node.name, node.params, node.body])
        let fn_val = val_fn(node.name, node.params, node.body)
        env_define(node.name, fn_val)
        // Store @attrs for runtime interception (@memo/@memoize/@cache)
        if node.value != "" {
            fn_attrs_set(node.name, node.value)
        }
        return val_void()
    }

    if k == "ExternFnDecl" {
        // Register extern function declaration.
        // node.value = @symbol("c_name") alias (empty → use node.name)
        // node.op    = @link("lib") library name (empty → default)
        let c_symbol = node.value
        if c_symbol == "" {
            c_symbol = node.name
        }
        let ret = node.ret_type
        let link = node.op
        extern_fns = extern_fns.push([node.name, c_symbol, ret, link])
        // Register as a builtin-style binding so calls route to FFI
        let builtin_name = "__extern_" + node.name
        env_define(node.name, val_str(builtin_name))
        return val_void()
    }

    if k == "IfStmt" {
        let cond = eval_expr(node.cond)
        if is_truthy(cond) {
            env_push_scope()
            eval_body(node.then_body)
            env_pop_scope()
        } else if node.else_body != "" {
            env_push_scope()
            eval_body(node.else_body)
            env_pop_scope()
        }
        return val_void()
    }

    if k == "CompoundAssign" {
        let lv = eval_expr(node.left)
        let rv = eval_expr(node.right)
        let result = eval_binop(node.op, lv, rv)
        if node.left.kind == "Ident" {
            env_set(node.left.name, result)
        }
        return val_void()
    }

    if k == "BreakStmt" {
        break_flag = true
        return val_void()
    }

    if k == "ContinueStmt" {
        continue_flag = true
        return val_void()
    }

    if k == "StructDecl" || k == "EnumDecl" || k == "TraitDecl" {
        // Type declarations — store for later use
        return val_void()
    }

    if k == "ImplBlock" {
        // Store impl block methods for struct method dispatch
        let target = node.target
        let methods = node.methods
        impl_store = impl_store.push([target, methods])
        // Also register methods as functions with mangled names: Type__method
        let mut mi = 0
        while mi < len(methods) {
            let m = methods[mi]
            let mangled = target + "__" + m.name
            env_fns = env_fns.push([mangled, m.params, m.body])
            mi = mi + 1
        }
        return val_void()
    }

    if k == "ThrowStmt" {
        let err = eval_expr(node.left)
        exec_throw(err)
        return val_void()
    }

    if k == "PanicStmt" {
        let msg_val = eval_expr(node.left)
        if msg_val.tag == "str" {
            panic_msg = msg_val.str_val
        } else {
            panic_msg = val_to_string(msg_val)
        }
        panic_flag = true
        // Also set throw_flag so existing propagation checks in while/for/if
        // blocks (which test throw_flag) abort immediately. The flag is never
        // cleared by try/catch/recover because panic_flag remains set and
        // those arms only reset throw_flag while panic_flag stays true, which
        // our propagation checks also watch.
        throw_flag = true
        return val_void()
    }

    if k == "TryCatch" {
        return exec_try_catch(node.left, node.name, node.right)
    }

    if k == "RecoverStmt" {
        let body = node.left
        let catch_var = node.name

        // Save throw state
        let saved_throw = throw_flag
        throw_flag = false

        // Execute body
        env_push_scope()
        let mut result = val_void()
        let mut ri = 0
        while ri < len(body) {
            if return_flag || throw_flag || panic_flag { ri = len(body) } else {
                result = exec_stmt_at(body, ri)
                ri = ri + 1
            }
        }
        env_pop_scope()

        // Panic is not recoverable — propagate to program exit.
        if panic_flag { return val_void() }

        if throw_flag {
            // Throw occurred — recover from it
            let err = throw_val
            throw_flag = false
            throw_val = val_void()
            if catch_var != "_" {
                // Bind the error to the variable in the calling scope
                env_define(catch_var, err)
            }
            return val_void()
        } else {
            throw_flag = saved_throw
        }
        return result
    }

    if k == "WhileStmt" {
        while !return_flag && !break_flag && !throw_flag {
            let cond = eval_expr(node.cond)
            if !is_truthy(cond) { return val_void() }
            env_push_scope()
            continue_flag = false
            let mut _wi = 0
            while _wi < len(node.body) {
                if return_flag || break_flag || continue_flag || throw_flag { _wi = len(node.body) } else {
                    exec_stmt_at(node.body, _wi)
                    _wi = _wi + 1
                }
            }
            env_pop_scope()
            if continue_flag { continue_flag = false }
        }
        if break_flag { break_flag = false }
        return val_void()
    }

    if k == "ForStmt" {
        let iter_val = eval_expr(node.iter_expr)
        if iter_val.tag == "array" {
            let items = get_array(iter_val)
            let mut _fi2 = 0
            while _fi2 < len(items) {
                if return_flag || break_flag || throw_flag { _fi2 = len(items) } else {
                    env_push_scope()
                    continue_flag = false
                    env_define(node.name, items[_fi2])
                    let mut _fbi = 0
                    while _fbi < len(node.body) {
                        if return_flag || break_flag || continue_flag || throw_flag { _fbi = len(node.body) } else {
                            exec_stmt_at(node.body, _fbi)
                            _fbi = _fbi + 1
                        }
                    }
                    env_pop_scope()
                    if continue_flag { continue_flag = false }
                    _fi2 = _fi2 + 1
                }
            }
        }
        if break_flag { break_flag = false }
        return val_void()
    }

    if k == "LoopStmt" {
        while !return_flag && !break_flag && !throw_flag {
            env_push_scope()
            eval_body(node.body)
            env_pop_scope()
        }
        if break_flag { break_flag = false }
        return val_void()
    }

    // Ignore unknown statement kinds
    return val_void()
}

// ── Execute a block of statements ────────────────────────

fn eval_body(stmts) {
    let mut result = val_void()
    let mut _bi = 0
    while _bi < len(stmts) {
        if return_flag || throw_flag { return result }
        result = exec_stmt_at(stmts, _bi)
        _bi = _bi + 1
    }
    return result
}

fn eval_block(stmts) {
    env_push_scope()
    let result = eval_body(stmts)
    env_pop_scope()
    return result
}

// ── Function call ────────────────────────────────────────

fn eval_call(node) {
    // Collect arguments
    let mut args = []
    let raw_args = node.args
    if type_of(raw_args) == "array" {
        for a in raw_args {
            args = args.push(eval_expr(a))
        }
    }

    // Method call: obj.method(args)
    let callee = node.left
    if type_of(callee) != "string" && callee.kind == "Field" {
        let obj = eval_expr(callee.left)
        let method = callee.name
        let result = call_method(obj, method, args)
        if type_of(callee.left) != "string" && callee.left.kind == "Ident" {
            if obj.tag == "array" && result.tag == "array" {
                if method == "push" || method == "pop" {
                    env_set(callee.left.name, result)
                }
            }
        }
        return result
    }

    // Direct call: name(args)
    if type_of(callee) != "string" && callee.kind == "Ident" {
        let name = callee.name
        // Builtins
        let builtin_result = call_builtin(name, args)
        if builtin_result.tag != "__not_builtin__" {
            return builtin_result
        }
        // User functions
        return call_user_fn(name, args)
    }

    // Indirect call (lambda etc)
    let callee_val = eval_expr(callee)
    if callee_val.tag == "fn" {
        return call_fn_val(callee_val, args)
    }

    return val_void()
}

fn find_fn(name) {
    let mut i = len(env_fns) - 1
    while i >= 0 {
        if env_fns[i][0] == name { return env_fns[i] }
        i = i - 1
    }
    return ""
}

fn call_user_fn(name, args) {
    let fn_info = find_fn(name)
    if fn_info == "" {
        // Try env lookup (for closures/passed functions)
        let fn_val = env_lookup(name)
        if fn_val.tag == "fn" {
            return call_fn_val(fn_val, args)
        }
        println("Runtime error: undefined function: " + name)
        return val_void()
    }

    // ── @memo/@memoize/@cache: check cache before execution ──
    let is_memo = has_memo_attr(name)
    let mut memo_key = ""
    if is_memo {
        memo_key = memo_key_for_args(name, args)
        let cached = memo_lookup(memo_key)
        if cached != "" {
            return cached[1]
        }
    }

    let params = fn_info[1]
    let body = fn_info[2]

    call_stack = call_stack.push(name)
    env_push_scope()
    let mut i = 0
    while i < len(params) && i < len(args) {
        if type_of(params[i]) == "string" {
            env_define(params[i], args[i])
        } else {
            env_define(params[i].name, args[i])
        }
        i = i + 1
    }

    let saved_flag = return_flag
    return_flag = false
    // Sprint C: save outer generator frame, start a fresh empty buffer
    // so that yields inside this call accumulate here only.
    let saved_gen_buffer = gen_buffer
    let saved_gen_active = gen_active
    gen_buffer = []
    gen_active = false
    // Inline body execution (avoid struct copy via eval_body)
    let mut _cbi = 0
    while _cbi < len(body) {
        if return_flag || throw_flag { _cbi = len(body) } else {
            exec_stmt_at(body, _cbi)
            _cbi = _cbi + 1
        }
    }
    let mut result = return_val
    // Sprint C: if at least one yield happened AND no explicit return
    // value was set, convert the accumulated buffer into an array value.
    if gen_active && !return_flag {
        result = val_array(gen_buffer)
    }
    gen_buffer = saved_gen_buffer
    gen_active = saved_gen_active
    return_flag = saved_flag
    return_val = val_void()
    env_pop_scope()
    // Pop call stack
    let mut new_stack = []
    let mut _csi = 0
    while _csi < len(call_stack) - 1 {
        new_stack = new_stack.push(call_stack[_csi])
        _csi = _csi + 1
    }
    call_stack = new_stack

    // ── @memo/@memoize/@cache: store result in cache ──
    if is_memo {
        memo_store(memo_key, result)
    }

    return result
}

fn call_fn_val(fn_val, args) {
    // ── Special functional closures ─────────────────────────
    if fn_val.str_val == "compose" {
        // compose(f, g) → f(g(x))
        let captured = closure_store[fn_val.int_val]
        let mut f = val_void()
        let mut g = val_void()
        let mut ci = 0
        while ci < len(captured) {
            if captured[ci][0] == "__compose_f" { f = captured[ci][1] }
            if captured[ci][0] == "__compose_g" { g = captured[ci][1] }
            ci = ci + 1
        }
        let inner = call_fn_val(g, args)
        return call_fn_val(f, [inner])
    }
    if fn_val.str_val == "curry" {
        // curry(fn, ...partial) → fn(partial..., args...)
        let captured = closure_store[fn_val.int_val]
        let mut f = val_void()
        let mut partial_arr = val_void()
        let mut ci = 0
        while ci < len(captured) {
            if captured[ci][0] == "__curry_fn" { f = captured[ci][1] }
            if captured[ci][0] == "__curry_partial" { partial_arr = captured[ci][1] }
            ci = ci + 1
        }
        let partial = get_array(partial_arr)
        let mut all_args = []
        for p in partial { all_args = all_args.push(p) }
        for a in args { all_args = all_args.push(a) }
        return call_fn_val(f, all_args)
    }
    if fn_val.str_val == "constant" {
        // constant(x) → fn() => x
        let captured = closure_store[fn_val.int_val]
        let mut ci = 0
        while ci < len(captured) {
            if captured[ci][0] == "__constant_val" { return captured[ci][1] }
            ci = ci + 1
        }
        return val_void()
    }

    // fn_val has fn_params (array) and fn_body (AST array)
    let params = fn_val.fn_params
    let body = fn_val.fn_body
    let is_closure = fn_val.str_val == "closure"

    // For closures, save current env and restore captured env
    let mut saved_vars = []
    let mut saved_scopes = []
    if is_closure {
        saved_vars = env_vars
        saved_scopes = env_scopes
        let captured = closure_store[fn_val.int_val]
        env_vars = captured
        env_scopes = [0]
    }

    env_push_scope()
    let mut i = 0
    while i < len(params) && i < len(args) {
        if type_of(params[i]) == "string" {
            env_define(params[i], args[i])
        } else {
            env_define(params[i].name, args[i])
        }
        i = i + 1
    }

    let saved_flag = return_flag
    return_flag = false
    // Sprint C: generator frame save/restore (see call_user_fn for notes)
    let saved_gen_buffer = gen_buffer
    let saved_gen_active = gen_active
    gen_buffer = []
    gen_active = false
    if type_of(body) == "array" {
        eval_body(body)
    } else {
        // Single expression body (lambda)
        return_val = eval_expr(body)
        return_flag = true
    }
    let mut result = return_val
    if gen_active && !return_flag {
        result = val_array(gen_buffer)
    }
    gen_buffer = saved_gen_buffer
    gen_active = saved_gen_active
    return_flag = saved_flag
    return_val = val_void()
    env_pop_scope()

    // Restore env for closures
    if is_closure {
        env_vars = saved_vars
        env_scopes = saved_scopes
    }

    return result
}

// ── Builtin functions ────────────────────────────────────

fn call_builtin(name, args) {
    let not_builtin = Val { tag: "__not_builtin__", int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }

    if name == "println" {
        let mut out = ""
        for a in args { out = out + val_to_string(a) }
        // R19: BrokenPipe(파이프 조기 종료) 감지 → graceful exit(0).
        // | head, | tail 등으로 consumer 종료 시 silent exit 1 방지.
        try {
            println(out)
        } catch e {
            let es = e.to_string()
            if es.contains("pipe") || es.contains("EPIPE") || es.contains("BrokenPipe") {
                exit(0)
            }
            eprintln("❌ [interpreter.println] " + es)
            exit(1)
        }
        return val_void()
    }
    if name == "print" {
        let mut out = ""
        for a in args { out = out + val_to_string(a) }
        try {
            print(out)
        } catch e {
            let es = e.to_string()
            if es.contains("pipe") || es.contains("EPIPE") || es.contains("BrokenPipe") {
                exit(0)
            }
            eprintln("❌ [interpreter.print] " + es)
            exit(1)
        }
        return val_void()
    }
    if name == "len" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == "str" { return val_int(len(a.str_val)) }
            if a.tag == "array" { return val_int(len(get_array(a))) }
        }
        return val_int(0)
    }
    if name == "to_string" {
        if len(args) > 0 { return val_str(val_to_string(args[0])) }
        return val_str("")
    }
    if name == "type_of" {
        if len(args) > 0 { return val_str(args[0].tag) }
        return val_str("void")
    }
    if name == "int" {
        if len(args) > 0 { return val_int(to_int(val_to_string(args[0]))) }
        return val_int(0)
    }
    if name == "float" {
        if len(args) > 0 { return val_float(to_float(val_to_string(args[0]))) }
        return val_float(0.0)
    }
    if name == "bool" {
        if len(args) > 0 { return val_bool(is_truthy(args[0])) }
        return val_bool(false)
    }
    if name == "char" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == "str" && len(a.str_val) > 0 {
                let cs = a.str_val.chars()
                return val_str(to_string(cs[0]))
            }
            if a.tag == "int" { return val_str(from_char_code(a.int_val)) }
        }
        return val_str("")
    }
    if name == "ord" {
        if len(args) > 0 && args[0].tag == "str" {
            let s = args[0].str_val
            if len(s) > 0 {
                let cs = s.chars()
                return val_int(char_code(cs[0]))
            }
        }
        return val_int(0)
    }
    if name == "chr" {
        if len(args) > 0 {
            return val_str(from_char_code(args[0].int_val))
        }
        return val_str("")
    }
    if name == "parse_int" {
        if len(args) > 0 {
            return val_int(to_int(args[0].str_val))
        }
        return val_int(0)
    }
    if name == "parse_float" {
        if len(args) > 0 {
            return val_float(to_float(args[0].str_val))
        }
        return val_float(0.0)
    }
    if name == "to_json" {
        if len(args) > 0 {
            return val_str(val_to_json(args[0]))
        }
        return val_str("null")
    }
    if name == "from_json" {
        if len(args) > 0 {
            return json_to_val(args[0].str_val)
        }
        return val_void()
    }
    if name == "is_alpha" {
        if len(args) > 0 { return val_bool(is_alpha(args[0].str_val)) }
        return val_bool(false)
    }
    if name == "is_digit" {
        if len(args) > 0 { return val_bool(is_digit(args[0].str_val)) }
        return val_bool(false)
    }
    if name == "is_alphanumeric" {
        if len(args) > 0 { return val_bool(is_alphanumeric(args[0].str_val)) }
        return val_bool(false)
    }
    if name == "format" {
        // format(template, arg0, arg1, ...) with {}, {0}, {:.2} support
        if len(args) == 0 { return val_str("") }
        let tmpl = args[0].str_val
        let mut out = ""
        let mut arg_idx = 1
        let chars_arr = tmpl.chars()
        let tlen = len(chars_arr)
        let mut ci = 0
        while ci < tlen {
            let ch = to_string(chars_arr[ci])
            if ch == "{" && ci + 1 < tlen {
                // Look for closing }
                let mut end = ci + 1
                while end < tlen && to_string(chars_arr[end]) != "}" {
                    end = end + 1
                }
                if end < tlen {
                    // Extract format spec between { and }
                    let mut spec = ""
                    let mut si = ci + 1
                    while si < end {
                        spec = spec + to_string(chars_arr[si])
                        si = si + 1
                    }
                    if spec == "" {
                        // {} — positional arg
                        if arg_idx < len(args) {
                            out = out + val_to_string(args[arg_idx])
                            arg_idx = arg_idx + 1
                        }
                    } else if spec.starts_with(":.") {
                        // {:.N} — float precision
                        let prec_str = spec.substring(2, len(spec))
                        let prec = to_int(prec_str)
                        if arg_idx < len(args) {
                            let fv = to_float_val(args[arg_idx])
                            out = out + to_string(round(fv, prec))
                            arg_idx = arg_idx + 1
                        }
                    } else {
                        // {N} — indexed arg
                        let idx_val = to_int(spec)
                        let actual = idx_val + 1
                        if actual < len(args) {
                            out = out + val_to_string(args[actual])
                        }
                    }
                    ci = end + 1
                } else {
                    out = out + ch
                    ci = ci + 1
                }
            } else {
                out = out + ch
                ci = ci + 1
            }
        }
        return val_str(out)
    }
    if name == "read_file" {
        if len(args) > 0 { return val_str(read_file(args[0].str_val)) }
        return val_str("")
    }
    if name == "read_lines" {
        if len(args) > 0 {
            let content = read_file(args[0].str_val)
            let lines = content.split("\n")
            let mut result = []
            for line in lines { result = result.push(val_str(line)) }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "write_file" {
        if len(args) >= 2 {
            write_file(args[0].str_val, args[1].str_val)
        }
        return val_void()
    }
    if name == "eprintln" {
        let mut out = ""
        for a in args { out = out + val_to_string(a) }
        eprintln(out)
        return val_void()
    }
    if name == "exit" {
        let code = 0
        if len(args) > 0 { code = args[0].int_val }
        exit(code)
        return val_void()
    }
    if name == "input" {
        let prompt = ""
        if len(args) > 0 { prompt = args[0].str_val }
        if prompt != "" { print(prompt) }
        let line = input()
        return val_str(line)
    }
    if name == "assert" {
        if len(args) > 0 {
            let cond = is_truthy(args[0])
            if !cond {
                let msg = "assertion failed"
                if len(args) >= 2 { msg = val_to_string(args[1]) }
                panic_flag = true
                panic_msg = msg
            }
        }
        return val_void()
    }
    if name == "range" {
        if len(args) >= 2 {
            let start = args[0].int_val
            let end_val = args[1].int_val
            let mut result = []
            let mut ri = start
            while ri < end_val {
                result = result.push(val_int(ri))
                ri = ri + 1
            }
            return val_array(result)
        }
        if len(args) == 1 {
            let end_val = args[0].int_val
            let mut result = []
            let mut ri = 0
            while ri < end_val {
                result = result.push(val_int(ri))
                ri = ri + 1
            }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "sort" {
        if len(args) > 0 && args[0].tag == "array" {
            let items = get_array(args[0])
            let sorted = sort_array(items)
            return val_array(sorted)
        }
        return val_array([])
    }
    if name == "random" {
        return val_float(random())
    }
    if name == "time" {
        return val_float(time())
    }
    if name == "sleep" {
        if len(args) > 0 { sleep(args[0].int_val) }
        return val_void()
    }
    if name == "chars" {
        if len(args) > 0 && args[0].tag == "str" {
            let cs = args[0].str_val.chars()
            let mut result = []
            for c in cs { result = result.push(val_str(to_string(c))) }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "push" {
        if len(args) >= 2 && args[0].tag == "array" {
            let items = get_array(args[0])
            let new_items = items.push(args[1])
            return val_array(new_items)
        }
        return args[0]
    }

    // ── Math builtins ────────────────────────────────────
    if name == "abs" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == "int" { return val_int(abs(a.int_val)) }
            if a.tag == "float" { return val_float(abs(a.float_val)) }
        }
        return val_int(0)
    }
    if name == "min" {
        if len(args) >= 2 {
            let a = args[0]
            let b = args[1]
            if a.tag == "int" && b.tag == "int" {
                if a.int_val < b.int_val { return a } else { return b }
            }
            let fa = to_float_val(a)
            let fb = to_float_val(b)
            if fa < fb { return val_float(fa) } else { return val_float(fb) }
        }
        return val_int(0)
    }
    if name == "max" {
        if len(args) >= 2 {
            let a = args[0]
            let b = args[1]
            if a.tag == "int" && b.tag == "int" {
                if a.int_val > b.int_val { return a } else { return b }
            }
            let fa = to_float_val(a)
            let fb = to_float_val(b)
            if fa > fb { return val_float(fa) } else { return val_float(fb) }
        }
        return val_int(0)
    }
    if name == "floor" {
        if len(args) > 0 { return val_int(floor(to_float_val(args[0]))) }
        return val_int(0)
    }
    if name == "ceil" {
        if len(args) > 0 { return val_int(ceil(to_float_val(args[0]))) }
        return val_int(0)
    }
    if name == "round" {
        if len(args) > 0 {
            if len(args) >= 2 {
                return val_float(round(to_float_val(args[0]), args[1].int_val))
            }
            return val_float(round(to_float_val(args[0])))
        }
        return val_float(0.0)
    }
    if name == "sqrt" {
        if len(args) > 0 { return val_float(sqrt(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "pow" {
        if len(args) >= 2 { return val_float(pow(to_float_val(args[0]), to_float_val(args[1]))) }
        return val_float(0.0)
    }
    if name == "sin" {
        if len(args) > 0 { return val_float(sin(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "cos" {
        if len(args) > 0 { return val_float(cos(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "tan" {
        if len(args) > 0 { return val_float(tan(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "ln" {
        if len(args) > 0 { return val_float(ln(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "log10" {
        if len(args) > 0 { return val_float(log10(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "exp" {
        if len(args) > 0 { return val_float(exp(to_float_val(args[0]))) }
        return val_float(0.0)
    }

    // ── Map constructor ──────────────────────────────────
    if name == "Map" {
        return val_map([], [])
    }

    // ── Callback trampoline builtins (G4) ────────────────
    // In interpreter mode, callbacks are tracked as slot IDs.
    // The actual C function pointer is only meaningful in compiled mode.
    if name == "callback_create" {
        if len(args) > 0 {
            let fn_val = args[0]
            // Store in callback_slots, return slot index as int
            let slot = callback_alloc(fn_val)
            return val_int(slot)
        }
        return val_int(-1)
    }
    if name == "callback_free" {
        if len(args) > 0 {
            callback_release(args[0].int_val)
        }
        return val_void()
    }
    if name == "callback_invoke" {
        // For testing: invoke a callback by slot ID with args
        if len(args) >= 1 {
            let slot = args[0].int_val
            let mut cb_args = []
            let mut ai = 1
            while ai < len(args) {
                cb_args = cb_args.push(args[ai])
                ai = ai + 1
            }
            return callback_call(slot, cb_args)
        }
        return val_void()
    }

    // ── G5: Pointer arithmetic builtins (interpreter-level) ──
    if name == "ptr_alloc" {
        if len(args) > 0 {
            let size = args[0].int_val
            let buf = ptr_alloc(size)
            return val_int(ptr_addr(buf))
        }
        return val_int(0)
    }
    if name == "ptr_free" {
        if len(args) >= 2 {
            ptr_free(args[0].int_val, args[1].int_val)
        }
        return val_void()
    }
    if name == "ptr_write" {
        if len(args) >= 3 {
            let p = args[0].int_val
            let off = args[1].int_val
            let v = args[2]
            if v.tag == "float" {
                ptr_write(p, off, v.float_val)
            } else {
                ptr_write(p, off, v.int_val)
            }
        }
        return val_void()
    }
    if name == "ptr_write_f32" {
        if len(args) >= 3 {
            ptr_write_f32(args[0].int_val, args[1].int_val, to_float_val(args[2]))
        }
        return val_void()
    }
    if name == "ptr_write_i32" {
        if len(args) >= 3 {
            ptr_write_i32(args[0].int_val, args[1].int_val, args[2].int_val)
        }
        return val_void()
    }
    if name == "ptr_read" {
        if len(args) >= 2 {
            return val_int(ptr_read(args[0].int_val, args[1].int_val))
        }
        return val_int(0)
    }
    if name == "ptr_read_f64" {
        if len(args) >= 2 {
            return val_float(ptr_read_f64(args[0].int_val, args[1].int_val))
        }
        return val_float(0.0)
    }
    if name == "ptr_read_f32" {
        if len(args) >= 2 {
            return val_float(ptr_read_f32(args[0].int_val, args[1].int_val))
        }
        return val_float(0.0)
    }
    if name == "ptr_read_i32" {
        if len(args) >= 2 {
            return val_int(ptr_read_i32(args[0].int_val, args[1].int_val))
        }
        return val_int(0)
    }
    if name == "ptr_offset" {
        if len(args) >= 2 {
            return val_int(args[0].int_val + args[1].int_val)
        }
        return val_int(0)
    }
    if name == "ptr_null" {
        return val_int(0)
    }
    if name == "ptr_addr" {
        if len(args) > 0 { return val_int(args[0].int_val) }
        return val_int(0)
    }
    if name == "deref" {
        if len(args) > 0 {
            return val_int(deref(args[0].int_val))
        }
        return val_int(0)
    }

    // ── FFI string conversion builtins ────────────────────
    if name == "cstring" {
        if len(args) > 0 && args[0].tag == "str" {
            return val_int(ptr_addr(args[0].str_val))
        }
        return val_int(0)
    }
    if name == "from_cstring" {
        if len(args) > 0 {
            return val_str(from_cstring(args[0].int_val))
        }
        return val_str("")
    }

    // ── G2: Struct packing builtins ──────────────────────
    if name == "struct_pack" {
        // Pack all args as f64 into a heap buffer, return pointer
        let size = len(args) * 8
        let buf = ptr_alloc(size)
        let p = ptr_addr(buf)
        let mut si = 0
        while si < len(args) {
            let v = to_float_val(args[si])
            ptr_write(p, si * 8, v)
            si = si + 1
        }
        return val_int(p)
    }
    if name == "struct_pack_f32" {
        let size = len(args) * 4
        let buf = ptr_alloc(size)
        let p = ptr_addr(buf)
        let mut si = 0
        while si < len(args) {
            let v = to_float_val(args[si])
            ptr_write_f32(p, si * 4, v)
            si = si + 1
        }
        return val_int(p)
    }
    if name == "struct_unpack" {
        if len(args) >= 2 {
            let p = args[0].int_val
            let idx = args[1].int_val
            return val_float(ptr_read_f64(p, idx * 8))
        }
        return val_float(0.0)
    }
    if name == "struct_unpack_f32" {
        if len(args) >= 2 {
            let p = args[0].int_val
            let idx = args[1].int_val
            return val_float(ptr_read_f32(p, idx * 4))
        }
        return val_float(0.0)
    }
    if name == "struct_rect" {
        if len(args) >= 4 {
            let buf = ptr_alloc(32)
            let p = ptr_addr(buf)
            ptr_write(p, 0, to_float_val(args[0]))
            ptr_write(p, 8, to_float_val(args[1]))
            ptr_write(p, 16, to_float_val(args[2]))
            ptr_write(p, 24, to_float_val(args[3]))
            return val_int(p)
        }
        return val_int(0)
    }
    if name == "struct_point" {
        if len(args) >= 2 {
            let buf = ptr_alloc(16)
            let p = ptr_addr(buf)
            ptr_write(p, 0, to_float_val(args[0]))
            ptr_write(p, 8, to_float_val(args[1]))
            return val_int(p)
        }
        return val_int(0)
    }
    if name == "struct_size" {
        if len(args) >= 2 {
            let buf = ptr_alloc(16)
            let p = ptr_addr(buf)
            ptr_write(p, 0, to_float_val(args[0]))
            ptr_write(p, 8, to_float_val(args[1]))
            return val_int(p)
        }
        return val_int(0)
    }
    if name == "struct_free" {
        if len(args) > 0 {
            ptr_free(args[0].int_val, 0)
        }
        return val_void()
    }

    // ── T9: Array aggregate builtins ────────────────────────
    if name == "any" {
        if len(args) >= 2 && args[0].tag == "array" {
            let items = get_array(args[0])
            for item in items {
                let r = call_fn_val(args[1], [item])
                if is_truthy(r) { return val_bool(true) }
            }
            return val_bool(false)
        }
        return val_bool(false)
    }
    if name == "all" {
        if len(args) >= 2 && args[0].tag == "array" {
            let items = get_array(args[0])
            for item in items {
                let r = call_fn_val(args[1], [item])
                if !is_truthy(r) { return val_bool(false) }
            }
            return val_bool(true)
        }
        return val_bool(true)
    }
    if name == "count" {
        if len(args) >= 2 && args[0].tag == "array" {
            let items = get_array(args[0])
            let mut c = 0
            for item in items {
                let r = call_fn_val(args[1], [item])
                if is_truthy(r) { c = c + 1 }
            }
            return val_int(c)
        }
        return val_int(0)
    }
    if name == "sum" {
        if len(args) > 0 && args[0].tag == "array" {
            let items = get_array(args[0])
            let mut has_float = false
            let mut si = 0.0
            for item in items {
                if item.tag == "float" { has_float = true }
                si = si + to_float_val(item)
            }
            if has_float { return val_float(si) }
            return val_int(floor(si))
        }
        return val_int(0)
    }
    if name == "sort" {
        if len(args) > 0 && args[0].tag == "array" {
            let items = get_array(args[0])
            let n = len(items)
            if n <= 1 { return val_array(items) }
            // Copy to mutable array, then bubble sort
            let mut sorted = []
            for item in items { sorted = sorted.push(item) }
            let mut si = 0
            while si < n - 1 {
                let mut sj = 0
                while sj < n - si - 1 {
                    let a = sorted[sj]
                    let b = sorted[sj + 1]
                    let mut do_swap = false
                    if a.tag == "int" && b.tag == "int" {
                        if a.int_val > b.int_val { do_swap = true }
                    } else if a.tag == "float" || b.tag == "float" {
                        if to_float_val(a) > to_float_val(b) { do_swap = true }
                    } else if a.tag == "str" && b.tag == "str" {
                        if a.str_val > b.str_val { do_swap = true }
                    }
                    if do_swap {
                        let tmp = sorted[sj]
                        sorted[sj] = sorted[sj + 1]
                        sorted[sj + 1] = tmp
                    }
                    sj = sj + 1
                }
                si = si + 1
            }
            return val_array(sorted)
        }
        return val_array([])
    }
    if name == "enumerate" {
        if len(args) > 0 && args[0].tag == "array" {
            let items = get_array(args[0])
            let mut result = []
            let mut ei = 0
            while ei < len(items) {
                result = result.push(val_array([val_int(ei), items[ei]]))
                ei = ei + 1
            }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "zip" {
        if len(args) >= 2 && args[0].tag == "array" && args[1].tag == "array" {
            let a_items = get_array(args[0])
            let b_items = get_array(args[1])
            let mut result = []
            let mut zi = 0
            let zn = min(len(a_items), len(b_items))
            while zi < zn {
                result = result.push(val_array([a_items[zi], b_items[zi]]))
                zi = zi + 1
            }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "find" {
        if len(args) >= 2 && args[0].tag == "array" {
            let items = get_array(args[0])
            for item in items {
                let r = call_fn_val(args[1], [item])
                if is_truthy(r) { return item }
            }
        }
        return val_void()
    }
    if name == "flat_map" {
        if len(args) >= 2 && args[0].tag == "array" {
            let items = get_array(args[0])
            let mut result = []
            for item in items {
                let sub = call_fn_val(args[1], [item])
                if sub.tag == "array" {
                    let sub_items = get_array(sub)
                    for s in sub_items { result = result.push(s) }
                } else {
                    result = result.push(sub)
                }
            }
            return val_array(result)
        }
        return val_array([])
    }

    // ── T9: String utility builtins ─────────────────────────
    if name == "repeat" {
        if len(args) >= 2 && args[0].tag == "str" {
            let s = args[0].str_val
            let n = args[1].int_val
            let mut out = ""
            let mut ri = 0
            while ri < n {
                out = out + s
                ri = ri + 1
            }
            return val_str(out)
        }
        return val_str("")
    }
    if name == "pad_left" {
        if len(args) >= 3 && args[0].tag == "str" {
            let s = args[0].str_val
            let width = args[1].int_val
            let ch = args[2].str_val
            let mut out = s
            while len(out) < width {
                out = ch + out
            }
            return val_str(out)
        }
        return val_str("")
    }
    if name == "pad_right" {
        if len(args) >= 3 && args[0].tag == "str" {
            let s = args[0].str_val
            let width = args[1].int_val
            let ch = args[2].str_val
            let mut out = s
            while len(out) < width {
                out = out + ch
            }
            return val_str(out)
        }
        return val_str("")
    }
    if name == "char_at" {
        if len(args) >= 2 && args[0].tag == "str" {
            let s = args[0].str_val
            let idx = args[1].int_val
            let cs = s.chars()
            if idx >= 0 && idx < len(cs) {
                return val_str(to_string(cs[idx]))
            }
        }
        return val_str("")
    }
    if name == "char_code" {
        if len(args) > 0 && args[0].tag == "str" {
            let s = args[0].str_val
            if len(s) > 0 {
                let cs = s.chars()
                return val_int(char_code(cs[0]))
            }
        }
        return val_int(0)
    }
    if name == "from_char_code" {
        if len(args) > 0 {
            let n = args[0].int_val
            return val_str(from_char_code(n))
        }
        return val_str("")
    }

    // ── T9: Math / activation builtins ──────────────────────
    if name == "tan" {
        if len(args) > 0 { return val_float(tan(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "asin" {
        if len(args) > 0 { return val_float(asin(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "acos" {
        if len(args) > 0 { return val_float(acos(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "atan" {
        if len(args) > 0 { return val_float(atan(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "atan2" {
        if len(args) >= 2 { return val_float(atan2(to_float_val(args[0]), to_float_val(args[1]))) }
        return val_float(0.0)
    }
    if name == "sigmoid" {
        if len(args) > 0 {
            let x = to_float_val(args[0])
            return val_float(1.0 / (1.0 + exp(-x)))
        }
        return val_float(0.5)
    }
    if name == "relu" {
        if len(args) > 0 {
            let x = to_float_val(args[0])
            if x > 0.0 { return val_float(x) }
            return val_float(0.0)
        }
        return val_float(0.0)
    }
    if name == "tanh" {
        if len(args) > 0 { return val_float(tanh(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "pi" {
        return val_float(3.141592653589793)
    }
    if name == "e" {
        return val_float(2.718281828459045)
    }
    if name == "log2" {
        if len(args) > 0 { return val_float(ln(to_float_val(args[0])) / ln(2.0)) }
        return val_float(0.0)
    }
    if name == "clamp" {
        if len(args) >= 3 {
            let x = to_float_val(args[0])
            let lo = to_float_val(args[1])
            let hi = to_float_val(args[2])
            if x < lo { return val_float(lo) }
            if x > hi { return val_float(hi) }
            return val_float(x)
        }
        return val_float(0.0)
    }

    // ── T9: I/O builtins ────────────────────────────────────
    if name == "write_file" {
        if len(args) >= 2 {
            write_file(args[0].str_val, args[1].str_val)
        }
        return val_void()
    }
    if name == "append_file" {
        if len(args) >= 2 {
            append_file(args[0].str_val, args[1].str_val)
        }
        return val_void()
    }
    if name == "file_exists" {
        if len(args) > 0 {
            return val_bool(file_exists(args[0].str_val))
        }
        return val_bool(false)
    }
    if name == "delete_file" {
        if len(args) > 0 {
            delete_file(args[0].str_val)
        }
        return val_void()
    }
    if name == "env_var" {
        if len(args) > 0 {
            return val_str(env_var(args[0].str_val))
        }
        return val_str("")
    }
    if name == "command_args" {
        let raw_args = args()
        let mut result = []
        for a in raw_args {
            result = result.push(val_str(to_string(a)))
        }
        return val_array(result)
    }

    // ── Error handling builtins ────────────────────────────
    if name == "error" {
        let msg = ""
        if len(args) > 0 { msg = val_to_string(args[0]) }
        let mut keys = [val_str("message"), val_str("trace")]
        let mut values = [val_str(msg), val_str(format_stack_trace())]
        return val_map(keys, values)
    }
    if name == "is_error" {
        if len(args) > 0 {
            let v = args[0]
            if v.tag == "map" {
                let ks = get_map_keys(v)
                let mut ki = 0
                while ki < len(ks) {
                    if ks[ki].tag == "str" && ks[ki].str_val == "message" {
                        return val_bool(true)
                    }
                    ki = ki + 1
                }
            }
        }
        return val_bool(false)
    }
    if name == "stack_trace" {
        return val_str(format_stack_trace())
    }

    // ── Functional builtins ─────────────────────────────────
    if name == "compose" {
        if len(args) >= 2 {
            let f = args[0]
            let g = args[1]
            // Build a closure that captures f and g
            let mut captured = []
            let mut ci = 0
            while ci < len(env_vars) {
                captured = captured.push([env_vars[ci][0], env_vars[ci][1]])
                ci = ci + 1
            }
            captured = captured.push(["__compose_f", f])
            captured = captured.push(["__compose_g", g])
            let idx = len(closure_store)
            closure_store = closure_store.push(captured)
            // Return a fn that calls f(g(x))
            // We use a special tag to identify compose closures
            return Val { tag: "fn", int_val: idx, float_val: 0.0, bool_val: false, str_val: "compose", char_val: "", array_val: "", fn_name: "__composed__", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
        }
        return val_void()
    }
    if name == "pipe" {
        if len(args) >= 2 {
            let mut val = args[0]
            let mut pi = 1
            while pi < len(args) {
                val = call_fn_val(args[pi], [val])
                pi = pi + 1
            }
            return val
        }
        if len(args) == 1 { return args[0] }
        return val_void()
    }
    if name == "curry" {
        if len(args) >= 1 {
            let f = args[0]
            let mut partial = []
            let mut pi = 1
            while pi < len(args) {
                partial = partial.push(args[pi])
                pi = pi + 1
            }
            // Build closure capturing f and partial args
            let mut captured = []
            let mut ci = 0
            while ci < len(env_vars) {
                captured = captured.push([env_vars[ci][0], env_vars[ci][1]])
                ci = ci + 1
            }
            captured = captured.push(["__curry_fn", f])
            captured = captured.push(["__curry_partial", val_array(partial)])
            let idx = len(closure_store)
            closure_store = closure_store.push(captured)
            return Val { tag: "fn", int_val: idx, float_val: 0.0, bool_val: false, str_val: "curry", char_val: "", array_val: "", fn_name: "__curried__", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
        }
        return val_void()
    }
    if name == "identity" {
        if len(args) > 0 { return args[0] }
        return val_void()
    }
    if name == "constant" {
        if len(args) > 0 {
            let val = args[0]
            let mut captured = []
            let mut ci = 0
            while ci < len(env_vars) {
                captured = captured.push([env_vars[ci][0], env_vars[ci][1]])
                ci = ci + 1
            }
            captured = captured.push(["__constant_val", val])
            let idx = len(closure_store)
            closure_store = closure_store.push(captured)
            return Val { tag: "fn", int_val: idx, float_val: 0.0, bool_val: false, str_val: "constant", char_val: "", array_val: "", fn_name: "__constant__", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
        }
        return val_void()
    }

    // ── String utility builtins (additions) ─────────────────
    if name == "center" {
        if len(args) >= 3 && args[0].tag == "str" {
            let s = args[0].str_val
            let width = args[1].int_val
            let ch = args[2].str_val
            let slen = len(s)
            if slen >= width { return val_str(s) }
            let total_pad = width - slen
            let left_pad = total_pad / 2
            let right_pad = total_pad - left_pad
            let mut out = ""
            let mut li = 0
            while li < left_pad { out = out + ch; li = li + 1 }
            out = out + s
            let mut ri = 0
            while ri < right_pad { out = out + ch; ri = ri + 1 }
            return val_str(out)
        }
        return val_str("")
    }
    if name == "str_count" || (name == "count" && len(args) >= 2 && args[0].tag == "str") {
        // count(s, substr) / str_count(s, substr) — count occurrences of substr in s
        if len(args) >= 2 && args[0].tag == "str" && args[1].tag == "str" {
            let s = args[0].str_val
            let sub = args[1].str_val
            let slen = len(s)
            let sublen = len(sub)
            if sublen == 0 { return val_int(0) }
            let mut cnt = 0
            let mut i = 0
            while i <= slen - sublen {
                if s.substring(i, i + sublen) == sub {
                    cnt = cnt + 1
                    i = i + sublen
                } else {
                    i = i + 1
                }
            }
            return val_int(cnt)
        }
        return val_int(0)
    }
    if name == "reverse" {
        // reverse(s) — reverse a string
        if len(args) > 0 && args[0].tag == "str" {
            let cs = args[0].str_val.chars()
            let mut out = ""
            let mut ri = len(cs) - 1
            while ri >= 0 {
                out = out + to_string(cs[ri])
                ri = ri - 1
            }
            return val_str(out)
        }
        // reverse(array) — reverse an array
        if len(args) > 0 && args[0].tag == "array" {
            let items = get_array(args[0])
            let mut result = []
            let mut ri = len(items) - 1
            while ri >= 0 {
                result = result.push(items[ri])
                ri = ri - 1
            }
            return val_array(result)
        }
        return val_void()
    }
    if name == "is_empty" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == "str" { return val_bool(a.str_val == "") }
            if a.tag == "array" { return val_bool(len(get_array(a)) == 0) }
            if a.tag == "map" { return val_bool(len(get_map_keys(a)) == 0) }
            if a.tag == "void" { return val_bool(true) }
        }
        return val_bool(true)
    }
    if name == "format_number" {
        if len(args) >= 2 {
            let n = to_float_val(args[0])
            let decimals = args[1].int_val
            return val_str(to_string(round(n, decimals)))
        }
        return val_str("0")
    }
    if name == "hex" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n == 0 { return val_str("0x0") }
            let mut val = n
            let mut is_neg = false
            if val < 0 { is_neg = true; val = -val }
            let digits = "0123456789abcdef"
            let dchars = digits.chars()
            let mut out = ""
            while val > 0 {
                let rem = val % 16
                out = to_string(dchars[rem]) + out
                val = val / 16
            }
            if is_neg { out = "-0x" + out } else { out = "0x" + out }
            return val_str(out)
        }
        return val_str("0x0")
    }
    if name == "bin" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n == 0 { return val_str("0b0") }
            let mut val = n
            let mut is_neg = false
            if val < 0 { is_neg = true; val = -val }
            let mut out = ""
            while val > 0 {
                if val % 2 == 1 { out = "1" + out } else { out = "0" + out }
                val = val / 2
            }
            if is_neg { out = "-0b" + out } else { out = "0b" + out }
            return val_str(out)
        }
        return val_str("0b0")
    }

    // ── Math builtins (additions) ───────────────────────────
    if name == "sign" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == "int" {
                if a.int_val > 0 { return val_int(1) }
                if a.int_val < 0 { return val_int(-1) }
                return val_int(0)
            }
            if a.tag == "float" {
                if a.float_val > 0.0 { return val_int(1) }
                if a.float_val < 0.0 { return val_int(-1) }
                return val_int(0)
            }
        }
        return val_int(0)
    }
    if name == "gcd" {
        if len(args) >= 2 {
            let mut a = args[0].int_val
            let mut b = args[1].int_val
            if a < 0 { a = -a }
            if b < 0 { b = -b }
            while b != 0 {
                let t = b
                b = a % b
                a = t
            }
            return val_int(a)
        }
        return val_int(0)
    }
    if name == "lcm" {
        if len(args) >= 2 {
            let mut a = args[0].int_val
            let mut b = args[1].int_val
            if a < 0 { a = -a }
            if b < 0 { b = -b }
            if a == 0 || b == 0 { return val_int(0) }
            // lcm = |a*b| / gcd(a,b)
            let mut ga = a
            let mut gb = b
            while gb != 0 {
                let t = gb
                gb = ga % gb
                ga = t
            }
            return val_int((a / ga) * b)
        }
        return val_int(0)
    }
    if name == "factorial" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n < 0 { return val_int(0) }
            let mut result = 1
            let mut fi = 2
            while fi <= n {
                result = result * fi
                fi = fi + 1
            }
            return val_int(result)
        }
        return val_int(1)
    }
    if name == "fib" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n <= 0 { return val_int(0) }
            if n == 1 { return val_int(1) }
            let mut a = 0
            let mut b = 1
            let mut fi = 2
            while fi <= n {
                let tmp = a + b
                a = b
                b = tmp
                fi = fi + 1
            }
            return val_int(b)
        }
        return val_int(0)
    }
    if name == "is_prime" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n < 2 { return val_bool(false) }
            if n < 4 { return val_bool(true) }
            if n % 2 == 0 { return val_bool(false) }
            if n % 3 == 0 { return val_bool(false) }
            let mut i = 5
            while i * i <= n {
                if n % i == 0 || n % (i + 2) == 0 { return val_bool(false) }
                i = i + 6
            }
            return val_bool(true)
        }
        return val_bool(false)
    }
    if name == "mod" {
        // Euclidean modulo: always returns non-negative for positive divisor
        if len(args) >= 2 {
            let a = args[0].int_val
            let b = args[1].int_val
            if b == 0 { return val_int(0) }
            let r = a % b
            if r < 0 { return val_int(r + abs(b)) }
            return val_int(r)
        }
        return val_int(0)
    }

    return not_builtin
}

// ── Method dispatch ──────────────────────────────────────

fn call_method(obj, method, args) {
    // String methods
    if obj.tag == "str" {
        let s = obj.str_val
        if method == "chars" {
            let cs = s.chars()
            let mut result = []
            for c in cs { result = result.push(val_str(to_string(c))) }
            return val_array(result)
        }
        if method == "len" { return val_int(len(s)) }
        if method == "contains" { return val_bool(s.contains(args[0].str_val)) }
        if method == "starts_with" { return val_bool(s.starts_with(args[0].str_val)) }
        if method == "ends_with" { return val_bool(s.ends_with(args[0].str_val)) }
        if method == "to_upper" { return val_str(s.to_upper()) }
        if method == "to_lower" { return val_str(s.to_lower()) }
        if method == "trim" { return val_str(s.trim()) }
        if method == "split" {
            let parts = s.split(args[0].str_val)
            let mut result = []
            for p in parts { result = result.push(val_str(p)) }
            return val_array(result)
        }
        if method == "replace" { return val_str(s.replace(args[0].str_val, args[1].str_val)) }
        if method == "substring" { return val_str(s.substring(args[0].int_val, args[1].int_val)) }
        if method == "index_of" { return val_int(s.index_of(args[0].str_val)) }
        if method == "repeat" {
            let n = args[0].int_val
            let mut result = ""
            let mut ri = 0
            while ri < n {
                result = result + s
                ri = ri + 1
            }
            return val_str(result)
        }
        if method == "reverse" {
            let cs = s.chars()
            let mut out = ""
            let mut ri = len(cs) - 1
            while ri >= 0 {
                out = out + to_string(cs[ri])
                ri = ri - 1
            }
            return val_str(out)
        }
        if method == "is_empty" {
            return val_bool(s == "")
        }
        if method == "count" {
            // .count(substr) — count occurrences
            if len(args) > 0 && args[0].tag == "str" {
                let sub = args[0].str_val
                let slen = len(s)
                let sublen = len(sub)
                if sublen == 0 { return val_int(0) }
                let mut cnt = 0
                let mut ci = 0
                while ci <= slen - sublen {
                    if s.substring(ci, ci + sublen) == sub {
                        cnt = cnt + 1
                        ci = ci + sublen
                    } else {
                        ci = ci + 1
                    }
                }
                return val_int(cnt)
            }
            return val_int(0)
        }
        if method == "pad_left" {
            let width = args[0].int_val
            let ch = args[1].str_val
            let mut out = s
            while len(out) < width { out = ch + out }
            return val_str(out)
        }
        if method == "pad_right" {
            let width = args[0].int_val
            let ch = args[1].str_val
            let mut out = s
            while len(out) < width { out = out + ch }
            return val_str(out)
        }
        if method == "center" {
            let width = args[0].int_val
            let ch = args[1].str_val
            let slen = len(s)
            if slen >= width { return val_str(s) }
            let total_pad = width - slen
            let left_pad = total_pad / 2
            let right_pad = total_pad - left_pad
            let mut out = ""
            let mut li = 0
            while li < left_pad { out = out + ch; li = li + 1 }
            out = out + s
            let mut ri = 0
            while ri < right_pad { out = out + ch; ri = ri + 1 }
            return val_str(out)
        }
        // ── String methods ported from src/interpreter.rs call_string_method ──
        if method == "trim_start" { return val_str(s.trim_start()) }
        if method == "trim_end" { return val_str(s.trim_end()) }
        if method == "parse_int" {
            let trimmed = s.trim()
            let n = to_int(trimmed)
            return val_int(n)
        }
        if method == "parse_float" {
            let trimmed = s.trim()
            let n = to_float(val_str(trimmed))
            return val_float(n)
        }
        if method == "join" {
            // "sep".join(array) — join array elements with separator
            if len(args) > 0 && args[0].tag == "array" {
                let items = get_array(args[0])
                let mut out = ""
                let mut ji = 0
                for item in items {
                    if ji > 0 { out = out + s }
                    out = out + val_to_string(item)
                    ji = ji + 1
                }
                return val_str(out)
            }
            return val_str("")
        }
        if method == "bytes" {
            let cs = s.chars()
            let mut result = []
            for c in cs { result = result.push(val_int(char_code(c))) }
            return val_array(result)
        }
    }

    // Array methods
    if obj.tag == "array" {
        let items = get_array(obj)
        if method == "len" { return val_int(len(items)) }
        if method == "push" { return val_array(items.push(args[0])) }
        if method == "pop" {
            if len(items) == 0 { return val_array([]) }
            let mut result = []
            let mut pi = 0
            while pi < len(items) - 1 {
                result = result.push(items[pi])
                pi = pi + 1
            }
            return val_array(result)
        }
        if method == "contains" {
            let target = args[0]
            for item in items {
                if val_eq(item, target) { return val_bool(true) }
            }
            return val_bool(false)
        }
        if method == "join" {
            let sep = args[0].str_val
            let mut out = ""
            let mut ji = 0
            for item in items {
                if ji > 0 { out = out + sep }
                out = out + val_to_string(item)
                ji = ji + 1
            }
            return val_str(out)
        }
        if method == "index_of" {
            let target = args[0]
            let mut ii = 0
            while ii < len(items) {
                if val_eq(items[ii], target) { return val_int(ii) }
                ii = ii + 1
            }
            return val_int(-1)
        }
        if method == "slice" {
            let start = args[0].int_val
            let end_idx = args[1].int_val
            let mut result = []
            let mut si = start
            while si < end_idx && si < len(items) {
                result = result.push(items[si])
                si = si + 1
            }
            return val_array(result)
        }
        if method == "reverse" {
            let mut result = []
            let mut ri = len(items) - 1
            while ri >= 0 {
                result = result.push(items[ri])
                ri = ri - 1
            }
            return val_array(result)
        }
        if method == "map" {
            let mut result = []
            for item in items {
                result = result.push(call_fn_val(args[0], [item]))
            }
            return val_array(result)
        }
        if method == "filter" {
            let mut result = []
            for item in items {
                let keep = call_fn_val(args[0], [item])
                if is_truthy(keep) { result = result.push(item) }
            }
            return val_array(result)
        }
        if method == "fold" {
            let mut acc = args[0]
            let f = args[1]
            for item in items {
                acc = call_fn_val(f, [acc, item])
            }
            return acc
        }
        if method == "for_each" {
            for item in items {
                call_fn_val(args[0], [item])
            }
            return val_void()
        }
        if method == "any" {
            for item in items {
                let r = call_fn_val(args[0], [item])
                if is_truthy(r) { return val_bool(true) }
            }
            return val_bool(false)
        }
        if method == "all" {
            for item in items {
                let r = call_fn_val(args[0], [item])
                if !is_truthy(r) { return val_bool(false) }
            }
            return val_bool(true)
        }
        if method == "flat_map" {
            let mut result = []
            for item in items {
                let sub = call_fn_val(args[0], [item])
                if sub.tag == "array" {
                    let sub_items = get_array(sub)
                    for s in sub_items { result = result.push(s) }
                } else {
                    result = result.push(sub)
                }
            }
            return val_array(result)
        }
        if method == "sort" {
            let sorted = sort_array(items)
            return val_array(sorted)
        }
        if method == "enumerate" {
            let mut result = []
            let mut ei = 0
            while ei < len(items) {
                result = result.push(val_array([val_int(ei), items[ei]]))
                ei = ei + 1
            }
            return val_array(result)
        }
        if method == "zip" {
            if len(args) > 0 && args[0].tag == "array" {
                let other = get_array(args[0])
                let mut result = []
                let mut zi = 0
                let zn = min(len(items), len(other))
                while zi < zn {
                    result = result.push(val_array([items[zi], other[zi]]))
                    zi = zi + 1
                }
                return val_array(result)
            }
            return val_array([])
        }
        if method == "take" {
            let n = args[0].int_val
            let mut result = []
            let mut ti = 0
            while ti < n && ti < len(items) {
                result = result.push(items[ti])
                ti = ti + 1
            }
            return val_array(result)
        }
        if method == "drop" {
            let n = args[0].int_val
            let mut result = []
            let mut di = n
            while di < len(items) {
                result = result.push(items[di])
                di = di + 1
            }
            return val_array(result)
        }
        if method == "unique" {
            let mut result = []
            let mut seen = []
            for item in items {
                let key = val_to_string(item)
                let mut found = false
                for s in seen {
                    if s == key { found = true }
                }
                if !found {
                    result = result.push(item)
                    seen = seen.push(key)
                }
            }
            return val_array(result)
        }
        if method == "count" {
            let mut c = 0
            for item in items {
                let r = call_fn_val(args[0], [item])
                if is_truthy(r) { c = c + 1 }
            }
            return val_int(c)
        }
        if method == "find" {
            for item in items {
                let r = call_fn_val(args[0], [item])
                if is_truthy(r) { return item }
            }
            return val_void()
        }
        if method == "group_by" {
            let mut keys = []
            let mut values = []
            for item in items {
                let key = call_fn_val(args[0], [item])
                let key_str = val_to_string(key)
                let mut found_idx = -1
                let mut gi = 0
                while gi < len(keys) {
                    if val_to_string(keys[gi]) == key_str { found_idx = gi }
                    gi = gi + 1
                }
                if found_idx == -1 {
                    keys = keys.push(key)
                    values = values.push(val_array([item]))
                } else {
                    let existing = get_array(values[found_idx])
                    values[found_idx] = val_array(existing.push(item))
                }
            }
            return val_map(keys, values)
        }
        if method == "flatten" {
            let mut result = []
            for item in items {
                if item.tag == "array" {
                    let sub = get_array(item)
                    for s in sub { result = result.push(s) }
                } else {
                    result = result.push(item)
                }
            }
            return val_array(result)
        }
        if method == "sum" {
            let mut has_float = false
            let mut total = 0.0
            for item in items {
                if item.tag == "float" { has_float = true }
                total = total + to_float_val(item)
            }
            if has_float { return val_float(total) }
            return val_int(floor(total))
        }
        if method == "min" {
            if len(items) == 0 { return val_void() }
            let mut best = items[0]
            let mut mi = 1
            while mi < len(items) {
                if to_float_val(items[mi]) < to_float_val(best) { best = items[mi] }
                mi = mi + 1
            }
            return best
        }
        if method == "max" {
            if len(items) == 0 { return val_void() }
            let mut best = items[0]
            let mut mi = 1
            while mi < len(items) {
                if to_float_val(items[mi]) > to_float_val(best) { best = items[mi] }
                mi = mi + 1
            }
            return best
        }
        if method == "chunk" {
            let n = args[0].int_val
            if n <= 0 { return val_array([]) }
            let mut result = []
            let mut ci = 0
            while ci < len(items) {
                let mut chunk = []
                let mut cj = 0
                while cj < n && ci + cj < len(items) {
                    chunk = chunk.push(items[ci + cj])
                    cj = cj + 1
                }
                result = result.push(val_array(chunk))
                ci = ci + n
            }
            return val_array(result)
        }
        if method == "window" {
            let n = args[0].int_val
            if n <= 0 || n > len(items) { return val_array([]) }
            let mut result = []
            let mut wi = 0
            while wi <= len(items) - n {
                let mut win = []
                let mut wj = 0
                while wj < n {
                    win = win.push(items[wi + wj])
                    wj = wj + 1
                }
                result = result.push(val_array(win))
                wi = wi + 1
            }
            return val_array(result)
        }
        if method == "scan" {
            // .scan(init, fn) — like fold but returns intermediate results
            let mut acc = args[0]
            let f = args[1]
            let mut result = [acc]
            for item in items {
                acc = call_fn_val(f, [acc, item])
                result = result.push(acc)
            }
            return val_array(result)
        }
        if method == "partition" {
            let pred = args[0]
            let mut matching = []
            let mut non_matching = []
            for item in items {
                let r = call_fn_val(pred, [item])
                if is_truthy(r) {
                    matching = matching.push(item)
                } else {
                    non_matching = non_matching.push(item)
                }
            }
            return val_array([val_array(matching), val_array(non_matching)])
        }
        if method == "interleave" {
            if len(args) > 0 && args[0].tag == "array" {
                let other = get_array(args[0])
                let mut result = []
                let max_len = max(len(items), len(other))
                let mut ii = 0
                while ii < max_len {
                    if ii < len(items) { result = result.push(items[ii]) }
                    if ii < len(other) { result = result.push(other[ii]) }
                    ii = ii + 1
                }
                return val_array(result)
            }
            return val_array(items)
        }
        if method == "frequencies" {
            let mut keys = []
            let mut values = []
            for item in items {
                let key_str = val_to_string(item)
                let mut found_idx = -1
                let mut fi = 0
                while fi < len(keys) {
                    if val_to_string(keys[fi]) == key_str { found_idx = fi }
                    fi = fi + 1
                }
                if found_idx == -1 {
                    keys = keys.push(item)
                    values = values.push(val_int(1))
                } else {
                    values[found_idx] = val_int(values[found_idx].int_val + 1)
                }
            }
            return val_map(keys, values)
        }
        if method == "rotate" {
            let n_items = len(items)
            if n_items == 0 { return val_array([]) }
            let mut n = args[0].int_val
            // Normalize: positive = rotate left
            n = n % n_items
            if n < 0 { n = n + n_items }
            let mut result = []
            let mut ri = 0
            while ri < n_items {
                result = result.push(items[(ri + n) % n_items])
                ri = ri + 1
            }
            return val_array(result)
        }
        if method == "sample" {
            let n = args[0].int_val
            let n_items = len(items)
            if n_items == 0 || n <= 0 { return val_array([]) }
            let mut result = []
            let mut si = 0
            while si < n {
                let idx = floor(random() * n_items)
                result = result.push(items[idx])
                si = si + 1
            }
            return val_array(result)
        }
    }

    // Map methods
    if obj.tag == "map" {
        if method == "get" { return map_get(obj, args[0]) }
        if method == "set" { return map_set(obj, args[0], args[1]) }
        if method == "contains_key" { return val_bool(map_contains_key(obj, args[0])) }
        if method == "keys" {
            let ks = get_map_keys(obj)
            return val_array(ks)
        }
        if method == "values" {
            let vs = get_map_values(obj)
            return val_array(vs)
        }
        if method == "len" { return val_int(len(get_map_keys(obj))) }
        if method == "remove" { return map_remove(obj, args[0]) }
        if method == "entries" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut result = []
            let mut ei = 0
            while ei < len(ks) {
                let pair = val_array([ks[ei], vs[ei]])
                result = result.push(pair)
                ei = ei + 1
            }
            return val_array(result)
        }
        if method == "merge" {
            if len(args) > 0 && args[0].tag == "map" {
                let other_ks = get_map_keys(args[0])
                let other_vs = get_map_values(args[0])
                let mut merged = obj
                let mut mi = 0
                while mi < len(other_ks) {
                    merged = map_set(merged, other_ks[mi], other_vs[mi])
                    mi = mi + 1
                }
                return merged
            }
            return obj
        }
        if method == "map_values" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut new_vs = []
            let mut mi = 0
            while mi < len(vs) {
                new_vs = new_vs.push(call_fn_val(args[0], [vs[mi]]))
                mi = mi + 1
            }
            return val_map(ks, new_vs)
        }
        if method == "filter_keys" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut new_ks = []
            let mut new_vs = []
            let mut mi = 0
            while mi < len(ks) {
                let keep = call_fn_val(args[0], [ks[mi]])
                if is_truthy(keep) {
                    new_ks = new_ks.push(ks[mi])
                    new_vs = new_vs.push(vs[mi])
                }
                mi = mi + 1
            }
            return val_map(new_ks, new_vs)
        }
        if method == "to_array" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut result = []
            let mut mi = 0
            while mi < len(ks) {
                result = result.push(val_array([ks[mi], vs[mi]]))
                mi = mi + 1
            }
            return val_array(result)
        }
        if method == "from_array" {
            // Static-like: called on empty map, takes an array of [key, val] pairs
            if len(args) > 0 && args[0].tag == "array" {
                let pairs = get_array(args[0])
                let mut new_ks = []
                let mut new_vs = []
                for pair in pairs {
                    if pair.tag == "array" {
                        let p = get_array(pair)
                        if len(p) >= 2 {
                            new_ks = new_ks.push(p[0])
                            new_vs = new_vs.push(p[1])
                        }
                    }
                }
                return val_map(new_ks, new_vs)
            }
            return val_map([], [])
        }
        if method == "invert" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            return val_map(vs, ks)
        }
        if method == "count" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            if len(args) > 0 {
                let pred = args[0]
                let mut cnt = 0
                let mut mi = 0
                while mi < len(ks) {
                    let r = call_fn_val(pred, [ks[mi], vs[mi]])
                    if is_truthy(r) { cnt = cnt + 1 }
                    mi = mi + 1
                }
                return val_int(cnt)
            }
            return val_int(len(ks))
        }
        if method == "any" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            if len(args) > 0 {
                let pred = args[0]
                let mut mi = 0
                while mi < len(ks) {
                    let r = call_fn_val(pred, [ks[mi], vs[mi]])
                    if is_truthy(r) { return val_bool(true) }
                    mi = mi + 1
                }
            }
            return val_bool(false)
        }
        if method == "all" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            if len(args) > 0 {
                let pred = args[0]
                let mut mi = 0
                while mi < len(ks) {
                    let r = call_fn_val(pred, [ks[mi], vs[mi]])
                    if !is_truthy(r) { return val_bool(false) }
                    mi = mi + 1
                }
            }
            return val_bool(true)
        }
    }

    // Struct method dispatch via impl blocks
    if obj.tag == "struct" {
        let sname = obj.struct_name
        // Look for impl block method
        let mut ii = 0
        while ii < len(impl_store) {
            if impl_store[ii][0] == sname {
                let methods = impl_store[ii][1]
                let mut mi = 0
                while mi < len(methods) {
                    if methods[mi].name == method {
                        let m = methods[mi]
                        let mparams = m.params
                        let mbody = m.body
                        env_push_scope()
                        // Bind self to the object
                        env_define("self", obj)
                        // Bind remaining params (skip 'self' if first param)
                        let mut pi = 0
                        let mut ai = 0
                        while pi < len(mparams) {
                            let pname = ""
                            if type_of(mparams[pi]) == "string" {
                                pname = mparams[pi]
                            } else {
                                pname = mparams[pi].name
                            }
                            if pname == "self" {
                                // skip — already bound
                            } else {
                                if ai < len(args) {
                                    env_define(pname, args[ai])
                                    ai = ai + 1
                                }
                            }
                            pi = pi + 1
                        }
                        let saved_flag = return_flag
                        return_flag = false
                        let mut bi = 0
                        while bi < len(mbody) {
                            if return_flag { bi = len(mbody) } else {
                                exec_stmt_at(mbody, bi)
                                bi = bi + 1
                            }
                        }
                        let result = return_val
                        return_flag = saved_flag
                        return_val = val_void()
                        env_pop_scope()
                        return result
                    }
                    mi = mi + 1
                }
            }
            ii = ii + 1
        }
        // Also try field access on struct as a fn val
        let fields = get_struct_fields(obj)
        if type_of(fields) != "string" {
            // Try calling method as a stored function value in fields
        }
    }

    println("Runtime error: unknown method ." + method + "() on " + obj.tag)
    return val_void()
}

// ── Helpers ──────────────────────────────────────────────

fn is_truthy(v) {
    if v.tag == "bool" { return v.bool_val }
    if v.tag == "int" { return v.int_val != 0 }
    if v.tag == "str" { return v.str_val != "" }
    if v.tag == "void" { return false }
    return true
}

fn val_to_string(v) {
    if v.tag == "int" { return to_string(v.int_val) }
    if v.tag == "float" { return to_string(v.float_val) }
    if v.tag == "bool" { return to_string(v.bool_val) }
    if v.tag == "str" { return v.str_val }
    if v.tag == "void" { return "void" }
    if v.tag == "array" {
        let items = get_array(v)
        let mut parts = []
        for item in items { parts = parts.push(val_to_string(item)) }
        return "[" + parts.join(", ") + "]"
    }
    if v.tag == "map" {
        let ks = get_map_keys(v)
        let vs = get_map_values(v)
        let mut parts = []
        let mut mi = 0
        while mi < len(ks) {
            parts = parts.push(val_to_string(ks[mi]) + ": " + val_to_string(vs[mi]))
            mi = mi + 1
        }
        return "{" + parts.join(", ") + "}"
    }
    if v.tag == "fn" { return "<fn " + v.fn_name + ">" }
    if v.tag == "enum" {
        let s = v.struct_name
        if v.int_val >= 0 {
            return s + "(" + val_to_string(get_enum_data(v)) + ")"
        }
        return s
    }
    return "<" + v.tag + ">"
}

// ── JSON serialization / deserialization ─────────────────

fn val_to_json(v) {
    if v.tag == "int" { return to_string(v.int_val) }
    if v.tag == "float" { return to_string(v.float_val) }
    if v.tag == "bool" {
        if v.bool_val { return "true" } else { return "false" }
    }
    if v.tag == "str" {
        // Escape special characters in JSON string
        let s = v.str_val
        let s = s.replace("\\", "\\\\")
        let s = s.replace("\"", "\\\"")
        let s = s.replace("\n", "\\n")
        let s = s.replace("\t", "\\t")
        return "\"" + s + "\""
    }
    if v.tag == "void" { return "null" }
    if v.tag == "array" {
        let items = get_array(v)
        let mut parts = []
        for item in items { parts = parts.push(val_to_json(item)) }
        return "[" + parts.join(",") + "]"
    }
    if v.tag == "map" {
        let ks = get_map_keys(v)
        let vs = get_map_values(v)
        let mut parts = []
        let mut mi = 0
        while mi < len(ks) {
            let key_str = val_to_json(ks[mi])
            // Ensure key is always a JSON string
            if !key_str.starts_with("\"") {
                key_str = "\"" + val_to_string(ks[mi]) + "\""
            }
            parts = parts.push(key_str + ":" + val_to_json(vs[mi]))
            mi = mi + 1
        }
        return "{" + parts.join(",") + "}"
    }
    return "null"
}

fn json_to_val(s) {
    let s = s.trim()
    if s == "null" { return val_void() }
    if s == "true" { return val_bool(true) }
    if s == "false" { return val_bool(false) }
    // String
    if s.starts_with("\"") && s.ends_with("\"") {
        let inner = s.substring(1, len(s) - 1)
        let inner = inner.replace("\\n", "\n")
        let inner = inner.replace("\\t", "\t")
        let inner = inner.replace("\\\"", "\"")
        let inner = inner.replace("\\\\", "\\")
        return val_str(inner)
    }
    // Array
    if s.starts_with("[") && s.ends_with("]") {
        let inner = s.substring(1, len(s) - 1).trim()
        if inner == "" { return val_array([]) }
        let parts = json_split_top(inner)
        let mut items = []
        for p in parts { items = items.push(json_to_val(p)) }
        return val_array(items)
    }
    // Object
    if s.starts_with("{") && s.ends_with("}") {
        let inner = s.substring(1, len(s) - 1).trim()
        if inner == "" { return val_map([], []) }
        let parts = json_split_top(inner)
        let mut keys = []
        let mut values = []
        for p in parts {
            let colon = json_find_colon(p)
            if colon >= 0 {
                let k = p.substring(0, colon).trim()
                let v = p.substring(colon + 1, len(p)).trim()
                keys = keys.push(json_to_val(k))
                values = values.push(json_to_val(v))
            }
        }
        return val_map(keys, values)
    }
    // Number
    if s.contains(".") { return val_float(to_float(s)) }
    return val_int(to_int(s))
}

// Split a JSON string at top-level commas (not inside [] {} or "")
fn json_split_top(s) {
    let chars = s.chars()
    let n = len(chars)
    let mut parts = []
    let mut depth = 0
    let mut in_str = false
    let mut start = 0
    let mut i = 0
    while i < n {
        let ch = to_string(chars[i])
        if in_str {
            if ch == "\\" { i = i + 1 }
            else if ch == "\"" { in_str = false }
        } else {
            if ch == "\"" { in_str = true }
            else if ch == "[" || ch == "{" { depth = depth + 1 }
            else if ch == "]" || ch == "}" { depth = depth - 1 }
            else if ch == "," && depth == 0 {
                parts = parts.push(s.substring(start, i).trim())
                start = i + 1
            }
        }
        i = i + 1
    }
    if start < n { parts = parts.push(s.substring(start, n).trim()) }
    return parts
}

// Find the first top-level colon in a JSON key:value pair
fn json_find_colon(s) {
    let chars = s.chars()
    let n = len(chars)
    let mut in_str = false
    let mut i = 0
    while i < n {
        let ch = to_string(chars[i])
        if in_str {
            if ch == "\\" { i = i + 1 }
            else if ch == "\"" { in_str = false }
        } else {
            if ch == "\"" { in_str = true }
            else if ch == ":" { return i }
        }
        i = i + 1
    }
    return -1
}

fn to_float(v) {
    if v.tag == "float" { return v.float_val }
    if v.tag == "int" { return v.int_val * 1.0 }
    return 0.0
}

fn to_float_val(v) {
    if v.tag == "float" { return v.float_val }
    if v.tag == "int" { return v.int_val * 1.0 }
    return 0.0
}

// ── Array storage (using host arrays) ────────────────────
// We store arrays as actual hexa arrays wrapped in Val

let mut array_store = []

fn val_array(items) {
    let idx = len(array_store)
    array_store = array_store.push(items)
    return Val { tag: "array", int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn get_array(v) {
    return array_store[v.int_val]
}

// ── sort helper (insertion sort) ────────────────────────
fn sort_val_compare(a, b) {
    // Returns negative if a < b, 0 if equal, positive if a > b
    if a.tag == "int" && b.tag == "int" {
        return a.int_val - b.int_val
    }
    if a.tag == "float" || b.tag == "float" {
        let fa = to_float_val(a)
        let fb = to_float_val(b)
        if fa < fb { return -1 }
        if fa > fb { return 1 }
        return 0
    }
    // Default: compare as strings
    let sa = val_to_string(a)
    let sb = val_to_string(b)
    if sa < sb { return -1 }
    if sa > sb { return 1 }
    return 0
}

fn sort_array(items) {
    // Insertion sort — simple, correct, good enough for interpreted use
    let mut arr = []
    let mut i = 0
    while i < len(items) {
        arr = arr.push(items[i])
        i = i + 1
    }
    let mut i = 1
    while i < len(arr) {
        let key = arr[i]
        let mut j = i - 1
        while j >= 0 && sort_val_compare(arr[j], key) > 0 {
            arr[j + 1] = arr[j]
            j = j - 1
        }
        arr[j + 1] = key
        i = i + 1
    }
    return arr
}

fn val_fn(name, params, body) {
    return Val { tag: "fn", int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: name, fn_params: params, fn_body: body, struct_name: "", struct_fields: "" }
}

fn val_closure(name, params, body, captured_env) {
    // Store captured env in closure_store, reference via int_val
    let idx = len(closure_store)
    closure_store = closure_store.push(captured_env)
    return Val { tag: "fn", int_val: idx, float_val: 0.0, bool_val: false, str_val: "closure", char_val: "", array_val: "", fn_name: name, fn_params: params, fn_body: body, struct_name: "", struct_fields: "" }
}

// ── Map storage ─────────────────────────────────────────
// Maps stored as pairs of [keys_array, values_array]
let mut map_store = []

fn val_map(keys, values) {
    let idx = len(map_store)
    map_store = map_store.push([keys, values])
    return Val { tag: "map", int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn get_map_keys(v) {
    return map_store[v.int_val][0]
}

fn get_map_values(v) {
    return map_store[v.int_val][1]
}

fn map_get(v, key) {
    let keys = get_map_keys(v)
    let values = get_map_values(v)
    let mut i = 0
    while i < len(keys) {
        if val_eq(keys[i], key) { return values[i] }
        i = i + 1
    }
    return val_void()
}

fn map_set(v, key, value) {
    let keys = get_map_keys(v)
    let values = get_map_values(v)
    let mut new_keys = []
    let mut new_values = []
    let mut found = false
    let mut i = 0
    while i < len(keys) {
        if val_eq(keys[i], key) {
            new_keys = new_keys.push(keys[i])
            new_values = new_values.push(value)
            found = true
        } else {
            new_keys = new_keys.push(keys[i])
            new_values = new_values.push(values[i])
        }
        i = i + 1
    }
    if !found {
        new_keys = new_keys.push(key)
        new_values = new_values.push(value)
    }
    return val_map(new_keys, new_values)
}

fn map_contains_key(v, key) {
    let keys = get_map_keys(v)
    let mut i = 0
    while i < len(keys) {
        if val_eq(keys[i], key) { return true }
        i = i + 1
    }
    return false
}

fn map_remove(v, key) {
    let keys = get_map_keys(v)
    let values = get_map_values(v)
    let mut new_keys = []
    let mut new_values = []
    let mut i = 0
    while i < len(keys) {
        if !val_eq(keys[i], key) {
            new_keys = new_keys.push(keys[i])
            new_values = new_values.push(values[i])
        }
        i = i + 1
    }
    return val_map(new_keys, new_values)
}

fn val_eq(a, b) {
    if a.tag != b.tag { return false }
    if a.tag == "int" { return a.int_val == b.int_val }
    if a.tag == "float" { return a.float_val == b.float_val }
    if a.tag == "bool" { return a.bool_val == b.bool_val }
    if a.tag == "str" { return a.str_val == b.str_val }
    if a.tag == "enum" { return a.struct_name == b.struct_name }
    return false
}

// ── Struct storage ───────────────────────────────────────
let mut struct_store = []

fn val_struct(name, fields) {
    let idx = len(struct_store)
    struct_store = struct_store.push(fields)
    return Val { tag: "struct", int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: name, struct_fields: "" }
}

fn get_struct_fields(v) {
    return struct_store[v.int_val]
}

// ── Enum value storage ──────────────────────────────────
// Enum values: tag="enum", struct_name="EnumName::Variant", str_val stores variant name
// If the variant carries data, it's stored in enum_data_store[int_val]
let mut enum_data_store = []

fn val_enum(enum_name, variant, data) {
    let full_name = enum_name + "::" + variant
    let mut data_idx = -1
    if type_of(data) != "string" || data != "" {
        data_idx = len(enum_data_store)
        enum_data_store = enum_data_store.push(data)
    }
    return Val { tag: "enum", int_val: data_idx, float_val: 0.0, bool_val: false, str_val: variant, char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: full_name, struct_fields: "" }
}

fn get_enum_data(v) {
    if v.int_val < 0 { return val_void() }
    return enum_data_store[v.int_val]
}

// ── Stack trace helper ──────────────────────────────────
fn format_stack_trace() {
    let mut trace = "Stack trace:"
    let mut i = len(call_stack) - 1
    while i >= 0 {
        trace = trace + "\n  at " + call_stack[i]
        i = i - 1
    }
    return trace
}

// ── Main entry: run AST ──────────────────────────────────

fn interpret(ast) {
    // Reset state
    env_vars = []
    env_scopes = [0]
    env_fns = []
    return_flag = false
    return_val = val_void()
    break_flag = false
    continue_flag = false
    throw_flag = false
    throw_val = val_void()
    panic_flag = false
    panic_msg = ""
    gen_buffer = []
    gen_active = false
    array_store = []
    map_store = []
    struct_store = []
    impl_store = []
    closure_store = []
    extern_fns = []
    enum_data_store = []
    call_stack = []
    fn_attrs = []
    memo_cache = []

    let mut result = val_void()
    let mut _si = 0
    while _si < len(ast) {
        if panic_flag || throw_flag { _si = len(ast) } else {
            result = exec_stmt_at(ast, _si)
            _si = _si + 1
            if return_flag {
                result = return_val
                return_flag = false
            }
        }
    }
    // Uncaught panic — print diagnostic. Uses println (no stderr binding in
    // self interp), prefixed with "panic: " so callers can detect the abort.
    if panic_flag {
        println("panic: " + panic_msg)
    }
    return result
}

