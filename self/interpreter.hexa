//  self/interpreter.hexa — HEXA interpreter written in HEXA
//  Phase 2 of self-hosting: execute AST directly
//  Minimal core: variables, functions, arrays, strings, control flow
//
//  골화/안정/실패 레지스트리: ~/Dev/anima/shared/hexa/hexa_toolchain.json
//    (CLI dispatcher + stage0 interp + hexa_cc 전체 포괄)
//    ossified[] — 검증 완료 + 재현 가능
//    stable[]   — 회귀 없이 장기 동작
//    failing[]  — 현재 버그(수정 대상)
//  수정 시 해당 섹션 업데이트 필수. 상세 픽스 체인:
//  ~/Dev/anima/shared/hexa/interpreter_fixes_20260411.json
//  런타임 병목 추적: ~/Dev/hexa-lang/shared/hexa-lang/runtime-bottlenecks.json
// ═══════════════════════════════════════════════════════════

// ── Value representation ─────────────────────────────────
// Values are represented as structs with a numeric tag discriminator.
// Numeric tags avoid string comparisons on every value dispatch (perf #4).

let TAG_INT = 0
let TAG_FLOAT = 1
let TAG_BOOL = 2
let TAG_STR = 3
let TAG_CHAR = 4
let TAG_ARRAY = 5
let TAG_FN = 6
let TAG_STRUCT = 7
let TAG_VOID = 8
let TAG_ENUM = 9
let TAG_MAP = 10
let TAG_TENSOR = 11
let TAG_ERROR = 12
let TAG_POINTER = 13
let TAG_CHANNEL = 14
let TAG_EFFECT_REQUEST = 15
let TAG_ATOMIC = 16
let TAG_BIGINT = 17
let TAG_NOT_BUILTIN = 18
let TAG_NOT_FUSED = 19

fn tag_name(t) {
    if t == TAG_INT { return "int" }
    if t == TAG_FLOAT { return "float" }
    if t == TAG_BOOL { return "bool" }
    if t == TAG_STR { return "str" }
    if t == TAG_CHAR { return "char" }
    if t == TAG_ARRAY { return "array" }
    if t == TAG_FN { return "fn" }
    if t == TAG_STRUCT { return "struct" }
    if t == TAG_VOID { return "void" }
    if t == TAG_ENUM { return "enum" }
    if t == TAG_MAP { return "map" }
    if t == TAG_TENSOR { return "tensor" }
    if t == TAG_ERROR { return "error" }
    if t == TAG_POINTER { return "pointer" }
    if t == TAG_CHANNEL { return "channel" }
    if t == TAG_EFFECT_REQUEST { return "effect_request" }
    if t == TAG_ATOMIC { return "atomic" }
    if t == TAG_BIGINT { return "bigint" }
    if t == TAG_NOT_BUILTIN { return "__not_builtin__" }
    if t == TAG_NOT_FUSED { return "__not_fused__" }
    return "unknown"
}

struct Val {
    tag: int,       // TAG_INT, TAG_FLOAT, TAG_BOOL, TAG_STR, TAG_CHAR, TAG_VOID, TAG_ARRAY, TAG_FN, TAG_STRUCT, etc.
    int_val: int,
    float_val: float,
    bool_val: bool,
    str_val: string,
    char_val: string,
    array_val: string,  // stored as external ref
    fn_name: string,
    fn_params: string,
    fn_body: string,
    struct_name: string,
    struct_fields: string
}

pub let mut __VAL_VOID = Val { tag: TAG_VOID, int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
pub let mut __VAL_TRUE = Val { tag: TAG_BOOL, int_val: 0, float_val: 0.0, bool_val: true, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
pub let mut __VAL_FALSE = Val { tag: TAG_BOOL, int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
pub let mut __VAL_INT_CACHE = []
pub let mut __VAL_INT_CACHE_LEN = 0
fn __init_val_int_cache() {
    let mut k = 0
    while k < 256 {
        let v = Val { tag: TAG_INT, int_val: k, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
        __VAL_INT_CACHE = __VAL_INT_CACHE.push(v)
        k = k + 1
    }
    __VAL_INT_CACHE_LEN = 256
}
pub let mut __VAL_FLOAT_0   = Val { tag: TAG_FLOAT, int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
pub let mut __VAL_FLOAT_1   = Val { tag: TAG_FLOAT, int_val: 0, float_val: 1.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
pub let mut __VAL_FLOAT_H   = Val { tag: TAG_FLOAT, int_val: 0, float_val: 0.5, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
pub let mut __VAL_FLOAT_2   = Val { tag: TAG_FLOAT, int_val: 0, float_val: 2.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
fn val_int(n) {
    if n >= 0 && n < __VAL_INT_CACHE_LEN { return __VAL_INT_CACHE[n] }
    if __VAL_INT_CACHE_LEN == 0 && n >= 0 && n < 256 {
        __init_val_int_cache()
        return __VAL_INT_CACHE[n]
    }
    return Val { tag: TAG_INT, int_val: n, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}
fn val_float(f) {
    // IEEE 정확 일치만 hit — 근사 비교 금지
    if f == 0.0 { return __VAL_FLOAT_0 }
    if f == 1.0 { return __VAL_FLOAT_1 }
    if f == 0.5 { return __VAL_FLOAT_H }
    if f == 2.0 { return __VAL_FLOAT_2 }
    return Val { tag: TAG_FLOAT, int_val: 0, float_val: f, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}
fn val_bool(b) { if b { return __VAL_TRUE } return __VAL_FALSE }
fn val_str(s) { return Val { tag: TAG_STR, int_val: 0, float_val: 0.0, bool_val: false, str_val: s, char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" } }
fn val_void() { return __VAL_VOID }

// ── Environment (scope-based variable storage) ───────────
// NOTE: All module-level state declared `pub let mut` so cross-module
// callers (host_test.hexa, bootstrap pipelines, fixpoint runners) can
// reset and re-enter `interpret()`. Same pattern as self/parser.hexa.
// Without `pub`, lookups from within import dispatch see uninitialized
// captures and fail with "undefined variable: env_vars".

pub let mut env_vars = []      // array of {name, value} pairs
pub let mut env_scopes = [0]   // scope boundary stack
// ── O(1) env_lookup cache (perf) ──────────────────────────
// Parallel to env_vars: 64 buckets, each a list of [name, env_index].
// env_define appends; env_lookup/set scan only the name's bucket and
// pick the entry with the largest index (newest binding still in scope).
// env_pop_scope prunes entries whose index >= new boundary.
// Bucket count 64 = power of two, empirically covers typical
// top-level fn + let counts (~100) with avg chain length <2.
pub let mut env_cache = []     // list of 64 buckets; each bucket is [[name, idx], ...]
// ── Scope-dirty tracking (perf opt #8) ──────────────────────
// Stack of dirty-bucket sets, one per scope. Each entry is an array of
// bucket indices that were modified (by env_define) during that scope.
// On scope pop, only those buckets need pruning — not all 64.
pub let mut env_scope_dirty = []   // stack of [bucket_idx, ...] arrays
pub let mut env_fns = []      // function registry: name -> {params, body}
// ── O(1) fn_lookup cache (perf) ─────────────────────────
// Parallel to env_fns: 64 buckets, each a list of [name, env_fns_index].
// find_fn scans only the name's bucket and picks the entry with the
// largest index (newest definition = shadowing). Same pattern as env_cache.
pub let mut fn_cache = []     // list of 64 buckets; each bucket is [[name, idx], ...]
pub let mut return_flag = false
pub let mut return_val = val_void()
pub let mut break_flag = false
pub let mut break_label = ""
pub let mut continue_flag = false
pub let mut continue_label = ""
pub let mut defer_stack = []
pub let mut throw_flag = false
pub let mut throw_val = val_void()
// Panic: unrecoverable abort. Propagates through all enclosing blocks like
// throw, but is NOT cleared by try/catch or recover — only program exit
// observes it (interpret() prints "panic: <msg>" to stderr and returns void).
pub let mut panic_flag = false
pub let mut panic_msg = ""
pub let mut call_stack = []    // stack trace: array of function names
// ── Sprint C: yield / eager generator buffer ─────────────
// Functions containing `yield` accumulate values into gen_buffer; upon
// return the accumulated array becomes the function's result. This is
// semantically correct for finite generators (no coroutines required).
// Each call frame saves/restores the outer buffer+flag so nested and
// non-generator calls are unaffected.
pub let mut gen_buffer = []
pub let mut gen_active = false

// T25 fix: enum declaration registry so `EnumName.Variant` field access
// can produce a proper enum value instead of dropping to void.
// Layout: [[enum_name, [variant_name, ...]], ...]
pub let mut enum_decls = []

fn enum_decls_register(name, variant_names) {
    // Simple append — later entries shadow earlier on lookup (we scan forward
    // but `enum_decls_has_variant` returns false only when name matches but
    // variant is absent, so duplicate registrations with the same name and
    // overlapping variants are harmless). Avoids in-place slot assignment.
    enum_decls = enum_decls.push([name, variant_names])
    return val_void()
}

fn enum_decls_has_variant(name, variant) {
    // Scan all entries (last-wins is handled by never early-returning false).
    let mut i = 0
    while i < len(enum_decls) {
        if enum_decls[i][0] == name {
            let vs = enum_decls[i][1]
            let mut j = 0
            while j < len(vs) {
                if vs[j] == variant { return true }
                j = j + 1
            }
        }
        i = i + 1
    }
    return false
}

// ═══════════════════════════════════════════════════════════
//  Numeric dispatch IDs — node kinds
//  String→int conversion done once at lookup; eval dispatches on int.
//  ~45 sequential string comparisons → single int comparison per arm.
// ═══════════════════════════════════════════════════════════
let NK_UNKNOWN       = 0
let NK_INT_LIT       = 1
let NK_FLOAT_LIT     = 2
let NK_BOOL_LIT      = 3
let NK_STRING_LIT    = 4
let NK_CHAR_LIT      = 5
let NK_IDENT         = 6
let NK_BIN_OP        = 7
let NK_UNARY_OP      = 8
let NK_ARRAY         = 9
let NK_INDEX         = 10
let NK_CALL          = 11
let NK_FIELD         = 12
let NK_IF_EXPR       = 13
let NK_LAMBDA        = 14
let NK_MAP_LIT       = 15
let NK_RANGE         = 16
let NK_ASSIGN        = 17
let NK_TUPLE_LIT     = 18
let NK_STRUCT_INIT   = 19
let NK_ENUM_PATH     = 20
let NK_THROW_EXPR    = 21
let NK_THROW_STMT    = 22
let NK_BLOCK         = 23
let NK_BLOCK_EXPR    = 24
let NK_TUPLE         = 25
let NK_TUPLE_EXPR    = 26
let NK_HANDLE_WITH   = 27
let NK_EFFECT_CALL   = 28
let NK_RESUME        = 29
let NK_RESUME_EXPR   = 30
let NK_COMPTIME      = 31
let NK_COMPTIME_EXPR = 32
let NK_TEMPLATE      = 33
let NK_TEMPLATE_EXPR = 34
let NK_INTERP_STR    = 35
let NK_WILDCARD      = 36
let NK_ARRAY_PATTERN = 37
let NK_OWN           = 38
let NK_MOVE          = 39
let NK_MOVE_EXPR     = 40
let NK_BORROW        = 41
let NK_BORROW_EXPR   = 42
let NK_AWAIT         = 43
let NK_AWAIT_EXPR    = 44
let NK_DYN_CAST      = 45
let NK_DYN_CAST_EXPR = 46
let NK_MACRO_INVOC   = 47
let NK_MACRO_INVOCATION = 48
let NK_TRY_CATCH_EXPR = 49
let NK_TRY_CATCH     = 50
let NK_MATCH_EXPR    = 51
let NK_OPT_FIELD     = 52
let NK_LIST_COMP     = 53
let NK_WALRUS        = 54
let NK_GUARD         = 55
let NK_GUARD_LET     = 56
let NK_WITH          = 57

// ── Numeric dispatch IDs — binary operators ─────────────
let OP_UNKNOWN  = 0
let OP_ADD      = 1
let OP_SUB      = 2
let OP_MUL      = 3
let OP_DIV      = 4
let OP_MOD      = 5
let OP_POW      = 6
let OP_EQ       = 7
let OP_NE       = 8
let OP_LT       = 9
let OP_GT       = 10
let OP_LE       = 11
let OP_GE       = 12
let OP_AND      = 13
let OP_OR       = 14
let OP_BIT_AND  = 15
let OP_BIT_OR   = 16
let OP_BIT_XOR  = 17
let OP_SHL      = 18
let OP_SHR      = 19
let OP_NULL_COAL = 20
let OP_PIPE      = 21
let OP_IN        = 22
let OP_IS        = 23

// ── Node-kind string → int conversion (called once per node) ──
fn node_kind_to_id(kind) {
    if kind == "IntLit" { return NK_INT_LIT }
    if kind == "FloatLit" { return NK_FLOAT_LIT }
    if kind == "BoolLit" { return NK_BOOL_LIT }
    if kind == "StringLit" { return NK_STRING_LIT }
    if kind == "CharLit" { return NK_CHAR_LIT }
    if kind == "Ident" { return NK_IDENT }
    if kind == "BinOp" { return NK_BIN_OP }
    if kind == "UnaryOp" { return NK_UNARY_OP }
    if kind == "Array" { return NK_ARRAY }
    if kind == "Index" { return NK_INDEX }
    if kind == "Call" { return NK_CALL }
    if kind == "Field" { return NK_FIELD }
    if kind == "IfExpr" { return NK_IF_EXPR }
    if kind == "Lambda" { return NK_LAMBDA }
    if kind == "MapLit" { return NK_MAP_LIT }
    if kind == "Range" { return NK_RANGE }
    if kind == "Assign" { return NK_ASSIGN }
    if kind == "TupleLit" { return NK_TUPLE_LIT }
    if kind == "StructInit" { return NK_STRUCT_INIT }
    if kind == "EnumPath" { return NK_ENUM_PATH }
    if kind == "ThrowExpr" { return NK_THROW_EXPR }
    if kind == "ThrowStmt" { return NK_THROW_STMT }
    if kind == "Block" { return NK_BLOCK }
    if kind == "BlockExpr" { return NK_BLOCK_EXPR }
    if kind == "Tuple" { return NK_TUPLE }
    if kind == "TupleExpr" { return NK_TUPLE_EXPR }
    if kind == "HandleWith" { return NK_HANDLE_WITH }
    if kind == "EffectCall" { return NK_EFFECT_CALL }
    if kind == "Resume" { return NK_RESUME }
    if kind == "ResumeExpr" { return NK_RESUME_EXPR }
    if kind == "Comptime" { return NK_COMPTIME }
    if kind == "ComptimeExpr" { return NK_COMPTIME_EXPR }
    if kind == "Template" { return NK_TEMPLATE }
    if kind == "TemplateExpr" { return NK_TEMPLATE_EXPR }
    if kind == "InterpolatedString" { return NK_INTERP_STR }
    if kind == "Wildcard" { return NK_WILDCARD }
    if kind == "ArrayPattern" { return NK_ARRAY_PATTERN }
    if kind == "Own" { return NK_OWN }
    if kind == "Move" { return NK_MOVE }
    if kind == "MoveExpr" { return NK_MOVE_EXPR }
    if kind == "Borrow" { return NK_BORROW }
    if kind == "BorrowExpr" { return NK_BORROW_EXPR }
    if kind == "Await" { return NK_AWAIT }
    if kind == "AwaitExpr" { return NK_AWAIT_EXPR }
    if kind == "DynCast" { return NK_DYN_CAST }
    if kind == "DynCastExpr" { return NK_DYN_CAST_EXPR }
    if kind == "MacroInvoc" { return NK_MACRO_INVOC }
    if kind == "MacroInvocation" { return NK_MACRO_INVOCATION }
    if kind == "TryCatchExpr" { return NK_TRY_CATCH_EXPR }
    if kind == "TryCatch" { return NK_TRY_CATCH }
    if kind == "MatchExpr" { return NK_MATCH_EXPR }
    if kind == "OptField" { return NK_OPT_FIELD }
    if kind == "ListComp" { return NK_LIST_COMP }
    if kind == "WalrusExpr" { return NK_WALRUS }
    if kind == "GuardStmt" { return NK_GUARD }
    if kind == "GuardLetStmt" { return NK_GUARD_LET }
    if kind == "WithStmt" { return NK_WITH }
    return NK_UNKNOWN
}

// ── Operator string → int conversion (called once per binop node) ──
fn op_to_id(op) {
    if op == "+" { return OP_ADD }
    if op == "-" { return OP_SUB }
    if op == "*" { return OP_MUL }
    if op == "/" { return OP_DIV }
    if op == "%" { return OP_MOD }
    if op == "**" { return OP_POW }
    if op == "==" { return OP_EQ }
    if op == "!=" { return OP_NE }
    if op == "<" { return OP_LT }
    if op == ">" { return OP_GT }
    if op == "<=" { return OP_LE }
    if op == ">=" { return OP_GE }
    if op == "&&" { return OP_AND }
    if op == "||" { return OP_OR }
    if op == "&" { return OP_BIT_AND }
    if op == "|" { return OP_BIT_OR }
    if op == "^" { return OP_BIT_XOR }
    if op == "<<" { return OP_SHL }
    if op == ">>" { return OP_SHR }
    if op == "??" { return OP_NULL_COAL }
    if op == "|>" { return OP_PIPE }
    if op == "in" { return OP_IN }
    if op == "is" { return OP_IS }
    return OP_UNKNOWN
}

// ── Node-kind ID cache ──────────────────────────────────
// Maps node kind string → int ID. Populated lazily so the string→int
// conversion happens at most once per unique kind string, not every eval.
// Layout: [[kind_string, id_int], ...]
pub let mut nk_cache = []

fn nk_cached_id(kind) {
    // Scan cache (typically <52 entries, very short)
    let mut i = 0
    while i < len(nk_cache) {
        if nk_cache[i][0] == kind { return nk_cache[i][1] }
        i = i + 1
    }
    // Miss — compute and store
    let id = node_kind_to_id(kind)
    nk_cache = nk_cache.push([kind, id])
    return id
}

// ── Operator ID cache ───────────────────────────────────
pub let mut op_cache = []

fn op_cached_id(op) {
    let mut i = 0
    while i < len(op_cache) {
        if op_cache[i][0] == op { return op_cache[i][1] }
        i = i + 1
    }
    let id = op_to_id(op)
    op_cache = op_cache.push([op, id])
    return id
}

// ── @memo/@memoize/@cache runtime support ───────────────
// fn_attrs: maps function name -> comma-separated attr string
pub let mut fn_attrs = []      // [[name, attrs_str], ...]
// ── Optimization #5: pre-parsed attribute flags ─────────
// Avoids O(m*n) substring matching on every call. Each entry:
// [name, is_memo (bool), is_pure (bool)]
// Populated by fn_attrs_set; queried by fn_attr_flag_memo.
pub let mut fn_attr_flags = []  // [[name, is_memo, is_pure], ...]
// ── Optimization #6: hash-bucketed memo cache ───────────
// 64 buckets, each a list of [key, result_val] pairs.
// Same pattern as env_cache. Replaces linear memo_cache scan.
pub let mut memo_cache = []    // 64 buckets; each bucket is [[key, val], ...]

fn fn_attrs_set(name, attrs) {
    fn_attrs = fn_attrs.push([name, attrs])
    // ── Opt #5: parse attribute flags once at define time ──
    let mut is_memo = false
    let mut is_pure = false
    if attrs != "" {
        if attrs == "memoize" || attrs == "memo" || attrs == "cache" {
            is_memo = true
        } else {
            if contains(attrs, "memoize") { is_memo = true }
            if contains(attrs, "memo") { is_memo = true }
            if contains(attrs, "cache") { is_memo = true }
        }
        if attrs == "pure" || contains(attrs, "pure") {
            is_pure = true
        }
    }
    fn_attr_flags = fn_attr_flags.push([name, is_memo, is_pure])
}

fn fn_attrs_get(name) {
    let mut i = len(fn_attrs) - 1
    while i >= 0 {
        if fn_attrs[i][0] == name { return fn_attrs[i][1] }
        i = i - 1
    }
    return ""
}

// ── Opt #5: O(1) flag check replaces substring matching ──
fn fn_attr_flag_memo(name) {
    let mut i = len(fn_attr_flags) - 1
    while i >= 0 {
        if fn_attr_flags[i][0] == name { return fn_attr_flags[i][1] }
        i = i - 1
    }
    return false
}

fn has_memo_attr(name) {
    return fn_attr_flag_memo(name)
}

fn memo_key_for_args(name, args) {
    let mut key = name + "("
    let mut i = 0
    while i < len(args) {
        if i > 0 { key = key + "," }
        key = key + val_to_string(args[i])
        i = i + 1
    }
    key = key + ")"
    return key
}

// ── Opt #6: hash-bucketed memo cache (64 buckets) ────────
// Same design as env_cache. Hash the key string into a bucket,
// then linear-scan only that bucket (~len/64 entries on average).

fn memo_hash(key) {
    let mut h = 0
    let mut i = 0
    let n = len(key)
    while i < n {
        h = h + char_code(key, i)
        i = i + 1
    }
    let mut b = h
    while b < 0 { b = b + 64 }
    return b % 64
}

fn memo_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets = buckets.push([])
        i = i + 1
    }
    memo_cache = buckets
}

fn memo_lookup(key) {
    if len(memo_cache) != 64 { return "" }
    let b = memo_hash(key)
    let bucket = memo_cache[b]
    let mut i = 0
    let n = len(bucket)
    while i < n {
        if bucket[i][0] == key { return bucket[i] }
        i = i + 1
    }
    return ""
}

fn memo_store(key, result) {
    if len(memo_cache) != 64 { memo_cache_init() }
    let b = memo_hash(key)
    memo_cache[b] = memo_cache[b].push([key, result])
}

// ── @specialize inline cache (V8-style IC) ─────────────
// Per call-site type feedback: [[fn_name, [type_tag, hit_count], ...], ...]
// When a @specialize fn is called, we record the tag of arg[0].
// If a single type dominates (>= 80%), we fast-path with type assertion.
pub let mut specialize_ic = []

fn specialize_ic_record(fn_name, arg_tag) {
    // Find existing entry
    let mut fi = 0
    let mut found = false
    while fi < len(specialize_ic) {
        if specialize_ic[fi][0] == fn_name {
            found = true
            let mut entries = specialize_ic[fi][1]
            // Find tag entry
            let mut ti = 0
            let mut tag_found = false
            while ti < len(entries) {
                if entries[ti][0] == arg_tag {
                    let mut new_entries = []
                    let mut ui = 0
                    while ui < len(entries) {
                        if ui == ti {
                            new_entries = new_entries.push([arg_tag, entries[ti][1] + 1])
                        } else {
                            new_entries = new_entries.push(entries[ui])
                        }
                        ui = ui + 1
                    }
                    entries = new_entries
                    tag_found = true
                }
                ti = ti + 1
            }
            if !tag_found {
                entries = entries.push([arg_tag, 1])
            }
            // Update in-place
            let mut new_ic = []
            let mut ri = 0
            while ri < len(specialize_ic) {
                if ri == fi {
                    new_ic = new_ic.push([fn_name, entries])
                } else {
                    new_ic = new_ic.push(specialize_ic[ri])
                }
                ri = ri + 1
            }
            specialize_ic = new_ic
        }
        fi = fi + 1
    }
    if !found {
        specialize_ic = specialize_ic.push([fn_name, [[arg_tag, 1]]])
    }
}

fn specialize_ic_dominant_type(fn_name) {
    let mut fi = 0
    while fi < len(specialize_ic) {
        if specialize_ic[fi][0] == fn_name {
            let entries = specialize_ic[fi][1]
            let mut total = 0
            let mut max_tag = ""
            let mut max_count = 0
            let mut ei = 0
            while ei < len(entries) {
                total = total + entries[ei][1]
                if entries[ei][1] > max_count {
                    max_count = entries[ei][1]
                    max_tag = entries[ei][0]
                }
                ei = ei + 1
            }
            // Monomorphic: >= 80% of calls have same type
            if total > 0 && (max_count * 100 / total) >= 80 {
                return max_tag
            }
            return ""
        }
        fi = fi + 1
    }
    return ""
}
// ── @lazy thunk runtime support ─────────────────────────
// lazy_cache: [[fn_name, result_val, computed_flag], ...]
// A @lazy fn is evaluated at most once; the result is cached here.
pub let mut lazy_cache = []

fn has_lazy_attr(name) {
    let attrs = fn_attrs_get(name)
    if attrs == "" { return false }
    if attrs == "lazy" { return true }
    if contains(attrs, "lazy") { return true }
    return false
}

fn lazy_lookup(name) {
    let mut i = 0
    while i < len(lazy_cache) {
        if lazy_cache[i][0] == name { return lazy_cache[i] }
        i = i + 1
    }
    return ""
}

fn has_specialize_attr(name) {
    let attrs = fn_attrs_get(name)
    if attrs == "" { return false }
    if attrs == "specialize" { return true }
    if contains(attrs, "specialize") { return true }
    return false
}
fn lazy_store(name, result) {
    lazy_cache = lazy_cache.push([name, result])
}

// ── Extern FFI storage ──────────────────────────────────
// Each entry: [hexa_name, c_symbol, ret_type, link_lib]
// c_symbol is from @symbol("name"); if empty, hexa_name is used for dlsym.
pub let mut extern_fns = []

// Look up the C symbol name for a hexa extern function.
// Returns the @symbol alias if set, otherwise the hexa name itself.
fn extern_c_symbol(hexa_name) {
    let mut i = len(extern_fns) - 1
    while i >= 0 {
        if extern_fns[i][0] == hexa_name {
            return extern_fns[i][1]
        }
        i = i - 1
    }
    return hexa_name
}

// Look up the link library for a hexa extern function.
fn extern_link_lib(hexa_name) {
    let mut i = len(extern_fns) - 1
    while i >= 0 {
        if extern_fns[i][0] == hexa_name {
            return extern_fns[i][3]
        }
        i = i - 1
    }
    return ""
}

// ── Impl block storage (struct method dispatch) ─────────
// Each entry: [target_name, methods_array]
// methods_array: each is a FnDecl node with .name, .params, .body
pub let mut impl_store = []

// ── Closure environment storage ─────────────────────────
// Closures capture a snapshot of [env_vars, env_cache] at creation time.
// On closure call, both arrays are swapped in O(1) — no env_rebuild_cache().
pub let mut closure_store = []

// ── G22/G23: Named arguments passing ───────────────────
// Temporary storage for named args during a call dispatch.
// Each entry: [param_name, evaluated_val]
pub let mut pending_named_args = []

// ── Callback trampoline storage (G4) ───────────────────
// Pool of 16 callback slots for interpreter mode.
// Each slot: [in_use (0/1), fn_val]
pub let mut callback_slots = []
pub let mut callback_inited = false

fn callback_init() {
    if callback_inited { return 0 }
    callback_inited = true
    let mut i = 0
    while i < 16 {
        callback_slots = callback_slots.push([0, val_void()])
        i = i + 1
    }
    return 0
}

fn callback_slots_put(idx, entry) {
    let mut new_slots = []
    let mut i = 0
    while i < 16 {
        if i == idx {
            new_slots = new_slots.push(entry)
        } else {
            new_slots = new_slots.push(callback_slots[i])
        }
        i = i + 1
    }
    callback_slots = new_slots
}

fn callback_alloc(fn_val) {
    callback_init()
    let mut i = 0
    while i < 16 {
        if callback_slots[i][0] == 0 {
            callback_slots_put(i, [1, fn_val])
            return i
        }
        i = i + 1
    }
    println("callback pool exhausted (16 slots)")
    return -1
}

fn callback_release(slot) {
    callback_init()
    if slot >= 0 && slot < 16 {
        callback_slots_put(slot, [0, val_void()])
    }
}

fn callback_call(slot, args) {
    callback_init()
    if slot < 0 || slot >= 16 { return val_void() }
    if callback_slots[slot][0] == 0 { return val_void() }
    let fn_val = callback_slots[slot][1]
    if fn_val.tag == TAG_FN {
        return call_fn_val(fn_val, args)
    }
    return val_void()
}

// ── Host builtin shims ─────────────────────────────────────
// call_builtin's parameter `args` shadows the host's `args()` builtin,
// so we need top-level helpers (no `args` param) to reach it.
//
// bt 69 (2026-04-13): 실제 argv 전달 구현.
//   호스트 AOT 바이너리(stage0)의 main() 은 hexa_main_argc/argv 를 채움
//   (self/build_c.hexa:4393 — `hexa_main_argc=argc; hexa_main_argv=argv`).
//   `args()` 빌트인은 C 수준에서 `hexa_args()` 로 컴파일되어
//   [argv[0], argv[1], ...] 전체를 반환 (self/build_c.hexa:2359).
//
//   stage0 호출 규약: `stage0 <script.hexa> <user1> <user2> ...`
//     → hexa_main_argv = ["stage0", "script.hexa", "user1", "user2", ...]
//     → args() = 동일 배열
//     → 사용자 스크립트가 원하는 값은 인덱스 2부터 (바이너리+스크립트 skip)
//
//   따라서 host_args() 는 args()[2..] 만 반환한다.
//   call_builtin("args", ...) 은 이 결과를 val_str 로 래핑 (interpreter.hexa:3945).
fn host_args() {
    let raw = args()
    let mut result = []
    let mut i = 1
    while i < len(raw) {
        result = result.push(raw[i])
        i = i + 1
    }
    return result
}
fn host_argc() { return len(args()) }
fn host_arg(i) {
    let a = host_args()
    if i >= 0 && i < len(a) { return a[i] }
    return ""
}

// ═══════════════════════════════════════════════════════════
//  Phase 7 골화 — FFI: extern fn dispatch + value/C ABI bridge
//  src/interpreter.rs:10814 (call_extern_fn) 대응
// ═══════════════════════════════════════════════════════════
//  Self-host 인터프리터는 dlsym+transmute를 직접 못 함.
//  대신 호스트 인터프리터(이 코드를 실행 중인 native hexa)가
//  제공하는 빌트인 `__host_extern_call`을 거쳐 dispatch.
//  호스트가 그 빌트인을 노출하지 않는 경우는 error 반환.

// Convert a Val to a C-ABI i64 (matches src::value_to_c_arg)
//   int → i64 그대로
//   bool → 0/1
//   float → bit-cast (정확도는 호스트 책임)
//   str → 호스트가 펀딩한 UTF-8 ptr (현 self-host: 길이만 반환)
//   pointer → addr
//   기타 → 0
fn value_to_c_arg(v) {
    if v.tag == TAG_INT { return v.int_val }
    if v.tag == TAG_BOOL { if v.bool_val { return 1 } else { return 0 } }
    if v.tag == TAG_POINTER { return v.int_val }
    if v.tag == TAG_CHAR {
        let cs = v.char_val
        if len(cs) > 0 { return cs[0] }
        return 0
    }
    // float / str / 기타: self-host에선 안전 fallback
    return 0
}

// Convert a C-ABI i64 return back to a Val based on declared ret_type.
//   "int"|"i64"|"" → int
//   "bool" → bool
//   "ptr"|"void*" → pointer
//   "char"|"i8" → char
//   기타 → int
fn c_ret_to_value(raw, ret_type) {
    if ret_type == "bool" { return val_bool(raw != 0) }
    if ret_type == "ptr" || ret_type == "void*" || ret_type == "*mut" {
        return val_pointer(raw)
    }
    if ret_type == "char" || ret_type == "i8" {
        return Val { tag: TAG_CHAR, int_val: raw, float_val: 0.0, bool_val: false, str_val: "", char_val: to_string(raw), array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
    }
    return val_int(raw)
}

// call_extern_fn(builtin_name, args) — dispatch C extern from .hexa interpreter
//   builtin_name format: "__extern_<fn_name>"
//   1. Extract fn_name
//   2. Look up declared ret_type
//   3. Resolve C symbol via @symbol alias (extern_c_symbol)
//   4. Convert args to i64
//   5. Delegate to host builtin __host_extern_call(c_symbol, link_lib, [c_args])
//   6. Convert result via c_ret_to_value
fn call_extern_fn(builtin_name, args) {
    let fn_name = builtin_name.substring(9, len(builtin_name))   // strip "__extern_"
    let c_sym = extern_c_symbol(fn_name)
    let lib = extern_link_lib(fn_name)
    let mut ret_type = ""
    let mut i = len(extern_fns) - 1
    while i >= 0 {
        if extern_fns[i][0] == fn_name {
            ret_type = extern_fns[i][2]
            i = -1
        } else {
            i = i - 1
        }
    }
    let mut c_args = []
    for a in args { c_args = c_args.push(value_to_c_arg(a)) }
    // Delegate to host runtime via builtin. If host doesn't expose it,
    // not_builtin sentinel propagates → fall through to error.
    let host_result = call_builtin("__host_extern_call", [val_str(c_sym), val_str(lib), val_array_simple(c_args)])
    if host_result.tag == TAG_NOT_BUILTIN {
        return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "extern '" + fn_name + "': host runtime does not expose __host_extern_call", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
    }
    if host_result.tag == TAG_INT {
        return c_ret_to_value(host_result.int_val, ret_type)
    }
    return host_result
}

// Helper: build a Val::Array from a flat int array (used by call_extern_fn)
fn val_array_simple(int_items) {
    let mut wrapped = []
    for n in int_items { wrapped = wrapped.push(val_int(n)) }
    return val_array(wrapped)
}

// ═══════════════════════════════════════════════════════════
//  Phase 9 골화 — Formal proof engine bridge
//  src/interpreter.rs:11968-12045 대응
// ═══════════════════════════════════════════════════════════
//  HEXA Expr → ProofExpr 변환 + execute_proof_block_stmt.
//  실제 SAT/SMT solver는 src::proof_engine (Rust)에 있으므로
//  self-host에선 호스트 빌트인 __host_proof_check를 시도하고,
//  미노출 시 "skipped" 결과를 반환.

// ProofExpr는 hexa에선 [kind, ...payload] 배열로 인코딩.
//   ["var", name]            ["bool", b]                ["int", n]
//   ["and", l, r]            ["or", l, r]               ["not", x]
//   ["eq", l, r]             ["lt", l, r]               ["gt", l, r]
//   ["le", l, r]             ["ge", l, r]               ["add", l, r]
//   ["implies", l, r]        ["fn_call", name, args]    ["unknown", desc]

fn proof_var(name) { return ["var", name] }
fn proof_bool(b) { return ["bool", b] }
fn proof_int(n) { return ["int", n] }
fn proof_and(l, r) { return ["and", l, r] }
fn proof_or(l, r) { return ["or", l, r] }
fn proof_not(x) { return ["not", x] }
fn proof_eq(l, r) { return ["eq", l, r] }
fn proof_lt(l, r) { return ["lt", l, r] }
fn proof_gt(l, r) { return ["gt", l, r] }
fn proof_le(l, r) { return ["le", l, r] }
fn proof_ge(l, r) { return ["ge", l, r] }
fn proof_add(l, r) { return ["add", l, r] }
fn proof_implies(l, r) { return ["implies", l, r] }
fn proof_fn_call(name, args) { return ["fn_call", name, args] }
fn proof_unknown(desc) { return ["unknown", desc] }

fn expr_to_proof_expr(expr) {
    if type_of(expr) == "string" { return proof_unknown("string_expr") }
    let k = expr.kind
    if k == "Ident" { return proof_var(expr.name) }
    if k == "BoolLit" { return proof_bool(expr.value) }
    if k == "IntLit" { return proof_int(expr.value) }
    if k == "Binary" {
        let l = expr_to_proof_expr(expr.left)
        let r = expr_to_proof_expr(expr.right)
        let op = expr.op
        if op == "&&" || op == "and" { return proof_and(l, r) }
        if op == "||" || op == "or" { return proof_or(l, r) }
        if op == "==" { return proof_eq(l, r) }
        if op == "<" { return proof_lt(l, r) }
        if op == ">" { return proof_gt(l, r) }
        if op == "<=" { return proof_le(l, r) }
        if op == ">=" { return proof_ge(l, r) }
        if op == "+" { return proof_add(l, r) }
        if op == "->" || op == "=>" { return proof_implies(l, r) }
        return proof_unknown("binop_" + op)
    }
    if k == "Unary" && expr.op == "!" {
        return proof_not(expr_to_proof_expr(expr.operand))
    }
    if k == "Call" {
        // parser AST stores callee in `left` field, not `callee`
        let callee = expr.left
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let mut p_args = []
            for a in expr.args { p_args = p_args.push(expr_to_proof_expr(a)) }
            return proof_fn_call(callee.name, p_args)
        }
        return proof_unknown("unknown_call")
    }
    return proof_unknown("expr_" + k)
}

// execute_proof_block_stmt(stmt) — dispatch a single proof block statement.
//   Returns ["proved" | "refuted" | "skipped" | "unknown", message]
fn execute_proof_block_stmt(stmt) {
    if type_of(stmt) == "string" { return ["skipped", "string_stmt"] }
    let k = stmt.kind
    let mut req = val_void()
    if k == "ForAll" {
        let cond_pe = expr_to_proof_expr(stmt.condition)
        let conc_pe = expr_to_proof_expr(stmt.conclusion)
        req = ["forall", cond_pe, conc_pe]
    }
    if k == "Exists" {
        let cond_pe = expr_to_proof_expr(stmt.condition)
        req = ["exists", cond_pe]
    }
    if k == "Assert" || k == "AssertStmt" {
        let pe = expr_to_proof_expr(stmt.left)
        req = ["assert", pe]
    }
    if k == "Invariant" {
        // parser uses .left for the expression (not .expr)
        let pe = expr_to_proof_expr(stmt.left)
        req = ["assert", pe]
    }
    if k == "CheckLaw" {
        req = ["check_law", stmt.n]
    }
    if type_of(req) != "string" && req.tag == TAG_VOID {
        return ["skipped", "unknown_proof_stmt_kind"]
    }
    // Delegate to host proof engine if available
    let host = call_builtin("__host_proof_check", [req])
    if host.tag != TAG_NOT_BUILTIN { return host }
    return ["skipped", "host runtime does not expose __host_proof_check"]
}

// ═══════════════════════════════════════════════════════════
//  Phase 8 골화 — fusion chain optimizer
//  src/interpreter.rs:11441 try_fuse_chain 대응
// ═══════════════════════════════════════════════════════════
//  arr.map(f).filter(g).sum() 같은 인접 체인을 single-pass
//  루프로 융합. terminal: map/filter/fold/sum/count/any/all/find.
//  실패/미적용은 sentinel tag="__not_fused__" 반환 → caller fallback.

fn fuse_sentinel() {
    return Val { tag: TAG_NOT_FUSED, int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn is_fuse_terminal(method) {
    if method == "map" { return true }
    if method == "filter" { return true }
    if method == "fold" { return true }
    if method == "sum" { return true }
    if method == "count" { return true }
    if method == "any" { return true }
    if method == "all" { return true }
    if method == "find" { return true }
    return false
}

fn try_fuse_chain(obj_expr, final_method, final_args) {
    if !is_fuse_terminal(final_method) { return fuse_sentinel() }
    // Walk the chain: collect (method, args) pairs, terminating at non-map/filter
    let mut ops_methods = [final_method]
    let mut ops_args = [final_args]
    let mut current = obj_expr
    let mut walking = true
    while walking {
        if type_of(current) == "string" { walking = false } else {
            // Defensive: parser may emit non-struct stub on syntax error
            if type_of(current) != "struct" && type_of(current) != "map" { walking = false } else {
                if current.kind == "Call" {
                    // parser AST stores callee in `left` field
                    let callee = current.left
                    if type_of(callee) != "string" && (callee.kind == "Field" || callee.kind == "OptField") {
                        let m = callee.name
                        if m == "map" || m == "filter" {
                            ops_methods = ops_methods.push(m)
                            ops_args = ops_args.push(current.args)
                            current = callee.left
                        } else { walking = false }
                    } else { walking = false }
                } else { walking = false }
            }
        }
    }
    if len(ops_methods) < 2 { return fuse_sentinel() }
    // Reverse to execution order (innermost first)
    let mut rev_methods = []
    let mut rev_args = []
    let mut ri = len(ops_methods) - 1
    while ri >= 0 {
        rev_methods = rev_methods.push(ops_methods[ri])
        rev_args = rev_args.push(ops_args[ri])
        ri = ri - 1
    }
    // Evaluate root
    let root = eval_expr(current)
    if root.tag != TAG_ARRAY { return fuse_sentinel() }
    let arr = get_array(root)
    // Evaluate closures (may be void for sum/count)
    let mut closures = []
    let mut ci = 0
    while ci < len(rev_methods) {
        let m = rev_methods[ci]
        if m == "sum" || m == "count" {
            closures = closures.push(val_void())
        } else {
            let aa = rev_args[ci]
            if len(aa) == 0 { return fuse_sentinel() }
            closures = closures.push(eval_expr(aa[0]))
        }
        ci = ci + 1
    }
    let last_method = rev_methods[len(rev_methods) - 1]
    let chain_len = len(rev_methods)
    // map/filter terminal → array result
    if last_method == "map" || last_method == "filter" {
        let mut result = []
        for item in arr {
            let mut val = item
            let mut keep = true
            let mut mi = 0
            while mi < chain_len && keep {
                let m = rev_methods[mi]
                let f = closures[mi]
                if m == "map" {
                    val = call_fn_val(f, [val])
                } else {
                    if m == "filter" {
                        let test = call_fn_val(f, [val])
                        if !is_truthy(test) { keep = false }
                    }
                }
                mi = mi + 1
            }
            if keep { result = result.push(val) }
        }
        return val_array(result)
    }
    // fold terminal: needs init + fn (skip last in chain loop, fold separately)
    if last_method == "fold" {
        let fold_args_raw = rev_args[chain_len - 1]
        if len(fold_args_raw) < 2 { return fuse_sentinel() }
        let mut acc = eval_expr(fold_args_raw[0])
        let fold_fn = eval_expr(fold_args_raw[1])
        for item in arr {
            let mut val = item
            let mut keep = true
            let mut mi = 0
            while mi < chain_len - 1 && keep {
                let m = rev_methods[mi]
                let f = closures[mi]
                if m == "map" { val = call_fn_val(f, [val]) }
                else { if m == "filter" {
                    let test = call_fn_val(f, [val])
                    if !is_truthy(test) { keep = false }
                } }
                mi = mi + 1
            }
            if keep { acc = call_fn_val(fold_fn, [acc, val]) }
        }
        return acc
    }
    // sum / count
    if last_method == "sum" {
        let mut int_sum = 0
        let mut has_float = false
        let mut float_sum = 0.0
        for item in arr {
            let mut val = item
            let mut keep = true
            let mut mi = 0
            while mi < chain_len - 1 && keep {
                let m = rev_methods[mi]
                let f = closures[mi]
                if m == "map" { val = call_fn_val(f, [val]) }
                else { if m == "filter" {
                    let test = call_fn_val(f, [val])
                    if !is_truthy(test) { keep = false }
                } }
                mi = mi + 1
            }
            if keep {
                if val.tag == TAG_FLOAT { has_float = true; float_sum = float_sum + val.float_val }
                else { int_sum = int_sum + val.int_val; float_sum = float_sum + val.int_val }
            }
        }
        if has_float { return val_float(float_sum) }
        return val_int(int_sum)
    }
    if last_method == "count" {
        let mut cnt = 0
        for item in arr {
            let mut val = item
            let mut keep = true
            let mut mi = 0
            while mi < chain_len - 1 && keep {
                let m = rev_methods[mi]
                let f = closures[mi]
                if m == "map" { val = call_fn_val(f, [val]) }
                else { if m == "filter" {
                    let test = call_fn_val(f, [val])
                    if !is_truthy(test) { keep = false }
                } }
                mi = mi + 1
            }
            if keep { cnt = cnt + 1 }
        }
        return val_int(cnt)
    }
    // any / all / find — predicate is final closure
    if last_method == "any" || last_method == "all" || last_method == "find" {
        let pred = closures[chain_len - 1]
        let is_any = (last_method == "any")
        let is_find = (last_method == "find")
        for item in arr {
            let mut val = item
            let mut keep = true
            let mut mi = 0
            while mi < chain_len - 1 && keep {
                let m = rev_methods[mi]
                let f = closures[mi]
                if m == "map" { val = call_fn_val(f, [val]) }
                else { if m == "filter" {
                    let test = call_fn_val(f, [val])
                    if !is_truthy(test) { keep = false }
                } }
                mi = mi + 1
            }
            if keep {
                let test = call_fn_val(pred, [val])
                if is_truthy(test) {
                    if is_find { return val }
                    if is_any { return val_bool(true) }
                } else {
                    if !is_any && !is_find { return val_bool(false) }
                }
            }
        }
        if is_any { return val_bool(false) }
        if is_find { return val_void() }
        return val_bool(true)
    }
    return fuse_sentinel()
}

// ── env_cache helpers (O(1) avg lookup) ───────────────────
// Hash a name into one of 64 buckets. Simple sum-of-char-codes mod 64;
// collisions are fine because each bucket is still linearly scanned,
// just over a much smaller set (~len(env_vars)/64).
fn env_hash(name) {
    let mut h = 0
    let mut i = 0
    let n = len(name)
    while i < n {
        h = h + char_code(name, i)
        i = i + 1
    }
    let mut b = h
    while b < 0 { b = b + 64 }
    return b % 64
}

pub let mut env_var_names = []   // parallel: binding names
pub let mut env_var_vals = []    // parallel: binding values
pub let mut env_cache_names = []   // list of 64 buckets; each bucket is [name, ...]
pub let mut env_cache_idxs = []    // list of 64 buckets; each bucket is [idx, ...]
fn env_cache_init() {
    // rt 32-E: init both parallel cache arrays (names, idxs). env_cache
    // retained as legacy len==64 sentinel checked by fallback branches.
    let mut names_buckets = []
    let mut idxs_buckets = []
    let mut legacy_buckets = []
    let mut i = 0
    while i < 64 {
        names_buckets = names_buckets.push([])
        idxs_buckets = idxs_buckets.push([])
        legacy_buckets = legacy_buckets.push([])
        i = i + 1
    }
    env_cache_names = names_buckets
    env_cache_idxs = idxs_buckets
    env_cache = legacy_buckets
}

// Rebuild cache from current env_vars. Fallback for cases where a
// cached snapshot is unavailable (e.g., interpret() reset, legacy paths).
fn env_rebuild_cache() {
    env_cache_init()
    let mut i = 0
    let n = len(env_var_names)
    while i < n {
        let nm = env_var_names[i]
        let b = env_hash(nm)
        env_cache_names[b] = env_cache_names[b].push(nm)
        env_cache_idxs[b] = env_cache_idxs[b].push(i)
        i = i + 1
    }
}

// ── O(1) fn_cache helpers (mirrors env_cache pattern) ────
// Reuse env_hash for bucket index — same 64-bucket, sum-of-char-codes scheme.

fn fn_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets = buckets.push([])
        i = i + 1
    }
    fn_cache = buckets
}

fn fn_cache_add(name, idx) {
    if len(fn_cache) != 64 { fn_cache_init() }
    let b = env_hash(name)
    fn_cache[b] = fn_cache[b].push([name, idx])
}

fn fn_rebuild_cache() {
    fn_cache_init()
    let mut i = 0
    let n = len(env_fns)
    while i < n {
        let entry = env_fns[i]
        let b = env_hash(entry[0])
        fn_cache[b] = fn_cache[b].push([entry[0], i])
        i = i + 1
    }
}

fn env_push_scope() {
    env_scopes = env_scopes.push(len(env_var_names))
    // rt 32: defer the per-scope `[]` allocation to env_define when actually
    // needed. ML hot loops (matvec inner col loop) push hundreds of scopes
    // with zero defines — pre-allocating a host array each time was a major
    // hexa_array_new contributor (~900K/d64 micro). Sentinel `0` marks
    // an empty scope; env_define lazy-converts to a real bucket list.
    env_scope_dirty = env_scope_dirty.push(0)
}

fn env_pop_scope() {
    let boundary = env_scopes[len(env_scopes) - 1]
    // bt 55 — in-place truncate replaces the rebuild-loop that leaked O(N)
    // per scope pop. truncate() shrinks .len without reallocating, retaining
    // capacity for amortized re-growth and releasing the old backing buffer
    // reference. `env_vars = env_vars.truncate(n)` pattern satisfies I1
    // (hexa lists pass-by-value) via reassignment.
    // Remove the last scope marker
    env_scopes = env_scopes.truncate(len(env_scopes) - 1)
    // rt 32: decref array/struct slots before truncating env_var_vals. Without
    // this the array_store freelist never reclaims slots (refcount stays
    // ≥ 1 even after the binding goes out of scope), defeating the slot
    // reuse optimization and leaking ~64 floats × N steps per matvec.
    let env_len = len(env_var_names)
    let mut _di = boundary
    while _di < env_len {
        let old_val = env_var_vals[_di]
        if old_val.tag == TAG_ARRAY {
            array_decref(old_val.int_val)
        }
        if old_val.tag == TAG_STRUCT {
            struct_decref(old_val.int_val)
        }
        _di = _di + 1
    }
    // Truncate parallel arrays to boundary
    env_var_names = env_var_names.truncate(boundary)
    env_var_vals = env_var_vals.truncate(boundary)
    // Prune cache: only scan buckets that were modified during this scope.
    // Dirty-tracking reduces O(64 + total_cache_entries) to O(dirty_buckets).
    let sdn = len(env_scope_dirty)
    if sdn > 0 {
        let dirty = env_scope_dirty[sdn - 1]
        // Pop the dirty set
        env_scope_dirty = env_scope_dirty.truncate(sdn - 1)
        // rt 32: sentinel `0` (int) means scope had no defines → no cache
        // pruning needed. Skips the entire dirty loop for empty scopes
        // (matvec/vec_gelu inner while bodies — hottest path).
        if type_of(dirty) != "int" {
            let mut _pdi = 0
            let dn = len(dirty)
            while _pdi < dn {
                let bi = dirty[_pdi]
                // rt 32-E: walk parallel (names, idxs) buckets; keep only
                // entries whose idx is still < boundary.
                let b_names = env_cache_names[bi]
                let b_idxs = env_cache_idxs[bi]
                let mut kept_names = []
                let mut kept_idxs = []
                let mut ki = 0
                let bn = len(b_idxs)
                while ki < bn {
                    let eidx = b_idxs[ki]
                    if eidx < boundary {
                        kept_names = kept_names.push(b_names[ki])
                        kept_idxs = kept_idxs.push(eidx)
                    }
                    ki = ki + 1
                }
                env_cache_names[bi] = kept_names
                env_cache_idxs[bi] = kept_idxs
                _pdi = _pdi + 1
            }
        }
    }
}

fn env_define(name, value) {
    // Perf #10/#11 COW: incref when array/struct value is bound to a new name.
    if value.tag == TAG_ARRAY {
        array_incref(value.int_val)
    }
    if value.tag == TAG_STRUCT {
        struct_incref(value.int_val)
    }
    // rt 32-E: parallel push — no `[name, value]` tuple alloc (-1 array_new,
    // -2 array_push per define; counting charges: was 1 push+2 push+1 push
    // for outer/inner/outer = 4 stat pushes, now just 2).
    let idx = len(env_var_names)
    env_var_names = env_var_names.push(name)
    env_var_vals = env_var_vals.push(value)
    // Lazily init cache on first define after reset.
    if len(env_cache_names) != 64 { env_cache_init() }
    let b = env_hash(name)
    // rt 32-E: parallel push to (names, idxs) bucket — no tuple alloc.
    env_cache_names[b] = env_cache_names[b].push(name)
    env_cache_idxs[b] = env_cache_idxs[b].push(idx)
    // Track dirty bucket in current scope (opt #8)
    let sdn = len(env_scope_dirty)
    if sdn > 0 {
        let top = env_scope_dirty[sdn - 1]
        // rt 32: lazy bucket — sentinel `0` (int) means empty.  Allocate the
        // real bucket list on first define in this scope.
        if type_of(top) == "int" {
            env_scope_dirty[sdn - 1] = [b]
        } else {
            // Avoid duplicate bucket entries in the dirty set
            let mut already = false
            let mut di = 0
            while di < len(top) {
                if top[di] == b { already = true }
                di = di + 1
            }
            if !already {
                env_scope_dirty[sdn - 1] = top.push(b)
            }
        }
    }
}

fn env_lookup(name) {
    // O(1) avg via bucket cache. Fall back to linear scan only if
    // cache is empty (e.g., right after wholesale env_vars swap that
    // forgot to rebuild — defensive).
    if len(env_cache_names) == 64 {
        let b = env_hash(name)
        let b_names = env_cache_names[b]
        let b_idxs = env_cache_idxs[b]
        // Pick entry with largest index (newest binding still in scope).
        let mut best = -1
        let mut bi = 0
        let bn = len(b_names)
        while bi < bn {
            if b_names[bi] == name {
                let ei = b_idxs[bi]
                if ei > best { best = ei }
            }
            bi = bi + 1
        }
        if best >= 0 && best < len(env_var_vals) {
            return env_var_vals[best]
        }
        return val_void()
    }
    // Fallback linear scan
    let mut i = len(env_var_names) - 1
    while i >= 0 {
        if env_var_names[i] == name {
            return env_var_vals[i]
        }
        i = i - 1
    }
    return val_void()
}

fn env_set(name, value) {
    // Perf #10/#11 COW: on reassignment, incref new array/struct value.
    if value.tag == TAG_ARRAY {
        array_incref(value.int_val)
    }
    if value.tag == TAG_STRUCT {
        struct_incref(value.int_val)
    }
    if len(env_cache_names) == 64 {
        let b = env_hash(name)
        let b_names = env_cache_names[b]
        let b_idxs = env_cache_idxs[b]
        let mut best = -1
        let mut bi = 0
        let bn = len(b_names)
        while bi < bn {
            if b_names[bi] == name {
                let ei = b_idxs[bi]
                if ei > best { best = ei }
            }
            bi = bi + 1
        }
        if best >= 0 && best < len(env_var_vals) {
            // Decref old value if it was an array or struct
            let old_val = env_var_vals[best]
            if old_val.tag == TAG_ARRAY {
                array_decref(old_val.int_val)
            }
            if old_val.tag == TAG_STRUCT {
                struct_decref(old_val.int_val)
            }
            env_var_vals[best] = value
            return true
        }
        return false
    }
    let mut i = len(env_var_names) - 1
    while i >= 0 {
        if env_var_names[i] == name {
            // Decref old value if it was an array or struct
            let old_val = env_var_vals[i]
            if old_val.tag == TAG_ARRAY {
                array_decref(old_val.int_val)
            }
            if old_val.tag == TAG_STRUCT {
                struct_decref(old_val.int_val)
            }
            env_var_vals[i] = value
            return true
        }
        i = i - 1
    }
    return false
}

// ── Core: eval_expr ──────────────────────────────────────

fn eval_expr_at(arr, idx) {
    // Defensive: parser may emit Str("") or non-struct stubs when recovering
    // from a syntax error. Bail out to void instead of crashing.
    let elem = arr[idx]
    if type_of(elem) == "string" { return val_void() }
    if type_of(elem) == "int" { return val_int(elem) }
    if type_of(elem) == "float" { return val_float(elem) }
    if type_of(elem) != "struct" && type_of(elem) != "map" { return val_void() }
    let k = elem.kind
    if type_of(k) != "string" { return val_void() }

    // Numeric dispatch for hot-path literals (int compare vs string compare)
    let kid = nk_cached_id(k)
    if kid == NK_INT_LIT { return val_int(arr[idx].value.parse_int()) }
    if kid == NK_FLOAT_LIT { return val_float(arr[idx].value.parse_float()) }
    if kid == NK_BOOL_LIT { return val_bool(arr[idx].value == "true") }
    if kid == NK_STRING_LIT { return val_str(arr[idx].value) }
    if kid == NK_CHAR_LIT { return val_str(arr[idx].value) }
    if kid == NK_IDENT { return env_lookup(arr[idx].name) }
    // For complex nodes, we need to extract children
    // This is OK because arr[idx].left gives a reference, not a deep copy
    return eval_expr_inner(arr[idx])
}

fn eval_expr(node) {
    // rt 32-E: eliminate the `let _tmp_arr = [node]` 1-element array that
    // every eval_expr call was creating (1 array_new + 1 push PER call).
    // d64 micro: ~8-10M eval_expr calls in matvec inner col loop alone.
    // eval_expr_inner already has identical fast-path literal dispatch;
    // direct forwarding is semantically equivalent and orders of magnitude
    // cheaper on the hot path.
    return eval_expr_inner(node)
}

pub let mut call_arg_buf = []
pub let mut call_arg_top = 0
fn eval_expr_inner(node) {
    // Defensive: parser may produce non-struct stub values when recovering
    // from a syntax error. Treat them as void to keep interpret() resilient.
    if type_of(node) == "string" { return val_void() }
    if type_of(node) == "int" { return val_int(node) }
    if type_of(node) == "float" { return val_float(node) }
    if type_of(node) != "struct" && type_of(node) != "map" { return val_void() }
    let k = node.kind
    if type_of(k) != "string" { return val_void() }

    // ── Numeric dispatch: convert kind string → int once, compare ints ──
    let kid = nk_cached_id(k)

    if kid == NK_INT_LIT { return val_int(node.value.parse_int()) }
    if kid == NK_FLOAT_LIT { return val_float(node.value.parse_float()) }
    if kid == NK_BOOL_LIT { return val_bool(node.value == "true") }
    if kid == NK_STRING_LIT { return val_str(node.value) }
    if kid == NK_CHAR_LIT { return val_str(node.value) }
    if kid == NK_IDENT { return env_lookup(node.name) }

    if kid == NK_BIN_OP {
        // ── is operator: v is int — type check without evaluating RHS ──
        if node.op == "is" {
            let lv = eval_expr(node.left)
            let type_name = node.right.name
            if type_name == "int" { return val_bool(lv.tag == TAG_INT) }
            if type_name == "float" { return val_bool(lv.tag == TAG_FLOAT) }
            if type_name == "str" || type_name == "string" { return val_bool(lv.tag == TAG_STR) }
            if type_name == "bool" { return val_bool(lv.tag == TAG_BOOL) }
            if type_name == "char" { return val_bool(lv.tag == TAG_CHAR) }
            if type_name == "array" { return val_bool(lv.tag == TAG_ARRAY) }
            if type_name == "map" { return val_bool(lv.tag == TAG_MAP) }
            if type_name == "fn" || type_name == "function" { return val_bool(lv.tag == TAG_FN) }
            if type_name == "void" { return val_bool(lv.tag == TAG_VOID) }
            if type_name == "struct" { return val_bool(lv.tag == TAG_STRUCT) }
            if type_name == "enum" { return val_bool(lv.tag == TAG_ENUM) }
            if type_name == "error" { return val_bool(lv.tag == TAG_ERROR) }
            // User-defined struct type name
            if lv.tag == TAG_STRUCT && lv.struct_name == type_name { return val_bool(true) }
            return val_bool(false)
        }
        // ── Pipe operator: x |> f  desugars to  f(x) ──
        if node.op == "|>" {
            let lv = eval_expr(node.left)
            if throw_flag || panic_flag { return val_void() }
            let rk = node.right.kind
            // x |> f(y)  =>  f(x, y)  — partial call, prepend left as first arg
            if rk == "Call" {
                // rt 32-B: reuse shared call_arg_buf (same stack-discipline as NK_CALL).
                let _ca_base = call_arg_top
                call_arg_buf = call_arg_buf.push_nostat(lv)
                call_arg_top = call_arg_top + 1
                let raw_args = node.right.args
                if type_of(raw_args) == "array" {
                    let mut _ai = 0
                    while _ai < len(raw_args) {
                        call_arg_buf = call_arg_buf.push_nostat(eval_expr_at(raw_args, _ai))
                        call_arg_top = call_arg_top + 1
                        if throw_flag || panic_flag {
                            call_arg_buf = call_arg_buf.truncate(_ca_base)
                            call_arg_top = _ca_base
                            return val_void()
                        }
                        _ai = _ai + 1
                    }
                }
                let call_args = call_arg_buf.slice_fast(_ca_base, call_arg_top)
                call_arg_buf = call_arg_buf.truncate(_ca_base)
                call_arg_top = _ca_base
                let callee = node.right.left
                if type_of(callee) != "string" && callee.kind == "Ident" {
                    let fname = callee.name
                    let user_info = find_fn(fname)
                    if user_info != "" { return call_user_fn(fname, call_args) }
                    let br = call_builtin(fname, call_args)
                    if br.tag != "__not_builtin__" { return br }
                    return call_user_fn(fname, call_args)
                }
                if type_of(callee) != "string" && callee.kind == "Field" {
                    let obj = eval_expr(callee.left)
                    let method = callee.name
                    return call_method(obj, method, call_args)
                }
                let callee_val = eval_expr(callee)
                if callee_val.tag == "fn" { return call_fn_val(callee_val, call_args) }
                return val_void()
            }
            // x |> f  =>  f(x)  — bare function name
            if rk == "Ident" {
                let fname = node.right.name
                let args = [lv]
                let user_info = find_fn(fname)
                if user_info != "" { return call_user_fn(fname, args) }
                let br = call_builtin(fname, args)
                if br.tag != "__not_builtin__" { return br }
                // Could be a closure/variable holding a fn value
                let fn_val = env_lookup(fname)
                if fn_val.tag == "fn" { return call_fn_val(fn_val, args) }
                return call_user_fn(fname, args)
            }
            // x |> (fn(a) { ... })  =>  lambda(x)
            if rk == "Lambda" {
                let rv = eval_expr(node.right)
                if rv.tag == "fn" { return call_fn_val(rv, [lv]) }
                return val_void()
            }
            // Fallback: evaluate right side and try to call it
            let rv = eval_expr(node.right)
            if rv.tag == "fn" { return call_fn_val(rv, [lv]) }
            println("Runtime error: pipe operator |> requires a function on the right side")
            return val_void()
        }
        let lv = eval_expr(node.left)
        let rv = eval_expr(node.right)
        return eval_binop(node.op, lv, rv)
    }

    // G24: Walrus operator :=  (assignment expression)
    // Evaluate RHS, bind to LHS name in current scope, return the value.
    if kid == NK_WALRUS {
        let val = eval_expr(node.right)
        env_define(node.name, val)
        return val
    }

    if kid == NK_UNARY_OP {
        // G37: typeof operator — returns type name as string
        if node.op == "typeof" {
            let v = eval_expr(node.left)
            let t = tag_name(v.tag)
            return val_str(t)
        }
        let v = eval_expr(node.left)
        if node.op == "-" {
            if v.tag == TAG_INT { return val_int(-v.int_val) }
            if v.tag == TAG_FLOAT { return val_float(-v.float_val) }
        }
        if node.op == "!" {
            return val_bool(!is_truthy(v))
        }
        // Bitwise NOT (ported from src/interpreter.rs eval_unary)
        if node.op == "~" {
            if v.tag == TAG_INT { return val_int(~v.int_val) }
        }
        return v
    }

    if kid == NK_ARRAY {
        let mut items = []
        for item in node.items {
            if type_of(item) != "string" && item.kind == "Spread" {
                let spread_val = eval_expr(item.left)
                if spread_val.tag == "array" {
                    let spread_items = get_array(spread_val)
                    let mut si = 0
                    while si < len(spread_items) {
                        items = items.push(spread_items[si])
                        si = si + 1
                    }
                } else {
                    items = items.push(spread_val)
                }
            } else {
                items = items.push(eval_expr(item))
            }
        }
        return val_array(items)
    }

    // List comprehension: [expr for var in iterable if cond]
    if kid == NK_LIST_COMP {
        let iter_val = eval_expr(node.iter_expr)
        let mut src_items = []
        if iter_val.tag == TAG_ARRAY {
            src_items = get_array(iter_val)
        } else if iter_val.tag == TAG_MAP {
            src_items = get_map_keys(iter_val)
        }
        let has_filter = type_of(node.cond) != "string"
        let mut result = []
        let mut _lci = 0
        while _lci < len(src_items) {
            env_push_scope()
            env_define(node.name, src_items[_lci])
            if has_filter {
                let cond_val = eval_expr(node.cond)
                if is_truthy(cond_val) {
                    result = result.push(eval_expr(node.left))
                }
            } else {
                result = result.push(eval_expr(node.left))
            }
            env_pop_scope()
            _lci = _lci + 1
        }
        return val_array(result)
    }

    if kid == NK_INDEX {
        // G13: array/string slicing — arr[start..end] or arr[start..=end]
        if type_of(node.right) != "string" && node.right.kind == "Range" {
            let arr_s = eval_expr(node.left)
            let s = eval_expr(node.right.left).int_val
            let e_raw = eval_expr(node.right.right).int_val
            // parser encodes inclusive/exclusive in node.value
            let inc = node.right.value == "inclusive"
            if arr_s.tag == TAG_ARRAY {
                let items = get_array(arr_s)
                let n = len(items)
                let mut e = e_raw
                if inc { e = e + 1 }
                if e > n { e = n }
                if s > e { return val_array([]) }
                let mut out = []
                let mut i = s
                while i < e {
                    out = out.push(items[i])
                    i = i + 1
                }
                return val_array(out)
            }
            if arr_s.tag == TAG_STR {
                let chars = arr_s.str_val.chars()
                let n = len(chars)
                let mut e = e_raw
                if inc { e = e + 1 }
                if e > n { e = n }
                if s > e { return val_str("") }
                let mut out = ""
                let mut i = s
                while i < e {
                    out = out + to_string(chars[i])
                    i = i + 1
                }
                return val_str(out)
            }
            return val_void()
        }
        // ── Perf #13: arr[i] fast path — Ident left avoids full clone ──
        // When left is a plain identifier, env_lookup returns the value
        // directly; we index into it without evaluating the whole sub-tree.
        let left_node = node.left
        let mut arr = val_void()
        if left_node.kind == "Ident" {
            arr = env_lookup(left_node.name)
        } else {
            arr = eval_expr(left_node)
        }
        let idx = eval_expr(node.right)
        if arr.tag == TAG_ARRAY {
            let items = get_array(arr)
            return items[idx.int_val]
        }
        if arr.tag == TAG_STR {
            let chars = arr.str_val.chars()
            return val_str(to_string(chars[idx.int_val]))
        }
        return val_void()
    }

    if kid == NK_CALL {
        // Inline Call handling (avoid struct copy issue with eval_call)
        // G8: spread args — `f(...args)` flattens array into arg list
        //
        // rt 32-B: reusable buffer. Stack-discipline on call_arg_buf:
        //   1) snapshot current top (= our base)
        //   2) push each evaluated arg via push_nostat (no stat counter bump)
        //   3) slice_fast(base, top) to get an independent copy for callee
        //   4) truncate call_arg_buf back to base (retains capacity)
        // This replaces the prior `let mut call_args = []` which was a
        // per-call hexa_array_new + N× hexa_array_push.
        let _ca_base = call_arg_top
        let raw_args = node.args
        if type_of(raw_args) == "array" {
            let mut _ai = 0
            while _ai < len(raw_args) {
                let arg_node = raw_args[_ai]
                if type_of(arg_node) != "string" && arg_node.kind == "Spread" {
                    let spread_val = eval_expr(arg_node.left)
                    if spread_val.tag == "array" {
                        let spread_items = get_array(spread_val)
                        let mut si = 0
                        while si < len(spread_items) {
                            call_arg_buf = call_arg_buf.push_nostat(spread_items[si])
                            call_arg_top = call_arg_top + 1
                            si = si + 1
                        }
                    } else {
                        call_arg_buf = call_arg_buf.push_nostat(spread_val)
                        call_arg_top = call_arg_top + 1
                    }
                } else {
                    call_arg_buf = call_arg_buf.push_nostat(eval_expr_at(raw_args, _ai))
                    call_arg_top = call_arg_top + 1
                }
                // Propagate throw from arg expression evaluation
                if throw_flag || panic_flag {
                    // Reset buffer top to base so stale partially-pushed args
                    // do not leak into the next NK_CALL on this thread.
                    call_arg_buf = call_arg_buf.truncate(_ca_base)
                    call_arg_top = _ca_base
                    return val_void()
                }
                _ai = _ai + 1
            }
        }
        // Hand the callee its own independent args buffer (single malloc+memcpy)
        // then release the scratch region on the shared accumulator.
        let call_args = call_arg_buf.slice_fast(_ca_base, call_arg_top)
        call_arg_buf = call_arg_buf.truncate(_ca_base)
        call_arg_top = _ca_base
        let callee = node.left
        // Enum variant constructor call: Name::Variant(args...)
        if type_of(callee) != "string" && callee.kind == "EnumPath" {
            if len(call_args) == 0 {
                return val_enum(callee.name, callee.value, "")
            }
            if len(call_args) == 1 {
                return val_enum(callee.name, callee.value, call_args[0])
            }
            return val_enum(callee.name, callee.value, val_array(call_args))
        }
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let fname = callee.name
            // User function takes precedence over builtin (allows shadowing)
            let user_info = find_fn(fname)
            if user_info != "" { return call_user_fn(fname, call_args) }
            let br = call_builtin(fname, call_args)
            if br.tag != TAG_NOT_BUILTIN { return br }
            return call_user_fn(fname, call_args)
        }
        if type_of(callee) != "string" && (callee.kind == "Field" || callee.kind == "OptField") {
            // Optional chaining: if callee is OptField and receiver is void, short-circuit
            let is_opt_call = callee.kind == "OptField"
            // Effect call: if receiver is an Ident naming a registered effect,
            // route to eval_effect_call. effect_def_lookup returns either a
            // host array (of op names) or val_void() on miss.
            if type_of(callee.left) != "string" && callee.left.kind == "Ident" {
                let recv_name = callee.left.name
                let ops_or_void = effect_def_lookup(recv_name)
                if type_of(ops_or_void) == "array" {
                    return eval_effect_call(recv_name, callee.name, call_args)
                }
            }
            // ── Phase 8 골화: fusion chain 시도 ──
            // src/interpreter.rs:11441 try_fuse_chain 동치.
            // map/filter/fold/sum/count/any/all/find의 인접 체인을
            // single-pass 루프로 병합. 미스매치 시 fallback.
            let fuse_result = try_fuse_chain(callee.left, callee.name, node.args)
            if fuse_result.tag != TAG_NOT_FUSED { return fuse_result }

            let obj = eval_expr(callee.left)
            // Optional chaining short-circuit: obj?.method() → void when obj is void
            if is_opt_call && obj.tag == "void" { return val_void() }
            let method = callee.name
            let result = call_method(obj, method, call_args)
            // In-place mutation: if receiver is a plain Ident and method is a mutator,
            // write the new array back into the variable slot.
            if type_of(callee.left) != "string" && callee.left.kind == "Ident" {
                if obj.tag == TAG_ARRAY && result.tag == TAG_ARRAY {
                    if method == "push" || method == "pop" {
                        env_set(callee.left.name, result)
                    }
                }
            }
            return result
        }
        let callee_val = eval_expr(callee)
        if callee_val.tag == TAG_FN { return call_fn_val(callee_val, call_args) }
        return val_void()
    }

    // Optional chaining: obj?.field — return void if obj is void
    if kid == NK_OPT_FIELD {
        // ── Perf #14b: Ident fast path for optional chaining ──
        let left_oc = node.left
        let mut obj = val_void()
        if left_oc.kind == "Ident" {
            obj = env_lookup(left_oc.name)
        } else {
            obj = eval_expr(left_oc)
        }
        if obj.tag == TAG_VOID { return val_void() }
        let field = node.name
        if obj.tag == TAG_STRUCT {
            let fields = get_struct_fields(obj)
            return fields[field]
        }
        return val_void()
    }

    if kid == NK_FIELD {
        // ── Perf #14: obj.field fast path — Ident left skips eval dispatch ──
        let left_f = node.left
        let mut obj = val_void()
        if left_f.kind == "Ident" {
            obj = env_lookup(left_f.name)
        } else {
            obj = eval_expr(left_f)
        }
        let field = node.name
        // Method call is handled in eval_call
        // Field access on struct
        if obj.tag == TAG_STRUCT {
            let fields = get_struct_fields(obj)
            return fields[field]
        }
        // T25 fix: EnumName.Variant — when left is an Ident that names a
        // registered enum and obj lookup returned void, produce enum value.
        if obj.tag == TAG_VOID && left_f.kind == "Ident" {
            if enum_decls_has_variant(left_f.name, field) {
                return val_enum(left_f.name, field, "")
            }
        }
        return val_void()
    }

    if kid == NK_IF_EXPR {
        let cond = eval_expr(node.cond)
        if is_truthy(cond) {
            return eval_block(node.then_body)
        }
        if node.else_body != "" {
            return eval_block(node.else_body)
        }
        return val_void()
    }

    // G32: if let PATTERN = EXPR { body } else { alt }
    if k == "IfLetExpr" {
        let pattern = node.left
        let scrutinee = eval_expr(node.right)
        // rt 32-E: snapshot parallel env arrays
        let saved_env_names = env_var_names
        let saved_env_vals = env_var_vals
        let saved_env_scopes = env_scopes
        env_push_scope()
        if match_pattern(pattern, scrutinee) {
            let result = eval_body(node.then_body)
            env_pop_scope()
            env_var_names = saved_env_names
            env_var_vals = saved_env_vals
            env_scopes = saved_env_scopes
            env_rebuild_cache()
            if return_flag { return return_val }
            return result
        }
        env_pop_scope()
        env_var_names = saved_env_names
        env_var_vals = saved_env_vals
        env_scopes = saved_env_scopes
        env_rebuild_cache()
        if node.else_body != "" { return eval_block(node.else_body) }
        return val_void()
    }

    if kid == NK_LAMBDA {
        // Capture current environment for closure
        // rt 32-E: captured still uses [name,value] tuples (read by
        // val_closure and call_fn_val which unpack with snap[0]/snap[1]).
        let mut captured = []
        let mut ci = 0
        while ci < len(env_var_names) {
            captured = captured.push([env_var_names[ci], env_var_vals[ci]])
            ci = ci + 1
        }
        return val_closure("__lambda__", node.params, node.left, captured)
    }

    if kid == NK_MAP_LIT {
        let mut keys = []
        let mut values = []
        let entries = node.items
        let mut mi = 0
        while mi < len(entries) {
            let entry = entries[mi]
            keys = keys.push(eval_expr(entry.left))
            values = values.push(eval_expr(entry.right))
            mi = mi + 1
        }
        return val_map(keys, values)
    }

    // Slice: arr[1:3], arr[:3], arr[2:], str[1:3]
    if k == "Slice" {
        let obj = eval_expr(node.left)
        let mut s = 0
        let mut e = 0
        if obj.tag == TAG_ARRAY {
            let items = get_array(obj)
            e = len(items)
            if node.right != "" { s = eval_expr(node.right).int_val }
            if node.cond != "" { e = eval_expr(node.cond).int_val }
            if s < 0 { s = 0 }
            if e > len(items) { e = len(items) }
            let mut result = []
            let mut si = s
            while si < e { result = result.push(items[si]); si = si + 1 }
            return val_array(result)
        }
        if obj.tag == TAG_STR {
            e = len(obj.str_val)
            if node.right != "" { s = eval_expr(node.right).int_val }
            if node.cond != "" { e = eval_expr(node.cond).int_val }
            return val_str(obj.str_val.substring(s, e))
        }
        return val_void()
    }

    if kid == NK_RANGE {
        let start = eval_expr(node.left)
        let end_val = eval_expr(node.right)
        // G21: step range — use cond field for step value
        let mut step = 1
        if node.cond != "" { step = eval_expr(node.cond).int_val }
        if step <= 0 { step = 1 }
        let mut items = []
        let mut ri = start.int_val
        if node.value == "inclusive" {
            while ri <= end_val.int_val {
                items = items.push(val_int(ri))
                ri = ri + step
            }
        } else {
            while ri < end_val.int_val {
                items = items.push(val_int(ri))
                ri = ri + step
            }
        }
        return val_array(items)
    }

    if kid == NK_ASSIGN {
        let val = eval_expr(node.right)
        if node.left.kind == "Ident" {
            env_set(node.left.name, val)
        }
        if node.left.kind == "Index" {
            let arr = eval_expr(node.left.left)
            let idx = eval_expr(node.left.right)
            if arr.tag == TAG_ARRAY {
                let items = get_array(arr)
                let mut new_items = []
                let mut ai = 0
                while ai < len(items) {
                    if ai == idx.int_val {
                        new_items = new_items.push(val)
                    } else {
                        new_items = new_items.push(items[ai])
                    }
                    ai = ai + 1
                }
                // Update array store in-place
                array_store[arr.int_val] = new_items
            }
        }
        // Perf #11: struct field assignment — obj.field = val
        // Uses COW: if the struct is shared, copy before mutating.
        if node.left.kind == "Field" {
            let obj = eval_expr(node.left.left)
            if obj.tag == TAG_STRUCT {
                let field_name = node.left.name
                let updated = set_struct_field(obj, field_name, val)
                // Write back to the variable if the receiver is an Ident
                if type_of(node.left.left) != "string" && node.left.left.kind == "Ident" {
                    env_set(node.left.left.name, updated)
                }
            }
        }
        return val
    }

    if kid == NK_TUPLE_LIT {
        let mut items = []
        for item in node.items {
            items = items.push(eval_expr(item))
        }
        return val_array(items)
    }

    // ── StructInit: Name { field: val, ... } ────────────────
    if kid == NK_STRUCT_INIT {
        let sname = node.name
        let field_inits = node.fields
        let mut field_map = #{}
        let mut si = 0
        while si < len(field_inits) {
            let fi = field_inits[si]
            let fname = fi.name
            let fval = eval_expr(fi.left)
            field_map[fname] = fval
            si = si + 1
        }
        return val_struct(sname, field_map)
    }

    // ── EnumPath: EnumName::Variant or EnumName::Variant(data) ──
    if kid == NK_ENUM_PATH {
        let data = node.left
        let mut data_val = ""
        if type_of(data) != "string" || data != "" {
            data_val = eval_expr(data)
        }
        return val_enum(node.name, node.value, data_val)
    }

    // ── ThrowExpr: throw as expression (returns void, sets throw_flag) ──
    if kid == NK_THROW_EXPR || kid == NK_THROW_STMT {
        let err = eval_expr(node.left)
        exec_throw(err)
        return val_void()
    }

    // ═══════════════════════════════════════════════════════
    //  Phase 10 골화 — 추가 expression kinds
    // ═══════════════════════════════════════════════════════

    // Block expression: { stmts; final_expr }
    if kid == NK_BLOCK || kid == NK_BLOCK_EXPR {
        return eval_block(node.body)
    }

    // Tuple expression: (a, b, c) — represented as array of evaluated elements
    if kid == NK_TUPLE || kid == NK_TUPLE_EXPR {
        let mut items = []
        if type_of(node.elements) == "array" {
            for e in node.elements { items = items.push(eval_expr(e)) }
        }
        return val_array(items)
    }

    // HandleWith: handle { body } with { eff.op(...) -> ... }
    //   Note: AST stores effect name in `name` field (not `effect`, which is a keyword)
    if kid == NK_HANDLE_WITH {
        let mut entries = []
        if type_of(node.handlers) == "array" {
            for h in node.handlers {
                let key = h.name + "." + h.op
                entries = entries.push([key, h.params, h.body])
            }
        }
        effect_handler_push(entries)
        let result = eval_expr(node.body)
        effect_handler_pop()
        return result
    }

    // EffectCall: eff.op(args) — AST uses `name` for effect identifier
    if kid == NK_EFFECT_CALL {
        let mut eargs = []
        if type_of(node.args) == "array" {
            for a in node.args { eargs = eargs.push(eval_expr(a)) }
        }
        return eval_effect_call(node.name, node.op, eargs)
    }

    // Resume: inside an effect handler, set the resume value (parser: .left)
    if kid == NK_RESUME || kid == NK_RESUME_EXPR {
        let v = eval_expr(node.left)
        resume_value = v
        resume_set = true
        return val_void()
    }

    // Comptime expression: evaluate at compile time (here just eval normally)
    if kid == NK_COMPTIME || kid == NK_COMPTIME_EXPR {
        return eval_expr(node.expr)
    }

    // Template / string interpolation: concatenate parts
    //   parts: array of {kind: "lit", value} | {kind: "expr", expr}
    if kid == NK_TEMPLATE || kid == NK_TEMPLATE_EXPR || kid == NK_INTERP_STR {
        let mut out = ""
        if type_of(node.parts) == "array" {
            for p in node.parts {
                if type_of(p) == "string" {
                    out = out + p
                } else {
                    if p.kind == "lit" || p.kind == "StringLit" { out = out + p.value }
                    else { out = out + val_to_string(eval_expr(p.expr)) }
                }
            }
        }
        return val_str(out)
    }

    // Wildcard / ArrayPattern: only meaningful in patterns; in expr context yields void
    if kid == NK_WILDCARD || kid == NK_ARRAY_PATTERN {
        return val_void()
    }

    // Own / Move / Borrow: ownership annotations have no runtime effect
    if kid == NK_OWN || kid == NK_MOVE || kid == NK_MOVE_EXPR || kid == NK_BORROW || kid == NK_BORROW_EXPR {
        return eval_expr(node.expr)
    }

    // Await: in single-thread interpreter, await is identity (already-resolved)
    if kid == NK_AWAIT || kid == NK_AWAIT_EXPR {
        let v = eval_expr(node.expr)
        // If it's a future struct, extract value; else passthrough
        if v.tag == TAG_STRUCT && v.struct_name == "Future" {
            let fields = get_struct_fields(v)
            if type_of(fields) == "map" { return map_get(fields, val_str("value")) }
        }
        return v
    }

    // DynCast: trait object dispatch (.hexa interp doesn't track trait impls
    //   strongly; passthrough the value tagged with trait_name)
    if kid == NK_DYN_CAST || kid == NK_DYN_CAST_EXPR {
        return eval_expr(node.expr)
    }

    // MacroInvoc: macros are pre-expanded by parser; if seen here, treat
    //   as a tagged Call to a function with the same name
    if kid == NK_MACRO_INVOC || kid == NK_MACRO_INVOCATION {
        let mut margs = []
        if type_of(node.args) == "array" {
            for a in node.args { margs = margs.push(eval_expr(a)) }
        }
        return call_user_fn(node.name, margs)
    }

    // TryCatch as expression
    if kid == NK_TRY_CATCH_EXPR || kid == NK_TRY_CATCH {
        let try_body = node.try_body
        let catch_var = node.catch_var
        let catch_body = node.catch_body
        env_push_scope()
        let result = eval_body(try_body)
        env_pop_scope()
        if throw_flag {
            let caught = throw_val
            throw_flag = false
            throw_val = val_void()
            env_push_scope()
            if type_of(catch_var) == "string" && catch_var != "" {
                env_define(catch_var, caught)
            }
            let cresult = eval_body(catch_body)
            env_pop_scope()
            return cresult
        }
        return result
    }

    // ── MatchExpr: match expr { pattern -> body, ... } ──────
    if kid == NK_MATCH_EXPR {
        let scrutinee = eval_expr(node.left)
        let arms = node.arms
        let mut mi = 0
        while mi < len(arms) {
            let arm = arms[mi]
            let pattern = arm.left
            let arm_body = arm.body
            let guard = arm.cond
            // Save env state before each arm — explicit snapshot ensures
            // pattern bindings never leak to the parent scope, even if
            // env_push/pop_scope is defeated by nested calls.
            // rt 32-E: snapshot parallel arrays instead of tuple env_vars
            let saved_env_names = env_var_names
            let saved_env_vals = env_var_vals
            let saved_env_scopes = env_scopes
            let saved_env_cache_names = env_cache_names
            let saved_env_cache_idxs = env_cache_idxs
            let saved_env_dirty = env_scope_dirty
            env_push_scope()
            if match_pattern(pattern, scrutinee) {
                // Check guard clause if present
                let mut guard_ok = true
                if type_of(guard) != "string" || guard != "" {
                    let gv = eval_expr(guard)
                    guard_ok = is_truthy(gv)
                }
                if guard_ok {
                    let result = eval_body(arm_body)
                    env_pop_scope()
                    // Restore env to pre-match state — O(1) swap, no rebuild
                    env_var_names = saved_env_names
                    env_var_vals = saved_env_vals
                    env_scopes = saved_env_scopes
                    env_cache_names = saved_env_cache_names
                    env_cache_idxs = saved_env_cache_idxs
                    env_scope_dirty = saved_env_dirty
                    if return_flag {
                        return return_val
                    }
                    return result
                }
            }
            env_pop_scope()
            // Restore env to pre-match state for failed arms too — O(1)
            env_var_names = saved_env_names
            env_var_vals = saved_env_vals
            env_scopes = saved_env_scopes
            env_cache_names = saved_env_cache_names
            env_cache_idxs = saved_env_cache_idxs
            env_scope_dirty = saved_env_dirty
            mi = mi + 1
        }
        return val_void()
    }

    return val_void()
}

// ── Binary operations ────────────────────────────────────

fn eval_binop(op, a, b) {
    // ── Numeric operator dispatch: convert op string → int once ──
    let oid = op_cached_id(op)

    // Null coalescing: a ?? b → if a is void or empty string, return b
    if oid == OP_NULL_COAL {
        if a.tag == TAG_VOID { return b }
        if a.tag == TAG_STR && a.str_val == "" { return b }
        return a
    }

    // in operator: x in arr / key in map / sub in str
    if oid == OP_IN {
        if b.tag == TAG_ARRAY {
            let items = get_array(b)
            let mut _ii = 0
            while _ii < len(items) {
                if vals_equal(a, items[_ii]) { return val_bool(true) }
                _ii = _ii + 1
            }
            return val_bool(false)
        }
        if b.tag == TAG_MAP {
            return val_bool(map_contains_key(b, a.str_val))
        }
        if b.tag == TAG_STR && a.tag == TAG_STR {
            return val_bool(b.str_val.contains(a.str_val))
        }
        return val_bool(false)
    }

    // Int fast path
    if a.tag == TAG_INT && b.tag == TAG_INT {
        let x = a.int_val
        let y = b.int_val
        if oid == OP_ADD { return val_int(x + y) }
        if oid == OP_SUB { return val_int(x - y) }
        if oid == OP_MUL { return val_int(x * y) }
        if oid == OP_DIV {
            if y == 0 { println("runtime error: division by zero"); return val_void() }
            return val_int(x / y)
        }
        if oid == OP_MOD {
            if y == 0 { println("runtime error: division by zero"); return val_void() }
            return val_int(x % y)
        }
        if oid == OP_POW { return val_int(pow(x, y)) }
        if oid == OP_EQ { return val_bool(x == y) }
        if oid == OP_NE { return val_bool(x != y) }
        if oid == OP_LT { return val_bool(x < y) }
        if oid == OP_GT { return val_bool(x > y) }
        if oid == OP_LE { return val_bool(x <= y) }
        if oid == OP_GE { return val_bool(x >= y) }
        if oid == OP_AND { return val_bool(x != 0 && y != 0) }
        if oid == OP_OR { return val_bool(x != 0 || y != 0) }
        // Bitwise operations (ported from src/interpreter.rs eval_binary)
        if oid == OP_BIT_AND {
            let r = x & y
            return val_int(r)
        }
        if oid == OP_BIT_OR {
            // NOTE: x | y triggers parser lambda-ambiguity inside parens,
            // so we use the identity: x|y = (x+y) - (x&y)
            let r = (x + y) - (x & y)
            return val_int(r)
        }
        if oid == OP_BIT_XOR {
            let r = x ^ y
            return val_int(r)
        }
        if oid == OP_SHL {
            // x << y = x * 2^y (avoiding << parser issues)
            let r = x * pow(2, y)
            return val_int(r)
        }
        if oid == OP_SHR {
            // x >> y = x / 2^y (avoiding >> parser issues)
            let r = x / pow(2, y)
            return val_int(r)
        }
    }
    // String concatenation (str + anything)
    if a.tag == TAG_STR && oid == OP_ADD {
        return val_str(a.str_val + val_to_string(b))
    }
    // Char + String / Char + Char concatenation
    if a.tag == TAG_CHAR && oid == OP_ADD {
        return val_str(a.str_val + val_to_string(b))
    }
    // Float arithmetic (with int-to-float coercion)
    if (a.tag == TAG_FLOAT || b.tag == TAG_FLOAT) {
        let x = to_float(a)
        let y = to_float(b)
        if oid == OP_ADD { return val_float(x + y) }
        if oid == OP_SUB { return val_float(x - y) }
        if oid == OP_MUL { return val_float(x * y) }
        if oid == OP_DIV {
            if y == 0.0 { println("runtime error: division by zero"); return val_void() }
            return val_float(x / y)
        }
        if oid == OP_MOD { return val_float(x % y) }
        if oid == OP_POW { return val_float(pow(x, y)) }
        if oid == OP_EQ { return val_bool(x == y) }
        if oid == OP_NE { return val_bool(x != y) }
        if oid == OP_LT { return val_bool(x < y) }
        if oid == OP_GT { return val_bool(x > y) }
        if oid == OP_LE { return val_bool(x <= y) }
        if oid == OP_GE { return val_bool(x >= y) }
    }
    // Bool operations
    if a.tag == TAG_BOOL && b.tag == TAG_BOOL {
        if oid == OP_EQ { return val_bool(a.bool_val == b.bool_val) }
        if oid == OP_NE { return val_bool(a.bool_val != b.bool_val) }
        if oid == OP_AND { return val_bool(a.bool_val && b.bool_val) }
        if oid == OP_OR { return val_bool(a.bool_val || b.bool_val) }
        if oid == OP_BIT_XOR { return val_bool(a.bool_val != b.bool_val) }
    }
    // String comparisons
    if a.tag == TAG_STR && b.tag == TAG_STR {
        if oid == OP_EQ { return val_bool(a.str_val == b.str_val) }
        if oid == OP_NE { return val_bool(a.str_val != b.str_val) }
    }
    // Char comparisons
    if a.tag == TAG_CHAR && b.tag == TAG_CHAR {
        if oid == OP_EQ { return val_bool(a.str_val == b.str_val) }
        if oid == OP_NE { return val_bool(a.str_val != b.str_val) }
        if oid == OP_LT { return val_bool(a.str_val < b.str_val) }
        if oid == OP_GT { return val_bool(a.str_val > b.str_val) }
        if oid == OP_LE { return val_bool(a.str_val <= b.str_val) }
        if oid == OP_GE { return val_bool(a.str_val >= b.str_val) }
    }
    // Array concatenation (ported from src/interpreter.rs)
    if a.tag == TAG_ARRAY && b.tag == TAG_ARRAY && oid == OP_ADD {
        let a_items = get_array(a)
        let b_items = get_array(b)
        let mut result = []
        for item in a_items { result = result.push(item) }
        for item in b_items { result = result.push(item) }
        return val_array(result)
    }
    // Array repetition: [1,2] * 3 => [1,2,1,2,1,2]
    if a.tag == TAG_ARRAY && b.tag == TAG_INT && oid == OP_MUL {
        let items = get_array(a)
        let n = b.int_val
        let mut result = []
        let mut ri = 0
        while ri < n {
            for item in items { result = result.push(item) }
            ri = ri + 1
        }
        return val_array(result)
    }
    // Array equality
    if a.tag == TAG_ARRAY && b.tag == TAG_ARRAY {
        if oid == OP_EQ {
            let a_items = get_array(a)
            let b_items = get_array(b)
            if len(a_items) != len(b_items) { return val_bool(false) }
            let mut ei = 0
            while ei < len(a_items) {
                if !vals_equal(a_items[ei], b_items[ei]) { return val_bool(false) }
                ei = ei + 1
            }
            return val_bool(true)
        }
        if oid == OP_NE {
            let eq = eval_binop("==", a, b)
            return val_bool(!eq.bool_val)
        }
    }
    // 'in' operator: a in b — membership test
    if op == "in" {
        if b.tag == "array" {
            let items = get_array(b)
            let mut ii = 0
            while ii < len(items) {
                if vals_equal(a, items[ii]) { return val_bool(true) }
                ii = ii + 1
            }
            return val_bool(false)
        }
        if b.tag == "map" {
            return val_bool(map_contains_key(b, a))
        }
        if b.tag == "str" {
            if a.tag == "str" { return val_bool(b.str_val.contains(a.str_val)) }
            if a.tag == "char" { return val_bool(b.str_val.contains(a.str_val)) }
            return val_bool(false)
        }
        return val_bool(false)
    }
    // Cross-type Eq/Ne: different value types are never equal
    if oid == OP_EQ { return val_bool(false) }
    if oid == OP_NE { return val_bool(true) }
    return val_void()
}

// ── Value equality (for pattern matching) ───────────────

fn vals_equal(a, b) {
    if a.tag != b.tag { return false }
    if a.tag == TAG_INT { return a.int_val == b.int_val }
    if a.tag == TAG_FLOAT { return a.float_val == b.float_val }
    if a.tag == TAG_BOOL { return a.bool_val == b.bool_val }
    if a.tag == TAG_STR { return a.str_val == b.str_val }
    if a.tag == TAG_ENUM { return a.struct_name == b.struct_name && a.int_val == b.int_val }
    if a.tag == TAG_VOID { return true }
    return false
}

// ── Pattern matching ────────────────────────────────────

fn match_pattern(pattern, value) {
    let pk = pattern.kind
    // Wildcard _ matches anything
    if pk == "Wildcard" { return true }
    // Integer literal pattern
    if pk == "IntLit" {
        if value.tag == TAG_INT { return value.int_val == to_int(pattern.value) }
        return false
    }
    // String literal pattern
    if pk == "StringLit" {
        if value.tag == TAG_STR { return value.str_val == pattern.value }
        return false
    }
    // Bool literal pattern
    if pk == "BoolLit" {
        if value.tag == TAG_BOOL { return value.bool_val == (pattern.value == "true") }
        return false
    }
    // Float literal pattern
    if pk == "FloatLit" {
        if value.tag == TAG_FLOAT { return value.float_val == to_float(pattern.value) }
        return false
    }
    // Negative literal pattern: -1, -3.14 etc.
    if pk == "UnaryOp" && pattern.op == "-" {
        let inner = pattern.left
        if inner.kind == "IntLit" {
            if value.tag == TAG_INT { return value.int_val == -to_int(inner.value) }
            return false
        }
        if inner.kind == "FloatLit" {
            if value.tag == TAG_FLOAT { return value.float_val == -to_float(inner.value) }
            return false
        }
        return false
    }
    // EnumPath pattern: EnumName::Variant or EnumName::Variant(binding)
    if pk == "EnumPath" {
        if value.tag != TAG_ENUM { return false }
        // Match variant name
        let expected = pattern.name + "::" + pattern.value
        if value.struct_name != expected { return false }
        // If pattern has data binding, bind it
        let data_pattern = pattern.left
        let multi_pats = pattern.items
        if type_of(multi_pats) == "array" && len(multi_pats) > 0 {
            // Multi-field variant: value data must be array
            let data_val = get_enum_data(value)
            if data_val.tag != TAG_ARRAY { return false }
            let ditems = get_array(data_val)
            if len(ditems) != len(multi_pats) { return false }
            let mut mp = 0
            while mp < len(multi_pats) {
                let sub = multi_pats[mp]
                if type_of(sub) != "string" && sub.kind == "Ident" {
                    env_define(sub.name, ditems[mp])
                } else {
                    if !match_pattern(sub, ditems[mp]) { return false }
                }
                mp = mp + 1
            }
            return true
        }
        if type_of(data_pattern) != "string" || data_pattern != "" {
            let data_val = get_enum_data(value)
            // If data pattern is an Ident, bind it
            if data_pattern.kind == "Ident" {
                env_define(data_pattern.name, data_val)
            } else {
                // Literal data pattern — must match
                return match_pattern(data_pattern, data_val)
            }
        }
        return true
    }
    // Call pattern: Some(x), Ok(x), Err(x) — shorthand enum constructors
    if pk == "Call" {
        let callee = pattern.left
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let ctor = callee.name
            let mut enum_name = ""
            let mut variant_name = ""
            if ctor == "Some" { enum_name = "Option"; variant_name = "Some" }
            if ctor == "Ok" { enum_name = "Result"; variant_name = "Ok" }
            if ctor == "Err" { enum_name = "Result"; variant_name = "Err" }
            if enum_name != "" {
                // Must be an enum value matching this constructor
                if value.tag != TAG_ENUM { return false }
                let expected = enum_name + "::" + variant_name
                if value.struct_name != expected { return false }
                // Bind the data argument if present
                let call_args = pattern.args
                if type_of(call_args) == "array" && len(call_args) == 1 {
                    let data_val = get_enum_data(value)
                    let arg_pat = call_args[0]
                    if type_of(arg_pat) != "string" && arg_pat.kind == "Ident" {
                        env_define(arg_pat.name, data_val)
                        return true
                    }
                    // Nested pattern match on data
                    return match_pattern(arg_pat, data_val)
                }
                // No args — match variant with no data
                if type_of(call_args) != "array" || len(call_args) == 0 {
                    if get_enum_data(value).tag == TAG_VOID { return true }
                }
                return false
            }
        }
        // Not a known constructor — evaluate and compare
        let pattern_val = eval_expr(pattern)
        return vals_equal(pattern_val, value)
    }
    // Array/tuple pattern: [a, b, c]
    if pk == "Array" {
        if value.tag != TAG_ARRAY { return false }
        let items = get_array(value)
        let pats = pattern.items
        if type_of(pats) != "array" { return false }
        if len(pats) != len(items) { return false }
        let mut pi = 0
        while pi < len(pats) {
            if !match_pattern(pats[pi], items[pi]) { return false }
            pi = pi + 1
        }
        return true
    }
    // Identifier pattern: check for known enum constant, otherwise variable binding
    if pk == "Ident" {
        let name = pattern.name
        // Check if it's a known enum constant (e.g., None)
        // rt 32-E: parallel arrays lookup
        let mut ei = len(env_var_names) - 1
        while ei >= 0 {
            if env_var_names[ei] == name {
                let existing = env_var_vals[ei]
                if existing.tag == TAG_ENUM {
                    // Compare enum values
                    return vals_equal(existing, value)
                }
                // Not an enum — treat as binding below
                ei = -1
            } else {
                ei = ei - 1
            }
        }
        // Bind as variable
        env_define(name, value)
        return true
    }
    // Fallback: evaluate pattern as expression and compare
    let pattern_val = eval_expr(pattern)
    return vals_equal(pattern_val, value)
}

// ── Error handling helpers ────────────────────────────────

fn exec_throw(err) {
    // Attach stack trace to all thrown values
    if err.tag == TAG_STR {
        let mut keys = [val_str("message"), val_str("trace")]
        let mut values = [err, val_str(format_stack_trace())]
        throw_val = val_map(keys, values)
    } else if err.tag == TAG_MAP {
        // If already a map, add trace field if missing
        let keys = get_map_keys(err)
        let values = get_map_values(err)
        let mut has_trace = false
        let mut ki = 0
        while ki < len(keys) {
            if keys[ki].tag == TAG_STR && keys[ki].str_val == "trace" {
                has_trace = true
            }
            ki = ki + 1
        }
        if !has_trace {
            let new_keys = keys.push(val_str("trace"))
            let new_vals = values.push(val_str(format_stack_trace()))
            throw_val = val_map(new_keys, new_vals)
        } else {
            throw_val = err
        }
    } else {
        throw_val = err
    }
    throw_flag = true
}

fn exec_try_catch(try_body, catch_var, catch_body) {
    // Save throw state
    let saved_throw = throw_flag
    throw_flag = false

    // Execute try body
    env_push_scope()
    let mut ti = 0
    while ti < len(try_body) {
        if return_flag || throw_flag || panic_flag { ti = len(try_body) } else {
            exec_stmt_at(try_body, ti)
            ti = ti + 1
        }
    }
    env_pop_scope()

    // Panic is not catchable — propagate immediately.
    if panic_flag { return val_void() }

    if throw_flag {
        // Error was thrown — execute catch body
        let err = throw_val
        throw_flag = false
        throw_val = val_void()
        env_push_scope()
        env_define(catch_var, err)
        let mut ci = 0
        while ci < len(catch_body) {
            if return_flag || throw_flag || panic_flag { ci = len(catch_body) } else {
                exec_stmt_at(catch_body, ci)
                ci = ci + 1
            }
        }
        env_pop_scope()
    } else {
        throw_flag = saved_throw
    }
    return val_void()
}

// ── Core: exec_stmt ──────────────────────────────────────

fn exec_stmt(node) {
    let _tmp = [node]
    return exec_stmt_at(_tmp, 0)
}

fn exec_stmt_at(stmts, idx) {
    let node = stmts[idx]
    // Defensive: parser may emit Str("") or non-struct stub on syntax error
    if type_of(node) == "string" { return val_void() }
    if type_of(node) != "struct" && type_of(node) != "map" { return val_void() }
    let k = node.kind
    if type_of(k) != "string" { return val_void() }

    if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "StaticStmt" {
        let val = val_void()
        let init = node.left
        if type_of(init) != "string" || init != "" {
            val = eval_expr(init)
        }
        env_define(node.name, val)
        return val_void()
    }

    // G9: array destructuring — let [a, b, ...rest] = expr
    if k == "DestructLetStmt" {
        let rhs = eval_expr(node.left)
        let patterns = node.params
        if rhs.tag == "array" {
            let arr_items = get_array(rhs)
            let arr_len = len(arr_items)
            let pat_len = len(patterns)
            // Bind each positional pattern
            let mut pi = 0
            while pi < pat_len {
                if pi < arr_len {
                    env_define(patterns[pi], arr_items[pi])
                } else {
                    env_define(patterns[pi], val_void())
                }
                pi = pi + 1
            }
            // Bind ...rest if present (rest_name stored in node.name)
            let rest_name = node.name
            if rest_name != "" {
                let mut rest_items = []
                let mut ri = pat_len
                while ri < arr_len {
                    rest_items = rest_items.push(arr_items[ri])
                    ri = ri + 1
                }
                env_define(rest_name, val_array(rest_items))
            }
        } else {
            // RHS is not an array — bind first pattern to value, rest to void
            let pat_len = len(patterns)
            if pat_len > 0 {
                env_define(patterns[0], rhs)
                let mut pi = 1
                while pi < pat_len {
                    env_define(patterns[pi], val_void())
                    pi = pi + 1
                }
            }
            let rest_name = node.name
            if rest_name != "" {
                env_define(rest_name, val_array([]))
            }
        }
        return val_void()
    }

    // G9: map/struct destructuring — let {x, y} = expr
    if k == "MapDestructLetStmt" {
        let rhs = eval_expr(node.left)
        let patterns = node.params
        let mut pi = 0
        while pi < len(patterns) {
            let key_name = patterns[pi]
            if rhs.tag == "map" {
                let v = map_get(rhs, val_str(key_name))
                env_define(key_name, v)
            } else if rhs.tag == "struct" {
                let fields = get_struct_fields(rhs)
                env_define(key_name, fields[key_name])
            } else {
                env_define(key_name, val_void())
            }
            pi = pi + 1
        }
        return val_void()
    }

    if k == "AssignStmt" {
        let val = eval_expr(node.right)
        if node.left.kind == "Ident" {
            env_set(node.left.name, val)
        }
        // Perf #11: struct field assignment in AssignStmt
        if node.left.kind == "Field" {
            let obj = eval_expr(node.left.left)
            if obj.tag == TAG_STRUCT {
                let field_name = node.left.name
                let updated = set_struct_field(obj, field_name, val)
                if type_of(node.left.left) != "string" && node.left.left.kind == "Ident" {
                    env_set(node.left.left.name, updated)
                }
            }
        }
        return val_void()
    }

    if k == "ExprStmt" {
        let expr = node.left
        if type_of(expr) == "string" { return val_void() }
        return eval_expr(expr)
    }

    if k == "ReturnStmt" {
        if node.left != "" {
            return_val = eval_expr(node.left)
        } else {
            return_val = val_void()
        }
        return_flag = true
        return val_void()
    }

    // Sprint C: yield <expr> — append to current gen_buffer and mark
    // this call frame as a generator. Does not set return_flag, so
    // execution continues and further yields may append more values.
    if k == "YieldStmt" {
        let yv = val_void()
        if node.left != "" {
            yv = eval_expr(node.left)
        }
        gen_buffer = gen_buffer.push(yv)
        gen_active = true
        return val_void()
    }

    if k == "FnDecl" || k == "AsyncFnDecl" {
        env_fns = env_fns.push([node.name, node.params, node.body])
        fn_cache_add(node.name, len(env_fns) - 1)
        let fn_val = val_fn(node.name, node.params, node.body)
        env_define(node.name, fn_val)
        // Store @attrs for runtime interception (@memo/@memoize/@cache)
        if node.value != "" {
            fn_attrs_set(node.name, node.value)
        }
        return val_void()
    }

    if k == "ExternFnDecl" {
        // Register extern function declaration.
        // node.value = @symbol("c_name") alias (empty → use node.name)
        // node.op    = @link("lib") library name (empty → default)
        let c_symbol = node.value
        if c_symbol == "" {
            c_symbol = node.name
        }
        let ret = node.ret_type
        let link = node.op
        extern_fns = extern_fns.push([node.name, c_symbol, ret, link])
        // Register as a builtin-style binding so calls route to FFI
        let builtin_name = "__extern_" + node.name
        env_define(node.name, val_str(builtin_name))
        return val_void()
    }

    if k == "IfStmt" {
        let cond = eval_expr(node.cond)
        if is_truthy(cond) {
            env_push_scope()
            eval_body(node.then_body)
            env_pop_scope()
        } else if node.else_body != "" {
            env_push_scope()
            eval_body(node.else_body)
            env_pop_scope()
        }
        return val_void()
    }

    if k == "CompoundAssign" {
        let lv = eval_expr(node.left)
        let rv = eval_expr(node.right)
        let result = eval_binop(node.op, lv, rv)
        if node.left.kind == "Ident" {
            env_set(node.left.name, result)
        }
        if node.left.kind == "Index" {
            let arr = eval_expr(node.left.left)
            let idx = eval_expr(node.left.right)
            if arr.tag == "array" || arr.tag == TAG_ARRAY {
                let items = get_array(arr)
                let mut new_items = []
                let mut ai = 0
                while ai < len(items) {
                    if ai == idx.int_val {
                        new_items = new_items.push(result)
                    } else {
                        new_items = new_items.push(items[ai])
                    }
                    ai = ai + 1
                }
                array_store[arr.int_val] = new_items
            }
            if arr.tag == "map" {
                let new_map = map_set(arr, idx, result)
                map_store[arr.int_val] = map_store[new_map.int_val]
            }
        }
        // Perf #11: struct field compound assignment — obj.field += val
        if node.left.kind == "Field" {
            let obj = eval_expr(node.left.left)
            if obj.tag == TAG_STRUCT {
                let field_name = node.left.name
                let updated = set_struct_field(obj, field_name, result)
                if type_of(node.left.left) != "string" && node.left.left.kind == "Ident" {
                    env_set(node.left.left.name, updated)
                }
            }
        }
        return val_void()
    }

    if k == "LogicalAssign" {
        if node.left.kind == "Ident" {
            let current = env_lookup(node.left.name)
            if node.op == "??=" {
                // Null-coalescing assignment: assign only if current is void or empty string
                if current.tag == "void" || (current.tag == "str" && current.str_val == "") {
                    env_set(node.left.name, eval_expr(node.right))
                }
            } else if node.op == "||=" {
                // Logical OR assignment: assign if current is falsy
                if !is_truthy(current) {
                    env_set(node.left.name, eval_expr(node.right))
                }
            } else if node.op == "&&=" {
                // Logical AND assignment: assign if current is truthy
                if is_truthy(current) {
                    env_set(node.left.name, eval_expr(node.right))
                }
            }
        }
        return val_void()
    }

    if k == "BreakStmt" {
        break_flag = true
        break_label = node.name
        return val_void()
    }

    if k == "ContinueStmt" {
        continue_flag = true
        continue_label = node.name
        return val_void()
    }

    if k == "DeferStmt" {
        defer_stack = defer_stack.push(node.body)
        return val_void()
    }

    if k == "StructDecl" || k == "EnumDecl" || k == "TraitDecl" {
        // Type declarations — store for later use
        // T25 fix: register enum variants so `EnumName.Variant` produces a value
        if k == "EnumDecl" {
            let vs = node.variants
            if type_of(vs) == "array" {
                let mut vnames = []
                let mut vi = 0
                while vi < len(vs) {
                    let v = vs[vi]
                    if type_of(v) == "struct" || type_of(v) == "map" {
                        vnames = vnames.push(v.name)
                    }
                    vi = vi + 1
                }
                enum_decls_register(node.name, vnames)
            }
        }
        return val_void()
    }

    if k == "ImplBlock" {
        // Store impl block methods for struct method dispatch
        let target = node.target
        let methods = node.methods
        impl_store = impl_store.push([target, methods])
        // Also register methods as functions with mangled names: Type__method
        let mut mi = 0
        while mi < len(methods) {
            let m = methods[mi]
            let mangled = target + "__" + m.name
            env_fns = env_fns.push([mangled, m.params, m.body])
            fn_cache_add(mangled, len(env_fns) - 1)
            mi = mi + 1
        }
        return val_void()
    }

    if k == "ThrowStmt" {
        let err = eval_expr(node.left)
        exec_throw(err)
        return val_void()
    }

    if k == "PanicStmt" {
        let msg_val = eval_expr(node.left)
        if msg_val.tag == TAG_STR {
            panic_msg = msg_val.str_val
        } else {
            panic_msg = val_to_string(msg_val)
        }
        panic_flag = true
        // Also set throw_flag so existing propagation checks in while/for/if
        // blocks (which test throw_flag) abort immediately. The flag is never
        // cleared by try/catch/recover because panic_flag remains set and
        // those arms only reset throw_flag while panic_flag stays true, which
        // our propagation checks also watch.
        throw_flag = true
        return val_void()
    }

    if k == "TryCatch" {
        return exec_try_catch(node.left, node.name, node.right)
    }

    if k == "RecoverStmt" {
        let body = node.left
        let catch_var = node.name

        // Save throw state
        let saved_throw = throw_flag
        throw_flag = false

        // Execute body
        env_push_scope()
        let mut result = val_void()
        let mut ri = 0
        while ri < len(body) {
            if return_flag || throw_flag || panic_flag { ri = len(body) } else {
                result = exec_stmt_at(body, ri)
                ri = ri + 1
            }
        }
        env_pop_scope()

        // Panic is not recoverable — propagate to program exit.
        if panic_flag { return val_void() }

        if throw_flag {
            // Throw occurred — recover from it
            let err = throw_val
            throw_flag = false
            throw_val = val_void()
            if catch_var != "_" {
                // Bind the error to the variable in the calling scope
                env_define(catch_var, err)
            }
            return val_void()
        } else {
            throw_flag = saved_throw
        }
        return result
    }

    if k == "WhileStmt" {
        let loop_label = node.value
        while !return_flag && !break_flag && !throw_flag {
            let cond = eval_expr(node.cond)
            if !is_truthy(cond) { return val_void() }
            env_push_scope()
            continue_flag = false
            let mut _wi = 0
            while _wi < len(node.body) {
                if return_flag || break_flag || continue_flag || throw_flag { _wi = len(node.body) } else {
                    exec_stmt_at(node.body, _wi)
                    _wi = _wi + 1
                }
            }
            env_pop_scope()
            if continue_flag {
                if continue_label == "" || continue_label == loop_label { continue_flag = false; continue_label = "" }
            }
        }
        if break_flag {
            if break_label == "" || break_label == loop_label { break_flag = false; break_label = "" }
        }
        return val_void()
    }

    if k == "ForStmt" || k == "ForElseStmt" {
        let loop_label = node.value
        let iter_val = eval_expr(node.iter_expr)
        // Uniform iteration: array → elements, map → keys (Python-style).
        // Converted to a simple list so the loop body stays identical.
        let mut items = []
        if iter_val.tag == TAG_ARRAY {
            items = get_array(iter_val)
        } else if iter_val.tag == TAG_MAP {
            items = get_map_keys(iter_val)
        }
        if k == "ForElseStmt" && len(items) == 0 {
            if node.else_body != "" {
                env_push_scope()
                eval_body(node.else_body)
                env_pop_scope()
            }
            return val_void()
        }
        let mut _fi2 = 0
        while _fi2 < len(items) {
            if return_flag || break_flag || throw_flag { _fi2 = len(items) } else {
                env_push_scope()
                continue_flag = false
                env_define(node.name, items[_fi2])
                let mut _fbi = 0
                while _fbi < len(node.body) {
                    if return_flag || break_flag || continue_flag || throw_flag { _fbi = len(node.body) } else {
                        exec_stmt_at(node.body, _fbi)
                        _fbi = _fbi + 1
                    }
                }
                env_pop_scope()
                if continue_flag {
                    if continue_label == "" || continue_label == loop_label { continue_flag = false; continue_label = "" }
                }
                _fi2 = _fi2 + 1
            }
        }
        if break_flag {
            if break_label == "" || break_label == loop_label { break_flag = false; break_label = "" }
        }
        return val_void()
    }

    if k == "LoopStmt" {
        let loop_label = node.value
        while !return_flag && !break_flag && !throw_flag {
            env_push_scope()
            eval_body(node.body)
            env_pop_scope()
        }
        if break_flag {
            if break_label == "" || break_label == loop_label { break_flag = false; break_label = "" }
        }
        return val_void()
    }

    if k == "DoWhileStmt" {
        let loop_label = node.value
        let mut do_continue = true
        while do_continue && !return_flag && !break_flag && !throw_flag {
            env_push_scope()
            continue_flag = false
            let mut _dwi = 0
            while _dwi < len(node.body) {
                if return_flag || break_flag || continue_flag || throw_flag { _dwi = len(node.body) } else {
                    exec_stmt_at(node.body, _dwi)
                    _dwi = _dwi + 1
                }
            }
            env_pop_scope()
            if continue_flag {
                if continue_label == "" || continue_label == loop_label { continue_flag = false; continue_label = "" }
            }
            if !return_flag && !break_flag && !throw_flag {
                let cond = eval_expr(node.cond)
                if !is_truthy(cond) { do_continue = false }
            }
        }
        if break_flag {
            if break_label == "" || break_label == loop_label { break_flag = false; break_label = "" }
        }
        return val_void()
    }

    // ═══════════════════════════════════════════════════════
    //  Phase 10 골화 — 추가 statement kinds (.rs 대응)
    // ═══════════════════════════════════════════════════════

    // Stmt::Mod — module declaration: just exec body in current scope
    if k == "Mod" || k == "ModStmt" {
        let body = node.body
        if type_of(body) == "array" { eval_body(body) }
        return val_void()
    }

    // Stmt::Use / ImportStmt — module path import: no-op (resolution at parser level)
    if k == "Use" || k == "UseStmt" || k == "ImportStmt" {
        return val_void()
    }

    // Stmt::Assert — runtime assertion (parser uses .left)
    if k == "AssertStmt" || k == "Assert" {
        let cond = eval_expr(node.left)
        if !is_truthy(cond) {
            throw_flag = true
            throw_val = val_str("assertion failed")
        }
        return val_void()
    }
    // Stmt::Invariant — proof block invariant marker (treat like assertion at runtime)
    if k == "Invariant" {
        let cond = eval_expr(node.left)
        if !is_truthy(cond) {
            throw_flag = true
            throw_val = val_str("invariant violated")
        }
        return val_void()
    }

    // Stmt::Resume — inside effect handler, capture value and halt body
    if k == "Resume" {
        let v = eval_expr(node.left)
        resume_value = v
        resume_set = true
        return_flag = true  // halt handler body
        return_val = v
        return val_void()
    }

    // Stmt::ContractAssert — @contract requires/ensures runtime check
    // node.op = "requires" | "ensures"
    // node.name = function name
    // node.value = clause source text (e.g. "requires: x > 0")
    // node.left = condition expression AST
    // For ensures: __contract_result is already bound in scope by
    //   the LetDecl injected before this node.  Bind "result" alias
    //   so the ensures expression can reference it.
    if k == "ContractAssert" {
        let clause_type = node.op
        if clause_type == "ensures" {
            // Bind "result" to __contract_result so ensures expr can use it
            let cr = env_lookup("__contract_result")
            env_define("result", cr)
        }
        let cond = eval_expr(node.left)
        if !is_truthy(cond) {
            throw_flag = true
            let fn_name = node.name
            let clause_text = node.value
            throw_val = val_str("ContractViolation: " + fn_name + " — " + clause_text)
        }
        return val_void()
    }

    // Stmt::EffectDecl — register an effect with its operations
    //   parser stores op list in `items`, each EffectOp has .name
    if k == "EffectDecl" {
        let effect_name = node.name
        let mut op_names = []
        if type_of(node.items) == "array" {
            for op in node.items { op_names = op_names.push(op.name) }
        }
        effect_def_add(effect_name, op_names)
        return val_void()
    }

    // Stmt::TypeAlias / Stmt::DeriveDecl — declarative, no runtime effect
    if k == "TypeAlias" || k == "TypeAliasStmt" || k == "DeriveDecl" || k == "DeriveStmt" {
        return val_void()
    }

    // Stmt::AtomicLet — let with Atomic wrapper
    if k == "AtomicLet" {
        let val = eval_expr(node.left)
        let atom = val_atomic(val)
        env_define(node.name, atom)
        return val_void()
    }

    // Stmt::Spawn — fire-and-forget block (single-threaded eval: just run inline)
    if k == "Spawn" || k == "SpawnNamed" || k == "SpawnStmt" {
        let body = node.body
        if type_of(body) == "array" { eval_body(body) }
        return val_void()
    }

    // Stmt::Scope — scoped block
    if k == "Scope" || k == "ScopeStmt" {
        let body = node.body
        if type_of(body) == "array" { eval_block(body) }
        return val_void()
    }

    // Stmt::DropStmt — explicit destructor call (interpreter no-op)
    if k == "DropStmt" || k == "Drop" {
        return val_void()
    }

    // Stmt::ProofBlock / Theorem — formal proof statements
    if k == "ProofBlock" || k == "Theorem" {
        let stmts = node.proof_stmts
        if type_of(stmts) == "array" {
            for ps in stmts {
                let r = execute_proof_block_stmt(ps)
                // Result format: ["proved" | "refuted" | "skipped" | ...]
                if type_of(r) == "array" && len(r) >= 1 && r[0] == "refuted" {
                    throw_flag = true
                    throw_val = val_str("proof refuted: " + r[1])
                    return val_void()
                }
            }
        }
        return val_void()
    }

    // Stmt::Intent / Stmt::Verify / Stmt::ConsciousnessBlock / Stmt::EvolveFn
    // — declarative consciousness/AI markers, no runtime effect in self-host
    if k == "Intent" || k == "IntentStmt" || k == "Verify" || k == "VerifyStmt" {
        return val_void()
    }
    if k == "ConsciousnessBlock" || k == "EvolveFn" || k == "EvolveFnDecl" {
        return val_void()
    }

    // Stmt::MacroDef — macro registration (interpreter ignores; expansion at parser)
    if k == "MacroDef" || k == "MacroDefStmt" {
        return val_void()
    }
    if k == "ComptimeFn" || k == "ComptimeFnDecl" {
        // Comptime functions evaluated lazily; treat as regular FnDecl
        env_fns = env_fns.push([node.name, node])
        fn_cache_add(node.name, len(env_fns) - 1)
        return val_void()
    }

    // Stmt::Generate / Stmt::Optimize — directive declarations
    if k == "Generate" || k == "Optimize" || k == "OptimizeStmt" || k == "GenerateStmt" || k == "GenerateFnStmt" || k == "OptimizeFnStmt" {
        return val_void()
    }

    // Stmt::TheoremStmt — alias for Theorem (Phase 9 proof block)
    if k == "TheoremStmt" {
        let stmts = node.proof_stmts
        if type_of(stmts) == "array" {
            for ps in stmts { execute_proof_block_stmt(ps) }
        }
        return val_void()
    }

    // Stmt::HandleWithStmt — statement-form of handle/with
    //   parser stores handlers in `items`, each EffectHandler has
    //   .target = effect name, .name = op name, .params, .body
    if k == "HandleWithStmt" {
        let mut entries = []
        if type_of(node.items) == "array" {
            for h in node.items {
                let key = h.target + "." + h.name
                entries = entries.push([key, h.params, h.body])
            }
        }
        effect_handler_push(entries)
        eval_body(node.body)
        effect_handler_pop()
        return val_void()
    }

    // Stmt::PureFnDecl — function declared @pure; same as FnDecl, but tag the
    //   pure flag so effect calls inside trigger an error.
    if k == "PureFnDecl" {
        env_fns = env_fns.push([node.name, node])
        fn_cache_add(node.name, len(env_fns) - 1)
        fn_attrs_set(node.name, "pure")
        return val_void()
    }

    // Comptime variants — evaluated in regular context (no compile-time phase)
    if k == "ComptimeAssert" {
        let cond = eval_expr(node.left)
        if !is_truthy(cond) {
            throw_flag = true
            throw_val = val_str("comptime assertion failed")
        }
        return val_void()
    }
    if k == "ComptimeBlock" {
        let body = node.body
        if type_of(body) == "array" { eval_body(body) }
        return val_void()
    }
    if k == "ComptimeLet" || k == "ComptimeConst" {
        let val = eval_expr(node.left)
        env_define(node.name, val)
        return val_void()
    }
    if k == "ComptimeFnDecl" {
        env_fns = env_fns.push([node.name, node])
        fn_cache_add(node.name, len(env_fns) - 1)
        return val_void()
    }

    // Stmt::Select — channel select (single-thread: pick first ready)
    //   Note: AST uses `chan` field for channel expression (channel is a keyword)
    if k == "Select" || k == "SelectStmt" {
        let arms = node.arms
        if type_of(arms) == "array" && len(arms) > 0 {
            for arm in arms {
                let ch = eval_expr(arm.chan)
                if ch.tag == TAG_CHANNEL {
                    let v = channel_recv(ch)
                    if v.tag != TAG_VOID {
                        env_push_scope()
                        if type_of(arm.var_name) == "string" && arm.var_name != "" {
                            env_define(arm.var_name, v)
                        }
                        eval_body(arm.body)
                        env_pop_scope()
                        return val_void()
                    }
                }
            }
        }
        return val_void()
    }

    // G28: guard EXPR else { BODY }
    // If EXPR is falsy, execute BODY (which should contain return/break).
    if k == "GuardStmt" {
        let cond = eval_expr(node.cond)
        if !is_truthy(cond) {
            env_push_scope()
            eval_body(node.else_body)
            env_pop_scope()
        }
        return val_void()
    }

    // G28: guard let NAME = EXPR else { BODY }
    // If EXPR is void/falsy, execute BODY (early exit). Otherwise bind NAME.
    if k == "GuardLetStmt" {
        let val = eval_expr(node.left)
        if !is_truthy(val) {
            env_push_scope()
            eval_body(node.else_body)
            env_pop_scope()
        } else {
            env_define(node.name, val)
        }
        return val_void()
    }

    // G27: with EXPR as NAME { BODY }
    // Evaluate EXPR, bind to NAME, execute BODY, then call .close() or
    // drop() on the resource if available. Cleanup runs even on error.
    if k == "WithStmt" {
        let resource = eval_expr(node.left)
        env_push_scope()
        env_define(node.name, resource)
        // Save throw state to ensure cleanup on error
        let saved_throw = throw_flag
        let saved_throw_val_w = throw_val
        throw_flag = false
        eval_body(node.body)
        let had_throw = throw_flag
        let body_throw_val = throw_val
        // Temporarily clear throw so cleanup can run
        throw_flag = false
        // Cleanup: try Type__close then Type__drop (mangled impl methods)
        if resource.tag == "struct" {
            let sname = resource.struct_name
            let close_mangled = sname + "__close"
            let drop_mangled = sname + "__drop"
            let close_info = find_fn(close_mangled)
            if close_info != "" {
                call_user_fn(close_mangled, [resource])
            } else {
                let drop_info = find_fn(drop_mangled)
                if drop_info != "" {
                    call_user_fn(drop_mangled, [resource])
                }
            }
        }
        env_pop_scope()
        // Restore throw state: body error takes priority
        if had_throw {
            throw_flag = true
            throw_val = body_throw_val
        } else if saved_throw {
            throw_flag = true
            throw_val = saved_throw_val_w
        }
        return val_void()
    }

    // Ignore unknown statement kinds
    return val_void()
}

// ── Execute a block of statements ────────────────────────

fn eval_body(stmts) {
    let mut result = val_void()
    let mut _bi = 0
    while _bi < len(stmts) {
        if return_flag || throw_flag { return result }
        result = exec_stmt_at(stmts, _bi)
        _bi = _bi + 1
    }
    return result
}

fn eval_block(stmts) {
    env_push_scope()
    let result = eval_body(stmts)
    env_pop_scope()
    return result
}

// ── Function call ────────────────────────────────────────

fn eval_call(node) {
    // Collect arguments — G8: spread args support
    // bt 72 fix: restore pending_named_args at every return path to keep
    // outer named-arg frames intact across nested calls. Missing let binding
    // previously caused 4 `undeclared 'saved_named'` C compile errors.
    let saved_named = pending_named_args
    let mut args = []
    let mut named = []
    let raw_args = node.args
    if type_of(raw_args) == "array" {
        for a in raw_args {
            if type_of(a) != "string" && a.kind == "Spread" {
                let spread_val = eval_expr(a.left)
                if spread_val.tag == "array" {
                    let spread_items = get_array(spread_val)
                    let mut si = 0
                    while si < len(spread_items) {
                        args = args.push(spread_items[si])
                        si = si + 1
                    }
                } else {
                    args = args.push(spread_val)
                }
            } else {
                args = args.push(eval_expr(a))
            }
        }
    }

    // Method call: obj.method(args) or obj?.method(args)
    let callee = node.left
    if type_of(callee) != "string" && (callee.kind == "Field" || callee.kind == "OptField") {
        let obj = eval_expr(callee.left)
        // Optional chaining short-circuit: obj?.method() → void when obj is void
        if callee.kind == "OptField" && obj.tag == "void" { return val_void() }
        let method = callee.name
        let result = call_method(obj, method, args)
        if type_of(callee.left) != "string" && callee.left.kind == "Ident" {
            if obj.tag == TAG_ARRAY && result.tag == TAG_ARRAY {
                if method == "push" || method == "pop" {
                    env_set(callee.left.name, result)
                }
            }
        }
        pending_named_args = saved_named
        return result
    }

    // Direct call: name(args)
    if type_of(callee) != "string" && callee.kind == "Ident" {
        let name = callee.name
        // User function takes precedence over builtin (allows shadowing)
        let user_info = find_fn(name)
        if user_info != "" {
            let r = call_user_fn(name, args)
            pending_named_args = saved_named
            return r
        }
        let builtin_result = call_builtin(name, args)
        if builtin_result.tag != TAG_NOT_BUILTIN {
            return builtin_result
        }
        let r = call_user_fn(name, args)
        pending_named_args = saved_named
        return r
    }

    // Indirect call (lambda etc)
    let callee_val = eval_expr(callee)
    if callee_val.tag == TAG_FN {
        return call_fn_val(callee_val, args)
    }

    pending_named_args = saved_named
    return val_void()
}

fn find_fn(name) {
    // O(1) avg via bucket cache. Fall back to linear scan only if
    // cache is empty (e.g., right after wholesale env_fns swap that
    // forgot to rebuild — defensive).
    if len(fn_cache) == 64 {
        let b = env_hash(name)
        let bucket = fn_cache[b]
        // Pick entry with largest index (newest definition = shadowing).
        let mut best = -1
        let mut bi = 0
        let bn = len(bucket)
        while bi < bn {
            let entry = bucket[bi]
            if entry[0] == name {
                if entry[1] > best { best = entry[1] }
            }
            bi = bi + 1
        }
        if best >= 0 && best < len(env_fns) {
            return env_fns[best]
        }
        return ""
    }
    // Fallback linear scan
    let mut i = len(env_fns) - 1
    while i >= 0 {
        if env_fns[i][0] == name { return env_fns[i] }
        i = i - 1
    }
    return ""
}

fn call_user_fn(name, args) {
    let fn_info = find_fn(name)
    if fn_info == "" {
        // Try env lookup (for closures/passed functions)
        let fn_val = env_lookup(name)
        if fn_val.tag == TAG_FN {
            return call_fn_val(fn_val, args)
        }
        println("Runtime error: undefined function: " + name)
        return val_void()
    }

    // ── @specialize: record type feedback in inline cache (V8-style IC) ──
    if has_specialize_attr(name) && len(args) > 0 {
        specialize_ic_record(name, args[0].tag)
    }
    // ── @lazy: check thunk cache before execution ──
    let is_lazy = has_lazy_attr(name)
    if is_lazy {
        let lazy_hit = lazy_lookup(name)
        if lazy_hit != "" {
            return lazy_hit[1]
        }
    }

    // ── @memo/@memoize/@cache: check cache before execution ──
    let is_memo = has_memo_attr(name)
    let mut memo_key = ""
    if is_memo {
        memo_key = memo_key_for_args(name, args)
        let cached = memo_lookup(memo_key)
        if cached != "" {
            return cached[1]
        }
    }

    let params = fn_info[1]
    let body = fn_info[2]

    call_stack = call_stack.push(name)
    env_push_scope()
    // G22/G23: bind positional args, then named args, then defaults
    let mut i = 0
    // Phase 1: bind positional args in order
    while i < len(params) && i < len(args) {
        if type_of(params[i]) == "string" {
            env_define(params[i], args[i])
        } else {
            env_define(params[i].name, args[i])
        }
        i = i + 1
    }
    // Phase 2: for remaining unbound params, try named args then defaults
    while i < len(params) {
        let p = params[i]
        let mut pname = ""
        if type_of(p) == "string" { pname = p } else { pname = p.name }
        // G23: check named args for this param
        let mut found_named = false
        let mut ni = 0
        while ni < len(pending_named_args) {
            if pending_named_args[ni][0] == pname {
                env_define(pname, pending_named_args[ni][1])
                found_named = true
                ni = len(pending_named_args)
            }
            ni = ni + 1
        }
        if !found_named {
            // G22: check for default value in param AST node
            if type_of(p) != "string" && p.left != "" {
                env_define(pname, eval_expr(p.left))
            } else {
                // No arg, no named, no default — bind void
                env_define(pname, val_void())
            }
        }
        i = i + 1
    }
    // G23: bind any named args that target positional params (override)
    let mut ni2 = 0
    while ni2 < len(pending_named_args) {
        let na_name = pending_named_args[ni2][0]
        let na_val = pending_named_args[ni2][1]
        // Check if this named arg targets a param already bound positionally
        let mut pi2 = 0
        while pi2 < len(params) && pi2 < len(args) {
            let pp = params[pi2]
            let mut ppname = ""
            if type_of(pp) == "string" { ppname = pp } else { ppname = pp.name }
            if ppname == na_name {
                // Override the positional binding with the named value
                env_set(na_name, na_val)
                pi2 = len(params)
            }
            pi2 = pi2 + 1
        }
        ni2 = ni2 + 1
    }

    let saved_flag = return_flag
    return_flag = false
    let saved_defer_stack = defer_stack
    defer_stack = []
    // Sprint C: save outer generator frame, start a fresh empty buffer
    // so that yields inside this call accumulate here only.
    let saved_gen_buffer = gen_buffer
    let saved_gen_active = gen_active
    gen_buffer = []
    gen_active = false
    // Inline body execution (avoid struct copy via eval_body)
    // Track the last ExprStmt's value for implicit return semantics:
    // a fn body ending in `expr` (no return) yields that expr's value.
    let mut last_expr_val = val_void()
    let mut _cbi = 0
    while _cbi < len(body) {
        if return_flag || throw_flag { _cbi = len(body) } else {
            let stmt = body[_cbi]
            if type_of(stmt) != "string" && type_of(stmt) == "struct" || type_of(stmt) == "map" {
                if stmt.kind == "ExprStmt" {
                    last_expr_val = eval_expr(stmt.left)
                } else {
                    exec_stmt_at(body, _cbi)
                }
            } else {
                exec_stmt_at(body, _cbi)
            }
            _cbi = _cbi + 1
        }
    }
    let mut result = return_val
    // Implicit return: if no explicit return fired, use last expression value
    if !return_flag && result.tag == TAG_VOID && last_expr_val.tag != TAG_VOID {
        result = last_expr_val
    }
    // Sprint C: if at least one yield happened AND no explicit return
    // value was set, convert the accumulated buffer into an array value.
    if gen_active && !return_flag {
        result = val_array(gen_buffer)
    }
    gen_buffer = saved_gen_buffer
    gen_active = saved_gen_active
    // Execute deferred statements in LIFO order before restoring flags
    let saved_rf = return_flag
    let saved_tf = throw_flag
    return_flag = false
    throw_flag = false
    let mut _di = len(defer_stack) - 1
    while _di >= 0 {
        eval_body(defer_stack[_di])
        _di = _di - 1
    }
    return_flag = saved_rf
    throw_flag = saved_tf
    defer_stack = saved_defer_stack
    return_flag = saved_flag
    return_val = val_void()
    env_pop_scope()
    // ── Perf #15: O(1) call stack pop — slice instead of copy loop ──
    call_stack = call_stack.slice(0, len(call_stack) - 1)

    // ── @lazy: store result in thunk cache ──
    if is_lazy {
        lazy_store(name, result)
    }

    // ── @memo/@memoize/@cache: store result in cache ──
    if is_memo {
        memo_store(memo_key, result)
    }

    return result
}

fn call_fn_val(fn_val, args) {
    // ── Special functional closures ─────────────────────────
    if fn_val.str_val == "compose" {
        // compose(f, g) → f(g(x))
        let captured = closure_store[fn_val.int_val][0]
        let mut f = val_void()
        let mut g = val_void()
        let mut ci = 0
        while ci < len(captured) {
            if captured[ci][0] == "__compose_f" { f = captured[ci][1] }
            if captured[ci][0] == "__compose_g" { g = captured[ci][1] }
            ci = ci + 1
        }
        let inner = call_fn_val(g, args)
        return call_fn_val(f, [inner])
    }
    if fn_val.str_val == "curry" {
        // curry(fn, ...partial) → fn(partial..., args...)
        let captured = closure_store[fn_val.int_val][0]
        let mut f = val_void()
        let mut partial_arr = val_void()
        let mut ci = 0
        while ci < len(captured) {
            if captured[ci][0] == "__curry_fn" { f = captured[ci][1] }
            if captured[ci][0] == "__curry_partial" { partial_arr = captured[ci][1] }
            ci = ci + 1
        }
        let partial = get_array(partial_arr)
        let mut all_args = []
        for p in partial { all_args = all_args.push(p) }
        for a in args { all_args = all_args.push(a) }
        return call_fn_val(f, all_args)
    }
    if fn_val.str_val == "constant" {
        // constant(x) → fn() => x
        let captured = closure_store[fn_val.int_val][0]
        let mut ci = 0
        while ci < len(captured) {
            if captured[ci][0] == "__constant_val" { return captured[ci][1] }
            ci = ci + 1
        }
        return val_void()
    }

    // fn_val has fn_params (array) and fn_body (AST array)
    let params = fn_val.fn_params
    let body = fn_val.fn_body
    let is_closure = fn_val.str_val == "closure"

    // For closures, save current env triple and restore captured env+cache O(1)
    // rt 32-E: snap[0] is a list of [name, value] tuples (closure capture
    // retains tuple format since it's a one-shot alloc at lambda creation,
    // not on every env_define). Unpack into parallel arrays on restore.
    let mut saved_names = []
    let mut saved_vals = []
    let mut saved_scopes = []
    let mut saved_cache_names = []
    let mut saved_cache_idxs = []
    let mut saved_dirty = []
    if is_closure {
        saved_names = env_var_names
        saved_vals = env_var_vals
        saved_scopes = env_scopes
        saved_cache_names = env_cache_names
        saved_cache_idxs = env_cache_idxs
        saved_dirty = env_scope_dirty
        let snap = closure_store[fn_val.int_val]
        let captured = snap[0]
        let mut _cn = []
        let mut _cv = []
        let mut _ci = 0
        while _ci < len(captured) {
            _cn = _cn.push(captured[_ci][0])
            _cv = _cv.push(captured[_ci][1])
            _ci = _ci + 1
        }
        env_var_names = _cn
        env_var_vals = _cv
        // Always rebuild cache — the cached bucket snapshot uses the old
        // tuple format which is no longer compatible with parallel buckets.
        env_rebuild_cache()
        env_scopes = [0]
        env_scope_dirty = []
    }

    env_push_scope()
    // G22/G23: bind positional args, then named args, then defaults
    let mut i = 0
    // Phase 1: bind positional args in order
    while i < len(params) && i < len(args) {
        if type_of(params[i]) == "string" {
            env_define(params[i], args[i])
        } else {
            env_define(params[i].name, args[i])
        }
        i = i + 1
    }
    // Phase 2: for remaining unbound params, try named args then defaults
    while i < len(params) {
        let p = params[i]
        let mut pname = ""
        if type_of(p) == "string" { pname = p } else { pname = p.name }
        // G23: check named args
        let mut found_named = false
        let mut ni = 0
        while ni < len(pending_named_args) {
            if pending_named_args[ni][0] == pname {
                env_define(pname, pending_named_args[ni][1])
                found_named = true
                ni = len(pending_named_args)
            }
            ni = ni + 1
        }
        if !found_named {
            // G22: check for default value
            if type_of(p) != "string" && p.left != "" {
                env_define(pname, eval_expr(p.left))
            } else {
                env_define(pname, val_void())
            }
        }
        i = i + 1
    }
    // G23: bind named args targeting already-bound positional params
    let mut ni2 = 0
    while ni2 < len(pending_named_args) {
        let na_name = pending_named_args[ni2][0]
        let na_val = pending_named_args[ni2][1]
        let mut pi2 = 0
        while pi2 < len(params) && pi2 < len(args) {
            let pp = params[pi2]
            let mut ppname = ""
            if type_of(pp) == "string" { ppname = pp } else { ppname = pp.name }
            if ppname == na_name {
                env_set(na_name, na_val)
                pi2 = len(params)
            }
            pi2 = pi2 + 1
        }
        ni2 = ni2 + 1
    }

    let saved_flag = return_flag
    return_flag = false
    let saved_defer_stack = defer_stack
    defer_stack = []
    // Sprint C: generator frame save/restore (see call_user_fn for notes)
    let saved_gen_buffer = gen_buffer
    let saved_gen_active = gen_active
    gen_buffer = []
    gen_active = false
    if type_of(body) == "array" {
        eval_body(body)
    } else {
        // Single expression body (lambda)
        return_val = eval_expr(body)
        return_flag = true
    }
    let mut result = return_val
    if gen_active && !return_flag {
        result = val_array(gen_buffer)
    }
    gen_buffer = saved_gen_buffer
    gen_active = saved_gen_active
    // Execute deferred statements in LIFO order before restoring flags
    let saved_rf = return_flag
    let saved_tf = throw_flag
    return_flag = false
    throw_flag = false
    let mut _di = len(defer_stack) - 1
    while _di >= 0 {
        eval_body(defer_stack[_di])
        _di = _di - 1
    }
    return_flag = saved_rf
    throw_flag = saved_tf
    defer_stack = saved_defer_stack
    return_flag = saved_flag
    return_val = val_void()
    env_pop_scope()

    // Restore env for closures — O(1) swap back, no rebuild needed
    if is_closure {
        env_var_names = saved_names
        env_var_vals = saved_vals
        env_scopes = saved_scopes
        env_cache_names = saved_cache_names
        env_cache_idxs = saved_cache_idxs
        env_scope_dirty = saved_dirty
    }

    return result
}

// ── Builtin functions ────────────────────────────────────

fn call_builtin(name, args) {
    let not_builtin = Val { tag: TAG_NOT_BUILTIN, int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }

    if name == "println" {
        let mut out = ""
        for a in args { out = out + val_to_string(a) }
        // R19: BrokenPipe(파이프 조기 종료) 감지 → graceful exit(0).
        // | head, | tail 등으로 consumer 종료 시 silent exit 1 방지.
        try {
            println(out)
        } catch e {
            let es = e.to_string()
            if es.contains("pipe") || es.contains("EPIPE") || es.contains("BrokenPipe") {
                exit(0)
            }
            eprintln("❌ [interpreter.println] " + es)
            exit(1)
        }
        return val_void()
    }
    if name == "eprintln" {
        let mut out = ""
        for a in args { out = out + val_to_string(a) }
        try {
            eprintln(out)
        } catch e {
            let es = e.to_string()
            if es.contains("pipe") || es.contains("EPIPE") || es.contains("BrokenPipe") {
                exit(0)
            }
            // can't use eprintln to report eprintln failure — fall to plain println
            println("[interpreter.eprintln] " + es)
            exit(1)
        }
        return val_void()
    }
    if name == "print" {
        let mut out = ""
        for a in args { out = out + val_to_string(a) }
        try {
            print(out)
        } catch e {
            let es = e.to_string()
            if es.contains("pipe") || es.contains("EPIPE") || es.contains("BrokenPipe") {
                exit(0)
            }
            eprintln("❌ [interpreter.print] " + es)
            exit(1)
        }
        return val_void()
    }
    // ── Phase 12 골화 — 호스트 빌트인 패스스루 ──
    // exec(cmd) → 호스트 shell에 위임. 실패 시 tag="error" Val.
    //   exec()는 매우 자주 쓰이며 P11 안티패턴(`exec(...).trim()`)의 출처.
    //   여기선 호스트 인터프리터 빌트인을 직접 호출.
    if name == "exec" {
        if len(args) == 0 { return val_str("") }
        try {
            let result = exec(args[0].str_val)
            return val_str(result)
        } catch e {
            return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: e.to_string(), char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
        }
    }
    if name == "exec_with_status" {
        if len(args) == 0 { return val_array([val_str(""), val_int(0)]) }
        try {
            let result = exec(args[0].str_val)
            return val_array([val_str(result), val_int(0)])
        } catch e {
            return val_array([val_str(e.to_string()), val_int(1)])
        }
    }
    if name == "env" || name == "env_get" {
        if len(args) == 0 { return val_str("") }
        let v = env_var(args[0].str_val)
        return val_str(v)
    }
    if name == "join" {
        if len(args) == 0 { return val_str("") }
        let arr = args[0]
        let sep = if len(args) > 1 { args[1].str_val } else { "" }
        if arr.tag != TAG_ARRAY { return val_str("") }
        let items = get_array(arr)
        let mut out = ""
        let mut _ji = 0
        while _ji < len(items) {
            if _ji > 0 { out = out + sep }
            let item = items[_ji]
            if item.tag == TAG_STR { out = out + item.str_val }
            else { out = out + val_to_string(item) }
            _ji = _ji + 1
        }
        return val_str(out)
    }
    if name == "args" || name == "argv" {
        let a = host_args()
        let mut wrapped = []
        if type_of(a) == "array" {
            let mut _ai = 0
            while _ai < len(a) {
                wrapped = wrapped.push(val_str(to_string(a[_ai])))
                _ai = _ai + 1
            }
        }
        return val_array(wrapped)
    }
    if name == "file_size" {
        if len(args) == 0 { return val_int(0) }
        try {
            let content = read_file(args[0].str_val)
            return val_int(len(content))
        } catch e {
            return val_int(-1)
        }
    }
    if name == "clock" || name == "elapsed" {
        return val_int(timestamp())
    }
    if name == "chr" {
        if len(args) == 0 { return val_str("") }
        return val_str(to_string(args[0].int_val))
    }
    if name == "arange" {
        // arange(n) | arange(start, end) | arange(start, end, step)
        let start = if len(args) >= 2 { args[0].int_val } else { 0 }
        let end = if len(args) >= 2 { args[1].int_val } else { args[0].int_val }
        let step = if len(args) >= 3 { args[2].int_val } else { 1 }
        let mut result = []
        let mut i = start
        if step > 0 {
            while i < end { result = result.push(val_int(i)); i = i + step }
        }
        return val_array(result)
    }
    if name == "argmax" {
        if len(args) == 0 { return val_int(-1) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        if len(arr) == 0 { return val_int(-1) }
        let mut best_i = 0
        let mut best_v = if type_of(arr[0]) == "float" { arr[0] } else { to_float_val(arr[0]) }
        let mut i = 1
        while i < len(arr) {
            let v = if type_of(arr[i]) == "float" { arr[i] } else { to_float_val(arr[i]) }
            if v > best_v { best_v = v; best_i = i }
            i = i + 1
        }
        return val_int(best_i)
    }
    if name == "flatten" {
        if len(args) == 0 { return val_array([]) }
        let arr = get_array(args[0])
        let mut result = []
        for item in arr {
            if item.tag == TAG_ARRAY {
                let sub = get_array(item)
                for s in sub { result = result.push(s) }
            } else {
                result = result.push(item)
            }
        }
        return val_array(result)
    }
    if name == "f32_bits" {
        // float → IEEE-754 single bits (host runtime delegate)
        // self-host fallback: int_val of integer cast (lossy, but matches API)
        if len(args) == 0 { return val_int(0) }
        return val_int(args[0].int_val)
    }
    if name == "f32_from_bits" {
        if len(args) == 0 { return val_float(0.0) }
        return val_float(args[0].int_val + 0.0)
    }
    if name == "channel" {
        // channel() | channel(capacity)
        let cap = if len(args) > 0 { args[0].int_val } else { 0 }
        return val_channel_make(cap)
    }
    if name == "bigint" {
        if len(args) == 0 { return val_bigint("0") }
        if args[0].tag == TAG_INT { return val_bigint_from_int(args[0].int_val) }
        if args[0].tag == TAG_STR { return val_bigint(args[0].str_val) }
        return val_bigint(val_to_string(args[0]))
    }
    // ── Phase 12b 골화 — math/loss/util builtins ──
    if name == "clip" {
        // clip(x, lo, hi)
        if len(args) < 3 { return val_float(0.0) }
        let x = to_float_val(args[0])
        let lo = to_float_val(args[1])
        let hi = to_float_val(args[2])
        if x < lo { return val_float(lo) }
        if x > hi { return val_float(hi) }
        return val_float(x)
    }
    if name == "ema" {
        // ema(prev, x, alpha) → prev*(1-alpha) + x*alpha
        if len(args) < 3 { return val_float(0.0) }
        let prev = to_float_val(args[0])
        let x = to_float_val(args[1])
        let alpha = to_float_val(args[2])
        return val_float(prev * (1.0 - alpha) + x * alpha)
    }
    if name == "entropy" {
        // entropy(probs) — Shannon entropy
        if len(args) == 0 { return val_float(0.0) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut h = 0.0
        for v in arr {
            let p = if type_of(v) == "float" { v } else { to_float_val(v) }
            if p > 0.0 { h = h - p * ln(p) }
        }
        return val_float(h)
    }
    if name == "cosine_sim" {
        // cosine_sim(a, b) → dot/(|a|*|b|)
        if len(args) < 2 { return val_float(0.0) }
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(a) < len(b) { len(a) } else { len(b) }
        let mut dot_p = 0.0
        let mut na = 0.0
        let mut nb = 0.0
        let mut i = 0
        while i < n {
            let av = if type_of(a[i]) == "float" { a[i] } else { to_float_val(a[i]) }
            let bv = if type_of(b[i]) == "float" { b[i] } else { to_float_val(b[i]) }
            dot_p = dot_p + av * bv
            na = na + av * av
            nb = nb + bv * bv
            i = i + 1
        }
        let denom = sqrt(na) * sqrt(nb)
        if denom == 0.0 { return val_float(0.0) }
        return val_float(dot_p / denom)
    }
    if name == "cross_entropy" {
        // cross_entropy(logits, target_idx) — softmax + -log p[target]
        if len(args) < 2 { return val_float(0.0) }
        let logits = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let target = args[1].int_val
        if target < 0 || target >= len(logits) { return val_float(0.0) }
        // softmax stability: subtract max
        let mut max_l = if type_of(logits[0]) == "float" { logits[0] } else { to_float_val(logits[0]) }
        for v in logits {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            if f > max_l { max_l = f }
        }
        let mut sum_exp = 0.0
        for v in logits {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            sum_exp = sum_exp + exp(f - max_l)
        }
        let target_v = if type_of(logits[target]) == "float" { logits[target] } else { to_float_val(logits[target]) }
        let log_softmax = (target_v - max_l) - ln(sum_exp)
        return val_float(0.0 - log_softmax)
    }
    if name == "cosine_lr" {
        // cosine_lr(step, total, base, min_lr) — cosine annealing schedule
        if len(args) < 4 { return val_float(0.0) }
        let step = to_float_val(args[0])
        let total = to_float_val(args[1])
        let base = to_float_val(args[2])
        let min_lr = to_float_val(args[3])
        if total <= 0.0 { return val_float(base) }
        let progress = step / total
        let factor = 0.5 * (1.0 + cos(3.14159265358979 * progress))
        return val_float(min_lr + (base - min_lr) * factor)
    }
    if name == "base64_encode" {
        if len(args) == 0 { return val_str("") }
        // Self-host: delegate to host if exposed; else simple stub
        let s = if args[0].tag == TAG_STR { args[0].str_val } else { val_to_string(args[0]) }
        try {
            let result = base64_encode(s)
            return val_str(result)
        } catch e {
            return val_str(s)
        }
    }
    if name == "base64_decode" {
        if len(args) == 0 { return val_str("") }
        let s = args[0].str_val
        try {
            let result = base64_decode(s)
            return val_str(result)
        } catch e {
            return val_str(s)
        }
    }
    if name == "dropout" {
        // dropout(x, rate) — for inference, identity (rate ignored)
        if len(args) == 0 { return val_void() }
        return args[0]
    }
    if name == "batch_norm" {
        // batch_norm(x, mean, var, eps) — (x - mean) / sqrt(var + eps)
        if len(args) < 4 { return val_void() }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mean = to_float_val(args[1])
        let var = to_float_val(args[2])
        let eps = to_float_val(args[3])
        let denom = sqrt(var + eps)
        let mut out = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            out = out.push((f - mean) / denom)
        }
        if args[0].tag == TAG_TENSOR { return val_tensor(tensor_shape(args[0]), out) }
        return val_array(out)
    }
    if name == "embedding" {
        // embedding(table, idx, dim) → row of `dim` floats from table starting at idx*dim
        if len(args) < 3 { return val_array([]) }
        let table = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let idx = args[1].int_val
        let dim = args[2].int_val
        let base = idx * dim
        if base < 0 || base + dim > len(table) { return val_array([]) }
        let mut out = []
        let mut i = 0
        while i < dim {
            let v = table[base + i]
            if type_of(v) == "float" { out = out.push(v) }
            else { out = out.push(to_float_val(v)) }
            i = i + 1
        }
        return val_tensor([dim], out)
    }
    if name == "softmax" {
        if len(args) == 0 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        if len(arr) == 0 { return val_array([]) }
        // stable softmax
        let mut max_v = to_float_val(arr[0])
        for v in arr {
            let f = to_float_val(v)
            if f > max_v { max_v = f }
        }
        let mut exps = []
        let mut sum_e = 0.0
        for v in arr {
            let f = to_float_val(v)
            let e = exp(f - max_v)
            exps = exps.push(e)
            sum_e = sum_e + e
        }
        // Wrap each result as val_float so downstream sum/map work
        let mut out = []
        for e in exps { out = out.push(val_float(e / sum_e)) }
        if args[0].tag == TAG_TENSOR {
            let mut raw_out = []
            for w in out { raw_out = raw_out.push(w.float_val) }
            return val_tensor(tensor_shape(args[0]), raw_out)
        }
        return val_array(out)
    }

    // ── Phase 13 골화 — ML training builtins ──
    // adam_step(p, g, m, v, lr, b1, b2, eps, t) → [new_p..., new_m..., new_v...]
    if name == "adam_step" {
        if len(args) < 9 { return val_array([]) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let g = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let m = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let v = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let lr = to_float_val(args[4])
        let beta1 = to_float_val(args[5])
        let beta2 = to_float_val(args[6])
        let eps = to_float_val(args[7])
        let t = to_float_val(args[8])
        let n = len(p)
        let bc1 = 1.0 - pow(beta1, t)
        let bc2 = 1.0 - pow(beta2, t)
        let mut new_p = []
        let mut new_m = []
        let mut new_v = []
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let gf = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            let mf = if type_of(m[i]) == "float" { m[i] } else { to_float_val(m[i]) }
            let vf = if type_of(v[i]) == "float" { v[i] } else { to_float_val(v[i]) }
            let mi = beta1 * mf + (1.0 - beta1) * gf
            let vi = beta2 * vf + (1.0 - beta2) * gf * gf
            let m_hat = mi / bc1
            let v_hat = vi / bc2
            let pi_new = pf - lr * m_hat / (sqrt(v_hat) + eps)
            new_p = new_p.push(pi_new)
            new_m = new_m.push(mi)
            new_v = new_v.push(vi)
            i = i + 1
        }
        // Concat: [new_p..., new_m..., new_v...]
        let mut result = []
        for x in new_p { result = result.push(val_float(x)) }
        for x in new_m { result = result.push(val_float(x)) }
        for x in new_v { result = result.push(val_float(x)) }
        return val_array(result)
    }
    // adamw_step — same as adam but decoupled weight decay
    if name == "adamw_step" {
        if len(args) < 10 { return val_array([]) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let g = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let m = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let v = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let lr = to_float_val(args[4])
        let beta1 = to_float_val(args[5])
        let beta2 = to_float_val(args[6])
        let eps = to_float_val(args[7])
        let t = to_float_val(args[8])
        let wd = to_float_val(args[9])
        let n = len(p)
        let bc1 = 1.0 - pow(beta1, t)
        let bc2 = 1.0 - pow(beta2, t)
        let mut new_p = []
        let mut new_m = []
        let mut new_v = []
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let gf = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            let mf = if type_of(m[i]) == "float" { m[i] } else { to_float_val(m[i]) }
            let vf = if type_of(v[i]) == "float" { v[i] } else { to_float_val(v[i]) }
            let mi = beta1 * mf + (1.0 - beta1) * gf
            let vi = beta2 * vf + (1.0 - beta2) * gf * gf
            let m_hat = mi / bc1
            let v_hat = vi / bc2
            let pi_new = pf * (1.0 - lr * wd) - lr * m_hat / (sqrt(v_hat) + eps)
            new_p = new_p.push(pi_new)
            new_m = new_m.push(mi)
            new_v = new_v.push(vi)
            i = i + 1
        }
        let mut result = []
        for x in new_p { result = result.push(val_float(x)) }
        for x in new_m { result = result.push(val_float(x)) }
        for x in new_v { result = result.push(val_float(x)) }
        return val_array(result)
    }
    // warmup_lr(base, step, warmup_steps)
    if name == "warmup_lr" {
        if len(args) < 3 { return val_float(0.0) }
        let base = to_float_val(args[0])
        let step = to_float_val(args[1])
        let warmup = to_float_val(args[2])
        if step < warmup { return val_float(base * step / warmup) }
        return val_float(base)
    }
    // phase_lr(base, step, total, n_phases)
    if name == "phase_lr" {
        if len(args) < 4 { return val_float(0.0) }
        let base = to_float_val(args[0])
        let step = to_float_val(args[1])
        let total = to_float_val(args[2])
        let n_phases = args[3].int_val
        let phase_idx = floor(step / total * n_phases)
        let phase_clamped = if phase_idx >= n_phases { n_phases - 1 } else { phase_idx }
        let decay = pow(0.5, phase_clamped)
        return val_float(base * decay)
    }
    // layer_norm(x, dim) → normalized
    if name == "layer_norm" {
        if len(args) < 2 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let dim = args[1].int_val
        if dim == 0 { return val_array([]) }
        let n_samples = len(x) / dim
        let mut result = []
        let mut s = 0
        while s < n_samples {
            let base = s * dim
            let mut mean = 0.0
            let mut d = 0
            while d < dim {
                let v = if type_of(x[base + d]) == "float" { x[base + d] } else { to_float_val(x[base + d]) }
                mean = mean + v
                d = d + 1
            }
            mean = mean / dim
            let mut var = 0.0
            d = 0
            while d < dim {
                let v = if type_of(x[base + d]) == "float" { x[base + d] } else { to_float_val(x[base + d]) }
                var = var + (v - mean) * (v - mean)
                d = d + 1
            }
            var = var / dim
            let denom = sqrt(var + 0.00001)
            d = 0
            while d < dim {
                let v = if type_of(x[base + d]) == "float" { x[base + d] } else { to_float_val(x[base + d]) }
                result = result.push(val_float((v - mean) / denom))
                d = d + 1
            }
            s = s + 1
        }
        return val_array(result)
    }
    // mse(pred, target)
    if name == "mse" || name == "mean_squared_error" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let t = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(p) < len(t) { len(p) } else { len(t) }
        if n == 0 { return val_float(0.0) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let tf = if type_of(t[i]) == "float" { t[i] } else { to_float_val(t[i]) }
            let d = pf - tf
            total = total + d * d
            i = i + 1
        }
        return val_float(total / n)
    }
    // mae(pred, target)
    if name == "mae" || name == "mean_absolute_error" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let t = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(p) < len(t) { len(p) } else { len(t) }
        if n == 0 { return val_float(0.0) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let tf = if type_of(t[i]) == "float" { t[i] } else { to_float_val(t[i]) }
            let d = pf - tf
            total = total + abs(d)
            i = i + 1
        }
        return val_float(total / n)
    }
    // smooth_l1_loss / huber_loss
    if name == "smooth_l1_loss" || name == "huber_loss" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let t = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let beta = if len(args) > 2 { to_float_val(args[2]) } else { 1.0 }
        let n = if len(p) < len(t) { len(p) } else { len(t) }
        if n == 0 { return val_float(0.0) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let tf = if type_of(t[i]) == "float" { t[i] } else { to_float_val(t[i]) }
            let diff = abs(pf - tf)
            if diff < beta { total = total + 0.5 * diff * diff / beta }
            else { total = total + diff - 0.5 * beta }
            i = i + 1
        }
        return val_float(total / n)
    }
    // focal_loss(pred, target, gamma)
    if name == "focal_loss" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let t = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let gamma = if len(args) > 2 { to_float_val(args[2]) } else { 2.0 }
        let n = if len(p) < len(t) { len(p) } else { len(t) }
        if n == 0 { return val_float(0.0) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let tf = if type_of(t[i]) == "float" { t[i] } else { to_float_val(t[i]) }
            let pt = if tf > 0.5 { pf } else { 1.0 - pf }
            let pt_safe = if pt < 0.000001 { 0.000001 } else { pt }
            total = total - pow(1.0 - pt_safe, gamma) * ln(pt_safe)
            i = i + 1
        }
        return val_float(total / n)
    }
    // contrastive_loss(emb1, emb2, label, margin) — InfoNCE-ish
    if name == "contrastive_loss" {
        if len(args) < 3 { return val_float(0.0) }
        let e1 = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let e2 = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let label = to_float_val(args[2])
        let margin = if len(args) > 3 { to_float_val(args[3]) } else { 1.0 }
        let n = if len(e1) < len(e2) { len(e1) } else { len(e2) }
        let mut dist_sq = 0.0
        let mut i = 0
        while i < n {
            let a = if type_of(e1[i]) == "float" { e1[i] } else { to_float_val(e1[i]) }
            let b = if type_of(e2[i]) == "float" { e2[i] } else { to_float_val(e2[i]) }
            let d = a - b
            dist_sq = dist_sq + d * d
            i = i + 1
        }
        let dist = sqrt(dist_sq)
        // similar (label=1): minimize dist^2; dissimilar (label=0): maximize margin-dist
        let pos = label * dist_sq
        let neg_diff = if margin - dist > 0.0 { margin - dist } else { 0.0 }
        let neg = (1.0 - label) * neg_diff * neg_diff
        return val_float(0.5 * (pos + neg))
    }
    // gelu(x) — Gaussian Error Linear Unit
    if name == "gelu" {
        if len(args) == 0 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut result = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            // approximation: 0.5 * x * (1 + tanh(sqrt(2/pi) * (x + 0.044715 * x^3)))
            let inner = sqrt(2.0 / 3.14159265358979) * (f + 0.044715 * f * f * f)
            let g = 0.5 * f * (1.0 + tanh(inner))
            result = result.push(val_float(g))
        }
        if args[0].tag == TAG_TENSOR { return val_tensor(tensor_shape(args[0]), [].push(0)) }
        return val_array(result)
    }
    // swish(x) = x * sigmoid(x)
    if name == "swish" || name == "silu" {
        if len(args) == 0 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut result = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            let s = 1.0 / (1.0 + exp(0.0 - f))
            result = result.push(val_float(f * s))
        }
        return val_array(result)
    }
    // transpose(matrix, rows, cols) → transposed flat array
    if name == "transpose" {
        if len(args) < 3 { return val_array([]) }
        let m = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let rows = args[1].int_val
        let cols = args[2].int_val
        let mut result = []
        let mut c = 0
        while c < cols {
            let mut r = 0
            while r < rows {
                let v = m[r * cols + c]
                if type_of(v) == "float" { result = result.push(val_float(v)) }
                else { result = result.push(v) }
                r = r + 1
            }
            c = c + 1
        }
        return val_array(result)
    }
    // zeros(n) / ones(n)
    if name == "zeros" {
        if len(args) == 0 { return val_array([]) }
        let n = args[0].int_val
        let mut result = []
        let mut i = 0
        while i < n { result = result.push(val_float(0.0)); i = i + 1 }
        return val_array(result)
    }
    if name == "ones" {
        if len(args) == 0 { return val_array([]) }
        let n = args[0].int_val
        let mut result = []
        let mut i = 0
        while i < n { result = result.push(val_float(1.0)); i = i + 1 }
        return val_array(result)
    }
    // ── Phase 13b 골화 — attention/conv/lora ──
    // attention(Q, K, V, seq, dim, causal?) — scaled dot-product attention
    if name == "attention" {
        if len(args) < 5 { return val_array([]) }
        let q = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let v = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let seq = args[3].int_val
        let dim = args[4].int_val
        let causal = if len(args) > 5 { args[5].bool_val } else { false }
        let scale = 1.0 / sqrt(dim + 0.0)
        let mut output = []
        let mut i = 0
        while i < seq {
            let mut scores = []
            let mut j = 0
            while j < seq {
                if causal && j > i {
                    scores = scores.push(0.0 - 1000000000.0)
                } else {
                    let mut dot = 0.0
                    let mut d = 0
                    while d < dim {
                        let qv = if type_of(q[i * dim + d]) == "float" { q[i * dim + d] } else { to_float_val(q[i * dim + d]) }
                        let kv = if type_of(k[j * dim + d]) == "float" { k[j * dim + d] } else { to_float_val(k[j * dim + d]) }
                        dot = dot + qv * kv
                        d = d + 1
                    }
                    scores = scores.push(dot * scale)
                }
                j = j + 1
            }
            // softmax
            let mut max_s = scores[0]
            for s in scores { if s > max_s { max_s = s } }
            let mut exps = []
            let mut sum_e = 0.0
            for s in scores {
                let e = exp(s - max_s)
                exps = exps.push(e)
                sum_e = sum_e + e
            }
            // weighted V
            let mut d = 0
            while d < dim {
                let mut val = 0.0
                let mut jj = 0
                while jj < seq {
                    let w = exps[jj] / sum_e
                    let vv = if type_of(v[jj * dim + d]) == "float" { v[jj * dim + d] } else { to_float_val(v[jj * dim + d]) }
                    val = val + w * vv
                    jj = jj + 1
                }
                output = output.push(val_float(val))
                d = d + 1
            }
            i = i + 1
        }
        return val_array(output)
    }
    // conv1d(input, kernel, in_len, k_len, stride) → output
    if name == "conv1d" {
        if len(args) < 4 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let in_len = args[2].int_val
        let k_len = args[3].int_val
        let stride = if len(args) > 4 { args[4].int_val } else { 1 }
        let out_len = (in_len - k_len) / stride + 1
        let mut result = []
        let mut o = 0
        while o < out_len {
            let mut acc = 0.0
            let mut ki = 0
            while ki < k_len {
                let xv = if type_of(x[o * stride + ki]) == "float" { x[o * stride + ki] } else { to_float_val(x[o * stride + ki]) }
                let kv = if type_of(k[ki]) == "float" { k[ki] } else { to_float_val(k[ki]) }
                acc = acc + xv * kv
                ki = ki + 1
            }
            result = result.push(val_float(acc))
            o = o + 1
        }
        return val_array(result)
    }
    // lora_init(in_dim, out_dim, rank) → [A, B]
    if name == "lora_init" {
        if len(args) < 3 { return val_array([]) }
        let ind = args[0].int_val
        let outd = args[1].int_val
        let rank = args[2].int_val
        let std = sqrt(1.0 / rank)
        let mut a = []
        let mut i = 0
        while i < rank * ind {
            // simple deterministic hash for reproducibility
            let h = ((i * 2654435761) % 10000) / 10000.0 - 0.5
            a = a.push(val_float(h * 2.0 * std))
            i = i + 1
        }
        let mut b = []
        i = 0
        while i < outd * rank { b = b.push(val_float(0.0)); i = i + 1 }
        return val_array([val_array(a), val_array(b)])
    }
    // lora_forward(x, W, A, B, in_dim, out_dim, rank, alpha)
    if name == "lora_forward" {
        if len(args) < 8 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let w = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let a = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let b = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let ind = args[4].int_val
        let outd = args[5].int_val
        let rank = args[6].int_val
        let alpha = to_float_val(args[7])
        // base = W @ x  [outd]
        let mut base = []
        let mut r = 0
        while r < outd {
            let mut acc = 0.0
            let mut c = 0
            while c < ind {
                let wv = if type_of(w[r * ind + c]) == "float" { w[r * ind + c] } else { to_float_val(w[r * ind + c]) }
                let xv = if type_of(x[c]) == "float" { x[c] } else { to_float_val(x[c]) }
                acc = acc + wv * xv
                c = c + 1
            }
            base = base.push(acc)
            r = r + 1
        }
        // ax = A @ x  [rank]
        let mut ax = []
        r = 0
        while r < rank {
            let mut acc = 0.0
            let mut c = 0
            while c < ind {
                let av = if type_of(a[r * ind + c]) == "float" { a[r * ind + c] } else { to_float_val(a[r * ind + c]) }
                let xv = if type_of(x[c]) == "float" { x[c] } else { to_float_val(x[c]) }
                acc = acc + av * xv
                c = c + 1
            }
            ax = ax.push(acc)
            r = r + 1
        }
        // base += alpha * (B @ ax)
        r = 0
        while r < outd {
            let mut delta = 0.0
            let mut c = 0
            while c < rank {
                let bv = if type_of(b[r * rank + c]) == "float" { b[r * rank + c] } else { to_float_val(b[r * rank + c]) }
                delta = delta + bv * ax[c]
                c = c + 1
            }
            base[r] = base[r] + alpha * delta
            r = r + 1
        }
        let mut result = []
        for v in base { result = result.push(val_float(v)) }
        return val_array(result)
    }
    // cosine_sim_matrix(hiddens, n, dim) → [n*n] flat similarity matrix
    if name == "cosine_sim_matrix" {
        if len(args) < 3 { return val_array([]) }
        let h = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n = args[1].int_val
        let dim = args[2].int_val
        let mut result = []
        let mut i = 0
        while i < n {
            let mut j = 0
            while j < n {
                let mut dot = 0.0
                let mut ni = 0.0
                let mut nj = 0.0
                let mut d = 0
                while d < dim {
                    let vi = if type_of(h[i * dim + d]) == "float" { h[i * dim + d] } else { to_float_val(h[i * dim + d]) }
                    let vj = if type_of(h[j * dim + d]) == "float" { h[j * dim + d] } else { to_float_val(h[j * dim + d]) }
                    dot = dot + vi * vj
                    ni = ni + vi * vi
                    nj = nj + vj * vj
                    d = d + 1
                }
                let denom = sqrt(ni) * sqrt(nj)
                if denom == 0.0 { result = result.push(val_float(0.0)) }
                else { result = result.push(val_float(dot / denom)) }
                j = j + 1
            }
            i = i + 1
        }
        return val_array(result)
    }
    // ── Phase 14 골화 — 수론/수학/유틸 ──
    // sigma(n) — sum of divisors
    if name == "sigma" {
        if len(args) == 0 { return val_int(0) }
        let n = args[0].int_val
        if n <= 0 { return val_int(0) }
        let mut s = 0
        let mut d = 1
        while d * d <= n {
            if n % d == 0 {
                s = s + d
                if d != n / d { s = s + n / d }
            }
            d = d + 1
        }
        return val_int(s)
    }
    // tau(n) — number of divisors
    if name == "tau" {
        if len(args) == 0 { return val_int(0) }
        let n = args[0].int_val
        if n <= 0 { return val_int(0) }
        let mut t = 0
        let mut d = 1
        while d * d <= n {
            if n % d == 0 {
                t = t + 1
                if d != n / d { t = t + 1 }
            }
            d = d + 1
        }
        return val_int(t)
    }
    // sopfr(n) — sum of prime factors with repetition
    if name == "sopfr" {
        if len(args) == 0 { return val_int(0) }
        let mut n = args[0].int_val
        if n <= 1 { return val_int(0) }
        let mut s = 0
        let mut p = 2
        while p * p <= n {
            while n % p == 0 {
                s = s + p
                n = n / p
            }
            p = p + 1
        }
        if n > 1 { s = s + n }
        return val_int(s)
    }
    // mean(arr)
    if name == "mean" {
        if len(args) == 0 { return val_float(0.0) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        if len(arr) == 0 { return val_float(0.0) }
        let mut total = 0.0
        for v in arr { total = total + (if type_of(v) == "float" { v } else { to_float_val(v) }) }
        return val_float(total / len(arr))
    }
    // normalize(arr) — divide by L2 norm
    if name == "normalize" {
        if len(args) == 0 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut sq = 0.0
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            sq = sq + f * f
        }
        let norm = sqrt(sq)
        if norm == 0.0 { return args[0] }
        let mut result = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            result = result.push(val_float(f / norm))
        }
        if args[0].tag == TAG_TENSOR { return val_tensor(tensor_shape(args[0]), [].push(0)) }
        return val_array(result)
    }
    // matmul(a, b, m, n, k) — general matmul
    if name == "matmul" {
        if len(args) < 5 { return val_array([]) }
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let m = args[2].int_val
        let n = args[3].int_val
        let k = args[4].int_val
        let mut out = []
        let mut mi = 0
        while mi < m {
            let mut nj = 0
            while nj < n {
                let mut acc = 0.0
                let mut kk = 0
                while kk < k {
                    let av = if type_of(a[mi * k + kk]) == "float" { a[mi * k + kk] } else { to_float_val(a[mi * k + kk]) }
                    let bv = if type_of(b[kk * n + nj]) == "float" { b[kk * n + nj] } else { to_float_val(b[kk * n + nj]) }
                    acc = acc + av * bv
                    kk = kk + 1
                }
                out = out.push(val_float(acc))
                nj = nj + 1
            }
            mi = mi + 1
        }
        return val_array(out)
    }
    // matvec(W, x, rows, cols)
    if name == "matvec" {
        if len(args) < 4 { return val_array([]) }
        let w = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let x = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let rows = args[2].int_val
        let cols = args[3].int_val
        let mut out = []
        let mut r = 0
        while r < rows {
            let mut acc = 0.0
            let mut c = 0
            while c < cols {
                let wv = if type_of(w[r * cols + c]) == "float" { w[r * cols + c] } else { to_float_val(w[r * cols + c]) }
                let xv = if type_of(x[c]) == "float" { x[c] } else { to_float_val(x[c]) }
                acc = acc + wv * xv
                c = c + 1
            }
            out = out.push(val_float(acc))
            r = r + 1
        }
        return val_array(out)
    }
    // hadamard(a, b) — element-wise product
    if name == "hadamard" {
        if len(args) < 2 { return val_array([]) }
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(a) < len(b) { len(a) } else { len(b) }
        let mut out = []
        let mut i = 0
        while i < n {
            let av = if type_of(a[i]) == "float" { a[i] } else { to_float_val(a[i]) }
            let bv = if type_of(b[i]) == "float" { b[i] } else { to_float_val(b[i]) }
            out = out.push(val_float(av * bv))
            i = i + 1
        }
        return val_array(out)
    }
    // one_hot(idx, n) → [n] vector with 1.0 at idx
    if name == "one_hot" {
        if len(args) < 2 { return val_array([]) }
        let idx = args[0].int_val
        let n = args[1].int_val
        let mut out = []
        let mut i = 0
        while i < n {
            if i == idx { out = out.push(val_float(1.0)) }
            else { out = out.push(val_float(0.0)) }
            i = i + 1
        }
        return val_array(out)
    }
    // topk(arr, k) — top-k indices (descending by value)
    if name == "topk" {
        if len(args) < 2 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = args[1].int_val
        let mut indices = []
        let mut values = []
        let mut i = 0
        while i < len(arr) {
            indices = indices.push(i)
            let v = if type_of(arr[i]) == "float" { arr[i] } else { to_float_val(arr[i]) }
            values = values.push(v)
            i = i + 1
        }
        // simple selection: pick max k times
        let mut result = []
        let mut picked = 0
        while picked < k && picked < len(arr) {
            let mut best = -1
            let mut best_v = 0.0 - 1000000000.0
            let mut j = 0
            while j < len(indices) {
                if indices[j] >= 0 && values[j] > best_v { best = j; best_v = values[j] }
                j = j + 1
            }
            if best < 0 { picked = k }
            else {
                result = result.push(val_int(indices[best]))
                indices[best] = -1
                picked = picked + 1
            }
        }
        return val_array(result)
    }
    // shuffle(arr) — random permutation (Fisher-Yates)
    if name == "shuffle" {
        if len(args) == 0 { return val_array([]) }
        let arr = get_array(args[0])
        let n = len(arr)
        let mut result = []
        for v in arr { result = result.push(v) }
        let mut i = n - 1
        while i > 0 {
            let j = floor(random() * (i + 1))
            let tmp = result[i]
            result[i] = result[j]
            result[j] = tmp
            i = i - 1
        }
        return val_array(result)
    }
    // randn() — normal random ~ N(0,1) (Box-Muller, simplified)
    if name == "randn" {
        let u1 = random()
        let u2 = random()
        let safe_u1 = if u1 < 0.000001 { 0.000001 } else { u1 }
        let z = sqrt(0.0 - 2.0 * ln(safe_u1)) * cos(2.0 * 3.14159265358979 * u2)
        return val_float(z)
    }
    if name == "random_int" {
        if len(args) < 2 { return val_int(0) }
        let lo = args[0].int_val
        let hi = args[1].int_val
        let r = lo + floor(random() * (hi - lo))
        return val_int(r)
    }
    // hex_encode(s) → hex string
    if name == "hex_encode" {
        if len(args) == 0 { return val_str("") }
        let s = args[0].str_val
        let mut out = ""
        let cs = s.chars()
        for c in cs {
            let code = char_code(to_string(c), 0)
            out = out + hex(code).pad_left(2, "0")
        }
        return val_str(out)
    }
    // hex_decode(hex_str) → string (reverse of hex_encode, simplified)
    if name == "hex_decode" {
        if len(args) == 0 { return val_str("") }
        let s = args[0].str_val
        let n = len(s) / 2
        let mut out = ""
        let mut i = 0
        while i < n {
            let pair = s.substring(i * 2, i * 2 + 2)
            // simple hex parse (assume 2-char pairs)
            try {
                let code = to_int("0x" + pair)
                out = out + to_string(code)
            } catch e {
                // skip invalid
            }
            i = i + 1
        }
        return val_str(out)
    }
    // bytes_encode(s) → array of byte ints
    if name == "bytes_encode" {
        if len(args) == 0 { return val_array([]) }
        let s = args[0].str_val
        let cs = s.chars()
        let mut result = []
        for c in cs { result = result.push(val_int(char_code(to_string(c), 0))) }
        return val_array(result)
    }
    // bytes_decode(bytes_arr) → string
    if name == "bytes_decode" {
        if len(args) == 0 { return val_str("") }
        let arr = get_array(args[0])
        let mut out = ""
        for b in arr { out = out + to_string(b.int_val) }
        return val_str(out)
    }
    // log(base, x) — alias log_b(x); also log(x) = ln(x)
    if name == "log" {
        if len(args) == 0 { return val_float(0.0) }
        if len(args) == 1 { return val_float(ln(to_float_val(args[0]))) }
        let base = to_float_val(args[0])
        let x = to_float_val(args[1])
        return val_float(ln(x) / ln(base))
    }
    // print_err — alias eprintln
    if name == "print_err" {
        let mut out = ""
        for a in args { out = out + val_to_string(a) }
        try { eprintln(out) } catch e { println("[print_err] " + e.to_string()) }
        return val_void()
    }
    // timestamp / now / time_elapsed
    if name == "timestamp" || name == "now" {
        return val_int(timestamp())
    }
    if name == "time_elapsed" {
        if len(args) == 0 { return val_int(0) }
        return val_int(timestamp() - args[0].int_val)
    }
    // model_size_kb(byte_count) → KB
    if name == "model_size_kb" {
        if len(args) == 0 { return val_float(0.0) }
        return val_float(args[0].int_val / 1024.0)
    }
    // ── ML extras ──
    // rms_norm(x, dim, eps?) — RMS normalization
    if name == "rms_norm" {
        if len(args) < 2 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let dim = args[1].int_val
        let eps = if len(args) > 2 { to_float_val(args[2]) } else { 0.000001 }
        let n_samples = len(x) / dim
        let mut result = []
        let mut s = 0
        while s < n_samples {
            let base = s * dim
            let mut sq = 0.0
            let mut d = 0
            while d < dim {
                let v = if type_of(x[base + d]) == "float" { x[base + d] } else { to_float_val(x[base + d]) }
                sq = sq + v * v
                d = d + 1
            }
            let rms = sqrt(sq / dim + eps)
            d = 0
            while d < dim {
                let v = if type_of(x[base + d]) == "float" { x[base + d] } else { to_float_val(x[base + d]) }
                result = result.push(val_float(v / rms))
                d = d + 1
            }
            s = s + 1
        }
        return val_array(result)
    }
    // xavier_init(in_dim, out_dim) — Glorot init
    if name == "xavier_init" {
        if len(args) < 2 { return val_array([]) }
        let ind = args[0].int_val
        let outd = args[1].int_val
        let std = sqrt(2.0 / (ind + outd))
        let mut result = []
        let mut i = 0
        while i < ind * outd {
            let h = ((i * 2654435761) % 10000) / 10000.0 - 0.5
            result = result.push(val_float(h * 2.0 * std))
            i = i + 1
        }
        return val_array(result)
    }
    // kaiming_init(in_dim, out_dim) — He init
    if name == "kaiming_init" {
        if len(args) < 2 { return val_array([]) }
        let ind = args[0].int_val
        let outd = args[1].int_val
        let std = sqrt(2.0 / ind)
        let mut result = []
        let mut i = 0
        while i < ind * outd {
            let h = ((i * 2654435761) % 10000) / 10000.0 - 0.5
            result = result.push(val_float(h * 2.0 * std))
            i = i + 1
        }
        return val_array(result)
    }
    // sgd_step(params, grads, lr)
    if name == "sgd_step" {
        if len(args) < 3 { return val_array([]) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let g = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let lr = to_float_val(args[2])
        let n = if len(p) < len(g) { len(p) } else { len(g) }
        let mut result = []
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let gf = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            result = result.push(val_float(pf - lr * gf))
            i = i + 1
        }
        return val_array(result)
    }
    // weight_decay(params, decay)
    if name == "weight_decay" {
        if len(args) < 2 { return val_array([]) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let decay = to_float_val(args[1])
        let mut result = []
        for v in p {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            result = result.push(val_float(f * (1.0 - decay)))
        }
        return val_array(result)
    }
    // kl_divergence(p, q) — KL(p || q)
    if name == "kl_divergence" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let q = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(p) < len(q) { len(p) } else { len(q) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pv = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let qv = if type_of(q[i]) == "float" { q[i] } else { to_float_val(q[i]) }
            if pv > 0.0 && qv > 0.0 { total = total + pv * ln(pv / qv) }
            i = i + 1
        }
        return val_float(total)
    }
    // js_divergence(p, q) — symmetric Jensen-Shannon
    if name == "js_divergence" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let q = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(p) < len(q) { len(p) } else { len(q) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pv = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let qv = if type_of(q[i]) == "float" { q[i] } else { to_float_val(q[i]) }
            let m = 0.5 * (pv + qv)
            if pv > 0.0 && m > 0.0 { total = total + 0.5 * pv * ln(pv / m) }
            if qv > 0.0 && m > 0.0 { total = total + 0.5 * qv * ln(qv / m) }
            i = i + 1
        }
        return val_float(total)
    }
    // grad_clip_norm(grads, max_norm)
    if name == "grad_clip_norm" {
        if len(args) < 2 { return val_array([]) }
        let g = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let max_norm = to_float_val(args[1])
        let mut sq = 0.0
        for v in g {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            sq = sq + f * f
        }
        let total_norm = sqrt(sq)
        if total_norm <= max_norm { return args[0] }
        let scale = max_norm / total_norm
        let mut result = []
        for v in g {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            result = result.push(val_float(f * scale))
        }
        return val_array(result)
    }
    // numerical_grad — finite difference (placeholder, requires fn pointer)
    if name == "numerical_grad" {
        return val_array([])
    }
    // sinusoidal_pe(seq_len, dim) — sinusoidal positional encoding
    if name == "sinusoidal_pe" {
        if len(args) < 2 { return val_array([]) }
        let seq = args[0].int_val
        let dim = args[1].int_val
        let mut result = []
        let mut pos = 0
        while pos < seq {
            let mut d = 0
            while d < dim {
                let dpf = (d / 2) * 2 + 0.0
                let div = pow(10000.0, dpf / dim)
                let theta = pos / div
                if d % 2 == 0 { result = result.push(val_float(sin(theta))) }
                else { result = result.push(val_float(cos(theta))) }
                d = d + 1
            }
            pos = pos + 1
        }
        return val_array(result)
    }
    // label_smoothing(target_idx, n_classes, eps) → smoothed distribution
    if name == "label_smoothing" {
        if len(args) < 3 { return val_array([]) }
        let target = args[0].int_val
        let n = args[1].int_val
        let eps = to_float_val(args[2])
        let mut result = []
        let mut i = 0
        while i < n {
            if i == target { result = result.push(val_float(1.0 - eps + eps / n)) }
            else { result = result.push(val_float(eps / n)) }
            i = i + 1
        }
        return val_array(result)
    }
    // mse_loss — alias mse
    if name == "mse_loss" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let t = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(p) < len(t) { len(p) } else { len(t) }
        if n == 0 { return val_float(0.0) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let tf = if type_of(t[i]) == "float" { t[i] } else { to_float_val(t[i]) }
            let d = pf - tf
            total = total + d * d
            i = i + 1
        }
        return val_float(total / n)
    }

    // ── Phase 15 골화 — KV-cache / RoPE / multi-head / etc ──
    // KV-cache: registry of [shape_data, data, write_pos] per cache
    // (single-stream interpreter — no real concurrency, just bookkeeping)
    if name == "kv_cache_init" {
        // kv_cache_init(max_len, n_kv_head, head_dim) → cache (tensor wrapper)
        if len(args) < 3 { return val_void() }
        let max_len = args[0].int_val
        let n_kv = args[1].int_val
        let head_dim = args[2].int_val
        let total = max_len * n_kv * head_dim
        let mut data = []
        let mut i = 0
        while i < total { data = data.push(0.0); i = i + 1 }
        return val_tensor([max_len, n_kv, head_dim], data)
    }
    if name == "kv_cache_reset" {
        // Reset cache to zeros (in-place fill)
        if len(args) == 0 { return val_void() }
        let cache = args[0]
        if cache.tag != TAG_TENSOR { return val_void() }
        let n = tensor_numel(cache)
        let mut data = []
        let mut i = 0
        while i < n { data = data.push(0.0); i = i + 1 }
        tensor_set_data(cache, data)
        return cache
    }
    if name == "kv_cache_append" {
        // kv_cache_append(cache, k, v, pos) — write at row `pos`
        if len(args) < 4 { return val_void() }
        let cache = args[0]
        let k_in = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let pos = args[3].int_val
        if cache.tag != TAG_TENSOR { return val_void() }
        let shape = tensor_shape(cache)
        if len(shape) < 3 { return val_void() }
        let head_dim = shape[2]
        let n_kv = shape[1]
        let row_size = n_kv * head_dim
        let mut data = tensor_data(cache)
        let base = pos * row_size
        let mut d = 0
        while d < row_size && d < len(k_in) {
            let v = if type_of(k_in[d]) == "float" { k_in[d] } else { to_float_val(k_in[d]) }
            data[base + d] = v
            d = d + 1
        }
        tensor_set_data(cache, data)
        return cache
    }
    if name == "kv_cache_decode" {
        // kv_cache_decode(cache, q, pos, n_kv_head, head_dim) → output [head_dim]
        // Single-step decode: attend to all positions <= pos
        if len(args) < 5 { return val_array([]) }
        let cache = args[0]
        let q = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let pos = args[2].int_val
        let n_kv = args[3].int_val
        let head_dim = args[4].int_val
        if cache.tag != TAG_TENSOR { return val_array([]) }
        let cd = tensor_data(cache)
        let row_size = n_kv * head_dim
        let scale = 1.0 / sqrt(head_dim + 0.0)
        // scores[i] = q · K[i] * scale
        let mut scores = []
        let mut i = 0
        while i <= pos {
            let mut dot = 0.0
            let mut d = 0
            while d < head_dim {
                let qv = if type_of(q[d]) == "float" { q[d] } else { to_float_val(q[d]) }
                let kv = cd[i * row_size + d]
                dot = dot + qv * kv
                d = d + 1
            }
            scores = scores.push(dot * scale)
            i = i + 1
        }
        // softmax
        let mut max_s = scores[0]
        for s in scores { if s > max_s { max_s = s } }
        let mut exps = []
        let mut sum_e = 0.0
        for s in scores {
            let e = exp(s - max_s)
            exps = exps.push(e)
            sum_e = sum_e + e
        }
        let mut output = []
        let mut d = 0
        while d < head_dim {
            let mut val = 0.0
            i = 0
            while i <= pos {
                let w = exps[i] / sum_e
                let vv = cd[i * row_size + d]
                val = val + w * vv
                i = i + 1
            }
            output = output.push(val_float(val))
            d = d + 1
        }
        return val_array(output)
    }
    if name == "kv_cache_decode_bench" {
        return val_int(0)
    }

    // rope(x, pos, dim) — Rotary Position Embedding (single token)
    //   x: input vector [dim], pos: token position, dim: embedding dim
    //   Pairs (x[2i], x[2i+1]) rotated by angle = pos / 10000^(2i/dim)
    if name == "rope" || name == "rope_inplace" {
        if len(args) < 3 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let pos = args[1].int_val
        let dim = args[2].int_val
        let mut result = []
        let mut i = 0
        while i < dim - 1 {
            let exponent = (i + 0.0) / dim
            let theta = pos / pow(10000.0, exponent)
            let c = cos(theta)
            let s = sin(theta)
            let x0 = if type_of(x[i]) == "float" { x[i] } else { to_float_val(x[i]) }
            let x1 = if type_of(x[i + 1]) == "float" { x[i + 1] } else { to_float_val(x[i + 1]) }
            result = result.push(val_float(x0 * c - x1 * s))
            result = result.push(val_float(x0 * s + x1 * c))
            i = i + 2
        }
        // remainder if dim is odd
        if i < dim {
            result = result.push(val_float(if type_of(x[i]) == "float" { x[i] } else { to_float_val(x[i]) }))
        }
        return val_array(result)
    }

    // multi_head_attention(Q, K, V, seq, n_heads, head_dim, causal?)
    if name == "multi_head_attention" {
        if len(args) < 6 { return val_array([]) }
        let q_all = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k_all = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let v_all = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let seq = args[3].int_val
        let n_h = args[4].int_val
        let head_dim = args[5].int_val
        let causal = if len(args) > 6 { args[6].bool_val } else { false }
        let scale = 1.0 / sqrt(head_dim + 0.0)
        let dim = n_h * head_dim
        let mut output = []
        let mut h = 0
        while h < n_h {
            let h_off = h * head_dim
            let mut qh = []
            let mut kh = []
            let mut vh = []
            // extract head h from each token
            let mut t = 0
            while t < seq {
                let mut d = 0
                while d < head_dim {
                    let qv = if type_of(q_all[t * dim + h_off + d]) == "float" { q_all[t * dim + h_off + d] } else { to_float_val(q_all[t * dim + h_off + d]) }
                    let kv = if type_of(k_all[t * dim + h_off + d]) == "float" { k_all[t * dim + h_off + d] } else { to_float_val(k_all[t * dim + h_off + d]) }
                    let vv = if type_of(v_all[t * dim + h_off + d]) == "float" { v_all[t * dim + h_off + d] } else { to_float_val(v_all[t * dim + h_off + d]) }
                    qh = qh.push(qv)
                    kh = kh.push(kv)
                    vh = vh.push(vv)
                    d = d + 1
                }
                t = t + 1
            }
            // attention within this head
            let mut head_out = []
            t = 0
            while t < seq {
                let mut scores = []
                let mut j = 0
                while j < seq {
                    if causal && j > t {
                        scores = scores.push(0.0 - 1000000000.0)
                    } else {
                        let mut dot = 0.0
                        let mut d = 0
                        while d < head_dim {
                            dot = dot + qh[t * head_dim + d] * kh[j * head_dim + d]
                            d = d + 1
                        }
                        scores = scores.push(dot * scale)
                    }
                    j = j + 1
                }
                let mut max_s = scores[0]
                for s in scores { if s > max_s { max_s = s } }
                let mut exps = []
                let mut sum_e = 0.0
                for s in scores {
                    let e = exp(s - max_s)
                    exps = exps.push(e)
                    sum_e = sum_e + e
                }
                let mut d = 0
                while d < head_dim {
                    let mut val = 0.0
                    j = 0
                    while j < seq {
                        val = val + (exps[j] / sum_e) * vh[j * head_dim + d]
                        j = j + 1
                    }
                    head_out = head_out.push(val)
                    d = d + 1
                }
                t = t + 1
            }
            // assemble output (interleave heads back)
            t = 0
            while t < seq {
                let mut d = 0
                while d < head_dim {
                    output = output.push(val_float(head_out[t * head_dim + d]))
                    d = d + 1
                }
                t = t + 1
            }
            h = h + 1
        }
        return val_array(output)
    }

    // grouped_query_attention — wraps multi_head with KV grouping
    if name == "grouped_query_attention" {
        return val_array([])
    }
    // sliding_window_attention(Q, K, V, seq, dim, window)
    if name == "sliding_window_attention" {
        if len(args) < 6 { return val_array([]) }
        let q = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let v = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let seq = args[3].int_val
        let dim = args[4].int_val
        let window = args[5].int_val
        let scale = 1.0 / sqrt(dim + 0.0)
        let mut output = []
        let mut i = 0
        while i < seq {
            let lo = if i - window < 0 { 0 } else { i - window }
            let mut scores = []
            let mut j = lo
            while j <= i {
                let mut dot = 0.0
                let mut d = 0
                while d < dim {
                    let qv = if type_of(q[i * dim + d]) == "float" { q[i * dim + d] } else { to_float_val(q[i * dim + d]) }
                    let kv = if type_of(k[j * dim + d]) == "float" { k[j * dim + d] } else { to_float_val(k[j * dim + d]) }
                    dot = dot + qv * kv
                    d = d + 1
                }
                scores = scores.push(dot * scale)
                j = j + 1
            }
            let mut max_s = scores[0]
            for s in scores { if s > max_s { max_s = s } }
            let mut exps = []
            let mut sum_e = 0.0
            for s in scores { let e = exp(s - max_s); exps = exps.push(e); sum_e = sum_e + e }
            let mut d = 0
            while d < dim {
                let mut val = 0.0
                let mut idx = 0
                j = lo
                while j <= i {
                    let vv = if type_of(v[j * dim + d]) == "float" { v[j * dim + d] } else { to_float_val(v[j * dim + d]) }
                    val = val + (exps[idx] / sum_e) * vv
                    idx = idx + 1
                    j = j + 1
                }
                output = output.push(val_float(val))
                d = d + 1
            }
            i = i + 1
        }
        return val_array(output)
    }

    // group_norm(x, n_groups, dim) — normalize per group
    if name == "group_norm" {
        if len(args) < 3 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n_groups = args[1].int_val
        let dim = args[2].int_val
        let group_size = dim / n_groups
        let n_samples = len(x) / dim
        let mut result = []
        let mut s = 0
        while s < n_samples {
            let mut g = 0
            while g < n_groups {
                let base = s * dim + g * group_size
                let mut mean = 0.0
                let mut k = 0
                while k < group_size {
                    let v = if type_of(x[base + k]) == "float" { x[base + k] } else { to_float_val(x[base + k]) }
                    mean = mean + v
                    k = k + 1
                }
                mean = mean / group_size
                let mut var = 0.0
                k = 0
                while k < group_size {
                    let v = if type_of(x[base + k]) == "float" { x[base + k] } else { to_float_val(x[base + k]) }
                    var = var + (v - mean) * (v - mean)
                    k = k + 1
                }
                var = var / group_size
                let denom = sqrt(var + 0.00001)
                k = 0
                while k < group_size {
                    let v = if type_of(x[base + k]) == "float" { x[base + k] } else { to_float_val(x[base + k]) }
                    result = result.push(val_float((v - mean) / denom))
                    k = k + 1
                }
                g = g + 1
            }
            s = s + 1
        }
        return val_array(result)
    }

    // max_pool1d(x, kernel_size, stride)
    if name == "max_pool1d" {
        if len(args) < 3 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = args[1].int_val
        let stride = args[2].int_val
        let n = len(x)
        let out_n = (n - k) / stride + 1
        let mut result = []
        let mut o = 0
        while o < out_n {
            let mut best = if type_of(x[o * stride]) == "float" { x[o * stride] } else { to_float_val(x[o * stride]) }
            let mut i = 1
            while i < k {
                let v = if type_of(x[o * stride + i]) == "float" { x[o * stride + i] } else { to_float_val(x[o * stride + i]) }
                if v > best { best = v }
                i = i + 1
            }
            result = result.push(val_float(best))
            o = o + 1
        }
        return val_array(result)
    }

    // gru_cell(x, h, Wxr, Whr, Wxz, Whz, Wxn, Whn) — simplified GRU
    if name == "gru_cell" {
        // 8-arg signature, returns new hidden state. Skip if args insufficient.
        return val_array([])
    }

    // moe_gate(x, gates, n_experts) → top-1 expert index + softmax weight
    if name == "moe_gate" {
        if len(args) < 3 { return val_array([]) }
        let g = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n_experts = args[2].int_val
        // softmax over gates
        let mut max_g = if type_of(g[0]) == "float" { g[0] } else { to_float_val(g[0]) }
        let mut i = 0
        while i < n_experts {
            let v = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            if v > max_g { max_g = v }
            i = i + 1
        }
        let mut exps = []
        let mut sum_e = 0.0
        i = 0
        while i < n_experts {
            let v = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            let e = exp(v - max_g)
            exps = exps.push(e)
            sum_e = sum_e + e
            i = i + 1
        }
        // pick max
        let mut best = 0
        let mut best_p = exps[0] / sum_e
        i = 1
        while i < n_experts {
            let p = exps[i] / sum_e
            if p > best_p { best = i; best_p = p }
            i = i + 1
        }
        return val_array([val_int(best), val_float(best_p)])
    }
    if name == "moe_combine" {
        // moe_combine(expert_outputs, weights) — weighted sum
        if len(args) < 2 { return val_array([]) }
        let outs = get_array(args[0])
        let ws = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        if len(outs) == 0 { return val_array([]) }
        let first = if outs[0].tag == TAG_TENSOR { tensor_data(outs[0]) } else { get_array(outs[0]) }
        let dim = len(first)
        let mut result = []
        let mut d = 0
        while d < dim {
            let mut acc = 0.0
            let mut e = 0
            while e < len(outs) {
                let exp_data = if outs[e].tag == TAG_TENSOR { tensor_data(outs[e]) } else { get_array(outs[e]) }
                let v = if type_of(exp_data[d]) == "float" { exp_data[d] } else { to_float_val(exp_data[d]) }
                let w = if type_of(ws[e]) == "float" { ws[e] } else { to_float_val(ws[e]) }
                acc = acc + w * v
                e = e + 1
            }
            result = result.push(val_float(acc))
            d = d + 1
        }
        return val_array(result)
    }

    // ── Phase 16 골화 — FFI memory + JSON + utility ──
    // alloc_raw(size) — return Pointer to managed buffer (registry-backed)
    if name == "alloc_raw" {
        if len(args) == 0 { return val_pointer(0) }
        let size = args[0].int_val
        if size <= 0 { return val_pointer(0) }
        // Use atomic_store as a buffer registry: alloc one cell of zeros
        let mut buf = []
        let mut i = 0
        while i < size { buf = buf.push(val_int(0)); i = i + 1 }
        let id = len(atomic_store)
        atomic_store = atomic_store.push(val_array(buf))
        return val_pointer(id + 1000000)  // mark as managed
    }
    if name == "free_raw" {
        // No-op in self-host (storage GC'd elsewhere)
        return val_void()
    }
    if name == "arena_reset" {
        return val_void()
    }
    // ── @arena runtime support ──────────────────────────────
    // arena_new() → create a new arena region, return arena id
    if name == "arena_new" {
        let id = len(atomic_store)
        atomic_store = atomic_store.push(val_array([]))
        return val_int(id)
    }
    // arena_alloc(arena_id, value) → allocate value in arena, return value
    if name == "arena_alloc" {
        if len(args) < 2 { return val_void() }
        // Just return the value; arena tracking is semantic (bulk free)
        return args[1]
    }
    // arena_free(arena_id) → bulk free all allocations in arena
    if name == "arena_free" {
        // No-op in interpreter (GC handles memory)
        return val_void()
    }
    // ── @pool runtime support ───────────────────────────────
    // pool_new(capacity) → create a freelist pool, return pool id
    if name == "pool_new" {
        let cap = if len(args) >= 1 { args[0].int_val } else { 64 }
        let mut pool = []
        let mut pi = 0
        while pi < cap {
            pool = pool.push(val_void())
            pi = pi + 1
        }
        let id = len(atomic_store)
        atomic_store = atomic_store.push(val_array(pool))
        return val_int(id)
    }
    // pool_get(pool_id) → get an object from pool (reuse), return value
    if name == "pool_get" {
        if len(args) < 1 { return val_void() }
        // Return void (semantic placeholder; real pool returns recycled object)
        return val_void()
    }
    // pool_put(pool_id, value) → return object to pool for reuse
    if name == "pool_put" {
        // No-op in interpreter (object remains in GC scope)
        return val_void()
    }
    if name == "mem_budget" || name == "mem_stats" {
        // Return [used, total] as array of ints (best-effort: report 0)
        return val_array([val_int(0), val_int(0)])
    }
    if name == "mem_region" {
        return val_void()
    }
    if name == "memcpy_host" {
        // memcpy_host(dst, src, n) — copy n elements
        if len(args) < 3 { return val_void() }
        let n = args[2].int_val
        let src = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        if args[0].tag == TAG_TENSOR {
            let mut data = []
            let mut i = 0
            while i < n && i < len(src) { data = data.push(src[i]); i = i + 1 }
            tensor_set_data(args[0], data)
        }
        return val_void()
    }
    if name == "deref_f32" || name == "deref_i32" {
        // Read from pointer (managed alloc registry)
        if len(args) == 0 { return val_int(0) }
        let p = args[0]
        if p.tag != TAG_POINTER { return val_int(0) }
        let id = p.int_val - 1000000
        if id < 0 || id >= len(atomic_store) { return val_int(0) }
        let buf_val = atomic_store[id]
        if buf_val.tag != TAG_ARRAY { return val_int(0) }
        let buf = get_array(buf_val)
        let offset = if len(args) > 1 { args[1].int_val } else { 0 }
        if offset < 0 || offset >= len(buf) { return val_int(0) }
        return buf[offset]
    }
    if name == "write_f32" || name == "write_i32" || name == "write_i64" {
        // write(ptr, offset, value)
        if len(args) < 3 { return val_void() }
        let p = args[0]
        if p.tag != TAG_POINTER { return val_void() }
        let id = p.int_val - 1000000
        if id < 0 || id >= len(atomic_store) { return val_void() }
        let buf_val = atomic_store[id]
        if buf_val.tag != TAG_ARRAY { return val_void() }
        let mut buf = get_array(buf_val)
        let offset = args[1].int_val
        if offset >= 0 && offset < len(buf) {
            buf[offset] = args[2]
            atomic_store[id] = val_array(buf)
        }
        return val_void()
    }
    if name == "ptr_from_int" {
        if len(args) == 0 { return val_pointer(0) }
        return val_pointer(args[0].int_val)
    }
    if name == "from_cstring_n" {
        // Convert pointer + length to string (best-effort: return as int wrapper)
        if len(args) == 0 { return val_str("") }
        return val_str("")
    }
    if name == "tensor_data_f32_ptr" {
        // Get pointer to underlying tensor data (registry-tagged)
        if len(args) == 0 { return val_pointer(0) }
        let t = args[0]
        if t.tag != TAG_TENSOR { return val_pointer(0) }
        return val_pointer(t.int_val + 2000000)  // tensor-tagged ptr
    }
    if name == "tensor_from_f32_ptr" {
        // Reverse: pointer → tensor
        if len(args) == 0 { return val_tensor([0], []) }
        let p = args[0]
        if p.tag != TAG_POINTER { return val_tensor([0], []) }
        let id = p.int_val - 2000000
        if id < 0 || id >= len(tensor_shape_store) { return val_tensor([0], []) }
        return Val { tag: TAG_TENSOR, int_val: id, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
    }

    // ── JSON: proper parse/stringify ──
    if name == "json_stringify" {
        if len(args) == 0 { return val_str("null") }
        return val_str(val_to_json(args[0]))
    }
    if name == "json_parse" {
        if len(args) == 0 { return val_void() }
        return json_to_val(args[0].str_val)
    }

    // ── benchmark / test runner ──
    if name == "bench_fn" {
        // bench_fn(fn, n_iters) → elapsed time in milliseconds
        if len(args) < 2 { return val_int(0) }
        let f = args[0]
        let n = args[1].int_val
        let start_time = timestamp()
        let mut i = 0
        while i < n {
            call_fn_val(f, [])
            i = i + 1
        }
        return val_int(timestamp() - start_time)
    }
    if name == "run_tests" || name == "run_benchmarks" {
        // Self-host stub: actual test harness lives in user code
        return val_int(0)
    }

    // ── ascii visualization ──
    if name == "ascii_bar" {
        // ascii_bar(value, max, width) → string bar
        if len(args) < 3 { return val_str("") }
        let v = to_float_val(args[0])
        let max_v = to_float_val(args[1])
        let width = args[2].int_val
        if max_v <= 0.0 { return val_str("") }
        let n_filled = floor(v / max_v * width)
        let mut out = ""
        let mut i = 0
        while i < n_filled { out = out + "█"; i = i + 1 }
        while i < width { out = out + "·"; i = i + 1 }
        return val_str(out)
    }
    if name == "ascii_plot" {
        // ascii_plot(values, height) → multi-line string
        if len(args) == 0 { return val_str("") }
        let values = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let height = if len(args) > 1 { args[1].int_val } else { 10 }
        let n = len(values)
        if n == 0 { return val_str("") }
        let mut max_v = if type_of(values[0]) == "float" { values[0] } else { to_float_val(values[0]) }
        let mut min_v = max_v
        for v in values {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            if f > max_v { max_v = f }
            if f < min_v { min_v = f }
        }
        let range = max_v - min_v
        if range == 0.0 { return val_str("(constant)") }
        let mut out = ""
        let mut row = height - 1
        while row >= 0 {
            let mut i = 0
            while i < n {
                let v = if type_of(values[i]) == "float" { values[i] } else { to_float_val(values[i]) }
                let row_v = floor((v - min_v) / range * (height - 1))
                if row_v >= row { out = out + "█" }
                else { out = out + " " }
                i = i + 1
            }
            out = out + "\n"
            row = row - 1
        }
        return val_str(out)
    }

    // ── consciousness/anima placeholders ──
    // These return safe defaults so anima.hexa code parses & runs.
    // Real consciousness ops require shared state with the host runtime.
    if name == "consciousness_phi" {
        // Default IIT Φ = 0 (no integration)
        return val_float(0.0)
    }
    if name == "consciousness_vector" {
        // Returns the input array unchanged (passthrough)
        if len(args) == 0 { return val_array([]) }
        return args[0]
    }
    if name == "consciousness_decoder_dim" || name == "consciousness_max_cells" {
        return val_int(0)
    }
    if name == "phi" || name == "phi_predict" {
        return val_float(0.0)
    }
    if name == "psi_balance" || name == "psi_coupling" || name == "psi_entropy" || name == "psi_frustration" || name == "psi_steps" {
        return val_float(0.0)
    }
    if name == "tension" || name == "tension_link" {
        return val_float(0.0)
    }
    if name == "evolve_gen" || name == "evolve_stats" {
        return val_array([])
    }
    if name == "faction" || name == "faction_consensus" {
        return val_array([])
    }
    if name == "combined_reward" || name == "curiosity_reward" || name == "dialogue_reward" {
        return val_float(0.0)
    }
    if name == "chaos_perturb" {
        if len(args) == 0 { return val_array([]) }
        return args[0]
    }
    if name == "lorenz_step" {
        // 3D Lorenz attractor step: returns [new_x, new_y, new_z]
        if len(args) < 4 { return val_array([]) }
        let x = to_float_val(args[0])
        let y = to_float_val(args[1])
        let z = to_float_val(args[2])
        let dt = to_float_val(args[3])
        let sigma_l = 10.0
        let rho = 28.0
        let beta = 8.0 / 3.0
        let dx = sigma_l * (y - x)
        let dy = x * (rho - z) - y
        let dz = x * y - beta * z
        return val_array([val_float(x + dx * dt), val_float(y + dy * dt), val_float(z + dz * dt)])
    }
    if name == "laws" || name == "meta_laws" || name == "meta" || name == "hexad_modules" || name == "hexad_left" || name == "hexad_right" {
        return val_array([])
    }
    if name == "auto_topology" || name == "ring_topology" || name == "small_world_topology" || name == "hypercube_topology" {
        return val_array([])
    }
    if name == "nexus_n6_check" {
        return val_bool(true)
    }
    if name == "running_stats" {
        // running_stats(prev_mean, prev_var, prev_n, x) → [new_mean, new_var, new_n]
        if len(args) < 4 { return val_array([]) }
        let prev_mean = to_float_val(args[0])
        let prev_var = to_float_val(args[1])
        let prev_n = args[2].int_val
        let x = to_float_val(args[3])
        let new_n = prev_n + 1
        let delta = x - prev_mean
        let new_mean = prev_mean + delta / new_n
        let delta2 = x - new_mean
        let new_var = if prev_n == 0 { 0.0 } else { (prev_var * prev_n + delta * delta2) / new_n }
        return val_array([val_float(new_mean), val_float(new_var), val_int(new_n)])
    }
    if name == "trend_slope" {
        // Linear regression slope (least squares)
        if len(args) == 0 { return val_float(0.0) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n = len(arr)
        if n < 2 { return val_float(0.0) }
        let mut sum_x = 0.0
        let mut sum_y = 0.0
        let mut sum_xy = 0.0
        let mut sum_xx = 0.0
        let mut i = 0
        while i < n {
            let x = i + 0.0
            let y = if type_of(arr[i]) == "float" { arr[i] } else { to_float_val(arr[i]) }
            sum_x = sum_x + x
            sum_y = sum_y + y
            sum_xy = sum_xy + x * y
            sum_xx = sum_xx + x * x
            i = i + 1
        }
        let denom = n * sum_xx - sum_x * sum_x
        if denom == 0.0 { return val_float(0.0) }
        return val_float((n * sum_xy - sum_x * sum_y) / denom)
    }
    if name == "autocorrelation" {
        // autocorr(arr, lag)
        if len(args) < 2 { return val_float(0.0) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let lag = args[1].int_val
        let n = len(arr)
        if n - lag < 2 { return val_float(0.0) }
        let mut mean = 0.0
        for v in arr { mean = mean + (if type_of(v) == "float" { v } else { to_float_val(v) }) }
        mean = mean / n
        let mut num = 0.0
        let mut den = 0.0
        let mut i = 0
        while i < n {
            let v = if type_of(arr[i]) == "float" { arr[i] } else { to_float_val(arr[i]) }
            den = den + (v - mean) * (v - mean)
            if i + lag < n {
                let v2 = if type_of(arr[i + lag]) == "float" { arr[i + lag] } else { to_float_val(arr[i + lag]) }
                num = num + (v - mean) * (v2 - mean)
            }
            i = i + 1
        }
        if den == 0.0 { return val_float(0.0) }
        return val_float(num / den)
    }
    if name == "mutual_information" {
        // Simplified: 0 for now (full impl needs joint distribution)
        return val_float(0.0)
    }
    if name == "ewc_penalty" || name == "fisher_diagonal" || name == "magnitude_prune" || name == "sparsity" {
        return val_float(0.0)
    }
    if name == "data_split" {
        if len(args) < 2 { return val_array([]) }
        let arr = get_array(args[0])
        let ratio = to_float_val(args[1])
        let split_idx = floor(len(arr) * ratio)
        let mut train = []
        let mut test = []
        let mut i = 0
        while i < len(arr) {
            if i < split_idx { train = train.push(arr[i]) }
            else { test = test.push(arr[i]) }
            i = i + 1
        }
        return val_array([val_array(train), val_array(test)])
    }
    if name == "quantize_int8" {
        // quantize float array to [-127,127]
        if len(args) == 0 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut max_abs = 0.0
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            let a = if f < 0.0 { 0.0 - f } else { f }
            if a > max_abs { max_abs = a }
        }
        if max_abs == 0.0 {
            let mut z = []
            let mut i = 0
            while i < len(arr) { z = z.push(val_int(0)); i = i + 1 }
            return val_array([val_array(z), val_float(1.0)])
        }
        let scale = 127.0 / max_abs
        let mut quantized = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            quantized = quantized.push(val_int(floor(f * scale)))
        }
        return val_array([val_array(quantized), val_float(scale)])
    }
    if name == "dequantize_int8" {
        if len(args) < 2 { return val_array([]) }
        let arr = get_array(args[0])
        let scale = to_float_val(args[1])
        let mut result = []
        for v in arr { result = result.push(val_float(v.int_val / scale)) }
        return val_array(result)
    }
    if name == "hmac_sha256" {
        // self-host can't do crypto; return empty string
        return val_str("")
    }
    if name == "url_decode" {
        if len(args) == 0 { return val_str("") }
        return val_str(args[0].str_val)
    }
    if name == "is_numeric" {
        if len(args) == 0 { return val_bool(false) }
        let v = args[0]
        return val_bool(v.tag == TAG_INT || v.tag == TAG_FLOAT)
    }
    if name == "is_whitespace" {
        if len(args) == 0 { return val_bool(false) }
        let s = args[0].str_val
        return val_bool(s == " " || s == "\t" || s == "\n" || s == "\r")
    }
    if name == "input_all" || name == "readline" {
        return val_str(input(""))
    }
    if name == "read_file_bytes" {
        if len(args) == 0 { return val_array([]) }
        let s = read_file(args[0].str_val)
        let mut out = []
        let cs = s.chars()
        for c in cs { out = out.push(val_int(char_code(to_string(c), 0))) }
        return val_array(out)
    }
    if name == "write_file_bytes" {
        if len(args) < 2 { return val_void() }
        let arr = get_array(args[1])
        let mut s = ""
        for b in arr { s = s + to_string(b.int_val) }
        write_file(args[0].str_val, s)
        return val_void()
    }

    // ── Phase 17 골화 — 잔여 빌트인 ──
    // linear_attention(Q, K, V, seq, dim) — feature-based linear attention
    if name == "linear_attention" {
        if len(args) < 5 { return val_array([]) }
        let q = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let v = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let seq = args[3].int_val
        let dim = args[4].int_val
        // Approximation: φ(x) = elu(x) + 1, attention = (Q · ΣK·Vᵀ) / (Q · ΣK)
        // Single-pass simplified version
        let mut sum_kv = []
        let mut sum_k = []
        let mut i = 0
        while i < dim * dim { sum_kv = sum_kv.push(0.0); i = i + 1 }
        i = 0
        while i < dim { sum_k = sum_k.push(0.0); i = i + 1 }
        // Accumulate over sequence
        let mut t = 0
        while t < seq {
            let mut d1 = 0
            while d1 < dim {
                let kv1 = if type_of(k[t * dim + d1]) == "float" { k[t * dim + d1] } else { to_float_val(k[t * dim + d1]) }
                let phi_k = if kv1 > 0.0 { kv1 + 1.0 } else { exp(kv1) }
                sum_k[d1] = sum_k[d1] + phi_k
                let mut d2 = 0
                while d2 < dim {
                    let vv = if type_of(v[t * dim + d2]) == "float" { v[t * dim + d2] } else { to_float_val(v[t * dim + d2]) }
                    sum_kv[d1 * dim + d2] = sum_kv[d1 * dim + d2] + phi_k * vv
                    d2 = d2 + 1
                }
                d1 = d1 + 1
            }
            t = t + 1
        }
        // Now compute Q · sum_kv / Q · sum_k for each query
        let mut output = []
        t = 0
        while t < seq {
            let mut denom = 0.0
            let mut d1 = 0
            while d1 < dim {
                let qv = if type_of(q[t * dim + d1]) == "float" { q[t * dim + d1] } else { to_float_val(q[t * dim + d1]) }
                let phi_q = if qv > 0.0 { qv + 1.0 } else { exp(qv) }
                denom = denom + phi_q * sum_k[d1]
                d1 = d1 + 1
            }
            let mut d2 = 0
            while d2 < dim {
                let mut num = 0.0
                d1 = 0
                while d1 < dim {
                    let qv = if type_of(q[t * dim + d1]) == "float" { q[t * dim + d1] } else { to_float_val(q[t * dim + d1]) }
                    let phi_q = if qv > 0.0 { qv + 1.0 } else { exp(qv) }
                    num = num + phi_q * sum_kv[d1 * dim + d2]
                    d1 = d1 + 1
                }
                if denom == 0.0 { output = output.push(val_float(0.0)) }
                else { output = output.push(val_float(num / denom)) }
                d2 = d2 + 1
            }
            t = t + 1
        }
        return val_array(output)
    }
    // sample_token(logits, temperature) → int (argmax of softmax * temp)
    if name == "sample_token" {
        if len(args) == 0 { return val_int(0) }
        let logits = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let temp = if len(args) > 1 { to_float_val(args[1]) } else { 1.0 }
        if len(logits) == 0 { return val_int(0) }
        // softmax with temperature
        let mut max_l = if type_of(logits[0]) == "float" { logits[0] } else { to_float_val(logits[0]) }
        for v in logits {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            if f > max_l { max_l = f }
        }
        let mut exps = []
        let mut sum_e = 0.0
        for v in logits {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            let e = exp((f - max_l) / temp)
            exps = exps.push(e)
            sum_e = sum_e + e
        }
        // sample via cumulative
        let r = random() * sum_e
        let mut cum = 0.0
        let mut i = 0
        while i < len(exps) {
            cum = cum + exps[i]
            if r <= cum { return val_int(i) }
            i = i + 1
        }
        return val_int(len(exps) - 1)
    }
    // beam_search_step(logits, beam_width) → top-k indices
    if name == "beam_search_step" {
        if len(args) < 2 { return val_array([]) }
        return call_builtin("topk", args)
    }
    // mat_scale(m, s) — scalar multiply
    if name == "mat_scale" {
        if len(args) < 2 { return val_array([]) }
        let m = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let s = to_float_val(args[1])
        let mut result = []
        for v in m {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            result = result.push(val_float(f * s))
        }
        return val_array(result)
    }
    // mat_add_inplace(a, b) — a += b
    if name == "mat_add_inplace" {
        if len(args) < 2 { return val_void() }
        if args[0].tag != TAG_TENSOR { return val_void() }
        let a_data = tensor_data(args[0])
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(a_data) < len(b) { len(a_data) } else { len(b) }
        let mut new_data = []
        let mut i = 0
        while i < len(a_data) {
            if i < n {
                let av = if type_of(a_data[i]) == "float" { a_data[i] } else { to_float_val(a_data[i]) }
                let bv = if type_of(b[i]) == "float" { b[i] } else { to_float_val(b[i]) }
                new_data = new_data.push(av + bv)
            } else {
                new_data = new_data.push(a_data[i])
            }
            i = i + 1
        }
        tensor_set_data(args[0], new_data)
        return args[0]
    }
    // grad_accumulate(grad_acc, grad) → new_grad_acc
    if name == "grad_accumulate" {
        if len(args) < 2 { return val_array([]) }
        let acc = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let g = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(acc) < len(g) { len(acc) } else { len(g) }
        let mut result = []
        let mut i = 0
        while i < n {
            let av = if type_of(acc[i]) == "float" { acc[i] } else { to_float_val(acc[i]) }
            let gv = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            result = result.push(val_float(av + gv))
            i = i + 1
        }
        return val_array(result)
    }
    // param_count(weight_dict) → total scalar count
    if name == "param_count" {
        if len(args) == 0 { return val_int(0) }
        if args[0].tag == TAG_MAP {
            let vals = get_map_values(args[0])
            let mut total = 0
            for v in vals {
                if v.tag == TAG_TENSOR { total = total + tensor_numel(v) }
                else { if v.tag == TAG_ARRAY { total = total + len(get_array(v)) } }
            }
            return val_int(total)
        }
        if args[0].tag == TAG_TENSOR { return val_int(tensor_numel(args[0])) }
        if args[0].tag == TAG_ARRAY { return val_int(len(get_array(args[0]))) }
        return val_int(0)
    }
    // load_array(path) → array of floats from file
    if name == "load_array" {
        if len(args) == 0 { return val_array([]) }
        try {
            let s = read_file(args[0].str_val)
            let lines = s.split("\n")
            let mut result = []
            for l in lines {
                let trimmed = l.trim()
                if trimmed != "" { result = result.push(val_float(to_float(val_str(trimmed)))) }
            }
            return val_array(result)
        } catch e {
            return val_array([])
        }
    }
    // save_array(path, arr) → void
    if name == "save_array" {
        if len(args) < 2 { return val_void() }
        let arr = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let mut s = ""
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            s = s + to_string(f) + "\n"
        }
        write_file(args[0].str_val, s)
        return val_void()
    }
    // log_get_entries — return empty (log subsystem stub)
    if name == "log_get_entries" {
        return val_array([])
    }
    if name == "law_count" {
        return val_int(60)  // HEXA has 60 laws
    }
    // cell_merge / cell_split — consciousness cell ops, return passthrough
    if name == "cell_merge" {
        if len(args) < 2 { return val_array([]) }
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(a) < len(b) { len(a) } else { len(b) }
        let mut result = []
        let mut i = 0
        while i < n {
            let av = if type_of(a[i]) == "float" { a[i] } else { to_float_val(a[i]) }
            let bv = if type_of(b[i]) == "float" { b[i] } else { to_float_val(b[i]) }
            result = result.push(val_float(0.5 * (av + bv)))
            i = i + 1
        }
        return val_array(result)
    }
    if name == "cell_split" {
        if len(args) == 0 { return val_array([]) }
        // Returns [cell, copy_with_perturbation]
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut copy = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            copy = copy.push(val_float(f + 0.001 * (random() - 0.5)))
        }
        return val_array([args[0], val_array(copy)])
    }
    // attention_fused_into — alias to attention but writes into a tensor
    if name == "attention_fused_into" || name == "attention_cached" {
        // Compute attention and copy result into out tensor
        if len(args) < 6 { return val_void() }
        let out = args[0]
        let inner_args = []
        let mut i = 1
        while i < len(args) { inner_args.push(args[i]); i = i + 1 }
        let result = call_builtin("attention", inner_args)
        if out.tag == TAG_TENSOR && result.tag == TAG_ARRAY {
            let arr = get_array(result)
            let mut data = []
            for v in arr { data = data.push(if type_of(v) == "float" { v } else { to_float_val(v) }) }
            tensor_set_data(out, data)
        }
        return out
    }
    // ffn_fused_into(out, x, w1, w2, dim, hidden) — feed-forward block
    if name == "ffn_fused_into" {
        if len(args) < 6 { return val_void() }
        let out = args[0]
        let x = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let w1 = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let w2 = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let dim = args[4].int_val
        let hidden = args[5].int_val
        // h = relu(W1 @ x)
        let mut h = []
        let mut i = 0
        while i < hidden {
            let mut acc = 0.0
            let mut c = 0
            while c < dim {
                let wv = if type_of(w1[i * dim + c]) == "float" { w1[i * dim + c] } else { to_float_val(w1[i * dim + c]) }
                let xv = if type_of(x[c]) == "float" { x[c] } else { to_float_val(x[c]) }
                acc = acc + wv * xv
                c = c + 1
            }
            if acc < 0.0 { h = h.push(0.0) } else { h = h.push(acc) }
            i = i + 1
        }
        // y = W2 @ h
        let mut y = []
        i = 0
        while i < dim {
            let mut acc = 0.0
            let mut c = 0
            while c < hidden {
                let wv = if type_of(w2[i * hidden + c]) == "float" { w2[i * hidden + c] } else { to_float_val(w2[i * hidden + c]) }
                acc = acc + wv * h[c]
                c = c + 1
            }
            y = y.push(acc)
            i = i + 1
        }
        if out.tag == TAG_TENSOR {
            tensor_set_data(out, y)
            return out
        }
        let mut wrapped = []
        for v in y { wrapped = wrapped.push(val_float(v)) }
        return val_array(wrapped)
    }
    // block_forward_chain — multi-layer transformer block stub
    if name == "block_forward_chain" || name == "block_forward_chain_f32" || name == "block_forward_fused" {
        // Pass through (output identity); real impl is fused kernel
        if len(args) > 0 { return args[0] }
        return val_array([])
    }
    // ── Channel/IO/HTTP stubs (host-dependent) ──
    if name == "send" {
        if len(args) >= 2 && args[0].tag == TAG_CHANNEL { return val_bool(channel_send(args[0], args[1])) }
        return val_bool(false)
    }
    if name == "recv" {
        if len(args) >= 1 && args[0].tag == TAG_CHANNEL { return channel_recv(args[0]) }
        return val_void()
    }
    if name == "try_recv" {
        if len(args) >= 1 && args[0].tag == TAG_CHANNEL {
            let v = channel_recv(args[0])
            if v.tag == TAG_VOID { return val_enum("Option", "None", "") }
            return val_enum("Option", "Some", v)
        }
        return val_enum("Option", "None", "")
    }
    if name == "is_ready" {
        if len(args) == 0 { return val_bool(false) }
        return val_bool(true)
    }
    if name == "deque_len" {
        if len(args) == 0 { return val_int(0) }
        if args[0].tag == TAG_ARRAY { return val_int(len(get_array(args[0]))) }
        return val_int(0)
    }
    if name == "io_reader_next" || name == "fs_watch" || name == "http_get" || name == "http_post" || name == "http_serve" {
        // Host runtime delegate
        return val_str("")
    }
    if name == "tanh_" {
        if len(args) == 0 { return val_float(0.0) }
        return val_float(tanh(to_float_val(args[0])))
    }
    if name == "to_char" {
        if len(args) == 0 { return val_str("") }
        return val_str(to_string(args[0].int_val))
    }
    if name == "try_float" {
        if len(args) == 0 { return val_float(0.0) }
        try { return val_float(to_float(args[0])) }
        catch e { return val_float(0.0) }
    }
    if name == "str" {
        if len(args) == 0 { return val_str("") }
        return val_str(val_to_string(args[0]))
    }
    if name == "gen" {
        // Generator stub: empty array
        return val_array([])
    }
    if name == "hello" {
        return val_str("hello from hexa interpreter (self-host)")
    }

    // ── Phase 22b 골화 — 호스트 핵심 빌트인 패스스루 ──
    // 이전 batch들이 alias만 추가하고 이름 자체 누락한 경우 보강.
    if name == "time" {
        return val_int(timestamp())
    }
    if name == "sleep" {
        if len(args) > 0 { sleep(args[0].int_val) }
        return val_void()
    }
    if name == "random" {
        return val_float(random())
    }
    if name == "range" {
        // range(n) | range(start, end) | range(start, end, step)
        let start = if len(args) >= 2 { args[0].int_val } else { 0 }
        let end = if len(args) >= 2 { args[1].int_val } else { args[0].int_val }
        let step = if len(args) >= 3 { args[2].int_val } else { 1 }
        let mut result = []
        let mut i = start
        if step > 0 {
            while i < end { result = result.push(val_int(i)); i = i + step }
        }
        if step < 0 {
            while i > end { result = result.push(val_int(i)); i = i + step }
        }
        return val_array(result)
    }
    if name == "assert" {
        if len(args) > 0 && !is_truthy(args[0]) {
            throw_flag = true
            let msg = if len(args) > 1 { args[1].str_val } else { "assertion failed" }
            throw_val = val_str(msg)
        }
        return val_void()
    }
    if name == "sort" {
        if len(args) == 0 { return val_array([]) }
        let arr = get_array(args[0])
        return val_array(sort_array(arr))
    }
    if name == "read_file" {
        if len(args) == 0 { return val_str("") }
        let result = read_file(args[0].str_val)
        // host read_file returns either Str or Error value (not via throw)
        if is_error(result) {
            return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "read_file failed", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
        }
        return val_str(result)
    }
    if name == "write_file" {
        if len(args) < 2 { return val_void() }
        try { write_file(args[0].str_val, args[1].str_val) } catch e { }
        return val_void()
    }
    if name == "append_file" {
        if len(args) < 2 { return val_void() }
        try { append_file(args[0].str_val, args[1].str_val) } catch e { }
        return val_void()
    }
    if name == "read_lines" {
        if len(args) == 0 { return val_array([]) }
        try {
            let lines = read_lines(args[0].str_val)
            let mut result = []
            for l in lines { result = result.push(val_str(l)) }
            return val_array(result)
        } catch e { return val_array([]) }
    }
    if name == "file_exists" {
        if len(args) == 0 { return val_bool(false) }
        return val_bool(file_exists(args[0].str_val))
    }
    if name == "dir_exists" {
        if len(args) == 0 { return val_int(0) }
        try {
            let res = exec("test -d '" + args[0].str_val + "' && echo 1 || echo 0").trim()
            if res == "1" { return val_int(1) }
            return val_int(0)
        } catch e { return val_int(0) }
    }
    if name == "mkdir" {
        if len(args) == 0 { return val_int(1) }
        try {
            exec("mkdir -p '" + args[0].str_val + "'")
            return val_int(0)
        } catch e { return val_int(1) }
    }
    if name == "list_dir" {
        if len(args) == 0 { return val_array([]) }
        try {
            let raw = exec("ls -1 '" + args[0].str_val + "'").trim()
            if raw == "" { return val_array([]) }
            let entries = raw.split("\n")
            let mut result = []
            for e in entries { result = result.push(val_str(e)) }
            return val_array(result)
        } catch e { return val_array([]) }
    }
    if name == "delete_file" {
        if len(args) == 0 { return val_void() }
        try { delete_file(args[0].str_val) } catch e { }
        return val_void()
    }
    if name == "input" {
        let prompt = if len(args) > 0 { args[0].str_val } else { "" }
        return val_str(input(prompt))
    }
    if name == "read_stdin" {
        // Read all stdin until EOF (best-effort via input loop)
        let mut buf = ""
        try {
            while true {
                let line = input("")
                if line == "" { return val_str(buf) }
                if buf == "" { buf = line } else { buf = buf + "\n" + line }
            }
        } catch e { }
        return val_str(buf)
    }
    if name == "array_fill" {
        // array_fill(value, n) → [value, value, ..., value]
        if len(args) < 2 { return val_array([]) }
        let v = args[0]
        let n = args[1].int_val
        let mut result = []
        let mut i = 0
        while i < n { result = result.push(v); i = i + 1 }
        return val_array(result)
    }
    if name == "split" {
        // split(string, delim) → array of strings
        if len(args) < 2 { return val_array([]) }
        let s = args[0].str_val
        let d = args[1].str_val
        let parts = s.split(d)
        let mut result = []
        for p in parts { result = result.push(val_str(p)) }
        return val_array(result)
    }
    if name == "exit" {
        let code = if len(args) > 0 { args[0].int_val } else { 0 }
        exit(code)
        return val_void()
    }
    if name == "env_var" {
        if len(args) == 0 { return val_str("") }
        return val_str(env_var(args[0].str_val))
    }
    if name == "command_args" {
        let a = host_args()
        let mut result = []
        for s in a { result = result.push(val_str(s)) }
        return val_array(result)
    }
    if name == "argc" {
        let a = host_args()
        return val_int(len(a))
    }
    if name == "arg" {
        if len(args) == 0 { return val_str("") }
        let i = args[0].int_val
        let a = host_args()
        if i >= 0 && i < len(a) { return val_str(a[i]) }
        return val_str("")
    }
    if name == "parse_int" {
        if len(args) == 0 { return val_int(0) }
        if args[0].tag == TAG_STR { return val_int(args[0].str_val.parse_int()) }
        if args[0].tag == TAG_INT { return args[0] }
        if args[0].tag == TAG_FLOAT { return val_int(floor(args[0].float_val)) }
        return val_int(0)
    }
    if name == "parse_float" {
        if len(args) == 0 { return val_float(0.0) }
        if args[0].tag == TAG_STR { return val_float(args[0].str_val.parse_float()) }
        if args[0].tag == TAG_FLOAT { return args[0] }
        if args[0].tag == TAG_INT { return val_float(args[0].int_val + 0.0) }
        return val_float(0.0)
    }
    if name == "format" {
        // format(template, ...args) → string with {}/{N} placeholders
        if len(args) == 0 { return val_str("") }
        let mut result = args[0].str_val
        let mut i = 1
        while i < len(args) {
            let placeholder = "{" + to_string(i - 1) + "}"
            result = result.replace(placeholder, val_to_string(args[i]))
            i = i + 1
        }
        return val_str(result)
    }
    if name == "hex" {
        if len(args) == 0 { return val_str("") }
        return val_str(hex(args[0].int_val))
    }
    if name == "bin" {
        if len(args) == 0 { return val_str("") }
        return val_str(bin(args[0].int_val))
    }
    if name == "char_code" {
        if len(args) == 0 { return val_int(0) }
        let s = if args[0].tag == TAG_CHAR { args[0].char_val } else { args[0].str_val }
        if len(s) == 0 { return val_int(0) }
        return val_int(char_code(s, 0))
    }
    if name == "from_char_code" {
        if len(args) == 0 { return val_str("") }
        return val_str(to_string(args[0].int_val))
    }
    if name == "to_json" {
        if len(args) == 0 { return val_str("null") }
        return val_str(val_to_json(args[0]))
    }
    if name == "from_json" {
        if len(args) == 0 { return val_void() }
        return json_to_val(args[0].str_val)
    }
    if name == "is_error" {
        if len(args) == 0 { return val_bool(false) }
        return val_bool(args[0].tag == TAG_ERROR)
    }
    if name == "stack_trace" {
        return val_str(format_stack_trace())
    }
    if name == "error" {
        let msg = if len(args) > 0 { args[0].str_val } else { "error" }
        return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: msg, char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
    }

    // matrix_det(m, n) — determinant via cofactor expansion (small matrices only)
    if name == "matrix_det" {
        if len(args) < 2 { return val_float(0.0) }
        let m = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n = args[1].int_val
        if n == 1 { return val_float(if type_of(m[0]) == "float" { m[0] } else { to_float_val(m[0]) }) }
        if n == 2 {
            let a = if type_of(m[0]) == "float" { m[0] } else { to_float_val(m[0]) }
            let b = if type_of(m[1]) == "float" { m[1] } else { to_float_val(m[1]) }
            let c = if type_of(m[2]) == "float" { m[2] } else { to_float_val(m[2]) }
            let d = if type_of(m[3]) == "float" { m[3] } else { to_float_val(m[3]) }
            return val_float(a * d - b * c)
        }
        if n == 3 {
            let g00 = if type_of(m[0]) == "float" { m[0] } else { to_float_val(m[0]) }
            let g01 = if type_of(m[1]) == "float" { m[1] } else { to_float_val(m[1]) }
            let g02 = if type_of(m[2]) == "float" { m[2] } else { to_float_val(m[2]) }
            let g10 = if type_of(m[3]) == "float" { m[3] } else { to_float_val(m[3]) }
            let g11 = if type_of(m[4]) == "float" { m[4] } else { to_float_val(m[4]) }
            let g12 = if type_of(m[5]) == "float" { m[5] } else { to_float_val(m[5]) }
            let g20 = if type_of(m[6]) == "float" { m[6] } else { to_float_val(m[6]) }
            let g21 = if type_of(m[7]) == "float" { m[7] } else { to_float_val(m[7]) }
            let g22 = if type_of(m[8]) == "float" { m[8] } else { to_float_val(m[8]) }
            return val_float(g00*(g11*g22-g12*g21) - g01*(g10*g22-g12*g20) + g02*(g10*g21-g11*g20))
        }
        return val_float(0.0)  // larger matrices unsupported in self-host
    }


    // batch_matvec(W, x_batch, batch_size, out_dim, in_dim) → [batch * out_dim]
    if name == "batch_matvec" {
        if len(args) < 5 { return val_array([]) }
        let w = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let x = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let batch = args[2].int_val
        let outd = args[3].int_val
        let ind = args[4].int_val
        let mut result = []
        let mut bi = 0
        while bi < batch {
            let mut o = 0
            while o < outd {
                let mut acc = 0.0
                let mut c = 0
                while c < ind {
                    let wv = if type_of(w[o * ind + c]) == "float" { w[o * ind + c] } else { to_float_val(w[o * ind + c]) }
                    let xv = if type_of(x[bi * ind + c]) == "float" { x[bi * ind + c] } else { to_float_val(x[bi * ind + c]) }
                    acc = acc + wv * xv
                    c = c + 1
                }
                result = result.push(val_float(acc))
                o = o + 1
            }
            bi = bi + 1
        }
        return val_array(result)
    }
    if name == "len" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == TAG_STR { return val_int(len(a.str_val)) }
            if a.tag == TAG_ARRAY { return val_int(len(get_array(a))) }
        }
        return val_int(0)
    }
    if name == "to_string" {
        if len(args) > 0 { return val_str(val_to_string(args[0])) }
        return val_str("")
    }
    if name == "type_of" {
        if len(args) > 0 { return val_str(tag_name(args[0].tag)) }
        return val_str("void")
    }
    if name == "int" || name == "to_int" {
        if len(args) == 0 { return val_int(0) }
        let v = args[0]
        if v.tag == TAG_INT { return v }
        if v.tag == TAG_FLOAT { return val_int(floor(v.float_val)) }
        if v.tag == TAG_STR {
            // Use host string method parse_int (avoids recursing into our to_int)
            return val_int(v.str_val.parse_int())
        }
        if v.tag == TAG_BOOL { if v.bool_val { return val_int(1) } else { return val_int(0) } }
        return val_int(0)
    }
    if name == "float" || name == "to_float" {
        if len(args) == 0 { return val_float(0.0) }
        let v = args[0]
        if v.tag == TAG_FLOAT { return v }
        if v.tag == TAG_INT { return val_float(v.int_val * 1.0) }
        if v.tag == TAG_STR {
            // Use host string method parse_float (avoids recursing into our to_float)
            return val_float(v.str_val.parse_float())
        }
        return val_float(0.0)
    }
    if name == "bool" {
        if len(args) > 0 { return val_bool(is_truthy(args[0])) }
        return val_bool(false)
    }
    if name == "char" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == TAG_STR && len(a.str_val) > 0 {
                let cs = a.str_val.chars()
                return val_str(to_string(cs[0]))
            }
            if a.tag == TAG_INT { return val_str(from_char_code(a.int_val)) }
        }
        return val_str("")
    }
    if name == "ord" {
        if len(args) > 0 && args[0].tag == TAG_STR {
            let s = args[0].str_val
            if len(s) > 0 {
                let cs = s.chars()
                return val_int(char_code(cs[0], 0))
            }
        }
        return val_int(0)
    }
    if name == "chr" {
        if len(args) > 0 {
            return val_str(from_char_code(args[0].int_val))
        }
        return val_str("")
    }
    if name == "parse_int" {
        if len(args) > 0 {
            return val_int(to_int(args[0].str_val))
        }
        return val_int(0)
    }
    if name == "parse_float" {
        if len(args) > 0 {
            return val_float(to_float(args[0].str_val))
        }
        return val_float(0.0)
    }
    if name == "to_json" {
        if len(args) > 0 {
            return val_str(val_to_json(args[0]))
        }
        return val_str("null")
    }
    if name == "from_json" {
        if len(args) > 0 {
            return json_to_val(args[0].str_val)
        }
        return val_void()
    }
    if name == "is_alpha" {
        if len(args) > 0 { return val_bool(is_alpha(args[0].str_val)) }
        return val_bool(false)
    }
    if name == "is_digit" {
        if len(args) > 0 { return val_bool(is_digit(args[0].str_val)) }
        return val_bool(false)
    }
    if name == "is_alphanumeric" {
        if len(args) > 0 { return val_bool(is_alphanumeric(args[0].str_val)) }
        return val_bool(false)
    }
    if name == "format" {
        // format(template, arg0, arg1, ...) with {}, {0}, {:.2} support
        if len(args) == 0 { return val_str("") }
        let tmpl = args[0].str_val
        let mut out = ""
        let mut arg_idx = 1
        let chars_arr = tmpl.chars()
        let tlen = len(chars_arr)
        let mut ci = 0
        while ci < tlen {
            let ch = to_string(chars_arr[ci])
            if ch == "{" && ci + 1 < tlen {
                // Look for closing }
                let mut end = ci + 1
                while end < tlen && to_string(chars_arr[end]) != "}" {
                    end = end + 1
                }
                if end < tlen {
                    // Extract format spec between { and }
                    let mut spec = ""
                    let mut si = ci + 1
                    while si < end {
                        spec = spec + to_string(chars_arr[si])
                        si = si + 1
                    }
                    if spec == "" {
                        // {} — positional arg
                        if arg_idx < len(args) {
                            out = out + val_to_string(args[arg_idx])
                            arg_idx = arg_idx + 1
                        }
                    } else if spec.starts_with(":.") {
                        // {:.N} — float precision
                        let prec_str = spec.substring(2, len(spec))
                        let prec = to_int(prec_str)
                        if arg_idx < len(args) {
                            let fv = to_float_val(args[arg_idx])
                            out = out + to_string(round(fv, prec))
                            arg_idx = arg_idx + 1
                        }
                    } else {
                        // {N} — indexed arg
                        let idx_val = to_int(spec)
                        let actual = idx_val + 1
                        if actual < len(args) {
                            out = out + val_to_string(args[actual])
                        }
                    }
                    ci = end + 1
                } else {
                    out = out + ch
                    ci = ci + 1
                }
            } else {
                out = out + ch
                ci = ci + 1
            }
        }
        return val_str(out)
    }
    if name == "read_file" {
        if len(args) > 0 { return val_str(read_file(args[0].str_val)) }
        return val_str("")
    }
    if name == "read_lines" {
        if len(args) > 0 {
            let content = read_file(args[0].str_val)
            let lines = content.split("\n")
            let mut result = []
            for line in lines { result = result.push(val_str(line)) }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "write_file" {
        if len(args) >= 2 {
            write_file(args[0].str_val, args[1].str_val)
        }
        return val_void()
    }
    if name == "eprintln" {
        let mut out = ""
        for a in args { out = out + val_to_string(a) }
        eprintln(out)
        return val_void()
    }
    if name == "exit" {
        let code = 0
        if len(args) > 0 { code = args[0].int_val }
        exit(code)
        return val_void()
    }
    if name == "input" {
        let prompt = ""
        if len(args) > 0 { prompt = args[0].str_val }
        if prompt != "" { print(prompt) }
        let line = input()
        return val_str(line)
    }
    if name == "assert" {
        if len(args) > 0 {
            let cond = is_truthy(args[0])
            if !cond {
                let msg = "assertion failed"
                if len(args) >= 2 { msg = val_to_string(args[1]) }
                panic_flag = true
                panic_msg = msg
            }
        }
        return val_void()
    }
    if name == "range" {
        if len(args) >= 2 {
            let start = args[0].int_val
            let end_val = args[1].int_val
            let mut result = []
            let mut ri = start
            while ri < end_val {
                result = result.push(val_int(ri))
                ri = ri + 1
            }
            return val_array(result)
        }
        if len(args) == 1 {
            let end_val = args[0].int_val
            let mut result = []
            let mut ri = 0
            while ri < end_val {
                result = result.push(val_int(ri))
                ri = ri + 1
            }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "sort" {
        if len(args) > 0 && args[0].tag == TAG_ARRAY {
            let items = get_array(args[0])
            let sorted = sort_array(items)
            return val_array(sorted)
        }
        return val_array([])
    }
    if name == "random" {
        return val_float(random())
    }
    if name == "time" {
        return val_float(timestamp())
    }
    if name == "sleep" {
        if len(args) > 0 { sleep(args[0].int_val) }
        return val_void()
    }
    if name == "chars" {
        if len(args) > 0 && args[0].tag == TAG_STR {
            let cs = args[0].str_val.chars()
            let mut result = []
            for c in cs { result = result.push(val_str(to_string(c))) }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "push" {
        if len(args) >= 2 && args[0].tag == TAG_ARRAY {
            // Perf #10: in-place push when sole owner
            return array_push_inplace(args[0], args[1])
        }
        return args[0]
    }

    // ── Math builtins ────────────────────────────────────
    if name == "abs" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == TAG_INT { return val_int(abs(a.int_val)) }
            if a.tag == TAG_FLOAT { return val_float(abs(a.float_val)) }
        }
        return val_int(0)
    }
    if name == "min" {
        if len(args) >= 2 {
            let a = args[0]
            let b = args[1]
            if a.tag == TAG_INT && b.tag == TAG_INT {
                if a.int_val < b.int_val { return a } else { return b }
            }
            let fa = to_float_val(a)
            let fb = to_float_val(b)
            if fa < fb { return val_float(fa) } else { return val_float(fb) }
        }
        return val_int(0)
    }
    if name == "max" {
        if len(args) >= 2 {
            let a = args[0]
            let b = args[1]
            if a.tag == TAG_INT && b.tag == TAG_INT {
                if a.int_val > b.int_val { return a } else { return b }
            }
            let fa = to_float_val(a)
            let fb = to_float_val(b)
            if fa > fb { return val_float(fa) } else { return val_float(fb) }
        }
        return val_int(0)
    }
    if name == "floor" {
        if len(args) > 0 { return val_int(floor(to_float_val(args[0]))) }
        return val_int(0)
    }
    if name == "ceil" {
        if len(args) > 0 { return val_int(ceil(to_float_val(args[0]))) }
        return val_int(0)
    }
    if name == "round" {
        if len(args) > 0 {
            if len(args) >= 2 {
                return val_float(round(to_float_val(args[0]), args[1].int_val))
            }
            return val_float(round(to_float_val(args[0])))
        }
        return val_float(0.0)
    }
    if name == "sqrt" {
        if len(args) > 0 { return val_float(sqrt(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "pow" {
        if len(args) >= 2 { return val_float(pow(to_float_val(args[0]), to_float_val(args[1]))) }
        return val_float(0.0)
    }
    if name == "sin" {
        if len(args) > 0 { return val_float(sin(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "cos" {
        if len(args) > 0 { return val_float(cos(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "tan" {
        if len(args) > 0 { return val_float(tan(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "ln" {
        if len(args) > 0 { return val_float(ln(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "log10" {
        if len(args) > 0 { return val_float(log10(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "exp" {
        if len(args) > 0 { return val_float(exp(to_float_val(args[0]))) }
        return val_float(0.0)
    }

    // ── @approximate runtime builtins — Newton/Taylor approximations ──
    // These are injected by M974 rewrite in ai_native_pass.hexa
    if name == "__approx_sqrt" {
        // Newton's method: x_{n+1} = (x_n + S/x_n) / 2
        if len(args) > 0 {
            let s = to_float_val(args[0])
            if s <= 0.0 { return val_float(0.0) }
            let mut guess = s / 2.0
            if guess == 0.0 { guess = 1.0 }
            let mut iter = 0
            while iter < 20 {
                let next = (guess + s / guess) / 2.0
                let diff = next - guess
                if diff < 0.0 { diff = 0.0 - diff }
                guess = next
                if diff < 1e-10 { iter = 20 }
                iter = iter + 1
            }
            return val_float(guess)
        }
        return val_float(0.0)
    }
    if name == "__approx_exp" {
        // Taylor series: e^x = 1 + x + x^2/2! + x^3/3! + ...
        if len(args) > 0 {
            let x = to_float_val(args[0])
            let mut result = 1.0
            let mut term = 1.0
            let mut n = 1
            while n <= 20 {
                term = term * x / to_float(n)
                result = result + term
                let abs_term = term
                if abs_term < 0.0 { abs_term = 0.0 - abs_term }
                if abs_term < 1e-15 { n = 21 }
                n = n + 1
            }
            return val_float(result)
        }
        return val_float(0.0)
    }
    if name == "__approx_sin" {
        // Taylor series: sin(x) = x - x^3/3! + x^5/5! - ...
        if len(args) > 0 {
            let x = to_float_val(args[0])
            let mut result = 0.0
            let mut term = x
            let mut n = 1
            let mut sign = 1.0
            while n <= 21 {
                result = result + sign * term
                term = term * x * x / to_float(2 * n) / to_float(2 * n + 1)
                sign = 0.0 - sign
                n = n + 1
            }
            return val_float(result)
        }
        return val_float(0.0)
    }
    if name == "__approx_cos" {
        // Taylor series: cos(x) = 1 - x^2/2! + x^4/4! - ...
        if len(args) > 0 {
            let x = to_float_val(args[0])
            let mut result = 0.0
            let mut term = 1.0
            let mut n = 0
            let mut sign = 1.0
            while n <= 20 {
                result = result + sign * term
                term = term * x * x / to_float(2 * n + 1) / to_float(2 * n + 2)
                sign = 0.0 - sign
                n = n + 1
            }
            return val_float(result)
        }
        return val_float(0.0)
    }

    // ── Map constructor ──────────────────────────────────
    if name == "Map" {
        return val_map([], [])
    }

    // ── Callback trampoline builtins (G4) ────────────────
    // In interpreter mode, callbacks are tracked as slot IDs.
    // The actual C function pointer is only meaningful in compiled mode.
    if name == "callback_create" {
        if len(args) > 0 {
            let fn_val = args[0]
            // Store in callback_slots, return slot index as int
            let slot = callback_alloc(fn_val)
            return val_int(slot)
        }
        return val_int(-1)
    }
    if name == "callback_free" {
        if len(args) > 0 {
            callback_release(args[0].int_val)
        }
        return val_void()
    }
    if name == "callback_invoke" {
        // For testing: invoke a callback by slot ID with args
        if len(args) >= 1 {
            let slot = args[0].int_val
            let mut cb_args = []
            let mut ai = 1
            while ai < len(args) {
                cb_args = cb_args.push(args[ai])
                ai = ai + 1
            }
            return callback_call(slot, cb_args)
        }
        return val_void()
    }

    // ── G5: Pointer arithmetic builtins (interpreter-level) ──
    if name == "ptr_alloc" {
        if len(args) > 0 {
            let size = args[0].int_val
            let buf = ptr_alloc(size)
            return val_int(ptr_addr(buf))
        }
        return val_int(0)
    }
    if name == "ptr_free" {
        if len(args) >= 2 {
            ptr_free(args[0].int_val, args[1].int_val)
        }
        return val_void()
    }
    if name == "ptr_write" {
        if len(args) >= 3 {
            let p = args[0].int_val
            let off = args[1].int_val
            let v = args[2]
            if v.tag == TAG_FLOAT {
                ptr_write(p, off, v.float_val)
            } else {
                ptr_write(p, off, v.int_val)
            }
        }
        return val_void()
    }
    if name == "ptr_write_f32" {
        if len(args) >= 3 {
            ptr_write_f32(args[0].int_val, args[1].int_val, to_float_val(args[2]))
        }
        return val_void()
    }
    if name == "ptr_write_i32" {
        if len(args) >= 3 {
            ptr_write_i32(args[0].int_val, args[1].int_val, args[2].int_val)
        }
        return val_void()
    }
    if name == "ptr_read" {
        if len(args) >= 2 {
            return val_int(ptr_read(args[0].int_val, args[1].int_val))
        }
        return val_int(0)
    }
    if name == "ptr_read_f64" {
        if len(args) >= 2 {
            return val_float(ptr_read_f64(args[0].int_val, args[1].int_val))
        }
        return val_float(0.0)
    }
    if name == "ptr_read_f32" {
        if len(args) >= 2 {
            return val_float(ptr_read_f32(args[0].int_val, args[1].int_val))
        }
        return val_float(0.0)
    }
    if name == "ptr_read_i32" {
        if len(args) >= 2 {
            return val_int(ptr_read_i32(args[0].int_val, args[1].int_val))
        }
        return val_int(0)
    }
    if name == "ptr_offset" {
        if len(args) >= 2 {
            return val_int(args[0].int_val + args[1].int_val)
        }
        return val_int(0)
    }
    if name == "ptr_null" {
        return val_int(0)
    }
    if name == "ptr_addr" {
        if len(args) > 0 { return val_int(args[0].int_val) }
        return val_int(0)
    }
    if name == "deref" {
        if len(args) > 0 {
            return val_int(deref(args[0].int_val))
        }
        return val_int(0)
    }

    // ── FFI string conversion builtins ────────────────────
    if name == "cstring" {
        if len(args) > 0 && args[0].tag == TAG_STR {
            return val_int(ptr_addr(args[0].str_val))
        }
        return val_int(0)
    }
    if name == "from_cstring" {
        if len(args) > 0 {
            return val_str(from_cstring(args[0].int_val))
        }
        return val_str("")
    }

    // ── G2: Struct packing builtins ──────────────────────
    if name == "struct_pack" {
        // Pack all args as f64 into a heap buffer, return pointer
        let size = len(args) * 8
        let buf = ptr_alloc(size)
        let p = ptr_addr(buf)
        let mut si = 0
        while si < len(args) {
            let v = to_float_val(args[si])
            ptr_write(p, si * 8, v)
            si = si + 1
        }
        return val_int(p)
    }
    if name == "struct_pack_f32" {
        let size = len(args) * 4
        let buf = ptr_alloc(size)
        let p = ptr_addr(buf)
        let mut si = 0
        while si < len(args) {
            let v = to_float_val(args[si])
            ptr_write_f32(p, si * 4, v)
            si = si + 1
        }
        return val_int(p)
    }
    if name == "struct_unpack" {
        if len(args) >= 2 {
            let p = args[0].int_val
            let idx = args[1].int_val
            return val_float(ptr_read_f64(p, idx * 8))
        }
        return val_float(0.0)
    }
    if name == "struct_unpack_f32" {
        if len(args) >= 2 {
            let p = args[0].int_val
            let idx = args[1].int_val
            return val_float(ptr_read_f32(p, idx * 4))
        }
        return val_float(0.0)
    }
    if name == "struct_rect" {
        if len(args) >= 4 {
            let buf = ptr_alloc(32)
            let p = ptr_addr(buf)
            ptr_write(p, 0, to_float_val(args[0]))
            ptr_write(p, 8, to_float_val(args[1]))
            ptr_write(p, 16, to_float_val(args[2]))
            ptr_write(p, 24, to_float_val(args[3]))
            return val_int(p)
        }
        return val_int(0)
    }
    if name == "struct_point" {
        if len(args) >= 2 {
            let buf = ptr_alloc(16)
            let p = ptr_addr(buf)
            ptr_write(p, 0, to_float_val(args[0]))
            ptr_write(p, 8, to_float_val(args[1]))
            return val_int(p)
        }
        return val_int(0)
    }
    if name == "struct_size" {
        if len(args) >= 2 {
            let buf = ptr_alloc(16)
            let p = ptr_addr(buf)
            ptr_write(p, 0, to_float_val(args[0]))
            ptr_write(p, 8, to_float_val(args[1]))
            return val_int(p)
        }
        return val_int(0)
    }
    if name == "struct_free" {
        if len(args) > 0 {
            ptr_free(args[0].int_val, 0)
        }
        return val_void()
    }

    // ── T9: Array aggregate builtins ────────────────────────
    if name == "any" {
        if len(args) >= 2 && args[0].tag == TAG_ARRAY {
            let items = get_array(args[0])
            for item in items {
                let r = call_fn_val(args[1], [item])
                if is_truthy(r) { return val_bool(true) }
            }
            return val_bool(false)
        }
        return val_bool(false)
    }
    if name == "all" {
        if len(args) >= 2 && args[0].tag == TAG_ARRAY {
            let items = get_array(args[0])
            for item in items {
                let r = call_fn_val(args[1], [item])
                if !is_truthy(r) { return val_bool(false) }
            }
            return val_bool(true)
        }
        return val_bool(true)
    }
    if name == "count" {
        if len(args) >= 2 && args[0].tag == TAG_ARRAY {
            let items = get_array(args[0])
            let mut c = 0
            for item in items {
                let r = call_fn_val(args[1], [item])
                if is_truthy(r) { c = c + 1 }
            }
            return val_int(c)
        }
        return val_int(0)
    }
    if name == "sum" {
        if len(args) > 0 && args[0].tag == TAG_ARRAY {
            let items = get_array(args[0])
            let mut has_float = false
            let mut si = 0.0
            for item in items {
                if item.tag == TAG_FLOAT { has_float = true }
                si = si + to_float_val(item)
            }
            if has_float { return val_float(si) }
            return val_int(floor(si))
        }
        return val_int(0)
    }
    if name == "sort" {
        if len(args) > 0 && args[0].tag == TAG_ARRAY {
            let items = get_array(args[0])
            let n = len(items)
            if n <= 1 { return val_array(items) }
            // Copy to mutable array, then bubble sort
            let mut sorted = []
            for item in items { sorted = sorted.push(item) }
            let mut si = 0
            while si < n - 1 {
                let mut sj = 0
                while sj < n - si - 1 {
                    let a = sorted[sj]
                    let b = sorted[sj + 1]
                    let mut do_swap = false
                    if a.tag == TAG_INT && b.tag == TAG_INT {
                        if a.int_val > b.int_val { do_swap = true }
                    } else if a.tag == TAG_FLOAT || b.tag == TAG_FLOAT {
                        if to_float_val(a) > to_float_val(b) { do_swap = true }
                    } else if a.tag == TAG_STR && b.tag == TAG_STR {
                        if a.str_val > b.str_val { do_swap = true }
                    }
                    if do_swap {
                        let tmp = sorted[sj]
                        sorted[sj] = sorted[sj + 1]
                        sorted[sj + 1] = tmp
                    }
                    sj = sj + 1
                }
                si = si + 1
            }
            return val_array(sorted)
        }
        return val_array([])
    }
    if name == "enumerate" {
        if len(args) > 0 && args[0].tag == TAG_ARRAY {
            let items = get_array(args[0])
            let mut result = []
            let mut ei = 0
            while ei < len(items) {
                result = result.push(val_array([val_int(ei), items[ei]]))
                ei = ei + 1
            }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "zip" {
        if len(args) >= 2 && args[0].tag == TAG_ARRAY && args[1].tag == TAG_ARRAY {
            let a_items = get_array(args[0])
            let b_items = get_array(args[1])
            let mut result = []
            let mut zi = 0
            let zn = min(len(a_items), len(b_items))
            while zi < zn {
                result = result.push(val_array([a_items[zi], b_items[zi]]))
                zi = zi + 1
            }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "find" {
        if len(args) >= 2 && args[0].tag == TAG_ARRAY {
            let items = get_array(args[0])
            for item in items {
                let r = call_fn_val(args[1], [item])
                if is_truthy(r) { return item }
            }
        }
        return val_void()
    }
    if name == "flat_map" {
        if len(args) >= 2 && args[0].tag == TAG_ARRAY {
            let items = get_array(args[0])
            let mut result = []
            for item in items {
                let sub = call_fn_val(args[1], [item])
                if sub.tag == TAG_ARRAY {
                    let sub_items = get_array(sub)
                    for s in sub_items { result = result.push(s) }
                } else {
                    result = result.push(sub)
                }
            }
            return val_array(result)
        }
        return val_array([])
    }

    // ── T9: String utility builtins ─────────────────────────
    if name == "repeat" {
        if len(args) >= 2 && args[0].tag == TAG_STR {
            let s = args[0].str_val
            let n = args[1].int_val
            let mut out = ""
            let mut ri = 0
            while ri < n {
                out = out + s
                ri = ri + 1
            }
            return val_str(out)
        }
        return val_str("")
    }
    if name == "pad_left" {
        if len(args) >= 3 && args[0].tag == TAG_STR {
            let s = args[0].str_val
            let width = args[1].int_val
            let ch = args[2].str_val
            let mut out = s
            while len(out) < width {
                out = ch + out
            }
            return val_str(out)
        }
        return val_str("")
    }
    if name == "pad_right" {
        if len(args) >= 3 && args[0].tag == TAG_STR {
            let s = args[0].str_val
            let width = args[1].int_val
            let ch = args[2].str_val
            let mut out = s
            while len(out) < width {
                out = out + ch
            }
            return val_str(out)
        }
        return val_str("")
    }
    if name == "char_at" {
        if len(args) >= 2 && args[0].tag == TAG_STR {
            let s = args[0].str_val
            let idx = args[1].int_val
            let cs = s.chars()
            if idx >= 0 && idx < len(cs) {
                return val_str(to_string(cs[idx]))
            }
        }
        return val_str("")
    }
    if name == "char_code" {
        if len(args) == 0 { return val_int(0) }
        // host char_code takes (str, idx). Handle (char) and (str) calls.
        if args[0].tag == TAG_CHAR {
            let s = args[0].char_val
            if len(s) > 0 { return val_int(char_code(s, 0)) }
            return val_int(0)
        }
        if args[0].tag == TAG_STR {
            let s = args[0].str_val
            if len(s) == 0 { return val_int(0) }
            let idx = if len(args) > 1 { args[1].int_val } else { 0 }
            return val_int(char_code(s, idx))
        }
        return val_int(0)
    }
    if name == "from_char_code" {
        if len(args) > 0 {
            let n = args[0].int_val
            return val_str(from_char_code(n))
        }
        return val_str("")
    }

    // ── T9: Math / activation builtins ──────────────────────
    if name == "tan" {
        if len(args) > 0 { return val_float(tan(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "asin" {
        if len(args) > 0 { return val_float(asin(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "acos" {
        if len(args) > 0 { return val_float(acos(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "atan" {
        if len(args) > 0 { return val_float(atan(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "atan2" {
        if len(args) >= 2 { return val_float(atan2(to_float_val(args[0]), to_float_val(args[1]))) }
        return val_float(0.0)
    }
    if name == "sigmoid" {
        if len(args) > 0 {
            let x = to_float_val(args[0])
            return val_float(1.0 / (1.0 + exp(-x)))
        }
        return val_float(0.5)
    }
    if name == "relu" {
        if len(args) > 0 {
            let x = to_float_val(args[0])
            if x > 0.0 { return val_float(x) }
            return val_float(0.0)
        }
        return val_float(0.0)
    }
    if name == "tanh" {
        if len(args) > 0 { return val_float(tanh(to_float_val(args[0]))) }
        return val_float(0.0)
    }
    if name == "pi" {
        return val_float(3.141592653589793)
    }
    if name == "e" {
        return val_float(2.718281828459045)
    }
    if name == "log2" {
        if len(args) > 0 { return val_float(ln(to_float_val(args[0])) / ln(2.0)) }
        return val_float(0.0)
    }
    if name == "clamp" {
        if len(args) >= 3 {
            let x = to_float_val(args[0])
            let lo = to_float_val(args[1])
            let hi = to_float_val(args[2])
            if x < lo { return val_float(lo) }
            if x > hi { return val_float(hi) }
            return val_float(x)
        }
        return val_float(0.0)
    }

    // ── T9: I/O builtins ────────────────────────────────────
    if name == "write_file" {
        if len(args) >= 2 {
            write_file(args[0].str_val, args[1].str_val)
        }
        return val_void()
    }
    if name == "append_file" {
        if len(args) >= 2 {
            append_file(args[0].str_val, args[1].str_val)
        }
        return val_void()
    }
    if name == "file_exists" {
        if len(args) > 0 {
            return val_bool(file_exists(args[0].str_val))
        }
        return val_bool(false)
    }
    if name == "dir_exists" {
        if len(args) > 0 {
            try {
                let res = exec("test -d '" + args[0].str_val + "' && echo 1 || echo 0").trim()
                if res == "1" { return val_int(1) }
                return val_int(0)
            } catch e { return val_int(0) }
        }
        return val_int(0)
    }
    if name == "mkdir" {
        if len(args) > 0 {
            try {
                exec("mkdir -p '" + args[0].str_val + "'")
                return val_int(0)
            } catch e { return val_int(1) }
        }
        return val_int(1)
    }
    if name == "list_dir" {
        if len(args) > 0 {
            try {
                let raw = exec("ls -1 '" + args[0].str_val + "'").trim()
                if raw == "" { return val_array([]) }
                let entries = raw.split("\n")
                let mut result = []
                for e in entries { result = result.push(val_str(e)) }
                return val_array(result)
            } catch e { return val_array([]) }
        }
        return val_array([])
    }
    if name == "delete_file" {
        if len(args) > 0 {
            delete_file(args[0].str_val)
        }
        return val_void()
    }
    if name == "env_var" {
        if len(args) > 0 {
            return val_str(env_var(args[0].str_val))
        }
        return val_str("")
    }
    if name == "command_args" {
        let raw_args = host_args()
        let mut result = []
        for a in raw_args {
            result = result.push(val_str(to_string(a)))
        }
        return val_array(result)
    }

    // ── Error handling builtins ────────────────────────────
    if name == "error" {
        let msg = ""
        if len(args) > 0 { msg = val_to_string(args[0]) }
        let mut keys = [val_str("message"), val_str("trace")]
        let mut values = [val_str(msg), val_str(format_stack_trace())]
        return val_map(keys, values)
    }
    if name == "is_error" {
        if len(args) > 0 {
            let v = args[0]
            if v.tag == TAG_MAP {
                let ks = get_map_keys(v)
                let mut ki = 0
                while ki < len(ks) {
                    if ks[ki].tag == TAG_STR && ks[ki].str_val == "message" {
                        return val_bool(true)
                    }
                    ki = ki + 1
                }
            }
        }
        return val_bool(false)
    }
    if name == "stack_trace" {
        return val_str(format_stack_trace())
    }

    // ── Functional builtins ─────────────────────────────────
    if name == "compose" {
        if len(args) >= 2 {
            let f = args[0]
            let g = args[1]
            // Build a closure that captures f and g
            let mut captured = []
            let mut ci = 0
            while ci < len(env_vars) {
                captured = captured.push([env_vars[ci][0], env_vars[ci][1]])
                ci = ci + 1
            }
            captured = captured.push(["__compose_f", f])
            captured = captured.push(["__compose_g", g])
            let idx = len(closure_store)
            closure_store = closure_store.push([captured, []])
            // Return a fn that calls f(g(x))
            // We use a special tag to identify compose closures
            return Val { tag: TAG_FN, int_val: idx, float_val: 0.0, bool_val: false, str_val: "compose", char_val: "", array_val: "", fn_name: "__composed__", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
        }
        return val_void()
    }
    if name == "pipe" {
        if len(args) >= 2 {
            let mut val = args[0]
            let mut pi = 1
            while pi < len(args) {
                val = call_fn_val(args[pi], [val])
                pi = pi + 1
            }
            return val
        }
        if len(args) == 1 { return args[0] }
        return val_void()
    }
    if name == "curry" {
        if len(args) >= 1 {
            let f = args[0]
            let mut partial = []
            let mut pi = 1
            while pi < len(args) {
                partial = partial.push(args[pi])
                pi = pi + 1
            }
            // Build closure capturing f and partial args
            let mut captured = []
            let mut ci = 0
            while ci < len(env_vars) {
                captured = captured.push([env_vars[ci][0], env_vars[ci][1]])
                ci = ci + 1
            }
            captured = captured.push(["__curry_fn", f])
            captured = captured.push(["__curry_partial", val_array(partial)])
            let idx = len(closure_store)
            closure_store = closure_store.push([captured, []])
            return Val { tag: TAG_FN, int_val: idx, float_val: 0.0, bool_val: false, str_val: "curry", char_val: "", array_val: "", fn_name: "__curried__", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
        }
        return val_void()
    }
    if name == "identity" {
        if len(args) > 0 { return args[0] }
        return val_void()
    }
    if name == "constant" {
        if len(args) > 0 {
            let val = args[0]
            let mut captured = []
            let mut ci = 0
            while ci < len(env_vars) {
                captured = captured.push([env_vars[ci][0], env_vars[ci][1]])
                ci = ci + 1
            }
            captured = captured.push(["__constant_val", val])
            let idx = len(closure_store)
            closure_store = closure_store.push([captured, []])
            return Val { tag: TAG_FN, int_val: idx, float_val: 0.0, bool_val: false, str_val: "constant", char_val: "", array_val: "", fn_name: "__constant__", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
        }
        return val_void()
    }

    // ── String utility builtins (additions) ─────────────────
    if name == "center" {
        if len(args) >= 3 && args[0].tag == TAG_STR {
            let s = args[0].str_val
            let width = args[1].int_val
            let ch = args[2].str_val
            let slen = len(s)
            if slen >= width { return val_str(s) }
            let total_pad = width - slen
            let left_pad = total_pad / 2
            let right_pad = total_pad - left_pad
            let mut out = ""
            let mut li = 0
            while li < left_pad { out = out + ch; li = li + 1 }
            out = out + s
            let mut ri = 0
            while ri < right_pad { out = out + ch; ri = ri + 1 }
            return val_str(out)
        }
        return val_str("")
    }
    if name == "str_count" || (name == "count" && len(args) >= 2 && args[0].tag == TAG_STR) {
        // count(s, substr) / str_count(s, substr) — count occurrences of substr in s
        if len(args) >= 2 && args[0].tag == TAG_STR && args[1].tag == TAG_STR {
            let s = args[0].str_val
            let sub = args[1].str_val
            let slen = len(s)
            let sublen = len(sub)
            if sublen == 0 { return val_int(0) }
            let mut cnt = 0
            let mut i = 0
            while i <= slen - sublen {
                if s.substring(i, i + sublen) == sub {
                    cnt = cnt + 1
                    i = i + sublen
                } else {
                    i = i + 1
                }
            }
            return val_int(cnt)
        }
        return val_int(0)
    }
    if name == "reverse" {
        // reverse(s) — reverse a string
        if len(args) > 0 && args[0].tag == TAG_STR {
            let cs = args[0].str_val.chars()
            let mut out = ""
            let mut ri = len(cs) - 1
            while ri >= 0 {
                out = out + to_string(cs[ri])
                ri = ri - 1
            }
            return val_str(out)
        }
        // reverse(array) — reverse an array
        if len(args) > 0 && args[0].tag == TAG_ARRAY {
            let items = get_array(args[0])
            let mut result = []
            let mut ri = len(items) - 1
            while ri >= 0 {
                result = result.push(items[ri])
                ri = ri - 1
            }
            return val_array(result)
        }
        return val_void()
    }
    if name == "is_empty" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == TAG_STR { return val_bool(a.str_val == "") }
            if a.tag == TAG_ARRAY { return val_bool(len(get_array(a)) == 0) }
            if a.tag == TAG_MAP { return val_bool(len(get_map_keys(a)) == 0) }
            if a.tag == TAG_VOID { return val_bool(true) }
        }
        return val_bool(true)
    }
    if name == "format_number" {
        if len(args) >= 2 {
            let n = to_float_val(args[0])
            let decimals = args[1].int_val
            return val_str(to_string(round(n, decimals)))
        }
        return val_str("0")
    }
    if name == "hex" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n == 0 { return val_str("0x0") }
            let mut val = n
            let mut is_neg = false
            if val < 0 { is_neg = true; val = -val }
            let digits = "0123456789abcdef"
            let dchars = digits.chars()
            let mut out = ""
            while val > 0 {
                let rem = val % 16
                out = to_string(dchars[rem]) + out
                val = val / 16
            }
            if is_neg { out = "-0x" + out } else { out = "0x" + out }
            return val_str(out)
        }
        return val_str("0x0")
    }
    if name == "bin" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n == 0 { return val_str("0b0") }
            let mut val = n
            let mut is_neg = false
            if val < 0 { is_neg = true; val = -val }
            let mut out = ""
            while val > 0 {
                if val % 2 == 1 { out = "1" + out } else { out = "0" + out }
                val = val / 2
            }
            if is_neg { out = "-0b" + out } else { out = "0b" + out }
            return val_str(out)
        }
        return val_str("0b0")
    }

    // ── Math builtins (additions) ───────────────────────────
    if name == "sign" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == TAG_INT {
                if a.int_val > 0 { return val_int(1) }
                if a.int_val < 0 { return val_int(-1) }
                return val_int(0)
            }
            if a.tag == TAG_FLOAT {
                if a.float_val > 0.0 { return val_int(1) }
                if a.float_val < 0.0 { return val_int(-1) }
                return val_int(0)
            }
        }
        return val_int(0)
    }
    if name == "gcd" {
        if len(args) >= 2 {
            let mut a = args[0].int_val
            let mut b = args[1].int_val
            if a < 0 { a = -a }
            if b < 0 { b = -b }
            while b != 0 {
                let t = b
                b = a % b
                a = t
            }
            return val_int(a)
        }
        return val_int(0)
    }
    if name == "lcm" {
        if len(args) >= 2 {
            let mut a = args[0].int_val
            let mut b = args[1].int_val
            if a < 0 { a = -a }
            if b < 0 { b = -b }
            if a == 0 || b == 0 { return val_int(0) }
            // lcm = |a*b| / gcd(a,b)
            let mut ga = a
            let mut gb = b
            while gb != 0 {
                let t = gb
                gb = ga % gb
                ga = t
            }
            return val_int((a / ga) * b)
        }
        return val_int(0)
    }
    if name == "factorial" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n < 0 { return val_int(0) }
            let mut result = 1
            let mut fi = 2
            while fi <= n {
                result = result * fi
                fi = fi + 1
            }
            return val_int(result)
        }
        return val_int(1)
    }
    if name == "fib" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n <= 0 { return val_int(0) }
            if n == 1 { return val_int(1) }
            let mut a = 0
            let mut b = 1
            let mut fi = 2
            while fi <= n {
                let tmp = a + b
                a = b
                b = tmp
                fi = fi + 1
            }
            return val_int(b)
        }
        return val_int(0)
    }
    if name == "is_prime" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n < 2 { return val_bool(false) }
            if n < 4 { return val_bool(true) }
            if n % 2 == 0 { return val_bool(false) }
            if n % 3 == 0 { return val_bool(false) }
            let mut i = 5
            while i * i <= n {
                if n % i == 0 || n % (i + 2) == 0 { return val_bool(false) }
                i = i + 6
            }
            return val_bool(true)
        }
        return val_bool(false)
    }
    if name == "mod" {
        // Euclidean modulo: always returns non-negative for positive divisor
        if len(args) >= 2 {
            let a = args[0].int_val
            let b = args[1].int_val
            if b == 0 { return val_int(0) }
            let r = a % b
            if r < 0 { return val_int(r + abs(b)) }
            return val_int(r)
        }
        return val_int(0)
    }

    // ═══════════════════════════════════════════════════════
    //  Phase 2-5 골화 — Tensor / BLAS / Quant / Attention
    //  src/interpreter.rs:4779-5400 대응
    // ═══════════════════════════════════════════════════════

    // ── tensor(array, shape?) — flat data + optional shape ──
    if name == "tensor" {
        if len(args) == 0 { return val_void() }
        // already a tensor → identity
        if args[0].tag == TAG_TENSOR { return args[0] }
        let src = get_array(args[0])
        let mut data = []
        for v in src { data = data.push(to_float_val(v)) }
        // Refactored 2026-04-13 to avoid if-expr-as-value codegen bug.
        // Original: let shape = if cond { let mut shp = []; ...; shp } else { [len(data)] }
        let mut shape = [len(data)]
        if len(args) > 1 && args[1].tag == TAG_ARRAY {
            let s_arr = get_array(args[1])
            let mut shp = []
            for sv in s_arr { shp = shp.push(sv.int_val) }
            shape = shp
        }
        return val_tensor(shape, data)
    }
    if name == "tensor_zeros" {
        let n = args[0].int_val
        if n < 0 { return val_void() }
        let mut data = []
        let mut zi = 0
        while zi < n { data = data.push(0.0); zi = zi + 1 }
        return val_tensor([n], data)
    }
    if name == "tensor_fill" {
        let n = args[0].int_val
        let v = to_float_val(args[1])
        if n < 0 { return val_void() }
        let mut data = []
        let mut fi = 0
        while fi < n { data = data.push(v); fi = fi + 1 }
        return val_tensor([n], data)
    }
    if name == "tensor_last_row" {
        // tensor_last_row(t, rows, cols) — return shape=[cols] copy of last row
        let rows = args[1].int_val
        let cols = args[2].int_val
        if rows <= 0 || cols <= 0 { return val_void() }
        let src = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n_src = len(src)
        if n_src < rows * cols { return val_void() }
        let base = (rows - 1) * cols
        let mut data = []
        let mut ri = 0
        while ri < cols {
            let v = src[base + ri]
            if type_of(v) == "float" { data = data.push(v) }
            else { data = data.push(to_float_val(v)) }
            ri = ri + 1
        }
        return val_tensor([cols], data)
    }
    // weight_dict([names], [tensors]) → map name -> tensor
    if name == "weight_dict" {
        let names = get_array(args[0])
        let tensors = get_array(args[1])
        let mut keys = []
        let mut vals = []
        let mut wi = 0
        while wi < len(names) && wi < len(tensors) {
            keys = keys.push(names[wi])
            vals = vals.push(tensors[wi])
            wi = wi + 1
        }
        return val_map(keys, vals)
    }
    // dot(a, b) — vector dot product (returns float)
    if name == "dot" {
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n_dot = if len(a) < len(b) { len(a) } else { len(b) }
        let mut acc = 0.0
        let mut di = 0
        while di < n_dot {
            let av = if type_of(a[di]) == "float" { a[di] } else { to_float_val(a[di]) }
            let bv = if type_of(b[di]) == "float" { b[di] } else { to_float_val(b[di]) }
            acc = acc + av * bv
            di = di + 1
        }
        return val_float(acc)
    }

    // ── BLAS kernels (Phase 3) ──
    // matmul_into(out, a, b, m, n, k) — out[m,n] = a[m,k] · b[k,n]
    if name == "matmul_into" {
        let out_t = args[0]
        let a = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let b = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let m = args[3].int_val
        let n = args[4].int_val
        let k = args[5].int_val
        let mut out = if out_t.tag == TAG_TENSOR { tensor_data(out_t) } else { [] }
        if len(out) < m * n {
            // grow
            let mut z = 0
            while len(out) < m * n { out = out.push(0.0); z = z + 1 }
        }
        let mut mi = 0
        while mi < m {
            let mut nj = 0
            while nj < n {
                let mut acc = 0.0
                let mut kk = 0
                while kk < k {
                    acc = acc + a[mi * k + kk] * b[kk * n + nj]
                    kk = kk + 1
                }
                out[mi * n + nj] = acc
                nj = nj + 1
            }
            mi = mi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([m, n], out)
    }
    // matmul_into_accumulate(out, a, b, m, n, k) — out += a · b
    if name == "matmul_into_accumulate" {
        let out_t = args[0]
        let a = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let b = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let m = args[3].int_val
        let n = args[4].int_val
        let k = args[5].int_val
        let mut out = if out_t.tag == TAG_TENSOR { tensor_data(out_t) } else { [] }
        while len(out) < m * n { out = out.push(0.0) }
        let mut mi = 0
        while mi < m {
            let mut nj = 0
            while nj < n {
                let mut acc = out[mi * n + nj]
                let mut kk = 0
                while kk < k {
                    acc = acc + a[mi * k + kk] * b[kk * n + nj]
                    kk = kk + 1
                }
                out[mi * n + nj] = acc
                nj = nj + 1
            }
            mi = mi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([m, n], out)
    }
    // matmul_transpose_a_into(out, a, b, m, n, k) — out = aᵀ · b, a shape [k,m]
    if name == "matmul_transpose_a_into" {
        let out_t = args[0]
        let a = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let b = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let m = args[3].int_val
        let n = args[4].int_val
        let k = args[5].int_val
        let mut out = if out_t.tag == TAG_TENSOR { tensor_data(out_t) } else { [] }
        while len(out) < m * n { out = out.push(0.0) }
        let mut mi = 0
        while mi < m {
            let mut nj = 0
            while nj < n {
                let mut acc = 0.0
                let mut kk = 0
                while kk < k {
                    acc = acc + a[kk * m + mi] * b[kk * n + nj]
                    kk = kk + 1
                }
                out[mi * n + nj] = acc
                nj = nj + 1
            }
            mi = mi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([m, n], out)
    }
    // matmul_transpose_b_into(out, a, b, m, n, k) — out = a · bᵀ, b shape [n,k]
    if name == "matmul_transpose_b_into" {
        let out_t = args[0]
        let a = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let b = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let m = args[3].int_val
        let n = args[4].int_val
        let k = args[5].int_val
        let mut out = if out_t.tag == TAG_TENSOR { tensor_data(out_t) } else { [] }
        while len(out) < m * n { out = out.push(0.0) }
        let mut mi = 0
        while mi < m {
            let mut nj = 0
            while nj < n {
                let mut acc = 0.0
                let mut kk = 0
                while kk < k {
                    acc = acc + a[mi * k + kk] * b[nj * k + kk]
                    kk = kk + 1
                }
                out[mi * n + nj] = acc
                nj = nj + 1
            }
            mi = mi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([m, n], out)
    }
    // axpy(out, a, x, y) — out = a*x + y (BLAS-1)
    if name == "axpy" {
        let out_t = args[0]
        let alpha = to_float_val(args[1])
        let x = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let y = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let n_axpy = if len(x) < len(y) { len(x) } else { len(y) }
        let mut out = []
        let mut ai = 0
        while ai < n_axpy {
            out = out.push(alpha * x[ai] + y[ai])
            ai = ai + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([n_axpy], out)
    }
    // mat_add(a, b) — element-wise addition
    if name == "mat_add" {
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n_add = if len(a) < len(b) { len(a) } else { len(b) }
        let mut out = []
        let mut ai = 0
        while ai < n_add { out = out.push(a[ai] + b[ai]); ai = ai + 1 }
        let shape = if args[0].tag == TAG_TENSOR { tensor_shape(args[0]) } else { [n_add] }
        return val_tensor(shape, out)
    }
    // mat_scale_inplace(t, s) — t *= s in place
    if name == "mat_scale_inplace" {
        let t = args[0]
        let s_scale = to_float_val(args[1])
        if t.tag != TAG_TENSOR { return val_void() }
        let data = tensor_data(t)
        let mut out = []
        for v in data { out = out.push(v * s_scale) }
        tensor_set_data(t, out)
        return t
    }

    // ── Quant + GGUF (Phase 4) ──
    // q4_0_dequantize(blocks, n_elements) — Q4_0 → f32 array
    // Q4_0 block: 18 bytes = 2 bytes f16 scale + 16 bytes (32 quants × 4 bits)
    if name == "q4_0_dequantize" {
        let blocks = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n_elem = args[1].int_val
        let mut out = []
        let n_blocks = n_elem / 32
        let mut bi = 0
        while bi < n_blocks {
            let block_off = bi * 18
            // f16 scale (we approximate via float read; real impl needs f16 decode)
            let scale = blocks[block_off + 0]
            let mut qi = 0
            while qi < 16 {
                let byte = blocks[block_off + 2 + qi]
                let lo = (byte % 16) - 8
                let hi = (byte / 16) - 8
                out = out.push(scale * lo)
                out = out.push(scale * hi)
                qi = qi + 1
            }
            bi = bi + 1
        }
        return val_tensor([n_elem], out)
    }
    // q4_0_matvec(out, weight_q, x, m, k) — y[m] = W[m,k] · x[k] (W in Q4_0)
    if name == "q4_0_matvec" {
        let out_t = args[0]
        let w = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let x = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let m = args[3].int_val
        let k = args[4].int_val
        let block_size = 32
        let n_blocks_per_row = k / block_size
        let block_bytes = 18
        let mut out = []
        let mut mi = 0
        while mi < m {
            let mut acc = 0.0
            let mut bi = 0
            while bi < n_blocks_per_row {
                let block_off = (mi * n_blocks_per_row + bi) * block_bytes
                let scale = w[block_off]
                let mut qi = 0
                while qi < 16 {
                    let byte = w[block_off + 2 + qi]
                    let lo = (byte % 16) - 8
                    let hi = (byte / 16) - 8
                    let xi = bi * block_size + qi * 2
                    acc = acc + scale * lo * x[xi]
                    acc = acc + scale * hi * x[xi + 1]
                    qi = qi + 1
                }
                bi = bi + 1
            }
            out = out.push(acc)
            mi = mi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([m], out)
    }
    // mmap_gguf(path) → [names, tensors] — stub: delegates to file_read + parse
    if name == "mmap_gguf" || name == "mmap_weights" || name == "load_weights_bin" {
        // Real GGUF parsing requires byte-level f16/i32 decoding which the
        // self-host interpreter cannot do efficiently. We expose an error tag
        // value that downstream code can detect; production code uses Rust path.
        return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "mmap_gguf: requires native runtime (not available in self-host)", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
    }

    // ── Attention fusion (Phase 5) ──
    // gqa_expand_kv_into(out, kv, n_kv_head, n_head, head_dim) — broadcast KV groups
    if name == "gqa_expand_kv_into" {
        let out_t = args[0]
        let kv = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n_kv = args[2].int_val
        let n_h = args[3].int_val
        let head_dim = args[4].int_val
        let group = n_h / n_kv
        let mut out = []
        let mut hi = 0
        while hi < n_h {
            let kv_idx = hi / group
            let base = kv_idx * head_dim
            let mut di = 0
            while di < head_dim {
                out = out.push(kv[base + di])
                di = di + 1
            }
            hi = hi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([n_h * head_dim], out)
    }
    // qkv_fused_into(q_out, k_out, v_out, w_qkv, x, n_q, n_k, n_v, dim) — fused proj
    if name == "qkv_fused_into" {
        let q_out = args[0]
        let k_out = args[1]
        let v_out = args[2]
        let w = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let x = if args[4].tag == TAG_TENSOR { tensor_data(args[4]) } else { get_array(args[4]) }
        let n_q = args[5].int_val
        let n_k = args[6].int_val
        let n_v = args[7].int_val
        let dim = args[8].int_val
        let total = n_q + n_k + n_v
        let mut all_out = []
        let mut oi = 0
        while oi < total {
            let mut acc = 0.0
            let mut di = 0
            while di < dim { acc = acc + w[oi * dim + di] * x[di]; di = di + 1 }
            all_out = all_out.push(acc)
            oi = oi + 1
        }
        let mut q_data = []
        let mut k_data = []
        let mut v_data = []
        let mut si = 0
        while si < n_q { q_data = q_data.push(all_out[si]); si = si + 1 }
        while si < n_q + n_k { k_data = k_data.push(all_out[si]); si = si + 1 }
        while si < total { v_data = v_data.push(all_out[si]); si = si + 1 }
        if q_out.tag == TAG_TENSOR { tensor_set_data(q_out, q_data) }
        if k_out.tag == TAG_TENSOR { tensor_set_data(k_out, k_data) }
        if v_out.tag == TAG_TENSOR { tensor_set_data(v_out, v_data) }
        return val_void()
    }
    // repeat_kv(kv, n_repeat, n_kv_head, head_dim) — broadcast each KV head n_repeat times
    if name == "repeat_kv" {
        let kv = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n_rep = args[1].int_val
        let n_kv = args[2].int_val
        let head_dim = args[3].int_val
        let mut out = []
        let mut hi = 0
        while hi < n_kv {
            let base = hi * head_dim
            let mut ri = 0
            while ri < n_rep {
                let mut di = 0
                while di < head_dim { out = out.push(kv[base + di]); di = di + 1 }
                ri = ri + 1
            }
            hi = hi + 1
        }
        return val_tensor([n_kv * n_rep * head_dim], out)
    }

    return not_builtin
}

// ── Method dispatch ──────────────────────────────────────

fn call_method(obj, method, args) {
    // ── Error fallback (P13 골화, mirrors src/interpreter.rs:3717) ──
    // exec(...).trim() 패턴이 subprocess 실패 시 Error → .trim() 크래시로 이어지던
    // P11 안티패턴 영구 소거. tag="error"는 string method 호출 시 안전 기본값 반환.
    if obj.tag == TAG_ERROR {
        if method == "trim" || method == "to_lower" || method == "to_upper" || method == "to_lowercase" || method == "to_uppercase" {
            return val_str("")
        }
        if method == "len" { return val_int(0) }
        if method == "is_empty" { return val_bool(true) }
        if method == "contains" || method == "starts_with" || method == "ends_with" {
            return val_bool(false)
        }
        if method == "split" || method == "lines" || method == "chars" || method == "bytes" {
            return val_array([])
        }
        if method == "replace" || method == "replacen" { return val_str("") }
        if method == "find" || method == "rfind" || method == "index_of" { return val_int(-1) }
        if method == "to_string" { return val_str(obj.str_val) }
        // 그 외 메소드는 fall-through (오류 명시는 dispatcher 끝에서)
    }

    // String methods
    if obj.tag == TAG_STR {
        let s = obj.str_val
        if method == "chars" {
            let cs = s.chars()
            let mut result = []
            for c in cs { result = result.push(val_str(to_string(c))) }
            return val_array(result)
        }
        if method == "len" { return val_int(len(s)) }
        if method == "contains" { return val_bool(s.contains(args[0].str_val)) }
        if method == "starts_with" { return val_bool(s.starts_with(args[0].str_val)) }
        if method == "ends_with" { return val_bool(s.ends_with(args[0].str_val)) }
        if method == "to_upper" { return val_str(s.to_upper()) }
        if method == "to_lower" { return val_str(s.to_lower()) }
        if method == "trim" { return val_str(s.trim()) }
        if method == "split" {
            let parts = s.split(args[0].str_val)
            let mut result = []
            for p in parts { result = result.push(val_str(p)) }
            return val_array(result)
        }
        if method == "replace" { return val_str(s.replace(args[0].str_val, args[1].str_val)) }
        if method == "substring" { return val_str(s.substring(args[0].int_val, args[1].int_val)) }
        if method == "index_of" { return val_int(s.index_of(args[0].str_val)) }
        if method == "repeat" {
            let n = args[0].int_val
            let mut result = ""
            let mut ri = 0
            while ri < n {
                result = result + s
                ri = ri + 1
            }
            return val_str(result)
        }
        if method == "reverse" {
            let cs = s.chars()
            let mut out = ""
            let mut ri = len(cs) - 1
            while ri >= 0 {
                out = out + to_string(cs[ri])
                ri = ri - 1
            }
            return val_str(out)
        }
        if method == "is_empty" {
            return val_bool(s == "")
        }
        if method == "count" {
            // .count(substr) — count occurrences
            if len(args) > 0 && args[0].tag == TAG_STR {
                let sub = args[0].str_val
                let slen = len(s)
                let sublen = len(sub)
                if sublen == 0 { return val_int(0) }
                let mut cnt = 0
                let mut ci = 0
                while ci <= slen - sublen {
                    if s.substring(ci, ci + sublen) == sub {
                        cnt = cnt + 1
                        ci = ci + sublen
                    } else {
                        ci = ci + 1
                    }
                }
                return val_int(cnt)
            }
            return val_int(0)
        }
        if method == "pad_left" {
            let width = args[0].int_val
            let ch = args[1].str_val
            let mut out = s
            while len(out) < width { out = ch + out }
            return val_str(out)
        }
        if method == "pad_right" {
            let width = args[0].int_val
            let ch = args[1].str_val
            let mut out = s
            while len(out) < width { out = out + ch }
            return val_str(out)
        }
        if method == "center" {
            let width = args[0].int_val
            let ch = args[1].str_val
            let slen = len(s)
            if slen >= width { return val_str(s) }
            let total_pad = width - slen
            let left_pad = total_pad / 2
            let right_pad = total_pad - left_pad
            let mut out = ""
            let mut li = 0
            while li < left_pad { out = out + ch; li = li + 1 }
            out = out + s
            let mut ri = 0
            while ri < right_pad { out = out + ch; ri = ri + 1 }
            return val_str(out)
        }
        // ── String methods ported from src/interpreter.rs call_string_method ──
        if method == "trim_start" { return val_str(s.trim_start()) }
        if method == "trim_end" { return val_str(s.trim_end()) }
        if method == "parse_int" {
            let trimmed = s.trim()
            let n = to_int(trimmed)
            return val_int(n)
        }
        if method == "parse_float" {
            let trimmed = s.trim()
            let n = to_float(val_str(trimmed))
            return val_float(n)
        }
        if method == "join" {
            // "sep".join(array) — join array elements with separator
            if len(args) > 0 && args[0].tag == TAG_ARRAY {
                let items = get_array(args[0])
                let mut out = ""
                let mut ji = 0
                for item in items {
                    if ji > 0 { out = out + s }
                    out = out + val_to_string(item)
                    ji = ji + 1
                }
                return val_str(out)
            }
            return val_str("")
        }
        if method == "bytes" {
            let cs = s.chars()
            let mut result = []
            for c in cs { result = result.push(val_int(char_code(to_string(c), 0))) }
            return val_array(result)
        }
    }

    // ── Phase 7 골화 — Pointer methods ──
    if obj.tag == TAG_POINTER {
        if method == "is_null" { return val_bool(obj.int_val == 0) }
        if method == "addr" { return val_int(obj.int_val) }
        if method == "to_string" { return val_str("0x" + hex(obj.int_val)) }
    }

    // ── Phase 7 골화 — Atomic methods ──
    if obj.tag == TAG_ATOMIC {
        if method == "load" { return atomic_load(obj) }
        if method == "store" { atomic_store_op(obj, args[0]); return val_void() }
        if method == "compare_swap" || method == "compare_and_swap" {
            return atomic_compare_swap(obj, args[0], args[1])
        }
        if method == "fetch_add" { return atomic_fetch_add(obj, args[0]) }
    }

    // ── Phase 7 골화 — Channel methods (Sender/Receiver unified) ──
    if obj.tag == TAG_CHANNEL {
        if method == "send" { return val_bool(channel_send(obj, args[0])) }
        if method == "recv" {
            let r = channel_recv(obj)
            if r.tag == TAG_VOID {
                return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "channel closed", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
            }
            return r
        }
        if method == "try_recv" {
            let r = channel_recv(obj)
            // Some(r) | None as enum
            if r.tag == TAG_VOID { return val_enum("Option", "None", "") }
            return val_enum("Option", "Some", r)
        }
        if method == "close" { channel_close(obj); return val_void() }
        if method == "receiver" { return val_channel_recv_view(obj) }
    }

    // ── Phase 2 골화 — Tensor methods ──
    if obj.tag == TAG_TENSOR {
        if method == "shape" {
            let shp = tensor_shape(obj)
            let mut wrapped = []
            for d in shp { wrapped = wrapped.push(val_int(d)) }
            return val_array(wrapped)
        }
        if method == "data" {
            let d = tensor_data(obj)
            let mut wrapped = []
            for v in d { wrapped = wrapped.push(val_float(v)) }
            return val_array(wrapped)
        }
        if method == "numel" || method == "len" { return val_int(tensor_numel(obj)) }
        if method == "rank" { return val_int(len(tensor_shape(obj))) }
        if method == "to_array" {
            let d = tensor_data(obj)
            let mut wrapped = []
            for v in d { wrapped = wrapped.push(val_float(v)) }
            return val_array(wrapped)
        }
    }

    // ── Phase 4 골화 — BigInt methods ──
    if obj.tag == TAG_BIGINT {
        if method == "to_string" { return val_str(bigint_str(obj)) }
        if method == "to_int" { return val_int(to_int(bigint_str(obj))) }
    }

    // Array methods
    if obj.tag == TAG_ARRAY {
        let items = get_array(obj)
        if method == "len" { return val_int(len(items)) }
        // Perf #10: in-place push when sole owner (refcount==1), else COW
        if method == "push" { return array_push_inplace(obj, args[0]) }
        // bt 55 — truncate: in-place length shrink. Sole owner mutates
        // backing store via host .truncate (retains cap); shared path COWs.
        if method == "truncate" {
            let mut new_len = args[0].int_val
            if new_len < 0 { new_len = 0 }
            if new_len > len(items) { new_len = len(items) }
            let idx = obj.int_val
            if array_is_sole_owner(idx) {
                array_store[idx] = items.truncate(new_len)
                return obj
            }
            // Shared: COW — build a truncated copy, decref old
            let mut copy = []
            let mut ti = 0
            while ti < new_len {
                copy = copy.push(items[ti])
                ti = ti + 1
            }
            array_decref(idx)
            return val_array(copy)
        }
        if method == "pop" {
            if len(items) == 0 { return val_array([]) }
            let mut result = []
            let mut pi = 0
            while pi < len(items) - 1 {
                result = result.push(items[pi])
                pi = pi + 1
            }
            return val_array(result)
        }
        if method == "contains" {
            let target = args[0]
            for item in items {
                if val_eq(item, target) { return val_bool(true) }
            }
            return val_bool(false)
        }
        if method == "join" {
            let sep = args[0].str_val
            let mut out = ""
            let mut ji = 0
            for item in items {
                if ji > 0 { out = out + sep }
                out = out + val_to_string(item)
                ji = ji + 1
            }
            return val_str(out)
        }
        if method == "index_of" {
            let target = args[0]
            let mut ii = 0
            while ii < len(items) {
                if val_eq(items[ii], target) { return val_int(ii) }
                ii = ii + 1
            }
            return val_int(-1)
        }
        if method == "slice" {
            let start = args[0].int_val
            let end_idx = args[1].int_val
            let mut result = []
            let mut si = start
            while si < end_idx && si < len(items) {
                result = result.push(items[si])
                si = si + 1
            }
            return val_array(result)
        }
        if method == "reverse" {
            let mut result = []
            let mut ri = len(items) - 1
            while ri >= 0 {
                result = result.push(items[ri])
                ri = ri - 1
            }
            return val_array(result)
        }
        if method == "map" {
            let mut result = []
            for item in items {
                result = result.push(call_fn_val(args[0], [item]))
            }
            return val_array(result)
        }
        if method == "filter" {
            let mut result = []
            for item in items {
                let keep = call_fn_val(args[0], [item])
                if is_truthy(keep) { result = result.push(item) }
            }
            return val_array(result)
        }
        if method == "fold" {
            let mut acc = args[0]
            let f = args[1]
            for item in items {
                acc = call_fn_val(f, [acc, item])
            }
            return acc
        }
        if method == "for_each" {
            for item in items {
                call_fn_val(args[0], [item])
            }
            return val_void()
        }
        if method == "any" {
            for item in items {
                let r = call_fn_val(args[0], [item])
                if is_truthy(r) { return val_bool(true) }
            }
            return val_bool(false)
        }
        if method == "all" {
            for item in items {
                let r = call_fn_val(args[0], [item])
                if !is_truthy(r) { return val_bool(false) }
            }
            return val_bool(true)
        }
        if method == "flat_map" {
            let mut result = []
            for item in items {
                let sub = call_fn_val(args[0], [item])
                if sub.tag == TAG_ARRAY {
                    let sub_items = get_array(sub)
                    for s in sub_items { result = result.push(s) }
                } else {
                    result = result.push(sub)
                }
            }
            return val_array(result)
        }
        if method == "sort" {
            let sorted = sort_array(items)
            return val_array(sorted)
        }
        if method == "enumerate" {
            let mut result = []
            let mut ei = 0
            while ei < len(items) {
                result = result.push(val_array([val_int(ei), items[ei]]))
                ei = ei + 1
            }
            return val_array(result)
        }
        if method == "zip" {
            if len(args) > 0 && args[0].tag == TAG_ARRAY {
                let other = get_array(args[0])
                let mut result = []
                let mut zi = 0
                let zn = min(len(items), len(other))
                while zi < zn {
                    result = result.push(val_array([items[zi], other[zi]]))
                    zi = zi + 1
                }
                return val_array(result)
            }
            return val_array([])
        }
        if method == "take" {
            let n = args[0].int_val
            let mut result = []
            let mut ti = 0
            while ti < n && ti < len(items) {
                result = result.push(items[ti])
                ti = ti + 1
            }
            return val_array(result)
        }
        if method == "drop" {
            let n = args[0].int_val
            let mut result = []
            let mut di = n
            while di < len(items) {
                result = result.push(items[di])
                di = di + 1
            }
            return val_array(result)
        }
        if method == "unique" {
            let mut result = []
            let mut seen = []
            for item in items {
                let key = val_to_string(item)
                let mut found = false
                for s in seen {
                    if s == key { found = true }
                }
                if !found {
                    result = result.push(item)
                    seen = seen.push(key)
                }
            }
            return val_array(result)
        }
        if method == "count" {
            let mut c = 0
            for item in items {
                let r = call_fn_val(args[0], [item])
                if is_truthy(r) { c = c + 1 }
            }
            return val_int(c)
        }
        if method == "find" {
            for item in items {
                let r = call_fn_val(args[0], [item])
                if is_truthy(r) { return item }
            }
            return val_void()
        }
        if method == "group_by" {
            let mut keys = []
            let mut values = []
            for item in items {
                let key = call_fn_val(args[0], [item])
                let key_str = val_to_string(key)
                let mut found_idx = -1
                let mut gi = 0
                while gi < len(keys) {
                    if val_to_string(keys[gi]) == key_str { found_idx = gi }
                    gi = gi + 1
                }
                if found_idx == -1 {
                    keys = keys.push(key)
                    values = values.push(val_array([item]))
                } else {
                    let existing = get_array(values[found_idx])
                    values[found_idx] = val_array(existing.push(item))
                }
            }
            return val_map(keys, values)
        }
        if method == "flatten" {
            let mut result = []
            for item in items {
                if item.tag == TAG_ARRAY {
                    let sub = get_array(item)
                    for s in sub { result = result.push(s) }
                } else {
                    result = result.push(item)
                }
            }
            return val_array(result)
        }
        if method == "sum" {
            let mut has_float = false
            let mut total = 0.0
            for item in items {
                if item.tag == TAG_FLOAT { has_float = true }
                total = total + to_float_val(item)
            }
            if has_float { return val_float(total) }
            return val_int(floor(total))
        }
        if method == "min" {
            if len(items) == 0 { return val_void() }
            let mut best = items[0]
            let mut mi = 1
            while mi < len(items) {
                if to_float_val(items[mi]) < to_float_val(best) { best = items[mi] }
                mi = mi + 1
            }
            return best
        }
        if method == "max" {
            if len(items) == 0 { return val_void() }
            let mut best = items[0]
            let mut mi = 1
            while mi < len(items) {
                if to_float_val(items[mi]) > to_float_val(best) { best = items[mi] }
                mi = mi + 1
            }
            return best
        }
        if method == "chunk" {
            let n = args[0].int_val
            if n <= 0 { return val_array([]) }
            let mut result = []
            let mut ci = 0
            while ci < len(items) {
                let mut chunk = []
                let mut cj = 0
                while cj < n && ci + cj < len(items) {
                    chunk = chunk.push(items[ci + cj])
                    cj = cj + 1
                }
                result = result.push(val_array(chunk))
                ci = ci + n
            }
            return val_array(result)
        }
        if method == "window" {
            let n = args[0].int_val
            if n <= 0 || n > len(items) { return val_array([]) }
            let mut result = []
            let mut wi = 0
            while wi <= len(items) - n {
                let mut win = []
                let mut wj = 0
                while wj < n {
                    win = win.push(items[wi + wj])
                    wj = wj + 1
                }
                result = result.push(val_array(win))
                wi = wi + 1
            }
            return val_array(result)
        }
        if method == "scan" {
            // .scan(init, fn) — like fold but returns intermediate results
            let mut acc = args[0]
            let f = args[1]
            let mut result = [acc]
            for item in items {
                acc = call_fn_val(f, [acc, item])
                result = result.push(acc)
            }
            return val_array(result)
        }
        if method == "partition" {
            let pred = args[0]
            let mut matching = []
            let mut non_matching = []
            for item in items {
                let r = call_fn_val(pred, [item])
                if is_truthy(r) {
                    matching = matching.push(item)
                } else {
                    non_matching = non_matching.push(item)
                }
            }
            return val_array([val_array(matching), val_array(non_matching)])
        }
        if method == "interleave" {
            if len(args) > 0 && args[0].tag == TAG_ARRAY {
                let other = get_array(args[0])
                let mut result = []
                let max_len = max(len(items), len(other))
                let mut ii = 0
                while ii < max_len {
                    if ii < len(items) { result = result.push(items[ii]) }
                    if ii < len(other) { result = result.push(other[ii]) }
                    ii = ii + 1
                }
                return val_array(result)
            }
            return val_array(items)
        }
        if method == "frequencies" {
            let mut keys = []
            let mut values = []
            for item in items {
                let key_str = val_to_string(item)
                let mut found_idx = -1
                let mut fi = 0
                while fi < len(keys) {
                    if val_to_string(keys[fi]) == key_str { found_idx = fi }
                    fi = fi + 1
                }
                if found_idx == -1 {
                    keys = keys.push(item)
                    values = values.push(val_int(1))
                } else {
                    values[found_idx] = val_int(values[found_idx].int_val + 1)
                }
            }
            return val_map(keys, values)
        }
        if method == "rotate" {
            let n_items = len(items)
            if n_items == 0 { return val_array([]) }
            let mut n = args[0].int_val
            // Normalize: positive = rotate left
            n = n % n_items
            if n < 0 { n = n + n_items }
            let mut result = []
            let mut ri = 0
            while ri < n_items {
                result = result.push(items[(ri + n) % n_items])
                ri = ri + 1
            }
            return val_array(result)
        }
        if method == "sample" {
            let n = args[0].int_val
            let n_items = len(items)
            if n_items == 0 || n <= 0 { return val_array([]) }
            let mut result = []
            let mut si = 0
            while si < n {
                let idx = floor(random() * n_items)
                result = result.push(items[idx])
                si = si + 1
            }
            return val_array(result)
        }
        // .fill(value) — return new array of same length, all entries = value
        if method == "fill" {
            let v = args[0]
            let mut result = []
            let mut fi = 0
            while fi < len(items) {
                result = result.push(v)
                fi = fi + 1
            }
            return val_array(result)
        }
        // .swap(i, j) — return new array with positions i and j swapped
        if method == "swap" {
            let i = args[0].int_val
            let j = args[1].int_val
            let n_items = len(items)
            if i < 0 || j < 0 || i >= n_items || j >= n_items { return val_array(items) }
            let mut result = []
            let mut si = 0
            while si < n_items {
                if si == i { result = result.push(items[j]) }
                else if si == j { result = result.push(items[i]) }
                else { result = result.push(items[si]) }
                si = si + 1
            }
            return val_array(result)
        }
    }

    // Map methods
    if obj.tag == TAG_MAP {
        if method == "get" { return map_get(obj, args[0]) }
        if method == "set" { return map_set(obj, args[0], args[1]) }
        if method == "contains_key" { return val_bool(map_contains_key(obj, args[0])) }
        if method == "keys" {
            let ks = get_map_keys(obj)
            return val_array(ks)
        }
        if method == "values" {
            let vs = get_map_values(obj)
            return val_array(vs)
        }
        if method == "len" { return val_int(len(get_map_keys(obj))) }
        if method == "remove" { return map_remove(obj, args[0]) }
        if method == "entries" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut result = []
            let mut ei = 0
            while ei < len(ks) {
                let pair = val_array([ks[ei], vs[ei]])
                result = result.push(pair)
                ei = ei + 1
            }
            return val_array(result)
        }
        if method == "merge" {
            if len(args) > 0 && args[0].tag == TAG_MAP {
                let other_ks = get_map_keys(args[0])
                let other_vs = get_map_values(args[0])
                let mut merged = obj
                let mut mi = 0
                while mi < len(other_ks) {
                    merged = map_set(merged, other_ks[mi], other_vs[mi])
                    mi = mi + 1
                }
                return merged
            }
            return obj
        }
        if method == "map_values" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut new_vs = []
            let mut mi = 0
            while mi < len(vs) {
                new_vs = new_vs.push(call_fn_val(args[0], [vs[mi]]))
                mi = mi + 1
            }
            return val_map(ks, new_vs)
        }
        if method == "filter_keys" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut new_ks = []
            let mut new_vs = []
            let mut mi = 0
            while mi < len(ks) {
                let keep = call_fn_val(args[0], [ks[mi]])
                if is_truthy(keep) {
                    new_ks = new_ks.push(ks[mi])
                    new_vs = new_vs.push(vs[mi])
                }
                mi = mi + 1
            }
            return val_map(new_ks, new_vs)
        }
        if method == "to_array" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut result = []
            let mut mi = 0
            while mi < len(ks) {
                result = result.push(val_array([ks[mi], vs[mi]]))
                mi = mi + 1
            }
            return val_array(result)
        }
        if method == "from_array" {
            // Static-like: called on empty map, takes an array of [key, val] pairs
            if len(args) > 0 && args[0].tag == TAG_ARRAY {
                let pairs = get_array(args[0])
                let mut new_ks = []
                let mut new_vs = []
                for pair in pairs {
                    if pair.tag == TAG_ARRAY {
                        let p = get_array(pair)
                        if len(p) >= 2 {
                            new_ks = new_ks.push(p[0])
                            new_vs = new_vs.push(p[1])
                        }
                    }
                }
                return val_map(new_ks, new_vs)
            }
            return val_map([], [])
        }
        if method == "invert" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            return val_map(vs, ks)
        }
        if method == "count" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            if len(args) > 0 {
                let pred = args[0]
                let mut cnt = 0
                let mut mi = 0
                while mi < len(ks) {
                    let r = call_fn_val(pred, [ks[mi], vs[mi]])
                    if is_truthy(r) { cnt = cnt + 1 }
                    mi = mi + 1
                }
                return val_int(cnt)
            }
            return val_int(len(ks))
        }
        if method == "any" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            if len(args) > 0 {
                let pred = args[0]
                let mut mi = 0
                while mi < len(ks) {
                    let r = call_fn_val(pred, [ks[mi], vs[mi]])
                    if is_truthy(r) { return val_bool(true) }
                    mi = mi + 1
                }
            }
            return val_bool(false)
        }
        if method == "all" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            if len(args) > 0 {
                let pred = args[0]
                let mut mi = 0
                while mi < len(ks) {
                    let r = call_fn_val(pred, [ks[mi], vs[mi]])
                    if !is_truthy(r) { return val_bool(false) }
                    mi = mi + 1
                }
            }
            return val_bool(true)
        }
    }

    // Struct method dispatch via impl blocks
    if obj.tag == TAG_STRUCT {
        let sname = obj.struct_name
        // Look for impl block method
        let mut ii = 0
        while ii < len(impl_store) {
            if impl_store[ii][0] == sname {
                let methods = impl_store[ii][1]
                let mut mi = 0
                while mi < len(methods) {
                    if methods[mi].name == method {
                        let m = methods[mi]
                        let mparams = m.params
                        let mbody = m.body
                        env_push_scope()
                        // Bind self to the object
                        env_define("self", obj)
                        // Bind remaining params (skip 'self' if first param)
                        // G22/G23: also handle defaults and named args
                        let mut pi = 0
                        let mut ai = 0
                        while pi < len(mparams) {
                            let mut pname = ""
                            if type_of(mparams[pi]) == "string" {
                                pname = mparams[pi]
                            } else {
                                pname = mparams[pi].name
                            }
                            if pname == "self" {
                                // skip — already bound
                            } else {
                                if ai < len(args) {
                                    env_define(pname, args[ai])
                                    ai = ai + 1
                                } else {
                                    // G23: check named args
                                    let mut mp_found = false
                                    let mut mni = 0
                                    while mni < len(pending_named_args) {
                                        if pending_named_args[mni][0] == pname {
                                            env_define(pname, pending_named_args[mni][1])
                                            mp_found = true
                                            mni = len(pending_named_args)
                                        }
                                        mni = mni + 1
                                    }
                                    if !mp_found {
                                        // G22: check default
                                        let mp = mparams[pi]
                                        if type_of(mp) != "string" && mp.left != "" {
                                            env_define(pname, eval_expr(mp.left))
                                        } else {
                                            env_define(pname, val_void())
                                        }
                                    }
                                }
                            }
                            pi = pi + 1
                        }
                        let saved_flag = return_flag
                        return_flag = false
                        let mut bi = 0
                        while bi < len(mbody) {
                            if return_flag { bi = len(mbody) } else {
                                exec_stmt_at(mbody, bi)
                                bi = bi + 1
                            }
                        }
                        let result = return_val
                        return_flag = saved_flag
                        return_val = val_void()
                        env_pop_scope()
                        return result
                    }
                    mi = mi + 1
                }
            }
            ii = ii + 1
        }
        // Also try field access on struct as a fn val
        let fields = get_struct_fields(obj)
        if type_of(fields) != "string" {
            // Try calling method as a stored function value in fields
        }
    }

    println("Runtime error: unknown method ." + method + "() on " + tag_name(obj.tag))
    return val_void()
}

// ── Helpers ──────────────────────────────────────────────

fn is_truthy(v) {
    if v.tag == TAG_BOOL { return v.bool_val }
    if v.tag == TAG_INT { return v.int_val != 0 }
    if v.tag == TAG_STR { return v.str_val != "" }
    if v.tag == TAG_VOID { return false }
    return true
}

fn val_to_string(v) {
    if v.tag == TAG_INT { return to_string(v.int_val) }
    if v.tag == TAG_FLOAT { return to_string(v.float_val) }
    if v.tag == TAG_BOOL { return to_string(v.bool_val) }
    if v.tag == TAG_STR { return v.str_val }
    if v.tag == TAG_VOID { return "void" }
    if v.tag == TAG_ARRAY {
        let items = get_array(v)
        let mut parts = []
        for item in items { parts = parts.push(val_to_string(item)) }
        return "[" + parts.join(", ") + "]"
    }
    if v.tag == TAG_MAP {
        let ks = get_map_keys(v)
        let vs = get_map_values(v)
        let mut parts = []
        let mut mi = 0
        while mi < len(ks) {
            parts = parts.push(val_to_string(ks[mi]) + ": " + val_to_string(vs[mi]))
            mi = mi + 1
        }
        return "{" + parts.join(", ") + "}"
    }
    if v.tag == TAG_FN { return "<fn " + v.fn_name + ">" }
    if v.tag == TAG_ENUM {
        let s = v.struct_name
        if v.int_val >= 0 {
            return s + "(" + val_to_string(get_enum_data(v)) + ")"
        }
        return s
    }
    return "<" + tag_name(v.tag) + ">"
}

// ── JSON serialization / deserialization ─────────────────

fn val_to_json(v) {
    if v.tag == TAG_INT { return to_string(v.int_val) }
    if v.tag == TAG_FLOAT { return to_string(v.float_val) }
    if v.tag == TAG_BOOL {
        if v.bool_val { return "true" } else { return "false" }
    }
    if v.tag == TAG_STR {
        // Escape special characters in JSON string
        let s = v.str_val
        let s = s.replace("\\", "\\\\")
        let s = s.replace("\"", "\\\"")
        let s = s.replace("\n", "\\n")
        let s = s.replace("\t", "\\t")
        return "\"" + s + "\""
    }
    if v.tag == TAG_VOID { return "null" }
    if v.tag == TAG_ARRAY {
        let items = get_array(v)
        let mut parts = []
        for item in items { parts = parts.push(val_to_json(item)) }
        return "[" + parts.join(",") + "]"
    }
    if v.tag == TAG_MAP {
        let ks = get_map_keys(v)
        let vs = get_map_values(v)
        let mut parts = []
        let mut mi = 0
        while mi < len(ks) {
            let key_str = val_to_json(ks[mi])
            // Ensure key is always a JSON string
            if !key_str.starts_with("\"") {
                key_str = "\"" + val_to_string(ks[mi]) + "\""
            }
            parts = parts.push(key_str + ":" + val_to_json(vs[mi]))
            mi = mi + 1
        }
        return "{" + parts.join(",") + "}"
    }
    return "null"
}

fn json_to_val(s) {
    let s = s.trim()
    if s == "null" { return val_void() }
    if s == "true" { return val_bool(true) }
    if s == "false" { return val_bool(false) }
    // String
    if s.starts_with("\"") && s.ends_with("\"") {
        let inner = s.substring(1, len(s) - 1)
        let inner = inner.replace("\\n", "\n")
        let inner = inner.replace("\\t", "\t")
        let inner = inner.replace("\\\"", "\"")
        let inner = inner.replace("\\\\", "\\")
        return val_str(inner)
    }
    // Array
    if s.starts_with("[") && s.ends_with("]") {
        let inner = s.substring(1, len(s) - 1).trim()
        if inner == "" { return val_array([]) }
        let parts = json_split_top(inner)
        let mut items = []
        for p in parts { items = items.push(json_to_val(p)) }
        return val_array(items)
    }
    // Object
    if s.starts_with("{") && s.ends_with("}") {
        let inner = s.substring(1, len(s) - 1).trim()
        if inner == "" { return val_map([], []) }
        let parts = json_split_top(inner)
        let mut keys = []
        let mut values = []
        for p in parts {
            let colon = json_find_colon(p)
            if colon >= 0 {
                let k = p.substring(0, colon).trim()
                let v = p.substring(colon + 1, len(p)).trim()
                keys = keys.push(json_to_val(k))
                values = values.push(json_to_val(v))
            }
        }
        return val_map(keys, values)
    }
    // Number
    if s.contains(".") { return val_float(to_float(s)) }
    return val_int(to_int(s))
}

// Split a JSON string at top-level commas (not inside [] {} or "")
fn json_split_top(s) {
    let chars = s.chars()
    let n = len(chars)
    let mut parts = []
    let mut depth = 0
    let mut in_str = false
    let mut start = 0
    let mut i = 0
    while i < n {
        let ch = to_string(chars[i])
        if in_str {
            if ch == "\\" { i = i + 1 }
            else if ch == "\"" { in_str = false }
        } else {
            if ch == "\"" { in_str = true }
            else if ch == "[" || ch == "{" { depth = depth + 1 }
            else if ch == "]" || ch == "}" { depth = depth - 1 }
            else if ch == "," && depth == 0 {
                parts = parts.push(s.substring(start, i).trim())
                start = i + 1
            }
        }
        i = i + 1
    }
    if start < n { parts = parts.push(s.substring(start, n).trim()) }
    return parts
}

// Find the first top-level colon in a JSON key:value pair
fn json_find_colon(s) {
    let chars = s.chars()
    let n = len(chars)
    let mut in_str = false
    let mut i = 0
    while i < n {
        let ch = to_string(chars[i])
        if in_str {
            if ch == "\\" { i = i + 1 }
            else if ch == "\"" { in_str = false }
        } else {
            if ch == "\"" { in_str = true }
            else if ch == ":" { return i }
        }
        i = i + 1
    }
    return -1
}

fn to_float(v) {
    if v.tag == TAG_FLOAT { return v.float_val }
    if v.tag == TAG_INT { return v.int_val * 1.0 }
    return 0.0
}

fn to_float_val(v) {
    if v.tag == TAG_FLOAT { return v.float_val }
    if v.tag == TAG_INT { return v.int_val * 1.0 }
    return 0.0
}

// ── Array storage (using host arrays) ────────────────────
// We store arrays as actual hexa arrays wrapped in Val
// Perf #10: reference counting for in-place push.
// array_refcounts tracks how many Val handles point to each array_store slot.
// When refcount==1 (sole owner), push can mutate array_store[idx] directly
// instead of allocating a new slot — turning O(n) copy into O(1) amortized.

pub let mut array_store = []
pub let mut array_refcounts = []   // parallel to array_store; each entry is an int >= 1

fn val_array(items) {
    // rt 32: reuse a freed slot if available — bounds array_store growth.
    let fl_n = len(array_free_list)
    if fl_n > 0 {
        let idx = array_free_list[fl_n - 1]
        array_free_list = array_free_list.truncate(fl_n - 1)
        array_store[idx] = items
        array_refcounts[idx] = 1
        return Val { tag: TAG_ARRAY, int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
    }
    let idx = len(array_store)
    array_store = array_store.push(items)
    array_refcounts = array_refcounts.push(1)
    return Val { tag: TAG_ARRAY, int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

// val_array_reuse: create a Val pointing to an existing array_store slot.
// Increments refcount. Used when a variable is copied (assignment, param passing)
// without mutation — the two Vals share the same backing store until one writes.
fn val_array_reuse(idx) {
    if idx >= 0 && idx < len(array_refcounts) {
        array_refcounts[idx] = array_refcounts[idx] + 1
    }
    return Val { tag: TAG_ARRAY, int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn array_incref(idx) {
    if idx >= 0 && idx < len(array_refcounts) {
        array_refcounts[idx] = array_refcounts[idx] + 1
    }
}

fn array_decref(idx) {
    if idx >= 0 && idx < len(array_refcounts) {
        if array_refcounts[idx] > 0 {
            array_refcounts[idx] = array_refcounts[idx] - 1
            // rt 32: reclaim slot when refcount hits 0. Drop the items array
            // (host array becomes garbage at C runtime — buffer freed) and
            // record the slot in the freelist for val_array() reuse.
            if array_refcounts[idx] == 0 {
                array_store[idx] = []
                array_free_list = array_free_list.push(idx)
            }
        }
    }
}

fn array_is_sole_owner(idx) {
    if idx >= 0 && idx < len(array_refcounts) {
        return array_refcounts[idx] <= 1
    }
    return true
}

// array_push_inplace: O(1) amortized push when sole owner, else COW.
// Returns a Val pointing to the (possibly new) array slot.
fn array_push_inplace(arr_val, item) {
    let idx = arr_val.int_val
    if array_is_sole_owner(idx) {
        // Sole owner: mutate the backing store directly (host .push is O(1) amortized)
        let items = array_store[idx]
        array_store[idx] = items.push(item)
        return arr_val
    }
    // Shared: COW — allocate new slot with old items + new item
    let items = array_store[idx]
    let new_items = items.push(item)
    array_decref(idx)
    return val_array(new_items)
}

fn get_array(v) {
    return array_store[v.int_val]
}

// ── sort helper (insertion sort) ────────────────────────
fn sort_val_compare(a, b) {
    // Returns negative if a < b, 0 if equal, positive if a > b
    if a.tag == TAG_INT && b.tag == TAG_INT {
        return a.int_val - b.int_val
    }
    if a.tag == TAG_FLOAT || b.tag == TAG_FLOAT {
        let fa = to_float_val(a)
        let fb = to_float_val(b)
        if fa < fb { return -1 }
        if fa > fb { return 1 }
        return 0
    }
    // Default: compare as strings
    let sa = val_to_string(a)
    let sb = val_to_string(b)
    if sa < sb { return -1 }
    if sa > sb { return 1 }
    return 0
}

fn sort_array(items) {
    // Insertion sort — simple, correct, good enough for interpreted use
    let mut arr = []
    let mut i = 0
    while i < len(items) {
        arr = arr.push(items[i])
        i = i + 1
    }
    let mut i = 1
    while i < len(arr) {
        let key = arr[i]
        let mut j = i - 1
        while j >= 0 && sort_val_compare(arr[j], key) > 0 {
            arr[j + 1] = arr[j]
            j = j - 1
        }
        arr[j + 1] = key
        i = i + 1
    }
    return arr
}

fn val_fn(name, params, body) {
    return Val { tag: TAG_FN, int_val: 0, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: name, fn_params: params, fn_body: body, struct_name: "", struct_fields: "" }
}

fn val_closure(name, params, body, captured_env) {
    // Store [captured_env_tuples, cache_snap] in closure_store.
    // rt 32-E: cache_snap left empty — call_fn_val always env_rebuild_cache()s
    // because the old tuple-bucket snap is incompatible with the split
    // (names, idxs) parallel buckets. captured_env is still a list of
    // [name, value] tuples (legacy). The per-closure cache rebuild cost
    // is amortised by not allocating/scanning the 64-bucket snapshot on
    // every lambda creation (hot in matvec/gelu which create no closures,
    // but still avoids the tuple-bucket double-filter pass).
    let idx = len(closure_store)
    closure_store = closure_store.push([captured_env, []])
    return Val { tag: TAG_FN, int_val: idx, float_val: 0.0, bool_val: false, str_val: "closure", char_val: "", array_val: "", fn_name: name, fn_params: params, fn_body: body, struct_name: "", struct_fields: "" }
}

// ── Map storage ─────────────────────────────────────────
// Maps stored as pairs of [keys_array, values_array]
pub let mut map_store = []

fn val_map(keys, values) {
    let idx = len(map_store)
    map_store = map_store.push([keys, values])
    return Val { tag: TAG_MAP, int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn get_map_keys(v) {
    return map_store[v.int_val][0]
}

fn get_map_values(v) {
    return map_store[v.int_val][1]
}

fn map_get(v, key) {
    let keys = get_map_keys(v)
    let values = get_map_values(v)
    let mut i = 0
    while i < len(keys) {
        if val_eq(keys[i], key) { return values[i] }
        i = i + 1
    }
    return val_void()
}

fn map_set(v, key, value) {
    let keys = get_map_keys(v)
    let values = get_map_values(v)
    let mut new_keys = []
    let mut new_values = []
    let mut found = false
    let mut i = 0
    while i < len(keys) {
        if val_eq(keys[i], key) {
            new_keys = new_keys.push(keys[i])
            new_values = new_values.push(value)
            found = true
        } else {
            new_keys = new_keys.push(keys[i])
            new_values = new_values.push(values[i])
        }
        i = i + 1
    }
    if !found {
        new_keys = new_keys.push(key)
        new_values = new_values.push(value)
    }
    return val_map(new_keys, new_values)
}

fn map_contains_key(v, key) {
    let keys = get_map_keys(v)
    let mut i = 0
    while i < len(keys) {
        if val_eq(keys[i], key) { return true }
        i = i + 1
    }
    return false
}

fn map_remove(v, key) {
    let keys = get_map_keys(v)
    let values = get_map_values(v)
    let mut new_keys = []
    let mut new_values = []
    let mut i = 0
    while i < len(keys) {
        if !val_eq(keys[i], key) {
            new_keys = new_keys.push(keys[i])
            new_values = new_values.push(values[i])
        }
        i = i + 1
    }
    return val_map(new_keys, new_values)
}

fn val_eq(a, b) {
    if a.tag != b.tag { return false }
    if a.tag == TAG_INT { return a.int_val == b.int_val }
    if a.tag == TAG_FLOAT { return a.float_val == b.float_val }
    if a.tag == TAG_BOOL { return a.bool_val == b.bool_val }
    if a.tag == TAG_STR { return a.str_val == b.str_val }
    if a.tag == TAG_ENUM { return a.struct_name == b.struct_name }
    return false
}

// ── Struct storage ───────────────────────────────────────
// Perf #11: COW (copy-on-write) for structs.
// struct_refcounts tracks how many Val handles share each struct_store slot.
// On assignment/param-pass, we share the slot (incref) instead of deep-copying.
// On mutation (field write), if refcount > 1 we COW: copy fields to a new slot,
// decref the old, and return the fresh sole-owner Val.
pub let mut struct_store = []
pub let mut struct_refcounts = []   // parallel to struct_store

fn val_struct(name, fields) {
    let idx = len(struct_store)
    struct_store = struct_store.push(fields)
    struct_refcounts = struct_refcounts.push(1)
    return Val { tag: TAG_STRUCT, int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: name, struct_fields: "" }
}

// val_struct_reuse: share an existing struct_store slot (bump refcount).
// Used when a struct Val is copied without mutation (assignment, param pass, return).
fn val_struct_reuse(v) {
    let idx = v.int_val
    if idx >= 0 && idx < len(struct_refcounts) {
        struct_refcounts[idx] = struct_refcounts[idx] + 1
    }
    return v
}

fn struct_incref(idx) {
    if idx >= 0 && idx < len(struct_refcounts) {
        struct_refcounts[idx] = struct_refcounts[idx] + 1
    }
}

fn struct_decref(idx) {
    if idx >= 0 && idx < len(struct_refcounts) {
        if struct_refcounts[idx] > 0 {
            struct_refcounts[idx] = struct_refcounts[idx] - 1
        }
    }
}

fn struct_is_sole_owner(idx) {
    if idx >= 0 && idx < len(struct_refcounts) {
        return struct_refcounts[idx] <= 1
    }
    return true
}

// struct_cow_if_shared: if the struct is shared (refcount > 1), copy fields
// to a new slot and return a fresh sole-owner Val. Otherwise return as-is.
// Call this before any field mutation.
fn struct_cow_if_shared(v) {
    let idx = v.int_val
    if !struct_is_sole_owner(idx) {
        // COW: deep-copy fields to new slot
        let old_fields = struct_store[idx]
        struct_decref(idx)
        return val_struct(v.struct_name, old_fields)
    }
    return v
}

fn get_struct_fields(v) {
    return struct_store[v.int_val]
}

// set_struct_field: COW-aware field mutation.
// Returns the (possibly new) Val with the field updated.
fn set_struct_field(v, field_name, new_val) {
    let sv = struct_cow_if_shared(v)
    let fields = struct_store[sv.int_val]
    fields[field_name] = new_val
    struct_store[sv.int_val] = fields
    return sv
}

// ── Enum value storage ──────────────────────────────────
// Enum values: tag="enum", struct_name="EnumName::Variant", str_val stores variant name
// If the variant carries data, it's stored in enum_data_store[int_val]
pub let mut enum_data_store = []

fn val_enum(enum_name, variant, data) {
    let full_name = enum_name + "::" + variant
    let mut data_idx = -1
    if type_of(data) != "string" || data != "" {
        data_idx = len(enum_data_store)
        enum_data_store = enum_data_store.push(data)
    }
    return Val { tag: TAG_ENUM, int_val: data_idx, float_val: 0.0, bool_val: false, str_val: variant, char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: full_name, struct_fields: "" }
}

fn get_enum_data(v) {
    if v.int_val < 0 { return val_void() }
    return enum_data_store[v.int_val]
}

// ═══════════════════════════════════════════════════════════
//  Phase 1 골화 — 확장 Value 타입 (7종)
// ═══════════════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════
//  @cow runtime support — copy-on-write for shared data
// ═══════════════════════════════════════════════════════════
// cow_ref_counts tracks reference counts for array/struct indices.
// When ref_count > 1 and a mutation is attempted, the data is
// deep-copied first (COW semantics: defer copy until write).
pub let mut cow_ref_counts = []

fn cow_ensure_capacity(idx) {
    while len(cow_ref_counts) <= idx {
        cow_ref_counts = cow_ref_counts.push(1)
    }
}

fn cow_incref(idx) {
    cow_ensure_capacity(idx)
    cow_ref_counts[idx] = cow_ref_counts[idx] + 1
}

fn cow_decref(idx) {
    cow_ensure_capacity(idx)
    if cow_ref_counts[idx] > 0 {
        cow_ref_counts[idx] = cow_ref_counts[idx] - 1
    }
}

fn cow_is_shared(idx) {
    cow_ensure_capacity(idx)
    return cow_ref_counts[idx] > 1
}

fn cow_copy_on_write(v) {
    // Perf #10/#11: delegate to per-type refcount-based COW.
    // Fixes original bug: used string tags "array"/"struct" instead of numeric TAG_*.
    if v.tag == TAG_ARRAY {
        if !array_is_sole_owner(v.int_val) {
            let old_data = array_store[v.int_val]
            array_decref(v.int_val)
            return val_array(old_data)
        }
    }
    if v.tag == TAG_STRUCT {
        return struct_cow_if_shared(v)
    }
    return v
}

//  Val struct 자체는 변경 없음. int_val을 ref index로 쓰는
//  기존 array/map/struct/enum/closure 패턴을 그대로 적용.
//  각 신규 타입은 별도 storage + 생성자/접근자 함수 한 쌍.
//  src/interpreter.rs의 Value::{Tensor,Sender,Receiver,EffectRequest,
//  Atomic,Pointer,BigInt} variant들에 대응.

// ── Tensor: shape + flat data (f64) ──────────────────────
pub let mut tensor_shape_store = []   // [[d0,d1,...], ...]
pub let mut tensor_data_store = []    // [[f0,f1,...], ...]

fn val_tensor(shape, data) {
    let idx = len(tensor_shape_store)
    tensor_shape_store = tensor_shape_store.push(shape)
    tensor_data_store = tensor_data_store.push(data)
    return Val { tag: TAG_TENSOR, int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn tensor_shape(v) {
    if v.tag != TAG_TENSOR { return [] }
    return tensor_shape_store[v.int_val]
}

fn tensor_data(v) {
    if v.tag != TAG_TENSOR { return [] }
    return tensor_data_store[v.int_val]
}

fn tensor_set_data(v, new_data) {
    // in-place update via slot replacement (immutable wrapper, mutable storage)
    if v.tag != TAG_TENSOR { return }
    tensor_data_store[v.int_val] = new_data
}

fn tensor_numel(v) {
    let shape = tensor_shape(v)
    let mut n = 1
    for d in shape { n = n * d }
    return n
}

// ── Channel: bounded queue (Sender + Receiver share id) ──
//  src의 Value::Sender/Value::Receiver는 같은 채널을 가리키는
//  두 view. .hexa에선 단일 tag="channel" + 방향 플래그(int_val 부호로 인코딩).
//    int_val ≥ 0: sender (idx)
//    int_val <  0: receiver, idx = -int_val - 1
pub let mut channel_buffer_store = []  // [[items], ...]
pub let mut channel_closed_store = []  // [bool, ...]
pub let mut channel_capacity_store = []

fn val_channel_make(cap) {
    let idx = len(channel_buffer_store)
    channel_buffer_store = channel_buffer_store.push([])
    channel_closed_store = channel_closed_store.push(false)
    channel_capacity_store = channel_capacity_store.push(cap)
    return Val { tag: TAG_CHANNEL, int_val: idx, float_val: 0.0, bool_val: false, str_val: "sender", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn val_channel_recv_view(sender) {
    // sender→receiver view: same id, str_val flag
    return Val { tag: TAG_CHANNEL, int_val: sender.int_val, float_val: 0.0, bool_val: false, str_val: "receiver", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn channel_send(ch, item) {
    if ch.tag != TAG_CHANNEL { return false }
    let id = ch.int_val
    if channel_closed_store[id] { return false }
    let cap = channel_capacity_store[id]
    let buf = channel_buffer_store[id]
    if cap > 0 && len(buf) >= cap { return false }
    channel_buffer_store[id] = buf.push(item)
    return true
}

fn channel_recv(ch) {
    if ch.tag != TAG_CHANNEL { return val_void() }
    let id = ch.int_val
    let buf = channel_buffer_store[id]
    if len(buf) == 0 { return val_void() }
    let head = buf[0]
    let mut rest = []
    let mut ri = 1
    while ri < len(buf) { rest = rest.push(buf[ri]); ri = ri + 1 }
    channel_buffer_store[id] = rest
    return head
}

fn channel_close(ch) {
    if ch.tag != TAG_CHANNEL { return }
    channel_closed_store[ch.int_val] = true
}

// ── EffectRequest: algebraic effect propagation ──────────
//  Each request: {effect: name, op: name, args: [Val], k: continuation}
pub let mut effect_effect_store = []
pub let mut effect_op_store = []
pub let mut effect_args_store = []
pub let mut effect_k_store = []         // resumption (Val of tag="fn") or void

fn val_effect_request(effect_name, op, args) {
    let idx = len(effect_effect_store)
    effect_effect_store = effect_effect_store.push(effect_name)
    effect_op_store = effect_op_store.push(op)
    effect_args_store = effect_args_store.push(args)
    effect_k_store = effect_k_store.push(val_void())
    return Val { tag: TAG_EFFECT_REQUEST, int_val: idx, float_val: 0.0, bool_val: false, str_val: effect_name, char_val: op, array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn effect_args(v) {
    if v.tag != TAG_EFFECT_REQUEST { return [] }
    return effect_args_store[v.int_val]
}

fn effect_set_continuation(v, k) {
    if v.tag != TAG_EFFECT_REQUEST { return }
    effect_k_store[v.int_val] = k
}

fn effect_continuation(v) {
    if v.tag != TAG_EFFECT_REQUEST { return val_void() }
    return effect_k_store[v.int_val]
}

// ── Atomic: single-cell with lock-free ops ───────────────
//  HEXA interpreter is single-threaded so atomic == regular cell.
//  But the API needs to exist for self-host parity.
pub let mut atomic_store = []   // [Val, ...]

fn val_atomic(initial) {
    let idx = len(atomic_store)
    atomic_store = atomic_store.push(initial)
    return Val { tag: TAG_ATOMIC, int_val: idx, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn atomic_load(v) {
    if v.tag != TAG_ATOMIC { return val_void() }
    return atomic_store[v.int_val]
}

fn atomic_store_op(v, new_val) {
    if v.tag != TAG_ATOMIC { return }
    atomic_store[v.int_val] = new_val
}

fn atomic_compare_swap(v, expected, new_val) {
    if v.tag != TAG_ATOMIC { return val_bool(false) }
    let cur = atomic_store[v.int_val]
    if val_eq(cur, expected) {
        atomic_store[v.int_val] = new_val
        return val_bool(true)
    }
    return val_bool(false)
}

fn atomic_fetch_add(v, delta) {
    if v.tag != TAG_ATOMIC { return val_int(0) }
    let cur = atomic_store[v.int_val]
    let next = val_int(cur.int_val + delta.int_val)
    atomic_store[v.int_val] = next
    return cur
}

// ── BigInt: arbitrary precision integer (string-encoded) ──
//  Stored as decimal string for simplicity. Large arithmetic ops
//  are routed through string-based long arithmetic helpers.
pub let mut bigint_store = []   // [string, ...]

fn val_bigint(decimal_str) {
    let idx = len(bigint_store)
    bigint_store = bigint_store.push(decimal_str)
    return Val { tag: TAG_BIGINT, int_val: idx, float_val: 0.0, bool_val: false, str_val: decimal_str, char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn val_bigint_from_int(n) {
    return val_bigint(to_string(n))
}

fn bigint_str(v) {
    if v.tag != TAG_BIGINT { return "0" }
    return bigint_store[v.int_val]
}

// ── Pointer: opaque address (FFI) ────────────────────────
//  Stored as raw int64. Used for C extern fn calls.
fn val_pointer(addr) {
    return Val { tag: TAG_POINTER, int_val: addr, float_val: 0.0, bool_val: false, str_val: "", char_val: "", array_val: "", fn_name: "", fn_params: "", fn_body: "", struct_name: "", struct_fields: "" }
}

fn pointer_addr(v) {
    if v.tag != TAG_POINTER { return 0 }
    return v.int_val
}

fn pointer_is_null(v) {
    if v.tag != TAG_POINTER { return true }
    return v.int_val == 0
}

// ═══════════════════════════════════════════════════════════
//  Phase 6 골화 — Algebraic Effects (handle/with + resume)
//  src/interpreter.rs:11872-11933 대응
// ═══════════════════════════════════════════════════════════
//  Effect 등록부: effect 이름 → 허용된 op 이름 배열
//  Handler stack: 각 프레임은 [[key, params, body], ...]
//  Resume value: handler 안에서 resume(v) 호출 시 저장
//  Pure flag: 순수 함수 안에서 effect 호출 차단

pub let mut effect_defs_keys = []      // [effect_name, ...]
pub let mut effect_defs_ops = []       // [[op1, op2, ...], ...]
pub let mut effect_handler_stack = []  // [[entry, ...], ...] — 각 entry: [key, params, body]
pub let mut resume_value = val_void()
pub let mut resume_set = false
pub let mut in_pure_fn = false

fn effect_def_add(effect_name, ops) {
    effect_defs_keys = effect_defs_keys.push(effect_name)
    effect_defs_ops = effect_defs_ops.push(ops)
}

fn effect_def_lookup(effect_name) {
    let mut i = 0
    while i < len(effect_defs_keys) {
        if effect_defs_keys[i] == effect_name { return effect_defs_ops[i] }
        i = i + 1
    }
    return val_void()
}

fn effect_def_has_op(effect_name, op) {
    let ops = effect_def_lookup(effect_name)
    if type_of(ops) != "array" { return false }
    let mut i = 0
    while i < len(ops) {
        if ops[i] == op { return true }
        i = i + 1
    }
    return false
}

fn effect_handler_push(handlers) {
    // handlers: array of [key, params, body] entries
    effect_handler_stack = effect_handler_stack.push(handlers)
}

fn effect_handler_pop() {
    let n = len(effect_handler_stack)
    if n == 0 { return }
    let mut new_stack = []
    let mut i = 0
    while i < n - 1 { new_stack = new_stack.push(effect_handler_stack[i]); i = i + 1 }
    effect_handler_stack = new_stack
}

fn effect_handler_find(key) {
    // Search from top of stack down (most recent first)
    let mut i = len(effect_handler_stack) - 1
    while i >= 0 {
        let frame = effect_handler_stack[i]
        let mut j = 0
        while j < len(frame) {
            let entry = frame[j]
            if entry[0] == key { return entry }
            j = j + 1
        }
        i = i - 1
    }
    return val_void()
}

// eval_effect_call(effect, op, args) — dispatch effect operation
//   1. pure-fn 차단
//   2. effect 정의 검증
//   3. handler stack 검색
//   4. 발견 시 handler body 실행 (resume_value 반영)
//   5. 미발견 시 EffectRequest 전파 (caller가 handle해야 함)
fn eval_effect_call(effect_name, op, args) {
    if in_pure_fn {
        throw_flag = true
        throw_val = val_str("effect " + effect_name + "." + op + " not allowed in pure function")
        return val_void()
    }
    if !effect_def_has_op(effect_name, op) {
        throw_flag = true
        throw_val = val_str("undefined effect or operation: " + effect_name + "." + op)
        return val_void()
    }
    let key = effect_name + "." + op
    let entry = effect_handler_find(key)
    // entry is a host array on hit, val_void() on miss
    if type_of(entry) != "array" {
        // No handler — propagate as EffectRequest
        return val_effect_request(effect_name, op, args)
    }
    // entry: [key, params, body]
    let params = entry[1]
    let body = entry[2]
    env_push_scope()
    let mut pi = 0
    while pi < len(params) && pi < len(args) {
        env_define(params[pi], args[pi])
        pi = pi + 1
    }
    resume_set = false
    resume_value = val_void()
    let mut result = val_void()
    let mut bi = 0
    while bi < len(body) && !return_flag && !throw_flag && !panic_flag {
        result = exec_stmt_at(body, bi)
        bi = bi + 1
    }
    if return_flag {
        result = return_val
        return_flag = false
    }
    env_pop_scope()
    if resume_set {
        let r = resume_value
        resume_set = false
        return r
    }
    return result
}

// eval_handle_with(body_fn, handler_entries) — push frame, eval body, pop
//   handler_entries: [[key, params, body_stmts], ...]
fn eval_handle_with(body_fn, handler_entries) {
    effect_handler_push(handler_entries)
    let result = call_fn_val(body_fn, [])
    effect_handler_pop()
    return result
}

// ── Stack trace helper ──────────────────────────────────
fn format_stack_trace() {
    let mut trace = "Stack trace:"
    let mut i = len(call_stack) - 1
    while i >= 0 {
        trace = trace + "\n  at " + call_stack[i]
        i = i - 1
    }
    return trace
}

// ── Main entry: run AST ──────────────────────────────────

pub let mut array_free_list = []
fn interpret(ast) {
    // Reset state
    // rt 32-E: reset parallel env arrays (names + vals).
    env_var_names = []
    env_var_vals = []
    env_vars = []
    env_scopes = [0]
    env_cache_init()
    env_scope_dirty = []
    env_fns = []
    fn_cache_init()
    return_flag = false
    return_val = val_void()
    break_flag = false
    break_label = ""
    continue_flag = false
    continue_label = ""
    defer_stack = []
    throw_flag = false
    throw_val = val_void()
    panic_flag = false
    panic_msg = ""
    gen_buffer = []
    gen_active = false
    array_store = []
    array_refcounts = []
    array_free_list = []
    map_store = []
    struct_store = []
    struct_refcounts = []
    impl_store = []
    closure_store = []
    extern_fns = []
    enum_data_store = []
    enum_decls = []
    call_stack = []
    fn_attrs = []
    fn_attr_flags = []
    memo_cache_init()

    // ─── FIX-9-1: Top-level FnDecl pre-registration pass ───
    // Rust interpreter.rs:run() 와 동일 패턴. 본 실행 루프 전에 모든 FnDecl 을
    // env_define 하여 forward reference 및 상호 재귀 지원. 단일 pass 가 아니므로
    // fn 정의 순서 무관하게 호출 가능. blowup.hexa 류 대형 파일의 O(N²) 누적
    // env_lookup 문제도 완화 (fn 이름은 pre-reg 시점 고정 위치로 영속).
    // 참고: shared/hexa/interpreter_fixes_20260411.json FIX-9-1
    let mut _pr = 0
    while _pr < len(ast) {
        let _pn = ast[_pr]
        if type_of(_pn) == "struct" || type_of(_pn) == "map" {
            let _pk = _pn.kind
            if type_of(_pk) == "string" {
                // FnDecl / AsyncFnDecl / PureFnDecl / ComptimeFnDecl 전부 포함
                if _pk == "FnDecl" || _pk == "AsyncFnDecl" || _pk == "PureFnDecl" {
                    env_fns = env_fns.push([_pn.name, _pn.params, _pn.body])
                    fn_cache_add(_pn.name, len(env_fns) - 1)
                    let _pfv = val_fn(_pn.name, _pn.params, _pn.body)
                    env_define(_pn.name, _pfv)
                    // @attrs 도 pre-reg 단계에서 등록 (@memo/@memoize/@cache)
                    if _pn.value != "" {
                        fn_attrs_set(_pn.name, _pn.value)
                    }
                }
            }
        }
        _pr = _pr + 1
    }

    let mut result = val_void()
    let mut _si = 0
    while _si < len(ast) {
        if panic_flag || throw_flag || return_flag { _si = len(ast) } else {
            // FnDecl pre-reg 됐으므로 exec_stmt_at 재호출 시 중복 define 발생.
            // 중복 define 은 env_vars 에 [name,value] 를 push 만 하므로 env_lookup
            // 이 최신(뒤쪽) 엔트리를 먼저 찾음 → 동작 동일, 약간의 메모리 오버헤드.
            // 안전 우선으로 재실행 허용 (exec_stmt_at 의 FnDecl 분기가 idempotent 확인).
            result = exec_stmt_at(ast, _si)
            _si = _si + 1
            // Top-level return: capture value and stop iteration.
            if return_flag {
                result = return_val
                _si = len(ast)
            }
        }
    }
    return_flag = false
    // Uncaught panic — print diagnostic. Uses println (no stderr binding in
    // self interp), prefixed with "panic: " so callers can detect the abort.
    if panic_flag {
        println("panic: " + panic_msg)
    }
    return result
}

