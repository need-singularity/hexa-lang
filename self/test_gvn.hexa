// =====================================================================
//  test_gvn.hexa -- GVN (Global Value Numbering) tests
//
//  GVN identifies equivalent expressions across the entire function
//  (beyond basic blocks), eliminating redundant computations globally.
//  The pass detects repeated sub-expressions and marks them for reuse.
//
//  Run: ./hexa test self/test_gvn.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_bool(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  HEXA GVN (Global Value Numbering) Test Suite")
println("=====================================================")
println("")

// -- 1. Redundant function call detection --
println("--- 1. Redundant call elimination ---")

fn expensive_compute(x) {
    let mut sum = 0
    let mut i = 0
    while i < x {
        sum = sum + i * i
        i = i + 1
    }
    return sum
}

// GVN should detect that a and b are identical expressions
let gvn_a = expensive_compute(10)
let gvn_b = expensive_compute(10)
check("gvn redundant call same result", gvn_a == gvn_b, true)
check("gvn call value correct", gvn_a, 285)

// -- 2. Redundant arithmetic expressions --
println("")
println("--- 2. Redundant arithmetic ---")

fn redundant_arith(x, y) {
    let a = x * y + 1
    let b = x * y + 1
    return a + b
}

check("gvn redundant arith", redundant_arith(5, 3), 32)

// -- 3. GVN across different code paths --
println("")
println("--- 3. Cross-path GVN ---")

fn cross_path_gvn(x) {
    let a = x * x
    let mut result = 0
    if x > 0 {
        result = a + 1
    } else {
        result = a - 1
    }
    let b = x * x
    return result + b
}

check("gvn cross path positive", cross_path_gvn(3), 19)
check("gvn cross path negative", cross_path_gvn(-2), 7)

// -- 4. GVN with nested expressions --
println("")
println("--- 4. Nested expression GVN ---")

fn nested_gvn(a, b) {
    let x = (a + b) * (a + b)
    let y = (a + b) * (a + b)
    return x + y
}

check("gvn nested expr", nested_gvn(3, 4), 98)

// -- 5. No false positive: different args --
println("")
println("--- 5. Different args (no false positive) ---")

fn different_args(x, y) {
    let a = x * x
    let b = y * y
    return a + b
}

check("gvn different args", different_args(3, 4), 25)

// -- 6. GVN with array operations --
println("")
println("--- 6. Array operation GVN ---")

fn array_gvn(arr) {
    let n = len(arr)
    let m = len(arr)
    return n + m
}

check("gvn array len", array_gvn([1, 2, 3]), 6)

// -- 7. GVN preserves semantics --
println("")
println("--- 7. Semantics preservation ---")

fn gvn_semantics(x) {
    let a = x + x
    let b = x * 2
    let c = x + x
    return a + b + c
}

check("gvn semantics", gvn_semantics(5), 30)

// -- 8. GVN with string ops --
println("")
println("--- 8. String GVN ---")

fn string_gvn(s) {
    let a = len(s)
    let b = len(s)
    return a + b
}

check("gvn string len", string_gvn("hello"), 10)

// -- 9. Multiple redundancy sites --
println("")
println("--- 9. Multiple redundancy sites ---")

fn multi_redundant(x) {
    let a = x * x
    let b = x * x
    let c = x * x
    return a + b + c
}

check("gvn triple redundant", multi_redundant(4), 48)

// -- 10. GVN with loop invariant --
println("")
println("--- 10. Loop-invariant code motion candidate ---")

fn loop_invariant(arr, factor) {
    let n = len(arr)
    let mut result = []
    let mut i = 0
    while i < n {
        result.push(arr[i] * factor)
        i = i + 1
    }
    return result
}

let r10 = loop_invariant([1, 2, 3], 10)
check("gvn loop invariant [0]", r10[0], 10)
check("gvn loop invariant [1]", r10[1], 20)
check("gvn loop invariant [2]", r10[2], 30)

// -- 11. GVN correct with mutation (no false elimination) --
println("")
println("--- 11. Mutation safety ---")

fn mutation_safe(x) {
    let mut v = x
    let a = v * v
    v = v + 1
    let b = v * v
    return a + b
}

check("gvn mutation safe", mutation_safe(3), 25)

// -- 12. Deeply nested expression GVN --
println("")
println("--- 12. Deep nested GVN ---")

fn deep_gvn(a, b, c) {
    let x = a + b + c
    let y = a + b + c
    let z = x * y
    return z
}

check("gvn deep nested", deep_gvn(1, 2, 3), 36)

// -- Summary --
println("")
println("=====================================================")
println("  GVN tests: " + to_string(pass_count) + " PASS, " + to_string(fail_count) + " FAIL")
println("=====================================================")
if fail_count > 0 {
    println("SOME TESTS FAILED")
}
