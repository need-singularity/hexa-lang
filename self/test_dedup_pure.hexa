// self/test_dedup_pure.hexa -- Tests for self/runtime/dedup_pure.hexa

// ── inlined from self/runtime/dedup_pure.hexa ──────────────────
// codegen_c2 import/use resolution for runtime/*_pure.hexa is not wired
// for test files; inline the module contents (same pattern as test_rle_pure).

fn dedup(arr) {
    let n = len(arr)
    if n == 0 { return [] }
    let mut out = []
    out.push(arr[0])
    let mut i = 1
    while i < n {
        if to_string(arr[i]) != to_string(arr[i - 1]) {
            out.push(arr[i])
        }
        i = i + 1
    }
    out
}

fn dedup_all(arr) {
    let n = len(arr)
    if n == 0 { return [] }
    let mut out = []
    let mut seen = []
    let mut i = 0
    while i < n {
        let key = to_string(arr[i])
        let mut found = false
        let mut j = 0
        while j < len(seen) {
            if seen[j] == key {
                found = true
            }
            j = j + 1
        }
        if found == false {
            out.push(arr[i])
            seen.push(key)
        }
        i = i + 1
    }
    out
}

fn is_unique(arr) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            if to_string(arr[i]) == to_string(arr[j]) { return false }
            j = j + 1
        }
        i = i + 1
    }
    true
}

fn count_unique(arr) {
    len(dedup_all(arr))
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn arrays_equal(a, b) {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if to_string(a[i]) != to_string(b[i]) { return false }
        i = i + 1
    }
    true
}

println("═══════════════════════════════════════════════════════")
println("  dedup_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── dedup: empty input ─────────────────────────────────────────
println("")
println("--- dedup: empty input ---")
check("dedup empty", len(dedup([])), 0)

// ── dedup: no consecutive dups ─────────────────────────────────
println("")
println("--- dedup: no consecutive dups ---")
check("dedup no dups", arrays_equal(dedup([1, 2, 3, 4]), [1, 2, 3, 4]), true)

// ── dedup: consecutive dups ────────────────────────────────────
println("")
println("--- dedup: consecutive dups ---")
check("dedup consec", arrays_equal(dedup([1, 1, 2, 2, 3]), [1, 2, 3]), true)
check("dedup all same", arrays_equal(dedup([5, 5, 5, 5]), [5]), true)

// ── dedup: non-consecutive dups preserved ──────────────────────
println("")
println("--- dedup: non-consecutive dups preserved ---")
check("dedup non-consec", arrays_equal(dedup([1, 2, 1, 2]), [1, 2, 1, 2]), true)

// ── dedup: single element ──────────────────────────────────────
println("")
println("--- dedup: single element ---")
check("dedup single", arrays_equal(dedup([42]), [42]), true)

// ── dedup_all: empty ───────────────────────────────────────────
println("")
println("--- dedup_all: empty ---")
check("dedup_all empty", len(dedup_all([])), 0)

// ── dedup_all: removes all dups ────────────────────────────────
println("")
println("--- dedup_all: removes all dups ---")
check("dedup_all basic", arrays_equal(dedup_all([1, 2, 1, 3, 2]), [1, 2, 3]), true)
check("dedup_all all same", arrays_equal(dedup_all([7, 7, 7]), [7]), true)
check("dedup_all no dups", arrays_equal(dedup_all([4, 5, 6]), [4, 5, 6]), true)

// ── dedup_all: strings ─────────────────────────────────────────
println("")
println("--- dedup_all: strings ---")
check("dedup_all str", arrays_equal(dedup_all(["a", "b", "a", "c"]), ["a", "b", "c"]), true)

// ── is_unique ──────────────────────────────────────────────────
println("")
println("--- is_unique ---")
check("is_unique empty", is_unique([]), true)
check("is_unique true", is_unique([1, 2, 3]), true)
check("is_unique false", is_unique([1, 2, 1]), false)
check("is_unique single", is_unique([42]), true)

// ── count_unique ───────────────────────────────────────────────
println("")
println("--- count_unique ---")
check("count_unique empty", count_unique([]), 0)
check("count_unique all diff", count_unique([1, 2, 3, 4]), 4)
check("count_unique with dups", count_unique([1, 2, 1, 3, 2]), 3)
check("count_unique all same", count_unique([5, 5, 5]), 1)

// ── Summary ────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
