// self/memory.hexa — HEXA MEMORY ported from src/memory.rs
//
// Egyptian Fraction Memory Allocator for Hexa.
// Memory is split into 3 regions using Egyptian fractions of n=6:
//   Stack: 1/2 = 50%  -- local variables, function frames, value types
//   Heap:  1/3 = 33%  -- dynamically allocated objects (structs, arrays, closures)
//   Arena: 1/6 = 17%  -- temporaries, string interning, compile-time data
//
// 1/2 + 1/3 + 1/6 = 1  (the only 3-way unit fraction decomposition from 6)

// ── Constants ──────────────────────────────────────────────

let EGYPTIAN_STACK = 2   // 1/2
let EGYPTIAN_HEAP  = 3   // 1/3
let EGYPTIAN_ARENA = 6   // 1/6

let DEFAULT_BUDGET = 67108864   // 64 * 1024 * 1024 = 64 MB
let MAX_FRAMES     = 64         // tau * sigma pattern: 4 * 16
let N_SIZE_CLASSES = 6
let HEADER_SIZE    = 8

let SIZE_CLASSES = [16, 32, 64, 128, 256, 512]

// ── MemRegion ──────────────────────────────────────────────

fn mem_region_name(region: string) -> string {
    match region {
        "stack" => return "stack",
        "heap"  => return "heap",
        "arena" => return "arena",
        _       => return "unknown"
    }
}

// ── StackFrame ─────────────────────────────────────────────

struct StackFrame {
    name_id: int,
    base: int
}

fn stack_frame_anon() -> int {
    return -1
}

// ── StackRegion ────────────────────────────────────────────

struct StackRegion {
    capacity: int,
    sp: int,
    generation: int,
    frame_names: [int],
    frame_bases: [int]
}

fn stack_region_new(capacity: int) -> StackRegion {
    return StackRegion {
        capacity: capacity,
        sp: 0,
        generation: 0,
        frame_names: [],
        frame_bases: []
    }
}

fn stack_region_alloc(region: StackRegion, size: int) -> StackRegion {
    if region.sp + size > region.capacity {
        print("ERROR: stack overflow: requested " + str(size) + " bytes, " + str(region.capacity - region.sp) + " available (1/2 budget exceeded)")
        return region
    }
    return StackRegion {
        capacity: region.capacity,
        sp: region.sp + size,
        generation: region.generation,
        frame_names: region.frame_names,
        frame_bases: region.frame_bases
    }
}

fn stack_region_alloc_offset(region: StackRegion) -> int {
    return region.sp
}

fn stack_region_free_to(region: StackRegion, new_sp: int) -> StackRegion {
    return StackRegion {
        capacity: region.capacity,
        sp: new_sp,
        generation: region.generation + 1,
        frame_names: region.frame_names,
        frame_bases: region.frame_bases
    }
}

fn stack_region_push_frame(region: StackRegion, name_id: int) -> StackRegion {
    if len(region.frame_names) >= MAX_FRAMES {
        return region
    }
    return StackRegion {
        capacity: region.capacity,
        sp: region.sp,
        generation: region.generation,
        frame_names: region.frame_names + [name_id],
        frame_bases: region.frame_bases + [region.sp]
    }
}

fn stack_region_pop_frame(region: StackRegion) -> StackRegion {
    let n = len(region.frame_names)
    if n == 0 {
        return region
    }
    let base = region.frame_bases[n - 1]
    // Trim last element (rebuild without last)
    let new_names: [int] = []
    let new_bases: [int] = []
    let i = 0
    while i < n - 1 {
        new_names = new_names + [region.frame_names[i]]
        new_bases = new_bases + [region.frame_bases[i]]
        i = i + 1
    }
    return StackRegion {
        capacity: region.capacity,
        sp: base,
        generation: region.generation + 1,
        frame_names: new_names,
        frame_bases: new_bases
    }
}

fn stack_region_used(region: StackRegion) -> int {
    return region.sp
}

fn stack_region_frame_depth(region: StackRegion) -> int {
    return len(region.frame_names)
}

// ── HeapRegion ─────────────────────────────────────────────
// Heap with header-based size tracking and segregated free lists.

struct HeapRegion {
    capacity: int,
    bump: int,
    used: int,
    live_allocs: int,
    free_list: [int]   // simplified: list of freed offsets
}

fn heap_region_new(capacity: int) -> HeapRegion {
    return HeapRegion {
        capacity: capacity,
        bump: 0,
        used: 0,
        live_allocs: 0,
        free_list: []
    }
}

fn align8(size: int) -> int {
    return ((size + 7) / 8) * 8
}

fn size_class(aligned: int) -> int {
    let i = 0
    while i < N_SIZE_CLASSES {
        if aligned <= SIZE_CLASSES[i] {
            return i
        }
        i = i + 1
    }
    return -1   // large allocation
}

fn heap_region_alloc(region: HeapRegion, size: int) -> HeapRegion {
    if size == 0 {
        return region
    }
    let aligned = align8(size)
    let total = HEADER_SIZE + aligned
    if region.bump + total > region.capacity {
        print("ERROR: heap full: requested " + str(size) + " bytes (1/3 budget exceeded)")
        return region
    }
    return HeapRegion {
        capacity: region.capacity,
        bump: region.bump + total,
        used: region.used + aligned,
        live_allocs: region.live_allocs + 1,
        free_list: region.free_list
    }
}

fn heap_region_alloc_offset(region: HeapRegion) -> int {
    return region.bump + HEADER_SIZE
}

fn heap_region_free(region: HeapRegion, aligned_size: int) -> HeapRegion {
    return HeapRegion {
        capacity: region.capacity,
        bump: region.bump,
        used: region.used - aligned_size,
        live_allocs: region.live_allocs - 1,
        free_list: region.free_list
    }
}

// ── ArenaRegion ────────────────────────────────────────────
// Bump-allocator arena -- extremely fast, reset at scope boundaries.

struct ArenaRegion {
    capacity: int,
    offset: int,
    generation: int
}

fn arena_region_new(capacity: int) -> ArenaRegion {
    return ArenaRegion { capacity: capacity, offset: 0, generation: 0 }
}

fn arena_region_alloc(region: ArenaRegion, size: int) -> ArenaRegion {
    if size == 0 {
        return region
    }
    let aligned = align8(size)
    if region.offset + aligned > region.capacity {
        print("ERROR: arena overflow: requested " + str(size) + " bytes (1/6 budget exceeded)")
        return region
    }
    return ArenaRegion {
        capacity: region.capacity,
        offset: region.offset + aligned,
        generation: region.generation
    }
}

fn arena_region_alloc_offset(region: ArenaRegion) -> int {
    return region.offset
}

fn arena_region_reset(region: ArenaRegion) -> ArenaRegion {
    return ArenaRegion {
        capacity: region.capacity,
        offset: 0,
        generation: region.generation + 1
    }
}

fn arena_region_used(region: ArenaRegion) -> int {
    return region.offset
}

// ── MemoryStats ────────────────────────────────────────────

struct MemoryStats {
    stack_used: int,
    stack_capacity: int,
    heap_used: int,
    heap_capacity: int,
    heap_allocs: int,
    arena_used: int,
    arena_capacity: int,
    arena_resets: int,
    total_budget: int,
    total_allocs: int,
    stack_frame_depth: int
}

fn memory_stats_display(s: MemoryStats) -> string {
    let out = "=== Egyptian Fraction Memory Report ===\n"
    out = out + "Budget: " + str(s.total_budget) + " bytes\n"
    out = out + "Identity: 1/2 + 1/3 + 1/6 = 1 (n=6)\n"
    out = out + "---\n"
    out = out + "Stack (1/2): " + str(s.stack_used) + " / " + str(s.stack_capacity) + " bytes\n"
    out = out + "  Frames: " + str(s.stack_frame_depth) + "\n"
    out = out + "Heap  (1/3): " + str(s.heap_used) + " / " + str(s.heap_capacity) + " bytes\n"
    out = out + "  Live objects: " + str(s.heap_allocs) + "\n"
    out = out + "Arena (1/6): " + str(s.arena_used) + " / " + str(s.arena_capacity) + " bytes\n"
    out = out + "  Resets: " + str(s.arena_resets) + "\n"
    out = out + "---\n"
    let total_used = s.stack_used + s.heap_used + s.arena_used
    out = out + "Total used: " + str(total_used) + " / " + str(s.total_budget) + " bytes\n"
    out = out + "Total allocations: " + str(s.total_allocs)
    return out
}

// ── VarHandle (packed region:2 | index:30) ─────────────────

struct VarHandle {
    raw: int
}

let VAR_HANDLE_NONE = VarHandle { raw: -1 }

fn var_handle_new(region: string, index: int) -> VarHandle {
    let tag = 0
    if region == "heap" {
        tag = 1
    } else if region == "arena" {
        tag = 2
    }
    return VarHandle { raw: tag * 1073741824 + index }   // 1 << 30
}

fn var_handle_region(h: VarHandle) -> string {
    let tag = h.raw / 1073741824
    if tag == 0 { return "stack" }
    if tag == 1 { return "heap" }
    return "arena"
}

fn var_handle_index(h: VarHandle) -> int {
    return h.raw % 1073741824
}

// ── VarRecord + Tracker ────────────────────────────────────

struct VarRecord {
    name: string,
    region: string,
    offset: int,
    size: int,
    alive: bool
}

struct Tracker {
    records: [VarRecord]
}

fn tracker_new() -> Tracker {
    return Tracker { records: [] }
}

fn tracker_record(t: Tracker, name: string, region: string, offset: int, size: int) -> Tracker {
    // Tombstone previous entry with same name + region
    let new_records: [VarRecord] = []
    let i = 0
    while i < len(t.records) {
        let r = t.records[i]
        if r.name == name && r.region == region && r.alive {
            new_records = new_records + [VarRecord { name: r.name, region: r.region, offset: r.offset, size: r.size, alive: false }]
        } else {
            new_records = new_records + [r]
        }
        i = i + 1
    }
    new_records = new_records + [VarRecord { name: name, region: region, offset: offset, size: size, alive: true }]
    return Tracker { records: new_records }
}

fn tracker_find_region(t: Tracker, name: string) -> string {
    let i = len(t.records) - 1
    while i >= 0 {
        let r = t.records[i]
        if r.name == name && r.alive {
            return r.region
        }
        i = i - 1
    }
    return ""
}

// ── EgyptianMemory ─────────────────────────────────────────
// The Egyptian Fraction memory manager.

struct EgyptianMemory {
    total_budget: int,
    stack: StackRegion,
    heap: HeapRegion,
    arena: ArenaRegion,
    total_allocs: int,
    tracker: Tracker
}

fn egyptian_memory_new(total_budget: int) -> EgyptianMemory {
    let stack_cap = total_budget / EGYPTIAN_STACK
    let heap_cap  = total_budget / EGYPTIAN_HEAP
    let arena_cap = total_budget / EGYPTIAN_ARENA
    return EgyptianMemory {
        total_budget: total_budget,
        stack: stack_region_new(stack_cap),
        heap: heap_region_new(heap_cap),
        arena: arena_region_new(arena_cap),
        total_allocs: 0,
        tracker: tracker_new()
    }
}

fn egyptian_memory_default() -> EgyptianMemory {
    return egyptian_memory_new(DEFAULT_BUDGET)
}

fn egyptian_memory_stats(mem: EgyptianMemory) -> MemoryStats {
    return MemoryStats {
        stack_used: stack_region_used(mem.stack),
        stack_capacity: mem.stack.capacity,
        heap_used: mem.heap.used,
        heap_capacity: mem.heap.capacity,
        heap_allocs: mem.heap.live_allocs,
        arena_used: arena_region_used(mem.arena),
        arena_capacity: mem.arena.capacity,
        arena_resets: mem.arena.generation,
        total_budget: mem.total_budget,
        total_allocs: mem.total_allocs,
        stack_frame_depth: stack_region_frame_depth(mem.stack)
    }
}

fn egyptian_memory_get_region(mem: EgyptianMemory, name: string) -> string {
    return tracker_find_region(mem.tracker, name)
}

// ── Region classification ──────────────────────────────────

fn classify_region(kind: string) -> string {
    match kind {
        "int"    => return "stack",
        "float"  => return "stack",
        "bool"   => return "stack",
        "char"   => return "stack",
        "void"   => return "stack",
        "array"  => return "heap",
        "struct" => return "heap",
        "map"    => return "heap",
        "lambda" => return "heap",
        "fn"     => return "heap",
        "set"    => return "heap",
        "string" => return "arena",
        "tuple"  => return "arena",
        "error"  => return "arena",
        _        => return "heap"
    }
}

// ── Value size estimation ──────────────────────────────────

fn estimate_value_size(kind: string, extra: int) -> int {
    match kind {
        "int"    => return 8,
        "float"  => return 8,
        "bool"   => return 1,
        "char"   => return 4,
        "void"   => return 0,
        "string" => return 24 + extra,
        "array"  => return 24 + extra * 16,
        "struct" => return 48 + extra * 40,
        "map"    => return 48 + extra * 40,
        "lambda" => return 64 + extra * 40,
        "fn"     => return 64,
        _        => return 32
    }
}

// ── Tests ──────────────────────────────────────────────────

fn test_egyptian_fraction_identity() {
    let total = 600
    let mem = egyptian_memory_new(total)
    let stats = egyptian_memory_stats(mem)
    assert(stats.stack_capacity == 300)   // 1/2
    assert(stats.heap_capacity == 200)    // 1/3
    assert(stats.arena_capacity == 100)   // 1/6
    assert(stats.stack_capacity + stats.heap_capacity + stats.arena_capacity == total)
    print("  PASS: egyptian_fraction_identity")
}

fn test_align8() {
    assert(align8(1) == 8)
    assert(align8(7) == 8)
    assert(align8(8) == 8)
    assert(align8(9) == 16)
    assert(align8(16) == 16)
    assert(align8(0) == 0)
    print("  PASS: align8")
}

fn test_size_class() {
    assert(size_class(8) == 0)    // 16B class
    assert(size_class(16) == 0)
    assert(size_class(32) == 1)
    assert(size_class(64) == 2)
    assert(size_class(128) == 3)
    assert(size_class(256) == 4)
    assert(size_class(512) == 5)
    assert(size_class(1024) == -1)  // large
    print("  PASS: size_class")
}

fn test_stack_region() {
    let sr = stack_region_new(300)
    assert(stack_region_used(sr) == 0)
    let sr2 = stack_region_alloc(sr, 8)
    assert(stack_region_used(sr2) == 8)
    let sr3 = stack_region_push_frame(sr2, 0)
    assert(stack_region_frame_depth(sr3) == 1)
    let sr4 = stack_region_pop_frame(sr3)
    assert(stack_region_frame_depth(sr4) == 0)
    print("  PASS: stack_region")
}

fn test_arena_region() {
    let ar = arena_region_new(100)
    assert(arena_region_used(ar) == 0)
    let ar2 = arena_region_alloc(ar, 16)
    assert(arena_region_used(ar2) == 16)
    let ar3 = arena_region_reset(ar2)
    assert(arena_region_used(ar3) == 0)
    assert(ar3.generation == 1)
    print("  PASS: arena_region")
}

fn test_classify_region() {
    assert(classify_region("int") == "stack")
    assert(classify_region("float") == "stack")
    assert(classify_region("bool") == "stack")
    assert(classify_region("array") == "heap")
    assert(classify_region("map") == "heap")
    assert(classify_region("string") == "arena")
    print("  PASS: classify_region")
}

fn test_estimate_value_size() {
    assert(estimate_value_size("int", 0) == 8)
    assert(estimate_value_size("float", 0) == 8)
    assert(estimate_value_size("bool", 0) == 1)
    assert(estimate_value_size("string", 5) == 29)
    print("  PASS: estimate_value_size")
}

fn test_var_handle() {
    let h = var_handle_new("heap", 12345)
    assert(var_handle_region(h) == "heap")
    assert(var_handle_index(h) == 12345)
    let h2 = var_handle_new("arena", 0)
    assert(var_handle_region(h2) == "arena")
    assert(var_handle_index(h2) == 0)
    let h3 = var_handle_new("stack", 999)
    assert(var_handle_region(h3) == "stack")
    assert(var_handle_index(h3) == 999)
    print("  PASS: var_handle")
}

fn test_memory_stats_display() {
    let mem = egyptian_memory_new(600)
    let stats = egyptian_memory_stats(mem)
    let output = memory_stats_display(stats)
    assert(len(output) > 0)
    print("  PASS: memory_stats_display")
}

// ── Main ───────────────────────────────────────────────────

print("=== memory.hexa tests ===")
test_egyptian_fraction_identity()
test_align8()
test_size_class()
test_stack_region()
test_arena_region()
test_classify_region()
test_estimate_value_size()
test_var_handle()
test_memory_stats_display()
print("All memory tests passed.")
