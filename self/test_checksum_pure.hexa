// self/test_checksum_pure.hexa -- Tests for self/runtime/checksum_pure.hexa
//
// Reference values computed with python3:
//   sdbm     — reference impl
//   djb2     — reference impl
//   adler32  — zlib.adler32
//   sum_xor  — reference impl
//   luhn     — Wikipedia / VISA test vectors

// ── inlined from self/runtime/checksum_pure.hexa ──────────────────

let TWO_POW_32 = 4294967296
let SDBM_MULT = 65599
let DJB2_INIT = 5381
let ADLER_MOD = 65521

fn sdbm_pure(s) {
    if type_of(s) != "string" { return 0 }
    let mut h = 0
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = ord(s.substring(i, i + 1))
        h = (c + h * SDBM_MULT) % TWO_POW_32
        i = i + 1
    }
    h
}

fn djb2_pure(s) {
    if type_of(s) != "string" { return DJB2_INIT }
    let mut h = DJB2_INIT
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = ord(s.substring(i, i + 1))
        h = (h * 33 + c) % TWO_POW_32
        i = i + 1
    }
    h
}

fn adler32_pure(s) {
    if type_of(s) != "string" { return 1 }
    let mut a = 1
    let mut b = 0
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = ord(s.substring(i, i + 1))
        a = (a + c) % ADLER_MOD
        b = (b + a) % ADLER_MOD
        i = i + 1
    }
    b * 65536 + a
}

fn sum_xor_pure(s) {
    if type_of(s) != "string" { return 0 }
    let mut h = 0
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = ord(s.substring(i, i + 1))
        h = h ^ c
        i = i + 1
    }
    h
}

fn luhn_pure(s) {
    if type_of(s) != "string" { return 0 }
    let n = len(s)
    let mut digits = []
    let mut i = 0
    while i < n {
        let c = ord(s.substring(i, i + 1))
        if c >= 48 {
            if c <= 57 {
                digits = digits + [c - 48]
            }
        }
        i = i + 1
    }
    let m = len(digits)
    let mut total = 0
    let mut k = 0
    while k < m {
        let mut d = digits[m - 1 - k]
        if (k % 2) == 1 {
            d = d * 2
            if d > 9 { d = d - 9 }
        }
        total = total + d
        k = k + 1
    }
    total % 10
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  checksum_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── sdbm_pure — known vectors ───────────────────────────────────
println("")
println("--- sdbm_pure (known vectors) ---")
check("empty",       sdbm_pure(""),           0)
check("'a'",         sdbm_pure("a"),          97)
check("'abc'",       sdbm_pure("abc"),        807794786)
check("'foo'",       sdbm_pure("foo"),        849955110)
check("'foobar'",    sdbm_pure("foobar"),     2789440269)
check("'hello'",     sdbm_pure("hello"),      684824882)
check("'123456789'", sdbm_pure("123456789"),  1755344949)
check("pangram",     sdbm_pure("The quick brown fox jumps over the lazy dog"), 2359783795)

// ── djb2_pure — known vectors ───────────────────────────────────
println("")
println("--- djb2_pure (known vectors) ---")
check("empty",       djb2_pure(""),           5381)
check("'a'",         djb2_pure("a"),          177670)
check("'abc'",       djb2_pure("abc"),        193485963)
check("'foo'",       djb2_pure("foo"),        193491849)
check("'foobar'",    djb2_pure("foobar"),     4259602622)
check("'hello'",     djb2_pure("hello"),      261238937)
check("'123456789'", djb2_pure("123456789"),  902675330)
check("pangram",     djb2_pure("The quick brown fox jumps over the lazy dog"), 885799134)

// ── adler32_pure — known vectors ───────────────────────────────
println("")
println("--- adler32_pure (known vectors) ---")
check("empty",       adler32_pure(""),           1)
check("'a'",         adler32_pure("a"),          6422626)
check("'abc'",       adler32_pure("abc"),        38600999)
check("'foo'",       adler32_pure("foo"),        42074437)
check("'foobar'",    adler32_pure("foobar"),     145425018)
check("'hello'",     adler32_pure("hello"),      103547413)
check("'hello world'", adler32_pure("hello world"), 436929629)
check("'123456789'", adler32_pure("123456789"),  152961502)
check("pangram",     adler32_pure("The quick brown fox jumps over the lazy dog"), 1541148634)

// ── sum_xor_pure — known vectors ────────────────────────────────
println("")
println("--- sum_xor_pure (known vectors) ---")
check("empty",       sum_xor_pure(""),        0)
check("'a'",         sum_xor_pure("a"),       97)
check("'abc'",       sum_xor_pure("abc"),     96)  // 'a'^'b'^'c' = 0x60
check("'foo'",       sum_xor_pure("foo"),     102)
check("'hello'",     sum_xor_pure("hello"),   98)
check("'hello world'", sum_xor_pure("hello world"), 32)
check("symmetry 'ab' == 'ba'", sum_xor_pure("ab"), sum_xor_pure("ba"))
check("self-cancel 'aa' == 0", sum_xor_pure("aa"), 0)
check("range <= 255", sum_xor_pure("The quick brown fox jumps over the lazy dog") < 256, true)

// ── luhn_pure — known vectors ───────────────────────────────────
println("")
println("--- luhn_pure (credit-card style) ---")
check("Wikipedia '79927398713'",      luhn_pure("79927398713"),      0)
check("VISA test '4532015112830366'", luhn_pure("4532015112830366"), 0)
check("bad check '123456789'",        luhn_pure("123456789"),        7)
check("empty returns 0",              luhn_pure(""),                 0)
check("non-digits skipped",
    luhn_pure("7992-7398-713"),
    luhn_pure("79927398713"))

// ── determinism / sanity ────────────────────────────────────────
println("")
println("--- determinism / sanity ---")
check("sdbm same input same",    sdbm_pure("abc") == sdbm_pure("abc"), true)
check("djb2 same input same",    djb2_pure("abc") == djb2_pure("abc"), true)
check("adler32 different diff",  adler32_pure("a") != adler32_pure("b"), true)
check("sdbm order matters",      sdbm_pure("ab") != sdbm_pure("ba"), true)
check("djb2 order matters",      djb2_pure("ab") != djb2_pure("ba"), true)
check("sdbm non-string -> 0",    sdbm_pure(42), 0)
check("djb2 non-string -> init", djb2_pure(42), DJB2_INIT)
check("adler32 non-string -> 1", adler32_pure(42), 1)

// ── range / type sanity ─────────────────────────────────────────
println("")
println("--- range sanity ---")
check("sdbm fits 32-bit",    sdbm_pure("hello world") < TWO_POW_32, true)
check("djb2 fits 32-bit",    djb2_pure("hello world") < TWO_POW_32, true)
check("adler32 fits 32-bit", adler32_pure("The quick brown fox jumps over the lazy dog") < TWO_POW_32, true)
check("luhn in [0,9]",       luhn_pure("12345") >= 0, true)
check("luhn in [0,9] max",   luhn_pure("99999") <= 9, true)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
