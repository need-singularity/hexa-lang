// test_m480_symbolic_fuse.hexa — M480 @symbolic strength reduction + M481/M482 @fuse chain detection
// Standalone smoke test for the two new AI-native vectors.

// ═══════════════════════════════════════
// Helper: power-of-two checks
// ═══════════════════════════════════════

fn is_power_of_two(n) {
    if n < 2 { return false }
    let mut v = n
    while v > 1 {
        if v % 2 != 0 { return false }
        v = v / 2
    }
    return true
}

fn log2_of(n) {
    let mut v = n
    let mut r = 0
    while v > 1 {
        v = v / 2
        r = r + 1
    }
    return r
}

// ═══════════════════════════════════════
// Test 1: is_power_of_two / log2_of
// ═══════════════════════════════════════

fn test_pow2_helpers() {
    assert(is_power_of_two(1) == false)
    assert(is_power_of_two(2) == true)
    assert(is_power_of_two(3) == false)
    assert(is_power_of_two(4) == true)
    assert(is_power_of_two(8) == true)
    assert(is_power_of_two(16) == true)
    assert(is_power_of_two(15) == false)
    assert(is_power_of_two(1024) == true)
    assert(log2_of(2) == 1)
    assert(log2_of(4) == 2)
    assert(log2_of(8) == 3)
    assert(log2_of(16) == 4)
    assert(log2_of(1024) == 10)
    println("Test 1 PASS: pow2 helpers")
}

// ═══════════════════════════════════════
// Test 2: @symbolic strength reduction verification
//   x * 8 should compute same result as x << 3
//   x / 4 should compute same result as x >> 2
//   x % 8 should compute same result as x & 7
// ═══════════════════════════════════════

fn test_symbolic_equivalence() {
    let x = 42
    // multiply by power of 2
    assert(x * 2 == x + x)
    assert(x * 4 == x + x + x + x)
    assert(x * 8 == 336)
    // divide by power of 2 (integer)
    assert(64 / 2 == 32)
    assert(64 / 4 == 16)
    assert(64 / 8 == 8)
    assert(1024 / 16 == 64)
    // modulo by power of 2
    assert(42 % 8 == 2)
    assert(100 % 16 == 4)
    assert(255 % 4 == 3)
    println("Test 2 PASS: symbolic equivalence")
}

// ═══════════════════════════════════════
// Test 3: @fuse call chain depth
// ═══════════════════════════════════════

fn call_chain_depth(expr_kind, inner_depth) {
    // Simplified model: if expr is a "call", depth = 1 + inner
    if expr_kind == "call" {
        return 1 + inner_depth
    }
    return inner_depth
}

fn test_fuse_chain_depth() {
    // f(x) = depth 1
    let d1 = call_chain_depth("call", 0)
    assert(d1 == 1)
    // f(g(x)) = depth 2
    let d2 = call_chain_depth("call", call_chain_depth("call", 0))
    assert(d2 == 2)
    // f(g(h(x))) = depth 3
    let d3 = call_chain_depth("call", call_chain_depth("call", call_chain_depth("call", 0)))
    assert(d3 == 3)
    // threshold for fusion candidate is >= 2
    assert(d1 < 2)
    assert(d2 >= 2)
    assert(d3 >= 2)
    println("Test 3 PASS: fuse chain depth")
}

// ═══════════════════════════════════════
// Test 4: strength reduction correctness for edge cases
// ═══════════════════════════════════════

fn test_symbolic_edge_cases() {
    // x * 1 should NOT trigger pow2 (handled by algebraic x*1→x)
    assert(is_power_of_two(1) == false)
    // x * 0 should NOT trigger pow2 (handled by x*0→0)
    assert(is_power_of_two(0) == false)
    // x * 3 should NOT trigger pow2 (not a power of two)
    assert(is_power_of_two(3) == false)
    // Large power of two
    assert(is_power_of_two(4096) == true)
    assert(log2_of(4096) == 12)
    // Verify: 7 * 4096 == 7 << 12 == 28672
    assert(7 * 4096 == 28672)
    println("Test 4 PASS: symbolic edge cases")
}

// ═══════════════════════════════════════
// Test 5: @fuse single intermediate variable elimination
//   Before: let temp = f(x); let result = g(temp); return result
//   After:  let result = g(f(x)); return result
// We verify the semantics are preserved (same output).
// ═══════════════════════════════════════

fn double(x) { return x * 2 }
fn add_one(x) { return x + 1 }
fn square(x) { return x * x }
fn negate(x) { return 0 - x }

// Before fusion: two intermediates
fn pipeline_before(x) {
    let a = double(x)
    let b = add_one(a)
    return b
}

// After fusion (what the rewrite should produce semantically): no intermediates
fn pipeline_after(x) {
    return add_one(double(x))
}

fn test_fuse_single_elim() {
    // Verify before and after produce identical results
    assert(pipeline_before(5) == pipeline_after(5))
    assert(pipeline_before(0) == pipeline_after(0))
    assert(pipeline_before(100) == pipeline_after(100))
    // Verify actual values: double(5)=10, add_one(10)=11
    assert(pipeline_before(5) == 11)
    assert(pipeline_after(5) == 11)
    println("Test 5 PASS: fuse single intermediate elimination")
}

// ═══════════════════════════════════════
// Test 6: @fuse chain fusion a→b→c becomes a→c
//   Before: let t1 = f(x); let t2 = g(t1); let t3 = h(t2); return t3
//   After:  return h(g(f(x)))
// ═══════════════════════════════════════

fn chain_before(x) {
    let t1 = double(x)
    let t2 = add_one(t1)
    let t3 = square(t2)
    return t3
}

fn chain_after(x) {
    return square(add_one(double(x)))
}

fn test_fuse_chain() {
    // double(3)=6, add_one(6)=7, square(7)=49
    assert(chain_before(3) == 49)
    assert(chain_after(3) == 49)
    assert(chain_before(3) == chain_after(3))
    // double(0)=0, add_one(0)=1, square(1)=1
    assert(chain_before(0) == 1)
    assert(chain_after(0) == 1)
    assert(chain_before(0) == chain_after(0))
    println("Test 6 PASS: fuse chain a->b->c")
}

// ═══════════════════════════════════════
// Test 7: @fuse map-filter fusion pattern
//   Before: let mapped = map_op(items); let filtered = filter_op(mapped); return filtered
//   After:  return filter_op(map_op(items))
// ═══════════════════════════════════════

fn map_double(arr) {
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        out.push(arr[i] * 2)
        i = i + 1
    }
    return out
}

fn filter_gt5(arr) {
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] > 5 {
            out.push(arr[i])
        }
        i = i + 1
    }
    return out
}

fn map_filter_before(arr) {
    let mapped = map_double(arr)
    let filtered = filter_gt5(mapped)
    return filtered
}

fn map_filter_after(arr) {
    return filter_gt5(map_double(arr))
}

fn test_fuse_map_filter() {
    let data = [1, 2, 3, 4, 5]
    // map_double → [2,4,6,8,10], filter_gt5 → [6,8,10]
    let r1 = map_filter_before(data)
    let r2 = map_filter_after(data)
    assert(len(r1) == 3)
    assert(len(r2) == 3)
    assert(r1[0] == 6)
    assert(r1[1] == 8)
    assert(r1[2] == 10)
    assert(r2[0] == 6)
    assert(r2[1] == 8)
    assert(r2[2] == 10)
    println("Test 7 PASS: fuse map-filter pattern")
}

// ═══════════════════════════════════════
// Test 8: @fuse safety — multi-use intermediates must NOT be eliminated
// ═══════════════════════════════════════

fn multi_use_safe(x) {
    let temp = double(x)
    let a = add_one(temp)
    let b = square(temp)  // temp used twice — must NOT fuse
    return a + b
}

fn test_fuse_multi_use_safe() {
    // double(3)=6, add_one(6)=7, square(6)=36, 7+36=43
    assert(multi_use_safe(3) == 43)
    println("Test 8 PASS: fuse multi-use safety (no elimination)")
}

// ═══════════════════════════════════════
// Test 9: @fuse with expression (not just call) intermediates
//   let temp = a + b; let result = temp * 2; → let result = (a + b) * 2;
// ═══════════════════════════════════════

fn expr_fuse_before(a, b) {
    let sum = a + b
    let result = sum * 2
    return result
}

fn expr_fuse_after(a, b) {
    return (a + b) * 2
}

fn test_fuse_expr_intermediate() {
    assert(expr_fuse_before(3, 4) == 14)
    assert(expr_fuse_after(3, 4) == 14)
    assert(expr_fuse_before(3, 4) == expr_fuse_after(3, 4))
    assert(expr_fuse_before(0, 0) == 0)
    assert(expr_fuse_before(10, 20) == 60)
    println("Test 9 PASS: fuse expression intermediates")
}

// ═══════════════════════════════════════
// Run all
// ═══════════════════════════════════════

test_pow2_helpers()
test_symbolic_equivalence()
test_fuse_chain_depth()
test_symbolic_edge_cases()
test_fuse_single_elim()
test_fuse_chain()
test_fuse_map_filter()
test_fuse_multi_use_safe()
test_fuse_expr_intermediate()
println("ALL 9 TESTS PASS")
