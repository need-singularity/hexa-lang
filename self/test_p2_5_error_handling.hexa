// ═══════════════════════════════════════════════════════════
//  test_p2_5_error_handling.hexa — P2-5 Error Handling Tests
//  Tests: exec_try_catch, exec_throw, ThrowExpr, stack trace,
//         error propagation across frames, LoopStmt throw abort,
//         map/struct throw with trace, re-throw patterns
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_contains(name, haystack, needle) {
    let s = to_string(haystack)
    if s.contains(needle) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — '" + s + "' does not contain '" + needle + "'")
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  P2-5: Error Handling — exec_try_catch + exec_throw")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic try/catch — no error ────────────────────────

println("--- Basic exec_try_catch ---")

let mut r1 = 0
try {
    r1 = 42
} catch e {
    r1 = -1
}
check("try no error", r1, 42)

// ── 2. Throw string — exec_throw attaches trace ─────────

let mut r2 = ""
try {
    throw "boom"
} catch e {
    r2 = to_string(e)
}
check_contains("throw str has message", r2, "boom")

// ── 3. Throw int — preserved as-is ──────────────────────

let mut r3 = 0
try {
    throw 42
} catch e {
    r3 = 1
}
check("throw int caught", r3, 1)

// ── 4. Throw map — trace attached if missing ─────────────

let mut r4 = ""
try {
    throw #{"code": 404, "msg": "not found"}
} catch e {
    r4 = to_string(e)
}
check_contains("throw map has code", r4, "404")

// ── 5. Function throw + catch ────────────────────────────

println("")
println("--- Function Throw ---")

fn require_positive(x) {
    if x <= 0 { throw "must be positive: " + to_string(x) }
    return x
}

let mut r5 = 0
try {
    r5 = require_positive(10)
} catch e {
    r5 = -1
}
check("fn no throw", r5, 10)

let mut r6 = 0
try {
    r6 = require_positive(-5)
} catch e {
    r6 = -1
}
check("fn throws", r6, -1)

// ── 6. Multi-frame propagation ───────────────────────────

println("")
println("--- Multi-Frame Propagation ---")

fn deep_a() { throw "deep" }
fn deep_b() { return deep_a() }
fn deep_c() { return deep_b() }
fn deep_d() { return deep_c() }

let mut r7 = 0
try {
    deep_d()
    r7 = 1
} catch e {
    r7 = 99
}
check("4-frame propagation", r7, 99)

// ── 7. Thrown error is catchable and inspectable ─────────

println("")
println("--- Error Inspection ---")

fn trace_inner() {
    throw "traced error"
}

fn trace_outer() {
    return trace_inner()
}

let mut r8 = ""
try {
    trace_outer()
} catch e {
    r8 = to_string(e)
}
check_contains("caught error has message", r8, "traced error")

// ── 8. Nested try/catch ──────────────────────────────────

println("")
println("--- Nested Try/Catch ---")

let mut r9 = ""
try {
    try {
        throw "inner"
    } catch e1 {
        r9 = "inner caught"
    }
    r9 = r9 + "+outer ok"
} catch e2 {
    r9 = "outer caught"
}
check("nested inner", r9, "inner caught+outer ok")

// Inner rethrows to outer
let mut r10 = ""
try {
    try {
        throw "L1"
    } catch e1 {
        throw "L2"
    }
} catch e2 {
    r10 = "rethrown"
}
check("nested rethrow", r10, "rethrown")

// ── 9. Three-level nesting ───────────────────────────────

let mut r11 = ""
try {
    try {
        try {
            throw "deep"
        } catch e1 {
            r11 = r11 + "L3-"
            throw "rethrow"
        }
    } catch e2 {
        r11 = r11 + "L2-"
        throw "rethrow2"
    }
} catch e3 {
    r11 = r11 + "L1"
}
check("three-level nesting", r11, "L3-L2-L1")

// ── 10. Try/catch in while loop ──────────────────────────

println("")
println("--- Loop + Error ---")

let mut errors = 0
let mut successes = 0
let mut i = 0
while i < 5 {
    try {
        if i == 2 || i == 4 { throw "skip" }
        successes = successes + 1
    } catch e {
        errors = errors + 1
    }
    i = i + 1
}
check("loop errors", errors, 2)
check("loop successes", successes, 3)

// ── 11. Try/catch in for loop ────────────────────────────

let mut for_sum = 0
let mut for_errs = 0
for x in [1, -2, 3, -4, 5] {
    try {
        if x < 0 { throw "neg" }
        for_sum = for_sum + x
    } catch e {
        for_errs = for_errs + 1
    }
}
check("for loop sum", for_sum, 9)
check("for loop errs", for_errs, 2)

// ── 12. Return inside try ────────────────────────────────

println("")
println("--- Return in Try ---")

fn try_return(x) {
    try {
        if x > 0 { return x * 2 }
        throw "neg"
    } catch e {
        return -1
    }
}

check("try return pos", try_return(5), 10)
check("try return neg", try_return(-5), -1)
check("try return zero", try_return(0), -1)

// ── 13. Error recovery + state rollback ──────────────────

println("")
println("--- State Rollback ---")

let mut state = 100
try {
    state = state - 50
    throw "abort"
    state = state - 10
} catch e {
    state = state + 50
}
check("rollback state", state, 100)

// ── 14. Error accumulation pattern ───────────────────────

println("")
println("--- Error Accumulation ---")

fn parse_int_safe(s) {
    if s == "abc" || s == "xyz" { throw "not a number" }
    return to_int(s)
}

let inputs = ["1", "abc", "3", "xyz", "5"]
let mut total = 0
let mut parse_errs = 0
for inp in inputs {
    try {
        total = total + parse_int_safe(inp)
    } catch e {
        parse_errs = parse_errs + 1
    }
}
check("parse total", total, 9)
check("parse errors", parse_errs, 2)

// ── 15. Retry pattern ────────────────────────────────────

println("")
println("--- Retry Pattern ---")

let mut attempt = 0
fn retry(max) {
    let mut i = 0
    while i < max {
        try {
            attempt = attempt + 1
            if attempt < 3 { throw "not ready" }
            return "success"
        } catch e {
            // continue
        }
        i = i + 1
    }
    return "failed"
}

check("retry result", retry(5), "success")
check("retry attempts", attempt, 3)

// ── 16. Partial execution — throw stops remaining stmts ──

println("")
println("--- Partial Execution ---")

let mut log = []
try {
    log = log.push("a")
    log = log.push("b")
    throw "stop"
    log = log.push("c")
    log = log.push("d")
} catch e {
    log = log.push("caught")
}
check("partial len", len(log), 3)
check("partial[0]", log[0], "a")
check("partial[1]", log[1], "b")
check("partial[2]", log[2], "caught")

// ── 17. Catch variable binding ───────────────────────────

println("")
println("--- Catch Var Binding ---")

let mut caught_val = ""
try {
    throw "specific error 42"
} catch my_err {
    caught_val = to_string(my_err)
}
check_contains("catch var has message", caught_val, "specific error 42")

// ── 18. Throw from recursive function ────────────────────

println("")
println("--- Recursive Throw ---")

fn rec_a(n) { throw "bottom" }
fn rec_b(n) { return rec_a(n) }
fn rec_c(n) { return rec_b(n) }

let mut rr = 0
try {
    rec_c(0)
    rr = 1
} catch e {
    rr = 99
}
check("recursive throw", rr, 99)

// ── 19. Sequential try/catch — independence ──────────────

println("")
println("--- Sequential Independence ---")

let mut s1 = 0
try { throw "e1" } catch e { s1 = 1 }

let mut s2 = 0
try { s2 = 42 } catch e { s2 = -1 }

let mut s3 = 0
try { throw "e3" } catch e { s3 = 3 }

check("seq s1", s1, 1)
check("seq s2 (no error)", s2, 42)
check("seq s3", s3, 3)

// ── 20. Try/catch with match ─────────────────────────────

println("")
println("--- Try + Match ---")

fn classify(x) {
    if x < 0 { throw "negative" }
    return match x {
        0 -> "zero",
        1 -> "one",
        _ -> "many"
    }
}

let mut cm1 = ""
try { cm1 = classify(0) } catch e { cm1 = "err" }
check("classify 0", cm1, "zero")

let mut cm2 = ""
try { cm2 = classify(5) } catch e { cm2 = "err" }
check("classify 5", cm2, "many")

let mut cm3 = ""
try { cm3 = classify(-1) } catch e { cm3 = "err" }
check("classify -1", cm3, "err")

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total_tests = pass_count + fail_count
println("  P2-5 Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total_tests) + " total")
if fail_count == 0 {
    println("  ALL P2-5 ERROR HANDLING TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    throw "P2-5 TESTS FAILED: " + to_string(fail_count)
}
