// ═══════════════════════════════════════════════════════════
//  test_cold_split.hexa — @cold code splitting (ROI #67)
//  Self-contained test: inlines the cold-split functions so
//  tests can run without importing the full ai_native_pass.
// ═══════════════════════════════════════════════════════════

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA @cold Code Splitting Tests (ROI #67)")
println("═══════════════════════════════════════════════════════")
println("")

// ═══════════════════════════════════════════════════════════
//  Inline: ROI #67 cold split functions
// ═══════════════════════════════════════════════════════════

let mut m978_cold_detected = 0
let mut m978_cold_outlined = 0
let mut m978_cold_blocks = 0

fn split_attrs_m0(s) {
    let mut out = []
    if s == "" { return out }
    let chars = s.chars()
    let total = len(chars)
    let mut i = 0
    let mut cur = ""
    while i < total {
        let c = to_string(chars[i])
        if c == "," {
            if cur != "" { out = out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if cur != "" { out = out.push(cur) }
    return out
}

fn attr_has(attrs, target) {
    let n = len(attrs)
    let mut i = 0
    while i < n {
        if attrs[i] == target { return true }
        i = i + 1
    }
    return false
}

fn is_cold_call_expr(expr) {
    if type_of(expr) == "string" { return false }
    if expr.kind == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" {
                if callee.name == "panic" { return true }
                if callee.name == "throw" { return true }
                if callee.name == "abort" { return true }
                if callee.name == "hexa_throw" { return true }
                if callee.name == "exit" { return true }
            }
        }
    }
    return false
}

fn is_cold_stmt(stmt) {
    if type_of(stmt) == "string" { return false }
    let k = stmt.kind
    if k == "ExprStmt" { return is_cold_call_expr(stmt.left) }
    if k == "ReturnStmt" { return is_cold_call_expr(stmt.left) }
    return false
}

fn body_has_cold_pattern(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        if is_cold_stmt(body[i]) { return true }
        i = i + 1
    }
    return false
}

fn count_cold_branches(body) {
    if type_of(body) != "array" { return 0 }
    let n = len(body)
    let mut c = 0
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "IfStmt" {
            if body_has_cold_pattern(stmt.then_body) { c = c + 1 }
            if type_of(stmt.else_body) == "array" && body_has_cold_pattern(stmt.else_body) { c = c + 1 }
            c = c + count_cold_branches(stmt.then_body)
            if type_of(stmt.else_body) == "array" { c = c + count_cold_branches(stmt.else_body) }
        }
        if type_of(stmt) != "string" && stmt.kind == "WhileStmt" {
            c = c + count_cold_branches(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn anp_detect_cold_path(fn_node) {
    if type_of(fn_node) == "string" { return 0 }
    if fn_node.kind != "FnDecl" { return 0 }
    let body = fn_node.body
    if type_of(body) != "array" { return 0 }
    if len(body) == 0 { return 0 }
    let cold_count = count_cold_branches(body)
    if cold_count > 0 {
        m978_cold_detected = m978_cold_detected + 1
        m978_cold_blocks = m978_cold_blocks + cold_count
    }
    return cold_count
}

fn make_cold_fn_name(parent_name, idx) {
    return parent_name + "__cold_" + to_string(idx)
}

fn rewrite_fn_with_body(fn_node, new_body) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: fn_node.value, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: new_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_cold_fn(name, params, cold_body) {
    return AstNode {
        kind: "FnDecl", name: name, value: "cold", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: params, body: cold_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_cold_call(cold_name, params) {
    let callee = AstNode {
        kind: "Ident", name: cold_name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let mut arg_list = []
    if type_of(params) == "array" {
        let mut pi = 0
        while pi < len(params) {
            let arg = AstNode {
                kind: "Ident", name: params[pi].name, value: "", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
            arg_list = arg_list.push(arg)
            pi = pi + 1
        }
    }
    let call_expr = AstNode {
        kind: "Call", name: "", value: "", op: "",
        left: callee, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: arg_list, fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: call_expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn outline_cold_body(body, parent_name, params, start_idx) {
    if type_of(body) != "array" { return #{ "body": body, "fns": [], "count": 0 } }
    let mut out = []
    let mut fns = []
    let mut idx = start_idx
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "IfStmt" {
            let then_cold = body_has_cold_pattern(stmt.then_body)
            let else_cold = type_of(stmt.else_body) == "array" && body_has_cold_pattern(stmt.else_body)
            let mut new_then = stmt.then_body
            let mut new_else = stmt.else_body
            if then_cold {
                let cold_name = make_cold_fn_name(parent_name, idx)
                let cold_fn = make_cold_fn(cold_name, params, stmt.then_body)
                fns = fns.push(cold_fn)
                new_then = [make_cold_call(cold_name, params)]
                idx = idx + 1
            }
            if else_cold {
                let cold_name = make_cold_fn_name(parent_name, idx)
                let cold_fn = make_cold_fn(cold_name, params, stmt.else_body)
                fns = fns.push(cold_fn)
                new_else = [make_cold_call(cold_name, params)]
                idx = idx + 1
            }
            if !then_cold && type_of(new_then) == "array" {
                let sub = outline_cold_body(new_then, parent_name, params, idx)
                new_then = sub["body"]
                let mut fi = 0
                while fi < len(sub["fns"]) {
                    fns = fns.push(sub["fns"][fi])
                    fi = fi + 1
                }
                idx = idx + sub["count"]
            }
            if !else_cold && type_of(new_else) == "array" {
                let sub = outline_cold_body(new_else, parent_name, params, idx)
                new_else = sub["body"]
                let mut fi = 0
                while fi < len(sub["fns"]) {
                    fns = fns.push(sub["fns"][fi])
                    fi = fi + 1
                }
                idx = idx + sub["count"]
            }
            let new_if = AstNode {
                kind: "IfStmt", name: stmt.name, value: stmt.value, op: stmt.op,
                left: stmt.left, right: stmt.right, cond: stmt.cond,
                then_body: new_then, else_body: new_else,
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
            out = out.push(new_if)
        } else if type_of(stmt) != "string" && stmt.kind == "WhileStmt" {
            let sub = outline_cold_body(stmt.body, parent_name, params, idx)
            let mut fi = 0
            while fi < len(sub["fns"]) {
                fns = fns.push(sub["fns"][fi])
                fi = fi + 1
            }
            idx = idx + sub["count"]
            let new_while = AstNode {
                kind: "WhileStmt", name: stmt.name, value: stmt.value, op: stmt.op,
                left: stmt.left, right: stmt.right, cond: stmt.cond,
                then_body: "", else_body: "",
                params: "", body: sub["body"], args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
            out = out.push(new_while)
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return #{ "body": out, "fns": fns, "count": idx - start_idx }
}

fn anp_outline_cold(fn_node) {
    if type_of(fn_node) == "string" { return [fn_node] }
    if fn_node.kind != "FnDecl" { return [fn_node] }
    let body = fn_node.body
    if type_of(body) != "array" { return [fn_node] }
    let cold_count = count_cold_branches(body)
    if cold_count == 0 { return [fn_node] }
    let result = outline_cold_body(body, fn_node.name, fn_node.params, 0)
    if len(result["fns"]) == 0 { return [fn_node] }
    let rewritten = rewrite_fn_with_body(fn_node, result["body"])
    m978_cold_outlined = m978_cold_outlined + len(result["fns"])
    let mut out_nodes = []
    let mut fi = 0
    while fi < len(result["fns"]) {
        out_nodes = out_nodes.push(result["fns"][fi])
        fi = fi + 1
    }
    out_nodes = out_nodes.push(rewritten)
    return out_nodes
}

fn anp_cold_split_pass(ast) {
    if type_of(ast) != "array" { return ast }
    m978_cold_detected = 0
    m978_cold_outlined = 0
    m978_cold_blocks = 0
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if type_of(node) != "string" && node.kind == "FnDecl" {
            let has_cold_attr = type_of(node.value) == "string" && node.value != ""
            let mut attrs = []
            if has_cold_attr { attrs = split_attrs_m0(node.value) }
            let is_cold_fn = attr_has(attrs, "cold")
            if is_cold_fn {
                out = out.push(node)
            } else {
                let cold_count = anp_detect_cold_path(node)
                if cold_count > 0 {
                    let outlined = anp_outline_cold(node)
                    let mut oi = 0
                    while oi < len(outlined) {
                        out = out.push(outlined[oi])
                        oi = oi + 1
                    }
                } else {
                    out = out.push(node)
                }
            }
        } else {
            out = out.push(node)
        }
        i = i + 1
    }
    if m978_cold_outlined > 0 {
        println("[ai-native] @cold split: " + to_string(m978_cold_detected) + " fn(s), " + to_string(m978_cold_outlined) + " block(s) outlined, " + to_string(m978_cold_blocks) + " cold branch(es)")
    }
    return out
}

// ═══════════════════════════════════════════════════════════
//  Helper: build AST nodes
// ═══════════════════════════════════════════════════════════

fn mk_ident(name) {
    return AstNode {
        kind: "Ident", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_int(v) {
    return AstNode {
        kind: "IntLit", name: "", value: to_string(v), op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_call(callee_name, args) {
    return AstNode {
        kind: "Call", name: "", value: "", op: "",
        left: mk_ident(callee_name), right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: args, fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_expr_stmt(expr) {
    return AstNode {
        kind: "ExprStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_return_stmt(expr) {
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_let_stmt(name, expr) {
    return AstNode {
        kind: "LetStmt", name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_if(cond_node, then_body, else_body) {
    return AstNode {
        kind: "IfStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond_node, then_body: then_body, else_body: else_body,
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_while(cond_node, wbody) {
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond_node, then_body: "", else_body: "",
        params: "", body: wbody, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_fn(name, attrs, params, fbody) {
    return AstNode {
        kind: "FnDecl", name: name, value: attrs, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: params, body: fbody, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_param(name) {
    return AstNode {
        kind: "Param", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_binop(op, left, right) {
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: left, right: right, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ═══════════════════════════════════════════════════════════
//  SECTION 1: is_cold_call_expr detection
// ═══════════════════════════════════════════════════════════
println("--- Section 1: is_cold_call_expr ---")

let panic_call = mk_call("panic", [mk_ident("msg")])
check("T01 panic is cold call", is_cold_call_expr(panic_call))

let throw_call = mk_call("throw", [mk_ident("err")])
check("T02 throw is cold call", is_cold_call_expr(throw_call))

let abort_call = mk_call("abort", [])
check("T03 abort is cold call", is_cold_call_expr(abort_call))

let exit_call = mk_call("exit", [mk_int(1)])
check("T04 exit is cold call", is_cold_call_expr(exit_call))

let hthrow_call = mk_call("hexa_throw", [mk_ident("e")])
check("T05 hexa_throw is cold call", is_cold_call_expr(hthrow_call))

let normal_call = mk_call("compute", [mk_int(42)])
check("T06 compute is not cold call", !is_cold_call_expr(normal_call))

check("T07 string is not cold call", !is_cold_call_expr("hello"))

// ═══════════════════════════════════════════════════════════
//  SECTION 2: is_cold_stmt detection
// ═══════════════════════════════════════════════════════════
println("")
println("--- Section 2: is_cold_stmt ---")

let panic_stmt = mk_expr_stmt(mk_call("panic", [mk_ident("x")]))
check("T08 ExprStmt(panic) is cold stmt", is_cold_stmt(panic_stmt))

let throw_ret = mk_return_stmt(mk_call("throw", [mk_ident("e")]))
check("T09 ReturnStmt(throw) is cold stmt", is_cold_stmt(throw_ret))

let normal_ret = mk_return_stmt(mk_int(42))
check("T10 return 42 is not cold stmt", !is_cold_stmt(normal_ret))

let let_stmt = mk_let_stmt("x", mk_int(10))
check("T11 let stmt is not cold stmt", !is_cold_stmt(let_stmt))

// ═══════════════════════════════════════════════════════════
//  SECTION 3: body_has_cold_pattern
// ═══════════════════════════════════════════════════════════
println("")
println("--- Section 3: body_has_cold_pattern ---")

let cold_body = [mk_expr_stmt(mk_call("println", [mk_ident("err")])), mk_expr_stmt(mk_call("panic", [mk_ident("msg")]))]
check("T12 body with panic has cold pattern", body_has_cold_pattern(cold_body))

let hot_body = [mk_let_stmt("x", mk_int(1)), mk_return_stmt(mk_ident("x"))]
check("T13 body without panic has no cold pattern", !body_has_cold_pattern(hot_body))

check("T14 empty body has no cold pattern", !body_has_cold_pattern([]))

check("T15 non-array has no cold pattern", !body_has_cold_pattern("not array"))

// ═══════════════════════════════════════════════════════════
//  SECTION 4: count_cold_branches
// ═══════════════════════════════════════════════════════════
println("")
println("--- Section 4: count_cold_branches ---")

let if_panic_then = mk_if(mk_ident("err"), [mk_expr_stmt(mk_call("panic", [mk_ident("msg")]))], [mk_return_stmt(mk_int(0))])
check("T16 if(panic in then) = 1 cold branch", count_cold_branches([if_panic_then]) == 1)

let if_panic_else = mk_if(mk_ident("ok"), [mk_return_stmt(mk_int(1))], [mk_expr_stmt(mk_call("panic", [mk_ident("err")]))])
check("T17 if(panic in else) = 1 cold branch", count_cold_branches([if_panic_else]) == 1)

let if_panic_both = mk_if(mk_ident("x"), [mk_expr_stmt(mk_call("panic", [mk_ident("a")]))], [mk_expr_stmt(mk_call("throw", [mk_ident("b")]))])
check("T18 if(panic in both) = 2 cold branches", count_cold_branches([if_panic_both]) == 2)

check("T19 no if = 0 cold branches", count_cold_branches(hot_body) == 0)

let inner_if = mk_if(mk_ident("deep"), [mk_expr_stmt(mk_call("abort", []))], [mk_return_stmt(mk_int(0))])
let outer_if = mk_if(mk_ident("top"), [inner_if, mk_return_stmt(mk_int(1))], [mk_return_stmt(mk_int(2))])
check("T20 nested if cold counted", count_cold_branches([outer_if]) >= 1)

// ═══════════════════════════════════════════════════════════
//  SECTION 5: anp_detect_cold_path
// ═══════════════════════════════════════════════════════════
println("")
println("--- Section 5: anp_detect_cold_path ---")

let fn_with_cold = mk_fn("process", "", [mk_param("x")], [if_panic_then, mk_return_stmt(mk_int(0))])
m978_cold_detected = 0
m978_cold_blocks = 0
let d1 = anp_detect_cold_path(fn_with_cold)
check("T21 detect cold in fn = 1", d1 == 1)

let fn_no_cold = mk_fn("compute", "", [mk_param("n")], [mk_return_stmt(mk_binop("+", mk_ident("n"), mk_int(1)))])
m978_cold_detected = 0
let d2 = anp_detect_cold_path(fn_no_cold)
check("T22 detect no cold in fn = 0", d2 == 0)

check("T23 string input = 0", anp_detect_cold_path("not a node") == 0)

let fn_empty = mk_fn("empty", "", [], [])
check("T24 empty body fn = 0", anp_detect_cold_path(fn_empty) == 0)

// ═══════════════════════════════════════════════════════════
//  SECTION 6: make_cold_fn_name
// ═══════════════════════════════════════════════════════════
println("")
println("--- Section 6: make_cold_fn_name ---")

check("T25 cold fn name idx 0", make_cold_fn_name("process", 0) == "process__cold_0")
check("T26 cold fn name idx 3", make_cold_fn_name("validate", 3) == "validate__cold_3")

// ═══════════════════════════════════════════════════════════
//  SECTION 7: anp_outline_cold
// ═══════════════════════════════════════════════════════════
println("")
println("--- Section 7: anp_outline_cold ---")

m978_cold_outlined = 0
let out_no_cold = anp_outline_cold(fn_no_cold)
check("T27 no cold = 1 node returned", len(out_no_cold) == 1)
check("T28 no cold = same fn", out_no_cold[0].name == "compute")

m978_cold_outlined = 0
let fn_cold_then = mk_fn("validate", "", [mk_param("x")], [
    mk_if(mk_ident("err"), [mk_expr_stmt(mk_call("panic", [mk_ident("msg")]))], [mk_return_stmt(mk_int(1))]),
    mk_return_stmt(mk_int(0))
])
let out_cold = anp_outline_cold(fn_cold_then)
check("T29 cold then outlined", len(out_cold) > 1)
check("T30 outlined fn is FnDecl", out_cold[0].kind == "FnDecl")
check("T31 outlined fn name", out_cold[0].name == "validate__cold_0")
check("T32 outlined fn has cold attr", out_cold[0].value == "cold")

let last_node = out_cold[len(out_cold) - 1]
check("T33 last node is parent fn", last_node.name == "validate")
check("T34 m978_cold_outlined > 0", m978_cold_outlined > 0)

// ═══════════════════════════════════════════════════════════
//  SECTION 8: anp_cold_split_pass — full AST pass
// ═══════════════════════════════════════════════════════════
println("")
println("--- Section 8: anp_cold_split_pass ---")

let ast_mixed = [
    fn_no_cold,
    fn_cold_then,
    mk_fn("helper", "", [], [mk_return_stmt(mk_int(99))])
]
let result_ast = anp_cold_split_pass(ast_mixed)
check("T35 pass returns array", type_of(result_ast) == "array")
check("T36 pass output > input", len(result_ast) > len(ast_mixed))
check("T37 m978_cold_detected > 0", m978_cold_detected > 0)
check("T38 m978_cold_outlined > 0", m978_cold_outlined > 0)
check("T39 m978_cold_blocks > 0", m978_cold_blocks > 0)

let mut found_compute = false
let mut found_helper = false
let mut ri = 0
while ri < len(result_ast) {
    if type_of(result_ast[ri]) != "string" && result_ast[ri].kind == "FnDecl" {
        if result_ast[ri].name == "compute" { found_compute = true }
        if result_ast[ri].name == "helper" { found_helper = true }
    }
    ri = ri + 1
}
check("T40 compute passes through", found_compute)
check("T41 helper passes through", found_helper)

// T42: @cold fn is not split
let cold_fn = mk_fn("error_handler", "cold", [], [mk_expr_stmt(mk_call("panic", [mk_ident("fatal")]))])
let ast_cold_fn = [cold_fn]
let result_cold = anp_cold_split_pass(ast_cold_fn)
check("T42 @cold fn not split", len(result_cold) == 1)
check("T43 @cold fn name preserved", result_cold[0].name == "error_handler")

// ═══════════════════════════════════════════════════════════
//  SECTION 9: Edge cases
// ═══════════════════════════════════════════════════════════
println("")
println("--- Section 9: Edge cases ---")

let result_nonarr = anp_cold_split_pass("not an array")
check("T44 non-array input returns as-is", result_nonarr == "not an array")

// Multiple cold branches in one fn
let fn_multi_cold = mk_fn("multi", "", [mk_param("a"), mk_param("b")], [
    mk_if(mk_ident("a"), [mk_expr_stmt(mk_call("panic", [mk_ident("err1")]))], [mk_return_stmt(mk_int(1))]),
    mk_if(mk_ident("b"), [mk_expr_stmt(mk_call("throw", [mk_ident("err2")]))], [mk_return_stmt(mk_int(2))]),
    mk_return_stmt(mk_int(0))
])
m978_cold_outlined = 0
let out_multi = anp_outline_cold(fn_multi_cold)
check("T45 multi cold = 3 nodes", len(out_multi) == 3)
check("T46 first outlined name", out_multi[0].name == "multi__cold_0")
check("T47 second outlined name", out_multi[1].name == "multi__cold_1")

// Cold in while loop body
let while_cold = mk_while(mk_ident("running"), [
    mk_if(mk_ident("fail"), [mk_expr_stmt(mk_call("abort", []))], [mk_return_stmt(mk_int(0))])
])
let fn_while_cold = mk_fn("loop_fn", "", [mk_param("running")], [while_cold, mk_return_stmt(mk_int(1))])
m978_cold_detected = 0
let d_while = anp_detect_cold_path(fn_while_cold)
check("T48 cold in while detected", d_while > 0)

// Cold in else branch
let fn_cold_else = mk_fn("check_val", "", [mk_param("v")], [
    mk_if(mk_binop(">", mk_ident("v"), mk_int(0)), [mk_return_stmt(mk_ident("v"))], [mk_expr_stmt(mk_call("panic", [mk_ident("negative")]))]),
    mk_return_stmt(mk_int(0))
])
m978_cold_outlined = 0
let out_else = anp_outline_cold(fn_cold_else)
check("T49 cold else outlined", len(out_else) > 1)
check("T50 cold else fn name", out_else[0].name == "check_val__cold_0")

// Outlined fn gets same params
let fn_with_params = mk_fn("proc", "", [mk_param("a"), mk_param("b"), mk_param("c")], [
    mk_if(mk_ident("err"), [mk_expr_stmt(mk_call("panic", [mk_ident("msg")]))], [mk_return_stmt(mk_int(0))]),
    mk_return_stmt(mk_int(1))
])
m978_cold_outlined = 0
let out_params = anp_outline_cold(fn_with_params)
check("T51 outlined fn has params", type_of(out_params[0].params) == "array")
check("T52 outlined fn params count = 3", len(out_params[0].params) == 3)

// ═══════════════════════════════════════════════════════════
//  SECTION 10: Various cold patterns
// ═══════════════════════════════════════════════════════════
println("")
println("--- Section 10: Various cold patterns ---")

let exit_body = [mk_expr_stmt(mk_call("exit", [mk_int(1)]))]
check("T53 exit() detected as cold", body_has_cold_pattern(exit_body))

let hthrow_body = [mk_expr_stmt(mk_call("hexa_throw", [mk_ident("e")]))]
check("T54 hexa_throw detected as cold", body_has_cold_pattern(hthrow_body))

let ret_panic_body = [mk_return_stmt(mk_call("panic", [mk_ident("fatal")]))]
check("T55 return panic() detected as cold", body_has_cold_pattern(ret_panic_body))

let println_body = [mk_expr_stmt(mk_call("println", [mk_ident("msg")]))]
check("T56 println is not cold", !body_has_cold_pattern(println_body))

// ═══════════════════════════════════════════════════════════
//  Summary
// ═══════════════════════════════════════════════════════════
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("  Total:  " + to_string(pass_count + fail_count) + " tests")
println("═══════════════════════════════════════════════════════")
