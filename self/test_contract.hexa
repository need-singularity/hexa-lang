// test_contract.hexa — @contract semantics end-to-end (ROI #150)
//
// 4 cases:
//   1) PASS         — pre+post hold (런타임 통과)
//   2) PRE-FAIL     — pre-assertion 위반 → try/catch 로 감지
//   3) POST-FAIL    — post-assertion 위반 → try/catch 로 감지
//   4) BOUNDS-ELIM  — pre=`i < arr.len()` 선언된 fn 에서 arr[i] 정상 동작
//                     (=codegen bounds-elim 후보. static hint 는
//                      self/attrs/_own/contract.contract_bounds_elim_hint 제공)
//
// interp runtime 은 `use` 를 script-mode 에서 지원하지 않아,
// hint 검증은 test 파일에 동일 패턴 매칭을 로컬 재구현.

let mut passed = 0
let mut failed = 0

fn note(name: string, ok: bool) {
    if ok {
        passed = passed + 1
        println("PASS " + name)
    } else {
        failed = failed + 1
        println("FAIL " + name)
    }
}

// ── Case 1: PASS ─────────────────────────────────────────────────
@contract(requires: x > 0, ensures: result > x)
fn inc_pos(x) {
    return x + 1
}
note("1 pre+post pass (inc_pos(10)==11)", inc_pos(10) == 11)

// ── Case 2: PRE-FAIL ────────────────────────────────────────────
@contract(requires: x > 0)
fn inc_req(x) {
    return x + 1
}
let mut pre_caught = false
try {
    inc_req(-1)
} catch e {
    pre_caught = true
}
note("2 pre-fail caught (inc_req(-1))", pre_caught)

// ── Case 3: POST-FAIL ───────────────────────────────────────────
@contract(ensures: result > 0)
fn inc_ens(x) {
    return x + 1
}
let mut post_caught = false
try {
    inc_ens(-10)
} catch e {
    post_caught = true
}
note("3 post-fail caught (inc_ens(-10))", post_caught)

// ── Case 4: BOUNDS-ELIM ─────────────────────────────────────────
// contract_bounds_elim_hint 의 로컬 재구현 (interp use 미지원 대비)
fn _is_simple(s) {
    let n = len(s)
    if n == 0 { return false }
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        let ch = char_code(c, 0)
        let a = (ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || ch == 95
        let d = ch >= 48 && ch <= 57
        if i == 0 {
            if !a { return false }
        } else {
            if !a && !d { return false }
        }
        i = i + 1
    }
    return true
}

fn bounds_elim_eligible(expr) {
    let e = expr.trim()
    let lt = e.index_of("<")
    if lt <= 0 { return false }
    let lhs = e.substring(0, lt).trim()
    let rhs = e.substring(lt + 1, len(e)).trim()
    // ARR.len()
    let dot = rhs.index_of(".len()")
    if dot > 0 {
        let arr = rhs.substring(0, dot).trim()
        if _is_simple(lhs) && _is_simple(arr) { return true }
    }
    // len(ARR)
    if rhs.starts_with("len(") && rhs.ends_with(")") {
        let inner = rhs.substring(4, len(rhs) - 1).trim()
        if _is_simple(lhs) && _is_simple(inner) { return true }
    }
    return false
}

// (a) 정적 패턴 매칭
let ok_a = bounds_elim_eligible("i < arr.len()")
let ok_b = bounds_elim_eligible("i < len(arr)")
let no_a = bounds_elim_eligible("x > 0")       // not a bounds expr
let no_b = bounds_elim_eligible("i + 1 < n")   // lhs not simple ident

// (b) @contract(pre=...) 선언된 fn 이 실제로도 안전 동작
@contract(requires: i < arr_len, ensures: result == 0)
fn first_zero(i, arr_len) {
    if i < arr_len { return 0 }
    return 0
}
let runtime_ok = first_zero(0, 3) == 0

let all_ok = ok_a && ok_b && !no_a && !no_b && runtime_ok
note("4 bounds-elim (hint+runtime)", all_ok)

// ── Summary ──────────────────────────────────────────────────────
println("")
println("contract-semantics: " + to_string(passed) + " passed, " + to_string(failed) + " failed")
if failed == 0 {
    println("ALL 4 @contract TESTS PASSED")
} else {
    println("SOME @contract TESTS FAILED")
}
