// test_contract.hexa — @contract semantics end-to-end tests
// Tests: requires precondition, ensures postcondition, result binding, branching

// ── Test 1: requires — happy path ────────────────────────
@contract(requires: x > 0)
fn inc_req(x) {
  return x + 1
}
assert inc_req(5) == 6
println("PASS 1: requires happy")

// ── Test 2: requires — violation caught ──────────────────
let mut req_caught = false
try {
  inc_req(-1)
} catch e {
  req_caught = true
}
assert req_caught
println("PASS 2: requires violation caught")

// ── Test 3: ensures — happy path ─────────────────────────
@contract(ensures: result > 0)
fn inc_ens(x) {
  return x + 1
}
assert inc_ens(5) == 6
println("PASS 3: ensures happy")

// ── Test 4: ensures — violation caught ───────────────────
let mut ens_caught = false
try {
  inc_ens(-10)
} catch e {
  ens_caught = true
}
assert ens_caught
println("PASS 4: ensures violation caught")

// ── Test 5: requires + ensures combined ──────────────────
@contract(requires: x > 0, ensures: result > x)
fn inc_both(x) {
  return x + 1
}
assert inc_both(10) == 11
println("PASS 5: requires+ensures combined")

// ── Test 6: ensures catches early return in if branch ────
@contract(ensures: result > 0)
fn guarded(x) {
  if x > 100 {
    return -1
  }
  return x + 1
}
assert guarded(5) == 6
println("PASS 6: ensures early-return happy")

let mut branch_caught = false
try {
  guarded(200)
} catch e {
  branch_caught = true
}
assert branch_caught
println("PASS 7: ensures early-return violation caught")

// ── Test 8: requires with complex expression ─────────────
@contract(requires: x > 0 && x < 100)
fn bounded(x) {
  return x * 2
}
assert bounded(50) == 100
println("PASS 8: complex requires happy")

let mut complex_caught = false
try {
  bounded(200)
} catch e {
  complex_caught = true
}
assert complex_caught
println("PASS 9: complex requires violation caught")

// ── Test 10: ensures with result referencing params ──────
@contract(ensures: result >= x * 2)
fn double_plus(x) {
  return x * 2 + 1
}
assert double_plus(5) == 11
println("PASS 10: ensures with param reference")

// ── Test 11: requires with boundary value ───────────────
@contract(requires: x >= 0)
fn abs_val(x) {
  if x < 0 { return -x }
  return x
}
assert abs_val(0) == 0
assert abs_val(5) == 5
println("PASS 11: requires boundary (x >= 0)")

// ── Test 12: ensures with multiple return paths ─────────
@contract(ensures: result >= 0)
fn safe_sub(x, y) {
  if x > y {
    return x - y
  }
  return 0
}
assert safe_sub(10, 3) == 7
assert safe_sub(3, 10) == 0
println("PASS 12: ensures multi-return")

// ── Test 13: requires + ensures with narrower contract ──
@contract(requires: x > 0, ensures: result > 1)
fn double_pos(x) {
  return x * 2
}
assert double_pos(1) == 2
assert double_pos(5) == 10
println("PASS 13: narrow contract")

let mut narrow_caught = false
try {
  double_pos(0)
} catch e {
  narrow_caught = true
}
assert narrow_caught
println("PASS 14: narrow contract violation caught")

// ── Test 15: contract error message contains clause text ─
let mut err_msg = ""
try {
  inc_req(-5)
} catch e {
  err_msg = to_string(e)
}
assert contains(err_msg, "contract violation") || contains(err_msg, "ContractViolation")
println("PASS 15: error message format")

println("")
println("ALL 15 @contract TESTS PASSED")
