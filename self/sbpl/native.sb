;; self/sbpl/native.sb — macOS sandbox profile for hexa-only tree.
;; Blocks file-write on .py / .rs / .sh / .toml extensions at the kernel
;; level. Claude Code (or any process) launched via
;;   sandbox-exec -f self/sbpl/native.sb <cmd>
;; gets EPERM on Write/Edit to banned suffixes — no hook, no userspace
;; guard, no race window.
;;
;; Scope: raw#8 (.py/.rs/.sh/.toml foreign-ext ban) covers ALL of
;; $WS (/Users/ghost/core/**). In-repo allowlist carve-outs are removed
;; (no bench/rust_baseline/, tool/emergency/, self/native/, or
;; scripts/safe_hexa_launchd.sh escape hatches).
;;
;; Write-allowed escape hatch (external to $WS):
;;   /tmp/hexa-work/        — sole scratch tree for temporary foreign-ext
;;                            files; outputs must be explicitly promoted
;;                            back into $WS as .hexa sources.
;;
;; Internal-scratch exceptions (for tool pipelines, not user code):
;;   /.hexa-cache/ /.claude-cache/ /.git/ /.hx/
;;   /tmp, /private/tmp, /var/folders (separate subpath allow block).
;;
;; SSOT: airgenome/rules/airgenome.json#AG10 + self/attrs/native.hexa.
;; Pairs with tool/foreign_ext_sweep.hexa (post-hoc rm fallback).
;;
;; Note: sandbox-exec is deprecated by Apple but still functional on all
;; current macOS versions (through Sequoia). When it stops working we
;; move to EndpointSecurity (entitlement required, separate spike).

(version 1)

;; Baseline — allow everything the wrapped process would normally do.
(allow default)

;; Deny writes to any path ending in a banned foreign extension.
;; `file-write*` covers create, truncate, append, rename-into, symlink-at.
(deny file-write*
  (regex #"\.py$")
  (regex #"\.rs$")
  (regex #"\.sh$")
  (regex #"\.toml$"))

;; Exceptions (later rules override earlier in SBPL). In-repo allowlist
;; carve-outs are stripped — raw#8 now covers all of $WS with the sole
;; write-allowed external escape hatch being /tmp/hexa-work/. Internal
;; scratch caches remain permitted so tool pipelines keep working.
;;
;; 2026-04-23 @convergence sandbox-test-hexa-false-positive:
;;   raw#8 F3 regex `test_[^/]+\.hexa$` was catching legit test suites
;;   under hexa-lang/tool/test_*.hexa (4 files: project_parser, sealed,
;;   roadmap_lint, readme_attr), blocking every write from the sandboxed
;;   Claude Code session. User could sed from a terminal (no sandbox),
;;   session could not. Carve-out below re-allows writes to real test
;;   harnesses that live under */tool/ or */test/ directories — the
;;   F3 intent ("scratch files outside test/ dirs") is preserved,
;;   the unintentional side-effect on real test suites is lifted.
(allow file-write*
  (subpath "/tmp/hexa-work")
  (regex #"/\.hexa-cache/")
  (regex #"/\.claude-cache/")
  (regex #"/\.git/")
  (regex #"/\.hx/")
  (regex #"/tool/test_[^/]+\.hexa$")   ; legit tool/ test harnesses
  (regex #"/test/test_[^/]+\.hexa$")   ; legit test/ test harnesses
  (regex #"/tests/test_[^/]+\.hexa$")) ; legit tests/ test harnesses

;; Writes under /tmp, /private/tmp, and user-level caches are always allowed —
;; tooling (hexa AOT cache, jq tmp files, drill logs, etc.) needs free access
;; there regardless of extension.
(allow file-write*
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath "/var/folders"))

;; raw#8 — file-name taxonomy (F1 version, F2 stage/phase, F3 temp, + no-backup absorbed from raw#34)
(deny file-write*
  (regex #"_v[0-9]+\.")             ; F1: _v2.xxx, _v10.xxx
  (regex #"_mk[0-9]+\.")            ; F1: _mk3.xxx
  (regex #"_new\.")                 ; F1: *_new.*
  (regex #"_copy\.")                ; F1: *_copy.*
  (regex #"_old\.")                 ; F1
  (regex #"_backup\.")              ; F1 (redundant but explicit)
  (regex #"_phase[0-9]+\.")         ; F2: _phase3.xxx
  (regex #"_stage[0-9]+\.")         ; F2
  (regex #"_Phase[0-9]+\.")         ; F2 capitalized
  (regex #"^/[^/]+/[^/]+/TMP-")     ; F3: TMP- prefix (in any project root)
  (regex #"TIMESTAMP-")             ; F3
  (regex #"test_[^/]+\.hexa$")      ; F3: test_xxx.hexa scratch files (outside test/ dirs)
  (regex #"\.bak$")                 ; no-backup
  (regex #"\.bak\.")                ; no-backup with dot-suffix (.bak.20260101)
  (regex #"-backup")                ; -backup / -backup-xxx
  (regex #"\.legacy-")              ; .legacy-xxx
  (regex #"\.orig$")                ; .orig
  (regex #"\.pre-"))                ; .pre-xxx

;; raw#13 — ai + git hook automation config ban
;; raw#13 expansion 2026-04-22 — per-repo .claude/settings*.json + agents/ + commands/ 추가 (AG10 purge 후 project-local 금지 확정).
(deny file-write*
  (regex #"/\.github/workflows/")
  (regex #"/\.githooks/")
  (regex #"/\.husky/")
  (regex #"/husky\.config\.")
  (regex #"/\.pre-commit-config\.ya?ml$")
  (regex #"/lefthook\.ya?ml$")
  (regex #"/\.cursorrules$")
  (regex #"/\.continue/")
  (regex #"/\.aider\.conf\.ya?ml$")
  (regex #"/\.windsurfrules$")
  (regex #"/CLAUDE\.md$")            ; per-repo CLAUDE.md
  (regex #"/\.claude/hooks/")
  (regex #"/\.claude/skills/")
  (regex #"/\.claude/settings\.json$")        ; per-repo Claude Code settings
  (regex #"/\.claude/settings\.local\.json$") ; per-repo local override
  (regex #"/\.claude/agents/")                ; per-repo sub-agent 정의
  (regex #"/\.claude/commands/"))             ; per-repo slash command 정의

;; raw#21 — deprecated-symlink-ban (SBPL uses `file-link` on macOS for
;; symlink/hardlink creation; `file-link*` is not defined by this kernel).
(deny file-link)
(allow file-link
  (subpath "/archive/deprecated")
  (regex #"/archive/deprecated/")
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath "/var/folders"))

;; raw#6 — folder-name F4 (banned basenames: utils/helpers/common/lib/misc/stuff/base).
;; Hive-only initial deployment 2026-04-25 (other repos still pending raw_6.list
;; expansion to cover their existing in-tree lib/ etc. directories).
;; Allowlist exempts node_modules (npm tree), packages/ (TS upstream fork),
;; infrastructure/, libs/, archive/ — same as the F4 scanner exemptions.
(deny file-write*
  (regex #"^/Users/[^/]+/core/hive/(.+/)?utils/")
  (regex #"^/Users/[^/]+/core/hive/(.+/)?helpers/")
  (regex #"^/Users/[^/]+/core/hive/(.+/)?common/")
  (regex #"^/Users/[^/]+/core/hive/(.+/)?lib/")
  (regex #"^/Users/[^/]+/core/hive/(.+/)?misc/")
  (regex #"^/Users/[^/]+/core/hive/(.+/)?stuff/")
  (regex #"^/Users/[^/]+/core/hive/(.+/)?base/"))
(allow file-write*
  (regex #"/node_modules/")
  (regex #"^/Users/[^/]+/core/hive/packages/")
  (regex #"^/Users/[^/]+/core/hive/infrastructure/")
  (regex #"^/Users/[^/]+/core/hive/libs/"))

;; raw#7 — tree-structure F5 (loner-dir) + F6 (parent-child duplication).
;;
;;   enforce-layer:           hive-agent (lint advisory)
;;   enforce-layer-secondary: — (no os-level layer available on macOS today)
;;   enforce-layer-rationale: SBPL kernel regex lacks dir-introspection (F5
;;     needs sibling-count, regex sees only the path string) and silently
;;     fail-opens on backreference patterns (F6 needs `<dir>/<dir>` literal
;;     repeat — smoke-tested 2026-04-26 via /tmp probe, backref deny did not
;;     block writes; all 3 fixture writes succeeded).
;;
;; STATUS: lint-only enforcement is FORMAL (not provisional). Until one of
;; the promotion paths below ships, raw#7 lives at enforce-layer hive-agent
;; and is treated as advisory by the OS layer.
;;
;; CANONICAL ENFORCEMENT SURFACE (mac+linux today):
;;   tool/ai_native_scan.hexa — F5/F6 scanners + --selftest contract +
;;   schema hexa.tree_structure_lint.v1 + AI-native trailers per raw#66.
;;
;; PROMOTION ROADMAP (in priority order):
;;   (C-linux)  self/native/native_gate.c hybrid — Linux LD_PRELOAD shim
;;              gains refuse_raw7_loner_dir() (stat parent dir, count
;;              dirent siblings on first-write) and refuse_raw7_parent_child_stem()
;;              (string-compare path components). macOS stays at lint-only
;;              until one of the macOS paths below lands. This is the next
;;              concrete promotion target — see TODO blocks in
;;              self/native/native_gate.c.
;;   (B)        Generated raw_7.list of concrete `<basename>/<basename>` pairs
;;              (parallel to raw_6.list mechanism). Inline as path-by-path
;;              SBPL deny rules. Over-time maintenance burden — only viable
;;              as a short-term bridge if specific repeat-offender pairs
;;              dominate violation reports.
;;   (D-mac)    EndpointSecurity migration — entitlement-required spike.
;;              Once we move off sandbox-exec (Apple-deprecated), ES has
;;              full FS introspection and can implement F5+F6 directly.
;;
;; SSOT for the lint complement: `/Users/ghost/core/hive/.raw:109-117`
;; raw#7 enforce field + tool/ai_native_scan.hexa.

;; raw#13/8 allow-exceptions — user-global tool configs + archive paths.
;; Regex is anchored to ^/Users/<one-segment>/.claude/ so the per-repo
;; /Users/ghost/core/<project>/.claude/ path stays denied (matches
;; native_gate.c::is_user_global_claude). Previous unanchored /\.claude/
;; allow was a bypass bug — Apr 22 settings.local.json writes leaked through.
(allow file-write*
  (regex #"^/Users/[^/]+/\.claude/")   ; user-global ~/.claude/ only (raw#13 exception)
  (regex #"^/Users/[^/]+/\.cursor/")   ; user-global ~/.cursor/ only
  (regex #"/archive/"))                ; archive/ paths allowed everywhere
