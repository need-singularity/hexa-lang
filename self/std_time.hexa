// self/std_time.hexa — HEXA TIME ported from src/std_time.rs
//
// Provides:
//   time_now()             — current unix timestamp (seconds)
//   time_now_ms()          — current unix timestamp (milliseconds)
//   time_sleep(ms)         — sleep for N milliseconds
//   time_format(ts, fmt)   — format timestamp as string
//   time_parse(s, fmt)     — parse string to timestamp
//   time_elapsed(start)    — milliseconds elapsed since start timestamp

fn time_now() -> int {
    return __builtin_time_now()
}

fn time_now_ms() -> int {
    return __builtin_time_now_ms()
}

fn time_sleep(ms) {
    __builtin_time_sleep(ms)
}

// -- Date parts --

struct DateParts {
    year: int,
    month: int,
    day: int,
    hour: int,
    minute: int,
    second: int
}

fn is_leap(year) -> bool {
    if year % 400 == 0 { return true }
    if year % 100 == 0 { return false }
    if year % 4 == 0 { return true }
    return false
}

fn timestamp_to_parts(ts) -> DateParts {
    let total_secs = ts
    if total_secs < 0 { total_secs = 0 }
    let second = total_secs % 60
    let total_mins = total_secs / 60
    let minute = total_mins % 60
    let total_hours = total_mins / 60
    let hour = total_hours % 24
    let days = total_hours / 24

    let year = 1970
    while true {
        let days_in_year = 365
        if is_leap(year) { days_in_year = 366 }
        if days < days_in_year { break }
        days = days - days_in_year
        year = year + 1
    }

    let month_days = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    if is_leap(year) { month_days[1] = 29 }

    let month = 1
    let mi = 0
    while mi < 12 {
        if days < month_days[mi] {
            month = mi + 1
            break
        }
        days = days - month_days[mi]
        mi = mi + 1
    }
    if mi == 12 { month = 12 }
    let day = days + 1

    return DateParts {
        year: year,
        month: month,
        day: day,
        hour: hour,
        minute: minute,
        second: second
    }
}

fn parts_to_timestamp(year, month, day, hour, minute, second) -> int {
    let days = 0
    let y = 1970
    while y < year {
        if is_leap(y) { days = days + 366 } else { days = days + 365 }
        y = y + 1
    }

    let month_days = [31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    if is_leap(year) { month_days[1] = 29 }

    let m = 0
    while m < month - 1 {
        days = days + month_days[m]
        m = m + 1
    }
    days = days + day - 1

    return days * 86400 + hour * 3600 + minute * 60 + second
}

// -- Format timestamp --

fn pad2(n) -> string {
    if n < 10 { return "0" + to_string(n) }
    return to_string(n)
}

fn pad4(n) -> string {
    if n < 10 { return "000" + to_string(n) }
    if n < 100 { return "00" + to_string(n) }
    if n < 1000 { return "0" + to_string(n) }
    return to_string(n)
}

fn time_format(ts, fmt) -> string {
    let p = timestamp_to_parts(ts)
    let result = fmt
    result = string_replace(result, "%Y", pad4(p.year))
    result = string_replace(result, "%m", pad2(p.month))
    result = string_replace(result, "%d", pad2(p.day))
    result = string_replace(result, "%H", pad2(p.hour))
    result = string_replace(result, "%M", pad2(p.minute))
    result = string_replace(result, "%S", pad2(p.second))
    return result
}

// -- Parse timestamp --

fn time_parse(s, fmt) -> int {
    let year = 1970
    let month = 1
    let day = 1
    let hour = 0
    let minute = 0
    let second = 0

    let si = 0
    let fi = 0
    while fi < len(fmt) {
        if si >= len(s) { break }
        if fi + 1 < len(fmt) {
            if fmt[fi] == "%" {
                let token = fmt[fi + 1]
                fi = fi + 2
                if token == "Y" {
                    let parsed = parse_digits(s, si, 4)
                    year = parsed[0]; si = si + parsed[1]
                }
                if token == "m" {
                    let parsed = parse_digits(s, si, 2)
                    month = parsed[0]; si = si + parsed[1]
                }
                if token == "d" {
                    let parsed = parse_digits(s, si, 2)
                    day = parsed[0]; si = si + parsed[1]
                }
                if token == "H" {
                    let parsed = parse_digits(s, si, 2)
                    hour = parsed[0]; si = si + parsed[1]
                }
                if token == "M" {
                    let parsed = parse_digits(s, si, 2)
                    minute = parsed[0]; si = si + parsed[1]
                }
                if token == "S" {
                    let parsed = parse_digits(s, si, 2)
                    second = parsed[0]; si = si + parsed[1]
                }
                continue
            }
        }
        fi = fi + 1
        si = si + 1
    }
    return parts_to_timestamp(year, month, day, hour, minute, second)
}

fn parse_digits(s, start, max_len) -> [int] {
    let val = 0
    let count = 0
    let i = 0
    while i < max_len {
        if start + i >= len(s) { break }
        let ch = s[start + i]
        if ch >= "0" {
            if ch <= "9" {
                val = val * 10 + (ord(ch) - ord("0"))
                count = count + 1
                i = i + 1
                continue
            }
        }
        break
    }
    return [val, count]
}

// -- Elapsed --

fn time_elapsed(start_ms) -> int {
    return time_now_ms() - start_ms
}
