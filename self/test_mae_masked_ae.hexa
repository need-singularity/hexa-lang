// ═══════════════════════════════════════════════════════════════
//  self/ml/mae_masked_ae.hexa — MAE Masked Autoencoder (#281)
//
//  He et al. 2021 Masked Autoencoder: patchify image → random-mask 75% →
//  encode *visible* patches → insert learnable mask tokens at dropped
//  positions → decode → reconstruct pixel patches → MSE.
//
//  CPU mini:
//    • 8×8 image, patch=4 → 4 patches (2×2 grid), each patch = 16 pixels
//    • 3 masked / 1 visible (75%)
//    • linear patch-embed to dim D = 8
//    • encoder: linear + GELU-lite (tanh approx) + linear
//    • decoder: linear back to 16 pixels per token
//
//  API:
//    mae_patchify(img, patch_size)              -> [[float]]  (N × P²)
//    mae_unpatchify(patches, H, W, patch_size)  -> [[float]]
//    mae_random_mask(N, mask_ratio, seed)       -> dict{ ids_keep, ids_mask, mask }
//    mae_init(embed_dim, patch_dim, seed)       -> dict
//    mae_forward(model, img, seed)              -> dict { "pred": [[f]], "mask": [f], "loss": f }
//    mae_reconstruction_loss(pred, target, mask)-> float   (MSE on masked)
//
//  @pure in all math helpers.
// ═══════════════════════════════════════════════════════════════

fn mae_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn mae_zeros(n) {
    let mut v = []
    let mut _i = 0
    while _i < n {
    return v
        _i = _i + 1
}

fn mae_zeros2d(m, n) {
    let mut w = []
    let mut _i = 0
    while _i < m {
    return w
        _i = _i + 1
}

fn mae_hash(seed, i, j) {
    let h = (seed * 2654435761 + i * 1315423911 + j * 731) % 10007
    return to_float(h) / 10007.0 - 0.5
}

fn mae_hash_u(seed, k) {
    let h = (seed * 7919 + k * 104729 + 31) % 10007
    return to_float(h) / 10007.0
}

// GELU approximation: 0.5 x (1 + tanh(√(2/π)(x + 0.044715 x³)))
fn mae_tanh(z) {
    let ez = exp(z)
    let enz = exp(0.0 - z)
    return (ez - enz) / (ez + enz)
}

fn mae_gelu(x) {
    let c = 0.7978845608
    let xc = x + 0.044715 * x * x * x
    return 0.5 * x * (1.0 + mae_tanh(c * xc))
}

// ─── (1) Patchify: an H×W image stored as [H][W] floats to
// a list of patches, each flattened to P² ──
fn mae_patchify(img, patch_size) {
    let H = len(img)
    let W = len(img[0])
    let gh = H / patch_size
    let gw = W / patch_size
    let N = gh * gw
    let P2 = patch_size * patch_size
    let mut patches = mae_zeros2d(N, P2)
    let mut pi = 0
    while pi < gh {
        for pj in 0..gw {
            let idx = pi * gw + pj
            for di in 0..patch_size {
                for dj in 0..patch_size {
                    let row = pi * patch_size + di
                    let col = pj * patch_size + dj
                    patches[idx][di * patch_size + dj] = img[row][col]
                }
            }
        }
        pi = pi + 1
    }
    return patches
}

// Inverse: list of patches → image
fn mae_unpatchify(patches, H, W, patch_size) {
    let gh = H / patch_size
    let gw = W / patch_size
    let mut img = mae_zeros2d(H, W)
    let mut pi = 0
    while pi < gh {
        for pj in 0..gw {
            let idx = pi * gw + pj
            for di in 0..patch_size {
                for dj in 0..patch_size {
                    img[pi * patch_size + di][pj * patch_size + dj] = patches[idx][di * patch_size + dj]
                }
            }
        }
        pi = pi + 1
    }
    return img
}

// ─── (2) random mask: keep ⌈(1-ratio)*N⌉ patches ──
fn mae_random_mask(N, mask_ratio, seed) {
    // pseudo-random shuffle via hash
    let mut order = []
    let mut keys = []
    let mut i = 0
    while i < N {
        order = order + [i]
        keys = keys + [mae_hash_u(seed, i)]
        i = i + 1
    }
    // simple insertion sort by keys (N small)
    let mut i = 1
    while i < N {
        let mut j = i
        while j > 0 {
            if keys[j] < keys[j - 1] {
                let tk = keys[j]; keys[j] = keys[j - 1]; keys[j - 1] = tk
                let to = order[j]; order[j] = order[j - 1]; order[j - 1] = to
                j = j - 1
            } else {
                j = 0
                break
            }
        }
        i = i + 1
    }
    let n_mask = N * 75 / 100
    let mut n_keep = N - n_mask
    if n_keep < 1 { n_keep = 1 }
    let mut ids_keep = []
    let mut ids_mask = []
    let mut i = 0
    while i < N {
        if i < n_keep {
            ids_keep = ids_keep + [order[i]]
        } else {
            ids_mask = ids_mask + [order[i]]
        }
        i = i + 1
    }
    // binary mask: 1 = masked (dropped, to reconstruct), 0 = visible
    let mut mask = mae_zeros(N)
    let n_m = len(ids_mask)
    let mut k = 0
    while k < n_m {
    let out = #{
        "ids_keep": ids_keep,
        "ids_mask": ids_mask,
        "mask": mask,
        "n_keep": n_keep,
        "n_mask": n_mask
    }
    return out
        k = k + 1
}

// ─── (3) model params ──
fn mae_init(embed_dim, patch_dim, seed) {
    // encoder: linear W_e [patch_dim → embed_dim]
    let mut W_e = mae_zeros2d(patch_dim, embed_dim)
    let mut i = 0
    while i < patch_dim {
        for j in 0..embed_dim {
            W_e[i][j] = 0.2 * mae_hash(seed, i, j)
        }
        i = i + 1
    }
    let b_e = mae_zeros(embed_dim)

    // encoder 2: [embed_dim → embed_dim]
    let mut W_e2 = mae_zeros2d(embed_dim, embed_dim)
    let mut i = 0
    while i < embed_dim {
        for j in 0..embed_dim {
            W_e2[i][j] = 0.2 * mae_hash(seed + 13, i, j)
        }
        i = i + 1
    }
    let b_e2 = mae_zeros(embed_dim)

    // decoder: [embed_dim → patch_dim]
    let mut W_d = mae_zeros2d(embed_dim, patch_dim)
    let mut i = 0
    while i < embed_dim {
        for j in 0..patch_dim {
            W_d[i][j] = 0.2 * mae_hash(seed + 27, i, j)
        }
        i = i + 1
    }
    let b_d = mae_zeros(patch_dim)

    // learnable mask token [embed_dim]
    let mut mask_token = mae_zeros(embed_dim)
    let mut i = 0
    while i < embed_dim {

    let model = #{
        "embed_dim": embed_dim,
        "patch_dim": patch_dim,
        "W_e": W_e,
        "b_e": b_e,
        "W_e2": W_e2,
        "b_e2": b_e2,
        "W_d": W_d,
        "b_d": b_d,
        "mask_token": mask_token
    }
    return model
        i = i + 1
}

// linear layer: y = W^T x + b
fn mae_linear(W, b, feat) {
    let din = len(W)
    let dout = len(W[0])
    let mut out = mae_zeros(dout)
    let mut j = 0
    while j < dout {
    for i in 0..din {
        for j in 0..dout {
            out[j] = out[j] + W[i][j] * feat[i]
        }
    }
    return out
        j = j + 1
}

fn mae_vec_gelu(feat) {
    let n = len(feat)
    let mut out = mae_zeros(n)
    let mut i = 0
    while i < n {
    return out
        i = i + 1
}

// ─── (4) encode a single patch ──
fn mae_encode_patch(model, patch) {
    let W_e = model["W_e"]
    let b_e = model["b_e"]
    let W_e2 = model["W_e2"]
    let b_e2 = model["b_e2"]
    let h1 = mae_linear(W_e, b_e, patch)
    let a1 = mae_vec_gelu(h1)
    let h2 = mae_linear(W_e2, b_e2, a1)
    return h2
}

// ─── (5) decode a single token ──
fn mae_decode_token(model, token) {
    let W_d = model["W_d"]
    let b_d = model["b_d"]
    return mae_linear(W_d, b_d, token)
}

// ─── (6) full forward pass: patchify → mask → encode visible →
// fill mask tokens → decode ──
fn mae_forward(model, img, seed) {
    let embed_dim = model["embed_dim"]
    let patch_size = 4
    let H = len(img)
    let W = len(img[0])
    let patches = mae_patchify(img, patch_size)
    let N = len(patches)
    let patch_dim = len(patches[0])

    let mask_info = mae_random_mask(N, 0.75, seed)
    let ids_keep = mask_info["ids_keep"]
    let ids_mask = mask_info["ids_mask"]
    let mask = mask_info["mask"]
    let n_keep = mask_info["n_keep"]

    // full sequence of tokens [N × embed_dim]
    let mut tokens = mae_zeros2d(N, embed_dim)
    let mask_token = model["mask_token"]
    // first, copy the mask token everywhere
    let mut i = 0
    while i < N {
        for k in 0..embed_dim { tokens[i][k] = mask_token[k] }
        i = i + 1
    }
    // then encode the visible patches and overwrite
    let mut ki = 0
    while ki < n_keep {
        let pidx = ids_keep[ki]
        let enc = mae_encode_patch(model, patches[pidx])
        for k in 0..embed_dim { tokens[pidx][k] = enc[k] }
        ki = ki + 1
    }

    // decode every token back to patch_dim
    let mut pred = mae_zeros2d(N, patch_dim)
    let mut i = 0
    while i < N {
        let rec = mae_decode_token(model, tokens[i])
        for k in 0..patch_dim { pred[i][k] = rec[k] }
        i = i + 1
    }

    // loss: MSE only on masked positions
    let loss = mae_reconstruction_loss(pred, patches, mask)

    let result = #{
        "pred": pred,
        "patches": patches,
        "mask": mask,
        "ids_keep": ids_keep,
        "ids_mask": ids_mask,
        "loss": loss,
        "N": N,
        "patch_dim": patch_dim
    }
    return result
}

// ─── (7) MSE on masked patches only, averaged over masked entries ──
fn mae_reconstruction_loss(pred, target, mask) {
    let N = len(pred)
    let P2 = len(pred[0])
    let mut s = 0.0
    let mut cnt = 0.0
    let mut i = 0
    while i < N {
        if mask[i] > 0.5 {
            for k in 0..P2 {
                let d = pred[i][k] - target[i][k]
                s = s + d * d
                cnt = cnt + 1.0
            }
        }
        i = i + 1
    }
    if cnt < 1.0 { return 0.0 }
    return s / cnt
}

// ─── (8) recon error over all patches (full image) ──
fn mae_total_error(pred, target) {
    let N = len(pred)
    let P2 = len(pred[0])
    let mut s = 0.0
    let mut i = 0
    while i < N {
        for k in 0..P2 {
            let d = pred[i][k] - target[i][k]
            s = s + d * d
        }
        i = i + 1
    }
    return s / to_float(N * P2)
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx(a, b, eps) {
    return fabs(a - b) < eps
}

println("═══════════════════════════════════════════════════════")
println("  MAE Masked Autoencoder (#281) Test Suite")
println("═══════════════════════════════════════════════════════")

// helper: build an 8x8 image with simple gradient
fn make_img() {
    let mut img = []
    let mut i = 0

    while i < 8 {
        let mut row = []
        let mut j = 0

        while j < 8 { row = row + [to_float(i * 8 + j) / 64.0] }
        img = img + [row]
    }
    return img
}

let img = make_img()

// ── Test 1: patchify shape ─
let patches = mae_patchify(img, 4)
check("4 patches total", len(patches) == 4)
check("patch dim 16", len(patches[0]) == 16)

// ── Test 2: unpatchify round trip ─
let restored = mae_unpatchify(patches, 8, 8, 4)
let mut rt_ok = true
let mut i = 0

while i < 8 {
    let mut j = 0

    while j < 8 {
        if fabs(restored[i][j] - img[i][j]) > 1.0e-10 { rt_ok = false }
    }
}
check("unpatchify round-trip", rt_ok)

// ── Test 3: specific patch values match corner of image ─
// patch[0] is top-left 4x4; img[0][0]=0.0, img[0][1]=1/64
check("patch[0][0] = img[0][0]", approx(patches[0][0], img[0][0], 1.0e-10))
check("patch[0][1] = img[0][1]", approx(patches[0][1], img[0][1], 1.0e-10))

// ── Test 4: random mask has correct counts ─
let minfo = mae_random_mask(4, 0.75, 42)
check("n_keep = 1", minfo["n_keep"] == 1)
let mask = minfo["mask"]
let mut masked_count = 0
let mut i = 0

while i < 4 {
    if mask[i] > 0.5 { masked_count = masked_count + 1 }
}
check("3 masked", masked_count == 3)
let ids_keep = minfo["ids_keep"]
check("ids_keep length 1", len(ids_keep) == 1)

// ── Test 5: model init shapes ─
let model = mae_init(8, 16, 42)
check("embed_dim = 8", model["embed_dim"] == 8)
check("patch_dim = 16", model["patch_dim"] == 16)
let W_e = model["W_e"]
check("W_e rows 16", len(W_e) == 16)
check("W_e cols 8", len(W_e[0]) == 8)
let W_d = model["W_d"]
check("W_d rows 8", len(W_d) == 8)
check("W_d cols 16", len(W_d[0]) == 16)
let mt = model["mask_token"]
check("mask_token length 8", len(mt) == 8)

// ── Test 6: encode → vector shape ─
let enc = mae_encode_patch(model, patches[0])
check("encoded dim 8", len(enc) == 8)

// ── Test 7: decode → patch_dim ─
let dec = mae_decode_token(model, enc)
check("decoded dim 16", len(dec) == 16)

// ── Test 8: forward pass ─
let out = mae_forward(model, img, 42)
let pred = out["pred"]
let loss = out["loss"]
check("pred N = 4", len(pred) == 4)
check("pred dim 16", len(pred[0]) == 16)
check("loss >= 0", loss >= 0.0)
check("loss finite", loss < 100.0)

// ── Test 9: deterministic: same seed → same loss ─
let out2 = mae_forward(model, img, 42)
check("deterministic loss", approx(out2["loss"], loss, 1.0e-12))

// ── Test 10: different seed → possibly different mask pattern ─
// check that ids_keep and ids_mask are disjoint partitions
let ids_mask = out["ids_mask"]
let ids_keep_out = out["ids_keep"]
check("ids_keep + ids_mask = N", len(ids_keep_out) + len(ids_mask) == 4)
let mut disjoint = true
let mut i = 0

while i < len(ids_keep_out) {
    let mut j = 0

    while j < len(ids_mask) {
        if ids_keep_out[i] == ids_mask[j] { disjoint = false }
    }
}
check("keep ∩ mask = ∅", disjoint)

// ── Test 11: mask applies only to dropped patches ─
let mask_out = out["mask"]
let mut mask_sum = 0
let mut i = 0

while i < 4 {
    if mask_out[i] > 0.5 { mask_sum = mask_sum + 1 }
}
check("mask covers 3 patches", mask_sum == 3)

// ── Test 12: reconstruction loss on zero diff = 0 ─
let loss_zero = mae_reconstruction_loss(patches, patches, mask_out)
check("loss(x,x) = 0", approx(loss_zero, 0.0, 1.0e-12))

// ── Test 13: reconstruction loss > 0 for different preds ─
let mut pred_bad = []
let mut i = 0

while i < 4 {
    let mut row = []
    let mut k = 0

    while k < 16 { row = row + [0.0] }
    pred_bad = pred_bad + [row]
}
let loss_bad = mae_reconstruction_loss(pred_bad, patches, mask_out)
check("bad pred positive loss", loss_bad > 0.0)

// ── Test 14: full-image total error ≥ masked loss (weak check) ─
let total = mae_total_error(pred, patches)
check("total error ≥ 0", total >= 0.0)

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
