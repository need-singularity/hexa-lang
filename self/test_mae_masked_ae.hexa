// ═══════════════════════════════════════════════════════════════
//  test_mae_masked_ae.hexa — MAE Masked Autoencoder (#281) tests
// ═══════════════════════════════════════════════════════════════

import "ml/mae_masked_ae.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx(a, b, eps) {
    return fabs(a - b) < eps
}

println("═══════════════════════════════════════════════════════")
println("  MAE Masked Autoencoder (#281) Test Suite")
println("═══════════════════════════════════════════════════════")

// helper: build an 8x8 image with simple gradient
fn make_img() {
    let mut img = []
    let mut i = 0

    while i < 8 {
        let mut row = []
        let mut j = 0

        while j < 8 { row = row + [to_float(i * 8 + j) / 64.0] }
        img = img + [row]
    }
    return img
}

let img = make_img()

// ── Test 1: patchify shape ─
let patches = mae_patchify(img, 4)
check("4 patches total", len(patches) == 4)
check("patch dim 16", len(patches[0]) == 16)

// ── Test 2: unpatchify round trip ─
let restored = mae_unpatchify(patches, 8, 8, 4)
let mut rt_ok = true
let mut i = 0

while i < 8 {
    let mut j = 0

    while j < 8 {
        if fabs(restored[i][j] - img[i][j]) > 1.0e-10 { rt_ok = false }
    }
}
check("unpatchify round-trip", rt_ok)

// ── Test 3: specific patch values match corner of image ─
// patch[0] is top-left 4x4; img[0][0]=0.0, img[0][1]=1/64
check("patch[0][0] = img[0][0]", approx(patches[0][0], img[0][0], 1.0e-10))
check("patch[0][1] = img[0][1]", approx(patches[0][1], img[0][1], 1.0e-10))

// ── Test 4: random mask has correct counts ─
let minfo = mae_random_mask(4, 0.75, 42)
check("n_keep = 1", minfo["n_keep"] == 1)
let mask = minfo["mask"]
let mut masked_count = 0
let mut i = 0

while i < 4 {
    if mask[i] > 0.5 { masked_count = masked_count + 1 }
}
check("3 masked", masked_count == 3)
let ids_keep = minfo["ids_keep"]
check("ids_keep length 1", len(ids_keep) == 1)

// ── Test 5: model init shapes ─
let model = mae_init(8, 16, 42)
check("embed_dim = 8", model["embed_dim"] == 8)
check("patch_dim = 16", model["patch_dim"] == 16)
let W_e = model["W_e"]
check("W_e rows 16", len(W_e) == 16)
check("W_e cols 8", len(W_e[0]) == 8)
let W_d = model["W_d"]
check("W_d rows 8", len(W_d) == 8)
check("W_d cols 16", len(W_d[0]) == 16)
let mt = model["mask_token"]
check("mask_token length 8", len(mt) == 8)

// ── Test 6: encode → vector shape ─
let enc = mae_encode_patch(model, patches[0])
check("encoded dim 8", len(enc) == 8)

// ── Test 7: decode → patch_dim ─
let dec = mae_decode_token(model, enc)
check("decoded dim 16", len(dec) == 16)

// ── Test 8: forward pass ─
let out = mae_forward(model, img, 42)
let pred = out["pred"]
let loss = out["loss"]
check("pred N = 4", len(pred) == 4)
check("pred dim 16", len(pred[0]) == 16)
check("loss >= 0", loss >= 0.0)
check("loss finite", loss < 100.0)

// ── Test 9: deterministic: same seed → same loss ─
let out2 = mae_forward(model, img, 42)
check("deterministic loss", approx(out2["loss"], loss, 1.0e-12))

// ── Test 10: different seed → possibly different mask pattern ─
// check that ids_keep and ids_mask are disjoint partitions
let ids_mask = out["ids_mask"]
let ids_keep_out = out["ids_keep"]
check("ids_keep + ids_mask = N", len(ids_keep_out) + len(ids_mask) == 4)
let mut disjoint = true
let mut i = 0

while i < len(ids_keep_out) {
    let mut j = 0

    while j < len(ids_mask) {
        if ids_keep_out[i] == ids_mask[j] { disjoint = false }
    }
}
check("keep ∩ mask = ∅", disjoint)

// ── Test 11: mask applies only to dropped patches ─
let mask_out = out["mask"]
let mut mask_sum = 0
let mut i = 0

while i < 4 {
    if mask_out[i] > 0.5 { mask_sum = mask_sum + 1 }
}
check("mask covers 3 patches", mask_sum == 3)

// ── Test 12: reconstruction loss on zero diff = 0 ─
let loss_zero = mae_reconstruction_loss(patches, patches, mask_out)
check("loss(x,x) = 0", approx(loss_zero, 0.0, 1.0e-12))

// ── Test 13: reconstruction loss > 0 for different preds ─
let mut pred_bad = []
let mut i = 0

while i < 4 {
    let mut row = []
    let mut k = 0

    while k < 16 { row = row + [0.0] }
    pred_bad = pred_bad + [row]
}
let loss_bad = mae_reconstruction_loss(pred_bad, patches, mask_out)
check("bad pred positive loss", loss_bad > 0.0)

// ── Test 14: full-image total error ≥ masked loss (weak check) ─
let total = mae_total_error(pred, patches)
check("total error ≥ 0", total >= 0.0)

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
