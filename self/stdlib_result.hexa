// ═══════════════════════════════════════════════════════════
//  stdlib_result.hexa — Result<T,E> and Option<T> Stdlib
//  Provides: Result enum, Option enum, and functional combinators
//  Usage: include or copy these definitions into your .hexa files
// ═══════════════════════════════════════════════════════════

// ── Result Type ─────────────────────────────────────────────
// Result represents a computation that may succeed (Ok) or fail (Err).

enum Result {
    Ok(val),
    Err(msg)
}

// ── Option Type ─────────────────────────────────────────────
// Option represents a value that may or may not exist.

enum Option {
    Some(val),
    None
}

// ═══════════════════════════════════════════════════════════
//  Result Constructors
// ═══════════════════════════════════════════════════════════

fn ok(val) {
    return Result::Ok(val)
}

fn err(msg) {
    return Result::Err(msg)
}

// ═══════════════════════════════════════════════════════════
//  Result Queries
// ═══════════════════════════════════════════════════════════

fn is_ok(r) {
    return match r {
        Ok(_) -> true,
        Err(_) -> false
    }
}

fn is_err(r) {
    return match r {
        Ok(_) -> false,
        Err(_) -> true
    }
}

// ═══════════════════════════════════════════════════════════
//  Result Extractors
// ═══════════════════════════════════════════════════════════

// unwrap: extract value or throw on Err
fn unwrap(r) {
    return match r {
        Ok(x) -> x,
        Err(e) -> { throw "unwrap called on Err: " + to_string(e) }
    }
}

// unwrap_or: extract value or return default
fn unwrap_or(r, default) {
    return match r {
        Ok(x) -> x,
        Err(_) -> default
    }
}

// unwrap_or_else: extract value or call fallback function
fn unwrap_or_else(r, fallback_fn) {
    return match r {
        Ok(x) -> x,
        Err(e) -> fallback_fn(e)
    }
}

// unwrap_err: extract error or throw on Ok
fn unwrap_err(r) {
    return match r {
        Ok(x) -> { throw "unwrap_err called on Ok: " + to_string(x) },
        Err(e) -> e
    }
}

// ═══════════════════════════════════════════════════════════
//  Result Combinators
// ═══════════════════════════════════════════════════════════

// map: transform the Ok value, pass through Err
// NOTE: use unique param names (map_fn, not f) to avoid runtime scope leakage
//       when calling the same higher-order function multiple times.
fn map_result(r, map_fn) {
    return match r {
        Ok(x) -> Result::Ok(map_fn(x)),
        Err(e) -> Result::Err(e)
    }
}

// map_err: transform the Err value, pass through Ok
fn map_err(r, err_fn) {
    return match r {
        Ok(x) -> Result::Ok(x),
        Err(e) -> Result::Err(err_fn(e))
    }
}

// and_then (flatMap/bind): chain Result-returning functions
// TIP: when chaining multiple and_then calls, use lambda wrappers
//      e.g., and_then(r, |x| my_fn(x)) instead of and_then(r, my_fn)
fn and_then(r, then_fn) {
    return match r {
        Ok(x) -> then_fn(x),
        Err(e) -> Result::Err(e)
    }
}

// or_else: recover from Err with a Result-returning function
fn or_else(r, else_fn) {
    return match r {
        Ok(x) -> Result::Ok(x),
        Err(e) -> else_fn(e)
    }
}

// ═══════════════════════════════════════════════════════════
//  Option Constructors
// ═══════════════════════════════════════════════════════════

fn some(val) {
    return Option::Some(val)
}

fn none() {
    return Option::None
}

// ═══════════════════════════════════════════════════════════
//  Option Queries & Extractors
// ═══════════════════════════════════════════════════════════

fn is_some(o) {
    return match o {
        Some(_) -> true,
        None -> false
    }
}

fn is_none(o) {
    return match o {
        Some(_) -> false,
        None -> true
    }
}

fn unwrap_option(o) {
    return match o {
        Some(x) -> x,
        None -> { throw "unwrap called on None" }
    }
}

fn unwrap_option_or(o, default) {
    return match o {
        Some(x) -> x,
        None -> default
    }
}

// ═══════════════════════════════════════════════════════════
//  Option Combinators
// ═══════════════════════════════════════════════════════════

fn map_option(o, opt_fn) {
    return match o {
        Some(x) -> Option::Some(opt_fn(x)),
        None -> Option::None
    }
}

fn and_then_option(o, opt_then) {
    return match o {
        Some(x) -> opt_then(x),
        None -> Option::None
    }
}

// ═══════════════════════════════════════════════════════════
//  Conversions: Result <-> Option
// ═══════════════════════════════════════════════════════════

fn result_to_option(r) {
    return match r {
        Ok(x) -> Option::Some(x),
        Err(_) -> Option::None
    }
}

fn option_to_result(o, err_msg) {
    return match o {
        Some(x) -> Result::Ok(x),
        None -> Result::Err(err_msg)
    }
}

// ═══════════════════════════════════════════════════════════
//  Error Propagation Helpers
// ═══════════════════════════════════════════════════════════

// try_call: wrap a throwing function into a Result
// NOTE: due to runtime fn-param scope behavior, avoid calling try_call
// multiple times with different functions. Use try_call1/try_call2 with
// lambda wrappers, or define separate wrapper functions for each use.
fn try_call(call_fn) {
    let mut result = Result::Err("unknown")
    try {
        result = Result::Ok(call_fn())
    } catch e {
        result = Result::Err(to_string(e))
    }
    return result
}

// try_call1: wrap a single-arg throwing function into a Result
fn try_call1(call1_fn, arg) {
    let mut result = Result::Err("unknown")
    try {
        result = Result::Ok(call1_fn(arg))
    } catch e {
        result = Result::Err(to_string(e))
    }
    return result
}

// try_call2: wrap a two-arg throwing function into a Result
fn try_call2(call2_fn, a, b) {
    let mut result = Result::Err("unknown")
    try {
        result = Result::Ok(call2_fn(a, b))
    } catch e {
        result = Result::Err(to_string(e))
    }
    return result
}
