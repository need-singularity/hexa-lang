// ═══════════════════════════════════════════════════════════
//  self/test_safetensors_mmap.hexa — smoke for roi.json #172
//
//  Exercises self/alloc/safetensors_mmap.hexa:
//    * builds a deterministic dummy .safetensors file on disk
//    * opens it via safetensors_mmap_open (mmap, no slurp)
//    * verifies header parse + TensorView metadata
//    * reads individual bytes back through safetensors_view_u8
//      (zero-copy path — the tensor bytes are NEVER materialised
//       into a hexa array)
//    * closes the mapping
//
//  실행: ./hexa test self/test_safetensors_mmap.hexa
//
//  Note — fs_mmap_ro requires native codegen; under the interp
//  interp fs_mmap_ro returns (0,0) and the test degrades to a
//  "handle-null is handled" check so the file still runs green
//  in the interp smoke matrix.
// ═══════════════════════════════════════════════════════════

use "self/alloc/safetensors_mmap"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  roi.json #172 — zero-copy mmap safetensors loader")
println("═══════════════════════════════════════════════════════")

// ── 1. Build a dummy safetensors file ───────────────────
//
// Layout (identical to the real HuggingFace format):
//   [0..8)   u64 LE header_len
//   [8..8+H) JSON header: two tensors t0 (F32, shape=[3]) + t1 (BF16, shape=[2,2])
//   [8+H..)  raw tensor data region

let st_path = "/tmp/_test_safetensors_mmap_dummy.safetensors"

let header_json = "{\"t0\":{\"dtype\":\"F32\",\"shape\":[3],\"data_offsets\":[0,12]},\"t1\":{\"dtype\":\"BF16\",\"shape\":[2,2],\"data_offsets\":[12,20]}}"

// Convert JSON string to byte array.
let mut json_bytes = []
let mut ci = 0
while ci < len(header_json) {
    json_bytes = json_bytes + [char_code(header_json, ci)]
    ci = ci + 1
}
let hsz = len(json_bytes)

// Pack u64 LE header_size.
let mut out_bytes = []
let mut tmp = hsz
let mut bi = 0
while bi < 8 {
    out_bytes = out_bytes + [tmp % 256]
    tmp = tmp / 256
    bi = bi + 1
}
// Append JSON header.
out_bytes = out_bytes + json_bytes

// Append tensor data — 20 bytes total (12 for t0, 8 for t1).
// Deterministic non-zero content so byte accessor assertions are
// meaningful:
//   t0 data region = [10,11,12, 20,21,22, 30,31,32, 40,41,42]
//   t1 data region = [50,51, 60,61, 70,71, 80,81]
let t0_data = [10, 11, 12, 20, 21, 22, 30, 31, 32, 40, 41, 42]
let t1_data = [50, 51, 60, 61, 70, 71, 80, 81]
out_bytes = out_bytes + t0_data + t1_data

write_bytes(st_path, out_bytes)
check("wrote dummy safetensors", file_exists(st_path))

// ── 2. Open via mmap loader ─────────────────────────────
let m = safetensors_mmap_open(st_path)

// Stage0 interp does not link syscall/to_cstr — fs_mmap_ro emits
// "undefined function" stderr and yields a handle whose views
// array is empty. Detect that and skip byte-level assertions so
// this scaffold stays green under interp. Native builds populate
// the full matrix.
let interp_skip = safetensors_mmap_is_null(m) || safetensors_mmap_count(m) == 0

if interp_skip {
    println("[SKIP] mmap unavailable under interp — skipping byte-level checks")
    // Native path tests close(); under interp fs_munmap hits
    // "undefined function: syscall" and returns void, so we do
    // not assert on the return value here. Scaffolding only.
    check("interp skip branch", true)
} else {
    // ── 3. Metadata ────────────────────────────────────────
    check_eq("tensor count == 2", safetensors_mmap_count(m), 2)
    check_eq("header_end == 8+hsz", m.header_end, 8 + hsz)
    check_eq("name[0] == t0", safetensors_mmap_name_at(m, 0), "t0")
    check_eq("name[1] == t1", safetensors_mmap_name_at(m, 1), "t1")

    // ── 4. Tensor views ────────────────────────────────────
    let v0 = safetensors_mmap_tensor(m, "t0")
    check("t0 view not null", tensor_view_is_null(v0) == false)
    check_eq("t0 dtype F32", v0.dtype, "F32")
    check_eq("t0 nbytes 12", v0.nbytes, 12)
    check_eq("t0 shape == [3]", len(v0.shape) == 1 && v0.shape[0] == 3, true)

    let v1 = safetensors_mmap_tensor(m, "t1")
    check("t1 view not null", tensor_view_is_null(v1) == false)
    check_eq("t1 dtype BF16", v1.dtype, "BF16")
    check_eq("t1 nbytes 8", v1.nbytes, 8)
    check_eq("t1 shape == [2,2]",
             len(v1.shape) == 2 && v1.shape[0] == 2 && v1.shape[1] == 2,
             true)

    // ── 5. Zero-copy byte accessor ─────────────────────────
    // Reads go straight through hexa_ptr_read_byte on the mmap
    // base — no byte-array copy of the tensor region exists.
    check_eq("t0[0] == 10", safetensors_view_u8(v0, 0), 10)
    check_eq("t0[1] == 11", safetensors_view_u8(v0, 1), 11)
    check_eq("t0[11] == 42", safetensors_view_u8(v0, 11), 42)
    check_eq("t0 oob(12) == 0", safetensors_view_u8(v0, 12), 0)
    check_eq("t0 oob(-1) == 0", safetensors_view_u8(v0, -1), 0)

    check_eq("t1[0] == 50", safetensors_view_u8(v1, 0), 50)
    check_eq("t1[7] == 81", safetensors_view_u8(v1, 7), 81)

    // ── 6. Addresses disjoint, inside file ─────────────────
    check("v0.addr inside file",
          v0.addr >= m.base_addr + m.header_end && v0.addr < m.base_addr + m.size)
    check("v1.addr == v0.addr + 12", v1.addr == v0.addr + 12)

    // ── 7. Total bytes sanity ──────────────────────────────
    check_eq("total_bytes == 20", safetensors_mmap_total_bytes(m), 20)

    // ── 8. Missing tensor returns null view ────────────────
    let vn = safetensors_mmap_tensor(m, "__nope__")
    check("missing tensor -> null view", tensor_view_is_null(vn))

    // ── 9. Close ───────────────────────────────────────────
    let rc = safetensors_mmap_close(m)
    check("close rc >= 0", rc >= 0)
}

// ── 10. Open non-existent path -> null handle ──────────────
// Native build: fs_mmap_ro returns (0,0) for missing files,
// so open() hits the null branch. Interp build: syscall is
// absent, the handle holds garbage but count stays 0 because
// the header parse could not enumerate any tensors.
let m_bad = safetensors_mmap_open("/tmp/_test_safetensors_mmap_does_not_exist.bin")
check("open(missing) -> empty handle",
      safetensors_mmap_is_null(m_bad) || safetensors_mmap_count(m_bad) == 0)
// Native-only: close() must succeed on the null handle path
// (short-circuited to return 0 without calling syscall). Under
// interp, the null handle also short-circuits and never reaches
// fs_munmap — so this stays green in both.
if safetensors_mmap_is_null(m_bad) {
    check_eq("close(null) == 0", safetensors_mmap_close(m_bad), 0)
}

println("")
println("═══════════════════════════════════════════════════════")
println("  safetensors_mmap: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
assert(fail_count == 0)
