//
//  Reference values computed via Python MurmurHash3 x86-32 impl.
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from runtime/murmur3_pure.hexa (includes inlined bit helpers) ──

let MASK32 = 0xFFFFFFFF

@pure
fn _pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

@pure
fn _shl(a, n) {
    if n <= 0 { return a }
    return a * _pow2(n)
}

@pure
fn _shr(a, n) {
    if n <= 0 { return a }
    return a / _pow2(n)
}

@pure
fn _or(a, b) {
    return (a + b) - (a & b)
}

@pure
fn _xor(a, b) {
    return a ^ b
}

@pure
fn _rotl32(x, r) {
    let v = x & MASK32
    let shift = r % 32
    if shift == 0 { return v }
    let lo = _shl(v, shift) & MASK32
    let hi = _shr(v, 32 - shift)
    return _or(lo, hi) & MASK32
}

let C1 = 0xCC9E2D51
let C2 = 0x1B873593

@pure
fn mul32(a, b) {
    let a32 = a & MASK32
    let b32 = b & MASK32
    let aL = a32 & 0xFFFF
    let aH = _shr(a32, 16)
    let bL = b32 & 0xFFFF
    let bH = _shr(b32, 16)
    let low = aL * bL
    let mid = (aL * bH + aH * bL) & 0xFFFF
    let result = low + _shl(mid, 16)
    return result & MASK32
}

@pure
fn fmix32(hh) {
    let mut h = hh & MASK32
    h = _xor(h, _shr(h, 16))
    h = mul32(h, 0x85EBCA6B)
    h = _xor(h, _shr(h, 13))
    h = mul32(h, 0xC2B2AE35)
    h = _xor(h, _shr(h, 16))
    return h & MASK32
}

@pure
fn get_byte(s, i) {
    return ord(s.substring(i, i + 1))
}

@pure
fn get_block32(s, block_start, i) {
    let base = block_start + i * 4
    let b0 = get_byte(s, base)
    let b1 = _shl(get_byte(s, base + 1), 8)
    let b2 = _shl(get_byte(s, base + 2), 16)
    let b3 = _shl(get_byte(s, base + 3), 24)
    return _or(_or(b0, b1), _or(b2, b3))
}

@pure
pub fn murmur3_hash32(data, seed) {
    if type_of(data) != "string" { return seed & MASK32 }

    let length = len(data)
    let mut h1 = seed & MASK32
    let nblocks = length / 4

    let mut i = 0
    while i < nblocks {
        let mut k1 = get_block32(data, 0, i)
        k1 = mul32(k1, C1)
        k1 = _rotl32(k1, 15)
        k1 = mul32(k1, C2)

        h1 = _xor(h1, k1)
        h1 = _rotl32(h1, 13)
        h1 = (mul32(h1, 5) + 0xE6546B64) & MASK32

        i = i + 1
    }

    let tail_start = nblocks * 4
    let rem = length & 3
    let mut k1 = 0

    if rem == 3 {
        k1 = _or(k1, _shl(get_byte(data, tail_start + 2), 16))
    }
    if rem >= 2 {
        k1 = _or(k1, _shl(get_byte(data, tail_start + 1), 8))
    }
    if rem >= 1 {
        k1 = _or(k1, get_byte(data, tail_start))
        k1 = mul32(k1, C1)
        k1 = _rotl32(k1, 15)
        k1 = mul32(k1, C2)
        h1 = _xor(h1, k1)
    }

    h1 = _xor(h1, length)
    h1 = fmix32(h1)

    return h1
}

@pure
pub fn murmur3_32(data, seed) {
    return murmur3_hash32(data, seed)
}

@pure
pub fn murmur3_simple(data) {
    return murmur3_hash32(data, 0)
}

// ── END INLINED ──

let mut pass = 0
let mut fail = 0

fn eq(name, actual, expected) {
    if actual == expected {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

println("===================================================")
println("  murmur3_pure.hexa -- test runner")
println("===================================================")

// ── empty string ──
println("")
println("--- empty string ---")
eq("empty seed=0", murmur3_hash32("", 0), 0)
eq("empty seed=1", murmur3_hash32("", 1), 1364076727)
eq("empty seed=0xDEADBEEF", murmur3_hash32("", 3735928559), 233162409)

// ── single byte ──
println("")
println("--- single byte ---")
eq("'a' seed=0", murmur3_hash32("a", 0), 1009084850)

// ── two bytes ──
println("")
println("--- two bytes ---")
eq("'ab' seed=0", murmur3_hash32("ab", 0), 2613040991)

// ── three bytes ──
println("")
println("--- three bytes ---")
eq("'abc' seed=0", murmur3_hash32("abc", 0), 3017643002)

// ── four bytes ──
println("")
println("--- exact block (4 bytes) ---")
eq("'abcd' seed=0", murmur3_hash32("abcd", 0), 1139631978)

// ── multi-byte strings ──
println("")
println("--- multi-byte ---")
eq("'hello' seed=0", murmur3_hash32("hello", 0), 613153351)
eq("'hello world' seed=0", murmur3_hash32("hello world", 0), 1586663183)
eq("'Hello, world!' seed=0", murmur3_hash32("Hello, world!", 0), 3224780355)
eq("'foo' seed=0", murmur3_hash32("foo", 0), 4138058784)
eq("'foobar' seed=0", murmur3_hash32("foobar", 0), 2764362941)

// ── long string ──
println("")
println("--- long string ---")
eq("quick brown fox seed=0", murmur3_hash32("The quick brown fox jumps over the lazy dog", 0), 776992547)

// ── seed variation ──
println("")
println("--- seed variation ---")
eq("'a' seed=42", murmur3_hash32("a", 42), 3001393763)
eq("'hello' seed=12345", murmur3_hash32("hello", 12345), 1321914039)
eq("'abc' seed=0xFFFFFFFF", murmur3_hash32("abc", 4294967295), 4236296879)

// ── determinism ──
println("")
println("--- determinism ---")
check("same input same hash", murmur3_hash32("test", 0) == murmur3_hash32("test", 0))
check("diff inputs diff hashes", murmur3_hash32("a", 0) != murmur3_hash32("b", 0))
check("diff seeds diff hashes", murmur3_hash32("x", 0) != murmur3_hash32("x", 1))

// ── non-string input ──
println("")
println("--- non-string guard ---")
eq("non-string returns seed", murmur3_hash32(42, 7), 7)

// ── murmur3_32 alias ──
println("")
println("--- murmur3_32 alias ---")
eq("murmur3_32 matches hash32", murmur3_32("hello", 0), murmur3_hash32("hello", 0))
eq("murmur3_32 empty seed=0", murmur3_32("", 0), 0)
eq("murmur3_32 abc seed=0", murmur3_32("abc", 0), 3017643002)

// ── murmur3_simple convenience ──
println("")
println("--- murmur3_simple ---")
eq("murmur3_simple hello", murmur3_simple("hello"), murmur3_hash32("hello", 0))
eq("murmur3_simple empty", murmur3_simple(""), 0)
eq("murmur3_simple foo", murmur3_simple("foo"), 4138058784)

// ── summary ──
println("")
println("===================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===================================================")

if fail > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
