// =====================================================================
//  test_compact_enum.hexa -- M977 @compact enum tag compression
//  Verifies that enum tag bit calculation and compact representation
//  are correct for various variant counts.
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=====================================================================")
println("  M977: @compact enum Tag Compression Tests")
println("=====================================================================")
println("")

// -- 1. Minimum bits calculation --

println("--- 1. min_bits_for_count ---")

fn min_bits(count) {
    if count <= 1 { return 1 }
    let mut bits = 0
    let mut v = count - 1
    while v > 0 {
        bits = bits + 1
        v = v / 2
    }
    return bits
}

check("bits: 1 variant", min_bits(1), 1)
check("bits: 2 variants", min_bits(2), 1)
check("bits: 3 variants", min_bits(3), 2)
check("bits: 4 variants", min_bits(4), 2)
check("bits: 5 variants", min_bits(5), 3)
check("bits: 8 variants", min_bits(8), 3)
check("bits: 9 variants", min_bits(9), 4)
check("bits: 16 variants", min_bits(16), 4)
check("bits: 17 variants", min_bits(17), 5)
check("bits: 32 variants", min_bits(32), 5)
check("bits: 64 variants", min_bits(64), 6)
check("bits: 128 variants", min_bits(128), 7)
check("bits: 256 variants", min_bits(256), 8)

// -- 2. Enum with 2 variants (bool-like, 1 bit) --

println("")
println("--- 2. Two-variant enum (1 bit) ---")

enum Direction {
    Left,
    Right
}

let d1 = Direction::Left
let d2 = Direction::Right

check("enum: Direction::Left tag", to_string(d1), "Direction::Left")
check("enum: Direction::Right tag", to_string(d2), "Direction::Right")
check("enum: 2 variants = 1 bit", min_bits(2), 1)

// -- 3. Enum with 3 variants (2 bits) --

println("")
println("--- 3. Three-variant enum (2 bits) ---")

enum Color {
    Red,
    Green,
    Blue
}

let c1 = Color::Red
let c2 = Color::Green
let c3 = Color::Blue

check("enum: Color::Red", to_string(c1), "Color::Red")
check("enum: Color::Green", to_string(c2), "Color::Green")
check("enum: Color::Blue", to_string(c3), "Color::Blue")
check("enum: 3 variants = 2 bits", min_bits(3), 2)

// -- 4. Enum with 4 variants (2 bits, exact fit) --

println("")
println("--- 4. Four-variant enum (2 bits exact) ---")

enum Season {
    Spring,
    Summer,
    Autumn,
    Winter
}

check("enum: Season 4 variants = 2 bits", min_bits(4), 2)

let s1 = Season::Spring
let s2 = Season::Summer
let s3 = Season::Autumn
let s4 = Season::Winter

check("enum: Spring", to_string(s1), "Season::Spring")
check("enum: Summer", to_string(s2), "Season::Summer")
check("enum: Autumn", to_string(s3), "Season::Autumn")
check("enum: Winter", to_string(s4), "Season::Winter")

// -- 5. Enum with 5+ variants (3 bits) --

println("")
println("--- 5. Five+ variant enum (3 bits) ---")

enum Weekday {
    Mon,
    Tue,
    Wed,
    Thu,
    Fri,
    Sat,
    Sun
}

check("enum: 7 variants = 3 bits", min_bits(7), 3)

let w1 = Weekday::Mon
let w7 = Weekday::Sun
check("enum: Weekday::Mon", to_string(w1), "Weekday::Mon")
check("enum: Weekday::Sun", to_string(w7), "Weekday::Sun")

// -- 6. Memory savings calculation --

println("")
println("--- 6. Memory savings ---")

fn savings_bits(count) {
    let bits = min_bits(count)
    if bits < 8 {
        return 8 - bits
    }
    return 0
}

check("savings: 2 variants", savings_bits(2), 7)
check("savings: 4 variants", savings_bits(4), 6)
check("savings: 8 variants", savings_bits(8), 5)
check("savings: 16 variants", savings_bits(16), 4)
check("savings: 256 variants", savings_bits(256), 0)

// -- 7. Enum match correctness --

println("")
println("--- 7. Match on compact enum ---")

fn describe_color(c) {
    return match c {
        Color::Red -> "warm",
        Color::Green -> "cool",
        Color::Blue -> "cool",
        _ -> "unknown"
    }
}

check("match: Red", describe_color(Color::Red), "warm")
check("match: Green", describe_color(Color::Green), "cool")
check("match: Blue", describe_color(Color::Blue), "cool")

// -- 8. Enum equality after compaction --

println("")
println("--- 8. Enum equality ---")

fn same_direction(a, b) {
    return to_string(a) == to_string(b)
}

check("eq: Left==Left", same_direction(Direction::Left, Direction::Left), true)
check("eq: Left==Right", same_direction(Direction::Left, Direction::Right), false)
check("eq: Right==Right", same_direction(Direction::Right, Direction::Right), true)

// -- 9. Enum in arrays --

println("")
println("--- 9. Enum in arrays ---")

let colors = [Color::Red, Color::Green, Color::Blue, Color::Red]
check("enum-array: len", len(colors), 4)
check("enum-array: [0]", to_string(colors[0]), "Color::Red")
check("enum-array: [1]", to_string(colors[1]), "Color::Green")
check("enum-array: [3]", to_string(colors[3]), "Color::Red")

// -- Summary --
println("")
println("=====================================================================")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================================")
assert(fail_count == 0)
