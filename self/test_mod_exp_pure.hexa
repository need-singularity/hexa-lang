// ═══════════════════════════════════════════════════════════════════
//  test_mod_exp_pure.hexa — Tests for self/runtime/mod_exp_pure.hexa
// ═══════════════════════════════════════════════════════════════════

import "runtime/mod_exp_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, got, want) {
    if got == want {
        pass = pass + 1
    } else {
        println("[FAIL] " + name + ": got " + to_string(got) + " want " + to_string(want))
        fail = fail + 1
    }
}

fn check_bool(name, got, want) {
    if got == want {
        pass = pass + 1
    } else {
        println("[FAIL] " + name + ": got " + to_string(got) + " want " + to_string(want))
        fail = fail + 1
    }
}

println("=== mod_exp_pure test suite ===")

// ────────────────────────────────────────────────────────────
// 1. mod_mul_pure — overflow-safe modular multiplication
// ────────────────────────────────────────────────────────────
check("mul 3*4 mod 5", mod_mul_pure(3, 4, 5), 2)
check("mul 7*8 mod 10", mod_mul_pure(7, 8, 10), 6)
check("mul 0*99 mod 7", mod_mul_pure(0, 99, 7), 0)
check("mul 99*0 mod 7", mod_mul_pure(99, 0, 7), 0)
check("mul a mod 1", mod_mul_pure(123, 456, 1), 0)
// Large values (tests Russian-peasant path)
check("mul large", mod_mul_pure(100000000, 100000000, 999999937), mod_mul_pure(100000000, 100000000, 999999937))

// ────────────────────────────────────────────────────────────
// 2. mod_exp_pure — binary exponentiation
// ────────────────────────────────────────────────────────────
check("2^10 mod 1000", mod_exp_pure(2, 10, 1000), 24)
check("3^13 mod 50", mod_exp_pure(3, 13, 50), 23)
check("5^3 mod 13", mod_exp_pure(5, 3, 13), 8)
check("7^256 mod 13", mod_exp_pure(7, 256, 13), 9)
check("10^9 mod 7", mod_exp_pure(10, 9, 7), 6)

// Edge: exp == 0 → always 1 (when m > 1)
check("exp=0", mod_exp_pure(999, 0, 7), 1)
check("exp=0 mod 1", mod_exp_pure(999, 0, 1), 0)

// Edge: mod == 1 → always 0
check("mod=1", mod_exp_pure(2, 10, 1), 0)

// Edge: base == 0
check("base=0 exp>0", mod_exp_pure(0, 5, 7), 0)
check("base=0 exp=0", mod_exp_pure(0, 0, 7), 1)

// Fermat's little theorem: a^(p-1) mod p == 1 for prime p, gcd(a,p)==1
check("fermat 2^6 mod 7", mod_exp_pure(2, 6, 7), 1)
check("fermat 3^12 mod 13", mod_exp_pure(3, 12, 13), 1)
check("fermat 5^16 mod 17", mod_exp_pure(5, 16, 17), 1)
check("fermat 2^96 mod 97", mod_exp_pure(2, 96, 97), 1)

// RSA-like: small example
// p=61, q=53, n=3233, e=17, d=2753
// m^e mod n then result^d mod n should give m back
let n_rsa = 3233
let e_rsa = 17
let d_rsa = 2753
let msg = 42
let cipher = mod_exp_pure(msg, e_rsa, n_rsa)
let decrypted = mod_exp_pure(cipher, d_rsa, n_rsa)
check("rsa encrypt-decrypt", decrypted, msg)

// ────────────────────────────────────────────────────────────
// 3. gcd_ext_pure — extended GCD
// ────────────────────────────────────────────────────────────
let e1 = gcd_ext_pure(35, 15)
check("ext_gcd(35,15) gcd", e1[0], 5)
// Verify Bezout: 35*x + 15*y == 5
let bezout1 = 35 * e1[1] + 15 * e1[2]
check("ext_gcd(35,15) bezout", bezout1, 5)

let e2 = gcd_ext_pure(99, 78)
check("ext_gcd(99,78) gcd", e2[0], 3)
let bezout2 = 99 * e2[1] + 78 * e2[2]
check("ext_gcd(99,78) bezout", bezout2, 3)

let e3 = gcd_ext_pure(240, 46)
check("ext_gcd(240,46) gcd", e3[0], 2)
let bezout3 = 240 * e3[1] + 46 * e3[2]
check("ext_gcd(240,46) bezout", bezout3, 2)

// Coprime
let e4 = gcd_ext_pure(17, 13)
check("ext_gcd(17,13) gcd", e4[0], 1)
let bezout4 = 17 * e4[1] + 13 * e4[2]
check("ext_gcd(17,13) bezout", bezout4, 1)

// ────────────────────────────────────────────────────────────
// 4. mod_inv_pure — modular inverse
// ────────────────────────────────────────────────────────────
check("inv(3,7)", mod_inv_pure(3, 7), 5)
check("inv(2,5)", mod_inv_pure(2, 5), 3)
check("inv(17,3120)", mod_inv_pure(17, 3120), 2753)

// Verify: (a * inv) mod m == 1
let inv_3_7 = mod_inv_pure(3, 7)
check("verify 3*inv mod 7", mod_mul_pure(3, inv_3_7, 7), 1)

let inv_17_3120 = mod_inv_pure(17, 3120)
check("verify 17*inv mod 3120", mod_mul_pure(17, inv_17_3120, 3120), 1)

// Non-coprime: no inverse exists
check("inv(4,6) none", mod_inv_pure(4, 6), -1)
check("inv(6,3) none", mod_inv_pure(6, 3), -1)
check("inv(0,5) none", mod_inv_pure(0, 5), -1)

// Edge: mod=1
check("inv(a,1)", mod_inv_pure(5, 1), 0)

// ────────────────────────────────────────────────────────────
// 5. Legacy aliases
// ────────────────────────────────────────────────────────────
check("legacy mod_exp", mod_exp(2, 10, 1000), 24)
check("legacy mod_inv", mod_inv(3, 7), 5)

// ────────────────────────────────────────────────────────────
// 6. gcd / lcm
// ────────────────────────────────────────────────────────────
check("gcd(12,8)", gcd(12, 8), 4)
check("gcd(7,13)", gcd(7, 13), 1)
check("gcd(0,5)", gcd(0, 5), 5)
check("gcd(-12,8)", gcd(-12, 8), 4)
check("lcm(4,6)", lcm(4, 6), 12)
check("lcm(0,5)", lcm(0, 5), 0)

// ────────────────────────────────────────────────────────────
// 7. is_prime_miller
// ────────────────────────────────────────────────────────────
check_bool("prime(2)", is_prime_miller(2, 5), true)
check_bool("prime(17)", is_prime_miller(17, 5), true)
check_bool("prime(97)", is_prime_miller(97, 7), true)
check_bool("prime(4)", is_prime_miller(4, 5), false)
check_bool("prime(1)", is_prime_miller(1, 5), false)
check_bool("prime(561 carmichael)", is_prime_miller(561, 7), false)

// ── Summary ──────────────────────────────────────────────────────
println("")
println("mod_exp_pure: " + to_string(pass) + " PASS, " + to_string(fail) + " FAIL")
if fail > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL PASS")
}
