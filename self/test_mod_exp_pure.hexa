// ═══════════════════════════════════════════════════════════════════
//  self/runtime/mod_exp_pure.hexa — pure-Hexa modular arithmetic
//
//  No C, no FFI, no 0b literals. Integer-only ops with overflow
//  awareness — Hexa float64 is safe up to 2^53.
//
//  Public API:
//      mod_mul_pure(a, b, m)            overflow-safe (a*b) mod m
//      mod_exp_pure(base, exp, m)       binary exponentiation O(log exp)
//      gcd_ext_pure(a, b)               extended GCD → [gcd, x, y]
//      mod_inv_pure(a, m)               modular inverse, -1 if none
//      gcd(a, b)                        Euclidean GCD
//      lcm(a, b)                        via GCD
//      is_prime_miller(n, k)            Miller-Rabin primality, k rounds
// ═══════════════════════════════════════════════════════════════════

// ── gcd — greatest common divisor (Euclidean) ────────────────────
@pure
pub fn gcd(a, b) {
    let mut x = if a < 0 { 0 - a } else { a }
    let mut y = if b < 0 { 0 - b } else { b }
    while y != 0 {
        let tmp = y
        y = x - (x / y) * y
        x = tmp
    }
    return x
}

// ── lcm — least common multiple via GCD ─────────────────────────
@pure
pub fn lcm(a, b) {
    if a == 0 { return 0 }
    if b == 0 { return 0 }
    let aa = if a < 0 { 0 - a } else { a }
    let bb = if b < 0 { 0 - b } else { b }
    return (aa / gcd(aa, bb)) * bb
}

// ── _mod_positive — ensure positive modular result ───────────────
@pure
fn _mod_positive(val, m) {
    let r = val - (val / m) * m
    if r < 0 { return r + m }
    return r
}

// ── mod_mul_pure — overflow-safe (a * b) mod m ───────────────────
// Splits via Russian-peasant double-and-add so intermediates
// never exceed ~2*m. Safe for m up to ~2^52.
@pure
pub fn mod_mul_pure(a, b, m) {
    if m <= 0 { return 0 }
    if m == 1 { return 0 }
    let mut aa = _mod_positive(a, m)
    let mut bb = _mod_positive(b, m)
    // Direct multiply is safe if both < 2^26 (~67 million)
    if aa < 67108864 {
        if bb < 67108864 {
            return _mod_positive(aa * bb, m)
        }
    }
    // Russian-peasant double-and-add
    let mut result = 0
    while bb > 0 {
        let half = bb / 2
        if half * 2 != bb {
            // bb is odd
            result = result + aa
            if result >= m { result = result - m }
        }
        aa = aa + aa
        if aa >= m { aa = aa - m }
        bb = half
    }
    return result
}

// ── mod_exp_pure — modular exponentiation via binary method ──────
// Computes (base^exp) mod m in O(log exp) multiplications.
// Uses mod_mul_pure for each step to stay overflow-safe.
@pure
pub fn mod_exp_pure(base, exp, m) {
    if m <= 0 { return 0 }
    if m == 1 { return 0 }
    let mut result = 1
    let mut b = _mod_positive(base, m)
    let mut e = exp
    if e < 0 { e = 0 }
    while e > 0 {
        let half = e / 2
        if half * 2 != e {
            result = mod_mul_pure(result, b, m)
        }
        e = half
        b = mod_mul_pure(b, b, m)
    }
    return result
}

// ── gcd_ext_pure — extended Euclidean algorithm ──────────────────
// Returns [gcd, x, y] such that a*x + b*y == gcd.
// Iterative to avoid recursion depth issues.
@pure
pub fn gcd_ext_pure(a, b) {
    let a_neg = a < 0
    let b_neg = b < 0
    let mut old_r = if a_neg { 0 - a } else { a }
    let mut r = if b_neg { 0 - b } else { b }
    let mut old_s = 1
    let mut s = 0
    let mut old_t = 0
    let mut t = 1

    while r != 0 {
        let q = old_r / r

        let tmp_r = r
        r = old_r - q * r
        old_r = tmp_r

        let tmp_s = s
        s = old_s - q * s
        old_s = tmp_s

        let tmp_t = t
        t = old_t - q * t
        old_t = tmp_t
    }

    // Adjust signs for negative original inputs
    let rx = if a_neg { 0 - old_s } else { old_s }
    let ry = if b_neg { 0 - old_t } else { old_t }
    return [old_r, rx, ry]
}

// ── mod_inv_pure — modular multiplicative inverse ────────────────
// Returns x in [0, m) such that (a * x) mod m == 1.
// Returns -1 if gcd(a, m) != 1 (inverse does not exist).
@pure
pub fn mod_inv_pure(a, m) {
    if m <= 0 { return -1 }
    if m == 1 { return 0 }
    let ext = gcd_ext_pure(a, m)
    let g = ext[0]
    if g != 1 { return -1 }
    let x = ext[1]
    return _mod_positive(x, m)
}

// ── Legacy aliases (keep backward compat) ────────────────────────

@pure
pub fn mod_exp(base, exp, m) { return mod_exp_pure(base, exp, m) }

@pure
pub fn mod_inv(a, m) { return mod_inv_pure(a, m) }

// ── is_prime_miller — Miller-Rabin probabilistic primality test ──
// Returns true if n is probably prime after k rounds.
// Deterministic for n < 3,215,031,751 with these 7 witnesses.
@pure
pub fn is_prime_miller(n, k) {
    if n < 2 { return false }
    if n == 2 { return true }
    if n == 3 { return true }
    let rem2 = n - (n / 2) * 2
    if rem2 == 0 { return false }

    // Write n - 1 as d * 2^r
    let mut d = n - 1
    let mut r = 0
    let mut d_rem = d - (d / 2) * 2
    // @partial — Stage 0: pre-witness acknowledgement, refine in follow-up
    while d_rem == 0 {
        d = d / 2
        r = r + 1
        d_rem = d - (d / 2) * 2
    }

    // Fixed witnesses for deterministic results up to large ranges
    let witnesses = [2, 3, 5, 7, 11, 13, 17]
    let num_witnesses = len(witnesses)
    let mut rounds = k
    if rounds > num_witnesses { rounds = num_witnesses }

    let mut wi = 0
    while wi < rounds {
        let mut a = witnesses[wi]
        if a >= n { a = 2 }
        if a >= n - 1 { a = n - 2 }
        if a < 2 { a = 2 }

        // Compute a^d mod n
        let mut x = mod_exp_pure(a, d, n)

        if x == 1 {
            wi = wi + 1
            continue
        }
        if x == n - 1 {
            wi = wi + 1
            continue
        }

        // Repeat r - 1 times: x = x^2 mod n
        let mut found = false
        let mut j = 0
        while j < r - 1 {
            x = mod_exp_pure(x, 2, n)
            if x == n - 1 {
                found = true
                j = r
            } else {
                j = j + 1
            }
        }

        if found == false { return false }
        wi = wi + 1
    }
    return true
}


// -- end inlined --

let mut pass = 0
let mut fail = 0

fn check(name, got, want) {
    if got == want {
        pass = pass + 1
    } else {
        println("[FAIL] " + name + ": got " + to_string(got) + " want " + to_string(want))
        fail = fail + 1
    }
}

fn check_bool(name, got, want) {
    if got == want {
        pass = pass + 1
    } else {
        println("[FAIL] " + name + ": got " + to_string(got) + " want " + to_string(want))
        fail = fail + 1
    }
}

println("=== mod_exp_pure test suite ===")

// ────────────────────────────────────────────────────────────
// 1. mod_mul_pure — overflow-safe modular multiplication
// ────────────────────────────────────────────────────────────
check("mul 3*4 mod 5", mod_mul_pure(3, 4, 5), 2)
check("mul 7*8 mod 10", mod_mul_pure(7, 8, 10), 6)
check("mul 0*99 mod 7", mod_mul_pure(0, 99, 7), 0)
check("mul 99*0 mod 7", mod_mul_pure(99, 0, 7), 0)
check("mul a mod 1", mod_mul_pure(123, 456, 1), 0)
// Large values (tests Russian-peasant path)
check("mul large", mod_mul_pure(100000000, 100000000, 999999937), mod_mul_pure(100000000, 100000000, 999999937))

// ────────────────────────────────────────────────────────────
// 2. mod_exp_pure — binary exponentiation
// ────────────────────────────────────────────────────────────
check("2^10 mod 1000", mod_exp_pure(2, 10, 1000), 24)
check("3^13 mod 50", mod_exp_pure(3, 13, 50), 23)
check("5^3 mod 13", mod_exp_pure(5, 3, 13), 8)
check("7^256 mod 13", mod_exp_pure(7, 256, 13), 9)
check("10^9 mod 7", mod_exp_pure(10, 9, 7), 6)

// Edge: exp == 0 → always 1 (when m > 1)
check("exp=0", mod_exp_pure(999, 0, 7), 1)
check("exp=0 mod 1", mod_exp_pure(999, 0, 1), 0)

// Edge: mod == 1 → always 0
check("mod=1", mod_exp_pure(2, 10, 1), 0)

// Edge: base == 0
check("base=0 exp>0", mod_exp_pure(0, 5, 7), 0)
check("base=0 exp=0", mod_exp_pure(0, 0, 7), 1)

// Fermat's little theorem: a^(p-1) mod p == 1 for prime p, gcd(a,p)==1
check("fermat 2^6 mod 7", mod_exp_pure(2, 6, 7), 1)
check("fermat 3^12 mod 13", mod_exp_pure(3, 12, 13), 1)
check("fermat 5^16 mod 17", mod_exp_pure(5, 16, 17), 1)
check("fermat 2^96 mod 97", mod_exp_pure(2, 96, 97), 1)

// RSA-like: small example
// p=61, q=53, n=3233, e=17, d=2753
// m^e mod n then result^d mod n should give m back
let n_rsa = 3233
let e_rsa = 17
let d_rsa = 2753
let msg = 42
let cipher = mod_exp_pure(msg, e_rsa, n_rsa)
let decrypted = mod_exp_pure(cipher, d_rsa, n_rsa)
check("rsa encrypt-decrypt", decrypted, msg)

// ────────────────────────────────────────────────────────────
// 3. gcd_ext_pure — extended GCD
// ────────────────────────────────────────────────────────────
let e1 = gcd_ext_pure(35, 15)
check("ext_gcd(35,15) gcd", e1[0], 5)
// Verify Bezout: 35*x + 15*y == 5
let bezout1 = 35 * e1[1] + 15 * e1[2]
check("ext_gcd(35,15) bezout", bezout1, 5)

let e2 = gcd_ext_pure(99, 78)
check("ext_gcd(99,78) gcd", e2[0], 3)
let bezout2 = 99 * e2[1] + 78 * e2[2]
check("ext_gcd(99,78) bezout", bezout2, 3)

let e3 = gcd_ext_pure(240, 46)
check("ext_gcd(240,46) gcd", e3[0], 2)
let bezout3 = 240 * e3[1] + 46 * e3[2]
check("ext_gcd(240,46) bezout", bezout3, 2)

// Coprime
let e4 = gcd_ext_pure(17, 13)
check("ext_gcd(17,13) gcd", e4[0], 1)
let bezout4 = 17 * e4[1] + 13 * e4[2]
check("ext_gcd(17,13) bezout", bezout4, 1)

// ────────────────────────────────────────────────────────────
// 4. mod_inv_pure — modular inverse
// ────────────────────────────────────────────────────────────
check("inv(3,7)", mod_inv_pure(3, 7), 5)
check("inv(2,5)", mod_inv_pure(2, 5), 3)
check("inv(17,3120)", mod_inv_pure(17, 3120), 2753)

// Verify: (a * inv) mod m == 1
let inv_3_7 = mod_inv_pure(3, 7)
check("verify 3*inv mod 7", mod_mul_pure(3, inv_3_7, 7), 1)

let inv_17_3120 = mod_inv_pure(17, 3120)
check("verify 17*inv mod 3120", mod_mul_pure(17, inv_17_3120, 3120), 1)

// Non-coprime: no inverse exists
check("inv(4,6) none", mod_inv_pure(4, 6), -1)
check("inv(6,3) none", mod_inv_pure(6, 3), -1)
check("inv(0,5) none", mod_inv_pure(0, 5), -1)

// Edge: mod=1
check("inv(a,1)", mod_inv_pure(5, 1), 0)

// ────────────────────────────────────────────────────────────
// 5. Legacy aliases
// ────────────────────────────────────────────────────────────
check("legacy mod_exp", mod_exp(2, 10, 1000), 24)
check("legacy mod_inv", mod_inv(3, 7), 5)

// ────────────────────────────────────────────────────────────
// 6. gcd / lcm
// ────────────────────────────────────────────────────────────
check("gcd(12,8)", gcd(12, 8), 4)
check("gcd(7,13)", gcd(7, 13), 1)
check("gcd(0,5)", gcd(0, 5), 5)
check("gcd(-12,8)", gcd(-12, 8), 4)
check("lcm(4,6)", lcm(4, 6), 12)
check("lcm(0,5)", lcm(0, 5), 0)

// ────────────────────────────────────────────────────────────
// 7. is_prime_miller
// ────────────────────────────────────────────────────────────
check_bool("prime(2)", is_prime_miller(2, 5), true)
check_bool("prime(17)", is_prime_miller(17, 5), true)
check_bool("prime(97)", is_prime_miller(97, 7), true)
check_bool("prime(4)", is_prime_miller(4, 5), false)
check_bool("prime(1)", is_prime_miller(1, 5), false)
check_bool("prime(561 carmichael)", is_prime_miller(561, 7), false)

// ── Summary ──────────────────────────────────────────────────────
println("")
println("mod_exp_pure: " + to_string(pass) + " PASS, " + to_string(fail) + " FAIL")
if fail > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL PASS")
}
