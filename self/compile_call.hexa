// self/compile_call.hexa — P7-8 multi-arg (3-arg) native Mach-O emitter.
//
// Extends compile_add.hexa from 2-arg to 3-arg user-defined function, proving
// the AAPCS64 caller/callee register convention scales past 2 registers
// (x0, x1) into x2 under a real BL fixup.
//
// source (conceptual):
//   fn add3(a1: Int, a2: Int, a3: Int) -> Int { return a1 + a2 + a3 }
//   fn main() -> Int { return add3(10, 20, 12) }   // expect exit=42
//
// AAPCS64:
//   - caller puts integer args into x0, x1, x2, ..., x7 in order.
//   - callee returns integer in x0.
//   - leaf function with no locals → no frame (STP/LDP x29/x30) needed.
//
// emitted .text layout (forward BL from main → add3):
//   offset  instr                           mnemonic
//   ──────  ─────                           ────────
//     0     MOVZ  x0, #10                   ; main: arg1
//     4     MOVZ  x1, #20                   ; main: arg2
//     8     MOVZ  x2, #12                   ; main: arg3
//    12     BL    add3                      ; multi-arg call (BL fixup!)
//    16     MOVZ  x16, #0x0001
//    20     MOVK  x16, #0x0200, LSL #16     ; x16 = 0x2000001 (SYS_exit)
//    24     SVC   #0x80                     ; exit(add3_result)
//    28     ADD   x0, x0, x1                ; add3 entry: x0 = a1 + a2
//    32     ADD   x0, x0, x2                ; x0 = (a1+a2) + a3
//    36     RET   x30                       ; return to lr
//
// BL at byte 12 targets byte 28:
//   rel instructions = (28 - 12) / 4 = 4
//   BL encoding      = 0x94000000 | 4 = 0x94000004 (LE: 04 00 00 94)
//
// First MOVZ at byte 0 encodes #10 into x0:
//   0xD2800000 | (10 << 5) | 0 = 0xD2800140 (LE: 40 01 80 D2)
//
// Output: /tmp/hexa_call_native — runs, exits 42, zero clang / as / ld.

// ═══════════════════════════════════════════════════════════
//  Inline ARM64 encoders — mirror self/codegen/arm64.hexa so the
//  file is standalone under hexa_stage0. Identical to compile_add.hexa.
// ═══════════════════════════════════════════════════════════

fn emit32_le(code: [int], instr: int) -> [int] {
    let b0 = instr % 256
    let b1 = (instr / 256) % 256
    let b2 = (instr / 65536) % 256
    let b3 = (instr / 16777216) % 256
    return code.push(b0).push(b1).push(b2).push(b3)
}

// MOVZ Xd, #imm16, LSL #0   (0xD2800000 | (imm16 << 5) | Rd)
fn enc_movz(rd: int, imm16: int) -> int {
    return 0xd2800000 + (imm16 * 32) + rd
}

// MOVK Xd, #imm16, LSL #hw*16  (hw in 0..3)
fn enc_movk(rd: int, imm16: int, hw: int) -> int {
    return 0xf2800000 + (hw * 2097152) + (imm16 * 32) + rd
}

// SVC #imm16
fn enc_svc(imm16: int) -> int {
    return 0xd4000001 + (imm16 * 32)
}

// ADD Xd, Xn, Xm   (64-bit, shifted reg, shift=0)
//   0x8B000000 | (Rm << 16) | (Rn << 5) | Rd
fn enc_add_reg(rd: int, rn: int, rm: int) -> int {
    return 0x8b000000 + (rm * 65536) + (rn * 32) + rd
}

// RET Xn (default x30 = lr)
//   0xD65F0000 | (Rn << 5)
fn enc_ret(rn: int) -> int {
    return 0xd65f0000 + (rn * 32)
}

// BL <offset> — placeholder encoding (imm26 = 0). Patched later.
fn enc_bl_placeholder() -> int {
    return 0x94000000
}

// ═══════════════════════════════════════════════════════════
//  Multi-function BL fixup pass — mirrors compile_add.hexa.
// ═══════════════════════════════════════════════════════════

struct CallFixup {
    code_offset: int,     // byte offset in code where BL sits
    target_fid: int       // function ID to resolve
}

struct FuncSymbol {
    fid: int,
    offset: int           // byte offset of function entry
}

fn symtab_lookup(syms: [FuncSymbol], fid: int) -> int {
    let mut i = 0
    while i < len(syms) {
        if syms[i].fid == fid {
            return syms[i].offset
        }
        i = i + 1
    }
    return -1
}

// Patch BL placeholders into real relative offsets (signed imm26).
fn patch_call_fixups_arm64(code: [int], fixups: [CallFixup], syms: [FuncSymbol]) -> [int] {
    let mut c = code
    let mut i = 0
    while i < len(fixups) {
        let fx = fixups[i]
        let target_off = symtab_lookup(syms, fx.target_fid)
        if target_off >= 0 {
            let bl_off = fx.code_offset
            let rel = (target_off - bl_off) / 4
            let mut imm26 = rel % 67108864          // 2^26
            if imm26 < 0 { imm26 = imm26 + 67108864 }  // wrap negative
            let patched = 0x94000000 + imm26
            c[bl_off]     = patched % 256
            c[bl_off + 1] = (patched / 256) % 256
            c[bl_off + 2] = (patched / 65536) % 256
            c[bl_off + 3] = (patched / 16777216) % 256
        }
        i = i + 1
    }
    return c
}

// ═══════════════════════════════════════════════════════════
//  Build the .text section for the 2-function, 3-arg program.
//
//  Byte layout (see doc-comment above):
//    0:  MOVZ x0, #10      (arg1)
//    4:  MOVZ x1, #20      (arg2)
//    8:  MOVZ x2, #12      (arg3)
//   12:  BL   add3         (forward, fixup)
//   16:  MOVZ x16, #1
//   20:  MOVK x16, #0x200, LSL #16
//   24:  SVC  #0x80
//   28:  ADD  x0, x0, x1   (add3 entry)
//   32:  ADD  x0, x0, x2
//   36:  RET  x30
//
//  Fixup: BL@12 → add3@28, rel = (28-12)/4 = 4.
// ═══════════════════════════════════════════════════════════

fn build_text_section() -> [int] {
    let mut syms = []
    let mut fixups = []
    let mut bytes = []

    // ── Function 0: main ──
    let main_offset = len(bytes)                          // = 0
    syms = syms.push(FuncSymbol { fid: 0, offset: main_offset })

    bytes = emit32_le(bytes, enc_movz(0, 10))             // 0:  MOVZ x0, #10
    bytes = emit32_le(bytes, enc_movz(1, 20))             // 4:  MOVZ x1, #20
    bytes = emit32_le(bytes, enc_movz(2, 12))             // 8:  MOVZ x2, #12
    // Record BL fixup BEFORE emitting the placeholder so code_offset
    // matches the byte where the BL word will start.
    fixups = fixups.push(CallFixup {
        code_offset: len(bytes),                           // = 12
        target_fid: 1                                      // → function `add3`
    })
    bytes = emit32_le(bytes, enc_bl_placeholder())        // 12: BL add3 (placeholder)
    bytes = emit32_le(bytes, enc_movz(16, 1))             // 16: MOVZ x16, #1
    bytes = emit32_le(bytes, enc_movk(16, 0x200, 1))      // 20: MOVK x16, #0x200, LSL #16
    bytes = emit32_le(bytes, enc_svc(0x80))               // 24: SVC #0x80

    // ── Function 1: add3 ──
    //   leaf, no locals, no frame → skip STP/LDP x29/x30.
    //   x30 (lr) already set by BL; RET x30 returns directly.
    let add3_offset = len(bytes)                           // = 28
    syms = syms.push(FuncSymbol { fid: 1, offset: add3_offset })

    bytes = emit32_le(bytes, enc_add_reg(0, 0, 1))        // 28: x0 = x0 + x1
    bytes = emit32_le(bytes, enc_add_reg(0, 0, 2))        // 32: x0 = x0 + x2
    bytes = emit32_le(bytes, enc_ret(30))                 // 36: RET x30

    // Multi-function link step — patch BL imm26.
    bytes = patch_call_fixups_arm64(bytes, fixups, syms)

    // Pad to 4-byte alignment (already aligned but be explicit).
    while len(bytes) % 4 != 0 {
        bytes = bytes.push(0)
    }
    return bytes
}

// ═══════════════════════════════════════════════════════════
//  Mach-O MH_EXECUTE wrapper — identical structure to compile_add.hexa.
// ═══════════════════════════════════════════════════════════

fn u32_to_hex(v: int, h: string) -> string {
    let mut parts = []
    parts.push(h[(v % 256) / 16])
    parts.push(h[(v % 256) % 16])
    parts.push(h[((v / 256) % 256) / 16])
    parts.push(h[((v / 256) % 256) % 16])
    parts.push(h[((v / 65536) % 256) / 16])
    parts.push(h[((v / 65536) % 256) % 16])
    parts.push(h[((v / 16777216) % 256) / 16])
    parts.push(h[((v / 16777216) % 256) % 16])
    return parts.join("")
}

fn u64_to_hex(v: int, h: string) -> string {
    let lo = v % 4294967296
    let hi = v / 4294967296
    return u32_to_hex(lo, h) + u32_to_hex(hi, h)
}

fn byte_to_hex(b: int, h: string) -> string {
    let mut parts = []
    parts.push(h[b / 16])
    parts.push(h[b % 16])
    return parts.join("")
}

fn build_macho_hex(text_bytes: [int]) -> string {
    let HEX = "0123456789abcdef"
    let MH_MAGIC_64 = 4277009103
    let CPU_ARM64   = 16777228
    let MH_EXECUTE  = 2
    let HDR_FLAGS   = 2097285
    let NCMDS       = 11
    let SIZEOFCMDS  = 576
    let PAGE        = 16384
    let CODE_OFF    = 768

    let code_bytes = len(text_bytes)
    let mut text_size_aligned = code_bytes
    if text_size_aligned % 4 != 0 {
        text_size_aligned = text_size_aligned + (4 - text_size_aligned % 4)
    }

    let mut parts = []
    let hdr_u32 = [MH_MAGIC_64, CPU_ARM64, 0, MH_EXECUTE, NCMDS, SIZEOFCMDS, HDR_FLAGS, 0]
    let mut hi = 0
    while hi < len(hdr_u32) {
        parts.push(u32_to_hex(hdr_u32[hi], HEX))
        hi = hi + 1
    }

    // LC_SEGMENT_64 __PAGEZERO
    parts.push("19000000" + "48000000")
    parts.push("5f5f504147455a45524f0000000000" + "00")
    parts.push("0000000000000000")
    parts.push("0000000001000000")
    parts.push("0000000000000000")
    parts.push("0000000000000000")
    parts.push("00000000" + "00000000" + "00000000" + "00000000")

    // LC_SEGMENT_64 __TEXT
    parts.push("19000000" + "98000000")
    parts.push("5f5f54455854000000000000000000" + "00")
    parts.push("0000000001000000")
    parts.push("0040000000000000")
    parts.push("0000000000000000")
    parts.push("0040000000000000")
    parts.push("05000000")
    parts.push("05000000")
    parts.push("01000000")
    parts.push("00000000")

    // section __text
    parts.push("5f5f74657874000000000000000000" + "00")
    parts.push("5f5f54455854000000000000000000" + "00")
    parts.push(u64_to_hex(4294967296 + CODE_OFF, HEX))
    parts.push(u64_to_hex(text_size_aligned, HEX))
    parts.push(u32_to_hex(CODE_OFF, HEX))
    parts.push("02000000")
    parts.push("00000000" + "00000000")
    parts.push("00040080")
    parts.push("00000000" + "00000000" + "00000000")

    // LC_SEGMENT_64 __LINKEDIT
    parts.push("19000000" + "48000000")
    parts.push("5f5f4c494e4b45444954000000000000")
    parts.push("0040000001000000")
    parts.push("0040000000000000")
    parts.push("0040000000000000")
    parts.push("3100000000000000")
    parts.push("01000000" + "01000000")
    parts.push("00000000" + "00000000")

    // LC_DYLD_CHAINED_FIXUPS
    parts.push("34000080" + "10000000" + "00400000" + "30000000")

    // LC_SYMTAB
    parts.push("02000000" + "18000000")
    parts.push("30400000")
    parts.push("00000000")
    parts.push("30400000")
    parts.push("01000000")

    // LC_DYSYMTAB
    parts.push("0b000000" + "50000000")
    let mut dyz_parts = []
    let mut dyz = 0
    while dyz < 72 {
        dyz_parts.push("00")
        dyz = dyz + 1
    }
    parts.push(dyz_parts.join(""))

    // LC_LOAD_DYLINKER
    parts.push("0e000000" + "20000000" + "0c000000")
    parts.push("2f7573722f6c69622f64796c6400")
    parts.push("000000000000")

    // LC_UUID
    parts.push("1b000000" + "18000000")
    parts.push("48455841414243444546303132333435")

    // LC_BUILD_VERSION
    parts.push("32000000" + "18000000")
    parts.push("01000000")
    parts.push("00000e00")
    parts.push("00000e00")
    parts.push("00000000")

    // LC_MAIN
    parts.push("28000080" + "18000000")
    parts.push(u64_to_hex(CODE_OFF, HEX))
    parts.push("0000000000000000")

    // LC_LOAD_DYLIB libSystem
    parts.push("0c000000" + "38000000")
    parts.push("18000000")
    parts.push("02000000")
    parts.push("00000100")
    parts.push("00000100")
    parts.push("2f7573722f6c69622f6c69625379737465")
    parts.push("6d2e422e64796c696200000000000000")

    let mut s = parts.join("")

    while (len(s) / 2) < CODE_OFF {
        s = s + "00"
    }

    let mut bi = 0
    while bi < len(text_bytes) {
        s = s + byte_to_hex(text_bytes[bi], HEX)
        bi = bi + 1
    }

    while (len(s) / 2) < PAGE {
        s = s + "00"
    }

    s = s + "00000000"
    s = s + "20000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "01000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "03000000"
    s = s + "00000000" + "00000000" + "00000000"
    s = s + "00"

    return s
}

// ═══════════════════════════════════════════════════════════
//  Driver
// ═══════════════════════════════════════════════════════════

println("=== P7-8 compile_call: multi-arg (3-arg AAPCS64) native Mach-O ===")
println("")
println("source (conceptual):")
println("  fn add3(a1, a2, a3) { return a1 + a2 + a3 }")
println("  fn main() { return add3(10, 20, 12) }   // expect exit=42")
println("")

// Step 1: emit .text with BL placeholder, then patch via fixup pass.
println("[1] emit .text with multi-arg BL fixup...")
let text = build_text_section()
println("  text bytes: " + to_string(len(text)))

// Verify first MOVZ x0, #10 at offset 0 is 40 01 80 D2:
//   enc_movz(0, 10) = 0xD2800000 | (10 << 5) | 0 = 0xD2800140
//   LE bytes: 40 01 80 D2
let m0 = text[0]
let m1 = text[1]
let m2 = text[2]
let m3 = text[3]
println("  MOVZ@0 bytes: " + to_string(m0) + " " + to_string(m1) + " " + to_string(m2) + " " + to_string(m3))
let movz_ok = m0 == 0x40 && m1 == 0x01 && m2 == 0x80 && m3 == 0xd2
if movz_ok {
    println("  [PASS] first MOVZ = 0xD2800140 (MOVZ x0, #10)")
} else {
    println("  [FAIL] first MOVZ encoding wrong — expected 40 01 80 D2")
}

// Verify MOVZ x2, #12 at offset 8:
//   enc_movz(2, 12) = 0xD2800000 | (12 << 5) | 2 = 0xD2800182
//   LE bytes: 82 01 80 D2
let m2a = text[8]
let m2b = text[9]
let m2c = text[10]
let m2d = text[11]
let movz_x2_ok = m2a == 0x82 && m2b == 0x01 && m2c == 0x80 && m2d == 0xd2
if movz_x2_ok {
    println("  [PASS] MOVZ x2, #12 @8 = 0xD2800182 (AAPCS64 3rd arg)")
} else {
    println("  [FAIL] MOVZ x2 wrong: got " + to_string(m2a) + " " + to_string(m2b) + " " + to_string(m2c) + " " + to_string(m2d))
}

// Verify BL patched correctly at offset 12: bytes 12..15 should be 04 00 00 94.
//   BL@12 → add3@28, rel = (28-12)/4 = 4, BL = 0x94000004.
let bl0 = text[12]
let bl1 = text[13]
let bl2 = text[14]
let bl3 = text[15]
println("  BL @12 bytes: " + to_string(bl0) + " " + to_string(bl1) + " " + to_string(bl2) + " " + to_string(bl3))
let bl_ok = bl0 == 4 && bl1 == 0 && bl2 == 0 && bl3 == 148
if bl_ok {
    println("  [PASS] BL imm26 = 4 (0x94000004, forward fixup to add3@28)")
} else {
    println("  [FAIL] BL fixup wrong — expected 04 00 00 94")
}

// Verify add3 entry = ADD x0, x0, x1 at offset 28:
//   enc_add_reg(0,0,1) = 0x8B000000 | (1<<16) | (0<<5) | 0 = 0x8B010000
//   LE bytes: 00 00 01 8B
let a0 = text[28]
let a1 = text[29]
let a2 = text[30]
let a3 = text[31]
let add_ok = a0 == 0x00 && a1 == 0x00 && a2 == 0x01 && a3 == 0x8b
if add_ok {
    println("  [PASS] add3 entry @28 = ADD x0, x0, x1 (0x8B010000)")
} else {
    println("  [FAIL] add3 entry wrong: got " + to_string(a0) + " " + to_string(a1) + " " + to_string(a2) + " " + to_string(a3))
}

// Verify RET x30 at offset 36:
//   enc_ret(30) = 0xD65F0000 | (30<<5) = 0xD65F03C0
//   LE bytes: C0 03 5F D6
let r0 = text[36]
let r1 = text[37]
let r2 = text[38]
let r3 = text[39]
let ret_ok = r0 == 0xc0 && r1 == 0x03 && r2 == 0x5f && r3 == 0xd6
if ret_ok {
    println("  [PASS] RET x30 @36 = 0xD65F03C0")
} else {
    println("  [FAIL] RET x30 wrong: got " + to_string(r0) + " " + to_string(r1) + " " + to_string(r2) + " " + to_string(r3))
}

// Step 2: wrap in Mach-O MH_EXECUTE.
println("[2] wrap in Mach-O MH_EXECUTE...")
let hex_data = build_macho_hex(text)
let macho_size = len(hex_data) / 2
println("  macho bytes: " + to_string(macho_size))

// Step 3: write /tmp/hexa_call_native.
println("[3] write /tmp/hexa_call_native...")
let out_path = "/tmp/hexa_call_native"
exec("printf '%s' '" + hex_data + "' | xxd -r -p > " + out_path)

// Step 4: chmod +x.
println("[4] chmod +x...")
exec("chmod +x " + out_path)

// Step 5: codesign ad-hoc (required on Apple Silicon).
println("[5] codesign (ad-hoc)...")
let cs = exec_with_status("codesign --force --sign - " + out_path + " 2>&1")
if cs[1] != 0 {
    println("  WARN codesign rc=" + to_string(cs[1]) + ": " + cs[0].trim())
}

// Step 6: run and capture exit code.
println("[6] run " + out_path + "...")
let r = exec_with_status(out_path + " 2>&1")
let exit_code = r[1]
println("  exit code = " + to_string(exit_code))

// Step 6b: xxd proof of BL fixup and first MOVZ.
println("[6b] xxd proof of BL fixup + first MOVZ (CODE_OFF=0x300)...")
let xxd = exec_with_status("xxd -s 0x300 -l 48 " + out_path)
println(xxd[0].trim())

println("")
println("=== doc-assert ===")
let want_rc = 42
let pass_rc = exit_code == want_rc

if movz_ok {
    println("  [PASS] first MOVZ x0,#10 encoded correctly")
} else {
    println("  [FAIL] first MOVZ encoding wrong")
}
if movz_x2_ok {
    println("  [PASS] MOVZ x2,#12 encoded (AAPCS64 3rd arg reg)")
} else {
    println("  [FAIL] MOVZ x2,#12 wrong")
}
if bl_ok {
    println("  [PASS] BL fixup patched (forward 4 instrs)")
} else {
    println("  [FAIL] BL fixup not patched correctly")
}
if add_ok {
    println("  [PASS] add3 callee first ADD encoded")
} else {
    println("  [FAIL] add3 callee ADD wrong")
}
if ret_ok {
    println("  [PASS] RET x30 terminates callee")
} else {
    println("  [FAIL] RET x30 wrong")
}
if pass_rc {
    println("  [PASS] exit == 42  (add3(10, 20, 12) = 42)")
} else {
    println("  [FAIL] exit mismatch: got " + to_string(exit_code) + " want " + to_string(want_rc))
}

if bl_ok {
    if pass_rc {
        println("")
        println("PASS — 3-arg AAPCS64 native Mach-O emitted by pure Hexa.")
        println("Proves BL fixup + caller x0/x1/x2 + leaf callee ABI.")
        println("  artifact: " + out_path)
        println("  size:     " + to_string(macho_size) + " bytes")
    }
}
