// ═══════════════════════════════════════════════════════════════
//  self/alloc/mod.hexa — Egyptian Memory Allocator module root.
//
//  Ports src/alloc/mod.rs (11 LOC) — re-export of egyptian.hexa.
//  Zero fragmentation by design. Three zones:
//    - Hot  (1/2): Stack region, fastest access
//    - Warm (1/3): Heap region, GC-managed
//    - Cold (1/6): Arena region, bulk-freed
// ═══════════════════════════════════════════════════════════════

// In hexa the sibling file self/alloc/egyptian.hexa defines:
//   struct ZoneStats, struct Zone, struct EgyptianAllocator,
//   struct DefragReport, struct AllocReport, struct FreeBlock
// and all free functions listed below. This mod.hexa is a manifest
// that documents the public surface (Rust pub re-exports).

// Public re-exports (documentation only — hexa has no `pub use`):
//   EgyptianAllocator, ZoneStats, DefragReport, AllocReport
//
//   egyptian_alloc_new(total_bytes) -> EgyptianAllocator
//   egyptian_alloc_hot(a, size)     -> int  (offset or -1)
//   egyptian_alloc_warm(a, size)    -> int
//   egyptian_alloc_cold(a, size)    -> int
//   egyptian_free_hot(a, off, size) -> bool
//   egyptian_free_warm(a, off, size)-> bool
//   egyptian_free_cold(a, off, size)-> bool
//   egyptian_alloc_auto(a, size)    -> int
//   egyptian_reset_arena(a)         -> EgyptianAllocator
//   egyptian_report(a)              -> AllocReport
//   egyptian_defrag_hints(a)        -> DefragReport
//   egyptian_zone_stats(a)          -> array of 3 ZoneStats
//   egyptian_record_cold_access(a, off)
//   egyptian_cold_promotion_candidates(a) -> array of int
