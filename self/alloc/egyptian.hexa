// ═══════════════════════════════════════════════════════════════
//  self/alloc/egyptian.hexa — Egyptian Fraction Allocator
//                             1/2 + 1/3 + 1/6 = 1
//
//  Port of src/alloc/egyptian.rs (625 LOC incl. tests).
//  Hexa uses integer offsets instead of raw pointers (*mut u8),
//  because raw pointer arithmetic is not part of the hexa surface.
//  An offset of -1 means "allocation failed / not in this zone".
//
//  Zone A (Hot,  1/2): 4096-byte blocks — stack frames, locals
//  Zone B (Warm, 1/3): 1024-byte blocks — heap objects
//  Zone C (Cold, 1/6):  256-byte blocks — arena / bulk
//
//  n=6 promotion threshold: accessed > 6 times -> promotion candidate.
//  Defrag alarm: free list total > 1/6 of zone -> needs compaction.
// ═══════════════════════════════════════════════════════════════

// ── Constants (block sizes derived from n=6 arithmetic) ────────
fn block_a() { return 4096 }   // 1 << 12 = 2^sigma
fn block_b() { return 1024 }   // 1 << 10 = 2^(sigma-phi)
fn block_c() { return 256  }   // 1 << 8  = 2^(sigma-tau)
fn promotion_threshold() { return 6 }
fn defrag_ratio_numerator()   { return 1 }
fn defrag_ratio_denominator() { return 6 }

// ── FreeBlock: a freed region tracked in the free list ─────────
struct FreeBlock {
    offset: int,
    size: int
}

// ── ZoneStats: per-zone allocation statistics ──────────────────
struct ZoneStats {
    alloc_count: int,
    free_count: int,
    reuse_count: int,
    total_allocated_bytes: int,
    total_freed_bytes: int
}

fn zone_stats_default() {
    return ZoneStats {
        alloc_count: 0,
        free_count: 0,
        reuse_count: 0,
        total_allocated_bytes: 0,
        total_freed_bytes: 0
    }
}

// ── Zone: backing store + free list + per-offset access counts ─
//   base_len  : capacity in bytes (we only track length, not real bytes)
//   free_list : array of FreeBlock
//   access_counts_off / access_counts_n : parallel arrays
//                                         (hexa has no tuple-in-array idiom)
struct Zone {
    base_len: int,
    block_size: int,
    next_free: int,
    allocated: int,
    free_list: array,
    stats: ZoneStats,
    access_counts_off: array,
    access_counts_n: array
}

fn zone_new(capacity, block_size) {
    return Zone {
        base_len: capacity,
        block_size: block_size,
        next_free: 0,
        allocated: 0,
        free_list: [],
        stats: zone_stats_default(),
        access_counts_off: [],
        access_counts_n: []
    }
}

// Align size up to block boundary.
fn zone_align_size(z: Zone, size) {
    let bs = z.block_size
    return (size + bs - 1) / bs * bs
}

// Find best-fit block in free list (smallest block >= required size).
// Returns index or -1.
fn zone_find_best_fit(z: Zone, required) {
    let fl = z.free_list
    let n = len(fl)
    let mut best_idx = -1
    let mut best_size = 0
    let mut i = 0
    while i < n {
        let b = fl[i]
        if b.size >= required {
            if best_idx < 0 {
                best_idx = i
                best_size = b.size
            } else {
                if b.size < best_size {
                    best_idx = i
                    best_size = b.size
                }
            }
        }
        i = i + 1
    }
    return best_idx
}

// Allocation result: (new_zone, offset). offset = -1 on failure.
struct AllocOut {
    zone: Zone,
    offset: int
}

// Try to allocate from free list first (best-fit), then bump.
fn zone_alloc(z: Zone, size) {
    let aligned = zone_align_size(z, size)

    // 1. Check free list — best-fit strategy
    let idx = zone_find_best_fit(z, aligned)
    if idx >= 0 {
        let fl_old = z.free_list
        let block = fl_old[idx]
        // Build new free list: old minus idx, plus remainder if any.
        let mut fl_new = []
        let mut i = 0
        let n = len(fl_old)
        while i < n {
            if i != idx {
                fl_new.push(fl_old[i])
            }
            i = i + 1
        }
        if block.size > aligned {
            fl_new.push(FreeBlock {
                offset: block.offset + aligned,
                size:   block.size - aligned
            })
        }
        let old_stats = z.stats
        let new_stats = ZoneStats {
            alloc_count: old_stats.alloc_count + 1,
            free_count:  old_stats.free_count,
            reuse_count: old_stats.reuse_count + 1,
            total_allocated_bytes: old_stats.total_allocated_bytes + aligned,
            total_freed_bytes:     old_stats.total_freed_bytes
        }
        let new_ac_off = z.access_counts_off.push(block.offset)
        let new_ac_n   = z.access_counts_n.push(0)
        let z2 = Zone {
            base_len: z.base_len,
            block_size: z.block_size,
            next_free: z.next_free,
            allocated: z.allocated + aligned,
            free_list: fl_new,
            stats: new_stats,
            access_counts_off: new_ac_off,
            access_counts_n:   new_ac_n
        }
        return AllocOut { zone: z2, offset: block.offset }
    }

    // 2. Bump allocation
    if z.next_free + aligned > z.base_len {
        return AllocOut { zone: z, offset: -1 }
    }
    let offset = z.next_free
    let old_stats2 = z.stats
    let new_stats2 = ZoneStats {
        alloc_count: old_stats2.alloc_count + 1,
        free_count:  old_stats2.free_count,
        reuse_count: old_stats2.reuse_count,
        total_allocated_bytes: old_stats2.total_allocated_bytes + aligned,
        total_freed_bytes:     old_stats2.total_freed_bytes
    }
    let new_ac_off2 = z.access_counts_off.push(offset)
    let new_ac_n2   = z.access_counts_n.push(0)
    let z3 = Zone {
        base_len: z.base_len,
        block_size: z.block_size,
        next_free: z.next_free + aligned,
        allocated: z.allocated + aligned,
        free_list: z.free_list,
        stats: new_stats2,
        access_counts_off: new_ac_off2,
        access_counts_n:   new_ac_n2
    }
    return AllocOut { zone: z3, offset: offset }
}

// Dealloc result: (new_zone, ok_bool)
struct DeallocOut {
    zone: Zone,
    ok: bool
}

// Free a region back to the free list.
fn zone_dealloc(z: Zone, offset, size) {
    if offset < 0 {
        return DeallocOut { zone: z, ok: false }
    }
    if offset >= z.base_len {
        return DeallocOut { zone: z, ok: false }
    }
    let aligned = zone_align_size(z, size)
    if offset + aligned > z.base_len {
        return DeallocOut { zone: z, ok: false }
    }
    let fl_new = z.free_list.push(FreeBlock { offset: offset, size: aligned })
    let old_stats = z.stats
    // saturating_sub
    let mut new_alloc = z.allocated - aligned
    if new_alloc < 0 { new_alloc = 0 }
    let new_stats = ZoneStats {
        alloc_count: old_stats.alloc_count,
        free_count:  old_stats.free_count + 1,
        reuse_count: old_stats.reuse_count,
        total_allocated_bytes: old_stats.total_allocated_bytes,
        total_freed_bytes:     old_stats.total_freed_bytes + aligned
    }
    // Remove offset from access tracking.
    let mut new_ac_off = []
    let mut new_ac_n = []
    let ao = z.access_counts_off
    let an = z.access_counts_n
    let nn = len(ao)
    let mut i = 0
    while i < nn {
        if ao[i] != offset {
            new_ac_off.push(ao[i])
            new_ac_n.push(an[i])
        }
        i = i + 1
    }
    let z2 = Zone {
        base_len: z.base_len,
        block_size: z.block_size,
        next_free: z.next_free,
        allocated: new_alloc,
        free_list: fl_new,
        stats: new_stats,
        access_counts_off: new_ac_off,
        access_counts_n:   new_ac_n
    }
    return DeallocOut { zone: z2, ok: true }
}

// Record an access to a given offset for temperature tracking.
fn zone_record_access(z: Zone, offset) {
    if offset < 0 { return z }
    if offset >= z.base_len { return z }
    let ao = z.access_counts_off
    let an = z.access_counts_n
    let n = len(ao)
    let mut new_n = []
    let mut hit = false
    let mut i = 0
    while i < n {
        if ao[i] == offset {
            new_n.push(an[i] + 1)
            hit = true
        } else {
            new_n.push(an[i])
        }
        i = i + 1
    }
    if hit == false { return z }
    return Zone {
        base_len: z.base_len,
        block_size: z.block_size,
        next_free: z.next_free,
        allocated: z.allocated,
        free_list: z.free_list,
        stats: z.stats,
        access_counts_off: ao,
        access_counts_n:   new_n
    }
}

// Return offsets that exceed the promotion threshold (>6 accesses).
fn zone_promotion_candidates(z: Zone) {
    let ao = z.access_counts_off
    let an = z.access_counts_n
    let n = len(ao)
    let thr = promotion_threshold()
    let mut out = []
    let mut i = 0
    while i < n {
        if an[i] > thr {
            out.push(ao[i])
        }
        i = i + 1
    }
    return out
}

// Check if zone needs defragmentation:
// free list total > 1/6 of zone capacity.
fn zone_needs_defrag(z: Zone) {
    let fl = z.free_list
    let n = len(fl)
    let mut total = 0
    let mut i = 0
    while i < n {
        total = total + fl[i].size
        i = i + 1
    }
    let num = defrag_ratio_numerator()
    let den = defrag_ratio_denominator()
    let threshold = z.base_len * num / den
    return total > threshold
}

fn zone_fragment_count(z: Zone) {
    return len(z.free_list)
}

// Reset live state. Keep cumulative stats.
fn zone_reset(z: Zone) {
    return Zone {
        base_len: z.base_len,
        block_size: z.block_size,
        next_free: 0,
        allocated: 0,
        free_list: [],
        stats: z.stats,
        access_counts_off: [],
        access_counts_n: []
    }
}

fn zone_capacity(z: Zone) { return z.base_len }
fn zone_used(z: Zone)     { return z.allocated }
fn zone_free_space(z: Zone) { return zone_capacity(z) - zone_used(z) }

// ═══════════════════════════════════════════════════════════════
//  EgyptianAllocator
// ═══════════════════════════════════════════════════════════════

struct EgyptianAllocator {
    total_bytes: int,
    zone_a: Zone,
    zone_b: Zone,
    zone_c: Zone
}

fn egyptian_alloc_new(total_bytes) {
    // 1/2 + 1/3 + 1/6 = 1
    let a_size = total_bytes / 2
    let b_size = total_bytes / 3
    let c_size = total_bytes / 6
    let remainder = total_bytes - a_size - b_size - c_size
    return EgyptianAllocator {
        total_bytes: total_bytes,
        zone_a: zone_new(a_size + remainder, block_a()),
        zone_b: zone_new(b_size, block_b()),
        zone_c: zone_new(c_size, block_c())
    }
}

// Allocation returns (new_allocator, offset). offset = -1 on failure.
struct EgAllocOut {
    alloc: EgyptianAllocator,
    offset: int
}

fn egyptian_alloc_hot(a: EgyptianAllocator, size) {
    let out = zone_alloc(a.zone_a, size)
    let a2 = EgyptianAllocator {
        total_bytes: a.total_bytes,
        zone_a: out.zone,
        zone_b: a.zone_b,
        zone_c: a.zone_c
    }
    return EgAllocOut { alloc: a2, offset: out.offset }
}

fn egyptian_alloc_warm(a: EgyptianAllocator, size) {
    let out = zone_alloc(a.zone_b, size)
    let a2 = EgyptianAllocator {
        total_bytes: a.total_bytes,
        zone_a: a.zone_a,
        zone_b: out.zone,
        zone_c: a.zone_c
    }
    return EgAllocOut { alloc: a2, offset: out.offset }
}

fn egyptian_alloc_cold(a: EgyptianAllocator, size) {
    let out = zone_alloc(a.zone_c, size)
    let a2 = EgyptianAllocator {
        total_bytes: a.total_bytes,
        zone_a: a.zone_a,
        zone_b: a.zone_b,
        zone_c: out.zone
    }
    return EgAllocOut { alloc: a2, offset: out.offset }
}

// Free returns (new_allocator, ok).
struct EgFreeOut {
    alloc: EgyptianAllocator,
    ok: bool
}

fn egyptian_free_hot(a: EgyptianAllocator, offset, size) {
    let out = zone_dealloc(a.zone_a, offset, size)
    let a2 = EgyptianAllocator {
        total_bytes: a.total_bytes,
        zone_a: out.zone,
        zone_b: a.zone_b,
        zone_c: a.zone_c
    }
    return EgFreeOut { alloc: a2, ok: out.ok }
}

fn egyptian_free_warm(a: EgyptianAllocator, offset, size) {
    let out = zone_dealloc(a.zone_b, offset, size)
    let a2 = EgyptianAllocator {
        total_bytes: a.total_bytes,
        zone_a: a.zone_a,
        zone_b: out.zone,
        zone_c: a.zone_c
    }
    return EgFreeOut { alloc: a2, ok: out.ok }
}

fn egyptian_free_cold(a: EgyptianAllocator, offset, size) {
    let out = zone_dealloc(a.zone_c, offset, size)
    let a2 = EgyptianAllocator {
        total_bytes: a.total_bytes,
        zone_a: a.zone_a,
        zone_b: a.zone_b,
        zone_c: out.zone
    }
    return EgFreeOut { alloc: a2, ok: out.ok }
}

// Record cold-zone access.
fn egyptian_record_cold_access(a: EgyptianAllocator, offset) {
    let z = zone_record_access(a.zone_c, offset)
    return EgyptianAllocator {
        total_bytes: a.total_bytes,
        zone_a: a.zone_a,
        zone_b: a.zone_b,
        zone_c: z
    }
}

// Cold promotion candidates (offsets accessed > 6 times).
fn egyptian_cold_promotion_candidates(a: EgyptianAllocator) {
    return zone_promotion_candidates(a.zone_c)
}

// Auto-select zone based on size heuristic.
fn egyptian_alloc_auto(a: EgyptianAllocator, size) {
    if size <= block_c() {
        // Small -> try cold first (arena), fallback hot
        let r1 = egyptian_alloc_cold(a, size)
        if r1.offset >= 0 { return r1 }
        return egyptian_alloc_hot(r1.alloc, size)
    }
    if size <= block_b() {
        // Medium -> warm zone, fallback hot
        let r2 = egyptian_alloc_warm(a, size)
        if r2.offset >= 0 { return r2 }
        return egyptian_alloc_hot(r2.alloc, size)
    }
    // Large -> hot zone
    return egyptian_alloc_hot(a, size)
}

// Reset cold zone (arena bulk-free).
fn egyptian_reset_arena(a: EgyptianAllocator) {
    return EgyptianAllocator {
        total_bytes: a.total_bytes,
        zone_a: a.zone_a,
        zone_b: a.zone_b,
        zone_c: zone_reset(a.zone_c)
    }
}

fn egyptian_total(a: EgyptianAllocator) { return a.total_bytes }

// Per-zone statistics — array of 3 ZoneStats.
fn egyptian_zone_stats(a: EgyptianAllocator) {
    return [a.zone_a.stats, a.zone_b.stats, a.zone_c.stats]
}

// ═══════════════════════════════════════════════════════════════
//  DefragReport
// ═══════════════════════════════════════════════════════════════

struct DefragReport {
    hot_needs_compaction: bool,
    hot_fragments: int,
    warm_needs_compaction: bool,
    warm_fragments: int,
    cold_needs_compaction: bool,
    cold_fragments: int
}

fn egyptian_defrag_hints(a: EgyptianAllocator) {
    return DefragReport {
        hot_needs_compaction:  zone_needs_defrag(a.zone_a),
        hot_fragments:         zone_fragment_count(a.zone_a),
        warm_needs_compaction: zone_needs_defrag(a.zone_b),
        warm_fragments:        zone_fragment_count(a.zone_b),
        cold_needs_compaction: zone_needs_defrag(a.zone_c),
        cold_fragments:        zone_fragment_count(a.zone_c)
    }
}

fn defrag_report_display(r: DefragReport) {
    let mut s = "Defrag Hints (threshold: > 1/"
    s = s + to_string(defrag_ratio_denominator()) + " of zone)\n"
    let mut hot_s = "ok"
    if r.hot_needs_compaction { hot_s = "NEEDED" }
    let mut warm_s = "ok"
    if r.warm_needs_compaction { warm_s = "NEEDED" }
    let mut cold_s = "ok"
    if r.cold_needs_compaction { cold_s = "NEEDED" }
    s = s + "  Hot:  " + to_string(r.hot_fragments)  + " fragments, compaction " + hot_s  + "\n"
    s = s + "  Warm: " + to_string(r.warm_fragments) + " fragments, compaction " + warm_s + "\n"
    s = s + "  Cold: " + to_string(r.cold_fragments) + " fragments, compaction " + cold_s + "\n"
    return s
}

// ═══════════════════════════════════════════════════════════════
//  AllocReport
// ═══════════════════════════════════════════════════════════════

struct AllocReport {
    total: int,
    hot_used: int,
    hot_cap: int,
    warm_used: int,
    warm_cap: int,
    cold_used: int,
    cold_cap: int
}

fn egyptian_report(a: EgyptianAllocator) {
    return AllocReport {
        total:     a.total_bytes,
        hot_used:  zone_used(a.zone_a),
        hot_cap:   zone_capacity(a.zone_a),
        warm_used: zone_used(a.zone_b),
        warm_cap:  zone_capacity(a.zone_b),
        cold_used: zone_used(a.zone_c),
        cold_cap:  zone_capacity(a.zone_c)
    }
}

fn alloc_report_utilization(r: AllocReport) {
    let used = r.hot_used + r.warm_used + r.cold_used
    if r.total == 0 { return 0 }
    // integer percent (x1000); hexa defaults to int math here.
    return used * 1000 / r.total
}

// Egyptian fractions guarantee zero external fragmentation by design.
fn alloc_report_fragmentation(r: AllocReport) { return 0 }

fn alloc_report_display(r: AllocReport) {
    let mut s = "Egyptian Allocator (1/2 + 1/3 + 1/6 = 1)\n"
    s = s + "  Hot  (1/2): " + to_string(r.hot_used)  + "/" + to_string(r.hot_cap)  + " bytes\n"
    s = s + "  Warm (1/3): " + to_string(r.warm_used) + "/" + to_string(r.warm_cap) + " bytes\n"
    s = s + "  Cold (1/6): " + to_string(r.cold_used) + "/" + to_string(r.cold_cap) + " bytes\n"
    s = s + "  Fragmentation: 0%\n"
    return s
}

// ═══════════════════════════════════════════════════════════════
//  Tests (ported from #[cfg(test)] mod tests)
// ═══════════════════════════════════════════════════════════════

@test fn test_egyptian_fraction_sum() {
    // 1/2 + 1/3 + 1/6 = 1
    let total = 6000
    let a = total / 2
    let b = total / 3
    let c = total / 6
    if a + b + c != total { return false }
    return true
}

@test fn test_zone_sizes() {
    if block_a() != 4096 { return false }
    if block_b() != 1024 { return false }
    if block_c() != 256  { return false }
    return true
}

@test fn test_alloc_and_report() {
    let a = egyptian_alloc_new(6000)
    let r = egyptian_report(a)
    if r.total != 6000 { return false }
    if alloc_report_fragmentation(r) != 0 { return false }
    return true
}

@test fn test_hot_alloc() {
    let a = egyptian_alloc_new(60000)
    let out = egyptian_alloc_hot(a, 100)
    if out.offset < 0 { return false }
    let r = egyptian_report(out.alloc)
    if r.hot_used <= 0 { return false }
    return true
}

@test fn test_arena_reset() {
    let a0 = egyptian_alloc_new(60000)
    let out = egyptian_alloc_cold(a0, 100)
    let r1 = egyptian_report(out.alloc)
    if r1.cold_used <= 0 { return false }
    let a2 = egyptian_reset_arena(out.alloc)
    let r2 = egyptian_report(a2)
    if r2.cold_used != 0 { return false }
    return true
}

@test fn test_free_list_reuse_hot() {
    let a0 = egyptian_alloc_new(600000)
    let o1 = egyptian_alloc_hot(a0, 100)
    if o1.offset < 0 { return false }
    let used_after = egyptian_report(o1.alloc).hot_used
    let f1 = egyptian_free_hot(o1.alloc, o1.offset, 100)
    if f1.ok == false { return false }
    let o2 = egyptian_alloc_hot(f1.alloc, 100)
    if o2.offset != o1.offset { return false }
    if egyptian_report(o2.alloc).hot_used != used_after { return false }
    return true
}

@test fn test_free_list_reuse_warm() {
    let a0 = egyptian_alloc_new(600000)
    let o1 = egyptian_alloc_warm(a0, 200)
    if o1.offset < 0 { return false }
    let f1 = egyptian_free_warm(o1.alloc, o1.offset, 200)
    if f1.ok == false { return false }
    let o2 = egyptian_alloc_warm(f1.alloc, 200)
    if o2.offset != o1.offset { return false }
    return true
}

@test fn test_free_list_reuse_cold() {
    let a0 = egyptian_alloc_new(600000)
    let o1 = egyptian_alloc_cold(a0, 50)
    if o1.offset < 0 { return false }
    let f1 = egyptian_free_cold(o1.alloc, o1.offset, 50)
    if f1.ok == false { return false }
    let o2 = egyptian_alloc_cold(f1.alloc, 50)
    if o2.offset != o1.offset { return false }
    return true
}

@test fn test_zones_independent() {
    let a0 = egyptian_alloc_new(600000)
    let oh = egyptian_alloc_hot(a0, 100)
    let ow = egyptian_alloc_warm(oh.alloc, 100)
    let oc = egyptian_alloc_cold(ow.alloc, 100)
    if oh.offset < 0 { return false }
    if ow.offset < 0 { return false }
    if oc.offset < 0 { return false }

    // Free from wrong zone should fail. Offsets are zone-local indices,
    // so we mimic Rust's out-of-zone check by using out-of-range offsets.
    // (The rust version checks pointer ranges; hexa uses base_len bounds.)
    let a1 = oc.alloc
    // Correct zones should succeed.
    let fh = egyptian_free_hot(a1, oh.offset, 100)
    if fh.ok == false { return false }
    let fw = egyptian_free_warm(fh.alloc, ow.offset, 100)
    if fw.ok == false { return false }
    let fc = egyptian_free_cold(fw.alloc, oc.offset, 100)
    if fc.ok == false { return false }
    return true
}

@test fn test_cold_promotion_candidates() {
    let a0 = egyptian_alloc_new(600000)
    let o1 = egyptian_alloc_cold(a0, 50)
    if o1.offset < 0 { return false }
    let mut a = o1.alloc
    if len(egyptian_cold_promotion_candidates(a)) != 0 { return false }

    // 6 accesses — still below threshold
    let mut i = 0
    while i < 6 {
        a = egyptian_record_cold_access(a, o1.offset)
        i = i + 1
    }
    if len(egyptian_cold_promotion_candidates(a)) != 0 { return false }

    // 7th access pushes over the threshold
    a = egyptian_record_cold_access(a, o1.offset)
    if len(egyptian_cold_promotion_candidates(a)) != 1 { return false }
    return true
}

