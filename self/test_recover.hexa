// ═══════════════════════════════════════════════════════════
//  test_recover.hexa — Tests for the recover keyword
//  Runs through self-hosted pipeline: tokenize -> parse -> interpret
//  recover { ... }     — catches any panic/throw, returns nil on error
//  recover |e| { ... } — catches any panic/throw, binds error to e
// ═══════════════════════════════════════════════════════════

use "self/core/law_io"

let HEXA = "./hexa"
let SELF_DIR = "self"
let TMP_DIR = "/tmp/hexa_recover_test"

exec("mkdir -p " + TMP_DIR)

let mut pass_count = 0
let mut fail_count = 0

// ── Load self-hosting pipeline sources ──────────────────
let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
let parser_src = read_file(SELF_DIR + "/parser.hexa")
let interp_src = read_file(SELF_DIR + "/interpreter.hexa")

let pipeline_src = lexer_src + "\n" + parser_src + "\n" + interp_src + "\n"

println("═══════════════════════════════════════════════════════")
println("  recover keyword tests (self-hosted pipeline)")
println("═══════════════════════════════════════════════════════")
println("")

let MARKER = "___RECOVER_RESULT___"

fn run_test(name, hexa_source, expected) {
    let src_file = TMP_DIR + "/src_" + name + ".hexa"
    let driver_file = TMP_DIR + "/drv_" + name + ".hexa"

    safe_write_file(src_file, hexa_source)

    let driver_code = pipeline_src + "\n" + "println(\"" + MARKER + "\")\n" + "let __test_src = read_file(\"" + src_file + "\")\n" + "let __tokens = tokenize(__test_src)\n" + "let __ast = parse(__tokens)\n" + "interpret(__ast)\n" + "println(\"" + MARKER + "\")\n"

    safe_write_file(driver_file, driver_code)

    let result = exec(HEXA + " " + driver_file + " 2>&1")

    if type_of(result) == "error" {
        println("[FAIL] " + name + ": exec error")
        fail_count = fail_count + 1
        return false
    }

    // Extract output between markers
    let lines = result.split("\n")
    let mut capture = false
    let mut output_lines = []
    for line in lines {
        if line == MARKER {
            if capture {
                capture = false
            } else {
                capture = true
            }
        } else {
            if capture {
                output_lines = output_lines.push(line)
            }
        }
    }
    let actual = output_lines.join("\n")

    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
        return true
    } else {
        println("[FAIL] " + name)
        println("  expected: " + expected)
        println("  actual:   " + actual)
        fail_count = fail_count + 1
        return false
    }
}

// ── 1. Basic recover from throw ────────────────────────────
run_test("basic_recover", "let mut x = 0\nrecover {\n  x = 1\n  throw \"boom\"\n  x = 2\n}\nprintln(x)", "1")

// ── 2. Recover with error binding ──────────────────────────
run_test("recover_binding", "recover |e| {\n  throw 99\n}\nprintln(e)", "99")

// ── 3. Recover returns value on success (no panic) ─────────
run_test("recover_passthrough", "let mut x = 0\nrecover {\n  x = 42\n}\nprintln(x)", "42")

// ── 4. No panic case — code runs normally ──────────────────
run_test("no_panic_flow", "let mut a = 0\nrecover {\n  a = a + 1\n  a = a + 1\n  a = a + 1\n}\nprintln(a)", "3")

// ── 5. Nested recover — inner catches, outer untouched ─────
run_test("nested_recover", "let mut inner_caught = false\nrecover {\n  recover |e2| {\n    throw \"inner_boom\"\n  }\n  inner_caught = true\n}\nprintln(inner_caught)", "true")

// ── 6. Recover does not mask normal flow ───────────────────
run_test("recover_normal_flow", "let mut x = 0\nrecover {\n  x = 1\n}\nx = x + 1\nprintln(x)", "2")

// ── 7. Multiple sequential recovers ────────────────────────
run_test("sequential_recovers", "let mut count = 0\nrecover {\n  throw \"a\"\n  count = count + 1\n}\nrecover {\n  throw \"b\"\n  count = count + 1\n}\nrecover {\n  count = count + 1\n}\nprintln(count)", "1")

// ── 8. Recover with no-error binding — var not defined ─────
run_test("recover_no_error_passthrough", "let mut x = \"ok\"\nrecover |e7| {\n  x = \"still_ok\"\n}\nprintln(x)", "still_ok")

// ── 9. Recover with arithmetic ─────────────────────────────
run_test("recover_arithmetic", "let mut x = 10\nrecover {\n  x = x + 5\n  throw \"boom\"\n  x = x + 100\n}\nprintln(x)", "15")

// ── 10. Recover preserves state before throw ───────────────
run_test("recover_state_preservation", "let mut a = 0\nlet mut b = 0\nrecover {\n  a = 1\n  b = 2\n  throw \"stop\"\n  a = 99\n  b = 99\n}\nprintln(to_string(a) + \",\" + to_string(b))", "1,2")

// ── 11. Recover in loop ────────────────────────────────────
run_test("recover_in_loop", "let mut sum = 0\nlet mut i = 0\nwhile i < 5 {\n  recover {\n    if i == 2 { throw \"skip\" }\n    sum = sum + i\n  }\n  i = i + 1\n}\nprintln(sum)", "8")

// ── 12. Recover with string accumulation ───────────────────
run_test("recover_string_accum", "let mut s = \"\"\nrecover {\n  s = s + \"a\"\n  s = s + \"b\"\n  throw \"halt\"\n  s = s + \"c\"\n}\ns = s + \"d\"\nprintln(s)", "abd")

// ── 13. Recover returns nil on throw (no binding) ──────────
run_test("recover_nil_on_throw", "let mut x = 0\nrecover {\n  x = 42\n}\nprintln(x)", "42")

// ── 14. Double nested recover ──────────────────────────────
run_test("double_nested_recover", "let mut result = \"\"\nrecover {\n  result = result + \"A\"\n  recover {\n    result = result + \"B\"\n    throw \"inner\"\n    result = result + \"C\"\n  }\n  result = result + \"D\"\n}\nprintln(result)", "ABD")

// ── 15. Recover with function call ─────────────────────────
run_test("recover_fn_call", "fn boom() {\n  throw \"fn_boom\"\n}\nlet mut x = \"ok\"\nrecover {\n  boom()\n  x = \"unreachable\"\n}\nprintln(x)", "ok")

// ── 16. Recover binding captures message ───────────────────
run_test("recover_binding_msg", "let mut msg = \"\"\nrecover |e| {\n  throw \"hello_error\"\n}\nprintln(\"ok\")", "ok")

// ── 17. Recover with conditional throw ─────────────────────
run_test("recover_cond_no_throw", "let mut x = 0\nlet flag = false\nrecover {\n  if flag { throw \"nope\" }\n  x = 99\n}\nprintln(x)", "99")

// ── 18. Recover followed by normal code ────────────────────
run_test("recover_then_normal", "let mut x = 0\nrecover {\n  throw \"err\"\n}\nx = 42\nprintln(x)", "42")

// ── 19. Multiple recovers accumulate ───────────────────────
run_test("recover_multi_accum", "let mut count = 0\nrecover {\n  count = count + 1\n}\nrecover {\n  count = count + 1\n}\nrecover {\n  count = count + 1\n}\nprintln(count)", "3")

// ── 20. Recover with counter ───────────────────────────────
run_test("recover_counter", "let mut n = 0\nrecover {\n  n = n + 1\n  n = n + 1\n  throw \"stop\"\n  n = n + 1\n}\nn = n + 1\nprintln(n)", "3")

// ── 21. Recover deep fn chain ──────────────────────────────
run_test("recover_deep_chain", "fn c() { throw \"deep\" }\nfn b() { c() }\nfn a() { b() }\nlet mut x = \"ok\"\nrecover {\n  a()\n  x = \"bad\"\n}\nprintln(x)", "ok")

// ── 22. Recover no-op (empty block) ────────────────────────
run_test("recover_empty_block", "let mut x = 1\nrecover {\n}\nx = x + 1\nprintln(x)", "2")

// ── 23. Recover with binding and no throw ──────────────────
run_test("recover_binding_no_throw", "let mut x = 0\nrecover |e| {\n  x = 55\n}\nprintln(x)", "55")

// ── 24. Three sequential recovers with throws ──────────────
run_test("three_seq_throws", "let mut s = \"\"\nrecover {\n  s = s + \"A\"\n  throw \"e1\"\n}\nrecover {\n  s = s + \"B\"\n  throw \"e2\"\n}\nrecover {\n  s = s + \"C\"\n  throw \"e3\"\n}\nprintln(s)", "ABC")

// ── 25. Recover preserves surrounding state ────────────────
run_test("recover_surround", "let mut before = 10\nrecover {\n  throw \"x\"\n}\nlet after = before + 5\nprintln(after)", "15")

// ── Summary ────────────────────────────────────────────────
println("")
println("recover tests: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
if fail_count > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
