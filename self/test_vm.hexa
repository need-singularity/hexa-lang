#!hexa lax
// ═══════════════════════════════════════════════════════════
//  test_vm.hexa — E2E test: lexer -> parser -> compiler -> VM
//  Verifies the bytecode VM executes compiled programs correctly.
// ═══════════════════════════════════════════════════════════

use "self/stdlib/law_io"

let _hexa_root = if len(env_var("HEXA_LANG")) > 0 { env_var("HEXA_LANG") } else { "." }
let SELF_DIR = _hexa_root + "/self"
let HEXA_BIN = _hexa_root + "/hexa"

// Load pipeline source modules
let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
let parser_src = read_file(SELF_DIR + "/parser.hexa")
let compiler_src = read_file(SELF_DIR + "/compiler.hexa")
let vm_src = read_file(SELF_DIR + "/vm.hexa")

let pipeline = lexer_src + "\n" + parser_src + "\n" + compiler_src + "\n" + vm_src + "\n"

let mut pass_count = 0
let mut fail_count = 0

fn run_vm_test(name, source, expected) {
    // Build a driver that:
    //   1. tokenizes the source
    //   2. parses tokens -> AST
    //   3. compiles AST -> bytecode
    //   4. runs bytecode on VM (capturing output)
    //   5. prints the captured output for verification

    let src_file = "/tmp/__hexa_vm_test_src.hexa"
    let driver_file = "/tmp/__hexa_vm_test_driver.hexa"

    safe_write_file(src_file, source)

    let driver = pipeline + "\n" + "let __src = read_file(\"" + src_file + "\")\n" + "let __tokens = tokenize(__src)\n" + "let __ast = parse(__tokens)\n" + "let __code = compile(__ast)\n" + "let __consts = get_constants()\n" + "let __fns = get_functions()\n" + "let __local_count = get_local_count()\n" + "let __result = vm_run_capture(__code, __consts, __fns)\n" + "println(\"VM_START\")\n" + "println(__result)\n" + "println(\"VM_END\")\n"

    safe_write_file(driver_file, driver)

    let result = exec(HEXA_BIN + " " + driver_file + " 2>&1")

    // Extract VM output between VM_START and VM_END markers
    let mut vm_out = ""
    if type_of(result) == "string" {
        let lines = result.split("\n")
        let mut capturing = false
        let mut i = 0
        while i < len(lines) {
            let line = lines[i]
            if line == "VM_END" {
                capturing = false
            }
            if capturing {
                if vm_out != "" {
                    vm_out = vm_out + "\n"
                }
                vm_out = vm_out + line
            }
            if line == "VM_START" {
                capturing = true
            }
            i = i + 1
        }
    }

    if vm_out == expected {
        println("PASS: " + name + " -> \"" + vm_out + "\"")
        return true
    } else {
        println("FAIL: " + name)
        println("  expected: \"" + expected + "\"")
        println("  got:      \"" + vm_out + "\"")
        if type_of(result) == "string" {
            // Show first few lines of output for debugging
            let dbg_lines = result.split("\n")
            let mut k = 0
            let show = 5
            if len(dbg_lines) < show { show = len(dbg_lines) }
            // Show last lines (likely errors)
            let start = len(dbg_lines) - show
            if start < 0 { start = 0 }
            while k < show {
                if start + k < len(dbg_lines) {
                    println("  | " + dbg_lines[start + k])
                }
                k = k + 1
            }
        }
        return false
    }
}

// ═══════════════════════════════════════════════════════════
//  TEST CASES
// ═══════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════")
println("  HEXA Self-Hosting VM Test")
println("  .hexa -> lex -> parse -> compile -> VM")
println("═══════════════════════════════════════════════════════")
println("")

// Test 1: println(42)
if run_vm_test("println(42)", "println(42)", "42") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 2: let + arithmetic
if run_vm_test("let x = 10; println(x+5)", "let x = 10\nprintln(x + 5)", "15") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 3: function call
let t3 = "fn add(a, b) {\n  return a + b\n}\nprintln(add(3, 4))"
if run_vm_test("fn add(a,b) -> println(add(3,4))", t3, "7") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 4: multiple println
let t4 = "println(1)\nprintln(2)\nprintln(3)"
if run_vm_test("multiple println", t4, "1\n2\n3") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 5: comparison + if
let t5 = "let x = 10\nif x > 5 {\n  println(1)\n} else {\n  println(0)\n}"
if run_vm_test("if x > 5", t5, "1") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 6: while loop
let t6 = "let mut i = 0\nlet mut sum = 0\nwhile i < 5 {\n  i = i + 1\n  sum = sum + i\n}\nprintln(sum)"
if run_vm_test("while loop sum", t6, "15") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 7: recursive factorial
let t7 = "fn fact(n) {\n  if n <= 1 {\n    return 1\n  }\n  return n * fact(n - 1)\n}\nprintln(fact(6))"
if run_vm_test("factorial(6)", t7, "720") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 8: string println
if run_vm_test("println string", "println(\"hello\")", "hello") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 9: boolean
if run_vm_test("println(true)", "println(true)", "true") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 10: nested function calls
let t10 = "fn twice(x) {\n  return x * 2\n}\nfn quad(x) {\n  return twice(twice(x))\n}\nprintln(quad(5))"
if run_vm_test("nested fn calls", t10, "20") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// ═══════════════════════════════════════════════════════════
//  EXTENDED TESTS — Phase 3 gap coverage
// ═══════════════════════════════════════════════════════════

// Test 11: modulo
if run_vm_test("modulo", "println(17 % 5)", "2") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 12: negation
if run_vm_test("negation", "let x = 10\nprintln(0 - x)", "-10") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 13: not operator
if run_vm_test("not operator", "let x = false\nif !x {\n  println(1)\n} else {\n  println(0)\n}", "1") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 14: string concatenation
if run_vm_test("string concat", "let a = \"hello\"\nlet b = \" world\"\nprintln(a + b)", "hello world") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 15: array literal + index
let t15 = "let arr = [10, 20, 30]\nprintln(arr[1])"
if run_vm_test("array index", t15, "20") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 16: for-in loop with range
let t16 = "let mut s = 0\nlet mut i = 0
while i < 5 {\n  s = s + i\n}\nprintln(s)"
if run_vm_test("for-in range", t16, "10") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 17: fibonacci
let t17 = "fn fib(n) {\n  if n <= 1 { return n }\n  return fib(n - 1) + fib(n - 2)\n}\nprintln(fib(10))"
if run_vm_test("fibonacci(10)", t17, "55") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 18: else-if chain
let t18 = "let x = 2\nif x == 1 {\n  println(\"one\")\n} else if x == 2 {\n  println(\"two\")\n} else {\n  println(\"other\")\n}"
if run_vm_test("else-if chain", t18, "two") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 19: nested while loops
let t19 = "let mut total = 0\nlet mut i = 0\nwhile i < 3 {\n  let mut j = 0\n  while j < 3 {\n    total = total + 1\n    j = j + 1\n  }\n  i = i + 1\n}\nprintln(total)"
if run_vm_test("nested while", t19, "9") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 20: array creation + len
let t20 = "let arr = [10, 20, 30]\nprintln(len(arr))"
if run_vm_test("array len", t20, "3") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 21: boolean logic AND/OR
let t21 = "let a = true\nlet b = false\nif a && !b {\n  println(\"yes\")\n} else {\n  println(\"no\")\n}"
if run_vm_test("boolean AND/OR", t21, "yes") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 22: multiple return values via array
let t22 = "fn pair(a, b) {\n  return [a, b]\n}\nlet p = pair(3, 7)\nprintln(p[0] + p[1])"
if run_vm_test("return array", t22, "10") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 23: early return from function
let t23 = "fn early(x) {\n  if x < 0 { return -1 }\n  return 1\n}\nprintln(early(-5))\nprintln(early(5))"
if run_vm_test("early return", t23, "-1\n1") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 24: float arithmetic
if run_vm_test("float arith", "println(2.5 + 1.5)", "4.0") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 25: deep recursion + multiple args
let t25 = "fn power(base, exp) {\n  if exp == 0 { return 1 }\n  return base * power(base, exp - 1)\n}\nprintln(power(2, 10))"
if run_vm_test("power(2,10)", t25, "1024") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL TESTS PASSED -- Self-hosting bytecode VM verified!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")

// Cleanup
exec("rm -f /tmp/__hexa_vm_test_src.hexa /tmp/__hexa_vm_test_driver.hexa")
