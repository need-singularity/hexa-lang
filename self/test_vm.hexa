let t28 = "fn abs(x) {\n  if x < 0 {\n    return 0 - x\n  }\n  return x\n}\nprintln(abs(5))\nprintln(abs(-3))\nprintln(abs(0))"
if run_vm_test("abs with multiple returns", t28, "5\n3\n0") {
