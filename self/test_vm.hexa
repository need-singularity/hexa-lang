// Test 14: Nested if/else — 3 levels deep
let t14 = "let x = 15\nif x > 20 {\n  println(\"big\")\n} else {\n  if x > 10 {\n    println(\"medium\")\n  } else {\n    println(\"small\")\n  }\n}"
if run_vm_test("nested if/else", t14, "medium") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 15: Multiple functions calling each other
let t15 = "fn double(x) {\n  return x * 2\n}\nfn add_one(x) {\n  return x + 1\n}\nfn transform(x) {\n  return add_one(double(x))\n}\nprintln(transform(5))\nprintln(transform(10))"
if run_vm_test("multi-fn chain", t15, "11\n21") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 16: Comparison operators — all 6
let t16 = "println(5 == 5)\nprintln(5 != 3)\nprintln(3 < 5)\nprintln(5 > 3)\nprintln(3 <= 3)\nprintln(5 >= 5)"
if run_vm_test("all 6 comparisons", t16, "true\ntrue\ntrue\ntrue\ntrue\ntrue") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 17: Comparison operators — false cases
let t17 = "println(5 == 3)\nprintln(5 != 5)\nprintln(5 < 3)\nprintln(3 > 5)\nprintln(5 <= 3)\nprintln(3 >= 5)"
if run_vm_test("all 6 comparisons (false)", t17, "false\nfalse\nfalse\nfalse\nfalse\nfalse") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 18: Logical operators && || !
let t18 = "println(true && true)\nprintln(true && false)\nprintln(false || true)\nprintln(false || false)\nprintln(!true)\nprintln(!false)"
if run_vm_test("logical && || !", t18, "true\nfalse\ntrue\nfalse\nfalse\ntrue") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 19: Fibonacci via VM (iterative)
let t19 = "fn fib(n) {\n  if n <= 1 {\n    return n\n  }\n  let mut a = 0\n  let mut b = 1\n  let mut i = 2\n  while i <= n {\n    let tmp = a + b\n    a = b\n    b = tmp\n    i = i + 1\n  }\n  return b\n}\nprintln(fib(0))\nprintln(fib(1))\nprintln(fib(10))\nprintln(fib(20))"
if run_vm_test("fibonacci iterative", t19, "0\n1\n55\n6765") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 20: Fibonacci via VM (recursive)
let t20 = "fn fib(n) {\n  if n <= 1 {\n    return n\n  }\n  return fib(n - 1) + fib(n - 2)\n}\nprintln(fib(10))"
if run_vm_test("fibonacci recursive", t20, "55") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 21: Format / string building through VM
let t21 = "let x = 42\nlet name = \"hexa\"\nprintln(\"value=\" + to_string(x))\nprintln(\"lang=\" + name)"
if run_vm_test("format string building", t21, "value=42\nlang=hexa") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 22: Nested if/else chain (if/else if/else)
let t22 = "fn grade(score) {\n  if score >= 90 {\n    return \"A\"\n  } else {\n    if score >= 80 {\n      return \"B\"\n    } else {\n      if score >= 70 {\n        return \"C\"\n      } else {\n        return \"F\"\n      }\n    }\n  }\n}\nprintln(grade(95))\nprintln(grade(85))\nprintln(grade(75))\nprintln(grade(60))"
if run_vm_test("nested if/else chain", t22, "A\nB\nC\nF") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 23: Array literal creation + iteration
let t23 = "let arr = [10, 20, 30, 40, 50]\nlet mut sum = 0\nlet mut i = 0\nwhile i < len(arr) {\n  sum = sum + arr[i]\n  i = i + 1\n}\nprintln(sum)"
if run_vm_test("array iteration sum", t23, "150") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 24: Modulo and negative arithmetic
let t24 = "println(17 % 5)\nprintln(10 - 15)\nprintln(3 * 0)"
if run_vm_test("modulo + negative + zero mul", t24, "2\n-5\n0") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 25: Mutual recursion — is_even / is_odd
let t25 = "fn is_even(n) {\n  if n == 0 {\n    return true\n  }\n  return is_odd(n - 1)\n}\nfn is_odd(n) {\n  if n == 0 {\n    return false\n  }\n  return is_even(n - 1)\n}\nprintln(is_even(4))\nprintln(is_odd(4))\nprintln(is_even(7))\nprintln(is_odd(7))"
if run_vm_test("mutual recursion", t25, "true\nfalse\nfalse\ntrue") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}

// Test 26: Empty array + len
let t26 = "let arr = []\nprintln(len(arr))"
if run_vm_test("empty array len", t26, "0") {
    pass_count = pass_count + 1
