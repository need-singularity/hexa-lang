// ═══════════════════════════════════════════════════════════════════
//  test_loss_scaling.hexa — ROI #104 correctness suite
//
//  Validates self/ai_native/loss_scaling.hexa:
//    T1   Normal grads -> scale grows after growth_interval steps
//    T2   Inf grads -> scale shrinks, skip_step=true
//    T3   Nan grads -> scale shrinks, skip_step=true
//    T4   Growth interval respected (no premature growth)
//    T5   Edge: scale=1.0 identity
//    T6   Edge: scale very large -> overflow -> backoff
//    T7   Round-trip: scale up then down recovers
//    T8   Empty grads -> has_zero=true, no inf/nan
//    T9   ls_scale_loss exact multiply
//    T10  AST detect unscaled backward
//    T11  AST detect already-scaled (no rewrite needed)
//    T12  AST rewrite wraps backward with scale
//    T13  All-zero grads -> scale still grows (not skipped)
//    T14  Multiple inf/nan cycles then recovery
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ai_native/loss_scaling.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ai_native/loss_scaling.hexa — AI-native ROI #104
//
//  @loss_scaling — dynamic loss scaling for fp16 / mixed-precision
//  training. When gradients underflow (become zero in fp16), scale
//  the loss upward; when they overflow (inf/nan), scale downward.
//
//  Without loss scaling, fp16 training frequently diverges because
//  small gradients clip to zero. The naive fix (manually picking a
//  fixed scale) is fragile; the AI-native approach auto-adjusts the
//  scale every step based on gradient health.
//
//  Public API  (ls_ prefix)
//  ────────────────────────
//      ls_init_state(init_scale, growth_factor, backoff_factor,
//                    growth_interval) -> map
//          • init_scale      : float > 0   (e.g. 65536.0)
//          • growth_factor   : float > 1   (e.g. 2.0)
//          • backoff_factor  : float in (0,1) (e.g. 0.5)
//          • growth_interval : int >= 1    (e.g. 2000)
//          • returns #{scale, growth_factor, backoff_factor,
//                      growth_interval, good_steps}
//
//      ls_scale_loss(loss, state) -> float
//          • returns loss * state["scale"]
//
//      ls_check_grads(grads) -> map #{has_inf, has_nan, has_zero}
//          • scans gradient array for inf / nan / all-zero
//
//      ls_update_scale(state, grad_check) -> map
//          • if inf or nan: scale *= backoff_factor, good_steps=0,
//            skip_step = true
//          • else: good_steps += 1; if good_steps >= growth_interval
//            then scale *= growth_factor, good_steps = 0
//          • returns new state map (same keys + skip_step)
//
//      ls_step(state, loss, grads) -> map #{scaled_loss, new_state,
//                                           skip_step}
//          • convenience: full pipeline in one call
//
//      detect_unscaled_loss(prog) -> bool
//          • AST predicate: returns true iff prog contains a
//            "backward" node with no "loss_scale" annotation.
//
//      rewrite_add_loss_scaling(prog) -> Program
//          • If detect_unscaled_loss(prog), wraps the backward node
//            in a "scaled_backward" node. Otherwise returns unchanged.
//
//  Numerical contract
//  ──────────────────
//      For every (loss, grads, state) with state["scale"] > 0:
//          ls_scale_loss(loss, state) == loss * state["scale"]
//      exactly (one multiply, no rounding beyond IEEE-754 float64).
//
//      After N consecutive clean steps (no inf/nan):
//          final_scale == init_scale * growth_factor^(N / interval)
//      within tol 1e-10.
//
//  Edge cases
//  ──────────
//      • empty grads []      -> has_inf=false, has_nan=false,
//                               has_zero=true (vacuously all zero)
//      • scale = 1.0         -> scaling is identity
//      • scale very large    -> overflow likely, backoff triggers
//      • all grads zero      -> has_zero=true but no inf/nan,
//                               scale still grows (zero grads may be
//                               legitimate in sparse models)
//
//  Grammar cautions (HX3 pitfalls)
//  ──────────────────────────────
//      - no semicolons
//      - no and/or -> && / ||
//      - no enum -> string tags
//      - abs → use abs_pure from math_pure.hexa
//      - let mut x = 0 for mutable variables (P15)
//      - range .. binds tighter than + -> parenthesize
//      - handle is reserved keyword -> never use as param name
//      - string/array concat in loops -> .push() + .join("")
//
//  AI-native attrs
//  ───────────────
//      @hot           — loss scaling runs every training step
//      @loss_scaling  — marker: unscaled -> scaled backward pass
//      @pure          — returns new state; no mutation of inputs
// ═══════════════════════════════════════════════════════════════════

// ── numeric helpers ────────────────────────────────────────────────

// ls104_fabs → abs_pure (math_pure.hexa)

// IEEE-754 inf check: a finite float satisfies x - x == 0.
// For inf, inf - inf = nan, so x - x != 0.
@pure
fn ls104_is_inf(x) {
    if x == 0.0 { return false }
    let d = x - x
    // nan != nan is true, so d != 0.0 catches both inf->nan and nan
    // We distinguish inf from nan: inf * 0 = nan, finite * 0 = 0.
    // But simpler: inf == inf is true, nan == nan is false.
    // If d != 0.0 and x == x, then x was inf.
    if d != 0.0 {
        if x == x { return true }
    }
    return false
}

// IEEE-754 nan check: nan != nan
@pure
fn ls104_is_nan(x) {
    if x != x { return true }
    return false
}

// ═══════════════════════════════════════════════════════════════════
//  ls_init_state — create initial scaler state
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn ls_init_state(init_scale, growth_factor, backoff_factor, growth_interval) {
    return #{
        "scale": init_scale,
        "growth_factor": growth_factor,
        "backoff_factor": backoff_factor,
        "growth_interval": growth_interval,
        "good_steps": 0
    }
}

// ═══════════════════════════════════════════════════════════════════
//  ls_scale_loss — multiply loss by current scale
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn ls_scale_loss(loss, state) {
    return loss * state["scale"]
}

// ═══════════════════════════════════════════════════════════════════
//  ls_check_grads — scan gradient array for inf / nan / all-zero
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn ls_check_grads(grads) {
    let n = len(grads)
    let mut found_inf = false
    let mut found_nan = false
    let mut all_zero = true
    let mut i = 0

    while i < n {
        let g = grads[i]
        if ls104_is_nan(g) { found_nan = true }
        if ls104_is_inf(g) { found_inf = true }
        if abs_pure(g) > 0.0 { all_zero = false }
    }
    // empty array is vacuously all-zero
    return #{
        "has_inf": found_inf,
        "has_nan": found_nan,
        "has_zero": all_zero
    }
}

// ═══════════════════════════════════════════════════════════════════
//  ls_update_scale — adjust scale based on gradient health
// ═══════════════════════════════════════════════════════════════════
@hot @loss_scaling @pure
pub fn ls_update_scale(state, grad_check) {
    let scale = state["scale"]
    let gf = state["growth_factor"]
    let bf = state["backoff_factor"]
    let gi = state["growth_interval"]
    let mut good = state["good_steps"]

    // Bad grads: scale down, reset counter, skip this step
    if grad_check["has_inf"] || grad_check["has_nan"] {
        let new_scale = scale * bf
        return #{
            "scale": new_scale,
            "growth_factor": gf,
            "backoff_factor": bf,
            "growth_interval": gi,
            "good_steps": 0,
            "skip_step": true
        }
    }

    // Good grads: increment counter, possibly grow
    good = good + 1
    let mut new_scale = scale
    if good >= gi {
        new_scale = scale * gf
        good = 0
    }

    return #{
        "scale": new_scale,
        "growth_factor": gf,
        "backoff_factor": bf,
        "growth_interval": gi,
        "good_steps": good,
        "skip_step": false
    }
}

// ═══════════════════════════════════════════════════════════════════
//  ls_step — full pipeline: scale loss, check grads, update state
// ═══════════════════════════════════════════════════════════════════
@hot @pure
pub fn ls_step(state, loss, grads) {
    let scaled = ls_scale_loss(loss, state)
    let gc = ls_check_grads(grads)
    let new_state = ls_update_scale(state, gc)
    return #{
        "scaled_loss": scaled,
        "new_state": new_state,
        "skip_step": new_state["skip_step"]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  AST side — pattern detect / rewrite
//
//  A Program is a list of LsStmt. Each stmt has a kind tag.
//  Stmt.kind in {
//      "backward", "scaled_backward", "other"
//  }
//  Stmt.has_scale : bool — whether loss_scale annotation is present
// ═══════════════════════════════════════════════════════════════════
struct LsStmt {
    kind: string
    has_scale: bool
}

pub fn ls_stmt(kind, has_scale) {
    return LsStmt{kind: kind, has_scale: has_scale}
}

pub fn ls_stmt_backward()        { return ls_stmt("backward", false) }
pub fn ls_stmt_scaled_backward() { return ls_stmt("scaled_backward", true) }
pub fn ls_stmt_other()           { return ls_stmt("other", false) }

@pure
fn detect_unscaled_loss_impl(prog) {
    let mut i = 0

    while i < len(prog) {
        let s = prog[i]
        if s.kind == "backward" {
            if !s.has_scale { return true }
        }
    }
    return false
}

pub fn detect_unscaled_loss(prog) {
    return detect_unscaled_loss_impl(prog)
}

@pure
fn rewrite_add_loss_scaling_impl(prog) {
    if !detect_unscaled_loss(prog) { return prog }
    let mut out = []
    let mut i = 0

    while i < len(prog) {
        let s = prog[i]
        if s.kind == "backward" && !s.has_scale {
            out.push(ls_stmt_scaled_backward())
        } else {
            out.push(s)
        }
    }
    return out
}

pub fn rewrite_add_loss_scaling(prog) {
    return rewrite_add_loss_scaling_impl(prog)
}


// -- end inlined --
// ── abs_pure (from runtime/math_pure.hexa) ──
fn abs_pure(v) {
    let t = type_of(v)
    if t == "int" {
        if v < 0 { return 0 - v }
        return v
    }
    if t == "float" {
        if v < 0.0 { return 0.0 - v }
        return v
    }
    v
}
// ── end abs_pure ──


let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_t(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn is_close(a, b, eps) {
    return fabs_t(a - b) < eps
}

// ── T1: Normal grads -> scale grows ────────────────────────────────
fn test_normal_grads_scale_grows() {
    let mut st = ls_init_state(1024.0, 2.0, 0.5, 3)
    let grads = [0.1, 0.2, 0.3, 0.4]

    // Run 3 clean steps (growth_interval = 3)
    let mut _i = 0

    while _i < 3 {
        let gc = ls_check_grads(grads)
        st = ls_update_scale(st, gc)
    }
    // After 3 clean steps, scale should double
    check("T1 normal grads scale grows", is_close(st["scale"], 2048.0, 1.0e-10))
    check("T1 good_steps reset", st["good_steps"] == 0)
    check("T1 skip_step false", st["skip_step"] == false)
}

// ── T2: Inf grads -> scale shrinks, skip ───────────────────────────
fn test_inf_grads_shrink() {
    let st = ls_init_state(1024.0, 2.0, 0.5, 2000)
    // Create inf by overflow: 1e308 * 2 = inf
    let big = 1.0e308
    let inf_val = big * 2.0
    let grads = [1.0, inf_val, 0.5]

    let gc = ls_check_grads(grads)
    check("T2 has_inf detected", gc["has_inf"] == true)

    let new_st = ls_update_scale(st, gc)
    check("T2 scale shrinks", is_close(new_st["scale"], 512.0, 1.0e-10))
    check("T2 skip_step true", new_st["skip_step"] == true)
    check("T2 good_steps reset", new_st["good_steps"] == 0)
}

// ── T3: Nan grads -> scale shrinks, skip ───────────────────────────
fn test_nan_grads_shrink() {
    let st = ls_init_state(1024.0, 2.0, 0.5, 2000)
    // nan = 0.0 / 0.0
    let nan_val = 0.0 / 0.0
    let grads = [nan_val, 1.0, 2.0]

    let gc = ls_check_grads(grads)
    check("T3 has_nan detected", gc["has_nan"] == true)

    let new_st = ls_update_scale(st, gc)
    check("T3 scale shrinks on nan", is_close(new_st["scale"], 512.0, 1.0e-10))
    check("T3 skip_step true", new_st["skip_step"] == true)
}

// ── T4: Growth interval respected ──────────────────────────────────
fn test_growth_interval_respected() {
    let mut st = ls_init_state(100.0, 2.0, 0.5, 5)
    let grads = [0.1, 0.2]

    // Run 4 clean steps (one short of interval=5)
    let mut _i = 0

    while _i < 4 {
        let gc = ls_check_grads(grads)
        st = ls_update_scale(st, gc)
    }
    check("T4 no premature growth", is_close(st["scale"], 100.0, 1.0e-10))
    check("T4 good_steps is 4", st["good_steps"] == 4)

    // One more step triggers growth
    let gc = ls_check_grads(grads)
    st = ls_update_scale(st, gc)
    check("T4 growth at interval", is_close(st["scale"], 200.0, 1.0e-10))
    check("T4 good_steps reset after growth", st["good_steps"] == 0)
}

// ── T5: Edge scale=1.0 identity ────────────────────────────────────
fn test_scale_one_identity() {
    let st = ls_init_state(1.0, 2.0, 0.5, 10)
    let loss = 3.14
    let scaled = ls_scale_loss(loss, st)
    check("T5 scale=1 identity", is_close(scaled, 3.14, 1.0e-15))
}

// ── T6: Edge scale very large -> overflow -> backoff ───────────────
fn test_scale_very_large() {
    let mut st = ls_init_state(1.0e300, 2.0, 0.5, 1)

    // Grow once -> 2e300
    let clean_gc = #{
        "has_inf": false,
        "has_nan": false,
        "has_zero": false
    }
    st = ls_update_scale(st, clean_gc)
    check("T6 large scale grows", is_close(st["scale"], 2.0e300, 1.0e290))

    // Simulate overflow grads
    let bad_gc = #{
        "has_inf": true,
        "has_nan": false,
        "has_zero": false
    }
    st = ls_update_scale(st, bad_gc)
    check("T6 backoff after overflow", is_close(st["scale"], 1.0e300, 1.0e290))
    check("T6 skip on overflow", st["skip_step"] == true)
}

// ── T7: Round-trip: scale up then down recovers ────────────────────
fn test_round_trip() {
    let init = 1024.0
    let gf = 2.0
    let bf = 0.5
    let mut st = ls_init_state(init, gf, bf, 1)

    let clean_gc = #{
        "has_inf": false,
        "has_nan": false,
        "has_zero": false
    }
    let bad_gc = #{
        "has_inf": true,
        "has_nan": false,
        "has_zero": false
    }

    // Grow: 1024 -> 2048
    st = ls_update_scale(st, clean_gc)
    check("T7 after grow", is_close(st["scale"], 2048.0, 1.0e-10))

    // Shrink: 2048 -> 1024
    st = ls_update_scale(st, bad_gc)
    check("T7 round-trip recovers", is_close(st["scale"], 1024.0, 1.0e-10))
}

// ── T8: Empty grads ────────────────────────────────────────────────
fn test_empty_grads() {
    let grads = []
    let gc = ls_check_grads(grads)
    check("T8 empty has_inf false", gc["has_inf"] == false)
    check("T8 empty has_nan false", gc["has_nan"] == false)
    check("T8 empty has_zero true", gc["has_zero"] == true)
}

// ── T9: ls_scale_loss exact multiply ───────────────────────────────
fn test_scale_loss_exact() {
    let st = ls_init_state(65536.0, 2.0, 0.5, 2000)
    let loss = 0.001
    let scaled = ls_scale_loss(loss, st)
    check("T9 exact multiply", is_close(scaled, 65.536, 1.0e-10))
}

// ── T10: AST detect unscaled backward ──────────────────────────────
fn test_ast_detect_unscaled() {
    let prog = [ls_stmt_other(), ls_stmt_backward(), ls_stmt_other()]
    check("T10 detect unscaled", detect_unscaled_loss(prog) == true)
}

// ── T11: AST detect already-scaled ─────────────────────────────────
fn test_ast_detect_already_scaled() {
    let prog = [ls_stmt_other(), ls_stmt_scaled_backward()]
    check("T11 already scaled", detect_unscaled_loss(prog) == false)
}

// ── T12: AST rewrite wraps backward ───────────────────────────────
fn test_ast_rewrite() {
    let prog = [ls_stmt_other(), ls_stmt_backward(), ls_stmt_other()]
    let rewritten = rewrite_add_loss_scaling(prog)
    check("T12 len preserved", len(rewritten) == 3)
    check("T12 first unchanged", rewritten[0].kind == "other")
    check("T12 backward -> scaled", rewritten[1].kind == "scaled_backward")
    check("T12 has_scale true", rewritten[1].has_scale == true)
    check("T12 last unchanged", rewritten[2].kind == "other")

    // Rewrite again should be no-op (already scaled)
    let rewritten2 = rewrite_add_loss_scaling(rewritten)
    check("T12 idempotent", rewritten2[1].kind == "scaled_backward")
}

// ── T13: All-zero grads -> scale still grows ───────────────────────
fn test_zero_grads_still_grow() {
    let mut st = ls_init_state(100.0, 2.0, 0.5, 2)
    let grads = [0.0, 0.0, 0.0]

    // Zero grads have no inf/nan, so scale should grow
    let mut _i = 0

    while _i < 2 {
        let gc = ls_check_grads(grads)
        st = ls_update_scale(st, gc)
    }
    check("T13 zero grads scale grows", is_close(st["scale"], 200.0, 1.0e-10))
    check("T13 skip false", st["skip_step"] == false)
}

// ── T14: Multiple inf/nan cycles then recovery ────────────────────
fn test_multi_cycle_recovery() {
    let mut st = ls_init_state(65536.0, 2.0, 0.5, 2)

    let bad_gc = #{
        "has_inf": true,
        "has_nan": false,
        "has_zero": false
    }
    let clean_gc = #{
        "has_inf": false,
        "has_nan": false,
        "has_zero": false
    }

    // 3 consecutive failures: 65536 -> 32768 -> 16384 -> 8192
    let mut _i = 0

    while _i < 3 {
        st = ls_update_scale(st, bad_gc)
    }
    check("T14 triple backoff", is_close(st["scale"], 8192.0, 1.0e-10))

    // 2 clean steps (interval=2) -> grow back: 8192 -> 16384
    let mut _i = 0

    while _i < 2 {
        st = ls_update_scale(st, clean_gc)
    }
    check("T14 recovery after failures", is_close(st["scale"], 16384.0, 1.0e-10))

    // 2 more clean steps -> 32768
    let mut _i = 0

    while _i < 2 {
        st = ls_update_scale(st, clean_gc)
    }
    check("T14 continued recovery", is_close(st["scale"], 32768.0, 1.0e-10))
}

// ── T15: ls_step full pipeline ─────────────────────────────────────
fn test_ls_step_pipeline() {
    let st = ls_init_state(1024.0, 2.0, 0.5, 1)
    let loss = 0.5
    let grads = [0.1, 0.2, 0.3]

    let result = ls_step(st, loss, grads)
    check("T15 scaled_loss correct", is_close(result["scaled_loss"], 512.0, 1.0e-10))
    check("T15 skip false", result["skip_step"] == false)
    // growth_interval=1, so scale should have grown
    check("T15 scale grew", is_close(result["new_state"]["scale"], 2048.0, 1.0e-10))
}

// ═══════════════════════════════════════════════════════════════════
//  Main
// ═══════════════════════════════════════════════════════════════════
test_normal_grads_scale_grows()
test_inf_grads_shrink()
test_nan_grads_shrink()
test_growth_interval_respected()
test_scale_one_identity()
test_scale_very_large()
test_round_trip()
test_empty_grads()
test_scale_loss_exact()
test_ast_detect_unscaled()
test_ast_detect_already_scaled()
test_ast_rewrite()
test_zero_grads_still_grow()
test_multi_cycle_recovery()
test_ls_step_pipeline()

