// ═══════════════════════════════════════════════════════════════
//  test_rope_scaling.hexa — RoPE Scaling / ALiBi correctness tests
//
//  Verifies:
//    1. Standard RoPE produces correct cos/sin pairs
//    2. NTK-aware scaling increases base frequency
//    3. YaRN blends high/low frequency correctly
//    4. ALiBi slopes follow geometric progression
//    5. ALiBi bias is linear in distance
//    6. apply_rope_to_vec rotation
//    7. Causal ALiBi bias
//    8. RoPE pos=0 gives identity-like rotation
//
//  Run: ./hexa self/test_rope_scaling.hexa
// ═══════════════════════════════════════════════════════════════

import "ml/rope_scaling.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx_eq(a, b, eps) {
    return fabs(a - b) < eps
}

println("═══════════════════════════════════════════════════════")
println("  RoPE Scaling / ALiBi Test Suite")
println("═══════════════════════════════════════════════════════")

let eps = 1.0e-5

// ── Test 1: Standard RoPE at pos=0 → cos=1, sin=0 ──────────
let rope0 = rope_standard(0, 4, 10000.0)
// dim=4 -> 2 pairs -> [cos0, sin0, cos1, sin1]
check("RoPE pos=0 length", len(rope0) == 4)
check("RoPE pos=0 cos=1", approx_eq(rope0[0], 1.0, eps) && approx_eq(rope0[2], 1.0, eps))
check("RoPE pos=0 sin=0", approx_eq(rope0[1], 0.0, eps) && approx_eq(rope0[3], 0.0, eps))

// ── Test 2: apply_rope_to_vec at pos=0 → identity ──────────
let vec0 = [3.0, 5.0, 7.0, 11.0]
let rotated0 = apply_rope_to_vec(vec0, rope0)
check("RoPE apply pos=0: identity", approx_eq(rotated0[0], 3.0, eps) && approx_eq(rotated0[1], 5.0, eps) && approx_eq(rotated0[2], 7.0, eps) && approx_eq(rotated0[3], 11.0, eps))

// ── Test 3: Standard RoPE at pos=1 → non-trivial rotation ──
let rope1 = rope_standard(1, 4, 10000.0)
// pair 0: freq = 1/10000^0 = 1.0, angle=1.0
// cos(1.0) ~ 0.5403, sin(1.0) ~ 0.8415
check("RoPE pos=1 cos(1)", approx_eq(rope1[0], cos(1.0), eps))
check("RoPE pos=1 sin(1)", approx_eq(rope1[1], sin(1.0), eps))

// ── Test 4: NTK scaling produces different base ─────────────
let ntk_base = ntk_scaled_base(10000.0, 64, 4.0)
// ntk_base = 10000 * 4^(64/62) ~ 10000 * 4.13... ~ 41300+
check("NTK base > original", ntk_base > 10000.0)
// The NTK scaled rope should differ from standard
let ntk_rope = rope_ntk_scaled(10, 4, 4.0)
let std_rope = rope_standard(10, 4, 10000.0)
let mut ntk_differs = false
let mut i = 0
while i < 4 {
    if fabs(ntk_rope[i] - std_rope[i]) > 0.001 {
        ntk_differs = true
    }
    i = i + 1
}
check("NTK rope differs from standard", ntk_differs)

// ── Test 5: YaRN produces valid cos/sin pairs ───────────────
let yarn = yarn_rope(5, 8, 4.0, 1.0, 32.0)
check("YaRN output length", len(yarn) == 8)
// cos^2 + sin^2 ~ 1 for each pair
let cs_sum = yarn[0] * yarn[0] + yarn[1] * yarn[1]
check("YaRN cos^2+sin^2 ~ 1", approx_eq(cs_sum, 1.0, 0.01))

// ── Test 6: ALiBi slopes geometric ──────────────────────────
let slopes = alibi_slopes(4)
check("ALiBi 4 slopes count", len(slopes) == 4)
// slopes should be decreasing: 2^(-2), 2^(-4), 2^(-6), 2^(-8)
check("ALiBi slope[0] = 2^-2", approx_eq(slopes[0], pow(2.0, -2.0), eps))
check("ALiBi slope[1] = 2^-4", approx_eq(slopes[1], pow(2.0, -4.0), eps))
// slopes are strictly decreasing
check("ALiBi slopes decreasing", slopes[0] > slopes[1] && slopes[1] > slopes[2] && slopes[2] > slopes[3])

// ── Test 7: ALiBi bias diagonal = 0 ────────────────────────
let bias = alibi_bias(4, 2)
check("ALiBi bias shape: heads", len(bias) == 2)
check("ALiBi bias shape: rows", len(bias[0]) == 4)
// diagonal entries (distance=0) should be 0
let diag_ok = approx_eq(bias[0][0][0], 0.0, eps) && approx_eq(bias[0][1][1], 0.0, eps) && approx_eq(bias[0][2][2], 0.0, eps)
check("ALiBi bias diagonal = 0", diag_ok)

// ── Test 8: ALiBi bias linear in distance ───────────────────
// bias[h][i][j] = -slope[h] * |i-j|
// bias uses num_heads=2, so recompute slopes for 2 heads
let slopes2 = alibi_slopes(2)
let expected_bias = (0.0 - slopes2[0]) * 2.0
check("ALiBi bias linear: dist=2", approx_eq(bias[0][2][0], expected_bias, eps))

// ── Test 9: ALiBi causal bias has -inf for future ───────────
let cbias = alibi_causal_bias(3, 2)
// position (0,1) should be -inf (j=1 > i=0)
check("ALiBi causal: future=-inf", cbias[0][0][1] < -1.0e20)
// position (1,0) should be finite
check("ALiBi causal: past=finite", cbias[0][1][0] > -1.0e10)

// ── Test 10: apply_rope_to_vec with non-zero pos ────────────
let rope_p5 = rope_standard(5, 4, 10000.0)
let vec1 = [1.0, 0.0, 0.0, 1.0]
let rotated = apply_rope_to_vec(vec1, rope_p5)
// For [1,0] with cos/sin: out = [cos, sin]
check("apply_rope pos=5 dim0", approx_eq(rotated[0], rope_p5[0], eps))
check("apply_rope pos=5 dim1", approx_eq(rotated[1], rope_p5[1], eps))

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
