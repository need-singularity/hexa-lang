// ═══════════════════════════════════════════════════════════
//  test_operator_overload.hexa — Operator Behavior Tests
//  Tests: all comparison ops, arithmetic edge cases, string ops,
//         boolean algebra, operator precedence, chained comparisons
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Operator Behavior Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Comparison operators with different values ─────────

println("--- Comparison Operators ---")

check("eq int same", 42 == 42, true)
check("eq int diff", 42 == 43, false)
check("neq int same", 42 != 42, false)
check("neq int diff", 42 != 43, true)

check("lt true", 1 < 2, true)
check("lt false", 2 < 1, false)
check("lt equal", 2 < 2, false)

check("gt true", 2 > 1, true)
check("gt false", 1 > 2, false)
check("gt equal", 2 > 2, false)

check("lte less", 1 <= 2, true)
check("lte equal", 2 <= 2, true)
check("lte greater", 3 <= 2, false)

check("gte greater", 3 >= 2, true)
check("gte equal", 2 >= 2, true)
check("gte less", 1 >= 2, false)

// ── 2. String comparison ──────────────────────────────────

println("")
println("--- String Comparison ---")

check("str eq same", "abc" == "abc", true)
check("str eq diff", "abc" == "xyz", false)
check("str neq", "hello" != "world", true)
check("str neq same", "abc" != "abc", false)
check("empty str eq", "" == "", true)
// Note: string < > comparison not supported in Hexa runtime

// ── 3. Arithmetic operator edge cases ─────────────────────

println("")
println("--- Arithmetic Edge Cases ---")

check("identity add", 0 + 42, 42)
check("identity mul", 1 * 42, 42)
check("neg negate", 0 - 42, -42)
check("double neg", 0 - (0 - 42), 42)

check("int div truncate", 7 / 2, 3)
check("int div exact", 8 / 4, 2)
check("mod positive", 10 % 3, 1)
check("mod 1", 10 % 1, 0)
check("mod large", 100 % 7, 2)

check("mul neg pos", -3 * 5, -15)
check("mul pos neg", 5 * -3, -15)
check("mul neg neg", -3 * -5, 15)

// ── 4. Float arithmetic ──────────────────────────────────

println("")
println("--- Float Arithmetic ---")

check("float add", 1.5 + 2.5, 4.0)
check("float sub", 5.5 - 2.5, 3.0)
check("float mul", 2.0 * 3.0, 6.0)
check("float div", 7.0 / 2.0, 3.5)
check("float neg", 0.0 - 1.5, -1.5)

// ── 5. Boolean operators ─────────────────────────────────

println("")
println("--- Boolean Operators ---")

check("and TT", true && true, true)
check("and TF", true && false, false)
check("and FT", false && true, false)
check("and FF", false && false, false)

check("or TT", true || true, true)
check("or TF", true || false, true)
check("or FT", false || true, true)
check("or FF", false || false, false)

check("not T", !true, false)
check("not F", !false, true)

check("complex and-or", true && false || true, true)
check("complex or-and", false || true && true, true)
check("parens override", (true || false) && false, false)

// ── 6. Operator precedence ───────────────────────────────

println("")
println("--- Precedence ---")

check("mul before add", 2 + 3 * 4, 14)
check("add then mul", (2 + 3) * 4, 20)
check("div before sub", 10 - 6 / 2, 7)
check("sub then div", (10 - 6) / 2, 2)
check("mixed prec 1", 1 + 2 * 3 + 4, 11)
check("mixed prec 2", 2 * 3 + 4 * 5, 26)
check("nested parens", ((1 + 2) * (3 + 4)), 21)
check("triple nest", (((2 + 3)) * 4), 20)

// ── 7. String concatenation ──────────────────────────────

println("")
println("--- String Concat ---")

check("concat 2", "a" + "b", "ab")
check("concat 3", "a" + "b" + "c", "abc")
check("concat 4", "a" + "b" + "c" + "d", "abcd")
check("concat empty left", "" + "hello", "hello")
check("concat empty right", "hello" + "", "hello")
check("concat spaces", "hello" + " " + "world", "hello world")

// ── 8. Comparison in expressions ─────────────────────────

println("")
println("--- Comparison in Expressions ---")

let x = 10
let y = 20
check("var compare lt", x < y, true)
check("var compare gt", x > y, false)
check("var compare eq", x == y, false)
check("expr compare", (x + 10) == y, true)
check("expr compare 2", x * 2 == y, true)
check("expr compare 3", x + y == 30, true)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL OPERATOR TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
