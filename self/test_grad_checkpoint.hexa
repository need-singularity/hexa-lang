// ═══════════════════════════════════════════════════════════════
//  test_grad_checkpoint.hexa — correctness + memory savings smoke
// ═══════════════════════════════════════════════════════════════

import "ml/grad_checkpoint.hexa"

let mut PASS = 0
let mut FAIL = 0

fn check(label, cond) {
    if cond {
        PASS = PASS + 1
        println("  [PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("  [FAIL] " + label)
    }
}

fn approx_eq(a, b, tol) {
    let mut d = a - b
    if d < 0.0 { d = 0.0 - d }
    return d < tol
}

// ── T1: seg_size=1 equivalent to no-ckpt forward/output ────
println("T1 forward output identical (seg=1 vs plain)")
let model1 = gc_make_random_model(6, 16, 1, 42)
let input1 = gc_make_input(16, 7)
let plain1 = gc_forward_plain(model1, input1)
let fwd1 = gc_forward(model1, input1)
let out_plain = plain1[len(plain1) - 1]
let out_ckpt = fwd1.final_out
let mut max_diff = 0.0
let mut i = 0
while i < 16 {
    let mut d = out_plain[i] - out_ckpt[i]
    if d < 0.0 { d = 0.0 - d }
    if d > max_diff { max_diff = d }
    i = i + 1
}
check("T1a forward match (max diff < 1e-6)", max_diff < 0.000001)

// ── T2: seg_size=2 forward output equals plain ─────────────
println("T2 forward output identical (seg=2)")
let model2 = gc_make_random_model(8, 32, 2, 101)
let input2 = gc_make_input(32, 23)
let plain2 = gc_forward_plain(model2, input2)
let fwd2 = gc_forward(model2, input2)
let mut max_diff2 = 0.0
i = 0
while i < 32 {
    let mut d = plain2[8][i] - fwd2.final_out[i]
    if d < 0.0 { d = 0.0 - d }
    if d > max_diff2 { max_diff2 = d }
    i = i + 1
}
check("T2a forward match (max diff < 1e-6)", max_diff2 < 0.000001)

// ── T3: memory savings — ckpt peak < plain peak ──────────────
println("T3 memory savings (12 layers, d=64, seg=4)")
let model3 = gc_make_random_model(12, 64, 4, 2024)
let input3 = gc_make_input(64, 11)
let plain3 = gc_forward_plain(model3, input3)
let fwd3 = gc_forward(model3, input3)
let peak_plain = gc_peak_activations_plain(plain3)
let peak_ckpt = gc_peak_activations(fwd3)
let savings = gc_savings_ratio(peak_ckpt, peak_plain)
println("  plain_peak=" + str(peak_plain) + " ckpt_peak=" + str(peak_ckpt) + " savings=" + str(savings))
check("T3a ckpt peak < plain peak", peak_ckpt < peak_plain)
check("T3b savings >= 40%", savings >= 0.4)

// ── T4: backward grads shape correct ───────────────────────
println("T4 backward grads — shape + nonzero")
let grad_out = gc_make_input(64, 99)
let bw = gc_backward(model3, fwd3, grad_out)
let grad_in = bw[0]
let grads = bw[1]
check("T4a grad_input length == in_dim", len(grad_in) == 64)
check("T4b grads count == num_layers", len(grads) == 12)
// Each per-layer grad is [dW, db]
let g0 = grads[0]
check("T4c grad[0] has [dW,db]", len(g0) == 2)
check("T4d dW length == in*out", len(g0[0]) == 64 * 64)
check("T4e db length == out_dim", len(g0[1]) == 64)

// ── T5: ckpt backward matches plain backward (numerical) ───
println("T5 backward match (ckpt vs plain)")
let bw_plain = gc_backward_plain(model3, plain3, grad_out)
let bw_ckpt  = gc_backward(model3, fwd3, grad_out)
// Compare grad_input
let gi_plain = bw_plain[0]
let gi_ckpt = bw_ckpt[0]
let mut max_gi_diff = 0.0
i = 0
while i < 64 {
    let mut d = gi_plain[i] - gi_ckpt[i]
    if d < 0.0 { d = 0.0 - d }
    if d > max_gi_diff { max_gi_diff = d }
    i = i + 1
}
check("T5a grad_input max diff < 1e-5", max_gi_diff < 0.00001)

// Compare dW of first layer
let gp0 = bw_plain[1][0]
let gc0 = bw_ckpt[1][0]
let mut max_dw_diff = 0.0
let nW = len(gp0[0])
i = 0
while i < nW {
    let mut d = gp0[0][i] - gc0[0][i]
    if d < 0.0 { d = 0.0 - d }
    if d > max_dw_diff { max_dw_diff = d }
    i = i + 1
}
check("T5b dW[0] max diff < 1e-5", max_dw_diff < 0.00001)

// ── T6: savings ratio math ─────────────────────────────────
println("T6 gc_num_segments")
check("T6a 12/4=3", gc_num_segments(12, 4) == 3)
check("T6b 12/5=3 (ceil)", gc_num_segments(12, 5) == 3)
check("T6c 7/3=3", gc_num_segments(7, 3) == 3)

println("---- test_grad_checkpoint: PASS=" + str(PASS) + " FAIL=" + str(FAIL) + " ----")
if FAIL > 0 { exit(1) }
