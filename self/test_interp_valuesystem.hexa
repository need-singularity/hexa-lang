// =====================================================================
//  test_interp_valuesystem.hexa — Phase 2 Value System + Environment Tests
//  Exercises the ported core data structures:
//    Value constructors, Environment (scope chain, variable lookup),
//    eval_binop (all operator types), eval_unary, string/array methods
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  Phase 2: Value System + Environment Tests")
println("=====================================================")
println("")

// ── 1. Value constructors ─────────────────────────────────

println("--- Value Constructors ---")

check("int literal", 42, 42)
check("float literal", 3.14, 3.14)
check("bool true", true, true)
check("bool false", false, false)
check("string literal", "hello", "hello")
check("empty string", "", "")
check("void is void", type_of(println("ok")), "void")

// ── 2. Arithmetic: int ────────────────────────────────────

println("")
println("--- Int Arithmetic ---")

check("add", 3 + 4, 7)
check("sub", 10 - 3, 7)
check("mul", 6 * 7, 42)
check("div", 100 / 10, 10)
check("mod", 17 % 5, 2)
check("negative mod", -7 % 3, -1)
check("pow", 2 ** 10, 1024)
check("add negative", -3 + -4, -7)
check("mul negatives", -3 * -4, 12)
check("sub to negative", 3 - 10, -7)

// ── 3. Arithmetic: float ──────────────────────────────────

println("")
println("--- Float Arithmetic ---")

check("float add", 1.5 + 2.5, 4.0)
check("float sub", 10.0 - 3.5, 6.5)
check("float mul", 2.0 * 3.5, 7.0)
check("float div", 7.0 / 2.0, 3.5)
check("float mod", 7.5 % 2.0, 1.5)
check("float pow", 2.0 ** 3.0, 8.0)

// ── 4. Int-Float coercion ─────────────────────────────────

println("")
println("--- Int-Float Coercion ---")

check("int + float", 1 + 2.5, 3.5)
check("float + int", 2.5 + 1, 3.5)
check("int * float", 3 * 2.5, 7.5)
check("float - int", 10.0 - 3, 7.0)

// ── 5. Comparison operators ───────────────────────────────

println("")
println("--- Comparisons ---")

check("int ==", 5 == 5, true)
check("int !=", 5 != 3, true)
check("int <", 3 < 5, true)
check("int >", 5 > 3, true)
check("int <=", 3 <= 3, true)
check("int >=", 5 >= 5, true)
check("float ==", 3.14 == 3.14, true)
check("float !=", 3.14 != 2.71, true)
check("float <", 2.0 < 3.0, true)
check("float <=", 2.0 <= 2.0, true)
check("float >=", 3.0 >= 3.0, true)
check("bool ==", true == true, true)
check("bool != t/f", true != false, true)
check("str ==", "abc" == "abc", true)
check("str !=", "abc" != "xyz", true)

// ── 6. Logical operators ──────────────────────────────────

println("")
println("--- Logical Ops ---")

check("and true", true && true, true)
check("and false", true && false, false)
check("or false", false || false, false)
check("or true", false || true, true)
check("not true", !true, false)
check("not false", !false, true)

// ── 7. Bitwise operators ──────────────────────────────────

println("")
println("--- Bitwise Ops ---")

let band = 255 & 15
check("bit and", band, 15)
let bxor = 255 ^ 15
check("bit xor", bxor, 240)
let bnot = ~0
check("bit not", bnot, -1)
let bnot42 = ~42
check("bit not 42", bnot42, -43)

// ── 8. String concatenation ───────────────────────────────

println("")
println("--- String Operations ---")

check("str concat", "hello" + " " + "world", "hello world")
check("str + int", "val=" + to_string(42), "val=42")
check("empty concat", "" + "abc", "abc")

// ── 9. String methods ─────────────────────────────────────

println("")
println("--- String Methods ---")

check("len", len("hello"), 5)
check("contains", "hello world".contains("world"), true)
check("contains false", "hello".contains("xyz"), false)
check("starts_with", "hello".starts_with("hel"), true)
check("ends_with", "hello".ends_with("llo"), true)
check("to_upper", "hello".to_upper(), "HELLO")
check("to_lower", "HELLO".to_lower(), "hello")
check("trim", "  hi  ".trim(), "hi")
check("trim_start", trim_start("  hi  "), "hi  ")
check("trim_end", trim_end("  hi  "), "  hi")
check("replace", "aabbcc".replace("bb", "XX"), "aaXXcc")
check("split count", len("a,b,c".split(",")), 3)
check("index_of", "hello".index_of("ll"), 2)
check("index_of miss", "hello".index_of("xyz"), -1)
check("substring", "hello world".substring(0, 5), "hello")
check("repeat", "ab".repeat(3), "ababab")
check("is_empty true", "".is_empty(), true)
check("is_empty false", "x".is_empty(), false)
let padded = "42".pad_left(5, "0")
check("pad_left", padded, "00042")
let rpad = "hi".pad_right(5, ".")
check("pad_right", rpad, "hi...")

// ── 10. Array operations ──────────────────────────────────

println("")
println("--- Array Operations ---")

let arr = [1, 2, 3]
check("array len", len(arr), 3)
check("array index", arr[0], 1)
check("array index 2", arr[2], 3)
check("array concat", len([1, 2] + [3, 4]), 4)
check("array eq", [1, 2, 3] == [1, 2, 3], true)
check("array ne", [1, 2] != [1, 2, 3], true)

// Array methods
let pushed = [1, 2].push(3)
check("push", len(pushed), 3)
check("push val", pushed[2], 3)

let joined = [1, 2, 3].join(", ")
check("join", joined, "1, 2, 3")

check("contains true", [10, 20, 30].contains(20), true)
check("contains false", [10, 20, 30].contains(99), false)

let rev = [1, 2, 3].reverse()
check("reverse[0]", rev[0], 3)
check("reverse[2]", rev[2], 1)

let sliced = [10, 20, 30, 40, 50].slice(1, 4)
check("slice len", len(sliced), 3)
check("slice[0]", sliced[0], 20)

let skipped = [1, 2, 3, 4, 5].slice(2, 5)
check("slice-skip len", len(skipped), 3)
check("slice-skip[0]", skipped[0], 3)

// ── 11. Environment: scope chain ──────────────────────────

println("")
println("--- Environment / Scope Chain ---")

let outer = 100
fn scope_test() {
    let inner = 200
    return outer + inner
}
check("scope access", scope_test(), 300)

let mut x = 10
fn mutate_outer() {
    x = 42
}
mutate_outer()
check("mutate outer", x, 42)

// Nested scopes via closure (fn-in-fn needs closure capture)
let mut depth_val = 0
fn level1() {
    let a = 1
    let level2 = |b| a + b
    depth_val = level2(2)
}
level1()
check("nested scope", depth_val, 3)

// Variable shadowing
let shadow = "outer"
fn shadow_test() {
    let shadow = "inner"
    return shadow
}
check("shadow", shadow_test(), "inner")
check("shadow original", shadow, "outer")

// ── 12. Closures ──────────────────────────────────────────

println("")
println("--- Closures ---")

fn make_adder(n) {
    return |x| x + n
}
let add5 = make_adder(5)
check("closure", add5(10), 15)

fn make_counter(start) {
    return |step| start + step
}
let counter = make_counter(100)
check("counter 100+1", counter(1), 101)
check("counter 100+5", counter(5), 105)
check("counter 100+10", counter(10), 110)

// ── 13. Control flow ──────────────────────────────────────

println("")
println("--- Control Flow ---")

// if/else
let cond_val = if true { 42 } else { 0 }
check("if true", cond_val, 42)
let cond_val2 = if false { 42 } else { 99 }
check("if false", cond_val2, 99)

// while loop
let mut wsum = 0
let mut wi = 1
while wi <= 10 {
    wsum = wsum + wi
    wi = wi + 1
}
check("while sum 1..10", wsum, 55)

// for-in
let mut fsum = 0
for v in [10, 20, 30] {
    fsum = fsum + v
}
check("for-in sum", fsum, 60)

// break
let mut bval = 0
let mut bi = 0
while bi < 100 {
    if bi == 5 { break }
    bval = bval + 1
    bi = bi + 1
}
check("break at 5", bval, 5)

// continue
let mut csum = 0
let mut ci = 0
while ci < 10 {
    ci = ci + 1
    if ci % 2 == 0 { continue }
    csum = csum + ci
}
check("continue odd sum", csum, 25)

// ── 14. Match expression ──────────────────────────────────

println("")
println("--- Match Expression ---")

fn describe(n) {
    match n {
        0 -> "zero"
        1 -> "one"
        2 -> "two"
        _ -> "many"
    }
}
check("match 0", describe(0), "zero")
check("match 1", describe(1), "one")
check("match _", describe(99), "many")

// ── 15. Struct + impl ─────────────────────────────────────

println("")
println("--- Struct + Impl ---")

struct Point {
    x: int,
    y: int
}

impl Point {
    fn sum(self) -> int {
        return self.x + self.y
    }
    fn scale(self, factor) {
        return Point { x: self.x * factor, y: self.y * factor }
    }
}

let p = Point { x: 3, y: 4 }
check("struct field x", p.x, 3)
check("struct field y", p.y, 4)
check("struct method sum", p.sum(), 7)
let p2 = p.scale(10)
check("struct method scale.x", p2.x, 30)

// ── 16. Map operations ───────────────────────────────────

println("")
println("--- Map Operations ---")

let m = #{"a": 1, "b": 2, "c": 3}
check("map get", m["a"], 1)
check("map len", len(keys(m)), 3)
check("map has_key", has_key(m, "b"), true)
check("map has_key miss", has_key(m, "z"), false)

// ── 17. Functional: higher-order array methods ────────────

println("")
println("--- Higher-Order Methods ---")

let doubled = [1, 2, 3].map(|x| x * 2)
check("map[0]", doubled[0], 2)
check("map[2]", doubled[2], 6)

let evens = [1, 2, 3, 4, 5, 6].filter(|x| x % 2 == 0)
check("filter len", len(evens), 3)
check("filter[0]", evens[0], 2)

let total = [1, 2, 3, 4].fold(0, |acc, x| acc + x)
check("fold sum", total, 10)

let any_big = [1, 2, 99].any(|x| x > 50)
check("any true", any_big, true)

let all_pos = [1, 2, 3].all(|x| x > 0)
check("all true", all_pos, true)

let found = [10, 20, 30].find(|x| x > 15)
check("find", found, 20)

// ── 18. Error handling ───────────────────────────────────

println("")
println("--- Error Handling ---")

let mut caught = ""
try {
    throw "test error"
} catch e {
    caught = to_string(e)
}
check("try/catch", caught, "Error(test error)")

// Nested try/catch
let mut inner_caught = ""
try {
    try {
        throw "inner"
    } catch e {
        inner_caught = to_string(e)
        throw "outer"
    }
} catch e {
    // outer catch
}
check("nested catch", inner_caught, "Error(inner)")

// ── 19. Cross-type equality (ported fallback) ─────────────

println("")
println("--- Cross-Type Equality ---")

check("int != str", 42 == "42", false)
check("int ne str", 42 != "42", true)
check("bool != int", true == 1, false)

// ══════════════════════════════════════════════════════════

println("")
println("=====================================================")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("  Total:   " + to_string(pass_count + fail_count))
println("=====================================================")

if fail_count > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
