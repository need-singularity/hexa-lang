// test_char_pure.hexa — Tests for self/runtime/char_pure.hexa
// Covers: is_digit_pure, is_alpha_pure, is_alnum_pure, is_space_pure,
//         is_hex_digit_pure. Accepts both int codepoints and 1-char strings.

// -- inlined from self/runtime/char_pure.hexa --
// (codegen import not wired for test files; same pattern as test_string_pure.hexa)

@pure
fn _ch_normalize(c) {
    let t = type_of(c)
    if t == "string" {
        if len(c) == 0 { return "" }
        return c.substring(0, 1)
    }
    if t == "int" {
        if c < 0 { return "" }
        if c > 126 { return "" }
        if c < 32 { return "" }
        let printable = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
        let idx = c - 32
        return printable.substring(idx, idx + 1)
    }
    ""
}

@pure
fn is_digit_pure(c) {
    let ch = _ch_normalize(c)
    if len(ch) == 0 { return false }
    let digits = "0123456789"
    let mut i = 0
    while i < 10 {
        if digits.substring(i, i + 1) == ch { return true }
        i = i + 1
    }
    false
}

@pure
fn is_alpha_pure(c) {
    let ch = _ch_normalize(c)
    if len(ch) == 0 { return false }
    let lowers = "abcdefghijklmnopqrstuvwxyz"
    let uppers = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    let mut i = 0
    while i < 26 {
        if lowers.substring(i, i + 1) == ch { return true }
        if uppers.substring(i, i + 1) == ch { return true }
        i = i + 1
    }
    false
}

@pure
fn is_alnum_pure(c) {
    if is_alpha_pure(c) { return true }
    if is_digit_pure(c) { return true }
    false
}

@pure
fn is_space_pure(c) {
    let ch = _ch_normalize(c)
    if len(ch) == 0 { return false }
    if ch == " " { return true }
    if ch == "\t" { return true }
    if ch == "\n" { return true }
    if ch == "\r" { return true }
    false
}

@pure
fn is_hex_digit_pure(c) {
    if is_digit_pure(c) { return true }
    let ch = _ch_normalize(c)
    if len(ch) == 0 { return false }
    let hex_letters = "abcdefABCDEF"
    let mut i = 0
    while i < 12 {
        if hex_letters.substring(i, i + 1) == ch { return true }
        i = i + 1
    }
    false
}

// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Character Classification Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── is_digit_pure ─────────────────────────────────────────────────
println("--- is_digit_pure ---")
check("digit '0'",  is_digit_pure("0"),  true)
check("digit '5'",  is_digit_pure("5"),  true)
check("digit '9'",  is_digit_pure("9"),  true)
check("digit 'a'",  is_digit_pure("a"),  false)
check("digit ' '",  is_digit_pure(" "),  false)
check("digit ''",   is_digit_pure(""),   false)
check("digit int 48", is_digit_pure(48), true)   // '0'
check("digit int 57", is_digit_pure(57), true)   // '9'
check("digit int 65", is_digit_pure(65), false)  // 'A'

// ── is_alpha_pure ─────────────────────────────────────────────────
println("")
println("--- is_alpha_pure ---")
check("alpha 'a'", is_alpha_pure("a"), true)
check("alpha 'Z'", is_alpha_pure("Z"), true)
check("alpha 'm'", is_alpha_pure("m"), true)
check("alpha '0'", is_alpha_pure("0"), false)
check("alpha '_'", is_alpha_pure("_"), false)
check("alpha ' '", is_alpha_pure(" "), false)
check("alpha int 65", is_alpha_pure(65), true)  // 'A'
check("alpha int 97", is_alpha_pure(97), true)  // 'a'
check("alpha int 48", is_alpha_pure(48), false) // '0'

// ── is_alnum_pure ─────────────────────────────────────────────────
println("")
println("--- is_alnum_pure ---")
check("alnum 'a'", is_alnum_pure("a"), true)
check("alnum '5'", is_alnum_pure("5"), true)
check("alnum 'Z'", is_alnum_pure("Z"), true)
check("alnum '_'", is_alnum_pure("_"), false)
check("alnum ' '", is_alnum_pure(" "), false)
check("alnum '!'", is_alnum_pure("!"), false)

// ── is_space_pure ─────────────────────────────────────────────────
println("")
println("--- is_space_pure ---")
check("space ' '",  is_space_pure(" "),  true)
check("space '\\t'", is_space_pure("\t"), true)
check("space '\\n'", is_space_pure("\n"), true)
check("space '\\r'", is_space_pure("\r"), true)
check("space 'a'",  is_space_pure("a"),  false)
check("space '0'",  is_space_pure("0"),  false)
check("space int 32", is_space_pure(32), true)  // ' '

// ── is_hex_digit_pure ─────────────────────────────────────────────
println("")
println("--- is_hex_digit_pure ---")
check("hex '0'", is_hex_digit_pure("0"), true)
check("hex '9'", is_hex_digit_pure("9"), true)
check("hex 'a'", is_hex_digit_pure("a"), true)
check("hex 'f'", is_hex_digit_pure("f"), true)
check("hex 'A'", is_hex_digit_pure("A"), true)
check("hex 'F'", is_hex_digit_pure("F"), true)
check("hex 'g'", is_hex_digit_pure("g"), false)
check("hex 'z'", is_hex_digit_pure("z"), false)
check("hex ' '", is_hex_digit_pure(" "), false)

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
