// ═══════════════════════════════════════════════════════════
//  test_closures_lambdas.hexa — Closure & Lambda Tests
//  Tests: |x| syntax, capture, higher-order, nested, composition
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Closure & Lambda Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic lambda ───────────────────────────────────────

println("--- Basic Lambda ---")

let double = |x| x * 2
check("lambda double(6)", double(6), 12)

let add = |a, b| a + b
check("lambda add(3,4)", add(3, 4), 7)

let identity = |x| x
check("lambda identity(42)", identity(42), 42)

let constant = |x| 99
check("lambda constant(0)", constant(0), 99)

// ── 2. Lambda with block body ─────────────────────────────

println("")
println("--- Block Body Lambda ---")

let calc = |x, y| {
    let sum = x + y
    return sum * 2
}
check("block lambda calc(3,4)", calc(3, 4), 14)

let abs_val = |x| {
    if x < 0 {
        return 0 - x
    }
    return x
}
check("block lambda abs(-7)", abs_val(-7), 7)
check("block lambda abs(3)", abs_val(3), 3)

// ── 3. Variable capture (closures) ────────────────────────

println("")
println("--- Variable Capture ---")

let factor = 6
let mul = |x| x * factor
check("capture mul(7)", mul(7), 42)

let base = 100
let offset = 5
let compute = |x| base + x * offset
check("capture multi-var", compute(3), 115)

let msg = "hello"
let greet = |name| msg + " " + name
check("capture string", greet("world"), "hello world")

// ── 4. Higher-order functions ─────────────────────────────

println("")
println("--- Higher-Order Functions ---")

fn apply(f, x) {
    return f(x)
}
check("apply double", apply(double, 5), 10)
check("apply identity", apply(identity, 42), 42)

fn apply2(f, a, b) {
    return f(a, b)
}
check("apply2 add", apply2(add, 10, 20), 30)

fn twice(f, x) {
    return f(f(x))
}
let inc = |x| x + 1
check("twice inc(5)", twice(inc, 5), 7)
check("twice double(3)", twice(double, 3), 12)

// ── 5. Function returning closure ─────────────────────────

println("")
println("--- Closure Factory ---")

fn make_adder(n) {
    return |x| x + n
}
let add10 = make_adder(10)
let add5 = make_adder(5)
check("make_adder(10)(32)", add10(32), 42)
check("make_adder(5)(7)", add5(7), 12)

fn make_multiplier(n) {
    return |x| x * n
}
let triple = make_multiplier(3)
check("make_multiplier(3)(7)", triple(7), 21)

// ── 6. Map pattern ────────────────────────────────────────

println("")
println("--- Map / Filter / Reduce ---")

fn map_array(arr, f) {
    let mut result = []
    for item in arr {
        result = result.push(f(item))
    }
    return result
}

let nums = [1, 2, 3, 4, 5]
let doubled = map_array(nums, |x| x * 2)
check("map *2 [0]", doubled[0], 2)
check("map *2 [4]", doubled[4], 10)
check("map *2 len", len(doubled), 5)

let squared = map_array(nums, |x| x * x)
check("map sq [2]", squared[2], 9)
check("map sq [4]", squared[4], 25)

// ── 7. Filter pattern ─────────────────────────────────────

fn filter_array(arr, pred) {
    let mut result = []
    for item in arr {
        if pred(item) {
            result = result.push(item)
        }
    }
    return result
}

let evens = filter_array([1, 2, 3, 4, 5, 6], |x| x % 2 == 0)
check("filter evens len", len(evens), 3)
check("filter evens[0]", evens[0], 2)
check("filter evens[2]", evens[2], 6)

let big = filter_array([1, 50, 3, 100, 7], |x| x > 10)
check("filter >10 len", len(big), 2)

// ── 8. Reduce pattern ─────────────────────────────────────

fn reduce(arr, init, f) {
    let mut acc = init
    for item in arr {
        acc = f(acc, item)
    }
    return acc
}

let sum = reduce([1, 2, 3, 4, 5], 0, |a, b| a + b)
check("reduce sum", sum, 15)

let product = reduce([1, 2, 3, 4, 5], 1, |a, b| a * b)
check("reduce product", product, 120)

let max_val = reduce([3, 7, 2, 9, 1], 0, |a, b| {
    if b > a { return b }
    return a
})
check("reduce max", max_val, 9)

// ── 9. Lambda in array ────────────────────────────────────

println("")
println("--- Lambda in Array ---")

let ops = [|x| x + 1, |x| x * 2, |x| x - 3]
check("ops[0](10)", ops[0](10), 11)
check("ops[1](10)", ops[1](10), 20)
check("ops[2](10)", ops[2](10), 7)

// ── 10. Nested closures ───────────────────────────────────

println("")
println("--- Nested Closures ---")

let outer = |x| {
    let inner = |y| x + y
    return inner(10)
}
check("nested closure", outer(5), 15)

fn compose(f, g) {
    return |x| f(g(x))
}
let inc_then_double = compose(double, inc)
check("compose inc->double(5)", inc_then_double(5), 12)

let double_then_inc = compose(inc, double)
check("compose double->inc(5)", double_then_inc(5), 11)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL CLOSURE/LAMBDA TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
