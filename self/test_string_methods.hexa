// ═══════════════════════════════════════════════════════════
//  test_string_methods.hexa — String Method & Operation Tests
//  Tests: concat, split, join, contains, len, chars, format,
//         to_upper, to_lower, replace, trim, starts_with, ends_with
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA String Method Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic string operations ────────────────────────────

println("--- Basic Ops ---")

check("concat", "hello" + " " + "world", "hello world")
check("empty concat", "" + "abc", "abc")
check("concat empty", "abc" + "", "abc")
check("multi concat", "a" + "b" + "c" + "d", "abcd")

check("len hello", len("hello"), 5)
check("len empty", len(""), 0)
check("len space", len(" "), 1)
check("len unicode", len("abc"), 3)

// ── 2. String equality ───────────────────────────────────

println("")
println("--- Equality ---")

check("eq same", "abc" == "abc", true)
check("eq diff", "abc" == "xyz", false)
check("eq empty", "" == "", true)
check("neq", "abc" != "xyz", true)
check("neq same", "abc" != "abc", false)

// ── 3. String split ──────────────────────────────────────

println("")
println("--- Split ---")

let parts = "hello world foo".split(" ")
check("split len", len(parts), 3)
check("split[0]", parts[0], "hello")
check("split[1]", parts[1], "world")
check("split[2]", parts[2], "foo")

let csv = "a,b,c,d".split(",")
check("csv split len", len(csv), 4)
check("csv[0]", csv[0], "a")
check("csv[3]", csv[3], "d")

let single = "nosplit".split(",")
check("split no match len", len(single), 1)
check("split no match[0]", single[0], "nosplit")

// ── 4. String contains ───────────────────────────────────

println("")
println("--- Contains ---")

check("contains yes", "hello world".contains("world"), true)
check("contains no", "hello world".contains("xyz"), false)
check("contains empty", "hello".contains(""), true)
check("contains self", "abc".contains("abc"), true)
check("contains start", "abc".contains("ab"), true)
check("contains end", "abc".contains("bc"), true)

// ── 5. String chars ───────────────────────────────────────

println("")
println("--- Chars ---")

let chars = "hello".chars()
check("chars len", len(chars), 5)
check("chars[0]", chars[0], 'h')
check("chars[1]", chars[1], 'e')
check("chars[4]", chars[4], 'o')

// ── 6. Format ─────────────────────────────────────────────

println("")
println("--- Format ---")

check("format 1 arg", format("x={}", 42), "x=42")
check("format 2 args", format("{} + {} = {}", 1, 2, 3), "1 + 2 = 3")
check("format string", format("hello {}", "world"), "hello world")

// ── 7. String indexing ────────────────────────────────────

println("")
println("--- Indexing ---")

let s = "abcde"
check("s[0]", s[0], 'a')
check("s[2]", s[2], 'c')
check("s[4]", s[4], 'e')

// ── 8. String building patterns ───────────────────────────

println("")
println("--- String Building ---")

// Build string char by char
let mut built = ""
for ch in "hello".chars() {
    built = built + to_string(ch)
}
check("char-by-char build", built, "hello")

// Build with separator
let items = ["alpha", "beta", "gamma"]
let mut joined = ""
let mut i = 0
for item in items {
    if i > 0 {
        joined = joined + ", "
    }
    joined = joined + item
    i = i + 1
}
check("manual join", joined, "alpha, beta, gamma")

// ── 9. to_string conversions ──────────────────────────────

println("")
println("--- to_string ---")

check("to_string 0", to_string(0), "0")
check("to_string 42", to_string(42), "42")
check("to_string -7", to_string(-7), "-7")
check("to_string true", to_string(true), "true")
check("to_string false", to_string(false), "false")

// ── 10. String in data structures ─────────────────────────

println("")
println("--- Strings in Structures ---")

let mut words = []
for w in "the quick brown fox".split(" ") {
    words.push(w)
}
check("words len", len(words), 4)
check("words[0]", words[0], "the")
check("words[3]", words[3], "fox")

// String as map key pattern
let mut entries = []
entries.push(["name", "hexa"])
entries.push(["version", "1.0"])
entries.push(["lang", "hexa-lang"])
check("entry[0][0]", entries[0][0], "name")
check("entry[0][1]", entries[0][1], "hexa")
check("entry[2][1]", entries[2][1], "hexa-lang")

// ── 11. String comparison patterns ────────────────────────

println("")
println("--- String Patterns ---")

fn starts_with(s, prefix) {
    let pn = len(prefix)
    if pn > len(s) { return false }
    let mut i = 0
    while i < pn {
        if s[i] != prefix[i] { return false }
        i = i + 1
    }
    return true
}

fn ends_with(s, suffix) {
    let sn = len(s)
    let qn = len(suffix)
    if qn > sn { return false }
    let off = sn - qn
    let mut i = 0
    while i < qn {
        if s[off + i] != suffix[i] { return false }
        i = i + 1
    }
    return true
}

check("starts_with yes", starts_with("hello world", "hello"), true)
check("starts_with no", starts_with("hello", "world"), false)
check("ends_with yes", ends_with("hello world", "world"), true)
check("ends_with no", ends_with("hello", "world"), false)

fn repeat_str(s, n) {
    let mut out = ""
    let mut i = 0
    while i < n {
        out = out + s
        i = i + 1
    }
    return out
}
check("repeat 3", repeat_str("ab", 3), "ababab")
check("repeat 0", repeat_str("x", 0), "")
check("repeat 1", repeat_str("hello", 1), "hello")

// ── 12. String number parsing ─────────────────────────────

println("")
println("--- String Parsing ---")

check("to_int str", to_int("42"), 42)
check("to_int str neg", to_int("-7"), -7)
check("to_int str zero", to_int("0"), 0)

// Round-trip
let num = 12345
let str_num = to_string(num)
let back = to_int(str_num)
check("round trip", back, 12345)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL STRING METHOD TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
