// ═══════════════════════════════════════════════════════════════════
//  test_hash_rng_pure.hexa — coverage for self/runtime/hash_rng_pure.hexa
//
//  Tests: hash_combine_pure, hash_int_pure, rng_xorshift32_pure,
//         rng_range_pure, shuffle_pure
//
//  (codegen import not wired for test files; inline the module body,
//   same pattern as test_bitops_pure.hexa / test_murmur3_pure.hexa.)
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from self/runtime/hash_rng_pure.hexa ──

let _MASK32 = 0xFFFFFFFF

@pure
fn _pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

@pure
fn _shl32(a, n) {
    if n <= 0 { return a & _MASK32 }
    return (a * _pow2(n)) & _MASK32
}

@pure
fn _shr32(a, n) {
    if n <= 0 { return a & _MASK32 }
    let m = a & _MASK32
    return m / _pow2(n)
}

@pure
fn hash_combine_pure(a, b) {
    let a32 = a & _MASK32
    let b32 = b & _MASK32
    let golden = 0x9E3779B9
    let seed_shl6 = _shl32(a32, 6)
    let seed_shr2 = _shr32(a32, 2)
    let mixed = (b32 + golden + seed_shl6 + seed_shr2) & _MASK32
    return (a32 ^ mixed) & _MASK32
}

@pure
fn hash_int_pure(n) {
    let mut h = n & _MASK32
    h = (h ^ _shr32(h, 16)) & _MASK32
    h = (h * 0x85EBCA6B) & _MASK32
    h = (h ^ _shr32(h, 13)) & _MASK32
    h = (h * 0xC2B2AE35) & _MASK32
    h = (h ^ _shr32(h, 16)) & _MASK32
    return h
}

@pure
fn rng_xorshift32_pure(state) {
    let mut x = state & _MASK32
    if x == 0 { x = 0x1 & _MASK32 }
    x = (x ^ _shl32(x, 13)) & _MASK32
    x = (x ^ _shr32(x, 17)) & _MASK32
    x = (x ^ _shl32(x, 5)) & _MASK32
    return [x, x]
}

@pure
fn rng_range_pure(state, lo, hi) {
    let step = rng_xorshift32_pure(state)
    let new_state = step[0]
    let raw = step[1]
    if hi <= lo { return [new_state, lo] }
    let span = hi - lo + 1
    let v = lo + (raw % span)
    return [new_state, v]
}

@pure
fn _swap_at(arr, i, j) {
    let n = len(arr)
    let mut out = []
    let mut k = 0
    while k < n {
        if k == i {
            out.push(arr[j])
        } else {
            if k == j {
                out.push(arr[i])
            } else {
                out.push(arr[k])
            }
        }
        k = k + 1
    }
    return out
}

@pure
fn shuffle_pure(arr, state) {
    let n = len(arr)
    if n <= 1 { return [arr, state] }
    let mut out = arr
    let mut st = state
    let mut i = n - 1
    while i > 0 {
        let step = rng_range_pure(st, 0, i)
        st = step[0]
        let j = step[1]
        if j != i {
            out = _swap_at(out, i, j)
        }
        i = i - 1
    }
    return [out, st]
}

// ── harness ─────────────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_true(name, actual) {
    if actual {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected true")
        fail_count = fail_count + 1
    }
}

fn check_ne(name, a, b) {
    if to_string(a) != to_string(b) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected different, both were: " + to_string(a))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Hash-Combine / RNG / Shuffle Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── hash_combine_pure ──────────────────────────────────────────────
println("--- hash_combine_pure ---")
// Deterministic reproducibility
let hc_ab = hash_combine_pure(1, 2)
let hc_ab_again = hash_combine_pure(1, 2)
check("combine(1,2) deterministic", hc_ab, hc_ab_again)

// Non-commutative (boost property)
check_ne("combine(1,2) != combine(2,1)",
    hash_combine_pure(1, 2), hash_combine_pure(2, 1))
check_ne("combine(7,13) != combine(13,7)",
    hash_combine_pure(7, 13), hash_combine_pure(13, 7))

// Different inputs -> different outputs
check_ne("combine(0,0) != combine(0,1)",
    hash_combine_pure(0, 0), hash_combine_pure(0, 1))
check_ne("combine(0,0) != combine(1,0)",
    hash_combine_pure(0, 0), hash_combine_pure(1, 0))

// Output stays within 32-bit range
check_true("combine(MAX,MAX) in 32-bit range",
    hash_combine_pure(0xFFFFFFFF, 0xFFFFFFFF) <= 0xFFFFFFFF)
check_true("combine(MAX,MAX) non-negative",
    hash_combine_pure(0xFFFFFFFF, 0xFFFFFFFF) >= 0)

// ── hash_int_pure ──────────────────────────────────────────────────
println("")
println("--- hash_int_pure ---")
// Deterministic
check("hash_int(42) deterministic", hash_int_pure(42), hash_int_pure(42))

// Avalanche: adjacent ints -> different hashes
check_ne("hash_int(0) != hash_int(1)",
    hash_int_pure(0), hash_int_pure(1))
check_ne("hash_int(1) != hash_int(2)",
    hash_int_pure(1), hash_int_pure(2))
check_ne("hash_int(100) != hash_int(101)",
    hash_int_pure(100), hash_int_pure(101))

// Output within 32-bit range
check_true("hash_int(MAX) in 32-bit range",
    hash_int_pure(0xFFFFFFFF) <= 0xFFFFFFFF)
check_true("hash_int(MAX) non-negative",
    hash_int_pure(0xFFFFFFFF) >= 0)

// ── rng_xorshift32_pure ────────────────────────────────────────────
println("")
println("--- rng_xorshift32_pure ---")
// Deterministic given seed
let r1 = rng_xorshift32_pure(42)
let r2 = rng_xorshift32_pure(42)
check("xorshift32(42) deterministic state", r1[0], r2[0])
check("xorshift32(42) deterministic value", r1[1], r2[1])

// Sequential calls produce different values
let s1 = rng_xorshift32_pure(12345)
let s2 = rng_xorshift32_pure(s1[0])
check_ne("xorshift32 sequential values differ", s1[1], s2[1])
let s3 = rng_xorshift32_pure(s2[0])
check_ne("xorshift32 step2 != step3", s2[1], s3[1])

// State-0 guard: never stuck at 0
let z = rng_xorshift32_pure(0)
check_ne("xorshift32(0) avoids fixed point", z[0], 0)

// Output in 32-bit range
check_true("xorshift32 value in 32-bit range", s1[1] <= 0xFFFFFFFF)
check_true("xorshift32 state in 32-bit range", s1[0] <= 0xFFFFFFFF)

// ── rng_range_pure ─────────────────────────────────────────────────
println("")
println("--- rng_range_pure ---")
// Bounded output — sample many values in [10, 20]
let mut st = 999
let mut all_in_range = true
let mut saw_low = false
let mut saw_high = false
let mut m = 0
while m < 200 {
    let step = rng_range_pure(st, 10, 20)
    st = step[0]
    let v = step[1]
    if v < 10 { all_in_range = false }
    if v > 20 { all_in_range = false }
    if v == 10 { saw_low = true }
    if v == 20 { saw_high = true }
    m = m + 1
}
check_true("rng_range [10,20] all within bounds", all_in_range)
check_true("rng_range [10,20] saw low endpoint over 200 samples", saw_low)
check_true("rng_range [10,20] saw high endpoint over 200 samples", saw_high)

// Degenerate ranges
let deg1 = rng_range_pure(7, 5, 5)
check("rng_range(7, 5, 5) single-point", deg1[1], 5)
let deg2 = rng_range_pure(7, 10, 3)
check("rng_range(7, 10, 3) hi<lo clamps to lo", deg2[1], 10)

// ── shuffle_pure ───────────────────────────────────────────────────
println("")
println("--- shuffle_pure ---")
let input = [1, 2, 3, 4, 5, 6, 7, 8]
let sh = shuffle_pure(input, 0xDEADBEEF)
let shuffled = sh[0]

// Preserves length
check("shuffle preserves length", len(shuffled), len(input))

// Preserves multiset (sum works since all elements are unique small ints)
let mut sum_in = 0
let mut sum_out = 0
let mut t = 0
while t < len(input) {
    sum_in = sum_in + input[t]
    sum_out = sum_out + shuffled[t]
    t = t + 1
}
check("shuffle preserves element sum", sum_out, sum_in)

// Same seed -> same permutation
let sh2 = shuffle_pure(input, 0xDEADBEEF)
check("shuffle deterministic across same seed",
    to_string(sh[0]), to_string(sh2[0]))

// Different seed -> different permutation (overwhelmingly likely for n=8)
let sh3 = shuffle_pure(input, 0x12345678)
check_ne("shuffle different seed gives different permutation",
    to_string(sh[0]), to_string(sh3[0]))

// Empty and singleton edge cases
let emp = shuffle_pure([], 42)
check("shuffle empty length", len(emp[0]), 0)
let one = shuffle_pure([99], 42)
check("shuffle singleton length", len(one[0]), 1)
check("shuffle singleton element", one[0][0], 99)

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
