// self/test_argparse.hexa — S-NEW-ARGPARSE acceptance smoke
//
// Self-contained: inline argparse surface for testing without I2.

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

// ── inline mirror ──────────────────────────────────────────────────────

fn ap_new(prog, desc) { return #{ "prog": prog, "desc": desc, "flags": [], "values": [], "positional": [] } }
fn ap_add_flag(p, short, long, help, default_v) {
    let mut flags = p["flags"]
    flags.push(#{ "short": short, "long": long, "help": help, "default": default_v })
    p["flags"] = flags
    return p
}
fn ap_add_value(p, short, long, help, default_v, required) {
    let mut values = p["values"]
    values.push(#{ "short": short, "long": long, "help": help, "default": default_v, "required": required })
    p["values"] = values
    return p
}
fn ap_add_positional(p, name, help, required) {
    let mut pos = p["positional"]
    pos.push(#{ "name": name, "help": help, "required": required })
    p["positional"] = pos
    return p
}
fn strip_dashes(s) {
    let n = len(s)
    let mut i = 0
    while i < n { if s[i] != '-' { return s.substring(i, n) } i = i + 1 }
    return ""
}
fn match_flag(p, tok) {
    let flags = p["flags"]
    let mut i = 0
    while i < len(flags) { let f = flags[i] if tok == f["short"] || tok == f["long"] { return f } i = i + 1 }
    return #{}
}
fn match_value(p, tok) {
    let values = p["values"]
    let mut i = 0
    while i < len(values) { let v = values[i] if tok == v["short"] || tok == v["long"] { return v } i = i + 1 }
    return #{}
}
fn ap_parse(p, argv) {
    let mut out = #{ "_extras": [], "_help": false }
    let flags = p["flags"]
    let mut fi = 0
    while fi < len(flags) { let f = flags[fi] out[strip_dashes(f["long"])] = f["default"] fi = fi + 1 }
    let values = p["values"]
    let mut vi = 0
    while vi < len(values) { let v = values[vi] out[strip_dashes(v["long"])] = v["default"] vi = vi + 1 }
    let mut pos_consumed = 0
    let positional = p["positional"]
    let mut extras = []
    let mut i = 0
    while i < len(argv) {
        let tok = argv[i]
        if tok == "-h" || tok == "--help" { out["_help"] = true i = i + 1 }
        else {
            let f = match_flag(p, tok)
            if len(f) > 0 { out[strip_dashes(f["long"])] = true i = i + 1 }
            else {
                let v = match_value(p, tok)
                if len(v) > 0 {
                    if i + 1 < len(argv) { out[strip_dashes(v["long"])] = argv[i + 1] i = i + 2 }
                    else { i = i + 1 }
                } else {
                    if pos_consumed < len(positional) {
                        let pos = positional[pos_consumed]
                        out[pos["name"]] = tok
                        pos_consumed = pos_consumed + 1
                        i = i + 1
                    } else { extras.push(tok) i = i + 1 }
                }
            }
        }
    }
    out["_extras"] = extras
    return out
}

// ── tests ──────────────────────────────────────────────────────────────

fn main() {
    // strip_dashes
    check("strip --foo", strip_dashes("--foo") == "foo")
    check("strip -x", strip_dashes("-x") == "x")

    // simple flag
    let p1 = ap_new("p1", "test")
    let p1b = ap_add_flag(p1, "-v", "--verbose", "verbose", false)
    let r1 = ap_parse(p1b, ["--verbose"])
    check("flag long set", r1["verbose"] == true)
    let r1b = ap_parse(p1b, ["-v"])
    check("flag short set", r1b["verbose"] == true)
    let r1c = ap_parse(p1b, [])
    check("flag default", r1c["verbose"] == false)

    // value with default
    let p2 = ap_new("p2", "test")
    let p2b = ap_add_value(p2, "-o", "--out", "out path", "default.txt", false)
    let r2 = ap_parse(p2b, ["--out", "path/x.txt"])
    check("value long", r2["out"] == "path/x.txt")
    let r2b = ap_parse(p2b, ["-o", "y.txt"])
    check("value short", r2b["out"] == "y.txt")
    let r2c = ap_parse(p2b, [])
    check("value default", r2c["out"] == "default.txt")

    // positional
    let p3 = ap_new("p3", "test")
    let p3b = ap_add_positional(p3, "input", "input file", true)
    let r3 = ap_parse(p3b, ["foo.txt"])
    check("positional", r3["input"] == "foo.txt")

    // help
    let p4 = ap_new("p4", "test")
    let r4 = ap_parse(p4, ["--help"])
    check("--help sets _help", r4["_help"] == true)
    let r4b = ap_parse(p4, ["-h"])
    check("-h sets _help", r4b["_help"] == true)

    // extras
    let p5 = ap_new("p5", "test")
    let r5 = ap_parse(p5, ["unknown1", "unknown2"])
    check("extras captured", len(r5["_extras"]) == 2)

    // mixed: flag + value + positional + extras
    let p6 = ap_new("p6", "test")
    let p6a = ap_add_flag(p6, "-q", "--quiet", "quiet", false)
    let p6b = ap_add_value(p6a, "-o", "--out", "out", "default", false)
    let p6c = ap_add_positional(p6b, "input", "input file", true)
    let r6 = ap_parse(p6c, ["-q", "-o", "X", "myfile.txt", "leftover"])
    check("mixed quiet", r6["quiet"] == true)
    check("mixed out", r6["out"] == "X")
    check("mixed input", r6["input"] == "myfile.txt")
    check("mixed extras 1", len(r6["_extras"]) == 1)

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
