// self/test_vendor_sdks.hexa — INDEP-3 vendor SDK shim aggregator selftest
//
// Runs the in-process unit checks of all 5 vendor SDK modules:
//   anthropic_sdk, openai_sdk, google_sdk, mistral_sdk, bedrock_sdk
//
// All checks are NON-NETWORK by design — they exercise the pure-hexa
// request builders + response/SSE parsers + extractors against fixed
// fixture inputs. Network-touching paths (anthropic_send / openai_send /
// google_send / mistral_send / bedrock_send_bearer) are NOT exercised
// here (raw 91 honest C3: would require live credentials and is out
// of scope for an offline gate).
//
// Run with:
//   hexa run self/test_vendor_sdks.hexa
//
// Aggregated PASS line:
//   __VENDOR_SDKS_AGG__ PASS modules=5 total=N fail=0
// Or FAIL line listing the failing module(s).
//
// raw 91 (no_silent_errors): on any module fail-count > 0, the
// aggregator emits __VENDOR_SDKS_AGG__ FAIL ... and exits 1 so CI
// gates fail loud.
// raw 159 (hexa-lang-upstream-proposal-mandate): this aggregator is
// the canonical post-port verification gate for hive packages/ai
// vendor-shim consumers.

use "self/stdlib/anthropic_sdk"
use "self/stdlib/openai_sdk"
use "self/stdlib/google_sdk"
use "self/stdlib/mistral_sdk"
use "self/stdlib/bedrock_sdk"

let f1 = anthropic_selftest()
let f2 = openai_selftest()
let f3 = google_selftest()
let f4 = mistral_selftest()
let f5 = bedrock_selftest()

let total_fail = f1 + f2 + f3 + f4 + f5

if total_fail == 0 {
    println("__VENDOR_SDKS_AGG__ PASS modules=5 total_fail=0")
} else {
    println("__VENDOR_SDKS_AGG__ FAIL modules=5 total_fail=" + to_string(total_fail) +
            " (anthropic=" + to_string(f1) +
            ", openai=" + to_string(f2) +
            ", google=" + to_string(f3) +
            ", mistral=" + to_string(f4) +
            ", bedrock=" + to_string(f5) + ")")
    exit(1)
}
