// ===============================================================
//  test_dp_sliding_window.hexa -- DP Sliding Window Optimization
//  M976: DP table O(n) -> O(k) memory via sliding window
//  ROI id=9, P3, effect 3x
// ===============================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("===============================================================")
println("  HEXA DP Sliding Window Tests -- O(n) -> O(k) Memory")
println("===============================================================")
println("")

// ================================================================
//  SECTION 1: Fibonacci -- dp[i] = dp[i-1] + dp[i-2]
//  Classic DP with lookback=2 -> only need 2 variables
// ================================================================

println("--- Section 1: Fibonacci (lookback=2) ---")

// Array-based DP (O(n) memory)
fn fib_dp_array(n) {
    if n <= 1 { return n }
    let mut dp = [0, 1]
    let mut i = 2
    while i <= n {
        dp.push(dp[i - 1] + dp[i - 2])
        i = i + 1
    }
    return dp[n]
}

// Manual sliding window (O(1) memory) -- the target pattern
fn fib_sliding(n) {
    if n <= 1 { return n }
    let mut prev2 = 0
    let mut prev1 = 1
    let mut i = 2
    while i <= n {
        let cur = prev1 + prev2
        prev2 = prev1
        prev1 = cur
        i = i + 1
    }
    return prev1
}

// Verify both produce identical results
check("fib_dp(0)", fib_dp_array(0), 0)
check("fib_dp(1)", fib_dp_array(1), 1)
check("fib_dp(2)", fib_dp_array(2), 1)
check("fib_dp(5)", fib_dp_array(5), 5)
check("fib_dp(10)", fib_dp_array(10), 55)
check("fib_dp(20)", fib_dp_array(20), 6765)

check("fib_sliding(0)", fib_sliding(0), 0)
check("fib_sliding(1)", fib_sliding(1), 1)
check("fib_sliding(2)", fib_sliding(2), 1)
check("fib_sliding(5)", fib_sliding(5), 5)
check("fib_sliding(10)", fib_sliding(10), 55)
check("fib_sliding(20)", fib_sliding(20), 6765)

// Equivalence check
let mut fib_eq = true
let mut fi = 0
while fi <= 25 {
    if fib_dp_array(fi) != fib_sliding(fi) { fib_eq = false }
    fi = fi + 1
}
check("fib array==sliding (0..25)", fib_eq, true)

println("")

// ================================================================
//  SECTION 2: Tribonacci -- dp[i] = dp[i-1] + dp[i-2] + dp[i-3]
//  Lookback=3 -> only need 3 variables
// ================================================================

println("--- Section 2: Tribonacci (lookback=3) ---")

fn trib_dp_array(n) {
    if n == 0 { return 0 }
    if n == 1 { return 0 }
    if n == 2 { return 1 }
    let mut dp = [0, 0, 1]
    let mut i = 3
    while i <= n {
        dp.push(dp[i - 1] + dp[i - 2] + dp[i - 3])
        i = i + 1
    }
    return dp[n]
}

fn trib_sliding(n) {
    if n == 0 { return 0 }
    if n == 1 { return 0 }
    if n == 2 { return 1 }
    let mut prev3 = 0
    let mut prev2 = 0
    let mut prev1 = 1
    let mut i = 3
    while i <= n {
        let cur = prev1 + prev2 + prev3
        prev3 = prev2
        prev2 = prev1
        prev1 = cur
        i = i + 1
    }
    return prev1
}

check("trib_dp(0)", trib_dp_array(0), 0)
check("trib_dp(2)", trib_dp_array(2), 1)
check("trib_dp(4)", trib_dp_array(4), 2)
check("trib_dp(7)", trib_dp_array(7), 13)
check("trib_dp(10)", trib_dp_array(10), 81)

check("trib_sliding(0)", trib_sliding(0), 0)
check("trib_sliding(2)", trib_sliding(2), 1)
check("trib_sliding(4)", trib_sliding(4), 2)
check("trib_sliding(7)", trib_sliding(7), 13)
check("trib_sliding(10)", trib_sliding(10), 81)

let mut trib_eq = true
let mut ti = 0
while ti <= 20 {
    if trib_dp_array(ti) != trib_sliding(ti) { trib_eq = false }
    ti = ti + 1
}
check("trib array==sliding (0..20)", trib_eq, true)

println("")

// ================================================================
//  SECTION 3: Staircase climbing -- dp[i] = dp[i-1] + dp[i-2]
//  Same recurrence as Fibonacci but different base cases
// ================================================================

println("--- Section 3: Staircase climbing (lookback=2) ---")

fn stairs_dp_array(n) {
    if n <= 1 { return 1 }
    let mut dp = [1, 1]
    let mut i = 2
    while i <= n {
        dp.push(dp[i - 1] + dp[i - 2])
        i = i + 1
    }
    return dp[n]
}

fn stairs_sliding(n) {
    if n <= 1 { return 1 }
    let mut prev2 = 1
    let mut prev1 = 1
    let mut i = 2
    while i <= n {
        let cur = prev1 + prev2
        prev2 = prev1
        prev1 = cur
        i = i + 1
    }
    return prev1
}

check("stairs_dp(0)", stairs_dp_array(0), 1)
check("stairs_dp(1)", stairs_dp_array(1), 1)
check("stairs_dp(5)", stairs_dp_array(5), 8)
check("stairs_dp(10)", stairs_dp_array(10), 89)

check("stairs_sliding(0)", stairs_sliding(0), 1)
check("stairs_sliding(1)", stairs_sliding(1), 1)
check("stairs_sliding(5)", stairs_sliding(5), 8)
check("stairs_sliding(10)", stairs_sliding(10), 89)

let mut stairs_eq = true
let mut si = 0
while si <= 20 {
    if stairs_dp_array(si) != stairs_sliding(si) { stairs_eq = false }
    si = si + 1
}
check("stairs array==sliding (0..20)", stairs_eq, true)

println("")

// ================================================================
//  SECTION 4: @optimize detection of DP pattern
//  Functions with @optimize that use the dp[i] = f(dp[i-1],dp[i-2])
//  pattern. The M973/M976 pass should detect these.
// ================================================================

println("--- Section 4: @optimize annotated DP detection ---")

@optimize fn fib_annotated(n) {
    if n <= 1 { return n }
    let mut dp = [0, 1]
    let mut i = 2
    while i <= n {
        dp.push(dp[i - 1] + dp[i - 2])
        i = i + 1
    }
    return dp[n]
}

// The @optimize pass should detect dp lookback and flag for sliding window
// Even if not rewritten yet, the function must produce correct results
check("fib_annotated(0)", fib_annotated(0), 0)
check("fib_annotated(1)", fib_annotated(1), 1)
check("fib_annotated(5)", fib_annotated(5), 5)
check("fib_annotated(10)", fib_annotated(10), 55)
check("fib_annotated(20)", fib_annotated(20), 6765)

println("")

// ================================================================
//  SECTION 5: Min-cost DP with lookback=2
//  dp[i] = min(dp[i-1], dp[i-2]) + cost[i]
// ================================================================

println("--- Section 5: Min-cost DP (lookback=2) ---")

fn min_cost_array(costs) {
    let n = len(costs)
    if n == 0 { return 0 }
    if n == 1 { return costs[0] }
    let mut dp = [costs[0], costs[1]]
    let mut i = 2
    while i < n {
        let prev1 = dp[i - 1]
        let prev2 = dp[i - 2]
        let mut best = prev1
        if prev2 < best { best = prev2 }
        dp.push(best + costs[i])
        i = i + 1
    }
    return dp[n - 1]
}

fn min_cost_sliding(costs) {
    let n = len(costs)
    if n == 0 { return 0 }
    if n == 1 { return costs[0] }
    let mut prev2 = costs[0]
    let mut prev1 = costs[1]
    let mut i = 2
    while i < n {
        let mut best = prev1
        if prev2 < best { best = prev2 }
        let cur = best + costs[i]
        prev2 = prev1
        prev1 = cur
        i = i + 1
    }
    return prev1
}

let costs1 = [10, 15, 20]
check("min_cost_array([10,15,20])", min_cost_array(costs1), 30)
check("min_cost_sliding([10,15,20])", min_cost_sliding(costs1), 30)

let costs2 = [1, 100, 1, 1, 1, 100, 1, 1, 100, 1]
check("min_cost_array long", min_cost_array(costs2), 6)
check("min_cost_sliding long", min_cost_sliding(costs2), 6)

let costs3 = [5]
check("min_cost_array([5])", min_cost_array(costs3), 5)
check("min_cost_sliding([5])", min_cost_sliding(costs3), 5)

println("")

// ================================================================
//  SECTION 6: Performance comparison (large N)
// ================================================================

println("--- Section 6: Performance at scale ---")

// Fibonacci at larger N
check("fib_sliding(30)", fib_sliding(30), 832040)

// Stairs at larger N
check("stairs_sliding(25)", stairs_sliding(25), 121393)

// Verify consistency
let mut large_eq = true
let mut li = 0
while li <= 30 {
    if fib_dp_array(li) != fib_sliding(li) { large_eq = false }
    li = li + 1
}
check("fib consistency (0..30)", large_eq, true)

println("")

// ================================================================
//  SUMMARY
// ================================================================

println("===============================================================")
println("  DP sliding window total: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("===============================================================")

if fail_count > 0 {
    println("SOME TESTS FAILED")
}
