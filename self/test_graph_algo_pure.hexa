// self/test_graph_algo_pure.hexa -- Tests for self/runtime/graph_algo_pure.hexa
//
// Inlined module: codegen_c2 import/use for runtime/*_pure.hexa isn't wired
// for test files (same pattern as test_graph_pure / test_rle_pure).

// ═══════════════════════════════════════════════════════════════════
// ── inlined graph_algo_pure.hexa ──────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

fn _set_at(arr, idx, val) {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx {
            out.push(val)
        } else {
            out.push(arr[i])
        }
        i = i + 1
    }
    return out
}

fn _contains(arr, val) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == val { return true }
        i = i + 1
    }
    return false
}

fn bfs_distance_pure(adj, start) {
    let n = len(adj)
    let mut dist = []
    let mut i = 0
    while i < n {
        dist.push(-1)
        i = i + 1
    }
    if n == 0 { return dist }
    if start < 0 { return dist }
    if start >= n { return dist }
    dist = _set_at(dist, start, 0)
    let mut queue = []
    queue.push(start)
    let mut head = 0
    while head < len(queue) {
        let cur = queue[head]
        head = head + 1
        let neighbors = adj[cur]
        let nn = len(neighbors)
        let mut j = 0
        while j < nn {
            let nb = neighbors[j]
            if nb >= 0 {
                if nb < n {
                    if dist[nb] == -1 {
                        dist = _set_at(dist, nb, dist[cur] + 1)
                        queue.push(nb)
                    }
                }
            }
            j = j + 1
        }
    }
    return dist
}

fn shortest_path_bfs_pure(adj, start, end) {
    let n = len(adj)
    if n == 0 { return [] }
    if start < 0 { return [] }
    if start >= n { return [] }
    if end < 0 { return [] }
    if end >= n { return [] }
    if start == end { return [start] }
    let mut parent = []
    let mut i = 0
    while i < n {
        parent.push(-1)
        i = i + 1
    }
    let mut visited = []
    let mut vi = 0
    while vi < n {
        visited.push(false)
        vi = vi + 1
    }
    visited = _set_at(visited, start, true)
    let mut queue = []
    queue.push(start)
    let mut head = 0
    let mut found = false
    while head < len(queue) {
        let cur = queue[head]
        head = head + 1
        if cur == end {
            found = true
            head = len(queue)
        } else {
            let neighbors = adj[cur]
            let nn = len(neighbors)
            let mut j = 0
            while j < nn {
                let nb = neighbors[j]
                if nb >= 0 {
                    if nb < n {
                        if visited[nb] == false {
                            visited = _set_at(visited, nb, true)
                            parent = _set_at(parent, nb, cur)
                            queue.push(nb)
                        }
                    }
                }
                j = j + 1
            }
        }
    }
    if found == false { return [] }
    let mut rev = []
    let mut cur2 = end
    let mut hops = 0
    while cur2 != -1 {
        rev.push(cur2)
        if cur2 == start {
            cur2 = -1
        } else {
            cur2 = parent[cur2]
        }
        hops = hops + 1
        if hops > n + 1 { cur2 = -1 }
    }
    let mut path = []
    let mut k = len(rev) - 1
    while k >= 0 {
        path.push(rev[k])
        k = k - 1
    }
    return path
}

fn _bfs_reach_undirected(adj, start, already_visited) {
    let n = len(adj)
    let mut comp = []
    let mut visited_local = already_visited
    if visited_local[start] { return [comp, visited_local] }
    visited_local = _set_at(visited_local, start, true)
    let mut queue = []
    queue.push(start)
    let mut head = 0
    while head < len(queue) {
        let cur = queue[head]
        head = head + 1
        comp.push(cur)
        let neighbors = adj[cur]
        let nn = len(neighbors)
        let mut j = 0
        while j < nn {
            let nb = neighbors[j]
            if nb >= 0 {
                if nb < n {
                    if visited_local[nb] == false {
                        visited_local = _set_at(visited_local, nb, true)
                        queue.push(nb)
                    }
                }
            }
            j = j + 1
        }
        let mut u = 0
        while u < n {
            if visited_local[u] == false {
                if _contains(adj[u], cur) {
                    visited_local = _set_at(visited_local, u, true)
                    queue.push(u)
                }
            }
            u = u + 1
        }
    }
    return [comp, visited_local]
}

fn connected_components_pure(adj) {
    let n = len(adj)
    let mut visited = []
    let mut i = 0
    while i < n {
        visited.push(false)
        i = i + 1
    }
    let mut comps = []
    let mut k = 0
    while k < n {
        if visited[k] == false {
            let pair = _bfs_reach_undirected(adj, k, visited)
            let comp = pair[0]
            visited = pair[1]
            comps.push(comp)
        }
        k = k + 1
    }
    return comps
}

fn topo_sort_adj_pure(adj) {
    let n = len(adj)
    if n == 0 { return [] }
    let mut in_deg = []
    let mut i = 0
    while i < n {
        in_deg.push(0)
        i = i + 1
    }
    let mut u = 0
    while u < n {
        let neighbors = adj[u]
        let nn = len(neighbors)
        let mut j = 0
        while j < nn {
            let v = neighbors[j]
            if v >= 0 {
                if v < n {
                    in_deg = _set_at(in_deg, v, in_deg[v] + 1)
                }
            }
            j = j + 1
        }
        u = u + 1
    }
    let mut queue = []
    let mut k = 0
    while k < n {
        if in_deg[k] == 0 {
            queue.push(k)
        }
        k = k + 1
    }
    let mut result = []
    let mut head = 0
    while head < len(queue) {
        let node = queue[head]
        head = head + 1
        result.push(node)
        let neighbors = adj[node]
        let nn = len(neighbors)
        let mut ni = 0
        while ni < nn {
            let nb = neighbors[ni]
            if nb >= 0 {
                if nb < n {
                    let new_val = in_deg[nb] - 1
                    in_deg = _set_at(in_deg, nb, new_val)
                    if new_val == 0 {
                        queue.push(nb)
                    }
                }
            }
            ni = ni + 1
        }
    }
    if len(result) != n { return [] }
    return result
}

fn has_cycle_directed_pure(adj) {
    let n = len(adj)
    if n == 0 { return false }
    let order = topo_sort_adj_pure(adj)
    return len(order) != n
}

// ═══════════════════════════════════════════════════════════════════
// ── Test harness ──────────────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  graph_algo_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── Fixture 1: linear chain 0 -> 1 -> 2 -> 3 (directed) ───────────
// adj[0]=[1]  adj[1]=[2]  adj[2]=[3]  adj[3]=[]
let chain = [[1], [2], [3], []]

println("")
println("--- bfs_distance: linear chain ---")
let d_chain = bfs_distance_pure(chain, 0)
check("chain dist len", len(d_chain), 4)
check("chain dist[0]", d_chain[0], 0)
check("chain dist[1]", d_chain[1], 1)
check("chain dist[2]", d_chain[2], 2)
check("chain dist[3]", d_chain[3], 3)

// Start from middle — directed, so 0 is unreachable from 2
let d_chain_mid = bfs_distance_pure(chain, 2)
check("chain dist from 2: [0]=-1", d_chain_mid[0], -1)
check("chain dist from 2: [2]=0", d_chain_mid[2], 0)
check("chain dist from 2: [3]=1", d_chain_mid[3], 1)

println("")
println("--- shortest_path_bfs: linear chain ---")
let p_chain = shortest_path_bfs_pure(chain, 0, 3)
check("chain path 0->3 len", len(p_chain), 4)
check("chain path 0->3 first", p_chain[0], 0)
check("chain path 0->3 last", p_chain[3], 3)
check("chain path self 2->2", shortest_path_bfs_pure(chain, 2, 2)[0], 2)
check("chain path self 2->2 len", len(shortest_path_bfs_pure(chain, 2, 2)), 1)

// No reverse path in directed chain
let p_chain_rev = shortest_path_bfs_pure(chain, 3, 0)
check("chain no path 3->0", len(p_chain_rev), 0)

// ── Fixture 2: tree with branches (directed root-down) ────────────
//       0
//      / \
//     1   2
//    / \   \
//   3   4   5
let tree = [[1, 2], [3, 4], [5], [], [], []]

println("")
println("--- bfs_distance: tree ---")
let d_tree = bfs_distance_pure(tree, 0)
check("tree dist[0]", d_tree[0], 0)
check("tree dist[1]", d_tree[1], 1)
check("tree dist[2]", d_tree[2], 1)
check("tree dist[3]", d_tree[3], 2)
check("tree dist[4]", d_tree[4], 2)
check("tree dist[5]", d_tree[5], 2)

println("")
println("--- shortest_path_bfs: tree 0 -> 5 ---")
let p_tree = shortest_path_bfs_pure(tree, 0, 5)
check("tree path 0->5 len", len(p_tree), 3)
check("tree path 0->5 [0]", p_tree[0], 0)
check("tree path 0->5 [1]", p_tree[1], 2)
check("tree path 0->5 [2]", p_tree[2], 5)

// ── Fixture 3: directed cycle 0 -> 1 -> 2 -> 0 ────────────────────
let cyc = [[1], [2], [0]]

println("")
println("--- has_cycle_directed / topo_sort on cycle ---")
check("cycle has_cycle", has_cycle_directed_pure(cyc), true)
check("cycle topo == []", len(topo_sort_adj_pure(cyc)), 0)

// ── Fixture 4: DAG for topo sort ──────────────────────────────────
//   0 -> 1 -> 3
//   0 -> 2 -> 3
let dag = [[1, 2], [3], [3], []]

println("")
println("--- topo_sort_adj_pure: DAG ---")
let topo = topo_sort_adj_pure(dag)
check("dag topo len", len(topo), 4)
check("dag topo starts at 0", topo[0], 0)
check("dag topo ends at 3", topo[len(topo) - 1], 3)
check("dag has_cycle false", has_cycle_directed_pure(dag), false)

// Empty graph
let empty_g = []
check("empty has_cycle", has_cycle_directed_pure(empty_g), false)
check("empty topo len", len(topo_sort_adj_pure(empty_g)), 0)

// ── Fixture 5: disconnected components (undirected view) ──────────
// Two separate parts: {0-1-2} and {3-4}
// Directed edges, but connected_components_pure treats as undirected.
let disc = [[1], [2], [], [4], []]

println("")
println("--- connected_components_pure: 2 parts ---")
let comps = connected_components_pure(disc)
check("disc num components", len(comps), 2)
check("disc comp0 len", len(comps[0]), 3)
check("disc comp1 len", len(comps[1]), 2)
check("disc comp0 contains 0", _contains(comps[0], 0), true)
check("disc comp0 contains 2", _contains(comps[0], 2), true)
check("disc comp1 contains 3", _contains(comps[1], 3), true)
check("disc comp1 contains 4", _contains(comps[1], 4), true)

// ── Fixture 6: single node ────────────────────────────────────────
let one = [[]]

println("")
println("--- single-node graph ---")
check("one bfs_distance[0]", bfs_distance_pure(one, 0)[0], 0)
check("one path self", shortest_path_bfs_pure(one, 0, 0)[0], 0)
check("one components", len(connected_components_pure(one)), 1)
check("one topo", topo_sort_adj_pure(one)[0], 0)
check("one no cycle", has_cycle_directed_pure(one), false)

// ── Fixture 7: empty graph ────────────────────────────────────────
println("")
println("--- empty graph ---")
check("empty bfs_distance len", len(bfs_distance_pure(empty_g, 0)), 0)
check("empty shortest_path", len(shortest_path_bfs_pure(empty_g, 0, 0)), 0)
check("empty components", len(connected_components_pure(empty_g)), 0)

// ── Fixture 8: unreachable target ─────────────────────────────────
// Graph: 0 -> 1, 2 isolated. Path 0 -> 2 should be [].
let unreach = [[1], [], []]

println("")
println("--- unreachable target ---")
check("unreach no path 0->2", len(shortest_path_bfs_pure(unreach, 0, 2)), 0)
check("unreach dist[2]", bfs_distance_pure(unreach, 0)[2], -1)

// ── Summary ────────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
