// ═══════════════════════════════════════════════════════════
//  test_ai_native_v2.hexa — AI-native @attr v2 extension tests
//  Tests: @specialize (M962), @lazy (M963), @reduce (M964)
//
//  Validates runtime-neutral semantics: the @attr annotations
//  are recognized by parser + ai_native_pass, runtime behavior
//  must be identical to unannotated code.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA AI-Native @attr v2 Tests (M962/M963/M964)")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. @specialize — literal-arg monomorphization ────────

println("--- @specialize (M962) ---")

@specialize fn spec_mul(x: int) -> int { return x * 10 }
@specialize fn spec_add(x: int, y: int) -> int { return x + y + 1 }
@specialize fn spec_poly(x: int) -> int { return x * x + 3 * x + 5 }
@specialize fn spec_shift(x: int) -> int { return x * 8 }
@specialize fn spec_clamp(v: int) -> int {
    if v > 100 { return 100 }
    if v < 0 { return 0 }
    return v
}

check("@specialize mul(5)", spec_mul(5), 50)
check("@specialize mul(0)", spec_mul(0), 0)
check("@specialize add(3,4)", spec_add(3, 4), 8)
check("@specialize poly(2)", spec_poly(2), 15)
check("@specialize poly(0)", spec_poly(0), 5)
check("@specialize shift(7)", spec_shift(7), 56)
check("@specialize clamp(50)", spec_clamp(50), 50)
check("@specialize clamp(250)", spec_clamp(250), 100)
check("@specialize clamp(-5)", spec_clamp(-5), 0)

// ── 2. @lazy — deferred pure thunks ──────────────────────

println("")
println("--- @lazy (M963) ---")

@pure @lazy fn lazy_pi() -> int { return 314159 }
@pure @lazy fn lazy_answer() -> int { return 42 }
@pure @lazy fn lazy_compute() -> int {
    let mut s = 0
    let mut i = 0
    while i < 10 {
        s = s + i
        i = i + 1
    }
    return s
}
@pure @lazy fn lazy_str() -> string { return "lazy!" }

// Note: Rust interp already rewrites @lazy fns into thunk-returning functions,
// so we force-evaluate via double-call. Static detection is what M963 validates.
let t_pi = lazy_pi()
let t_ans = lazy_answer()
let t_cmp = lazy_compute()
let t_str = lazy_str()
check("@lazy pi force", t_pi(), 314159)
check("@lazy answer force", t_ans(), 42)
check("@lazy compute force 0..10", t_cmp(), 45)
check("@lazy str force", t_str(), "lazy!")
check("@lazy pi idempotent", t_pi() == t_pi(), true)
check("@lazy answer stable", t_ans(), 42)

// ── 3. @reduce — accumulator fold detection ──────────────

println("")
println("--- @reduce (M964) ---")

@reduce fn reduce_sum(n: int) -> int {
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + i
        i = i + 1
    }
    return s
}

@reduce fn reduce_product(n: int) -> int {
    let mut p = 1
    let mut i = 1
    while i <= n {
        p = p * i
        i = i + 1
    }
    return p
}

@reduce fn reduce_sum_squares(n: int) -> int {
    let mut s = 0
    let mut i = 1
    while i <= n {
        s = s + i * i
        i = i + 1
    }
    return s
}

@reduce fn reduce_count_odd(n: int) -> int {
    let mut c = 0
    let mut i = 0
    while i < n {
        if i % 2 == 1 { c = c + 1 }
        i = i + 1
    }
    return c
}

@reduce fn reduce_pow2(n: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

check("@reduce sum 0..10", reduce_sum(10), 45)
check("@reduce sum 0..100", reduce_sum(100), 4950)
check("@reduce sum 0", reduce_sum(0), 0)
check("@reduce product 5!", reduce_product(5), 120)
check("@reduce product 10!", reduce_product(10), 3628800)
check("@reduce sum_squares 1..5", reduce_sum_squares(5), 55)
check("@reduce sum_squares 1..10", reduce_sum_squares(10), 385)
check("@reduce count_odd 0..10", reduce_count_odd(10), 5)
check("@reduce count_odd 0..100", reduce_count_odd(100), 50)
check("@reduce pow2 10", reduce_pow2(10), 1024)
check("@reduce pow2 0", reduce_pow2(0), 1)

// ── 4. Combined attrs ────────────────────────────────────

println("")
println("--- @reduce + @pure combination ---")

@pure @reduce fn pure_reduce_sum(n: int) -> int {
    let mut s = 0
    let mut i = 1
    while i <= n {
        s = s + i
        i = i + 1
    }
    return s
}

check("@pure @reduce 1..10", pure_reduce_sum(10), 55)
check("@pure @reduce 1..100", pure_reduce_sum(100), 5050)
check("@pure @reduce idempotent", pure_reduce_sum(50) == pure_reduce_sum(50), true)

@pure @specialize fn pure_spec(x: int) -> int {
    return x * 2 + 1
}

check("@pure @specialize odd(5)", pure_spec(5), 11)
check("@pure @specialize odd(0)", pure_spec(0), 1)
check("@pure @specialize odd(7)", pure_spec(7), 15)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL AI-NATIVE v2 TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
