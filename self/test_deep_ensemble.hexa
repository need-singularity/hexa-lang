// ═══════════════════════════════════════════════════════════════
//  test_deep_ensemble.hexa — Deep Ensemble (#273) tests
//
//  Verifies:
//    1. softmax sums to 1
//    2. softmax non-negative
//    3. entropy of uniform = log(K)
//    4. entropy of delta = 0
//    5. member init shapes (W1, W2, b1, b2)
//    6. forward_logits output length
//    7. forward_probs sums to 1
//    8. ensemble members have distinct first weights (different seeds)
//    9. ensemble probs sum to 1
//   10. ensemble probs between individual extremes
//   11. mutual info non-negative
//   12. regression mean/var both finite, var≥0
//   13. identical members give zero variance
//   14. argmax correctness
//
//  Run: ./hexa self/test_deep_ensemble.hexa
// ═══════════════════════════════════════════════════════════════

import "ml/deep_ensemble.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(v) {
    if v < 0.0 { return 0.0 - v }
    return v
}
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("═══════════════════════════════════════════════════════")
println("  Deep Ensemble (#273) Test Suite")
println("═══════════════════════════════════════════════════════")

// ── Test 1: softmax sum to 1
let p1 = de_softmax([1.0, 2.0, 3.0])
let s1 = p1[0] + p1[1] + p1[2]
check("softmax sums to 1", approx(s1, 1.0, 1.0e-9))

// ── Test 2: softmax non-negative
let neg_ok = p1[0] >= 0.0 && p1[1] >= 0.0 && p1[2] >= 0.0
check("softmax non-negative", neg_ok)

// ── Test 3: entropy of uniform over K=4 = log(4) ≈ 1.386294
let uniform4 = [0.25, 0.25, 0.25, 0.25]
check("entropy uniform = log(4)", approx(de_entropy(uniform4), 1.3862943611198906, 1.0e-6))

// ── Test 4: entropy of delta distribution = 0
let delta = [0.0, 1.0, 0.0]
check("entropy delta = 0", approx(de_entropy(delta), 0.0, 1.0e-6))

// ── Test 5: member init shapes
let m1 = de_init_member(3, 4, 2, 42)
check("W1 rows", len(m1["W1"]) == 4)
check("W1 cols", len(m1["W1"][0]) == 3)
check("b1 length", len(m1["b1"]) == 4)
check("W2 rows", len(m1["W2"]) == 2)
check("W2 cols", len(m1["W2"][0]) == 4)
check("b2 length", len(m1["b2"]) == 2)

// ── Test 6: forward_logits output length
let feat6 = [0.1, 0.2, 0.3]
let lg6 = de_forward_logits(m1, feat6)
check("logits length", len(lg6) == 2)

// ── Test 7: forward_probs sums to 1
let p7 = de_forward_probs(m1, feat6)
let s7 = p7[0] + p7[1]
check("member probs sum to 1", approx(s7, 1.0, 1.0e-9))

// ── Test 8: ensemble members differ
let ens = de_make_ensemble(4, 3, 4, 2, 7)
let diff = ens[0]["W1"][0][0] - ens[1]["W1"][0][0]
check("members have distinct W1[0][0]", fabs(diff) > 1.0e-6)

// ── Test 9: ensemble probs sum to 1
let ep = de_ensemble_probs(ens, feat6)
let se = ep[0] + ep[1]
check("ensemble probs sum to 1", approx(se, 1.0, 1.0e-9))

// ── Test 10: ensemble prob[0] between min and max of individual
let mut min0 = 2.0
let mut max0 = 0.0 - 2.0
for m in 0..4 {
    let pm = de_forward_probs(ens[m], feat6)
    if pm[0] < min0 { min0 = pm[0] }
    if pm[0] > max0 { max0 = pm[0] }
}
check("ensemble prob between min and max", ep[0] >= min0 - 1.0e-9 && ep[0] <= max0 + 1.0e-9)

// ── Test 11: mutual information non-negative (up to tolerance)
let mi = de_mutual_information(ens, feat6)
check("mutual info >= 0", mi >= 0.0 - 1.0e-9)

// ── Test 12: regression ensemble on out_dim=1
let ens_r = de_make_ensemble(5, 2, 4, 1, 13)
let feat12 = [0.3, 0.0 - 0.2]
let res = de_reg_mean_var(ens_r, feat12)
check("reg variance >= 0", res["var"] >= 0.0)
check("reg mean finite", fabs(res["mean"]) < 1000.0)

// ── Test 13: identical members → zero variance
let mm = de_init_member(2, 3, 1, 99)
let ens_same = [mm, mm, mm]
let res_same = de_reg_mean_var(ens_same, [0.1, 0.2])
check("identical members zero var", approx(res_same["var"], 0.0, 1.0e-12))

// ── Test 14: argmax
check("argmax simple", de_argmax([0.1, 0.5, 0.4]) == 1)

// ── Test 15: predict returns valid class index
let pred = de_predict(ens, feat6)
check("predict in range", pred == 0 || pred == 1)

// ── Test 16: predictive entropy positive and bounded
let h_pred = de_predictive_entropy(ens, feat6)
check("predictive entropy >= 0", h_pred >= 0.0)
check("predictive entropy <= log(2)", h_pred <= 0.6931471805599453 + 1.0e-6)

// ── Test 17: cross-entropy loss on simple dataset is positive
let ce = de_ce_loss(m1, [feat6, [0.4, 0.5, 0.6]], [0, 1])
check("ce loss positive", ce >= 0.0)

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
