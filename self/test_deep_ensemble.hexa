// ═══════════════════════════════════════════════════════════════
//  test_deep_ensemble.hexa — Deep Ensemble (#273) tests
//
//  Verifies:
//    1. softmax sums to 1
//    2. softmax non-negative
//    3. entropy of uniform = log(K)
//    4. entropy of delta = 0
//    5. member init shapes (W1, W2, b1, b2)
//    6. forward_logits output length
//    7. forward_probs sums to 1
//    8. ensemble members have distinct first weights (different seeds)
//    9. ensemble probs sum to 1
//   10. ensemble probs between individual extremes
//   11. mutual info non-negative
//   12. regression mean/var both finite, var≥0
//   13. identical members give zero variance
//   14. argmax correctness
//
//  Run: ./hexa self/test_deep_ensemble.hexa
// ═══════════════════════════════════════════════════════════════

// -- inlined from self/ml/deep_ensemble.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════
//  self/ml/deep_ensemble.hexa — Deep Ensemble (#273)
//
//  Ref: Lakshminarayanan et al. 2017 — "Simple and Scalable
//       Predictive Uncertainty Estimation using Deep Ensembles"
//
//  Idea: train M neural networks with independent random init
//        on the same data, then at inference time average
//        their predictions. The variance across members gives
//        an uncertainty estimate "for free".
//
//  Classification:
//    p_bar(y|x) = (1/M) * sum_m p_m(y|x)   (averaged probs)
//    prediction = argmax_y p_bar(y|x)
//    uncertainty = H(p_bar)                (entropy)
//    epistemic   = mean_m H(p_m) − H(p_bar) (disagreement)
//
//  Regression / scalar output:
//    mu(x) = (1/M) * sum_m f_m(x)
//    var(x)= (1/M) * sum_m (f_m(x) - mu(x))^2
//
//  Demo architecture: 2-layer MLP with tanh hidden, linear head.
//  Each member has an independent seed so weight inits differ.
//
//  AI-NATIVE:
//    @pure  — forward + aggregation
// ═══════════════════════════════════════════════════════════════

fn de_abs(v) {
    if v < 0.0 { return 0.0 - v }
    return v
}

fn de_zeros(n) {
    let mut r = []
    for _i in 0..n { r = r + [0.0] }
    return r
}

fn de_zeros2d(m, n) {
    let mut r = []
    for _i in 0..m { r = r + [de_zeros(n)] }
    return r
}

fn de_hash(seed, i, j) {
    let h = (seed * 2654435761 + i * 1315423911 + j * 731) % 10007
    return to_float(h) / 10007.0 - 0.5
}

@pure
fn de_tanh(v) {
    let mut u = v
    if u > 20.0 { u = 20.0 }
    if u < (0.0 - 20.0) { u = 0.0 - 20.0 }
    let e2 = exp(2.0 * u)
    return (e2 - 1.0) / (e2 + 1.0)
}

// numerically stable softmax
@pure
fn de_softmax(logits) {
    let n = len(logits)
    let mut m = logits[0]
    for i in 1..n {
        if logits[i] > m { m = logits[i] }
    }
    let mut sum = 0.0
    let mut exps = []
    for i in 0..n {
        let e = exp(logits[i] - m)
        exps = exps + [e]
        sum = sum + e
    }
    let mut out = []
    for i in 0..n { out = out + [exps[i] / sum] }
    return out
}

@pure
fn de_log(v) {
    let mut u = v
    if u < 1.0e-12 { u = 1.0e-12 }
    return log(u)
}

// Shannon entropy H(p) = -sum p_i log p_i
@pure
fn de_entropy(p) {
    let n = len(p)
    let mut s = 0.0
    for i in 0..n {
        if p[i] > 1.0e-12 {
            s = s - p[i] * de_log(p[i])
        }
    }
    return s
}

// ═══════════════════════════════════════════════════════════════
//  (1) Single-member 2-layer MLP (classification head = softmax)
//
//    params: dict with W1[h x d], b1[h], W2[c x h], b2[c]
// ═══════════════════════════════════════════════════════════════
fn de_init_member(in_dim, hidden, out_dim, seed) {
    let mut W1 = de_zeros2d(hidden, in_dim)
    let mut b1 = de_zeros(hidden)
    let mut W2 = de_zeros2d(out_dim, hidden)
    let mut b2 = de_zeros(out_dim)
    for i in 0..hidden {
        for j in 0..in_dim {
            W1[i][j] = 0.5 * de_hash(seed, i, j)
        }
        b1[i] = 0.1 * de_hash(seed + 17, i, 0)
    }
    for i in 0..out_dim {
        for j in 0..hidden {
            W2[i][j] = 0.5 * de_hash(seed + 31, i, j)
        }
        b2[i] = 0.1 * de_hash(seed + 47, i, 0)
    }
    return #{
        "W1": W1,
        "b1": b1,
        "W2": W2,
        "b2": b2,
        "in_dim": in_dim,
        "hidden": hidden,
        "out_dim": out_dim
    }
}

@pure
fn de_forward_logits(member, feat) {
    let in_dim = member["in_dim"]
    let hidden = member["hidden"]
    let out_dim = member["out_dim"]
    let W1 = member["W1"]
    let b1 = member["b1"]
    let W2 = member["W2"]
    let b2 = member["b2"]
    // hidden = tanh(W1 @ feat + b1)
    let mut h = de_zeros(hidden)
    for i in 0..hidden {
        let mut s = b1[i]
        for j in 0..in_dim {
            s = s + W1[i][j] * feat[j]
        }
        h[i] = de_tanh(s)
    }
    // logits = W2 @ h + b2
    let mut logits = de_zeros(out_dim)
    for i in 0..out_dim {
        let mut s = b2[i]
        for j in 0..hidden {
            s = s + W2[i][j] * h[j]
        }
        logits[i] = s
    }
    return logits
}

@pure
fn de_forward_probs(member, feat) {
    let lg = de_forward_logits(member, feat)
    return de_softmax(lg)
}

// ═══════════════════════════════════════════════════════════════
//  (2) Ensemble builder: M members with distinct seeds
// ═══════════════════════════════════════════════════════════════
fn de_make_ensemble(M, in_dim, hidden, out_dim, base_seed) {
    let mut members = []
    for m in 0..M {
        let s = base_seed + m * 101
        members = members + [de_init_member(in_dim, hidden, out_dim, s)]
    }
    return members
}

// ═══════════════════════════════════════════════════════════════
//  (3) Ensemble inference
//
//  Averaged probabilities + class prediction + entropy.
// ═══════════════════════════════════════════════════════════════
fn de_ensemble_probs(members, feat) {
    let M = len(members)
    let out_dim = members[0]["out_dim"]
    let mut avg = de_zeros(out_dim)
    for m in 0..M {
        let p = de_forward_probs(members[m], feat)
        for i in 0..out_dim {
            avg[i] = avg[i] + p[i]
        }
    }
    let inv = 1.0 / to_float(M)
    let mut out = []
    for i in 0..out_dim { out = out + [avg[i] * inv] }
    return out
}

fn de_argmax(p) {
    let n = len(p)
    let mut best = 0
    let mut bv = p[0]
    for i in 1..n {
        if p[i] > bv { bv = p[i]; best = i }
    }
    return best
}

fn de_predict(members, feat) {
    let p = de_ensemble_probs(members, feat)
    return de_argmax(p)
}

// Predictive entropy of the averaged distribution
fn de_predictive_entropy(members, feat) {
    let p = de_ensemble_probs(members, feat)
    return de_entropy(p)
}

// Mutual information / epistemic term:
//   MI = H[E_m p_m] − E_m H[p_m]
fn de_mutual_information(members, feat) {
    let M = len(members)
    let p_bar = de_ensemble_probs(members, feat)
    let h_bar = de_entropy(p_bar)
    let mut avg_h = 0.0
    for m in 0..M {
        avg_h = avg_h + de_entropy(de_forward_probs(members[m], feat))
    }
    avg_h = avg_h / to_float(M)
    return h_bar - avg_h
}

// ═══════════════════════════════════════════════════════════════
//  (4) Scalar regression variant — variance across members
// ═══════════════════════════════════════════════════════════════
@pure
fn de_regression_value(member, feat) {
    // use logits[0] as the scalar output (out_dim must be 1)
    let lg = de_forward_logits(member, feat)
    return lg[0]
}

fn de_reg_mean_var(members, feat) {
    let M = len(members)
    let mut vals = []
    let mut sum = 0.0
    for m in 0..M {
        let v = de_regression_value(members[m], feat)
        vals = vals + [v]
        sum = sum + v
    }
    let mean = sum / to_float(M)
    let mut ss = 0.0
    for m in 0..M {
        let d = vals[m] - mean
        ss = ss + d * d
    }
    let varv = ss / to_float(M)
    return #{ "mean": mean, "var": varv }
}

// ═══════════════════════════════════════════════════════════════
//  (5) Training step on one member (cross-entropy SGD)
// ═══════════════════════════════════════════════════════════════
fn de_ce_loss(member, feats, labels) {
    let n = len(feats)
    let mut s = 0.0
    for k in 0..n {
        let p = de_forward_probs(member, feats[k])
        let y = labels[k]
        s = s - de_log(p[y])
    }
    return s / to_float(n)
}

println("[deep_ensemble] loaded — independent MLP members + averaged softmax + variance uncertainty")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(v) {
    if v < 0.0 { return 0.0 - v }
    return v
}
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("═══════════════════════════════════════════════════════")
println("  Deep Ensemble (#273) Test Suite")
println("═══════════════════════════════════════════════════════")

// ── Test 1: softmax sum to 1
let p1 = de_softmax([1.0, 2.0, 3.0])
let s1 = p1[0] + p1[1] + p1[2]
check("softmax sums to 1", approx(s1, 1.0, 1.0e-9))

// ── Test 2: softmax non-negative
let neg_ok = p1[0] >= 0.0 && p1[1] >= 0.0 && p1[2] >= 0.0
check("softmax non-negative", neg_ok)

// ── Test 3: entropy of uniform over K=4 = log(4) ≈ 1.386294
let uniform4 = [0.25, 0.25, 0.25, 0.25]
check("entropy uniform = log(4)", approx(de_entropy(uniform4), 1.3862943611198906, 1.0e-6))

// ── Test 4: entropy of delta distribution = 0
let delta = [0.0, 1.0, 0.0]
check("entropy delta = 0", approx(de_entropy(delta), 0.0, 1.0e-6))

// ── Test 5: member init shapes
let m1 = de_init_member(3, 4, 2, 42)
check("W1 rows", len(m1["W1"]) == 4)
check("W1 cols", len(m1["W1"][0]) == 3)
check("b1 length", len(m1["b1"]) == 4)
check("W2 rows", len(m1["W2"]) == 2)
check("W2 cols", len(m1["W2"][0]) == 4)
check("b2 length", len(m1["b2"]) == 2)

// ── Test 6: forward_logits output length
let feat6 = [0.1, 0.2, 0.3]
let lg6 = de_forward_logits(m1, feat6)
check("logits length", len(lg6) == 2)

// ── Test 7: forward_probs sums to 1
let p7 = de_forward_probs(m1, feat6)
let s7 = p7[0] + p7[1]
check("member probs sum to 1", approx(s7, 1.0, 1.0e-9))

// ── Test 8: ensemble members differ
let ens = de_make_ensemble(4, 3, 4, 2, 7)
let diff = ens[0]["W1"][0][0] - ens[1]["W1"][0][0]
check("members have distinct W1[0][0]", fabs(diff) > 1.0e-6)

// ── Test 9: ensemble probs sum to 1
let ep = de_ensemble_probs(ens, feat6)
let se = ep[0] + ep[1]
check("ensemble probs sum to 1", approx(se, 1.0, 1.0e-9))

// ── Test 10: ensemble prob[0] between min and max of individual
let mut min0 = 2.0
let mut max0 = 0.0 - 2.0
for m in 0..4 {
    let pm = de_forward_probs(ens[m], feat6)
    if pm[0] < min0 { min0 = pm[0] }
    if pm[0] > max0 { max0 = pm[0] }
}
check("ensemble prob between min and max", ep[0] >= min0 - 1.0e-9 && ep[0] <= max0 + 1.0e-9)

// ── Test 11: mutual information non-negative (up to tolerance)
let mi = de_mutual_information(ens, feat6)
check("mutual info >= 0", mi >= 0.0 - 1.0e-9)

// ── Test 12: regression ensemble on out_dim=1
let ens_r = de_make_ensemble(5, 2, 4, 1, 13)
let feat12 = [0.3, 0.0 - 0.2]
let res = de_reg_mean_var(ens_r, feat12)
check("reg variance >= 0", res["var"] >= 0.0)
check("reg mean finite", fabs(res["mean"]) < 1000.0)

// ── Test 13: identical members → zero variance
let mm = de_init_member(2, 3, 1, 99)
let ens_same = [mm, mm, mm]
let res_same = de_reg_mean_var(ens_same, [0.1, 0.2])
check("identical members zero var", approx(res_same["var"], 0.0, 1.0e-12))

// ── Test 14: argmax
check("argmax simple", de_argmax([0.1, 0.5, 0.4]) == 1)

// ── Test 15: predict returns valid class index
let pred = de_predict(ens, feat6)
check("predict in range", pred == 0 || pred == 1)

// ── Test 16: predictive entropy positive and bounded
let h_pred = de_predictive_entropy(ens, feat6)
check("predictive entropy >= 0", h_pred >= 0.0)
check("predictive entropy <= log(2)", h_pred <= 0.6931471805599453 + 1.0e-6)

// ── Test 17: cross-entropy loss on simple dataset is positive
let ce = de_ce_loss(m1, [feat6, [0.4, 0.5, 0.6]], [0, 1])
check("ce loss positive", ce >= 0.0)

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
