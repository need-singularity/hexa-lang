// ===================================================================
//  test_inference_scaling.hexa — Inference Scaling verification (#178)
//
//  Tests (30+):
//    T1  best_of_n picks highest score
//    T2  best_of_n single candidate returns idx 0
//    T3  majority_vote picks most common
//    T4  majority_vote tie broken by first
//    T5  majority_vote single answer
//    T6  weighted_vote picks highest weight sum
//    T7  weighted_vote respects weight magnitude
//    T8  reward_ranked top-1 is correct
//    T9  reward_ranked sorted descending
//    T10 reward_ranked length matches input
//    T11 compute_budget basic division
//    T12 compute_budget zero cost returns 1
//    T13 compute_budget zero budget returns 1
//    T14 quality_curve marginal gains correct
//    T15 quality_curve monotone gains for concave
//    T16 quality_curve empty for single point
//    T17 scaling_predict two-point fit
//    T18 power_law_fit multi-point
//    T19 power_law_predict matches known
//    T20 best_of_n_early stops when threshold met
//    T21 best_of_n_early evaluates all if below threshold
//    T22 deduplicate removes duplicates
//    T23 deduplicate preserves first weight
//    T24 agreement_confidence unanimous = 1.0
//    T25 agreement_confidence split = 0.5
//    T26 efficiency_ratio correct magnitude
//    T27 optimal_n finds cutoff
//    T28 budget_optimal caps at max_n
//    T29 budget_optimal quality multiplier
//    T30 argmax correctness
//    T31 weighted_vote single candidate
//    T32 reward_ranked preserves all indices
//    T33 scaling_predict extrapolation grows
//
//  Run: cargo run --release -- self/test_inference_scaling.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// === inlined from inference_scaling.hexa =============================

fn is_zeros(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

fn is_zeros_int(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0] }
    return v
}

fn is_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn is_abs_int(x) {
    if x < 0 { return 0 - x }
    return x
}

fn is_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut _i = 0

    while _i < 30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn is_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1

    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn is_log_approx(x) {
    if x <= 0.0 { return -20.0 }
    let mut y = 0.0
    if x > 1.0 { y = to_float(to_int(x)) / 3.0 }
    if x < 1.0 { y = -1.0 }
    let mut _i = 0

    while _i < 40 {
        let ey = is_exp(y)
        if ey < 1.0e-15 { ey = 1.0e-15 }
        y = y + (x - ey) / ey
    }
    return y
}

fn is_pow(base, exp_val) {
    if base <= 0.0 { return 0.0 }
    return is_exp(exp_val * is_log_approx(base))
}

@pure
fn is_argmax(scores) {
    let n = len(scores)
    if n == 0 { return -1 }
    let mut best = 0
    let mut best_v = scores[0]
    let mut i = 1

    while i < n {
        if scores[i] > best_v {
            best_v = scores[i]
            best = i
        }
    }
    return best
}

@pure
fn is_best_of_n(responses, score_fn) {
    let n = len(responses)
    if n == 0 { return [-1, 0.0] }
    let mut best_idx = 0
    let mut best_score = score_fn(responses[0])
    let mut i = 1

    while i < n {
        let s = score_fn(responses[i])
        if s > best_score {
            best_score = s
            best_idx = i
        }
    }
    return [best_idx, best_score]
}

@pure
fn is_majority_vote(answers) {
    let n = len(answers)
    if n == 0 { return [-1, 0] }
    let mut unique = []
    let mut counts = []
    let mut i = 0

    while i < n {
        let a = answers[i]
        let mut found = false
        let mut j = 0

        while j < len(unique) {
            if unique[j] == a {
                counts[j] = counts[j] + 1
                found = true
            }
        }
        if found == false {
            unique = unique + [a]
            counts = counts + [1]
        }
    }
    let mut best_idx = 0
    let mut best_count = counts[0]
    let mut i = 1

    while i < len(counts) {
        if counts[i] > best_count {
            best_count = counts[i]
            best_idx = i
        }
    }
    return [unique[best_idx], best_count]
}

@pure
fn is_weighted_vote(answers, weights) {
    let n = len(answers)
    if n == 0 { return [-1, 0.0] }
    let mut unique = []
    let mut sums = []
    let mut i = 0

    while i < n {
        let a = answers[i]
        let w = weights[i]
        let mut found = false
        let mut j = 0

        while j < len(unique) {
            if unique[j] == a {
                sums[j] = sums[j] + w
                found = true
            }
        }
        if found == false {
            unique = unique + [a]
            sums = sums + [w]
        }
    }
    let mut best_idx = 0
    let mut best_w = sums[0]
    let mut i = 1

    while i < len(sums) {
        if sums[i] > best_w {
            best_w = sums[i]
            best_idx = i
        }
    }
    return [unique[best_idx], best_w]
}

@pure
fn is_reward_ranked(responses, reward_fn) {
    let n = len(responses)
    if n == 0 { return [[], []] }
    let mut scores = is_zeros(n)
    let mut i = 0

    while i < n {
        scores[i] = reward_fn(responses[i])
    }
    let mut indices = is_zeros_int(n)
    let mut i = 0

    while i < n { indices[i] = i }
    let mut i = 0

    while i < n {
        let mut best = i
        let mut j = (i + 1)

        while j < n {
            if scores[indices[j]] > scores[indices[best]] {
                best = j
            }
        }
        if best != i {
            let tmp = indices[i]
            indices[i] = indices[best]
            indices[best] = tmp
        }
    }
    let mut sorted_scores = is_zeros(n)
    let mut i = 0

    while i < n {
        sorted_scores[i] = scores[indices[i]]
    }
    return [indices, sorted_scores]
}

@pure
fn is_compute_budget(budget, cost_per) {
    if cost_per <= 0.0 { return 1 }
    if budget <= 0.0 { return 1 }
    let raw_n = to_int(budget / cost_per)
    if raw_n < 1 { return 1 }
    return raw_n
}

@pure
fn is_budget_optimal(budget, cost_per, max_n) {
    let n_raw = is_compute_budget(budget, cost_per)
    let mut n = n_raw
    if n > max_n { n = max_n }
    let quality_mult = is_sqrt(to_float(n))
    return [n, quality_mult]
}

@pure
fn is_quality_curve(best_scores_by_n) {
    let k = len(best_scores_by_n)
    if k < 2 { return [] }
    let mut gains = []
    let mut i = 1

    while i < k {
        let gain = best_scores_by_n[i] - best_scores_by_n[i - 1]
        gains = gains + [gain]
    }
    return gains
}

@pure
fn is_efficiency_ratio(best_scores_by_n, cost_per_sample) {
    let gains = is_quality_curve(best_scores_by_n)
    let k = len(gains)
    let mut ratios = []
    let mut i = 0

    while i < k {
        if cost_per_sample > 0.0 {
            ratios = ratios + [gains[i] / cost_per_sample]
        } else {
            ratios = ratios + [0.0]
        }
    }
    return ratios
}

@pure
fn is_optimal_n(best_scores_by_n, min_gain_threshold) {
    let gains = is_quality_curve(best_scores_by_n)
    let k = len(gains)
    let mut optimal = 1
    let fp_eps = 1.0e-9
    let mut i = 0

    while i < k {
        if gains[i] >= (min_gain_threshold - fp_eps) {
            optimal = i + 2
        }
    }
    return optimal
}

@pure
fn is_power_law_fit_two(n1, q1, n2, q2) {
    if n1 <= 0.0 { return [0.0, 0.0] }
    if n2 <= 0.0 { return [0.0, 0.0] }
    if q1 <= 0.0 { return [0.0, 0.0] }
    if q2 <= 0.0 { return [0.0, 0.0] }
    let log_ratio_q = is_log_approx(q2 / q1)
    let log_ratio_n = is_log_approx(n2 / n1)
    if is_abs(log_ratio_n) < 1.0e-10 { return [q1, 0.0] }
    let b = log_ratio_q / log_ratio_n
    let a = q1 / is_pow(n1, b)
    return [a, b]
}

@pure
fn is_power_law_predict(a, b, n) {
    if n <= 0.0 { return 0.0 }
    return a * is_pow(n, b)
}

@pure
fn is_power_law_fit(ns, qs) {
    let k = len(ns)
    if k < 2 { return [0.0, 0.0] }
    let mut sum_x = 0.0
    let mut sum_y = 0.0
    let mut sum_xx = 0.0
    let mut sum_xy = 0.0
    let mut count = 0
    let mut i = 0

    while i < k {
        if ns[i] > 0.0 {
            if qs[i] > 0.0 {
                let lx = is_log_approx(ns[i])
                let ly = is_log_approx(qs[i])
                sum_x = sum_x + lx
                sum_y = sum_y + ly
                sum_xx = sum_xx + lx * lx
                sum_xy = sum_xy + lx * ly
                count = count + 1
            }
        }
    }
    if count < 2 { return [0.0, 0.0] }
    let cf = to_float(count)
    let denom = cf * sum_xx - sum_x * sum_x
    if is_abs(denom) < 1.0e-12 { return [0.0, 0.0] }
    let b = (cf * sum_xy - sum_x * sum_y) / denom
    let log_a = (sum_y - b * sum_x) / cf
    let a = is_exp(log_a)
    return [a, b]
}

@pure
fn is_scaling_predict(ns, qs, n_target) {
    let params = is_power_law_fit(ns, qs)
    let a = params[0]
    let b = params[1]
    return is_power_law_predict(a, b, n_target)
}

@pure
fn is_best_of_n_early(responses, score_fn, threshold) {
    let n = len(responses)
    if n == 0 { return [-1, 0.0, 0] }
    let mut best_idx = 0
    let mut best_score = score_fn(responses[0])
    if best_score >= threshold { return [0, best_score, 1] }
    let mut i = 1

    while i < n {
        let s = score_fn(responses[i])
        if s > best_score {
            best_score = s
            best_idx = i
        }
        if best_score >= threshold {
            return [best_idx, best_score, i + 1]
        }
    }
    return [best_idx, best_score, n]
}

@pure
fn is_deduplicate(answers, weights) {
    let n = len(answers)
    let mut unique_a = []
    let mut unique_w = []
    let mut i = 0

    while i < n {
        let a = answers[i]
        let mut dup = false
        let mut j = 0

        while j < len(unique_a) {
            if unique_a[j] == a { dup = true }
        }
        if dup == false {
            unique_a = unique_a + [a]
            unique_w = unique_w + [weights[i]]
        }
    }
    return [unique_a, unique_w]
}

@pure
fn is_agreement_confidence(answers) {
    let vote = is_majority_vote(answers)
    let n = len(answers)
    if n == 0 { return 0.0 }
    return to_float(vote[1]) / to_float(n)
}

// === mock score functions ============================================

fn mock_score(x) {
    // response is an integer; score = value * 0.1
    return to_float(x) * 0.1
}

fn mock_reward(x) {
    // reward model: prefer higher values, with slight nonlinearity
    return to_float(x) * 0.5 + 1.0
}

// =====================================================================
//  TESTS
// =====================================================================

// T1: best_of_n picks highest score
let r1 = is_best_of_n([3, 7, 2, 9, 1], mock_score)
check("T1 best_of_n picks highest score idx=3", r1[0] == 3)
check("T1b best_of_n best score=0.9", approx(r1[1], 0.9, 0.01))

// T2: best_of_n single candidate returns idx 0
let r2 = is_best_of_n([42], mock_score)
check("T2 best_of_n single candidate idx=0", r2[0] == 0)

// T3: majority_vote picks most common
let v3 = is_majority_vote([1, 2, 2, 3, 2, 1])
check("T3 majority_vote winner=2", v3[0] == 2)
check("T3b majority_vote count=3", v3[1] == 3)

// T4: majority_vote tie broken by first occurrence
let v4 = is_majority_vote([1, 2, 1, 2])
// 1 and 2 each appear 2 times; first unique is 1
check("T4 majority_vote tie -> first (1)", v4[0] == 1)

// T5: majority_vote single answer
let v5 = is_majority_vote([7])
check("T5 majority_vote single=7", v5[0] == 7)
check("T5b majority_vote count=1", v5[1] == 1)

// T6: weighted_vote picks highest weight sum
let wv6 = is_weighted_vote([1, 2, 1, 3], [0.3, 0.9, 0.5, 0.2])
// answer 1: 0.3+0.5=0.8, answer 2: 0.9, answer 3: 0.2
check("T6 weighted_vote winner=2", wv6[0] == 2)

// T7: weighted_vote respects weight magnitude
let wv7 = is_weighted_vote([1, 1, 2, 2], [0.1, 0.1, 5.0, 5.0])
// answer 1: 0.2, answer 2: 10.0
check("T7 weighted_vote big weights -> answer 2", wv7[0] == 2)
check("T7b weighted total=10.0", approx(wv7[1], 10.0, 0.01))

// T8: reward_ranked top-1 is correct
let rr8 = is_reward_ranked([2, 5, 1, 8, 3], mock_reward)
let top1_idx = rr8[0][0]
check("T8 reward_ranked top-1 = idx 3 (value 8)", top1_idx == 3)

// T9: reward_ranked sorted descending
let rr_scores = rr8[1]
let mut sorted_ok = true
let mut i = 1

while i < len(rr_scores) {
    if rr_scores[i] > rr_scores[i - 1] { sorted_ok = false }
}
check("T9 reward_ranked scores descending", sorted_ok)

// T10: reward_ranked length matches
check("T10 reward_ranked len indices=5", len(rr8[0]) == 5)
check("T10b reward_ranked len scores=5", len(rr8[1]) == 5)

// T11: compute_budget basic division
let n11 = is_compute_budget(100.0, 10.0)
check("T11 compute_budget 100/10=10", n11 == 10)

// T12: compute_budget zero cost returns 1
let n12 = is_compute_budget(100.0, 0.0)
check("T12 compute_budget zero cost=1", n12 == 1)

// T13: compute_budget zero budget returns 1
let n13 = is_compute_budget(0.0, 10.0)
check("T13 compute_budget zero budget=1", n13 == 1)

// T14: quality_curve marginal gains correct
let curve14 = [0.5, 0.7, 0.8, 0.85, 0.87]
let gains14 = is_quality_curve(curve14)
check("T14 quality_curve len=4", len(gains14) == 4)
check("T14b first gain=0.2", approx(gains14[0], 0.2, 0.01))
check("T14c second gain=0.1", approx(gains14[1], 0.1, 0.01))

// T15: quality_curve monotone decreasing gains (concave)
let mut decreasing = true
let mut i = 1

while i < len(gains14) {
    if gains14[i] > gains14[i - 1] { decreasing = false }
}
check("T15 quality_curve gains are decreasing (concave)", decreasing)

// T16: quality_curve empty for single point
let gains16 = is_quality_curve([0.5])
check("T16 quality_curve single -> empty", len(gains16) == 0)

// T17: scaling_predict two-point fit
// If Q(1)=1.0, Q(4)=2.0, then b ~ 0.5 (sqrt scaling)
// Predict Q(16) should be ~4.0
let fit17 = is_power_law_fit_two(1.0, 1.0, 4.0, 2.0)
let pred17 = is_power_law_predict(fit17[0], fit17[1], 16.0)
check("T17 scaling two-point Q(16) ~ 4.0", approx(pred17, 4.0, 0.5))

// T18: power_law_fit multi-point
// sqrt-like data: Q(1)=1, Q(4)=2, Q(9)=3, Q(16)=4
let ns18 = [1.0, 4.0, 9.0, 16.0]
let qs18 = [1.0, 2.0, 3.0, 4.0]
let fit18 = is_power_law_fit(ns18, qs18)
// b should be ~ 0.5
check("T18 power_law_fit b ~ 0.5", approx(fit18[1], 0.5, 0.15))

// T19: power_law_predict matches known point
let pred19 = is_power_law_predict(fit18[0], fit18[1], 9.0)
check("T19 power_law_predict Q(9) ~ 3.0", approx(pred19, 3.0, 0.5))

// T20: best_of_n_early stops when threshold met
// responses: [1, 2, 10, 3, 4], score = val*0.1, threshold = 0.9
let early20 = is_best_of_n_early([1, 2, 10, 3, 4], mock_score, 0.9)
check("T20 early stop idx=2 (score=1.0)", early20[0] == 2)
check("T20b early stop n_evaluated=3", early20[2] == 3)

// T21: best_of_n_early evaluates all if below threshold
let early21 = is_best_of_n_early([1, 2, 3], mock_score, 999.0)
check("T21 no early stop -> all evaluated", early21[2] == 3)
check("T21b best idx=2", early21[0] == 2)

// T22: deduplicate removes duplicates
let dd22 = is_deduplicate([1, 2, 1, 3, 2], [0.5, 0.3, 0.7, 0.1, 0.9])
check("T22 deduplicate 3 unique", len(dd22[0]) == 3)

// T23: deduplicate preserves first weight
check("T23 dedup first weight of 1 = 0.5", approx(dd22[1][0], 0.5, 0.01))
check("T23b dedup first weight of 2 = 0.3", approx(dd22[1][1], 0.3, 0.01))

// T24: agreement_confidence unanimous = 1.0
let conf24 = is_agreement_confidence([5, 5, 5, 5])
check("T24 unanimous confidence=1.0", approx(conf24, 1.0, 0.01))

// T25: agreement_confidence split = 0.5
let conf25 = is_agreement_confidence([1, 2, 1, 2])
check("T25 split confidence=0.5", approx(conf25, 0.5, 0.01))

// T26: efficiency_ratio correct
let eff26 = is_efficiency_ratio([0.5, 0.7, 0.8], 1.0)
check("T26 efficiency_ratio len=2", len(eff26) == 2)
check("T26b first ratio=0.2", approx(eff26[0], 0.2, 0.01))

// T27: optimal_n finds cutoff
let opt27 = is_optimal_n([0.5, 0.7, 0.8, 0.85, 0.87], 0.05)
check("T27 optimal_n=4 (last gain>=0.05 is 0.05 at idx 2->3)", opt27 == 4)

// T28: budget_optimal caps at max_n
let bo28 = is_budget_optimal(1000.0, 1.0, 50)
check("T28 budget_optimal capped at 50", bo28[0] == 50)

// T29: budget_optimal quality multiplier = sqrt(n)
let bo29 = is_budget_optimal(16.0, 1.0, 100)
check("T29 budget n=16", bo29[0] == 16)
check("T29b quality_mult ~ sqrt(16) = 4.0", approx(bo29[1], 4.0, 0.1))

// T30: argmax correctness
check("T30 argmax [0.1, 0.9, 0.5] = 1", is_argmax([0.1, 0.9, 0.5]) == 1)
check("T30b argmax [3.0, 1.0, 2.0] = 0", is_argmax([3.0, 1.0, 2.0]) == 0)

// T31: weighted_vote single candidate
let wv31 = is_weighted_vote([99], [0.7])
check("T31 weighted_vote single=99", wv31[0] == 99)
check("T31b weight=0.7", approx(wv31[1], 0.7, 0.01))

// T32: reward_ranked preserves all indices (set coverage)
let rr32 = is_reward_ranked([10, 20, 30], mock_reward)
let mut sum_idx = 0
let mut i = 0

while i < 3 { sum_idx = sum_idx + rr32[0][i] }
check("T32 reward_ranked indices sum=0+1+2=3", sum_idx == 3)

// T33: scaling_predict extrapolation grows
let pred33a = is_scaling_predict(ns18, qs18, 25.0)
let pred33b = is_scaling_predict(ns18, qs18, 100.0)
check("T33 scaling Q(100) > Q(25)", pred33b > pred33a)

// =====================================================================
println("")
println("=== inference_scaling test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
