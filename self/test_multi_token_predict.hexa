// test_multi_token_predict.hexa — HEXA-LANG ML #62
// Multi-Token Prediction verification (≥12 tests)
import "ml/multi_token_predict.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("PASS " + name)
    } else {
        fail = fail + 1
        println("FAIL " + name)
    }
}

fn _abs(x) {
    if x < 0.0 { return 0.0 - x }
    x
}

// ── Setup ──────────────────────────────────────────────────────
let cfg = mtp_make_config(8, 6, 4)   // vocab=8, hidden=6, n_heads=4
let model = mtp_make_model(cfg, 42)
let tokens = [1, 3, 5, 2]
let targets = [4, 6, 0, 7]

// ── Test 1: config wiring ──────────────────────────────────────
check("cfg.vocab=8", model.cfg.vocab == 8)

// ── Test 2: model has n_heads heads ────────────────────────────
check("n_heads=4", len(model.heads) == 4)

// ── Test 3: backbone output dim = hidden ───────────────────────
let h_vec = mtp_backbone(model, tokens)
check("backbone dim=hidden", len(h_vec) == 6)

// ── Test 4: head logits dim = vocab ────────────────────────────
let l0 = mtp_head_logits(model, 0, h_vec)
check("head0 logits=vocab", len(l0) == 8)

// ── Test 5: softmax sums to ~1.0 ───────────────────────────────
let sm = mtp_softmax(l0)
let mut s = 0.0
let mut i = 0
while i < len(sm) {
    s = s + sm[i]
    i = i + 1
}
check("softmax sums to 1", _abs(s - 1.0) < 0.001)

// ── Test 6: log_softmax agrees with softmax ────────────────────
let lsm = mtp_log_softmax(l0)
let mut agree = 1
let mut k = 0
while k < len(lsm) {
    let recon = exp(lsm[k])
    if _abs(recon - sm[k]) > 0.01 { agree = 0 }
    k = k + 1
}
check("log_softmax round-trip", agree == 1)

// ── Test 7: CE is non-negative for valid target ────────────────
let ce0 = mtp_ce(l0, 0)
check("ce >= 0", ce0 >= 0.0)

// ── Test 8: MTP loss = sum of per-head CE ──────────────────────
let total = mtp_loss(model, tokens, targets)
let per = mtp_loss_per_head(model, tokens, targets)
let mut sum_per = 0.0
let mut pi = 0
while pi < len(per) {
    sum_per = sum_per + per[pi]
    pi = pi + 1
}
check("loss = sum per-head", _abs(total - sum_per) < 0.0001)

// ── Test 9: per-head count matches n_heads ─────────────────────
check("per-head len=n_heads", len(per) == 4)

// ── Test 10: predict_n returns n tokens ────────────────────────
let preds = mtp_predict_n(model, tokens)
check("predict_n len=n_heads", len(preds) == 4)

// ── Test 11: all predicted tokens are in vocab ─────────────────
let mut ok_vocab = 1
let mut vi = 0
while vi < len(preds) {
    if preds[vi] < 0 { ok_vocab = 0 }
    if preds[vi] >= 8 { ok_vocab = 0 }
    vi = vi + 1
}
check("preds within vocab", ok_vocab == 1)

// ── Test 12: train step reduces loss ───────────────────────────
let res = mtp_train_step(model, tokens, targets, 0.5)
let new_loss = res[0]
check("train_step reduces loss", new_loss < total)

// ── Test 13: iterated training monotone-enough ─────────────────
let mut m = model
let mut last = total
let mut ok_iter = 1
let mut it = 0
while it < 5 {
    let r = mtp_train_step(m, tokens, targets, 0.5)
    let nl = r[0]
    m = r[1]
    if nl > last + 0.0001 { ok_iter = 0 }
    last = nl
    it = it + 1
}
check("5-step training non-increasing", ok_iter == 1)
check("final loss < initial", last < total)

// ── Test 14: inference loop produces max_tokens ────────────────
let gen = mtp_inference_loop(model, tokens, 12)
check("inference_loop produced 12", len(gen) == 12)

// ── Test 15: inference is faster than 1-token AR ───────────────
// MTP commits n heads per pass so for max=12,n_heads=4 the number
// of backbone calls is ceil(12/4)=3. We approximate by checking
// the output tail and confirming determinism.
let gen2 = mtp_inference_loop(model, tokens, 12)
let mut det = 1
let mut di = 0
while di < 12 {
    if gen[di] != gen2[di] { det = 0 }
    di = di + 1
}
check("inference deterministic", det == 1)

// ── Test 16: speculative verify returns n-length mask ──────────
let mask = mtp_speculative_verify(model, tokens, 0)
check("verify mask len=n_heads", len(mask) == 4)

// ── Test 17: mask entries are 0/1 only ─────────────────────────
let mut mask_ok = 1
let mut mi = 0
while mi < len(mask) {
    if mask[mi] != 0 {
        if mask[mi] != 1 { mask_ok = 0 }
    }
    mi = mi + 1
}
check("verify mask is binary", mask_ok == 1)

// ── Test 18: @multi_token_predict step wrapper ─────────────────
let step = mtp_step(model, tokens, targets)
let s_pred = step[0]
let s_loss = step[1]
let s_acc = step[2]
check("mtp_step pred len", len(s_pred) == 4)
check("mtp_step loss len", len(s_loss) == 4)
check("mtp_step accept len", len(s_acc) == 4)

// ── Test 19: grad estimate is finite and non-zero ──────────────
let g = mtp_grad_estimate(model, tokens, targets, 0.001)
check("grad finite", _abs(g) < 1000.0)

println("")
println("pass=" + to_string(pass) + " fail=" + to_string(fail))
if fail == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass) + " passed")
