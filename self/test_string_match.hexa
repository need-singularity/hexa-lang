// ================================================================
//  test_string_match.hexa -- ROI #65: String matching KMP/Aho-Corasick
//  Tests anp_kmp_failure, anp_kmp_search, anp_kmp_search_all,
//  anp_aho_build, anp_aho_search
//  Self-contained: no imports from ai_native_pass.hexa
// ================================================================

// ── KMP failure function ────────────────────────────────────────
fn anp_kmp_failure(pattern) {
    let p = pattern.chars()
    let m = len(p)
    let mut fail = []
    let mut fi = 0
    while fi < m {
        fail.push(0)
        fi = fi + 1
    }
    if m <= 1 { return fail }
    let mut k = 0
    let mut i = 1
    while i < m {
        while k > 0 && to_string(p[k]) != to_string(p[i]) {
            k = fail[k - 1]
        }
        if to_string(p[k]) == to_string(p[i]) {
            k = k + 1
        }
        fail[i] = k
        i = i + 1
    }
    return fail
}

// ── KMP search (first match) ───────────────────────────────────
fn anp_kmp_search(text, pattern) {
    let t = text.chars()
    let p = pattern.chars()
    let n = len(t)
    let m = len(p)
    if m == 0 { return 0 }
    if n < m { return -1 }
    let fail = anp_kmp_failure(pattern)
    let mut j = 0
    let mut i = 0
    while i < n {
        while j > 0 && to_string(p[j]) != to_string(t[i]) {
            j = fail[j - 1]
        }
        if to_string(p[j]) == to_string(t[i]) {
            j = j + 1
        }
        if j == m {
            return i - m + 1
        }
        i = i + 1
    }
    return -1
}

// ── KMP search all occurrences ─────────────────────────────────
fn anp_kmp_search_all(text, pattern) {
    let t = text.chars()
    let p = pattern.chars()
    let n = len(t)
    let m = len(p)
    let mut result = []
    if m == 0 { return result }
    if n < m { return result }
    let fail = anp_kmp_failure(pattern)
    let mut j = 0
    let mut i = 0
    while i < n {
        while j > 0 && to_string(p[j]) != to_string(t[i]) {
            j = fail[j - 1]
        }
        if to_string(p[j]) == to_string(t[i]) {
            j = j + 1
        }
        if j == m {
            result.push(i - m + 1)
            j = fail[j - 1]
        }
        i = i + 1
    }
    return result
}

// ── Aho-Corasick build ─────────────────────────────────────────
fn anp_aho_build(patterns) {
    let mut goto_keys = [[]]
    let mut goto_vals = [[]]
    let mut fail_links = [0]
    let mut output = [[]]
    let mut next_id = 1
    let mut pi = 0
    while pi < len(patterns) {
        let pat = patterns[pi].chars()
        let mut cur = 0
        let mut ci = 0
        while ci < len(pat) {
            let ch = to_string(pat[ci])
            let mut found = -1
            let mut ki = 0
            while ki < len(goto_keys[cur]) {
                if goto_keys[cur][ki] == ch {
                    found = goto_vals[cur][ki]
                }
                ki = ki + 1
            }
            if found == -1 {
                let new_node = next_id
                next_id = next_id + 1
                goto_keys[cur] = goto_keys[cur].push(ch)
                goto_vals[cur] = goto_vals[cur].push(new_node)
                goto_keys.push([])
                goto_vals.push([])
                fail_links.push(0)
                output.push([])
                cur = new_node
            } else {
                cur = found
            }
            ci = ci + 1
        }
        output[cur] = output[cur].push(pi)
        pi = pi + 1
    }
    let mut queue = []
    let mut ri = 0
    while ri < len(goto_vals[0]) {
        let child = goto_vals[0][ri]
        fail_links[child] = 0
        queue.push(child)
        ri = ri + 1
    }
    let mut qi = 0
    while qi < len(queue) {
        let u = queue[qi]
        let mut ei = 0
        while ei < len(goto_keys[u]) {
            let ch = goto_keys[u][ei]
            let v = goto_vals[u][ei]
            let mut f = fail_links[u]
            let mut cont = true
            while cont {
                let mut fchild = -1
                let mut fki = 0
                while fki < len(goto_keys[f]) {
                    if goto_keys[f][fki] == ch {
                        fchild = goto_vals[f][fki]
                    }
                    fki = fki + 1
                }
                if fchild != -1 {
                    fail_links[v] = fchild
                    cont = false
                } else {
                    if f == 0 {
                        fail_links[v] = 0
                        cont = false
                    } else {
                        f = fail_links[f]
                    }
                }
            }
            let mut oi = 0
            while oi < len(output[fail_links[v]]) {
                output[v] = output[v].push(output[fail_links[v]][oi])
                oi = oi + 1
            }
            queue.push(v)
            ei = ei + 1
        }
        qi = qi + 1
    }
    return #{
        "goto_keys": goto_keys,
        "goto_vals": goto_vals,
        "fail_links": fail_links,
        "output": output,
        "num_patterns": len(patterns)
    }
}

// ── Aho-Corasick search ────────────────────────────────────────
fn anp_aho_search(text, aho_state, patterns) {
    let t = text.chars()
    let n = len(t)
    let gk = aho_state["goto_keys"]
    let gv = aho_state["goto_vals"]
    let fl = aho_state["fail_links"]
    let outp = aho_state["output"]
    let mut results = []
    let mut cur = 0
    let mut i = 0
    while i < n {
        let ch = to_string(t[i])
        let mut advanced = false
        while !advanced {
            let mut child = -1
            let mut ki = 0
            while ki < len(gk[cur]) {
                if gk[cur][ki] == ch {
                    child = gv[cur][ki]
                }
                ki = ki + 1
            }
            if child != -1 {
                cur = child
                advanced = true
            } else {
                if cur == 0 {
                    advanced = true
                } else {
                    cur = fl[cur]
                }
            }
        }
        let mut oi = 0
        while oi < len(outp[cur]) {
            let pat_idx = outp[cur][oi]
            let pat_len = len(patterns[pat_idx])
            let start_pos = i - pat_len + 1
            results.push([start_pos, pat_idx])
            oi = oi + 1
        }
        i = i + 1
    }
    return results
}

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("================================================================")
println("  ROI #65: String Matching -- KMP / Aho-Corasick Tests")
println("================================================================")
println("")

// ── Section 1: KMP failure function ─────────────────────────────
println("--- 1. KMP failure function ---")

check_eq("fail empty", anp_kmp_failure(""), [])
check_eq("fail single", anp_kmp_failure("a"), [0])
check_eq("fail ab", anp_kmp_failure("ab"), [0, 0])
check_eq("fail aa", anp_kmp_failure("aa"), [0, 1])
check_eq("fail aab", anp_kmp_failure("aab"), [0, 1, 0])
check_eq("fail abab", anp_kmp_failure("abab"), [0, 0, 1, 2])
check_eq("fail abcabc", anp_kmp_failure("abcabc"), [0, 0, 0, 1, 2, 3])
check_eq("fail aabaaab", anp_kmp_failure("aabaaab"), [0, 1, 0, 1, 2, 2, 3])
check_eq("fail aaaa", anp_kmp_failure("aaaa"), [0, 1, 2, 3])
check_eq("fail ababaca", anp_kmp_failure("ababaca"), [0, 0, 1, 2, 3, 0, 1])

println("")

// ── Section 2: KMP search (first match) ─────────────────────────
println("--- 2. KMP search (first match) ---")

check_eq("kmp empty pattern", anp_kmp_search("hello", ""), 0)
check_eq("kmp not found", anp_kmp_search("hello", "xyz"), -1)
check_eq("kmp at start", anp_kmp_search("abcdef", "abc"), 0)
check_eq("kmp at end", anp_kmp_search("abcdef", "def"), 3)
check_eq("kmp in middle", anp_kmp_search("abcdef", "cde"), 2)
check_eq("kmp single char found", anp_kmp_search("hello", "l"), 2)
check_eq("kmp single char miss", anp_kmp_search("hello", "z"), -1)
check_eq("kmp full match", anp_kmp_search("abc", "abc"), 0)
check_eq("kmp pattern longer", anp_kmp_search("ab", "abc"), -1)
check_eq("kmp repeated", anp_kmp_search("aaaa", "aa"), 0)
check_eq("kmp overlap", anp_kmp_search("aabaabaab", "aab"), 0)
check_eq("kmp tricky", anp_kmp_search("ababababc", "ababc"), 4)

println("")

// ── Section 3: KMP search all occurrences ───────────────────────
println("--- 3. KMP search all ---")

check_eq("kmp_all no match", anp_kmp_search_all("hello", "xyz"), [])
check_eq("kmp_all single", anp_kmp_search_all("abcabc", "abc"), [0, 3])
check_eq("kmp_all overlap", anp_kmp_search_all("aaaa", "aa"), [0, 1, 2])
check_eq("kmp_all multi", anp_kmp_search_all("abXabXab", "ab"), [0, 3, 6])
check_eq("kmp_all none", anp_kmp_search_all("abcdef", "gh"), [])
check_eq("kmp_all entire", anp_kmp_search_all("aaa", "aaa"), [0])
check_eq("kmp_all empty pat", anp_kmp_search_all("abc", ""), [])

println("")

// ── Section 4: Aho-Corasick build + search ──────────────────────
println("--- 4. Aho-Corasick multi-pattern search ---")

let patterns1 = ["he", "she", "his", "hers"]
let ac1 = anp_aho_build(patterns1)
check("aho build ok", ac1["num_patterns"] == 4)

let r1 = anp_aho_search("ushers", ac1, patterns1)
// "ushers" should find: "she" at 1, "he" at 2, "hers" at 2
// Aho-Corasick reports end positions, our impl reports start positions
let mut found_she = false
let mut found_he = false
let mut found_hers = false
let mut ri = 0
while ri < len(r1) {
    let pos = r1[ri][0]
    let pidx = r1[ri][1]
    if pidx == 0 && pos == 2 { found_he = true }
    if pidx == 1 && pos == 1 { found_she = true }
    if pidx == 3 && pos == 2 { found_hers = true }
    ri = ri + 1
}
check("aho ushers finds 'he'", found_he)
check("aho ushers finds 'she'", found_she)
check("aho ushers finds 'hers'", found_hers)

// Single pattern AC
let patterns2 = ["abc"]
let ac2 = anp_aho_build(patterns2)
let r2 = anp_aho_search("xabcyabcz", ac2, patterns2)
check_eq("aho single pat count", len(r2), 2)
check_eq("aho single pat pos0", r2[0][0], 1)
check_eq("aho single pat pos1", r2[1][0], 5)

// No match
let patterns3 = ["xyz", "uvw"]
let ac3 = anp_aho_build(patterns3)
let r3 = anp_aho_search("abcdef", ac3, patterns3)
check_eq("aho no match", len(r3), 0)

// Overlapping patterns
let patterns4 = ["a", "ab", "abc"]
let ac4 = anp_aho_build(patterns4)
let r4 = anp_aho_search("abc", ac4, patterns4)
// Should find "a" at 0, "ab" at 0, "abc" at 0
check("aho overlap count >= 3", len(r4) >= 3)

println("")

// ── Section 5: KMP correctness against naive ────────────────────
println("--- 5. KMP vs naive equivalence ---")

// Naive O(nm) search for reference
fn naive_search(text, pattern) {
    let t = text.chars()
    let p = pattern.chars()
    let n = len(t)
    let m = len(p)
    if m == 0 { return 0 }
    if n < m { return -1 }
    let mut i = 0
    while i <= n - m {
        let mut j = 0
        let mut ok = true
        while j < m && ok {
            if to_string(t[i + j]) != to_string(p[j]) {
                ok = false
            }
            j = j + 1
        }
        if ok { return i }
        i = i + 1
    }
    return -1
}

let texts = ["", "a", "abcabc", "aaaaaaa", "the quick brown fox", "ababababc"]
let pats = ["", "a", "abc", "aaa", "fox", "ababc", "zzz"]

let mut ti = 0
while ti < len(texts) {
    let mut pi = 0
    while pi < len(pats) {
        let text = texts[ti]
        let pat = pats[pi]
        if pat != "" {
            let naive_r = naive_search(text, pat)
            let kmp_r = anp_kmp_search(text, pat)
            check("equiv t=" + text + " p=" + pat, naive_r == kmp_r)
        }
        pi = pi + 1
    }
    ti = ti + 1
}

println("")

// ── Section 6: Edge cases ───────────────────────────────────────
println("--- 6. Edge cases ---")

check_eq("kmp same string", anp_kmp_search("abc", "abc"), 0)
check_eq("kmp single both", anp_kmp_search("a", "a"), 0)
check_eq("kmp single mismatch", anp_kmp_search("a", "b"), -1)
check_eq("kmp long pattern", anp_kmp_search("ab", "abcdefgh"), -1)
check_eq("kmp all same", anp_kmp_search("aaaaaaa", "aaa"), 0)
check_eq("kmp_all all same", anp_kmp_search_all("aaaaaaa", "aaa"), [0, 1, 2, 3, 4])

// Aho-Corasick with single-char patterns
let patterns5 = ["a", "b", "c"]
let ac5 = anp_aho_build(patterns5)
let r5 = anp_aho_search("abc", ac5, patterns5)
check_eq("aho single-char count", len(r5), 3)

// Aho-Corasick with empty text
let r6 = anp_aho_search("", ac5, patterns5)
check_eq("aho empty text", len(r6), 0)

println("")

// ── Summary ─────────────────────────────────────────────────────
println("================================================================")
println("  ROI #65 string-match: " + to_string(pass_count) + " PASS, " + to_string(fail_count) + " FAIL")
println("================================================================")

if fail_count > 0 {
    println("SOME TESTS FAILED")
}
