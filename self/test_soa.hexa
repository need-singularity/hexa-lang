// =============================================================
//  test_soa.hexa -- @soa AoS-to-SoA transformation tests
//  Tests: struct array field splitting for cache efficiency
//  (ROI id=21)
// =============================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=============================================================")
println("  HEXA @soa AoS-to-SoA Tests (ROI id=21)")
println("=============================================================")
println("")

// -- 1. Manual AoS: struct array access pattern --

println("--- AoS baseline ---")

fn aos_sum_x() {
    let points = [
        #{"x": 1, "y": 2},
        #{"x": 3, "y": 4},
        #{"x": 5, "y": 6}
    ]
    let mut sum = 0
    let mut i = 0
    while i < len(points) {
        sum = sum + points[i]["x"]
        i = i + 1
    }
    return sum
}

check("aos_sum_x", aos_sum_x(), 9)

fn aos_sum_y() {
    let points = [
        #{"x": 10, "y": 20},
        #{"x": 30, "y": 40},
        #{"x": 50, "y": 60}
    ]
    let mut sum = 0
    let mut i = 0
    while i < len(points) {
        sum = sum + points[i]["y"]
        i = i + 1
    }
    return sum
}

check("aos_sum_y", aos_sum_y(), 120)

// -- 2. Manual SoA: field-parallel arrays --

println("")
println("--- SoA equivalent ---")

fn soa_sum_x() {
    let xs = [1, 3, 5]
    let ys = [2, 4, 6]
    let mut sum = 0
    let mut i = 0
    while i < len(xs) {
        sum = sum + xs[i]
        i = i + 1
    }
    return sum
}

check("soa_sum_x", soa_sum_x(), 9)

fn soa_sum_y() {
    let xs = [10, 30, 50]
    let ys = [20, 40, 60]
    let mut sum = 0
    let mut i = 0
    while i < len(ys) {
        sum = sum + ys[i]
        i = i + 1
    }
    return sum
}

check("soa_sum_y", soa_sum_y(), 120)

// -- 3. AoS to SoA manual equivalence --

println("")
println("--- AoS=SoA equivalence ---")

check("aos_x == soa_x", aos_sum_x(), soa_sum_x())
check("aos_y == soa_y", aos_sum_y(), soa_sum_y())

// -- 4. Field iteration pattern --

println("")
println("--- Field iteration ---")

fn iterate_single_field() {
    let data = [
        #{"val": 100},
        #{"val": 200},
        #{"val": 300},
        #{"val": 400}
    ]
    let mut sum = 0
    let mut i = 0
    while i < len(data) {
        sum = sum + data[i]["val"]
        i = i + 1
    }
    return sum
}

check("iterate_single_field", iterate_single_field(), 1000)

// -- 5. Multi-field computation --

println("")
println("--- Multi-field computation ---")

fn dot_product_aos() {
    let a = [
        #{"x": 1, "y": 2, "z": 3},
        #{"x": 4, "y": 5, "z": 6}
    ]
    let b = [
        #{"x": 7, "y": 8, "z": 9},
        #{"x": 10, "y": 11, "z": 12}
    ]
    let mut sum = 0
    let mut i = 0
    while i < len(a) {
        sum = sum + a[i]["x"] * b[i]["x"] + a[i]["y"] * b[i]["y"] + a[i]["z"] * b[i]["z"]
        i = i + 1
    }
    return sum
}

check("dot_product_aos", dot_product_aos(), 50 + 167)

// -- 6. SoA equivalent of dot product --

fn dot_product_soa() {
    let ax = [1, 4]
    let ay = [2, 5]
    let az = [3, 6]
    let bx = [7, 10]
    let by = [8, 11]
    let bz = [9, 12]
    let mut sum = 0
    let mut i = 0
    while i < len(ax) {
        sum = sum + ax[i] * bx[i] + ay[i] * by[i] + az[i] * bz[i]
        i = i + 1
    }
    return sum
}

check("dot_product_soa", dot_product_soa(), dot_product_aos())

// -- Summary --
println("")
println("=============================================================")
println("  @soa Tests: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=============================================================")
