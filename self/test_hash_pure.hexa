// self/test_hash_pure.hexa -- Tests for self/runtime/hash_pure.hexa
//
// Reference values obtained via:
//   printf '%s' "..." | python3 -c "import sys,hashlib,struct; s=sys.stdin.buffer.read(); h=0x811C9DC5
//   for b in s: h^=b; h=(h*0x01000193)&0xFFFFFFFF
//   print(h)"
// (standard FNV-1a 32-bit)

// ── inlined from self/runtime/hash_pure.hexa ──────────────────────

let FNV_OFFSET_32 = 2166136261
let FNV_PRIME_32  = 16777619
let FNV_MOD_32    = 4294967296

fn fnv1a_pure(s, n) {
    if type_of(s) != "string" { return FNV_OFFSET_32 }
    let mut h = FNV_OFFSET_32
    let mut i = 0
    let lim = if n < len(s) { n } else { len(s) }
    while i < lim {
        let b = ord(s.substring(i, i + 1))
        h = h ^ b
        h = (h * FNV_PRIME_32) % FNV_MOD_32
        i = i + 1
    }
    h
}

fn fnv1a_str_pure(s) {
    fnv1a_pure(s, len(s))
}

fn bucket_of_pure(s, buckets) {
    if buckets <= 0 { return 0 }
    let h = fnv1a_str_pure(s)
    h % buckets
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  hash_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── fnv1a_str_pure ──────────────────────────────────────────
// Reference values from standard FNV-1a 32-bit.
println("")
println("--- fnv1a_str_pure (known vectors) ---")
check("empty string", fnv1a_str_pure(""), FNV_OFFSET_32)
check("single 'a'", fnv1a_str_pure("a"), 3826002220)
check("'foo'", fnv1a_str_pure("foo"), 2851307223)
check("'hello world'", fnv1a_str_pure("hello world"), 3582672807)

// ── determinism ─────────────────────────────────────────────
println("")
println("--- determinism ---")
check("same input same hash", fnv1a_str_pure("abc") == fnv1a_str_pure("abc"), true)
check("diff inputs diff hashes", fnv1a_str_pure("a") != fnv1a_str_pure("b"), true)

// ── fnv1a_pure (length arg) ─────────────────────────────────
println("")
println("--- fnv1a_pure (length-bounded) ---")
check("hash 0 bytes", fnv1a_pure("anything", 0), FNV_OFFSET_32)
check("hash over-length clips", fnv1a_pure("abc", 999), fnv1a_str_pure("abc"))
check("hash prefix", fnv1a_pure("abcdef", 3), fnv1a_str_pure("abc"))
check("non-string returns offset", fnv1a_pure(42, 5), FNV_OFFSET_32)

// ── bucket_of_pure ──────────────────────────────────────────
println("")
println("--- bucket_of_pure ---")
check("bucket 64 range", bucket_of_pure("foo", 64) >= 0 && bucket_of_pure("foo", 64) < 64, true)
check("bucket 1 always 0", bucket_of_pure("anything", 1), 0)
check("bucket 0 returns 0", bucket_of_pure("x", 0), 0)
check("bucket neg returns 0", bucket_of_pure("x", -5), 0)
check("bucket stability", bucket_of_pure("abc", 32) == bucket_of_pure("abc", 32), true)

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
