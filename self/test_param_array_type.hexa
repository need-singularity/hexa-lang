// Test: array type annotations in function parameters

fn sum_list(xs) -> float {
    let mut s = 0.0
    for x in xs {
        s = s + x
    }
    return s
}

fn first_row_sum(m) -> float {
    let row = m[0]
    let mut s = 0.0
    for x in row {
        s = s + x
    }
    return s
}

// Untyped param still works (regression guard)
fn add_one(x) {
    return x + 1
}

fn main() {
    let xs = [1.0, 2.0, 3.0, 4.0]
    let s = sum_list(xs)
    if s == 10.0 {
        print("sum_list PASS")
    } else {
        print("sum_list FAIL")
    }

    let m = [[1.0, 2.0], [3.0, 4.0]]
    let r = first_row_sum(m)
    if r == 3.0 {
        print("first_row_sum PASS")
    } else {
        print("first_row_sum FAIL")
    }

    let y = add_one(41)
    if y == 42 {
        print("untyped PASS")
    } else {
        print("untyped FAIL")
    }
}

main()
