// ═══════════════════════════════════════════════════════════
//  test_impl_codegen_c.hexa — P2-6/C2 Impl block → C code path
//
//  Verifies that codegen_c2_full now emits C functions for struct
//  methods (ImplBlock) and that method calls dispatch through the
//  runtime hexa_is_type chain to Type__method(...) instead of being
//  skipped. End-to-end: .hexa → pipeline → .c → clang → run.
// ═══════════════════════════════════════════════════════════

use "self/stdlib/law_io"

let _hexa_root = if len(env_var("HEXA_LANG")) > 0 { env_var("HEXA_LANG") } else { "." }
let HEXA = _hexa_root + "/hexa"
let SELF_DIR = _hexa_root + "/self"
let TMP_DIR = "/tmp/hexa_impl_codegen_c"
let RUNTIME_DIR = SELF_DIR

exec("mkdir -p " + TMP_DIR)

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn build_pipeline_source() {
    let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
    let parser_src = read_file(SELF_DIR + "/parser.hexa")
    let cg_src = read_file(SELF_DIR + "/codegen_c2.hexa")
    return lexer_src + "\n" + parser_src + "\n" + cg_src + "\n"
}

let pipeline_src = build_pipeline_source()

fn run_c2(name, hexa_source) {
    let c_file = TMP_DIR + "/" + name + ".c"
    let bin_file = TMP_DIR + "/" + name
    let driver_file = TMP_DIR + "/" + name + "_driver.hexa"
    let src_file = TMP_DIR + "/" + name + ".hexa"
    safe_write_file(src_file, hexa_source)
    let driver = pipeline_src + "\n" + "let __src = read_file(\"" + src_file + "\")\n" + "let __tokens = tokenize(__src)\n" + "let __ast = parse(__tokens)\n" + "let __c = codegen_c2_full(__ast)\n" + "write_file(\"" + c_file + "\", __c)\n" + "println(\"PIPELINE_OK\")\n"
    safe_write_file(driver_file, driver)
    let pr = exec(HEXA + " " + driver_file + " 2>&1")
    if !pr.contains("PIPELINE_OK") {
        println("  pipeline failed: " + pr)
        return "PIPELINE_FAIL"
    }
    let cc = "clang -O0 -I " + RUNTIME_DIR + " " + c_file + " -o " + bin_file + " -lm 2>&1"
    let cres = exec(cc)
    if !file_exists(bin_file) {
        println("  clang failed: " + cres)
        return "CLANG_FAIL"
    }
    let rout = exec(bin_file + " 2>&1")
    return rout
}

fn join_lines(lines) {
    let mut out = ""
    let mut i = 0
    while i < len(lines) {
        out = out + lines[i] + "\n"
        i = i + 1
    }
    return out
}

// ── Test 1: basic struct + single-arg impl method ─────────
let src1 = join_lines([
    "struct Point { x: int, y: int }",
    "impl Point {",
    "    fn sqdist(self, other) {",
    "        let dx = self.x - other.x",
    "        let dy = self.y - other.y",
    "        return dx * dx + dy * dy",
    "    }",
    "}",
    "let a = Point { x: 0, y: 0 }",
    "let b = Point { x: 3, y: 4 }",
    "println(a.sqdist(b))"
])

let out1 = run_c2("t1_point", src1)
check("1 sqdist origin to (3,4)", out1.trim(), "25")

// ── Test 2: multi-method impl with area/perimeter ─────────
let src2 = join_lines([
    "struct Rect { w: int, h: int }",
    "impl Rect {",
    "    fn area(self) { return self.w * self.h }",
    "    fn perimeter(self) { return 2 * (self.w + self.h) }",
    "}",
    "let r = Rect { w: 5, h: 3 }",
    "println(r.area())",
    "println(r.perimeter())"
])

let out2 = run_c2("t2_rect", src2)
check("2 rect multi-method", out2.trim(), "15\n16")

// ── Test 3: method name shadowing builtin (`len`) ─────────
let src3 = join_lines([
    "struct Range { lo: int, hi: int }",
    "impl Range {",
    "    fn mylen(self) { return self.hi - self.lo }",
    "}",
    "let r = Range { lo: 2, hi: 9 }",
    "println(r.mylen())",
    "let arr = [1, 2, 3, 4]",
    "println(len(arr))"
])

let out3 = run_c2("t3_user_method", src3)
check("3 user method + builtin len", out3.trim(), "7\n4")

// ── Summary ───────────────────────────────────────────────
println("")
println("═══════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL")
println("═══════════════════════════════════════")
