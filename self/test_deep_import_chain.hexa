// self/test_deep_import_chain.hexa — ROI #149 regression test.
//
// Bug: when a `.hexa` entry point transitively imports 5 or more modules via
// `use` statements, the compiled binary exits silently (exit 0, no output).
// 1-4 chain depth works. See docs/plans/roi_149 for root-cause notes.
//
// This test file transitively imports 6 modules:
//   test_deep_import_chain -> chain_mod_f -> e -> d -> c -> b -> chain_mod_a
//
// Expected output (both interpreter and native paths):
//   deep import chain: begin
//   chain_fn_f: depth 6
//   chain_fn_e: depth 5
//   chain_fn_d: depth 4
//   chain_fn_c: depth 3
//   chain_fn_b: depth 2
//   chain_fn_a: depth 1 (leaf)
//   deep import chain: end

use "self/chain_mod_f"

fn main() {
    println("deep import chain: begin")
    chain_fn_f()
    println("deep import chain: end")
}

main()
