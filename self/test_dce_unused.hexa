// self/test_dce_unused.hexa
// ROI #176 — tests for the @unused DCE extended pass
// Scaffold: symbol-graph + BFS reachability + @unused reporting.
//
// The pass under test lives at self/rewrite/dce_unused.hexa. For
// isolation (and because .hexa `import` semantics are still evolving),
// we re-declare the minimal surface here so the test runs standalone
// via `hexa self/test_dce_unused.hexa`.

// ── Test harness ──────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

// ── Local mirror of self/rewrite/dce_unused.hexa ──────────────────

struct SymbolNode {
    name: string,
    kind: string,
    refs: [string],
    is_entry: bool
}

struct SymbolGraph {
    nodes: [SymbolNode]
}

struct ReachReport {
    reachable: [string],
    unused: [string],
    total: int,
    reached: int,
    dropped: int
}

fn new_symbol_graph() -> SymbolGraph {
    return SymbolGraph { nodes: [] }
}

fn make_symbol(name: string, kind: string, refs: [string], is_entry: bool) -> SymbolNode {
    return SymbolNode { name: name, kind: kind, refs: refs, is_entry: is_entry }
}

fn graph_add(g: SymbolGraph, node: SymbolNode) -> SymbolGraph {
    let mut ns = g.nodes
    ns.push(node)
    return SymbolGraph { nodes: ns }
}

fn graph_size(g: SymbolGraph) -> int { return len(g.nodes) }

fn graph_find(g: SymbolGraph, name: string) -> int {
    let mut i = 0
    while i < len(g.nodes) {
        if g.nodes[i].name == name { return i }
        i = i + 1
    }
    return -1
}

fn str_list_contains(lst: [string], v: string) -> bool {
    let mut i = 0
    while i < len(lst) {
        if lst[i] == v { return true }
        i = i + 1
    }
    return false
}

fn str_list_push_unique(lst: [string], v: string) -> [string] {
    if str_list_contains(lst, v) { return lst }
    let mut out = lst
    out.push(v)
    return out
}

fn collect_entry_points(g: SymbolGraph) -> [string] {
    let mut roots: [string] = []
    let mut i = 0
    while i < len(g.nodes) {
        let n = g.nodes[i]
        if n.is_entry { roots = str_list_push_unique(roots, n.name) }
        if n.name == "main" { roots = str_list_push_unique(roots, n.name) }
        i = i + 1
    }
    return roots
}

fn bfs_reachable(g: SymbolGraph, roots: [string]) -> [string] {
    let mut visited: [string] = []
    let mut queue: [string] = []
    let mut head = 0

    let mut ri = 0
    while ri < len(roots) {
        let r = roots[ri]
        if !str_list_contains(visited, r) {
            visited = str_list_push_unique(visited, r)
            queue.push(r)
        }
        ri = ri + 1
    }

    while head < len(queue) {
        let cur = queue[head]
        head = head + 1
        let idx = graph_find(g, cur)
        if idx >= 0 {
            let refs = g.nodes[idx].refs
            let mut j = 0
            while j < len(refs) {
                let child = refs[j]
                if !str_list_contains(visited, child) {
                    visited = str_list_push_unique(visited, child)
                    queue.push(child)
                }
                j = j + 1
            }
        }
    }

    return visited
}

fn analyze_reachability(g: SymbolGraph) -> ReachReport {
    let roots = collect_entry_points(g)
    let reached = bfs_reachable(g, roots)
    let mut unused: [string] = []
    let mut i = 0
    while i < len(g.nodes) {
        let n = g.nodes[i]
        if !str_list_contains(reached, n.name) {
            unused = str_list_push_unique(unused, n.name)
        }
        i = i + 1
    }
    return ReachReport {
        reachable: reached,
        unused: unused,
        total: graph_size(g),
        reached: len(reached),
        dropped: len(unused)
    }
}

fn prune_unused(g: SymbolGraph, report: ReachReport) -> SymbolGraph {
    let mut out: [SymbolNode] = []
    let mut i = 0
    while i < len(g.nodes) {
        let n = g.nodes[i]
        if str_list_contains(report.reachable, n.name) { out.push(n) }
        i = i + 1
    }
    return SymbolGraph { nodes: out }
}

fn list_unused_symbols(g: SymbolGraph) -> [string] {
    return analyze_reachability(g).unused
}

// ── Tests ─────────────────────────────────────────────────────────

println("===============================================================")
println("  HEXA DCE @unused Extended Tests (ROI #176)")
println("===============================================================")

// Section 1: empty graph
println("")
println("--- Section 1: empty graph ---")
let g0 = new_symbol_graph()
let r0 = analyze_reachability(g0)
check("empty total",    r0.total,       0)
check("empty reached",  r0.reached,     0)
check("empty dropped",  r0.dropped,     0)

// Section 2: single entry, no refs
println("")
println("--- Section 2: single entry ---")
let mut g1 = new_symbol_graph()
g1 = graph_add(g1, make_symbol("main", "fn", [], true))
let r1 = analyze_reachability(g1)
check("single total",   r1.total,       1)
check("single reached", r1.reached,     1)
check("single dropped", r1.dropped,     0)

// Section 3: linear chain main -> a -> b (no dead code)
println("")
println("--- Section 3: linear chain, all live ---")
let mut g2 = new_symbol_graph()
g2 = graph_add(g2, make_symbol("main", "fn", ["a"], true))
g2 = graph_add(g2, make_symbol("a",    "fn", ["b"], false))
g2 = graph_add(g2, make_symbol("b",    "fn", [],    false))
let r2 = analyze_reachability(g2)
check("chain total",    r2.total,       3)
check("chain reached",  r2.reached,     3)
check("chain dropped",  r2.dropped,     0)

// Section 4: isolated dead symbol
println("")
println("--- Section 4: isolated dead symbol ---")
let mut g3 = new_symbol_graph()
g3 = graph_add(g3, make_symbol("main", "fn", ["alive"], true))
g3 = graph_add(g3, make_symbol("alive","fn", [],        false))
g3 = graph_add(g3, make_symbol("dead", "fn", [],        false))
let r3 = analyze_reachability(g3)
check("dead total",    r3.total,   3)
check("dead reached",  r3.reached, 2)
check("dead dropped",  r3.dropped, 1)
check("dead name",     r3.unused[0], "dead")

// Section 5: dead cluster (dead references another dead)
println("")
println("--- Section 5: dead cluster ---")
let mut g4 = new_symbol_graph()
g4 = graph_add(g4, make_symbol("main",    "fn", ["live"],       true))
g4 = graph_add(g4, make_symbol("live",    "fn", [],             false))
g4 = graph_add(g4, make_symbol("orphan1", "fn", ["orphan2"],    false))
g4 = graph_add(g4, make_symbol("orphan2", "fn", [],             false))
let r4 = analyze_reachability(g4)
check("cluster total",   r4.total,   4)
check("cluster reached", r4.reached, 2)
check("cluster dropped", r4.dropped, 2)

// Section 6: cycle among reachable nodes (BFS must terminate)
println("")
println("--- Section 6: cycle reachable ---")
let mut g5 = new_symbol_graph()
g5 = graph_add(g5, make_symbol("main", "fn", ["a"], true))
g5 = graph_add(g5, make_symbol("a",    "fn", ["b"], false))
g5 = graph_add(g5, make_symbol("b",    "fn", ["a"], false))  // cycle a<->b
let r5 = analyze_reachability(g5)
check("cycle total",    r5.total,   3)
check("cycle reached",  r5.reached, 3)
check("cycle dropped",  r5.dropped, 0)

// Section 7: cycle among dead nodes (still unused)
println("")
println("--- Section 7: dead cycle ---")
let mut g6 = new_symbol_graph()
g6 = graph_add(g6, make_symbol("main", "fn", [],        true))
g6 = graph_add(g6, make_symbol("x",    "fn", ["y"],     false))
g6 = graph_add(g6, make_symbol("y",    "fn", ["x"],     false))
let r6 = analyze_reachability(g6)
check("deadcycle total",   r6.total,   3)
check("deadcycle reached", r6.reached, 1)
check("deadcycle dropped", r6.dropped, 2)

// Section 8: multiple entry points
println("")
println("--- Section 8: multiple entries ---")
let mut g7 = new_symbol_graph()
g7 = graph_add(g7, make_symbol("main",       "fn", ["h"], true))
g7 = graph_add(g7, make_symbol("extra_root", "fn", ["k"], true))
g7 = graph_add(g7, make_symbol("h",          "fn", [],    false))
g7 = graph_add(g7, make_symbol("k",          "fn", [],    false))
g7 = graph_add(g7, make_symbol("orphan",     "fn", [],    false))
let r7 = analyze_reachability(g7)
check("multi total",   r7.total,   5)
check("multi reached", r7.reached, 4)
check("multi dropped", r7.dropped, 1)
check("multi orphan",  r7.unused[0], "orphan")

// Section 9: prune_unused yields a cleaner graph
println("")
println("--- Section 9: prune_unused ---")
let pruned = prune_unused(g7, r7)
check("prune size", graph_size(pruned), 4)
check("prune preserves main",    graph_find(pruned, "main")       >= 0, true)
check("prune preserves extra",   graph_find(pruned, "extra_root") >= 0, true)
check("prune drops orphan",      graph_find(pruned, "orphan") == -1,    true)

// Section 10: list_unused_symbols convenience API
println("")
println("--- Section 10: list_unused_symbols ---")
let unused_list = list_unused_symbols(g3)
check("convenience len",  len(unused_list), 1)
check("convenience name", unused_list[0],   "dead")

// Section 11: recursion (self-reference) does not loop
println("")
println("--- Section 11: self-recursion ---")
let mut g8 = new_symbol_graph()
g8 = graph_add(g8, make_symbol("main",  "fn", ["rec"], true))
g8 = graph_add(g8, make_symbol("rec",   "fn", ["rec"], false))  // self-loop
g8 = graph_add(g8, make_symbol("gone",  "fn", [],      false))
let r8 = analyze_reachability(g8)
check("rec total",   r8.total,   3)
check("rec reached", r8.reached, 2)
check("rec dropped", r8.dropped, 1)
check("rec gone",    r8.unused[0], "gone")

// Section 12: entries remain live even if nothing references them
println("")
println("--- Section 12: isolated entry ---")
let mut g9 = new_symbol_graph()
g9 = graph_add(g9, make_symbol("main",        "fn", [], true))
g9 = graph_add(g9, make_symbol("ffi_export",  "fn", [], true))  // explicit root
g9 = graph_add(g9, make_symbol("internal",    "fn", [], false))
let r9 = analyze_reachability(g9)
check("iso total",   r9.total,   3)
check("iso reached", r9.reached, 2)
check("iso dropped", r9.dropped, 1)

// ── Summary ───────────────────────────────────────────────────────

println("")
println("===============================================================")
println("  DCE @unused total: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("===============================================================")

if fail_count > 0 {
    println("SOME TESTS FAILED")
}
