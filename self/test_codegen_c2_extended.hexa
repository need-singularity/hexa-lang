// ── 36. Map dynamic build with contains_key ─────────────────
let out36 = run_c2("t36_map_dynamic", join_lines([
    "let mut freq = #{}",
    "let words = [\"a\", \"b\", \"a\", \"c\", \"b\", \"a\"]",
    "for w in words {",
    "    if freq.contains_key(w) {",
    "        freq[w] = freq[w] + 1",
    "    } else {",
    "        freq[w] = 1",
    "    }",
    "}",
    "println(freq[\"a\"])",
    "println(freq[\"b\"])",
    "println(freq[\"c\"])"
]))
if out36 != "PIPELINE_FAIL" && out36 != "CLANG_FAIL" {
    let lines36 = out36.trim().split("\n")
    check("36a freq a", lines36[0], "3")
    check("36b freq b", lines36[1], "2")
    check("36c freq c", lines36[2], "1")
} else {
    println("[FAIL] 36 map dynamic: " + out36)
    fail_count = fail_count + 3
}

// ═══════════════════════════════════════════════════════════
//  Summary
// ═══════════════════════════════════════════════════════════
println("")
println("═══════════════════════════════════════════════════════")
println("  Phase4+5 Extended: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL (total " + to_string(pass_count + fail_count) + ")")
if fail_count == 0 {
    println("  ALL PASS")
} else {
    println("  SOME TESTS FAILED — see above")
}
println("═══════════════════════════════════════════════════════")
