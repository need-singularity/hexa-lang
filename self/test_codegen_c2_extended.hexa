    "println(m[\"a\"])",
    "println(m[\"b\"])",
    "println(len(m))"
]))
if out29 != "PIPELINE_FAIL" && out29 != "CLANG_FAIL" {
    let lines29 = out29.trim().split("\n")
    check("29a map lit get a", lines29[0], "1")
    check("29b map lit get b", lines29[1], "2")
    check("29c map lit len", lines29[2], "3")
} else {
    println("[FAIL] 29 map lit: " + out29)
    fail_count = fail_count + 3
}

