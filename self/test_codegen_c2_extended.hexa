// ── 15. Try/catch ───────────────────────────────────────────
let src15 = join_lines([
    "fn risky(x) {",
    "    if x < 0 { throw 99 }",
    "    return x * 2",
    "}",
    "fn safe_call(x) {",
    "    try {",
    "        let r = risky(x)",
    "        return r",
    "    } catch e {",
    "        return e",
    "    }",
    "}",
    "println(safe_call(5))",
    "println(safe_call(-1))"
])
let out15 = run_c2("t15_try_catch", src15)
check("15 try/catch/throw", out15, "10\n99")

// ── 16. Multi-function mutual calls ─────────────────────────
let src16 = join_lines([
    "fn is_even(n) {",
    "    if n == 0 { return 1 }",
    "    return is_odd(n - 1)",
    "}",
    "fn is_odd(n) {",
    "    if n == 0 { return 0 }",
    "    return is_even(n - 1)",
    "}",
    "println(is_even(4))",
    "println(is_odd(3))"
])
let out16 = run_c2("t16_mutual_recursion", src16)
check("16 mutual recursion", out16, "1\n1")

