// ═══════════════════════════════════════════════════════════
//  test_codegen_c2_extended.hexa — Phase 4 C codegen 갭 검증 + 확장
//
//  codegen_c2_full 의 미검증 경로를 E2E (.hexa -> C -> clang -> native)
//  로 테스트. 기존 49 assertions(test_codegen_output) + 3 impl tests 보강.
// ═══════════════════════════════════════════════════════════

let _hexa_root = if len(env_var("HEXA_LANG")) > 0 { env_var("HEXA_LANG") } else { "." }
let HEXA = _hexa_root + "/hexa"
let SELF_DIR = _hexa_root + "/self"
let TMP_DIR = "/tmp/hexa_codegen_c2_ext"
let RUNTIME_DIR = SELF_DIR

exec("mkdir -p " + TMP_DIR)

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    let a = to_string(actual).trim()
    let e = to_string(expected).trim()
    if a == e {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: [" + e + "], got: [" + a + "]")
        fail_count = fail_count + 1
    }
}

fn build_pipeline_source() {
    let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
    let parser_src = read_file(SELF_DIR + "/parser.hexa")
    let cg_src = read_file(SELF_DIR + "/codegen_c2.hexa")
    return lexer_src + "\n" + parser_src + "\n" + cg_src + "\n"
}

let pipeline_src = build_pipeline_source()

// Run .hexa source through pipeline -> C -> clang -> execute
fn run_c2(name, hexa_source) {
    let c_file = TMP_DIR + "/" + name + ".c"
    let bin_file = TMP_DIR + "/" + name
    let driver_file = TMP_DIR + "/" + name + "_driver.hexa"
    let src_file = TMP_DIR + "/" + name + ".hexa"
    write_file(src_file, hexa_source)
    let driver = pipeline_src + "\n" + "let __src = read_file(\"" + src_file + "\")\n" + "let __tokens = tokenize(__src)\n" + "let __ast = parse(__tokens)\n" + "let __c = codegen_c2_full(__ast)\n" + "write_file(\"" + c_file + "\", __c)\n" + "println(\"PIPELINE_OK\")\n"
    write_file(driver_file, driver)
    let pr = exec(HEXA + " " + driver_file + " 2>&1")
    if type_of(pr) != "string" || !pr.contains("PIPELINE_OK") {
        let msg = to_string(pr)
        println("  [" + name + "] pipeline failed: " + msg)
        return "PIPELINE_FAIL"
    }
    let cc = "clang -O0 -Wno-return-type -I " + RUNTIME_DIR + " " + c_file + " -o " + bin_file + " -lm 2>&1"
    let cres = exec(cc)
    if !file_exists(bin_file) {
        let cmsg = to_string(cres)
        println("  [" + name + "] clang failed: " + cmsg)
        return "CLANG_FAIL"
    }
    let rout = exec(bin_file + " 2>&1")
    return rout
}

// Run pipeline only and inspect generated C (no compile)
fn gen_c(name, hexa_source) {
    let c_file = TMP_DIR + "/" + name + ".c"
    let driver_file = TMP_DIR + "/" + name + "_driver.hexa"
    let src_file = TMP_DIR + "/" + name + ".hexa"
    write_file(src_file, hexa_source)
    let driver = pipeline_src + "\n" + "let __src = read_file(\"" + src_file + "\")\n" + "let __tokens = tokenize(__src)\n" + "let __ast = parse(__tokens)\n" + "let __c = codegen_c2_full(__ast)\n" + "write_file(\"" + c_file + "\", __c)\n" + "println(\"C_GEN_OK\")\n"
    write_file(driver_file, driver)
    let pr = exec(HEXA + " " + driver_file + " 2>&1")
    if type_of(pr) != "string" || !pr.contains("C_GEN_OK") {
        println("  [" + name + "] gen_c failed: " + to_string(pr))
        return "GEN_FAIL"
    }
    return read_file(c_file)
}

fn join_lines(lines) {
    let mut out = ""
    let mut i = 0
    while i < len(lines) {
        out = out + lines[i] + "\n"
        i = i + 1
    }
    return out
}

println("═══════════════════════════════════════════════════════")
println("  codegen_c2 Extended E2E Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Desugared compound assignment (lexer/parser lack += token) ─
let src1 = join_lines([
    "fn main_test() {",
    "    let mut x = 10",
    "    x = x + 5",
    "    x = x - 3",
    "    x = x * 2",
    "    x = x / 4",
    "    x = x % 5",
    "    println(x)",
    "}",
    "main_test()"
])
let out1 = run_c2("t01_compound_assign", src1)
check("01 desugared compound assign", out1, "1")

// ── 2. Nested if-else chains ────────────────────────────────
let src2 = join_lines([
    "fn classify(n) {",
    "    if n < 0 {",
    "        return -1",
    "    } else {",
    "        if n == 0 {",
    "            return 0",
    "        } else {",
    "            return 1",
    "        }",
    "    }",
    "}",
    "println(classify(-5))",
    "println(classify(0))",
    "println(classify(7))"
])
let out2 = run_c2("t02_nested_if", src2)
check("02 nested if-else", out2, "-1\n0\n1")

// ── 3. While with break/continue ────────────────────────────
let src3 = join_lines([
    "fn sum_odd(n) {",
    "    let mut s = 0",
    "    let mut i = 0",
    "    while i < n {",
    "        i = i + 1",
    "        if i % 2 == 0 {",
    "            continue",
    "        }",
    "        s = s + i",
    "        if s > 20 {",
    "            break",
    "        }",
    "    }",
    "    return s",
    "}",
    "println(sum_odd(100))"
])
let out3 = run_c2("t03_break_continue", src3)
check("03 while break/continue", out3, "25")

// ── 4. For range loop ───────────────────────────────────────
let src4 = join_lines([
    "fn sum_range() {",
    "    let mut s = 0",
    "    for i in 0..10 {",
    "        s = s + i",
    "    }",
    "    return s",
    "}",
    "println(sum_range())"
])
let out4 = run_c2("t04_for_range", src4)
check("04 for range 0..10", out4, "45")

// ── 5. Recursive fibonacci ──────────────────────────────────
let src5 = join_lines([
    "fn fib(n) {",
    "    if n <= 1 { return n }",
    "    return fib(n - 1) + fib(n - 2)",
    "}",
    "println(fib(10))"
])
let out5 = run_c2("t05_fib_recursive", src5)
check("05 fib(10)=55", out5, "55")

// ── 6. Match statement (integer patterns) ───────────────────
let src6 = join_lines([
    "fn day_name(d) {",
    "    match d {",
    "        1 -> { return 1 }",
    "        2 -> { return 2 }",
    "        _ -> { return 0 }",
    "    }",
    "    return -1",
    "}",
    "println(day_name(1))",
    "println(day_name(2))",
    "println(day_name(99))"
])
let out6 = run_c2("t06_match_stmt", src6)
check("06 match statement", out6, "1\n2\n0")

// ── 7. Match expression (value-producing) ───────────────────
let src7 = join_lines([
    "fn sign(x) {",
    "    let r = match x {",
    "        0 -> { 0 }",
    "        _ -> {",
    "            if x > 0 { 1 } else { -1 }",
    "        }",
    "    }",
    "    return r",
    "}",
    "println(sign(-3))",
    "println(sign(0))",
    "println(sign(5))"
])
// Note: match expr with nested if might be complex, check what we get
let out7 = run_c2("t07_match_expr", src7)
check("07 match expression", out7, "-1\n0\n1")

// ── 8. Enum with match ──────────────────────────────────────
let src8 = join_lines([
    "enum Dir { Up, Down, Left, Right }",
    "fn dir_val(d) {",
    "    match d {",
    "        Dir::Up -> { return 1 }",
    "        Dir::Down -> { return 2 }",
    "        Dir::Left -> { return 3 }",
    "        Dir::Right -> { return 4 }",
    "    }",
    "    return 0",
    "}",
    "println(dir_val(Dir::Up))",
    "println(dir_val(Dir::Right))"
])
let out8 = run_c2("t08_enum_match", src8)
check("08 enum + match", out8, "1\n4")

