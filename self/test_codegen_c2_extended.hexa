// ═══════════════════════════════════════════════════════════
//  C Code Generation Pattern Checks (non-E2E)
// ═══════════════════════════════════════════════════════════

// ── 26. LoopStmt generates while(1) ─────────────────────────
let c26 = gen_c("t26_loop", join_lines([
    "fn foo() {",
    "    loop {",
    "        break",
    "    }",
    "}"
]))
if c26.contains("while") || c26.contains("for (;;") || c26.contains("LoopStmt") {
    println("[PASS] 26 loop stmt handled or falls through")
    pass_count = pass_count + 1
} else {
    println("[FAIL] 26 loop stmt — no recognizable loop pattern in C output")
    fail_count = fail_count + 1
}

// ── 27. TypeAlias is skip/no-crash ──────────────────────────
let c27 = gen_c("t27_typealias", join_lines([
    "type MyInt = Int",
    "fn foo() { println(42) }"
]))
if c27 != "GEN_FAIL" {
    println("[PASS] 27 type alias no crash")
    pass_count = pass_count + 1
} else {
    println("[FAIL] 27 type alias crashes pipeline")
    fail_count = fail_count + 1
}

// ── 28. ComptimeConst handled as global ─────────────────────
let c28 = gen_c("t28_comptime", join_lines([
    "comptime const MAX = 100",
    "fn foo() { println(42) }"
]))
if c28 != "GEN_FAIL" {
    println("[PASS] 28 comptime const no crash")
    pass_count = pass_count + 1
} else {
    println("[FAIL] 28 comptime const crashes pipeline")
    fail_count = fail_count + 1
}

// ── 29. Map literal codegen ─────────────────────────────────
