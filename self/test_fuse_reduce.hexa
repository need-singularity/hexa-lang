// ═══════════════════════════════════════════════════════════
//  test_fuse_reduce.hexa — M974 @fuse reduce/fold/sum chain fusion
//  ROI id=4, P2, effect 3x
//
//  Verifies that a hand-written fused loop (mirroring the AST
//  rewrite produced by ai_native_pass.hexa / fuse_reduce_body)
//  is semantically equivalent to the original .map/.filter/.fold/.sum chain.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  M974: @fuse reduce/fold/sum chain → loop rewrite")
println("═══════════════════════════════════════════════════════")
println("")

// ────────────────────────────────────────────────────────────
//  SECTION 1: arr.map(f).fold(init, h)
//  Original: arr.map(|x| x * 2).fold(0, |acc, x| acc + x)
//  Fused:    single loop with accumulator
//  [1,2,3,4] → (2+4+6+8) = 20
// ────────────────────────────────────────────────────────────
println("--- map + fold chain ---")

fn orig_map_fold(arr) {
    return arr.map(|x| x * 2).fold(0, |acc, x| acc + x)
}

// Fused version — what M974 produces:
fn fused_map_fold(arr) {
    let mut __fracc0 = 0
    let __frsrc0 = arr
    let mut __fri0 = 0
    while __fri0 < __frsrc0.len() {
        let __frx0 = __frsrc0[__fri0]
        let __frm0_0 = __frx0 * 2
        __fracc0 = __fracc0 + __frm0_0
        __fri0 = __fri0 + 1
    }
    return __fracc0
}

check("map+fold [1,2,3,4] orig", orig_map_fold([1, 2, 3, 4]), 20)
check("map+fold [1,2,3,4] fused", fused_map_fold([1, 2, 3, 4]), 20)
check("map+fold [5] orig", orig_map_fold([5]), 10)
check("map+fold [5] fused", fused_map_fold([5]), 10)
check("map+fold [] orig", orig_map_fold([]), 0)
check("map+fold [] fused", fused_map_fold([]), 0)

// ────────────────────────────────────────────────────────────
//  SECTION 2: arr.filter(g).fold(init, h)
//  Original: arr.filter(|x| x > 3).fold(0, |acc, x| acc + x)
//  [1,2,3,4,5,6] → filter [4,5,6] → fold = 15
// ────────────────────────────────────────────────────────────
println("")
println("--- filter + fold chain ---")

fn orig_filter_fold(arr) {
    return arr.filter(|x| x > 3).fold(0, |acc, x| acc + x)
}

fn fused_filter_fold(arr) {
    let mut __fracc0 = 0
    let __frsrc0 = arr
    let mut __fri0 = 0
    while __fri0 < __frsrc0.len() {
        let __frx0 = __frsrc0[__fri0]
        if __frx0 > 3 {
            __fracc0 = __fracc0 + __frx0
        }
        __fri0 = __fri0 + 1
    }
    return __fracc0
}

check("filter+fold [1..6] orig", orig_filter_fold([1, 2, 3, 4, 5, 6]), 15)
check("filter+fold [1..6] fused", fused_filter_fold([1, 2, 3, 4, 5, 6]), 15)
check("filter+fold [1,2] orig", orig_filter_fold([1, 2]), 0)
check("filter+fold [1,2] fused", fused_filter_fold([1, 2]), 0)

// ────────────────────────────────────────────────────────────
//  SECTION 3: arr.map(f).filter(g).fold(init, h)
//  Full 3-stage: map → filter → fold in single loop
//  [1,2,3,4,5].map(|x| x*10).filter(|x| x>20).fold(0, |a,x| a+x)
//  map [10,20,30,40,50] → filter [30,40,50] → fold 120
// ────────────────────────────────────────────────────────────
println("")
println("--- map + filter + fold chain ---")

fn orig_map_filter_fold(arr) {
    return arr.map(|x| x * 10).filter(|x| x > 20).fold(0, |acc, x| acc + x)
}

fn fused_map_filter_fold(arr) {
    let mut __fracc0 = 0
    let __frsrc0 = arr
    let mut __fri0 = 0
    while __fri0 < __frsrc0.len() {
        let __frx0 = __frsrc0[__fri0]
        let __frm0_0 = __frx0 * 10
        if __frm0_0 > 20 {
            __fracc0 = __fracc0 + __frm0_0
        }
        __fri0 = __fri0 + 1
    }
    return __fracc0
}

check("map+filter+fold [1..5] orig", orig_map_filter_fold([1, 2, 3, 4, 5]), 120)
check("map+filter+fold [1..5] fused", fused_map_filter_fold([1, 2, 3, 4, 5]), 120)
check("map+filter+fold [1] orig", orig_map_filter_fold([1]), 0)
check("map+filter+fold [1] fused", fused_map_filter_fold([1]), 0)

// ────────────────────────────────────────────────────────────
//  SECTION 4: arr.map(f).fold(init, h) — product
//  [1,2,3].map(|x| x+1).fold(1, |acc,x| acc*x) = 2*3*4 = 24
// ────────────────────────────────────────────────────────────
println("")
println("--- map + fold product ---")

fn orig_map_fold_product(arr) {
    return arr.map(|x| x + 1).fold(1, |acc, x| acc * x)
}

fn fused_map_fold_product(arr) {
    let mut __fracc0 = 1
    let __frsrc0 = arr
    let mut __fri0 = 0
    while __fri0 < __frsrc0.len() {
        let __frx0 = __frsrc0[__fri0]
        let __frm0_0 = __frx0 + 1
        __fracc0 = __fracc0 * __frm0_0
        __fri0 = __fri0 + 1
    }
    return __fracc0
}

check("map+fold product [1,2,3] orig", orig_map_fold_product([1, 2, 3]), 24)
check("map+fold product [1,2,3] fused", fused_map_fold_product([1, 2, 3]), 24)
check("map+fold product [] orig", orig_map_fold_product([]), 1)
check("map+fold product [] fused", fused_map_fold_product([]), 1)

// ────────────────────────────────────────────────────────────
//  SECTION 5: arr.map(f).sum()
//  [1,2,3,4].map(|x| x*2).sum() = 2+4+6+8 = 20
// ────────────────────────────────────────────────────────────
println("")
println("--- map + sum chain ---")

fn orig_map_sum(arr) {
    return arr.map(|x| x * 2).sum()
}

fn fused_map_sum(arr) {
    let mut __fracc0 = 0
    let __frsrc0 = arr
    let mut __fri0 = 0
    while __fri0 < __frsrc0.len() {
        let __frx0 = __frsrc0[__fri0]
        let __frm0_0 = __frx0 * 2
        __fracc0 = __fracc0 + __frm0_0
        __fri0 = __fri0 + 1
    }
    return __fracc0
}

check("map+sum [1,2,3,4] orig", orig_map_sum([1, 2, 3, 4]), 20)
check("map+sum [1,2,3,4] fused", fused_map_sum([1, 2, 3, 4]), 20)
check("map+sum [] orig", orig_map_sum([]), 0)
check("map+sum [] fused", fused_map_sum([]), 0)

// ────────────────────────────────────────────────────────────
//  SECTION 6: arr.filter(g).sum()
//  [1,2,3,4,5,6].filter(|x| x > 3).sum() = 4+5+6 = 15
// ────────────────────────────────────────────────────────────
println("")
println("--- filter + sum chain ---")

fn orig_filter_sum(arr) {
    return arr.filter(|x| x > 3).sum()
}

fn fused_filter_sum(arr) {
    let mut __fracc0 = 0
    let __frsrc0 = arr
    let mut __fri0 = 0
    while __fri0 < __frsrc0.len() {
        let __frx0 = __frsrc0[__fri0]
        if __frx0 > 3 {
            __fracc0 = __fracc0 + __frx0
        }
        __fri0 = __fri0 + 1
    }
    return __fracc0
}

check("filter+sum [1..6] orig", orig_filter_sum([1, 2, 3, 4, 5, 6]), 15)
check("filter+sum [1..6] fused", fused_filter_sum([1, 2, 3, 4, 5, 6]), 15)
check("filter+sum [1,2] orig", orig_filter_sum([1, 2]), 0)
check("filter+sum [1,2] fused", fused_filter_sum([1, 2]), 0)

// ────────────────────────────────────────────────────────────
//  SECTION 7: arr.filter(g).map(f).fold — mixed order
//  [1,2,3,4,5,6].filter(|x| x%2==0).map(|x| x*x).fold(0, |a,b| a+b)
//  filter [2,4,6] → map [4,16,36] → fold 56
// ────────────────────────────────────────────────────────────
println("")
println("--- filter + map + fold chain ---")

fn orig_filter_map_fold(arr) {
    return arr.filter(|x| x % 2 == 0).map(|x| x * x).fold(0, |a, b| a + b)
}

fn fused_filter_map_fold(arr) {
    let mut __fracc0 = 0
    let __frsrc0 = arr
    let mut __fri0 = 0
    while __fri0 < __frsrc0.len() {
        let __frx0 = __frsrc0[__fri0]
        if __frx0 % 2 == 0 {
            let __frm0_1 = __frx0 * __frx0
            __fracc0 = __fracc0 + __frm0_1
        }
        __fri0 = __fri0 + 1
    }
    return __fracc0
}

check("filter+map+fold [1..6] orig", orig_filter_map_fold([1, 2, 3, 4, 5, 6]), 56)
check("filter+map+fold [1..6] fused", fused_filter_map_fold([1, 2, 3, 4, 5, 6]), 56)

// ────────────────────────────────────────────────────────────
//  Summary
// ────────────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  RESULT: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
