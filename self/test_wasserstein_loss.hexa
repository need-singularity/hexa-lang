// ═══════════════════════════════════════════════════════════════
//  self/ml/wasserstein_loss.hexa — Wasserstein Loss (#279)
//
//  Sinkhorn-based entropic OT between two 1D weighted samples.
//
//  For μ = Σ a_i δ_{xi}  and  ν = Σ b_j δ_{yj} with cost c_ij = (xi-yj)²,
//    K_ij = exp(-c_ij / eps)
//    u = a ./ (K v),  v = b ./ (K^T u)   (iterate)
//    transport plan γ_ij = u_i K_ij v_j
//    W²_eps = Σ γ_ij c_ij
//
//  Sinkhorn divergence (unbiased):
//    S_eps(μ, ν) = W_eps(μ, ν) - 0.5*W_eps(μ, μ) - 0.5*W_eps(ν, ν)
//
//  CPU mini: N,M ≤ 16, iters ≤ 50.
//
//  API:
//    wl_sinkhorn_loss(xs, a, ys, b, eps, n_iter)   -> float
//    wl_sinkhorn_div(xs, a, ys, b, eps, n_iter)    -> float (≥ 0, debiased)
//    wl_plan(xs, a, ys, b, eps, n_iter)            -> [[float]]
//
//  @pure — deterministic given inputs
// ═══════════════════════════════════════════════════════════════

fn wl_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn wl_max_f(a, b) {
    if a > b { return a }
    return b
}

fn wl_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn wl_zeros2d(m, n) {
    let mut w = []
    for _i in 0..m { w = w + [wl_zeros(n)] }
    return w
}

// ── cost matrix: squared Euclidean on scalars ─────────────────
fn wl_cost_sq(xs, ys) {
    let n = len(xs)
    let m = len(ys)
    let mut c = wl_zeros2d(n, m)
    for i in 0..n {
        for j in 0..m {
            let d = xs[i] - ys[j]
            c[i][j] = d * d
        }
    }
    return c
}

// ── kernel K_ij = exp(-c/eps) ────────────────────────────────
fn wl_kernel(c, eps) {
    let n = len(c)
    let m = len(c[0])
    let mut K = wl_zeros2d(n, m)
    for i in 0..n {
        for j in 0..m {
            let e = 0.0 - c[i][j] / eps
            K[i][j] = exp(e)
        }
    }
    return K
}

// ── Sinkhorn iteration ────────────────────────────────────────
// returns dict { "u": [..], "v": [..], "K": [[..]] }
fn wl_sinkhorn_iter(a, b, K, n_iter) {
    let n = len(a)
    let m = len(b)
    let mut u = wl_zeros(n)
    for i in 0..n { u[i] = 1.0 }
    let mut v = wl_zeros(m)
    for j in 0..m { v[j] = 1.0 }

    for _k in 0..n_iter {
        // u = a / (K v)
        let mut new_u = wl_zeros(n)
        for i in 0..n {
            let mut s = 0.0
            for j in 0..m { s = s + K[i][j] * v[j] }
            if s < 1.0e-30 { s = 1.0e-30 }
            new_u[i] = a[i] / s
        }
        u = new_u
        // v = b / (K^T u)
        let mut new_v = wl_zeros(m)
        for j in 0..m {
            let mut s = 0.0
            for i in 0..n { s = s + K[i][j] * u[i] }
            if s < 1.0e-30 { s = 1.0e-30 }
            new_v[j] = b[j] / s
        }
        v = new_v
    }
    let out = #{ "u": u, "v": v }
    return out
}

// ── transport plan γ_ij = u_i K_ij v_j ───────────────────────
fn wl_plan(xs, a, ys, b, eps, n_iter) {
    let c = wl_cost_sq(xs, ys)
    let K = wl_kernel(c, eps)
    let uv = wl_sinkhorn_iter(a, b, K, n_iter)
    let u = uv["u"]
    let v = uv["v"]
    let n = len(xs)
    let m = len(ys)
    let mut g = wl_zeros2d(n, m)
    for i in 0..n {
        for j in 0..m {
            g[i][j] = u[i] * K[i][j] * v[j]
        }
    }
    return g
}

// ── entropic Wasserstein²: <γ, c> ─────────────────────────────
fn wl_sinkhorn_loss(xs, a, ys, b, eps, n_iter) {
    let c = wl_cost_sq(xs, ys)
    let K = wl_kernel(c, eps)
    let uv = wl_sinkhorn_iter(a, b, K, n_iter)
    let u = uv["u"]
    let v = uv["v"]
    let n = len(xs)
    let m = len(ys)
    let mut w2 = 0.0
    for i in 0..n {
        for j in 0..m {
            let g = u[i] * K[i][j] * v[j]
            w2 = w2 + g * c[i][j]
        }
    }
    return w2
}

// ── Sinkhorn divergence S_eps = W(a,b) - ½W(a,a) - ½W(b,b) ───
fn wl_sinkhorn_div(xs, a, ys, b, eps, n_iter) {
    let w_ab = wl_sinkhorn_loss(xs, a, ys, b, eps, n_iter)
    let w_aa = wl_sinkhorn_loss(xs, a, xs, a, eps, n_iter)
    let w_bb = wl_sinkhorn_loss(ys, b, ys, b, eps, n_iter)
    let out = w_ab - 0.5 * w_aa - 0.5 * w_bb
    if out < 0.0 { return 0.0 }
    return out
}

// ── marginals of transport plan ───────────────────────────────
fn wl_row_marginal(g) {
    let n = len(g)
    let m = len(g[0])
    let mut r = wl_zeros(n)
    for i in 0..n {
        let mut s = 0.0
        for j in 0..m { s = s + g[i][j] }
        r[i] = s
    }
    return r
}

fn wl_col_marginal(g) {
    let n = len(g)
    let m = len(g[0])
    let mut c = wl_zeros(m)
    for j in 0..m {
        let mut s = 0.0
        for i in 0..n { s = s + g[i][j] }
        c[j] = s
    }
    return c
}

// ── normalize vector to sum 1 ─────────────────────────────────
fn wl_normalize(v) {
    let n = len(v)
    let mut s = 0.0
    for i in 0..n { s = s + v[i] }
    if s < 1.0e-30 { s = 1.0e-30 }
    let mut out = wl_zeros(n)
    for i in 0..n { out[i] = v[i] / s }
    return out
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx(a, b, eps) {
    return fabs(a - b) < eps
}

println("═══════════════════════════════════════════════════════")
println("  Wasserstein Loss (#279) Test Suite")
println("═══════════════════════════════════════════════════════")

// ── helper: uniform weights ──
fn uniform(n) {
    let mut w = []
    let u = 1.0 / to_float(n)
    for _i in 0..n { w = w + [u] }
    return w
}

// ── Test 1: cost matrix shape & value ─
let xs1 = [0.0, 1.0, 2.0]
let ys1 = [0.0, 1.0]
let c1 = wl_cost_sq(xs1, ys1)
check("cost rows = 3", len(c1) == 3)
check("cost cols = 2", len(c1[0]) == 2)
check("c[0][0]=0", approx(c1[0][0], 0.0, 1.0e-10))
check("c[2][0]=4", approx(c1[2][0], 4.0, 1.0e-10))

// ── Test 2: kernel > 0 and K[i][i diagonal match] ──
let K1 = wl_kernel(c1, 1.0)
check("K[0][0]=1", approx(K1[0][0], 1.0, 1.0e-10))
check("K all positive", K1[0][1] > 0.0 && K1[2][0] > 0.0)

// ── Test 3: Sinkhorn loss(a, a) ≈ 0 for identical distributions ──
let a1 = uniform(3)
let w_aa = wl_sinkhorn_loss(xs1, a1, xs1, a1, 0.1, 100)
check("W(a,a) ≈ 0 after entropic", w_aa < 0.15)

// ── Test 4: Sinkhorn divergence of same dist = 0 ──
let s_aa = wl_sinkhorn_div(xs1, a1, xs1, a1, 0.1, 100)
check("S(a,a) = 0", approx(s_aa, 0.0, 1.0e-6))

// ── Test 5: Sinkhorn divergence ≥ 0 ──
let ys2 = [2.0, 3.0, 4.0]
let b2 = uniform(3)
let s_ab = wl_sinkhorn_div(xs1, a1, ys2, b2, 0.1, 100)
check("S(μ,ν) ≥ 0", s_ab >= 0.0)

// ── Test 6: shifted distribution distance roughly (shift)² ──
// xs=[0,1,2], ys=[2,3,4] → shift=2, expect ≈ 4 for non-entropic
// entropic blurs; use moderate eps to avoid underflow
let w_shift = wl_sinkhorn_loss(xs1, a1, ys2, b2, 1.0, 200)
check("W(shift=2) > 2", w_shift > 2.0)
check("W(shift=2) < 8", w_shift < 8.0)

// ── Test 7: plan shape and marginal preservation ──
let g = wl_plan(xs1, a1, ys2, b2, 0.1, 200)
check("plan rows = 3", len(g) == 3)
check("plan cols = 3", len(g[0]) == 3)
let row = wl_row_marginal(g)
let col = wl_col_marginal(g)
let mut row_ok = true
for i in 0..3 {
    if fabs(row[i] - a1[i]) > 0.05 { row_ok = false }
}
check("row marginal ≈ a", row_ok)
let mut col_ok = true
for j in 0..3 {
    if fabs(col[j] - b2[j]) > 0.05 { col_ok = false }
}
check("col marginal ≈ b", col_ok)

// ── Test 8: triangle-like: farther distribution larger W ──
// Use larger eps (~cost scale) to avoid K underflow
let ys3 = [5.0, 6.0, 7.0]
let w_far = wl_sinkhorn_loss(xs1, a1, ys3, b2, 5.0, 200)
let w_near_cmp = wl_sinkhorn_loss(xs1, a1, ys2, b2, 5.0, 200)
check("W(far) > W(near)", w_far > w_near_cmp)

// ── Test 9: monotonic in eps (rough) — smaller eps closer to true OT ──
let w_eps_big = wl_sinkhorn_loss(xs1, a1, ys2, b2, 1.0, 200)
let w_eps_sml = wl_sinkhorn_loss(xs1, a1, ys2, b2, 0.01, 300)
check("eps=1 gives W ≥ eps=0.01 not trivially", w_eps_big > 0.0 && w_eps_sml > 0.0)

// ── Test 10: normalize helper ──
let v = [1.0, 2.0, 1.0]
let nv = wl_normalize(v)
let mut ns = 0.0
for i in 0..3 { ns = ns + nv[i] }
check("normalize sums to 1", approx(ns, 1.0, 1.0e-10))

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
