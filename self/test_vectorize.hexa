// =============================================================
//  test_vectorize.hexa -- @vectorize SIMD auto-vectorization
//  Tests: scalar loop to SIMD conversion (ROI id=24)
// =============================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=============================================================")
println("  HEXA @vectorize SIMD Tests (ROI id=24)")
println("=============================================================")
println("")

// -- 1. Array add scalar (vectorizable pattern) --

println("--- Array add scalar ---")

fn arr_add_scalar(arr, scalar) {
    let mut result = []
    let mut i = 0
    while i < len(arr) {
        result = result.push(arr[i] + scalar)
        i = i + 1
    }
    return result
}

let a1 = arr_add_scalar([1, 2, 3, 4, 5, 6, 7, 8], 10)
check("add_scalar len", len(a1), 8)
check("add_scalar[0]", a1[0], 11)
check("add_scalar[3]", a1[3], 14)
check("add_scalar[7]", a1[7], 18)

// -- 2. Array multiply scalar --

println("")
println("--- Array multiply scalar ---")

fn arr_mul_scalar(arr, scalar) {
    let mut result = []
    let mut i = 0
    while i < len(arr) {
        result = result.push(arr[i] * scalar)
        i = i + 1
    }
    return result
}

let m1 = arr_mul_scalar([2, 4, 6, 8], 3)
check("mul_scalar len", len(m1), 4)
check("mul_scalar[0]", m1[0], 6)
check("mul_scalar[1]", m1[1], 12)
check("mul_scalar[3]", m1[3], 24)

// -- 3. Element-wise array addition --

println("")
println("--- Element-wise add ---")

fn arr_add(a, b) {
    let mut result = []
    let mut i = 0
    while i < len(a) {
        result = result.push(a[i] + b[i])
        i = i + 1
    }
    return result
}

let ew1 = arr_add([1, 2, 3, 4], [10, 20, 30, 40])
check("elem_add len", len(ew1), 4)
check("elem_add[0]", ew1[0], 11)
check("elem_add[3]", ew1[3], 44)

// -- 4. In-place array modification (vectorizable) --

println("")
println("--- In-place modification ---")

fn inplace_add(scalar) {
    let mut arr = [10, 20, 30, 40, 50, 60, 70, 80]
    let mut i = 0
    while i < len(arr) {
        arr[i] = arr[i] + scalar
        i = i + 1
    }
    return arr
}

let ip1 = inplace_add(5)
check("inplace_add len", len(ip1), 8)
check("inplace_add[0]", ip1[0], 15)
check("inplace_add[4]", ip1[4], 55)
check("inplace_add[7]", ip1[7], 85)

// -- 5. Dot product (reduction, partially vectorizable) --

println("")
println("--- Dot product ---")

fn dot_product(a, b) {
    let mut sum = 0
    let mut i = 0
    while i < len(a) {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    return sum
}

check("dot [1,2,3].[4,5,6]", dot_product([1, 2, 3], [4, 5, 6]), 32)
check("dot [1,0,0].[0,1,0]", dot_product([1, 0, 0], [0, 1, 0]), 0)
check("dot [2,2,2].[3,3,3]", dot_product([2, 2, 2], [3, 3, 3]), 18)

// -- 6. Array sum (reduction) --

println("")
println("--- Array sum ---")

fn arr_sum(arr) {
    let mut sum = 0
    let mut i = 0
    while i < len(arr) {
        sum = sum + arr[i]
        i = i + 1
    }
    return sum
}

check("sum [1..8]", arr_sum([1, 2, 3, 4, 5, 6, 7, 8]), 36)
check("sum empty", arr_sum([]), 0)
check("sum single", arr_sum([42]), 42)

// -- 7. Non-aligned length (remainder handling) --

println("")
println("--- Remainder handling ---")

fn add_and_sum(arr, scalar) {
    let mut sum = 0
    let mut i = 0
    while i < len(arr) {
        sum = sum + (arr[i] + scalar)
        i = i + 1
    }
    return sum
}

// Length 5 = 4 (vectorized) + 1 (remainder)
check("remainder len=5", add_and_sum([1, 2, 3, 4, 5], 10), 65)
// Length 7 = 4 (vectorized) + 3 (remainder)
check("remainder len=7", add_and_sum([1, 2, 3, 4, 5, 6, 7], 0), 28)
// Length 1 = all remainder
check("remainder len=1", add_and_sum([100], 1), 101)

// -- 8. Large array performance check --

println("")
println("--- Large array ---")

fn build_and_sum(n, add_val) {
    let mut arr = []
    let mut i = 0
    while i < n {
        arr = arr.push(i)
        i = i + 1
    }
    let mut sum = 0
    i = 0
    while i < len(arr) {
        sum = sum + arr[i] + add_val
        i = i + 1
    }
    return sum
}

check("large n=100", build_and_sum(100, 0), 4950)
check("large n=100+1", build_and_sum(100, 1), 5050)

// -- Summary --
println("")
println("=============================================================")
println("  @vectorize: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=============================================================")
