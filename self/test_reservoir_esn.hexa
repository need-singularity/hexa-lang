// ═══════════════════════════════════════════════════════════════════
//  test_reservoir_esn.hexa — Reservoir Computing ESN (#285)
// ═══════════════════════════════════════════════════════════════════

import "ml/reservoir_esn.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(inp) { if inp < 0.0 { return 0.0 - inp } return inp }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Reservoir Computing ESN (#285) ===")

// ── T1 build model shapes ──────────────────────────────────
let model1 = esn_build(2, 10, 0.5, 0.9, 42)
check("T1 W_in shape", len(model1["W_in"]) == 10 && len(model1["W_in"][0]) == 2)
check("T1 W_res shape", len(model1["W_res"]) == 10 && len(model1["W_res"][0]) == 10)

// ── T2 spectral radius ≤ requested + epsilon ────────────────
let rho = esn_spectral_radius(model1["W_res"])
check("T2 spectral radius approx", fabs_(rho - 0.9) < 0.05)

// ── T3 single step dimension ───────────────────────────────
let s0 = []
let mut state3 = []
for _i in 0..10 { state3 = state3 + [0.0] }
let s1 = esn_step(model1, state3, [1.0, 0.5])
check("T3 step dim", len(s1) == 10)

// ── T4 echo-state contraction: zero input → state decays ───
let mut state4 = []
for _i in 0..10 { state4 = state4 + [1.0] }
let mut norm_prev = 0.0
for i in 0..10 { norm_prev = norm_prev + state4[i] * state4[i] }
for _t in 0..20 {
    state4 = esn_step(model1, state4, [0.0, 0.0])
}
let mut norm_after = 0.0
for i in 0..10 { norm_after = norm_after + state4[i] * state4[i] }
check("T4 state decays with zero input", norm_after < norm_prev)

// ── T5 run over a sequence ─────────────────────────────────
let U5 = [[1.0, 0.0], [0.9, 0.1], [0.5, 0.5], [0.1, 0.9], [0.0, 1.0]]
let X5 = esn_run(model1, U5)
check("T5 run length", len(X5) == 5)
check("T5 run state dim", len(X5[0]) == 10)

// ── T6 identity readout (should fit trivially) ─────────────
let model6 = esn_build(1, 8, 0.5, 0.9, 7)
let nT = 30
let mut U6 = []
let mut Y6 = []
for t in 0..nT {
    let v = to_float(t) * 0.1
    U6 = U6 + [[v]]
    Y6 = Y6 + [[v]]
}
let states6 = esn_run(model6, U6)
let W_out = esn_fit_readout(states6, Y6, 0.1)
check("T6 W_out shape", len(W_out) == 1 && len(W_out[0]) == 8)

// ── T7 fitted MSE low on training data ────────────────────
let preds6 = esn_predict_seq(model6, W_out, U6)
let mse6 = esn_mse(preds6, Y6)
check("T7 train MSE low", mse6 < 0.1)

// ── T8 predict has right shape ────────────────────────────
check("T8 predict shape", len(preds6) == nT && len(preds6[0]) == 1)

// ── T9 MSE zero on identical ───────────────────────────────
check("T9 MSE(self)=0", approx_(esn_mse(Y6, Y6), 0.0, 1.0e-9))

// ── T10 MSE positive on different ──────────────────────────
let mut Y10 = []
for t in 0..nT {
    Y10 = Y10 + [[to_float(t) * 0.1 + 1.0]]
}
let mse10 = esn_mse(Y10, Y6)
check("T10 MSE(different)>0", mse10 > 0.5)

// ── T11 step with different inputs gives different states ─
let s_a = esn_step(model1, state3, [1.0, 0.0])
let s_b = esn_step(model1, state3, [0.0, 1.0])
let mut diff = 0.0
for i in 0..10 { diff = diff + fabs_(s_a[i] - s_b[i]) }
check("T11 input sensitivity", diff > 0.01)

// ── T12 echo-state property: forget initial state ─────────
let mut s_init_a = []
let mut s_init_b = []
for i in 0..10 {
    s_init_a = s_init_a + [1.0]
    s_init_b = s_init_b + [-1.0]
}
let driver = [[0.5, 0.3], [0.2, 0.4], [0.1, 0.6], [0.3, 0.3], [0.4, 0.2], [0.5, 0.5], [0.1, 0.9], [0.8, 0.2]]
let mut sa = s_init_a
let mut sb = s_init_b
// Initial drift
let mut drift0 = 0.0
for i in 0..10 { drift0 = drift0 + fabs_(sa[i] - sb[i]) }
for _rep in 0..5 {
    for t in 0..8 {
        sa = esn_step(model1, sa, driver[t])
        sb = esn_step(model1, sb, driver[t])
    }
}
let mut drift = 0.0
for i in 0..10 { drift = drift + fabs_(sa[i] - sb[i]) }
check("T12 echo-state converges", drift < drift0)

println("")
println("=== Reservoir ESN summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
