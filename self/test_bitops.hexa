#!hexa lax
// self/test_bitops.hexa — ROI #162 P7-6a GAP-3 seed test (standalone).
//
// Verifies the expanded `lower_binop_mnemonic` recognizes bitwise / shift
// ops and the emit_function_arm64 dispatch in self/codegen/mod.hexa now
// carries band/bor/bxor/shl/shr cases. Runs under hexa_stage0 without
// flatten_imports by asserting the mnemonic route directly.

fn _p7_6a_mnemonic(op_str) {
    if op_str == "add" { return "add" }
    if op_str == "bitand" { return "bitand" }
    if op_str == "bitor"  { return "bitor" }
    if op_str == "bitxor" { return "bitxor" }
    if op_str == "shl"    { return "shl" }
    if op_str == "shr"    { return "shr" }
    if op_str == "and" { return "and" }
    if op_str == "or"  { return "or" }
    if op_str == "xor" { return "xor" }
    return ""
}

// Smoke-check that the ARM64 shifted-register encodings match what
// ir_to_arm64.hexa emits for the same op. These constants mirror the
// single-source-of-truth in self/codegen/arm64.hexa.
fn _encode_rrr(base, rd, rn, rm) {
    return base + (rm * 65536) + (rn * 32) + rd
}

fn _expect(label, got, want) {
    if got == want {
        println("  PASS " + label)
        return 1
    }
    println("  FAIL " + label + " expected=" + want + " got=" + got)
    return 0
}

println("=== ROI #162 P7-6a GAP-3: BinOp bitwise / shift coverage ===")
let mut pass = 0

// Mnemonic table reach.
pass = pass + _expect("bitand->bitand", _p7_6a_mnemonic("bitand"), "bitand")
pass = pass + _expect("bitor ->bitor",  _p7_6a_mnemonic("bitor"),  "bitor")
pass = pass + _expect("bitxor->bitxor", _p7_6a_mnemonic("bitxor"), "bitxor")
pass = pass + _expect("shl   ->shl",    _p7_6a_mnemonic("shl"),    "shl")
pass = pass + _expect("shr   ->shr",    _p7_6a_mnemonic("shr"),    "shr")
pass = pass + _expect("and   ->and",    _p7_6a_mnemonic("and"),    "and")
pass = pass + _expect("or    ->or",     _p7_6a_mnemonic("or"),     "or")
pass = pass + _expect("xor   ->xor",    _p7_6a_mnemonic("xor"),    "xor")

// Encoder smoke: AND x1, x2, x3  → 0x8a030041
let e_and = _encode_rrr(2315255808, 1, 2, 3)   // 0x8a000000 + 3<<16 + 2<<5 + 1
pass = pass + _expect("ARM64 AND encode", e_and, 2315452481)   // 0x8a030041

// ORR x4, x5, x6  → 0xaa0600a4  (0xaa000000 + 6<<16 + 5<<5 + 4)
let e_orr = _encode_rrr(2852126720, 4, 5, 6)
pass = pass + _expect("ARM64 ORR encode", e_orr, 2852520100)   // 0xaa0600a4

// LSLV x1, x2, x3 → 0x9ac32041  (0x9ac02000 + 3<<16 + 2<<5 + 1)
let e_lslv = _encode_rrr(2596159488, 1, 2, 3)
pass = pass + _expect("ARM64 LSLV encode", e_lslv, 2596356161) // 0x9ac32041

if pass == 11 {
    println("ALL PASS (11/11)")
} else {
    println("FAIL (" + pass + "/11)")
}
