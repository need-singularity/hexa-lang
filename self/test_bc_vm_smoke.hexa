fn bcvm_smoke_main() {
    println("=== rt#36-C bc_vm smoke ===")
    bcvm_test_arith()
    bcvm_test_mul()
    bcvm_test_branch()
    bcvm_test_trap_underflow()
    bcvm_test_local()
    bcvm_test_not()
    bcvm_test_loadk()
    bcvm_test_loop()
    bcvm_test_call()
    bcvm_test_div()
    bcvm_test_mod()
    bcvm_test_neq()
    bcvm_test_le()
    bcvm_test_gt()
    bcvm_test_ge()
    bcvm_test_jmpt()
    bcvm_test_pop()
    bcvm_test_loadnil()
    bcvm_test_loadfalse()
    bcvm_test_global()
    bcvm_test_print()
    bcvm_test_return0()
    println("=== done ===")
}

bcvm_smoke_main()
