// Test 16: JMPT — forward true-jump skips the 0 branch, lands on 99.
//   0: LOADI 5
//   1: LOADI 5
//   2: EQ                 ; true on stack
//   3: JMPT +2            ; true → pc=6 (cur_pc=4, 4+2=6)
//   4: LOADI 0            ; (skipped if true)
//   5: JMP  +1            ; skip the 99 branch when false (cur_pc=6, 6+1=7)
//   6: LOADI 99           ; landing pad on true
//   7: RETURN
fn bcvm_test_jmpt() {
    println("[T16] jmpt: (5==5) ? 99 : 0 = 99")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 5),
        bc_enc_sbx(BC_OP_LOADI, 5),
        bc_enc_abx(BC_OP_EQ,   0),
        bc_enc_sbx(BC_OP_JMPT, 2),
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_sbx(BC_OP_JMP,  1),
        bc_enc_sbx(BC_OP_LOADI, 99),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 2)
    let r = bc_vm_run()
    if r == 99 { println("  PASS jmpt=" + to_string(r)) } else { println("  FAIL jmpt got=" + to_string(r)) }
}

// Test 17: POP — discard top, return remaining (99).
//   0: LOADI 99
//   1: LOADI 42
//   2: POP      ; discards 42 → 99 on top
//   3: RETURN
fn bcvm_test_pop() {
    println("[T17] pop: discard top, keep 99")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 99),
        bc_enc_sbx(BC_OP_LOADI, 42),
        bc_enc_abx(BC_OP_POP,   0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 2)
    let r = bc_vm_run()
    if r == 99 { println("  PASS pop=" + to_string(r)) } else { println("  FAIL pop got=" + to_string(r)) }
}

// Test 18: LOADNIL — returns BC_NIL ("<nil>").
fn bcvm_test_loadnil() {
    println("[T18] loadnil: return nil")
    bcvm_reset_registries()
    let code = [
        bc_enc_abx(BC_OP_LOADNIL, 0),
        bc_enc_abx(BC_OP_RETURN,  0)
    ]
    bcvm_push_proto("<main>", code, 0, 1)
    let r = bc_vm_run()
    if r == BC_NIL { println("  PASS loadnil=<nil>") } else { println("  FAIL loadnil got=" + to_string(r)) }
}

// Test 19: LOADFALSE — returns false.
fn bcvm_test_loadfalse() {
    println("[T19] loadfalse: return false")
    bcvm_reset_registries()
    let code = [
        bc_enc_abx(BC_OP_LOADFALSE, 0),
        bc_enc_abx(BC_OP_RETURN,    0)
    ]
    bcvm_push_proto("<main>", code, 0, 1)
    let r = bc_vm_run()
    if r == false { println("  PASS loadfalse=false") } else { println("  FAIL loadfalse got=" + to_string(r)) }
}

// Test 20: STORE_GLOBAL + LOAD_GLOBAL — store 7 to global "gx", read back.
//   consts[0] = "gx" (name string). b16 encodes the const idx.
//   0: LOADI 7
//   1: STORE_GLOBAL (a=0, b16=0)
//   2: LOAD_GLOBAL  (a=0, b16=0)
//   3: RETURN
fn bcvm_test_global() {
    println("[T20] global: store/load \"gx\" = 7")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 7),
        bc_enc_ab16(BC_OP_STORE_GLOBAL, 0, 0),
        bc_enc_ab16(BC_OP_LOAD_GLOBAL,  0, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto_with_consts("<main>", 0, code, 0, 2, ["gx"])
    let r = bc_vm_run()
    if r == 7 { println("  PASS global=" + to_string(r)) } else { println("  FAIL global got=" + to_string(r)) }
}

// Test 21: PRINT — emits stdout line; return value is 1 so we can verify
// the VM kept going past the PRINT.
//   0: LOADI 123
//   1: PRINT      ; pops 123, prints "123"
//   2: LOADI 1
//   3: RETURN
fn bcvm_test_print() {
    println("[T21] print: stdout 123, return 1")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 123),
        bc_enc_abx(BC_OP_PRINT, 0),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 1)
    let r = bc_vm_run()
    if r == 1 { println("  PASS print post-return=" + to_string(r)) } else { println("  FAIL print got=" + to_string(r)) }
}

// Test 22: RETURN0 — void return pops frame without a value; run returns BC_NIL.
fn bcvm_test_return0() {
    println("[T22] return0: void return = <nil>")
    bcvm_reset_registries()
    let code = [
        bc_enc_abx(BC_OP_RETURN0, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 0)
    let r = bc_vm_run()
    if r == BC_NIL { println("  PASS return0=<nil>") } else { println("  FAIL return0 got=" + to_string(r)) }
}

fn bcvm_smoke_main() {
    println("=== rt#36-C bc_vm smoke ===")
    bcvm_test_arith()
    bcvm_test_mul()
    bcvm_test_branch()
    bcvm_test_trap_underflow()
    bcvm_test_local()
    bcvm_test_not()
    bcvm_test_loadk()
    bcvm_test_loop()
    bcvm_test_call()
    bcvm_test_div()
    bcvm_test_mod()
    bcvm_test_neq()
    bcvm_test_le()
    bcvm_test_gt()
    bcvm_test_ge()
    bcvm_test_jmpt()
    bcvm_test_pop()
    bcvm_test_loadnil()
    bcvm_test_loadfalse()
    bcvm_test_global()
    bcvm_test_print()
    bcvm_test_return0()
    println("=== done ===")
}

bcvm_smoke_main()
