}

// ── INLINED from bc_vm.hexa ──
let mut vm_stack = []
let mut vm_locals = []
let mut vm_frame_proto = []
let mut vm_frame_pc    = []
let mut vm_frame_fp    = []
let mut vm_frame_closure = []
let mut vm_global_names = []
let mut vm_global_vals  = []
let mut vm_trap = false
let mut vm_trap_msg = ""
let mut vm_halted = false
let mut vm_try_catch_pc     = []
let mut vm_try_stack_size   = []
let mut vm_try_frame_depth  = []
let BC_NIL = "<nil>"
let BC_MAP_TAG = "<bc_map>"
let BC_STRUCT_TAG = "<bc_struct>"
let BC_CLOSURE_TAG = "<bc_closure>"
let BC_CELL_TAG = "<bc_cell>"

fn bc_vm_is_cell(v) {
    if type_of(v) != "array" { return false }
    if len(v) != 2 { return false }
    if v[0] != BC_CELL_TAG { return false }
    return true
}
fn bc_vm_cell_deref(v) { return v[1] }
fn bc_vm_cell_store(cell, new_val) {
    cell[1] = new_val
    return cell
}

fn bc_vm_reset() {
    vm_stack = []
    vm_locals = []
    vm_frame_proto = []
    vm_frame_pc = []
    vm_frame_fp = []
    vm_frame_closure = []
    vm_global_names = []
    vm_global_vals = []
    vm_trap = false
    vm_trap_msg = ""
    vm_halted = false
    vm_try_catch_pc = []
    vm_try_stack_size = []
    vm_try_frame_depth = []
}

fn bc_vm_arr_shrink_last(arr) {
    let n = len(arr)
    if n <= 0 { return arr }
    return arr.truncate(n - 1)
}
fn bc_vm_arr_truncate(arr, keep_n) {
    if keep_n < 0 { keep_n = 0 }
    return arr.truncate(keep_n)
}

fn bc_vm_push(v) { vm_stack = vm_stack.push(v) }
fn bc_vm_pop() {
    let n = len(vm_stack)
    if n == 0 {
        vm_trap = true
        vm_trap_msg = "stack underflow"
        return BC_NIL
    }
    let top = vm_stack[n - 1]
    vm_stack = vm_stack.truncate(n - 1)
    return top
}
fn bc_vm_peek() {
    let n = len(vm_stack)
    if n == 0 {
        vm_trap = true
        vm_trap_msg = "stack peek underflow"
        return BC_NIL
    }
    return vm_stack[n - 1]
}
fn bc_vm_truncate(arr, n) {
    if n < 0 { n = 0 }
    return arr.truncate(n)
}
fn bc_vm_setat(arr, i, v) {
    arr[i] = v
    return arr
}

fn bc_vm_find_global(name) {
    let mut i = 0
    let n = len(vm_global_names)
    while i < n {
        if vm_global_names[i] == name { return i }
        i = i + 1
    }
    return -1
}
fn bc_vm_set_global(name, v) {
    let idx = bc_vm_find_global(name)
    if idx >= 0 {
        vm_global_vals = bc_vm_setat(vm_global_vals, idx, v)
    } else {
        vm_global_names = vm_global_names.push(name)
        vm_global_vals  = vm_global_vals.push(v)
    }
}
fn bc_vm_get_global(name) {
    let idx = bc_vm_find_global(name)
    if idx < 0 {
        vm_trap = true
        vm_trap_msg = "undefined global: " + name
        return BC_NIL
    }
    return vm_global_vals[idx]
}

fn bc_vm_parse_int(s) {
    let chars = s.chars()
    let n = len(chars)
    if n == 0 { return 0 }
    let mut i = 0
    let mut result = 0
    let mut neg = false
    if to_string(chars[0]) == "-" { neg = true; i = 1 }
    while i < n {
        let c = to_string(chars[i])
        let mut d = -1
        if c == "0" { d = 0 }
        if c == "1" { d = 1 }
        if c == "2" { d = 2 }
        if c == "3" { d = 3 }
        if c == "4" { d = 4 }
        if c == "5" { d = 5 }
        if c == "6" { d = 6 }
        if c == "7" { d = 7 }
        if c == "8" { d = 8 }
        if c == "9" { d = 9 }
        if d < 0 { return 0 }
        result = result * 10 + d
        i = i + 1
    }
    if neg { return 0 - result }
    return result
}

fn bc_vm_resolve_call(caller_proto_idx, b16) {
    if b16 < len(bc_protos) { return b16 }
    let consts = bc_proto_consts[caller_proto_idx]
    if b16 < len(consts) {
        let fname = consts[b16]
        let mut i = 0
        while i < len(bc_protos) {
            let p = bc_protos[i]
            if p.name == fname { return i }
            i = i + 1
        }
    }
    return -1
}

fn bc_vm_push_frame(proto_idx, nargs) {
    let target_locals = bc_proto_localcounts[proto_idx]
    let fp = len(vm_locals)
    let mut i = 0
    while i < target_locals {
        vm_locals = vm_locals.push(BC_NIL)
        i = i + 1
    }
    let mut j = nargs - 1
    while j >= 0 {
        let v = bc_vm_pop()
        vm_locals = bc_vm_setat(vm_locals, fp + j, v)
        j = j - 1
    }
    vm_frame_proto   = vm_frame_proto.push(proto_idx)
    vm_frame_pc      = vm_frame_pc.push(0)
    vm_frame_fp      = vm_frame_fp.push(fp)
    vm_frame_closure = vm_frame_closure.push(BC_NIL)
}

fn bc_vm_push_frame_indirect(proto_idx, nargs, closure) {
    let target_locals = bc_proto_localcounts[proto_idx]
    let fp = len(vm_locals)
    let mut i = 0
    while i < target_locals {
        vm_locals = vm_locals.push(BC_NIL)
        i = i + 1
    }
    let mut j = nargs - 1
    while j >= 0 {
        let v = bc_vm_pop()
        if vm_trap { return }
        vm_locals = bc_vm_setat(vm_locals, fp + j, v)
        j = j - 1
    }
    let _discard = bc_vm_pop()
    if vm_trap { return }
    vm_frame_proto   = vm_frame_proto.push(proto_idx)
    vm_frame_pc      = vm_frame_pc.push(0)
    vm_frame_fp      = vm_frame_fp.push(fp)
    vm_frame_closure = vm_frame_closure.push(closure)
}

fn bc_vm_pop_frame() {
    let depth = len(vm_frame_proto)
    if depth == 0 {
        vm_trap = true
        vm_trap_msg = "frame underflow"
        return
    }
    let fp = vm_frame_fp[depth - 1]
    vm_locals = bc_vm_truncate(vm_locals, fp)
    vm_frame_proto   = bc_vm_truncate(vm_frame_proto,   depth - 1)
    vm_frame_pc      = bc_vm_truncate(vm_frame_pc,      depth - 1)
    vm_frame_fp      = bc_vm_truncate(vm_frame_fp,      depth - 1)
    vm_frame_closure = bc_vm_truncate(vm_frame_closure, depth - 1)
}

fn bc_vm_is_truthy(v) {
    if v == false { return false }
    if v == true { return true }
    if v == BC_NIL { return false }
    if v == 0 { return false }
    if v == 0.0 { return false }
    return true
}

fn bc_vm_add(a, b) { return a + b }
fn bc_vm_sub(a, b) { return a - b }
fn bc_vm_mul(a, b) { return a * b }
fn bc_vm_div(a, b) {
    if b == 0 { vm_trap = true; vm_trap_msg = "division by zero"; return 0 }
    return a / b
}
fn bc_vm_mod(a, b) {
    if b == 0 { vm_trap = true; vm_trap_msg = "modulo by zero"; return 0 }
    return a % b
}
fn bc_vm_addf(a, b) { return to_float(a) + to_float(b) }
fn bc_vm_subf(a, b) { return to_float(a) - to_float(b) }
fn bc_vm_mulf(a, b) { return to_float(a) * to_float(b) }
fn bc_vm_divf(a, b) {
    let fb = to_float(b)
    if fb == 0.0 { vm_trap = true; vm_trap_msg = "float division by zero"; return 0.0 }
    return to_float(a) / fb
}
fn bc_vm_parse_float(s) { return to_float(s) }

fn bc_vm_eq(a, b)  { return a == b }
fn bc_vm_neq(a, b) { return a != b }
fn bc_vm_lt(a, b)  { return a <  b }
fn bc_vm_le(a, b)  { return a <= b }
fn bc_vm_gt(a, b)  { return a >  b }
fn bc_vm_ge(a, b)  { return a >= b }

fn bc_vm_run_loop() {
    if vm_trap { return BC_NIL }
    let mut last_return = BC_NIL
    while len(vm_frame_proto) > 0 {
        if vm_trap { return last_return }
        let depth = len(vm_frame_proto)
        let proto_idx = vm_frame_proto[depth - 1]
        let pc = vm_frame_pc[depth - 1]
        let fp = vm_frame_fp[depth - 1]
        let code = bc_proto_codes[proto_idx]
        if pc >= len(code) {
            vm_trap = true
            vm_trap_msg = "pc past code end"
            return last_return
        }
        let raw = code[pc]
        let op = bc_op_of(raw)
        vm_frame_pc = bc_vm_setat(vm_frame_pc, depth - 1, pc + 1)

        if op == BC_OP_LOADI {
            let v = bc_sbx_of(raw)
            bc_vm_push(v)
        } else if op == BC_OP_LOADK {
            let cidx = bc_bx_of(raw)
            let consts = bc_proto_consts[proto_idx]
            if cidx >= len(consts) { vm_trap = true; vm_trap_msg = "LOADK: const idx out of range"; return last_return }
            let s = consts[cidx]
            let parsed = bc_vm_parse_int(s)
            if s == to_string(parsed) { bc_vm_push(parsed) } else { bc_vm_push(s) }
        } else if op == BC_OP_LOADF {
            let cidx = bc_bx_of(raw)
            let consts = bc_proto_consts[proto_idx]
            if cidx >= len(consts) { vm_trap = true; vm_trap_msg = "LOADF: const idx out of range"; return last_return }
            bc_vm_push(bc_vm_parse_float(consts[cidx]))
        } else if op == BC_OP_LOADNIL {
            bc_vm_push(BC_NIL)
        } else if op == BC_OP_LOADTRUE {
            bc_vm_push(true)
        } else if op == BC_OP_LOADFALSE {
            bc_vm_push(false)
        } else if op == BC_OP_LOAD_LOCAL {
            let slot = bc_bx_of(raw)
            let slot_abs = fp + slot
            if slot_abs >= len(vm_locals) { vm_trap = true; vm_trap_msg = "LOAD_LOCAL: slot out of range"; return last_return }
            let ll_v = vm_locals[slot_abs]
            if bc_vm_is_cell(ll_v) { bc_vm_push(bc_vm_cell_deref(ll_v)) } else { bc_vm_push(ll_v) }
        } else if op == BC_OP_STORE_LOCAL {
            let slot = bc_bx_of(raw)
            let slot_abs = fp + slot
            let v = bc_vm_pop()
            if slot_abs >= len(vm_locals) {
                while len(vm_locals) <= slot_abs { vm_locals = vm_locals.push(BC_NIL) }
            }
            let sl_cur = vm_locals[slot_abs]
            if bc_vm_is_cell(sl_cur) { let _w = bc_vm_cell_store(sl_cur, v) } else { vm_locals = bc_vm_setat(vm_locals, slot_abs, v) }
        } else if op == BC_OP_HOIST_CELL {
            let hc_slot = bc_bx_of(raw)
            let hc_abs = fp + hc_slot
            if hc_abs >= len(vm_locals) { vm_trap = true; vm_trap_msg = "HOIST_CELL: slot out of range"; return last_return }
            let hc_cur = vm_locals[hc_abs]
            if bc_vm_is_cell(hc_cur) { bc_vm_push(hc_cur) } else {
                let hc_new = [BC_CELL_TAG, hc_cur]
                vm_locals = bc_vm_setat(vm_locals, hc_abs, hc_new)
                bc_vm_push(hc_new)
            }
        } else if op == BC_OP_LOAD_GLOBAL {
            let b16 = bc_b16_of(raw)
            let consts = bc_proto_consts[proto_idx]
            if b16 >= len(consts) { vm_trap = true; vm_trap_msg = "LOAD_GLOBAL: name const idx out of range"; return last_return }
            let name = consts[b16]
            let v = bc_vm_get_global(name)
            if vm_trap { return last_return }
            bc_vm_push(v)
        } else if op == BC_OP_STORE_GLOBAL {
            let b16 = bc_b16_of(raw)
            let consts = bc_proto_consts[proto_idx]
            if b16 >= len(consts) { vm_trap = true; vm_trap_msg = "STORE_GLOBAL: name const idx out of range"; return last_return }
            let name = consts[b16]
            let v = bc_vm_pop()
            bc_vm_set_global(name, v)
        } else if op == BC_OP_ADD {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_add(a, b))
        } else if op == BC_OP_SUB {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_sub(a, b))
        } else if op == BC_OP_MUL {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_mul(a, b))
        } else if op == BC_OP_DIV {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_div(a, b))
            if vm_trap { return last_return }
        } else if op == BC_OP_MOD {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_mod(a, b))
            if vm_trap { return last_return }
        } else if op == BC_OP_ADDF {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_addf(a, b))
        } else if op == BC_OP_SUBF {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_subf(a, b))
        } else if op == BC_OP_MULF {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_mulf(a, b))
        } else if op == BC_OP_DIVF {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_divf(a, b))
            if vm_trap { return last_return }
        } else if op == BC_OP_EQ {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_eq(a, b))
        } else if op == BC_OP_NEQ {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_neq(a, b))
        } else if op == BC_OP_LT {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_lt(a, b))
        } else if op == BC_OP_LE {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_le(a, b))
        } else if op == BC_OP_GT {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_gt(a, b))
        } else if op == BC_OP_GE {
            let b = bc_vm_pop(); let a = bc_vm_pop(); bc_vm_push(bc_vm_ge(a, b))
        } else if op == BC_OP_NOT {
            let v = bc_vm_pop(); bc_vm_push(!bc_vm_is_truthy(v))
        } else if op == BC_OP_AND {
            let b = bc_vm_pop(); let a = bc_vm_pop()
            if bc_vm_is_truthy(a) { bc_vm_push(bc_vm_is_truthy(b)) } else { bc_vm_push(false) }
        } else if op == BC_OP_OR {
            let b = bc_vm_pop(); let a = bc_vm_pop()
            if bc_vm_is_truthy(a) { bc_vm_push(true) } else { bc_vm_push(bc_vm_is_truthy(b)) }
        } else if op == BC_OP_JMP {
            let delta = bc_sbx_of(raw)
            let d2 = len(vm_frame_proto)
            let cur_pc = vm_frame_pc[d2 - 1]
            vm_frame_pc = bc_vm_setat(vm_frame_pc, d2 - 1, cur_pc + delta)
        } else if op == BC_OP_JMPF {
            let delta = bc_sbx_of(raw)
            let v = bc_vm_pop()
            if !bc_vm_is_truthy(v) {
                let d2 = len(vm_frame_proto)
                let cur_pc = vm_frame_pc[d2 - 1]
                vm_frame_pc = bc_vm_setat(vm_frame_pc, d2 - 1, cur_pc + delta)
            }
        } else if op == BC_OP_JMPT {
            let delta = bc_sbx_of(raw)
            let v = bc_vm_pop()
            if bc_vm_is_truthy(v) {
                let d2 = len(vm_frame_proto)
                let cur_pc = vm_frame_pc[d2 - 1]
                vm_frame_pc = bc_vm_setat(vm_frame_pc, d2 - 1, cur_pc + delta)
            }
        } else if op == BC_OP_CALL {
            let nargs = bc_a_of(raw)
            let b16 = bc_b16_of(raw)
            if b16 == BC_CALL_INDIRECT {
                let n_stack = len(vm_stack)
                let callee_idx = n_stack - nargs - 1
                if callee_idx < 0 { vm_trap = true; vm_trap_msg = "CALL indirect: stack underflow"; return last_return }
                let callee = vm_stack[callee_idx]
                let mut ok = false
                let mut target_proto = -1
                if type_of(callee) == "array" {
                    if len(callee) == 4 {
                        if callee[0] == BC_CLOSURE_TAG {
                            target_proto = callee[1]
                            if target_proto >= 0 { if target_proto < len(bc_protos) { ok = true } }
                        }
                    }
                }
                if !ok { vm_trap = true; vm_trap_msg = "CALL indirect: callee is not a closure"; return last_return }
                bc_vm_push_frame_indirect(target_proto, nargs, callee)
                if vm_trap { return last_return }
            } else {
                let target = bc_vm_resolve_call(proto_idx, b16)
                if target < 0 { vm_trap = true; vm_trap_msg = "CALL: cannot resolve target proto"; return last_return }
                bc_vm_push_frame(target, nargs)
                if vm_trap { return last_return }
            }
        } else if op == BC_OP_RETURN {
            let rv = bc_vm_pop()
            bc_vm_pop_frame()
            if vm_trap { return last_return }
            last_return = rv
            if len(vm_frame_proto) > 0 { bc_vm_push(rv) }
        } else if op == BC_OP_RETURN0 {
            bc_vm_pop_frame()
            if vm_trap { return last_return }
            last_return = BC_NIL
            if len(vm_frame_proto) > 0 { bc_vm_push(BC_NIL) }
        } else if op == BC_OP_POP {
            let _v = bc_vm_pop()
        } else if op == BC_OP_POPN {
            let popn_count = bc_bx_of(raw)
            let mut popn_i = 0
            while popn_i < popn_count { let _v = bc_vm_pop(); if vm_trap { return last_return }; popn_i = popn_i + 1 }
        } else if op == BC_OP_DUP {
            let dup_n = len(vm_stack)
            if dup_n == 0 { vm_trap = true; vm_trap_msg = "DUP: stack underflow"; return last_return }
            bc_vm_push(vm_stack[dup_n - 1])
        } else if op == BC_OP_MOVE {
            let mv_dst = bc_a_of(raw)
            let mv_src = bc_b16_of(raw)
            let mv_src_abs = fp + mv_src
            let mv_dst_abs = fp + mv_dst
            if mv_src_abs >= len(vm_locals) { vm_trap = true; vm_trap_msg = "MOVE: src slot out of range"; return last_return }
            while len(vm_locals) <= mv_dst_abs { vm_locals = vm_locals.push(BC_NIL) }
            vm_locals = bc_vm_setat(vm_locals, mv_dst_abs, vm_locals[mv_src_abs])
        } else if op == BC_OP_TAILCALL {
            let tc_nargs = bc_a_of(raw)
            let tc_b16 = bc_b16_of(raw)
            let tc_target = bc_vm_resolve_call(proto_idx, tc_b16)
            if tc_target < 0 { vm_trap = true; vm_trap_msg = "TAILCALL: cannot resolve target proto"; return last_return }
            bc_vm_push_frame(tc_target, tc_nargs)
            if vm_trap { return last_return }
        } else if op == BC_OP_CLOSURE {
            let cl_pidx = bc_bx_of(raw)
            if cl_pidx >= len(bc_protos) { vm_trap = true; vm_trap_msg = "CLOSURE: proto idx out of range"; return last_return }
            bc_vm_push([BC_CLOSURE_TAG, cl_pidx, [], []])
        } else if op == BC_OP_NEW_CLOSURE_UPVAL {
            let uv_cidx = bc_bx_of(raw)
            let uv_consts = bc_proto_consts[proto_idx]
            let mut uv_name = ""
            if uv_cidx < len(uv_consts) { uv_name = uv_consts[uv_cidx] }
            let uv_val = bc_vm_pop()
            let uv_closure = bc_vm_pop()
            if vm_trap { return last_return }
            let mut uv_tag_ok = false
            let mut uv_pidx = -1
            let mut uv_names = []
            let mut uv_vals = []
            if type_of(uv_closure) == "array" {
                if len(uv_closure) == 4 {
                    if uv_closure[0] == BC_CLOSURE_TAG {
                        uv_tag_ok = true
                        uv_pidx = uv_closure[1]
                        uv_names = uv_closure[2]
                        uv_vals = uv_closure[3]
                    }
                }
            }
            if !uv_tag_ok { vm_trap = true; vm_trap_msg = "NEW_CLOSURE_UPVAL: not a closure"; return last_return }
            bc_vm_push([BC_CLOSURE_TAG, uv_pidx, uv_names.push(uv_name), uv_vals.push(uv_val)])
        } else if op == BC_OP_LOAD_UPVAL {
            let lu_cidx = bc_bx_of(raw)
            let lu_consts = bc_proto_consts[proto_idx]
            if lu_cidx >= len(lu_consts) { vm_trap = true; vm_trap_msg = "LOAD_UPVAL: const idx out of range"; return last_return }
            let lu_name = lu_consts[lu_cidx]
            let lu_depth = len(vm_frame_closure)
            if lu_depth == 0 { vm_trap = true; vm_trap_msg = "LOAD_UPVAL: no active frame"; return last_return }
            let lu_cl = vm_frame_closure[lu_depth - 1]
            let mut lu_found = false
            let mut lu_val = BC_NIL
            if type_of(lu_cl) == "array" {
                if len(lu_cl) == 4 {
                    if lu_cl[0] == BC_CLOSURE_TAG {
                        let lu_names = lu_cl[2]
                        let lu_vals  = lu_cl[3]
                        let mut lu_i = 0
                        let lu_n = len(lu_names)
                        while lu_i < lu_n {
                            if lu_names[lu_i] == lu_name { lu_val = lu_vals[lu_i]; lu_found = true; lu_i = lu_n } else { lu_i = lu_i + 1 }
                        }
                    }
                }
            }
            if !lu_found { vm_trap = true; vm_trap_msg = "LOAD_UPVAL: upvalue not bound: " + lu_name; return last_return }
            if bc_vm_is_cell(lu_val) { bc_vm_push(bc_vm_cell_deref(lu_val)) } else { bc_vm_push(lu_val) }
        } else if op == BC_OP_STORE_UPVAL {
            let su_cidx = bc_bx_of(raw)
            let su_consts = bc_proto_consts[proto_idx]
            if su_cidx >= len(su_consts) { vm_trap = true; vm_trap_msg = "STORE_UPVAL: const idx out of range"; return last_return }
            let su_name = su_consts[su_cidx]
            let su_depth = len(vm_frame_closure)
            if su_depth == 0 { vm_trap = true; vm_trap_msg = "STORE_UPVAL: no active frame"; return last_return }
            let su_val = bc_vm_pop()
            if vm_trap { return last_return }
            let su_cl = vm_frame_closure[su_depth - 1]
            let mut su_found = false
            if type_of(su_cl) == "array" {
                if len(su_cl) == 4 {
                    if su_cl[0] == BC_CLOSURE_TAG {
                        let su_pidx = su_cl[1]
                        let su_names = su_cl[2]
                        let su_vals  = su_cl[3]
                        let mut su_i = 0
                        let su_n = len(su_names)
                        while su_i < su_n {
                            if su_names[su_i] == su_name {
                                su_found = true
                                if bc_vm_is_cell(su_vals[su_i]) { bc_vm_cell_store(su_vals[su_i], su_val) } else {
                                    let mut su_new_vals = []
                                    let mut su_j = 0
                                    while su_j < su_n {
                                        if su_j == su_i { su_new_vals = su_new_vals.push(su_val) } else { su_new_vals = su_new_vals.push(su_vals[su_j]) }
                                        su_j = su_j + 1
                                    }
                                    vm_frame_closure = bc_vm_setat(vm_frame_closure, su_depth - 1, [BC_CLOSURE_TAG, su_pidx, su_names, su_new_vals])
                                }
                                su_i = su_n
                            } else { su_i = su_i + 1 }
                        }
                    }
                }
            }
            if !su_found { vm_trap = true; vm_trap_msg = "STORE_UPVAL: upvalue not bound: " + su_name; return last_return }
        } else if op == BC_OP_PRINT {
            let pn = bc_a_of(raw)
            let mut pparts = []
            let mut pi = 0
            while pi < pn { pparts = pparts.push(bc_vm_pop()); pi = pi + 1 }
            let mut pout = ""
            let mut pj = pn - 1
            while pj >= 0 { pout = pout + to_string(pparts[pj]); pj = pj - 1 }
            print(pout)
        } else if op == BC_OP_PRINTLN {
            let pln = bc_a_of(raw)
            let mut plparts = []
            let mut pli = 0
            while pli < pln { plparts = plparts.push(bc_vm_pop()); pli = pli + 1 }
            let mut plout = ""
            let mut plj = pln - 1
            while plj >= 0 { plout = plout + to_string(plparts[plj]); plj = plj - 1 }
            println(plout)
        } else if op == BC_OP_NOP {
            // no-op
        } else if op == BC_OP_TO_STRING {
            let v = bc_vm_pop(); bc_vm_push(to_string(v))
        } else if op == BC_OP_TO_INT {
            let v = bc_vm_pop()
            if type_of(v) == "string" { bc_vm_push(v.parse_int()) } else if type_of(v) == "float" { bc_vm_push(to_int(v)) } else { bc_vm_push(v) }
        } else if op == BC_OP_TO_FLOAT {
            let v = bc_vm_pop(); bc_vm_push(to_float(v))
        } else if op == BC_OP_TYPE_OF {
            let v = bc_vm_pop(); bc_vm_push(type_of(v))
        } else if op == BC_OP_HALT {
            let n = len(vm_stack)
            if n > 0 { last_return = vm_stack[n - 1] }
            vm_halted = true
            return last_return
        } else if op == BC_OP_ASSERT_INT {
            let v = bc_vm_peek()
            if vm_trap { return last_return }
            if type_of(v) != "int" { vm_trap = true; vm_trap_msg = "ASSERT_INT failed: got " + type_of(v); return last_return }
        } else if op == BC_OP_ASSERT_FLOAT {
            let v = bc_vm_peek()
            if vm_trap { return last_return }
            if type_of(v) != "float" { vm_trap = true; vm_trap_msg = "ASSERT_FLOAT failed: got " + type_of(v); return last_return }
        } else if op == BC_OP_NEW_ARRAY {
            let count = bc_b16_of(raw)
            let mut buf = []
            let mut k = 0
            while k < count { buf = buf.push(bc_vm_pop()); if vm_trap { return last_return }; k = k + 1 }
            let mut arr = []
            let mut j = count - 1
            while j >= 0 { arr = arr.push(buf[j]); j = j - 1 }
            bc_vm_push(arr)
        } else if op == BC_OP_ARR_GET {
            let idx = bc_vm_pop()
            let arr = bc_vm_pop()
            if vm_trap { return last_return }
            let mut ag_is_map = false
            let mut ag_is_str = false
            if type_of(arr) == "string" { ag_is_str = true } else if type_of(arr) == "array" { if len(arr) == 3 { if arr[0] == BC_MAP_TAG { ag_is_map = true } } }
            if ag_is_map {
                let mks = arr[1]; let mvs = arr[2]; let mkn = len(mks)
                let mut mi = 0; let mut mhit = BC_NIL
                while mi < mkn { if mks[mi] == idx { mhit = mvs[mi]; mi = mkn } else { mi = mi + 1 } }
                bc_vm_push(mhit)
            } else if ag_is_str {
                let ag_chars = arr.chars()
                bc_vm_push(to_string(ag_chars[idx]))
            } else { bc_vm_push(arr[idx]) }
        } else if op == BC_OP_ARR_SET {
            let v = bc_vm_pop(); let idx = bc_vm_pop(); let arr = bc_vm_pop()
            if vm_trap { return last_return }
            let mut as_is_map = false
            let mut as_is_str = false
            if type_of(arr) == "string" { as_is_str = true } else if type_of(arr) == "array" { if len(arr) == 3 { if arr[0] == BC_MAP_TAG { as_is_map = true } } }
            if as_is_map {
                let as_keys = arr[1]; let as_vals = arr[2]; let as_nk = len(as_keys)
                let mut as_hit = -1; let mut as_i = 0
                while as_i < as_nk { if as_keys[as_i] == idx { as_hit = as_i; as_i = as_nk } else { as_i = as_i + 1 } }
                let mut as_new_keys = as_keys; let mut as_new_vals = as_vals
                if as_hit >= 0 { as_new_vals = bc_vm_setat(as_vals, as_hit, v) } else { as_new_keys = as_keys.push(idx); as_new_vals = as_vals.push(v) }
                bc_vm_push([BC_MAP_TAG, as_new_keys, as_new_vals])
            } else if as_is_str {
                let as_chars = arr.chars(); let as_cn = len(as_chars)
                let mut as_out = ""; let mut as_ci = 0
                while as_ci < as_cn { if as_ci == idx { as_out = as_out + to_string(v) } else { as_out = as_out + to_string(as_chars[as_ci]) }; as_ci = as_ci + 1 }
                bc_vm_push(as_out)
            } else { bc_vm_push(bc_vm_setat(arr, idx, v)) }
        } else if op == BC_OP_ARR_PUSH {
            let v = bc_vm_pop(); let arr = bc_vm_pop()
            if vm_trap { return last_return }
            bc_vm_push(arr.push(v))
        } else if op == BC_OP_ARR_LEN {
            let arr = bc_vm_pop()
            if vm_trap { return last_return }
            let mut n = 0
            if type_of(arr) == "array" {
                if len(arr) == 3 { if arr[0] == BC_MAP_TAG { n = len(arr[1]) } else { n = len(arr) } } else { n = len(arr) }
            } else { n = len(arr) }
            bc_vm_push(n)
        } else if op == BC_OP_NEW_MAP {
            let pair_count = bc_b16_of(raw)
            let mut kbuf = []; let mut vbuf = []; let mut k2 = 0
            while k2 < pair_count { let vp = bc_vm_pop(); let kp = bc_vm_pop(); if vm_trap { return last_return }; kbuf = kbuf.push(kp); vbuf = vbuf.push(vp); k2 = k2 + 1 }
            let mut keys = []; let mut vals = []; let mut j2 = pair_count - 1
            while j2 >= 0 { keys = keys.push(kbuf[j2]); vals = vals.push(vbuf[j2]); j2 = j2 - 1 }
            bc_vm_push([BC_MAP_TAG, keys, vals])
        } else if op == BC_OP_MAP_GET {
            let key_mg = bc_vm_pop(); let m_mg = bc_vm_pop()
            if vm_trap { return last_return }
            let keys_mg = m_mg[1]; let vals_mg = m_mg[2]; let nk = len(keys_mg)
            let mut i_mg = 0; let mut hit_val = BC_NIL
            while i_mg < nk { if keys_mg[i_mg] == key_mg { hit_val = vals_mg[i_mg]; i_mg = nk } else { i_mg = i_mg + 1 } }
            bc_vm_push(hit_val)
        } else if op == BC_OP_MAP_SET {
            let v_ms = bc_vm_pop(); let key_ms = bc_vm_pop(); let m_ms = bc_vm_pop()
            if vm_trap { return last_return }
            let keys_ms = m_ms[1]; let vals_ms = m_ms[2]; let nk2 = len(keys_ms)
            let mut found_idx = -1; let mut i_ms = 0
            while i_ms < nk2 { if keys_ms[i_ms] == key_ms { found_idx = i_ms; i_ms = nk2 } else { i_ms = i_ms + 1 } }
            let mut new_keys = keys_ms; let mut new_vals = vals_ms
            if found_idx >= 0 { new_vals = bc_vm_setat(vals_ms, found_idx, v_ms) } else { new_keys = keys_ms.push(key_ms); new_vals = vals_ms.push(v_ms) }
            bc_vm_push([BC_MAP_TAG, new_keys, new_vals])
        } else if op == BC_OP_NEW_STRUCT {
            let n_fields = bc_a_of(raw)
            let name_cidx = bc_b16_of(raw)
            let consts_ns = bc_proto_consts[proto_idx]
            let mut sname = ""
            if name_cidx < len(consts_ns) { sname = consts_ns[name_cidx] }
            let mut sval_buf = []; let mut skey_buf = []; let mut sk = 0
            while sk < n_fields { sval_buf = sval_buf.push(bc_vm_pop()); if vm_trap { return last_return }; skey_buf = skey_buf.push(bc_vm_pop()); if vm_trap { return last_return }; sk = sk + 1 }
            let mut skeys = []; let mut svals = []; let mut sj = n_fields - 1
            while sj >= 0 { skeys = skeys.push(skey_buf[sj]); svals = svals.push(sval_buf[sj]); sj = sj - 1 }
            bc_vm_push([BC_STRUCT_TAG, sname, skeys, svals])
        } else if op == BC_OP_LOAD_FIELD {
            let fcidx = bc_bx_of(raw)
            let consts_lf = bc_proto_consts[proto_idx]
            let mut fname = ""
            if fcidx < len(consts_lf) { fname = consts_lf[fcidx] }
            let sobj_lf = bc_vm_pop()
            if vm_trap { return last_return }
            let mut lf_hit = BC_NIL
            if type_of(sobj_lf) == "array" {
                if len(sobj_lf) == 4 {
                    if sobj_lf[0] == BC_STRUCT_TAG {
                        let lf_keys = sobj_lf[2]; let lf_vals = sobj_lf[3]; let lf_n = len(lf_keys)
                        let mut lf_i = 0
                        while lf_i < lf_n { if lf_keys[lf_i] == fname { lf_hit = lf_vals[lf_i]; lf_i = lf_n } else { lf_i = lf_i + 1 } }
                    }
                }
            }
            bc_vm_push(lf_hit)
        } else if op == BC_OP_STORE_FIELD {
            let sfcidx = bc_bx_of(raw)
            let consts_sf = bc_proto_consts[proto_idx]
            let mut sfname = ""
            if sfcidx < len(consts_sf) { sfname = consts_sf[sfcidx] }
            let sf_val = bc_vm_pop(); let sf_obj = bc_vm_pop()
            if vm_trap { return last_return }
            let mut sf_tag = ""; let mut sf_type = ""; let mut sf_keys = []; let mut sf_vals = []
            if type_of(sf_obj) == "array" { if len(sf_obj) == 4 { if sf_obj[0] == BC_STRUCT_TAG { sf_tag = sf_obj[0]; sf_type = sf_obj[1]; sf_keys = sf_obj[2]; sf_vals = sf_obj[3] } } }
            if sf_tag == "" { vm_trap = true; vm_trap_msg = "STORE_FIELD: not a struct value"; return last_return }
            let sf_nk = len(sf_keys); let mut sf_hitidx = -1; let mut sf_i = 0
            while sf_i < sf_nk { if sf_keys[sf_i] == sfname { sf_hitidx = sf_i; sf_i = sf_nk } else { sf_i = sf_i + 1 } }
            let mut sf_new_keys = sf_keys; let mut sf_new_vals = sf_vals
            if sf_hitidx >= 0 { sf_new_vals = bc_vm_setat(sf_vals, sf_hitidx, sf_val) } else { sf_new_keys = sf_keys.push(sfname); sf_new_vals = sf_vals.push(sf_val) }
            bc_vm_push([BC_STRUCT_TAG, sf_type, sf_new_keys, sf_new_vals])
        } else if op == BC_OP_TRY {
            let t_sbx = bc_sbx_of(raw)
            let t_cur_pc = vm_frame_pc[depth - 1]
            let t_catch_pc = t_cur_pc + t_sbx
            vm_try_catch_pc    = vm_try_catch_pc.push(t_catch_pc)
            vm_try_stack_size  = vm_try_stack_size.push(len(vm_stack))
            vm_try_frame_depth = vm_try_frame_depth.push(len(vm_frame_proto))
        } else if op == BC_OP_ENDTRY {
            if len(vm_try_catch_pc) > 0 {
                vm_try_catch_pc    = bc_vm_arr_shrink_last(vm_try_catch_pc)
                vm_try_stack_size  = bc_vm_arr_shrink_last(vm_try_stack_size)
                vm_try_frame_depth = bc_vm_arr_shrink_last(vm_try_frame_depth)
            }
        } else if op == BC_OP_THROW {
            let th_val = bc_vm_pop()
            if vm_trap { return last_return }
            let th_n = len(vm_try_catch_pc)
            if th_n == 0 { vm_trap = true; vm_trap_msg = "uncaught throw: " + to_string(th_val); return last_return }
            let th_saved_sp = vm_try_stack_size[th_n - 1]
            let th_saved_fd = vm_try_frame_depth[th_n - 1]
            let th_catch_pc = vm_try_catch_pc[th_n - 1]
            vm_try_catch_pc    = bc_vm_arr_shrink_last(vm_try_catch_pc)
            vm_try_stack_size  = bc_vm_arr_shrink_last(vm_try_stack_size)
            vm_try_frame_depth = bc_vm_arr_shrink_last(vm_try_frame_depth)
            vm_stack         = bc_vm_arr_truncate(vm_stack, th_saved_sp)
            vm_frame_proto   = bc_vm_arr_truncate(vm_frame_proto,   th_saved_fd)
            vm_frame_pc      = bc_vm_arr_truncate(vm_frame_pc,      th_saved_fd)
            vm_frame_fp      = bc_vm_arr_truncate(vm_frame_fp,      th_saved_fd)
            vm_frame_closure = bc_vm_arr_truncate(vm_frame_closure, th_saved_fd)
            bc_vm_push(th_val)
            let th_new_d = len(vm_frame_proto)
            if th_new_d > 0 { vm_frame_pc = bc_vm_setat(vm_frame_pc, th_new_d - 1, th_catch_pc) }
        } else if op == BC_OP_PROFILE_HOOK {
            // NOP
        } else {
            vm_trap = true
            vm_trap_msg = "unimplemented opcode: " + bc_opname(op) + " (" + to_string(op) + ")"
            return last_return
        }
    }
    return last_return
}

fn bc_vm_run() {
    bc_vm_reset()
    let mut main_idx = -1
    let mut user_main_idx = -1
    let mut i = 0
    while i < len(bc_protos) {
        let p = bc_protos[i]
        if p.name == "<main>" { main_idx = i }
        if p.name == "main"   { user_main_idx = i }
        i = i + 1
    }
    let mut top_result = BC_NIL
    if main_idx >= 0 {
        bc_vm_push_frame(main_idx, 0)
        if vm_trap { return BC_NIL }
        top_result = bc_vm_run_loop()
    } else {
        if user_main_idx < 0 { return BC_NIL }
    }
    if !vm_trap && !vm_halted && user_main_idx >= 0 {
        vm_stack = []
        bc_vm_push_frame(user_main_idx, 0)
        if vm_trap { return top_result }
        return bc_vm_run_loop()
    }
    return top_result
}

fn bc_vm_trap_hit() { return vm_trap }
fn bc_vm_trap_reason() { return vm_trap_msg }
fn bc_vm_halted_hit() { return vm_halted }

fn bc_vm_call_by_name(name) {
    bc_vm_reset()
    let mut target = -1
    let mut i = 0
    while i < len(bc_protos) {
        let p = bc_protos[i]
        if p.name == name { target = i }
        i = i + 1
    }
    if target < 0 { vm_trap = true; vm_trap_msg = "bc_vm_call_by_name: no such proto: " + name; return BC_NIL }
    bc_vm_push_frame(target, 0)
    if vm_trap { return BC_NIL }
    return bc_vm_run_loop()
}
// ── END INLINED ──

fn bcvm_push_proto(name, codes, n_locals, max_stack) {
    let p = BcProto {
        name: name,
        n_params: 0,
        n_locals: n_locals,
        max_stack: max_stack,
        code_len: len(codes),
        consts_len: 0
    }
    bc_protos            = bc_protos.push(p)
    bc_proto_codes       = bc_proto_codes.push(codes)
    bc_proto_consts      = bc_proto_consts.push([])
    bc_proto_localcounts = bc_proto_localcounts.push(n_locals)
    bc_proto_max_stacks  = bc_proto_max_stacks.push(max_stack)
}

fn bcvm_push_proto_with_consts(name, n_params, codes, n_locals, max_stack, consts) {
    let p = BcProto {
        name: name,
        n_params: n_params,
        n_locals: n_locals,
        max_stack: max_stack,
        code_len: len(codes),
        consts_len: len(consts)
    }
    bc_protos            = bc_protos.push(p)
    bc_proto_codes       = bc_proto_codes.push(codes)
    bc_proto_consts      = bc_proto_consts.push(consts)
    bc_proto_localcounts = bc_proto_localcounts.push(n_locals)
    bc_proto_max_stacks  = bc_proto_max_stacks.push(max_stack)
}

fn bcvm_reset_registries() {
    bc_protos = []
    bc_proto_codes = []
    bc_proto_consts = []
    bc_proto_localcounts = []
    bc_proto_max_stacks = []
}

fn bcvm_test_arith() {
    println("[T1] arith: 42 + 8 - 5 = 45")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 42),
        bc_enc_sbx(BC_OP_LOADI, 8),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_sbx(BC_OP_LOADI, 5),
        bc_enc_abx(BC_OP_SUB, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 2)
    let r = bc_vm_run()
    if r == 45 { println("  PASS arith=" + to_string(r)) } else { println("  FAIL arith got=" + to_string(r)) }
}

fn bcvm_test_mul() {
    println("[T2] mul: 6 * 7 = 42")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 6),
        bc_enc_sbx(BC_OP_LOADI, 7),
        bc_enc_abx(BC_OP_MUL, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 2)
    let r = bc_vm_run()
    if r == 42 { println("  PASS mul=" + to_string(r)) } else { println("  FAIL mul got=" + to_string(r)) }
}

// Layout for (10 == 10) ? 1 : 0:
//   0: LOADI 10
//   1: LOADI 10
//   2: EQ
//   3: JMPF +2     (false → pc=6)
//   4: LOADI 1
//   5: JMP  +1     (skip else → pc=7)
//   6: LOADI 0
//   7: RETURN
fn bcvm_test_branch() {
    println("[T3] branch: (10 == 10) ? 1 : 0 = 1")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 10),
        bc_enc_sbx(BC_OP_LOADI, 10),
        bc_enc_abx(BC_OP_EQ,  0),
        bc_enc_sbx(BC_OP_JMPF, 2),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_sbx(BC_OP_JMP,  1),
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 2)
    let r = bc_vm_run()
    if r == 1 { println("  PASS branch=" + to_string(r)) } else { println("  FAIL branch got=" + to_string(r)) }
}

fn bcvm_test_trap_underflow() {
    println("[T4] trap: RETURN on empty stack")
    bcvm_reset_registries()
    let code = [ bc_enc_abx(BC_OP_RETURN, 0) ]
    bcvm_push_proto("<main>", code, 0, 0)
    let _r = bc_vm_run()
    let got = bc_vm_trap_hit()
    if got { println("  PASS trap-set") } else { println("  FAIL trap-not-set") }
}

