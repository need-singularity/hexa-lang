// Test 16: JMPT — forward true-jump skips the 0 branch, lands on 99.
//   0: LOADI 5
//   1: LOADI 5
//   2: EQ                 ; true on stack
//   3: JMPT +2            ; true → pc=6 (cur_pc=4, 4+2=6)
//   4: LOADI 0            ; (skipped if true)
//   5: JMP  +1            ; skip the 99 branch when false (cur_pc=6, 6+1=7)
//   6: LOADI 99           ; landing pad on true
//   7: RETURN
fn bcvm_test_jmpt() {
    println("[T16] jmpt: (5==5) ? 99 : 0 = 99")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 5),
        bc_enc_sbx(BC_OP_LOADI, 5),
        bc_enc_abx(BC_OP_EQ,   0),
        bc_enc_sbx(BC_OP_JMPT, 2),
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_sbx(BC_OP_JMP,  1),
        bc_enc_sbx(BC_OP_LOADI, 99),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 2)
    let r = bc_vm_run()
    if r == 99 { println("  PASS jmpt=" + to_string(r)) } else { println("  FAIL jmpt got=" + to_string(r)) }
}

