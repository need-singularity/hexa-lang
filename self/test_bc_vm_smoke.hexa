    let r = bc_vm_run()
    if r == "hello" { println("  PASS loadk=\"" + r + "\"") } else { println("  FAIL loadk got=" + to_string(r)) }
}

// Test 8: backward JMP as a counting loop — sum 1..5 = 15.
//   locals: 0=sum, 1=i
//   0: LOADI 0        ; sum=0
//   1: STORE_LOCAL 0
//   2: LOADI 1        ; i=1
//   3: STORE_LOCAL 1
//  top (pc=4):
//   4: LOAD_LOCAL 1   ; push i
//   5: LOADI 6        ; push 6
//   6: LT             ; push i<6
//   7: JMPF +9        ; exit loop → pc=17 (cur_pc=8, 8+9=17)
//   8: LOAD_LOCAL 0   ; sum += i
//   9: LOAD_LOCAL 1
//  10: ADD
//  11: STORE_LOCAL 0
//  12: LOAD_LOCAL 1   ; i = i + 1
//  13: LOADI 1
//  14: ADD
//  15: STORE_LOCAL 1
//  16: JMP -13        ; back to pc=4 (cur_pc=17, 17-13=4)
//  17: LOAD_LOCAL 0
//  18: RETURN
fn bcvm_test_loop() {
    println("[T8] loop: sum 1..5 = 15")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 0),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_STORE_LOCAL, 1),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 1),
        bc_enc_sbx(BC_OP_LOADI, 6),
        bc_enc_abx(BC_OP_LT,  0),
        bc_enc_sbx(BC_OP_JMPF, 9),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 1),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 0),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 1),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 1),
        bc_enc_sbx(BC_OP_JMP, -13),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 2, 3)
    let r = bc_vm_run()
    if r == 15 { println("  PASS loop=" + to_string(r)) } else { println("  FAIL loop got=" + to_string(r)) }
}

// Test 9: CALL / RETURN with argument — double(21) returns 42.
//   <main> body:
//     0: LOADI 21
//     1: CALL  A=1 B16=1     (proto index 1 = double)
//     2: RETURN
//   double(x) body (proto idx 1):
//     0: LOAD_LOCAL 0   ; x
//     1: LOADI 2
//     2: MUL
//     3: RETURN
fn bcvm_test_call() {
    println("[T9] call: double(21) = 42")
    bcvm_reset_registries()
    let main_code = [
        bc_enc_sbx(BC_OP_LOADI, 21),
        bc_enc_ab16(BC_OP_CALL, 1, 1),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    let dbl_code = [
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_sbx(BC_OP_LOADI, 2),
        bc_enc_abx(BC_OP_MUL, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", main_code, 0, 2)
    bcvm_push_proto_with_consts("double", 1, dbl_code, 1, 2, [])
    let r = bc_vm_run()
    if r == 42 { println("  PASS call=" + to_string(r)) } else { println("  FAIL call got=" + to_string(r)) }
}

