// rt#36-C smoke test: drive bc_emitter globals through bc_vm_run_loop.
//
// Validates the core MVP opcodes (LOADI, ADD/SUB/MUL, EQ, JMPF/JMP,
// RETURN) plus trap detection on stack underflow. Bypasses the AST
// path by populating bc_protos / bc_proto_codes / bc_proto_consts
// directly — rt#36-D will swap this for a real parser→emitter→vm
// chain once NaN-box + frame spill are in.
//
// Run via module_loader (T36 resolved — O(n²) char-push → substring):
//   ./build/hexa_stage0 self/module_loader.hexa \
//     self/test_bc_vm_smoke.hexa /tmp/bcvm.hexa
//   ./build/hexa_stage0 /tmp/bcvm.hexa

use "bc_emitter"
use "bc_vm"

fn bcvm_push_proto(name, codes, n_locals, max_stack) {
    let p = BcProto {
        name: name,
        n_params: 0,
        n_locals: n_locals,
        max_stack: max_stack,
        code_len: len(codes),
        consts_len: 0
    }
    bc_protos            = bc_protos.push(p)
    bc_proto_codes       = bc_proto_codes.push(codes)
    bc_proto_consts      = bc_proto_consts.push([])
    bc_proto_localcounts = bc_proto_localcounts.push(n_locals)
    bc_proto_max_stacks  = bc_proto_max_stacks.push(max_stack)
}

fn bcvm_push_proto_with_consts(name, n_params, codes, n_locals, max_stack, consts) {
    let p = BcProto {
        name: name,
        n_params: n_params,
        n_locals: n_locals,
        max_stack: max_stack,
        code_len: len(codes),
        consts_len: len(consts)
    }
    bc_protos            = bc_protos.push(p)
    bc_proto_codes       = bc_proto_codes.push(codes)
    bc_proto_consts      = bc_proto_consts.push(consts)
    bc_proto_localcounts = bc_proto_localcounts.push(n_locals)
    bc_proto_max_stacks  = bc_proto_max_stacks.push(max_stack)
}

fn bcvm_reset_registries() {
    bc_protos = []
    bc_proto_codes = []
    bc_proto_consts = []
    bc_proto_localcounts = []
    bc_proto_max_stacks = []
}

fn bcvm_test_arith() {
    println("[T1] arith: 42 + 8 - 5 = 45")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 42),
        bc_enc_sbx(BC_OP_LOADI, 8),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_sbx(BC_OP_LOADI, 5),
        bc_enc_abx(BC_OP_SUB, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 2)
    let r = bc_vm_run()
    if r == 45 { println("  PASS arith=" + to_string(r)) } else { println("  FAIL arith got=" + to_string(r)) }
}

fn bcvm_test_mul() {
    println("[T2] mul: 6 * 7 = 42")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 6),
        bc_enc_sbx(BC_OP_LOADI, 7),
        bc_enc_abx(BC_OP_MUL, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 2)
    let r = bc_vm_run()
    if r == 42 { println("  PASS mul=" + to_string(r)) } else { println("  FAIL mul got=" + to_string(r)) }
}

// Layout for (10 == 10) ? 1 : 0:
//   0: LOADI 10
//   1: LOADI 10
//   2: EQ
//   3: JMPF +2     (false → pc=6)
//   4: LOADI 1
//   5: JMP  +1     (skip else → pc=7)
//   6: LOADI 0
//   7: RETURN
fn bcvm_test_branch() {
    println("[T3] branch: (10 == 10) ? 1 : 0 = 1")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 10),
        bc_enc_sbx(BC_OP_LOADI, 10),
        bc_enc_abx(BC_OP_EQ,  0),
        bc_enc_sbx(BC_OP_JMPF, 2),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_sbx(BC_OP_JMP,  1),
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 2)
    let r = bc_vm_run()
    if r == 1 { println("  PASS branch=" + to_string(r)) } else { println("  FAIL branch got=" + to_string(r)) }
}

fn bcvm_test_trap_underflow() {
    println("[T4] trap: RETURN on empty stack")
    bcvm_reset_registries()
    let code = [ bc_enc_abx(BC_OP_RETURN, 0) ]
    bcvm_push_proto("<main>", code, 0, 0)
    let _r = bc_vm_run()
    let got = bc_vm_trap_hit()
    if got { println("  PASS trap-set") } else { println("  FAIL trap-not-set") }
}

// Test 5: local slot I/O — store 42 to slot 0, load it back, return.
fn bcvm_test_local() {
    println("[T5] local: store/load slot 0 = 42")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 42),
        bc_enc_abx(BC_OP_STORE_LOCAL, 0),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 1, 2)
    let r = bc_vm_run()
    if r == 42 { println("  PASS local=" + to_string(r)) } else { println("  FAIL local got=" + to_string(r)) }
}

// Test 6: NOT — !true = false.
fn bcvm_test_not() {
    println("[T6] not: !true = false")
    bcvm_reset_registries()
    let code = [
        bc_enc_abx(BC_OP_LOADTRUE, 0),
        bc_enc_abx(BC_OP_NOT, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 0, 1)
    let r = bc_vm_run()
    if r == false { println("  PASS not=false") } else { println("  FAIL not got=" + to_string(r)) }
}

// Test 7: LOADK — load "hello" from const pool.
fn bcvm_test_loadk() {
    println("[T7] loadk: const[0] = \"hello\"")
    bcvm_reset_registries()
    let code = [
        bc_enc_abx(BC_OP_LOADK, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto_with_consts("<main>", 0, code, 0, 1, ["hello"])
    let r = bc_vm_run()
    if r == "hello" { println("  PASS loadk=\"" + r + "\"") } else { println("  FAIL loadk got=" + to_string(r)) }
}

// Test 8: backward JMP as a counting loop — sum 1..5 = 15.
//   locals: 0=sum, 1=i
//   0: LOADI 0        ; sum=0
//   1: STORE_LOCAL 0
//   2: LOADI 1        ; i=1
//   3: STORE_LOCAL 1
//  top (pc=4):
//   4: LOAD_LOCAL 1   ; push i
//   5: LOADI 6        ; push 6
//   6: LT             ; push i<6
//   7: JMPF +9        ; exit loop → pc=17 (cur_pc=8, 8+9=17)
//   8: LOAD_LOCAL 0   ; sum += i
//   9: LOAD_LOCAL 1
//  10: ADD
//  11: STORE_LOCAL 0
//  12: LOAD_LOCAL 1   ; i = i + 1
//  13: LOADI 1
//  14: ADD
//  15: STORE_LOCAL 1
//  16: JMP -13        ; back to pc=4 (cur_pc=17, 17-13=4)
//  17: LOAD_LOCAL 0
//  18: RETURN
fn bcvm_test_loop() {
    println("[T8] loop: sum 1..5 = 15")
    bcvm_reset_registries()
    let code = [
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 0),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_STORE_LOCAL, 1),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 1),
        bc_enc_sbx(BC_OP_LOADI, 6),
        bc_enc_abx(BC_OP_LT,  0),
        bc_enc_sbx(BC_OP_JMPF, 9),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 1),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 0),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 1),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 1),
        bc_enc_sbx(BC_OP_JMP, -13),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", code, 2, 3)
    let r = bc_vm_run()
    if r == 15 { println("  PASS loop=" + to_string(r)) } else { println("  FAIL loop got=" + to_string(r)) }
}

// Test 9: CALL / RETURN with argument — double(21) returns 42.
//   <main> body:
//     0: LOADI 21
//     1: CALL  A=1 B16=1     (proto index 1 = double)
//     2: RETURN
//   double(x) body (proto idx 1):
//     0: LOAD_LOCAL 0   ; x
//     1: LOADI 2
//     2: MUL
//     3: RETURN
fn bcvm_test_call() {
    println("[T9] call: double(21) = 42")
    bcvm_reset_registries()
    let main_code = [
        bc_enc_sbx(BC_OP_LOADI, 21),
        bc_enc_ab16(BC_OP_CALL, 1, 1),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    let dbl_code = [
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_sbx(BC_OP_LOADI, 2),
        bc_enc_abx(BC_OP_MUL, 0),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvm_push_proto("<main>", main_code, 0, 2)
    bcvm_push_proto_with_consts("double", 1, dbl_code, 1, 2, [])
    let r = bc_vm_run()
    if r == 42 { println("  PASS call=" + to_string(r)) } else { println("  FAIL call got=" + to_string(r)) }
}

// ─────────────────────────────────────────────────────────────
// Extended coverage (T10~T22): DIV, MOD, NEQ, LE, GT, GE, JMPT,
// POP, LOADNIL, LOADFALSE, LOAD_GLOBAL, STORE_GLOBAL, PRINT,
// RETURN0. Total coverage after extension: 28/28 MVP opcodes.
// ─────────────────────────────────────────────────────────────

