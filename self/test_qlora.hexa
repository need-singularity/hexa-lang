// ═══════════════════════════════════════════════════════════
//  test_qlora.hexa — QLoRA unit tests
//  Tests: NF4 round-trip, forward dims, backward frozen base
// ═══════════════════════════════════════════════════════════

// ── inlined from self/ml/qlora.hexa ──────────────────
// codegen_c2 import not wired for test files

// ═══════════════════════════════════════════════════════════
//  qlora.hexa — QLoRA: Quantized Low-Rank Adaptation
//  (Dettmers et al. 2023)
//
//  Pure Hexa, no C/FFI.
//
//  NF4 (Normal Float 4-bit) quantization with per-block absmax
//  scaling (block_size=64) + trainable LoRA A,B float matrices.
//
//  y = dequant(base_nf4) @ input + scale * (B @ A @ input)
//
//  Only A and B receive gradients — base weights stay frozen
//  in 4-bit quantized form.
//
//  AI-NATIVE:
//    @pure math kernels
//    @memoize codebook + scale constants
// ═══════════════════════════════════════════════════════════

// ── NF4 codebook: 16 levels from normal distribution quantiles ──
// These are the exact NF4 quantile levels for a standard normal
// distribution, symmetric around zero.
fn nf4_codebook() {
    return [
        -1.0, -0.6962, -0.5251, -0.3949,
        -0.2844, -0.1848, -0.0911, 0.0,
        0.0796, 0.1609, 0.2461, 0.3379,
        0.4407, 0.5626, 0.7230, 1.0
    ]
}

// ── nearest codebook index ──────────────────────────────────
@pure
fn nearest_nf4(x, book) {
    let mut best = 0
    let mut bestd = 1000000.0
    let mut k = 0

    while k < 16 {
        let d = x - book[k]
        let dd = if d < 0.0 { 0.0 - d } else { d }
        if dd < bestd {
            bestd = dd
            best = k
        }
    }
    return best
}

// ── absmax of a slice ───────────────────────────────────────
@pure
fn block_absmax(arr, start, count) {
    let mut m = 0.0
    let mut i = 0

    while i < count {
        let v = arr[start + i]
        let a = if v < 0.0 { 0.0 - v } else { v }
        if a > m { m = a }
    }
    if m < 0.000001 { m = 0.000001 }
    return m
}

// ═══════════════════════════════════════════════════════════
//  1. quantize_nf4(weights) -> dict
//     Block-wise NF4 quantization with block_size=64
//     Returns: {"quant": [int], "scales": [float], "block_size": 64}
// ═══════════════════════════════════════════════════════════
fn quantize_nf4(weights) {
    let book = nf4_codebook()
    let n = len(weights)
    let bs = 64
    let num_blocks = (n + bs - 1) / bs

    let mut quant = []
    let mut scales = []

    let mut blk = 0


    while blk < num_blocks {
        let start = blk * bs
        let mut count = bs
        if start + count > n { count = n - start }

        let scale = block_absmax(weights, start, count)
        scales.push(scale)

        let mut i = 0


        while i < count {
            let norm = weights[start + i] / scale
            let idx = nearest_nf4(norm, book)
            quant.push(idx)
        }
    }

    return #{"quant": quant, "scales": scales, "block_size": bs}
}

// ═══════════════════════════════════════════════════════════
//  2. dequantize_nf4(qw) -> [float]
//     Restore approximate float weights from NF4 dict
// ═══════════════════════════════════════════════════════════
fn dequantize_nf4(qw) {
    let book = nf4_codebook()
    let quant = qw["quant"]
    let scales = qw["scales"]
    let bs = qw["block_size"]
    let n = len(quant)

    let mut out = []
    let mut i = 0

    while i < n {
        let blk = i / bs
        let scale = scales[blk]
        let val = book[quant[i]] * scale
        out.push(val)
    }
    return out
}

// ── helper: matvec y[m] = W[m][n] @ x[n] ───────────────────
@pure
fn q_matvec(w, x, m, n) {
    let mut y = []
    let mut i = 0

    while i < m {
        let mut s = 0.0
        let mut j = 0

        while j < n {
            s = s + w[i][j] * x[j]
        }
        y.push(s)
    }
    return y
}

// ── helper: zeros 1D ────────────────────────────────────────
fn zeros1(n) {
    let mut v = []
    let mut i = 0

    while i < n { v.push(0.0) }
    return v
}

// ── helper: zeros 2D ────────────────────────────────────────
fn zeros2(m, n) {
    let mut r = []
    let mut i = 0

    while i < m { r.push(zeros1(n)) }
    return r
}

// ── helper: small random init via LCG ───────────────────────
fn lcg_init(m, n, seed) {
    let mut s = seed
    let mut r = []
    let mut i = 0

    while i < m {
        let mut row = []
        let mut j = 0

        while j < n {
            s = (s * 1103515245 + 12345) % 2147483647
            let v = (to_float(s % 2000) - 1000.0) / 10000.0
            row.push(v)
        }
        r.push(row)
    }
    return r
}

// ── helper: flatten 2D matrix row-major ─────────────────────
fn mat_to_flat(w, m, n) {
    let mut out = []
    let mut i = 0

    while i < m {
        let mut j = 0

        while j < n {
            out.push(w[i][j])
        }
    }
    return out
}

// ── helper: unflatten to 2D matrix ──────────────────────────
fn flat_to_mat(flat, m, n) {
    let mut out = []
    let mut i = 0

    while i < m {
        let mut row = []
        let mut j = 0

        while j < n {
            row.push(flat[i * n + j])
        }
        out.push(row)
    }
    return out
}

// ═══════════════════════════════════════════════════════════
//  3. qlora_layer_new(in_dim, out_dim, rank) -> dict
//     Frozen NF4 base weights + trainable LoRA A, B
// ═══════════════════════════════════════════════════════════
fn qlora_layer_new(in_dim, out_dim, rank) {
    // Generate random base weights then quantize to NF4
    let w_float = lcg_init(out_dim, in_dim, 42)
    let w_flat = mat_to_flat(w_float, out_dim, in_dim)
    let base_nf4 = quantize_nf4(w_flat)

    // LoRA A: [rank, in_dim] — zero init (residual starts at 0)
    let lora_a = zeros2(rank, in_dim)
    // LoRA B: [out_dim, rank] — small random init
    let lora_b = lcg_init(out_dim, rank, 7777)
    // scale = alpha / rank (alpha = rank by default so scale = 1.0)
    let alpha = to_float(rank)
    let scale = alpha / to_float(rank)

    return #{
        "in_dim": in_dim,
        "out_dim": out_dim,
        "rank": rank,
        "base_nf4": base_nf4,
        "lora_a": lora_a,
        "lora_b": lora_b,
        "scale": scale,
        "alpha": alpha
    }
}

// ═══════════════════════════════════════════════════════════
//  4. qlora_forward(layer, input) -> [float]
//     output = dequant(base) @ input + scale * (B @ (A @ input))
// ═══════════════════════════════════════════════════════════
fn qlora_forward(layer, input) {
    let in_dim = layer["in_dim"]
    let out_dim = layer["out_dim"]
    let rank = layer["rank"]
    let scale = layer["scale"]

    // Dequantize base weights and reshape to [out_dim, in_dim]
    let base_flat = dequantize_nf4(layer["base_nf4"])
    let base_w = flat_to_mat(base_flat, out_dim, in_dim)

    // base_out = base_w @ input
    let base_out = q_matvec(base_w, input, out_dim, in_dim)

    // LoRA path: A @ input -> [rank], then B @ that -> [out_dim]
    let ax = q_matvec(layer["lora_a"], input, rank, in_dim)
    let bax = q_matvec(layer["lora_b"], ax, out_dim, rank)

    // Combine: base + scale * lora
    let mut y = []
    let mut i = 0

    while i < out_dim {
        y.push(base_out[i] + scale * bax[i])
    }
    return y
}

// ═══════════════════════════════════════════════════════════
//  5. qlora_backward(layer, grad, input) -> dict
//     Only compute gradients for A and B (base is frozen)
//     grad_B[i][p] = scale * grad[i] * (A @ input)[p]
//     grad_A[p][j] = scale * (B^T @ grad)[p] * input[j]
//     Returns: {"grad_a": [[float]], "grad_b": [[float]]}
// ═══════════════════════════════════════════════════════════
fn qlora_backward(layer, grad, input) {
    let in_dim = layer["in_dim"]
    let out_dim = layer["out_dim"]
    let rank = layer["rank"]
    let scale = layer["scale"]
    let lora_a = layer["lora_a"]
    let lora_b = layer["lora_b"]

    // A @ input -> [rank]
    let ax = q_matvec(lora_a, input, rank, in_dim)

    // B^T @ grad -> [rank]
    let mut bt_grad = []
    let mut p = 0

    while p < rank {
        let mut acc = 0.0
        let mut i = 0

        while i < out_dim {
            acc = acc + lora_b[i][p] * grad[i]
        }
        bt_grad.push(acc)
    }

    // grad_B[i][p] = scale * grad[i] * ax[p]
    let mut grad_b = []
    let mut i = 0

    while i < out_dim {
        let mut row = []
        let mut p = 0

        while p < rank {
            row.push(scale * grad[i] * ax[p])
        }
        grad_b.push(row)
    }

    // grad_A[p][j] = scale * bt_grad[p] * input[j]
    let mut grad_a = []
    let mut p = 0

    while p < rank {
        let mut row = []
        let mut j = 0

        while j < in_dim {
            row.push(scale * bt_grad[p] * input[j])
        }
        grad_a.push(row)
    }

    return #{"grad_a": grad_a, "grad_b": grad_b}
}

// ── SGD update for 2D matrix ────────────────────────────────
@pure
fn sgd_update_2d(w, g, lr, m, n) {
    let mut out = []
    let mut i = 0

    while i < m {
        let mut row = []
        let mut j = 0

        while j < n {
            row.push(w[i][j] - lr * g[i][j])
        }
        out.push(row)
    }
    return out
}

// ── qlora_step: apply gradients to A and B only ─────────────
fn qlora_step(layer, grads, lr) {
    let rank = layer["rank"]
    let in_dim = layer["in_dim"]
    let out_dim = layer["out_dim"]

    let new_a = sgd_update_2d(layer["lora_a"], grads["grad_a"], lr, rank, in_dim)
    let new_b = sgd_update_2d(layer["lora_b"], grads["grad_b"], lr, out_dim, rank)

    return #{
        "in_dim": in_dim,
        "out_dim": out_dim,
        "rank": rank,
        "base_nf4": layer["base_nf4"],
        "lora_a": new_a,
        "lora_b": new_b,
        "scale": layer["scale"],
        "alpha": layer["alpha"]
    }
}

// ── quantization error metric ───────────────────────────────
fn quant_error(original, restored) {
    let n = len(original)
    let mut sum_sq_err = 0.0
    let mut sum_sq_orig = 0.0
    let mut i = 0

    while i < n {
        let d = original[i] - restored[i]
        sum_sq_err = sum_sq_err + d * d
        sum_sq_orig = sum_sq_orig + original[i] * original[i]
    }
    if sum_sq_orig < 0.000001 { return 0.0 }
    return sqrt(sum_sq_err / sum_sq_orig)
}


// ── end inlined ──────────────────────────────

let mut passed = 0
let mut failed = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        passed = passed + 1
    } else {
        println("[FAIL] " + name)
        failed = failed + 1
    }
}

// ── Test 1: NF4 quantize/dequantize round-trip error < 10% ──
fn test_roundtrip() {
    // Generate test weights using LCG
    let mut weights = []
    let mut s = 12345
    let mut i = 0

    while i < 256 {
        s = (s * 1103515245 + 12345) % 2147483647
        let v = (to_float(s % 20000) - 10000.0) / 10000.0
        weights.push(v)
    }

    let qw = quantize_nf4(weights)
    let restored = dequantize_nf4(qw)

    // Check lengths match
    check("roundtrip: lengths match", len(restored) == len(weights))

    // Relative error: sqrt(sum((orig-rest)^2) / sum(orig^2))
    let err = quant_error(weights, restored)
    println("  NF4 relative error: " + to_string(err))
    check("roundtrip: error < 10%", err < 0.1)

    // Check block_size is 64
    check("roundtrip: block_size=64", qw["block_size"] == 64)

    // Check scales count
    let expected_blocks = (256 + 63) / 64
    check("roundtrip: scales count", len(qw["scales"]) == expected_blocks)
}

// ── Test 2: qlora_forward produces correct output dimensions ──
fn test_forward_dims() {
    let in_dim = 8
    let out_dim = 4
    let rank = 2
    let layer = qlora_layer_new(in_dim, out_dim, rank)

    // Create input vector
    let mut input = []
    let mut i = 0

    while i < in_dim { input.push(1.0) }

    let output = qlora_forward(layer, input)
    check("forward: output length == out_dim", len(output) == out_dim)

    // Output should be finite (not NaN or huge)
    let mut all_finite = true
    let mut i = 0

    while i < out_dim {
        let v = output[i]
        if v > 1000000.0 { all_finite = false }
        if v < -1000000.0 { all_finite = false }
    }
    check("forward: output values finite", all_finite)
}

// ── Test 3: with A=0, LoRA residual is zero ─────────────────
fn test_lora_zero_init() {
    let in_dim = 8
    let out_dim = 4
    let rank = 2
    let layer = qlora_layer_new(in_dim, out_dim, rank)

    // A is zero-initialized, so LoRA branch should be zero
    // Forward with and without LoRA should give same result
    let mut input = []
    let mut i = 0

    while i < in_dim { input.push(0.5) }

    let y = qlora_forward(layer, input)

    // Compute base-only output for comparison
    let base_flat = dequantize_nf4(layer["base_nf4"])
    let mut base_only = []
    let mut i = 0

    while i < out_dim {
        let mut s = 0.0
        let mut j = 0

        while j < in_dim {
            s = s + base_flat[i * in_dim + j] * input[j]
        }
        base_only.push(s)
    }

    // Should be identical since A=0
    let mut max_diff = 0.0
    let mut i = 0

    while i < out_dim {
        let d = y[i] - base_only[i]
        let ad = if d < 0.0 { 0.0 - d } else { d }
        if ad > max_diff { max_diff = ad }
    }
    println("  A=0 max_diff: " + to_string(max_diff))
    check("zero_init: LoRA residual is zero when A=0", max_diff < 0.0001)
}

// ── Test 4: backward only produces gradients for A and B ────
fn test_backward_frozen() {
    let in_dim = 8
    let out_dim = 4
    let rank = 2
    let layer = qlora_layer_new(in_dim, out_dim, rank)

    let mut input = []
    let mut i = 0

    while i < in_dim { input.push(0.3 + to_float(i) * 0.1) }

    // Fake gradient from upstream
    let mut grad = []
    let mut i = 0

    while i < out_dim { grad.push(1.0) }

    let grads = qlora_backward(layer, grad, input)

    // Check grad_a dimensions: [rank, in_dim]
    check("backward: grad_a rows == rank", len(grads["grad_a"]) == rank)
    check("backward: grad_a cols == in_dim", len(grads["grad_a"][0]) == in_dim)

    // Check grad_b dimensions: [out_dim, rank]
    check("backward: grad_b rows == out_dim", len(grads["grad_b"]) == out_dim)
    check("backward: grad_b cols == rank", len(grads["grad_b"][0]) == rank)

    // No grad for base weights — dict has only grad_a and grad_b
    let has_base_grad = has_key(grads, "grad_base")
    check("backward: no grad for base (frozen)", has_base_grad == false)
}

// ── Test 5: qlora_step updates A/B, base stays frozen ───────
fn test_step_updates() {
    let in_dim = 8
    let out_dim = 4
    let rank = 2
    let layer = qlora_layer_new(in_dim, out_dim, rank)

    let mut input = []
    let mut i = 0

    while i < in_dim { input.push(1.0) }

    // Do a forward/backward/step cycle
    let y = qlora_forward(layer, input)
    let mut grad = []
    let mut i = 0

    while i < out_dim { grad.push(y[i]) }

    let grads = qlora_backward(layer, grad, input)
    let updated = qlora_step(layer, grads, 0.01)

    // Base NF4 should be identical
    let orig_q = layer["base_nf4"]["quant"]
    let new_q = updated["base_nf4"]["quant"]
    let mut base_same = true
    let mut i = 0

    while i < len(orig_q) {
        if orig_q[i] != new_q[i] { base_same = false }
    }
    check("step: base NF4 unchanged after update", base_same)

    // A should have changed (grad was non-zero because B is nonzero and input nonzero)
    // Actually A starts at zero and grad_a depends on B^T @ grad * input
    // B is random, grad is nonzero, input is nonzero -> grad_a nonzero -> A changes
    let mut a_changed = false
    let mut p = 0

    while p < rank {
        let mut j = 0

        while j < in_dim {
            if updated["lora_a"][p][j] != layer["lora_a"][p][j] {
                a_changed = true
            }
        }
    }
    check("step: lora_a updated", a_changed)
}

// ── Test 6: quantize edge cases ─────────────────────────────
fn test_edge_cases() {
    // All zeros
    let mut zeros = []
    let mut i = 0

    while i < 128 { zeros.push(0.0) }
    let qz = quantize_nf4(zeros)
    let dz = dequantize_nf4(qz)
    let mut max_z = 0.0
    let mut i = 0

    while i < 128 {
        let a = if dz[i] < 0.0 { 0.0 - dz[i] } else { dz[i] }
        if a > max_z { max_z = a }
    }
    check("edge: zeros roundtrip near zero", max_z < 0.001)

    // Non-multiple-of-64 length
    let mut odd = []
    let mut i = 0

    while i < 100 { odd.push(to_float(i) / 100.0) }
    let qo = quantize_nf4(odd)
    let do2 = dequantize_nf4(qo)
    check("edge: non-64-multiple length preserved", len(do2) == 100)
}

// ── Run all tests ───────────────────────────────────────────
println("=== QLoRA Tests ===")
test_roundtrip()
test_forward_dims()
test_lora_zero_init()
test_backward_frozen()
test_step_updates()
test_edge_cases()

println("")
println("Results: " + to_string(passed) + " passed, " + to_string(failed) + " failed")
if failed > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
