// self/test_lru_pure.hexa -- Tests for self/runtime/lru_pure.hexa

// ── inlined from self/runtime/lru_pure.hexa ────────────────────
// codegen_c2 import/use resolution for runtime/*_pure.hexa is not wired
// for test files; inline the module contents (same pattern as test_rle_pure).

// Dict-based LRU to avoid nested-array codegen flattening
fn lru_new(capacity) {
    let mut c = #{}
    c["k"] = []
    c["v"] = []
    c["cap"] = capacity
    return c
}

fn _lru_find(keys, key) {
    let mut i = 0
    while i < len(keys) {
        if to_string(keys[i]) == to_string(key) { return i }
        i = i + 1
    }
    -1
}

fn _lru_remove_at(arr, idx) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        if i != idx {
            out.push(arr[i])
        }
        i = i + 1
    }
    out
}

fn _lru_make(keys, vals, cap) {
    let mut c = #{}
    c["k"] = keys
    c["v"] = vals
    c["cap"] = cap
    return c
}

fn lru_get(cache, key) {
    let keys = cache["k"]
    let vals = cache["v"]
    let cap = cache["cap"]
    let idx = _lru_find(keys, key)
    if idx == -1 {
        let mut r = #{}
        r["cache"] = cache
        r["val"] = nil
        return r
    }
    let val = vals[idx]
    let new_keys = _lru_remove_at(keys, idx).push(keys[idx])
    let new_vals = _lru_remove_at(vals, idx).push(val)
    let mut r = #{}
    r["cache"] = _lru_make(new_keys, new_vals, cap)
    r["val"] = val
    return r
}

fn lru_put(cache, key, val) {
    let keys = cache["k"]
    let vals = cache["v"]
    let cap = cache["cap"]
    let idx = _lru_find(keys, key)
    if idx != -1 {
        let k2 = _lru_remove_at(keys, idx).push(key)
        let v2 = _lru_remove_at(vals, idx).push(val)
        return _lru_make(k2, v2, cap)
    }
    let mut k = keys
    let mut v = vals
    if len(k) >= cap {
        k = _lru_remove_at(k, 0)
        v = _lru_remove_at(v, 0)
    }
    k.push(key)
    v.push(val)
    return _lru_make(k, v, cap)
}

fn lru_size(cache) {
    len(cache["k"])
}

fn lru_keys(cache) {
    cache["k"]
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn arrays_equal(a, b) {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if to_string(a[i]) != to_string(b[i]) { return false }
        i = i + 1
    }
    true
}

println("═══════════════════════════════════════════════════════")
println("  lru_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── new cache ──────────────────────────────────────────────────
println("")
println("--- lru_new ---")
let mut c0 = nil
c0 = lru_new(3)
check("new size", lru_size(c0), 0)

// ── put and get ────────────────────────────────────────────────
println("")
println("--- put and get ---")
let mut pc = nil
pc = lru_new(3)
pc = lru_put(pc, "a", 10)
check("put a size", lru_size(pc), 1)
let mut r1 = nil
r1 = lru_get(pc, "a")
check("get a val", r1["val"], 10)

pc = lru_put(pc, "b", 20)
pc = lru_put(pc, "c", 30)
check("put 3 size", lru_size(pc), 3)

let mut r2 = nil
r2 = lru_get(pc, "b")
check("get b val", r2["val"], 20)
let mut r3 = nil
r3 = lru_get(pc, "c")
check("get c val", r3["val"], 30)

// ── miss ───────────────────────────────────────────────────────
println("")
println("--- miss ---")
let mut r_miss = nil
r_miss = lru_get(pc, "z")
check("miss val", r_miss["val"], nil)

// ── eviction (LRU) ─────────────────────────────────────────────
println("")
println("--- eviction (LRU) ---")
// pc has a, b, c — order: a(oldest), b, c(newest)
// insert d -> evicts a (LRU)
let mut ec = nil
ec = lru_new(3)
ec = lru_put(ec, "a", 10)
ec = lru_put(ec, "b", 20)
ec = lru_put(ec, "c", 30)
ec = lru_put(ec, "d", 40)
check("after evict size", lru_size(ec), 3)
let mut r_d = nil
r_d = lru_get(ec, "d")
check("get d val", r_d["val"], 40)
let mut r_a_evicted = nil
r_a_evicted = lru_get(ec, "a")
check("a evicted", r_a_evicted["val"], nil)
let mut r_b_still = nil
r_b_still = lru_get(ec, "b")
check("b still present", r_b_still["val"], 20)

// ── access refreshes recency ───────────────────────────────────
println("")
println("--- access refreshes recency ---")
// Build fresh: b, c, d in cache (cap 3)
let mut rc = nil
rc = lru_new(3)
rc = lru_put(rc, "b", 20)
rc = lru_put(rc, "c", 30)
rc = lru_put(rc, "d", 40)
// get b -> moves b to most recent: c, d, b
let mut tmp_b = nil
tmp_b = lru_get(rc, "b")
rc = tmp_b["cache"]
// insert e -> evicts c (now LRU), not b
rc = lru_put(rc, "e", 50)
let mut r_c_gone = nil
r_c_gone = lru_get(rc, "c")
check("c evicted after b refresh", r_c_gone["val"], nil)
let mut r_b_kept = nil
r_b_kept = lru_get(rc, "b")
check("b kept after refresh", r_b_kept["val"], 20)

// ── update existing ────────────────────────────────────────────
println("")
println("--- update existing ---")
let mut uc = nil
uc = lru_new(2)
uc = lru_put(uc, "x", 100)
uc = lru_put(uc, "x", 200)
check("update size", lru_size(uc), 1)
let mut r_upd = nil
r_upd = lru_get(uc, "x")
check("update val", r_upd["val"], 200)

// ── capacity 1 ─────────────────────────────────────────────────
println("")
println("--- capacity 1 ---")
let mut tc = nil
tc = lru_new(1)
tc = lru_put(tc, "p", 1)
tc = lru_put(tc, "q", 2)
check("cap1 size", lru_size(tc), 1)
let mut rt1 = nil
rt1 = lru_get(tc, "q")
check("cap1 has q", rt1["val"], 2)
let mut rt2 = nil
rt2 = lru_get(tc, "p")
check("cap1 p evicted", rt2["val"], nil)

// ── lru_keys ───────────────────────────────────────────────────
println("")
println("--- lru_keys ---")
let mut kc = nil
kc = lru_new(3)
kc = lru_put(kc, "x", 1)
kc = lru_put(kc, "y", 2)
kc = lru_put(kc, "z", 3)
check("keys len", len(lru_keys(kc)), 3)

// ── Summary ────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
