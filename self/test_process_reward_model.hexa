// ===================================================================
//  test_process_reward_model.hexa — Process Reward Model (#222)
//
//  Tests (35):
//    #1  prm_sigmoid(0) ~ 0.5
//    #2  prm_sigmoid bounds [0,1] for extremes
//    #3  prm_log_safe(0) bounded (no -inf)
//    #4  prm_log_safe(1) ~ 0
//    #5  prm_create_scorer dim correct
//    #6  prm_create_scorer bias starts at 0
//    #7  prm_score_step in (0, 1)
//    #8  prm_score_step deterministic
//    #9  prm_score_trajectory length == n_steps
//    #10 prm_score_trajectory all in (0,1)
//    #11 prm_aggregate_min picks smallest
//    #12 prm_aggregate_min single step = score
//    #13 prm_aggregate_product correct
//    #14 prm_aggregate_product range [0,1]
//    #15 prm_aggregate_min_last formula
//    #16 prm_aggregate_min_last single step = score
//    #17 prm_aggregate_weighted uniform = average
//    #18 prm_aggregate_weighted custom weights
//    #19 prm_beam_search_step ≤ beam_size
//    #20 prm_beam_search_step preserves indices from candidates
//    #21 prm_beam_search_step beam_size > n returns all
//    #22 prm_beam_search_step beam_size 1 returns best
//    #23 prm_bce_loss ≥ 0
//    #24 prm_bce_loss zero for correct prediction (p≈1, y=1)
//    #25 prm_bce_loss zero for correct prediction (p≈0, y=0)
//    #26 prm_bce_loss large for wrong prediction
//    #27 prm_train_step changes W
//    #28 prm_train_step decreases loss for one example
//    #29 prm_train_step bias updates
//    #30 prm_eval_trajectory returns scalar in [0,1]
//    #31 prm_eval_trajectory matches min_last(scores)
//    #32 prm_compare_trajectories returns 0 or 1
//    #33 prm_compare_trajectories better-traj wins
//    #34 constant score trajectory: min == product == avg == score
//    #35 prm_score_trajectory empty list = []
//
//  Run: PATH=$HOME/.cargo/bin:$PATH ./hexa self/test_process_reward_model.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(idx, name, cond) {
    if cond {
        println("[PASS] #" + str(idx) + " " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] #" + str(idx) + " " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ===================================================================
//  Inlined PRM implementation (mirrors self/ml/process_reward_model.hexa)
// ===================================================================

fn prm_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn prm_max(a, b) {
    if a > b { return a }
    return b
}

fn prm_min(a, b) {
    if a < b { return a }
    return b
}

fn prm_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1

    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn prm_log_safe(x) {
    if x <= 1.0e-12 { return -30.0 }
    let mut y = 0.0
    let t = (x - 1.0) / (x + 1.0)
    let t2 = t * t
    let mut term = t
    let mut i = 0

    while i < 15 {
        y = y + term / to_float(2 * i + 1)
        term = term * t2
    }
    return 2.0 * y
}

fn prm_sigmoid(x) {
    if x > 20.0 { return 1.0 }
    if x < -20.0 { return 0.0 }
    return 1.0 / (1.0 + prm_exp(0.0 - x))
}

fn prm_zeros(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

fn prm_ones(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [1.0] }
    return v
}

fn prm_init_vec(dim, seed) {
    let mut v = []
    let mut i = 0

    while i < dim {
        let h = (i * 251 + seed * 6173) % 10007
        let val = (to_float(h) / 10007.0 - 0.5) * 0.2
        v = v + [val]
    }
    return v
}

fn prm_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    let mut i = 0

    while i < n { s = s + a[i] * b[i] }
    return s
}

fn prm_create_scorer(dim) {
    let W = prm_init_vec(dim, 1337)
    let b = [0.0]
    return [W, b]
}

fn prm_score_step(scorer, hidden, dim) {
    let W = scorer[0]
    let b = scorer[1]
    let logit = prm_dot(W, hidden) + b[0]
    return prm_sigmoid(logit)
}

fn prm_score_trajectory(scorer, hidden_steps, n_steps, dim) {
    let mut scores = []
    let mut i = 0

    while i < n_steps {
        scores = scores + [prm_score_step(scorer, hidden_steps[i], dim)]
    }
    return scores
}

fn prm_aggregate_min(scores, n) {
    if n == 0 { return 0.0 }
    let mut m = scores[0]
    let mut i = 1

    while i < n {
        if scores[i] < m { m = scores[i] }
    }
    return m
}

fn prm_aggregate_product(scores, n) {
    if n == 0 { return 0.0 }
    let mut p = 1.0
    let mut i = 0

    while i < n { p = p * scores[i] }
    return p
}

fn prm_aggregate_min_last(scores, n) {
    if n == 0 { return 0.0 }
    let m = prm_aggregate_min(scores, n)
    let last = scores[n - 1]
    return (m + last) / 2.0
}

fn prm_aggregate_weighted(scores, weights, n) {
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0

    while i < n { s = s + scores[i] * weights[i] }
    return s
}

fn prm_beam_search_step(prm_scorer, candidates, hidden_states, dim, beam_size) {
    let n = len(candidates)
    if n == 0 { return [] }
    let mut scores = []
    let mut i = 0

    while i < n {
        scores = scores + [prm_score_step(prm_scorer, hidden_states[i], dim)]
    }
    let k = if beam_size < n { beam_size } else { n }
    let mut taken = []
    let mut _u = 0

    while _u < n { taken = taken + [false] }
    let mut top = []
    let mut _u = 0

    while _u < k {
        let mut best_idx = -1
        let mut best_val = -1.0
        let mut j = 0

        while j < n {
            if taken[j] == false {
                if scores[j] > best_val {
                    best_val = scores[j]
                    best_idx = j
                }
            }
        }
        if best_idx >= 0 {
            top = top + [candidates[best_idx]]
            taken[best_idx] = true
        }
    }
    return top
}

fn prm_bce_loss(score, label) {
    let p = score
    let y = label
    let one_m_p = 1.0 - p
    let term1 = y * prm_log_safe(p)
    let term2 = (1.0 - y) * prm_log_safe(one_m_p)
    let loss = 0.0 - (term1 + term2)
    if loss < 0.0 { return 0.0 }
    return loss
}

fn prm_train_step(scorer, hidden, label, dim, lr) {
    let W = scorer[0]
    let b = scorer[1]
    let p = prm_score_step(scorer, hidden, dim)
    let diff = p - label
    let mut new_W = []
    let mut i = 0

    while i < dim {
        new_W = new_W + [W[i] - lr * diff * hidden[i]]
    }
    let new_b = [b[0] - lr * diff]
    return [new_W, new_b]
}

fn prm_eval_trajectory(scorer, trajectory, n_steps, dim) {
    let scores = prm_score_trajectory(scorer, trajectory, n_steps, dim)
    return prm_aggregate_min_last(scores, n_steps)
}

fn prm_compare_trajectories(scorer, traj_a, traj_b, n_steps_a, n_steps_b, dim) {
    let qa = prm_eval_trajectory(scorer, traj_a, n_steps_a, dim)
    let qb = prm_eval_trajectory(scorer, traj_b, n_steps_b, dim)
    if qa >= qb { return 0 }
    return 1
}

// ===================================================================
//  TESTS
// ===================================================================

println("=== Process Reward Model (#222) Tests ===")

let DIM = 6

// ── #1 sigmoid(0) ~ 0.5
check(1, "prm_sigmoid(0) ~ 0.5", approx(prm_sigmoid(0.0), 0.5, 0.01))

// ── #2 sigmoid bounds
let s_pos = prm_sigmoid(50.0)
let s_neg = prm_sigmoid(-50.0)
check(2, "prm_sigmoid bounds [0,1]", s_pos <= 1.0 && s_pos >= 0.99 && s_neg >= 0.0 && s_neg <= 0.01)

// ── #3 log_safe(0) bounded (no -inf)
let log_zero = prm_log_safe(0.0)
check(3, "prm_log_safe(0) bounded", log_zero > -100.0 && log_zero < 0.0)

// ── #4 log_safe(1) ~ 0
check(4, "prm_log_safe(1) ~ 0", approx(prm_log_safe(1.0), 0.0, 0.001))

// ── #5 create_scorer dim
let scorer = prm_create_scorer(DIM)
let W0 = scorer[0]
check(5, "prm_create_scorer W has dim entries", len(W0) == DIM)

// ── #6 create_scorer bias zero
let b0 = scorer[1]
check(6, "prm_create_scorer bias = 0", approx(b0[0], 0.0, 1.0e-9))

// ── #7 score_step in (0,1)
let h_one = [0.1, -0.2, 0.3, 0.4, -0.1, 0.2]
let s1 = prm_score_step(scorer, h_one, DIM)
check(7, "prm_score_step in (0,1)", s1 > 0.0 && s1 < 1.0)

// ── #8 score_step deterministic
let s1b = prm_score_step(scorer, h_one, DIM)
check(8, "prm_score_step deterministic", approx(s1, s1b, 1.0e-9))

// ── #9 score_trajectory length
let h_a = [0.1, -0.2, 0.3, 0.4, -0.1, 0.2]
let h_b = [-0.1, 0.2, -0.3, 0.1, 0.2, 0.0]
let h_c = [0.05, 0.05, 0.1, -0.1, 0.0, 0.3]
let h_d = [-0.2, -0.1, 0.2, 0.1, -0.05, 0.15]
let traj4 = [h_a, h_b, h_c, h_d]
let scores4 = prm_score_trajectory(scorer, traj4, 4, DIM)
check(9, "prm_score_trajectory length == n_steps", len(scores4) == 4)

// ── #10 trajectory all in (0,1)
let mut all_in_range = true
let mut i = 0

while i < 4 {
    if scores4[i] <= 0.0 || scores4[i] >= 1.0 { all_in_range = false }
}
check(10, "prm_score_trajectory all in (0,1)", all_in_range)

// ── #11 aggregate_min picks smallest
let demo = [0.8, 0.5, 0.9, 0.3, 0.7]
check(11, "prm_aggregate_min picks smallest", approx(prm_aggregate_min(demo, 5), 0.3, 1.0e-9))

// ── #12 aggregate_min single step
let one_score = [0.42]
check(12, "prm_aggregate_min single step", approx(prm_aggregate_min(one_score, 1), 0.42, 1.0e-9))

// ── #13 aggregate_product correct
let demo2 = [0.5, 0.5, 0.5]
check(13, "prm_aggregate_product = 0.125", approx(prm_aggregate_product(demo2, 3), 0.125, 1.0e-6))

// ── #14 aggregate_product in [0,1] (each in [0,1])
let prod = prm_aggregate_product(demo, 5)
check(14, "prm_aggregate_product in [0,1]", prod >= 0.0 && prod <= 1.0)

// ── #15 aggregate_min_last formula
// demo = [0.8, 0.5, 0.9, 0.3, 0.7]; min=0.3 last=0.7 -> (0.3+0.7)/2 = 0.5
check(15, "prm_aggregate_min_last (0.3+0.7)/2 = 0.5", approx(prm_aggregate_min_last(demo, 5), 0.5, 1.0e-6))

// ── #16 aggregate_min_last single step
check(16, "prm_aggregate_min_last single step", approx(prm_aggregate_min_last(one_score, 1), 0.42, 1.0e-9))

// ── #17 aggregate_weighted uniform = average
let demo3 = [0.2, 0.4, 0.6, 0.8]
let uniform_w = [0.25, 0.25, 0.25, 0.25]
let avg_demo = (0.2 + 0.4 + 0.6 + 0.8) / 4.0
check(17, "prm_aggregate_weighted uniform = average", approx(prm_aggregate_weighted(demo3, uniform_w, 4), avg_demo, 1.0e-6))

// ── #18 aggregate_weighted custom weights
let custom_w = [0.5, 0.0, 0.0, 0.5]
// 0.2*0.5 + 0.8*0.5 = 0.5
check(18, "prm_aggregate_weighted custom weights", approx(prm_aggregate_weighted(demo3, custom_w, 4), 0.5, 1.0e-6))

// ── #19 beam_search_step ≤ beam_size
let cand = [10, 11, 12, 13, 14]
let h_states = [h_a, h_b, h_c, h_d, h_a]
let beam = prm_beam_search_step(scorer, cand, h_states, DIM, 3)
check(19, "prm_beam_search_step ≤ beam_size", len(beam) <= 3)

// ── #20 beam preserves indices from candidates
let mut all_in_cand = true
let mut i = 0

while i < len(beam) {
    let mut found = false
    let mut j = 0

    while j < 5 {
        if beam[i] == cand[j] { found = true }
    }
    if found == false { all_in_cand = false }
}
check(20, "prm_beam_search_step indices in candidates", all_in_cand)

// ── #21 beam_size > n returns all n
let beam_big = prm_beam_search_step(scorer, cand, h_states, DIM, 10)
check(21, "prm_beam_search_step beam_size>n returns all", len(beam_big) == 5)

// ── #22 beam_size 1 returns best
let beam1 = prm_beam_search_step(scorer, cand, h_states, DIM, 1)
// verify it's the highest scoring candidate
let mut best_score = -1.0
let mut best_idx = 0
let mut i = 0

while i < 5 {
    let sc = prm_score_step(scorer, h_states[i], DIM)
    if sc > best_score {
        best_score = sc
        best_idx = i
    }
}
check(22, "prm_beam_search_step beam=1 picks best", len(beam1) == 1 && beam1[0] == cand[best_idx])

// ── #23 BCE loss ≥ 0
let bce1 = prm_bce_loss(0.7, 1.0)
let bce2 = prm_bce_loss(0.3, 0.0)
let bce3 = prm_bce_loss(0.5, 1.0)
check(23, "prm_bce_loss ≥ 0", bce1 >= 0.0 && bce2 >= 0.0 && bce3 >= 0.0)

// ── #24 BCE near zero for correct (p≈1, y=1)
let bce_correct = prm_bce_loss(0.9999, 1.0)
check(24, "prm_bce_loss near 0 for p≈1 y=1", bce_correct < 0.01)

// ── #25 BCE near zero for correct (p≈0, y=0)
let bce_correct0 = prm_bce_loss(0.0001, 0.0)
check(25, "prm_bce_loss near 0 for p≈0 y=0", bce_correct0 < 0.01)

// ── #26 BCE large for wrong prediction
let bce_wrong = prm_bce_loss(0.0001, 1.0)
check(26, "prm_bce_loss large for wrong prediction", bce_wrong > 1.0)

// ── #27 train_step changes W
let scorer2 = prm_train_step(scorer, h_one, 1.0, DIM, 0.5)
let W_new = scorer2[0]
let mut any_changed = false
let mut i = 0

while i < DIM {
    if fabs(W_new[i] - W0[i]) > 1.0e-9 { any_changed = true }
}
check(27, "prm_train_step changes W", any_changed)

// ── #28 train_step decreases loss for one example
let p_before = prm_score_step(scorer, h_one, DIM)
let loss_before = prm_bce_loss(p_before, 1.0)
let mut sc_iter = scorer
let mut _step = 0

while _step < 20 {
    sc_iter = prm_train_step(sc_iter, h_one, 1.0, DIM, 0.5)
}
let p_after = prm_score_step(sc_iter, h_one, DIM)
let loss_after = prm_bce_loss(p_after, 1.0)
check(28, "prm_train_step decreases loss", loss_after < loss_before)

// ── #29 train_step updates bias
let scorer3 = prm_train_step(scorer, h_one, 1.0, DIM, 0.5)
let b_new = scorer3[1]
check(29, "prm_train_step updates bias", fabs(b_new[0] - 0.0) > 1.0e-9)

// ── #30 eval_trajectory returns scalar in [0,1]
let q = prm_eval_trajectory(scorer, traj4, 4, DIM)
check(30, "prm_eval_trajectory in [0,1]", q >= 0.0 && q <= 1.0)

// ── #31 eval_trajectory matches min_last(scores)
let s_t = prm_score_trajectory(scorer, traj4, 4, DIM)
let q_ref = prm_aggregate_min_last(s_t, 4)
check(31, "prm_eval_trajectory == min_last", approx(q, q_ref, 1.0e-9))

// ── #32 compare_trajectories returns 0 or 1
let cmp = prm_compare_trajectories(scorer, traj4, traj4, 4, 4, DIM)
check(32, "prm_compare_trajectories returns 0 or 1", cmp == 0 || cmp == 1)

// ── #33 compare: better-traj wins
// Train scorer to score h_a high (label 1) and verify a traj of all h_a
// beats a traj of all h_a but truncated to fewer steps then we override
// with a clearly worse trajectory by pushing W in opposite direction.
let mut sc_pos = scorer
let mut _step = 0

while _step < 30 {
    sc_pos = prm_train_step(sc_pos, h_a, 1.0, DIM, 0.5)
    sc_pos = prm_train_step(sc_pos, h_b, 0.0, DIM, 0.5)
}
let traj_good = [h_a, h_a, h_a]
let traj_bad = [h_b, h_b, h_b]
let cmp_result = prm_compare_trajectories(sc_pos, traj_good, traj_bad, 3, 3, DIM)
check(33, "prm_compare_trajectories better wins", cmp_result == 0)

// ── #34 constant score trajectory: min == product (when all=1.0) etc.
// Use a scorer trained so that score(h_a) ≈ 1.0
let mut sc_const = scorer
let mut _step = 0

while _step < 40 {
    sc_const = prm_train_step(sc_const, h_a, 1.0, DIM, 0.8)
}
let constant_traj = [h_a, h_a, h_a, h_a]
let cs = prm_score_trajectory(sc_const, constant_traj, 4, DIM)
let cs_min = prm_aggregate_min(cs, 4)
let cs_last = cs[3]
let cs_first = cs[0]
// constant scoring → min == first == last == every step
let constant_check = approx(cs_min, cs_first, 1.0e-6) && approx(cs_first, cs_last, 1.0e-6)
check(34, "constant score trajectory: min==first==last", constant_check)

// ── #35 score_trajectory empty list = []
let empty_scores = prm_score_trajectory(scorer, [], 0, DIM)
check(35, "prm_score_trajectory empty = []", len(empty_scores) == 0)

// ===================================================================
//  Summary
// ===================================================================
println("")
println("=== Process Reward Model test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
