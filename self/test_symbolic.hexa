// test_symbolic.hexa — @symbolic simplification end-to-end tests
// Tests: x*2 → x+x, x*1 → x, x*0 → 0, x**2 → x*x, shift↔pow2

// ── Test 1: x * 2 → x + x ──────────────────────────────
@symbolic
fn mul2(x) {
  return x * 2
}
assert mul2(5) == 10
assert mul2(0) == 0
assert mul2(-3) == -6
println("PASS 1: x*2 → x+x")

// ── Test 2: x * 1 → x ──────────────────────────────────
@symbolic
fn mul1(x) {
  return x * 1
}
assert mul1(42) == 42
assert mul1(0) == 0
println("PASS 2: x*1 → x")

// ── Test 3: x * 0 → 0 ──────────────────────────────────
@symbolic
fn mul0(x) {
  return x * 0
}
assert mul0(999) == 0
assert mul0(-1) == 0
println("PASS 3: x*0 → 0")

// ── Test 4: x ** 2 → x * x ─────────────────────────────
@symbolic
fn sq(x) {
  return x ** 2
}
assert sq(5) == 25
assert sq(0) == 0
assert sq(-3) == 9
println("PASS 4: x**2 → x*x")

// ── Test 5: x ** 1 → x ─────────────────────────────────
@symbolic
fn pow1(x) {
  return x ** 1
}
assert pow1(7) == 7
assert pow1(0) == 0
println("PASS 5: x**1 → x")

// ── Test 6: x ** 0 → 1 ─────────────────────────────────
@symbolic
fn pow0(x) {
  return x ** 0
}
assert pow0(7) == 1
assert pow0(0) == 1
println("PASS 6: x**0 → 1")

// ── Test 7: x * 8 → x << 3 (pow2 strength reduction) ──
@symbolic
fn mul8(x) {
  return x * 8
}
assert mul8(1) == 8
assert mul8(3) == 24
assert mul8(0) == 0
println("PASS 7: x*8 → x<<3")

// ── Test 8: x * 4 → x << 2 ─────────────────────────────
@symbolic
fn mul4(x) {
  return x * 4
}
assert mul4(1) == 4
assert mul4(5) == 20
println("PASS 8: x*4 → x<<2")

// ── Test 9: x / 4 → x >> 2 ─────────────────────────────
@symbolic
fn div4(x) {
  return x / 4
}
assert div4(16) == 4
assert div4(20) == 5
println("PASS 9: x/4 → x>>2")

// ── Test 10: x % 8 → x & 7 ─────────────────────────────
@symbolic
fn mod8(x) {
  return x % 8
}
assert mod8(17) == 1
assert mod8(16) == 0
assert mod8(7) == 7
println("PASS 10: x%8 → x&7")

// ── Test 11: combined — multiple symbolic ops in one fn ─
@symbolic
fn combined(x) {
  let a = x * 2
  let b = x * 0
  let c = x * 1
  return a + b + c
}
assert combined(5) == 15
assert combined(0) == 0
println("PASS 11: combined symbolic ops")

// ── Test 12: x * 2 preserves correctness with negative ─
@symbolic
fn neg_mul2(x) {
  return x * 2
}
assert neg_mul2(-10) == -20
assert neg_mul2(-1) == -2
println("PASS 12: neg x*2 correctness")

// ── Test 13: x ** 2 with larger values ──────────────────
@symbolic
fn sq_large(x) {
  return x ** 2
}
assert sq_large(10) == 100
assert sq_large(12) == 144
println("PASS 13: x**2 larger values")

// ── Test 14: x * 16 → x << 4 ───────────────────────────
@symbolic
fn mul16(x) {
  return x * 16
}
assert mul16(1) == 16
assert mul16(3) == 48
println("PASS 14: x*16 → x<<4")

// ── Test 15: nested symbolic: (x*2) + (x**2) ───────────
@symbolic
fn nested_sym(x) {
  return (x * 2) + (x ** 2)
}
assert nested_sym(3) == 15
assert nested_sym(0) == 0
assert nested_sym(1) == 3
println("PASS 15: nested symbolic")

println("")
println("ALL 15 @symbolic TESTS PASSED")
