// ===================================================================
//  test_continuous_batching.hexa — Continuous Batching Tests
//
//  Verifies:
//    1. Scheduler creation with correct defaults
//    2. add_request enqueues correctly
//    3. run_iteration decodes one token per active slot
//    4. Completed requests appear in get_completed
//    5. Dynamic slot filling from pending queue
//    6. run_until_done processes all requests
//    7. Max batch size limits active slots
//    8. scheduler_stats returns correct counts
//    9. Multiple requests with different max_tokens
//   10. current_batch_size tracks active count
//
//  Run: ./hexa self/test_continuous_batching.hexa
//  Minimum 10 check() statements.
// ===================================================================

import "ml/continuous_batching.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("===================================================================")
println("  Continuous Batching Test Suite")
println("===================================================================")

// ===================================================================
//  T1: create_scheduler initial state
// ===================================================================
let s0 = create_scheduler(4)
check("T1 scheduler max_batch=4", s0.max_batch == 4)

// ===================================================================
//  T2: add_request increases pending count
// ===================================================================
let s1 = add_request(s0, "Hello", 3)
check("T2 pending count after add", len(s1.pending) == 1)

// ===================================================================
//  T3: add_request assigns incremental IDs
// ===================================================================
let s2 = add_request(s1, "World", 5)
check("T3 second request id=1", s2.pending[1].id == 1)

// ===================================================================
//  T4: Request has correct prompt and max_tokens
// ===================================================================
check("T4 request prompt correct", s2.pending[0].prompt == "Hello")
check("T4b request max_tokens correct", s2.pending[0].max_tokens == 3)

// ===================================================================
//  T5: run_iteration moves pending to active
// ===================================================================
let s3 = run_iteration(s2, [])
let stats3 = scheduler_stats(s3)
let active_count = stats3[1]
check("T5 pending moved to active", active_count >= 1)

// ===================================================================
//  T6: run_iteration generates tokens
// ===================================================================
check("T6 total tokens > 0 after iteration", stats3[3] > 0)

// ===================================================================
//  T7: run_until_done completes all requests
// ===================================================================
let s_full = create_scheduler(2)
let s_f1 = add_request(s_full, "test1", 3)
let s_f2 = add_request(s_f1, "test2", 2)
let s_f3 = add_request(s_f2, "test3", 4)
let s_done = run_until_done(s_f3, [], 100)
let completed = get_completed(s_done)
check("T7 all 3 requests completed", len(completed) == 3)

// ===================================================================
//  T8: Completed requests have correct token counts
// ===================================================================
let mut all_have_tokens = true
let mut ci = 0
while ci < len(completed) {
    if completed[ci].tokens_generated < 1 {
        all_have_tokens = false
    }
    ci = ci + 1
}
check("T8 all completed have tokens", all_have_tokens)

// ===================================================================
//  T9: Max batch limits active slots
// ===================================================================
let s_batch = create_scheduler(2)
let s_b1 = add_request(s_batch, "a", 10)
let s_b2 = add_request(s_b1, "b", 10)
let s_b3 = add_request(s_b2, "c", 10)
let s_b4 = add_request(s_b3, "d", 10)
let s_b_iter = run_iteration(s_b4, [])
let b_active = len(s_b_iter.active)
check("T9 max_batch=2 limits active slots", b_active <= 2)

// ===================================================================
//  T10: pending_count correct
// ===================================================================
let pc = pending_count(s_b_iter)
check("T10 pending_count after batch fill", pc >= 1)

// ===================================================================
//  T11: current_batch_size matches active
// ===================================================================
let cbs = current_batch_size(s_b_iter)
check("T11 current_batch_size = active count", cbs == b_active)

// ===================================================================
//  T12: scheduler_stats format
// ===================================================================
let stats_full = scheduler_stats(s_done)
check("T12 scheduler_stats has 4 elements", len(stats_full) == 4)

// ===================================================================
//  T13: Empty scheduler run_iteration is no-op
// ===================================================================
let s_empty = create_scheduler(4)
let s_empty_iter = run_iteration(s_empty, [])
let empty_stats = scheduler_stats(s_empty_iter)
check("T13 empty scheduler: 0 tokens", empty_stats[3] == 0)

// ===================================================================
//  T14: Single request completes in max_tokens iterations
// ===================================================================
let s_single = create_scheduler(1)
let s_s1 = add_request(s_single, "single", 2)
let s_s_done = run_until_done(s_s1, [], 50)
let s_s_comp = get_completed(s_s_done)
check("T14 single request completes", len(s_s_comp) == 1)

// ===================================================================
//  Summary
// ===================================================================
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
