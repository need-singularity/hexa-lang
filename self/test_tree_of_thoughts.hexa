// ===================================================================
//  self/test_tree_of_thoughts.hexa — Tree of Thoughts verification
//
//  Roadmap id=55. Pure .hexa. Self-contained (inlines module source
//  per HX4 test convention, see test_cot_distill.hexa).
//
//  Tests (>=12):
//    1.  tot_make_node / accessors
//    2.  tot_expand produces k children with correct depth
//    3.  tot_expand wraps around short suffix lists
//    4.  tot_heuristic rewards keyword hits
//    5.  tot_heuristic prefers deeper nodes (small bonus)
//    6.  tot_vote is non-negative
//    7.  tot_score combines heuristic + vote
//    8.  tot_topk returns top-k sorted desc
//    9.  tot_topk handles k > n
//   10.  tot_search_bfs respects beam width (frontier cap)
//   11.  tot_search_bfs reaches max_depth leaves
//   12.  tot_search_dfs visits all expected nodes (depth-bounded)
//   13.  tot_search_dfs backtracking (pops stack correctly)
//   14.  tot_combine_best picks highest score
//   15.  tot_combine_majority picks most common trailing token
//   16.  tot_solve bfs+best end-to-end
//   17.  tot_solve dfs+majority end-to-end
//   18.  tot_last_suffix extracts trailing token
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx(a, b, eps) {
    return fabs(a - b) < eps
}

// ── inlined from self/ml/tree_of_thoughts.hexa ───────────────────

fn tot_id_of(node)      { return node[0] }
fn tot_parent_of(node)  { return node[1] }
fn tot_depth_of(node)   { return node[2] }
fn tot_content_of(node) { return node[3] }
fn tot_score_of(node)   { return node[4] }

fn tot_make_node(id, parent, depth, content, score) {
    return [id, parent, depth, content, score]
}

fn tot_fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn tot_expand(parent_node, suffixes, k, next_id_start) {
    let parent_id = tot_id_of(parent_node)
    let parent_depth = tot_depth_of(parent_node)
    let parent_content = tot_content_of(parent_node)
    let ns = len(suffixes)
    let mut out = []
    let mut i = 0
    while i < k {
        let idx = i % ns
        let suf = suffixes[idx]
        let new_content = parent_content + " -> " + suf
        let new_id = next_id_start + i
        let child = tot_make_node(new_id, parent_id, parent_depth + 1, new_content, 0.0)
        out = out + [child]
        i = i + 1
    }
    return out
}

fn tot_heuristic(content, keywords, depth) {
    let mut score = 0.1 * to_float(depth)
    let nk = len(keywords)
    let mut i = 0
    while i < nk {
        let kw = keywords[i]
        if content.index_of(kw) >= 0 {
            score = score + 1.0
        }
        i = i + 1
    }
    let arrow = " -> "
    let mut cnt = 0
    let mut j = 0
    let cl = len(content)
    let al = len(arrow)
    while j + al <= cl {
        if content.substring(j, j + al) == arrow {
            cnt = cnt + 1
        }
        j = j + 1
    }
    if cnt > depth { score = score - 0.25 * to_float(cnt - depth) }
    return score
}

fn tot_vote(content, keywords, num_voters) {
    let mut total = 0.0
    let mut v = 0
    while v < num_voters {
        let nk = len(keywords)
        if nk == 0 { return 0.0 }
        let mut hits = 0.0
        let mut i = 0
        while i < nk {
            if (i + v) % 2 == 0 {
                let kw = keywords[i]
                if content.index_of(kw) >= 0 {
                    hits = hits + 1.0
                }
            }
            i = i + 1
        }
        total = total + hits
        v = v + 1
    }
    if num_voters == 0 { return 0.0 }
    return total / to_float(num_voters)
}

fn tot_score(node, keywords, num_voters) {
    let content = tot_content_of(node)
    let depth = tot_depth_of(node)
    let h = tot_heuristic(content, keywords, depth)
    let v = tot_vote(content, keywords, num_voters)
    return h + 0.5 * v
}

fn tot_topk(nodes, k) {
    let n = len(nodes)
    if n == 0 { return [] }
    let mut arr = []
    let mut a = 0
    while a < n {
        arr = arr + [nodes[a]]
        a = a + 1
    }
    let mut i = 0
    while i < n {
        let mut best = i
        let mut j = i + 1
        while j < n {
            if tot_score_of(arr[j]) > tot_score_of(arr[best]) {
                best = j
            }
            j = j + 1
        }
        if best != i {
            let tmp = arr[i]
            arr[i] = arr[best]
            arr[best] = tmp
        }
        i = i + 1
    }
    let take = if k < n { k } else { n }
    let mut out = []
    let mut m = 0
    while m < take {
        out = out + [arr[m]]
        m = m + 1
    }
    return out
}

fn tot_search_bfs(root_content, suffixes, keywords, max_depth, beam_width, num_voters) {
    let root = tot_make_node(0, -1, 0, root_content, 0.0)
    let root_scored = tot_make_node(0, -1, 0, root_content, tot_score(root, keywords, num_voters))
    let mut all_nodes = [root_scored]
    let mut frontier = [root_scored]
    let mut next_id = 1
    let mut d = 0
    while d < max_depth {
        let mut children = []
        let nf = len(frontier)
        let mut i = 0
        while i < nf {
            let parent = frontier[i]
            let expanded = tot_expand(parent, suffixes, beam_width, next_id)
            next_id = next_id + len(expanded)
            let ne = len(expanded)
            let mut j = 0
            while j < ne {
                let child = expanded[j]
                let sc = tot_score(child, keywords, num_voters)
                let scored = tot_make_node(tot_id_of(child), tot_parent_of(child), tot_depth_of(child), tot_content_of(child), sc)
                children = children + [scored]
                j = j + 1
            }
            i = i + 1
        }
        let cn = len(children)
        let mut k = 0
        while k < cn {
            all_nodes = all_nodes + [children[k]]
            k = k + 1
        }
        frontier = tot_topk(children, beam_width)
        if len(frontier) == 0 { d = max_depth }
        d = d + 1
    }
    return all_nodes
}

fn tot_search_dfs(root_content, suffixes, keywords, max_depth, branch, num_voters) {
    let root = tot_make_node(0, -1, 0, root_content, 0.0)
    let root_s = tot_make_node(0, -1, 0, root_content, tot_score(root, keywords, num_voters))
    let mut visited = [root_s]
    let mut stack = [root_s]
    let mut next_id = 1
    while len(stack) > 0 {
        let top = len(stack) - 1
        let cur = stack[top]
        let mut new_stack = []
        let mut z = 0
        while z < top {
            new_stack = new_stack + [stack[z]]
            z = z + 1
        }
        stack = new_stack
        if tot_depth_of(cur) < max_depth {
            let kids = tot_expand(cur, suffixes, branch, next_id)
            next_id = next_id + len(kids)
            let nk = len(kids)
            let mut ii = 0
            while ii < nk {
                let child = kids[ii]
                let sc = tot_score(child, keywords, num_voters)
                let child_s = tot_make_node(tot_id_of(child), tot_parent_of(child), tot_depth_of(child), tot_content_of(child), sc)
                visited = visited + [child_s]
                stack = stack + [child_s]
                ii = ii + 1
            }
        }
    }
    return visited
}

fn tot_combine_best(nodes) {
    let n = len(nodes)
    if n == 0 { return [] }
    let mut best = nodes[0]
    let mut i = 1
    while i < n {
        if tot_score_of(nodes[i]) > tot_score_of(best) {
            best = nodes[i]
        }
        i = i + 1
    }
    return best
}

fn tot_last_suffix(content) {
    let arrow = " -> "
    let al = len(arrow)
    let cl = len(content)
    let mut last = 0
    let mut j = 0
    while j + al <= cl {
        if content.substring(j, j + al) == arrow {
            last = j + al
        }
        j = j + 1
    }
    return content.substring(last, cl)
}

fn tot_combine_majority(nodes, target_depth) {
    let n = len(nodes)
    if n == 0 { return "" }
    let mut labels = []
    let mut i = 0
    while i < n {
        if tot_depth_of(nodes[i]) == target_depth {
            labels = labels + [tot_last_suffix(tot_content_of(nodes[i]))]
        }
        i = i + 1
    }
    let nl = len(labels)
    if nl == 0 { return "" }
    let mut best_label = labels[0]
    let mut best_count = 0
    let mut a = 0
    while a < nl {
        let cand = labels[a]
        let mut c = 0
        let mut b = 0
        while b < nl {
            if labels[b] == cand { c = c + 1 }
            b = b + 1
        }
        if c > best_count {
            best_count = c
            best_label = cand
        }
        a = a + 1
    }
    return best_label
}

fn tot_solve(root_content, suffixes, keywords, max_depth, width, num_voters, mode, combine) {
    let mut nodes = []
    if mode == "bfs" {
        nodes = tot_search_bfs(root_content, suffixes, keywords, max_depth, width, num_voters)
    } else {
        nodes = tot_search_dfs(root_content, suffixes, keywords, max_depth, width, num_voters)
    }
    let mut leaves = []
    let n = len(nodes)
    let mut i = 0
    while i < n {
        if tot_depth_of(nodes[i]) == max_depth {
            leaves = leaves + [nodes[i]]
        }
        i = i + 1
    }
    let mut best_node = []
    if combine == "best" {
        if len(leaves) > 0 {
            best_node = tot_combine_best(leaves)
        } else {
            best_node = tot_combine_best(nodes)
        }
    }
    let label = tot_combine_majority(nodes, max_depth)
    return [best_node, label, n]
}

// ═══════════════════════════════════════════════════════════════════
//  Tests
// ═══════════════════════════════════════════════════════════════════

println("=== Tree of Thoughts (id=55) ===")

// ── test 1: node helpers ─────────────────────────────────────────
let n0 = tot_make_node(7, 3, 2, "root -> a", 1.25)
check("make_node id",     tot_id_of(n0) == 7)
check("make_node parent", tot_parent_of(n0) == 3)
check("make_node depth",  tot_depth_of(n0) == 2)
check("make_node content", tot_content_of(n0) == "root -> a")
check("make_node score",  approx(tot_score_of(n0), 1.25, 0.0001))

// ── test 2: expand produces k children, depth+1 ─────────────────
let parent = tot_make_node(0, -1, 0, "Q", 0.0)
let suffixes = ["reason", "answer", "plan"]
let kids3 = tot_expand(parent, suffixes, 3, 1)
check("expand len == k", len(kids3) == 3)
check("expand depth+1", tot_depth_of(kids3[0]) == 1)
check("expand parent id linked", tot_parent_of(kids3[1]) == 0)
check("expand content has arrow", kids3[0][3].index_of(" -> ") >= 0)

// ── test 3: expand wraps around short suffix list ───────────────
let kids5 = tot_expand(parent, ["a", "b"], 5, 100)
check("expand wraps len=5", len(kids5) == 5)
check("expand wraps id start", tot_id_of(kids5[0]) == 100)
check("expand wraps id end",   tot_id_of(kids5[4]) == 104)
check("expand wraps cycles suffix", tot_content_of(kids5[0]) == tot_content_of(kids5[2]))

// ── test 4: heuristic keyword hits ───────────────────────────────
let h_hit  = tot_heuristic("Q -> answer", ["answer"], 1)
let h_miss = tot_heuristic("Q -> other", ["answer"], 1)
check("heuristic keyword bump", h_hit > h_miss)

// ── test 5: heuristic depth bonus ────────────────────────────────
let h_deep    = tot_heuristic("Q", [], 5)
let h_shallow = tot_heuristic("Q", [], 1)
check("heuristic depth bonus", h_deep > h_shallow)

// ── test 6: vote non-negative ────────────────────────────────────
let v_simple = tot_vote("Q -> answer", ["answer", "plan"], 3)
check("vote non-negative", v_simple >= 0.0)

// ── test 7: score combines heuristic + vote ──────────────────────
let scored_node = tot_make_node(1, 0, 1, "Q -> answer", 0.0)
let combined = tot_score(scored_node, ["answer"], 2)
check("score > 0 for keyword hit", combined > 0.0)

// ── test 8: topk sorted descending ───────────────────────────────
let a_node = tot_make_node(1, 0, 1, "x", 0.5)
let b_node = tot_make_node(2, 0, 1, "y", 3.0)
let c_node = tot_make_node(3, 0, 1, "z", 1.7)
let d_node = tot_make_node(4, 0, 1, "w", 2.2)
let topk2 = tot_topk([a_node, b_node, c_node, d_node], 2)
check("topk len == k", len(topk2) == 2)
check("topk[0] has highest score", approx(tot_score_of(topk2[0]), 3.0, 0.0001))
check("topk[1] second highest", approx(tot_score_of(topk2[1]), 2.2, 0.0001))

// ── test 9: topk handles k > n ───────────────────────────────────
let topk_big = tot_topk([a_node, b_node], 10)
check("topk k>n clipped to n", len(topk_big) == 2)

// ── test 10: bfs respects beam width ─────────────────────────────
let tree_bfs = tot_search_bfs("Q", ["a", "b", "c"], ["a"], 2, 2, 2)
// root + (≤2 frontier × 2 children) level 1 + level 2 …
// because beam=2 we expect a bounded tree
check("bfs non-empty", len(tree_bfs) > 0)
check("bfs root present", tot_depth_of(tree_bfs[0]) == 0)
// count depth-1 children: beam 2 * 2 children = at most 2 expansions but
// we expand beam_width children per parent so 1 parent (root) * 2 = 2
let mut d1_cnt = 0
let nb = len(tree_bfs)
let mut bi = 0
while bi < nb {
    if tot_depth_of(tree_bfs[bi]) == 1 { d1_cnt = d1_cnt + 1 }
    bi = bi + 1
}
check("bfs depth=1 children == beam (2)", d1_cnt == 2)

// ── test 11: bfs reaches max_depth ───────────────────────────────
let mut has_leaf = false
let mut li = 0
while li < nb {
    if tot_depth_of(tree_bfs[li]) == 2 { has_leaf = true }
    li = li + 1
}
check("bfs reaches max_depth", has_leaf)

// ── test 12: dfs visits all nodes bounded by depth ──────────────
let tree_dfs = tot_search_dfs("Q", ["a", "b"], ["a"], 2, 2, 1)
// total = 1 root + 2 depth-1 + 4 depth-2 = 7
check("dfs visited count 7", len(tree_dfs) == 7)

// ── test 13: dfs backtracking (depth-2 leaves present) ──────────
let mut dfs_d2 = 0
let nd = len(tree_dfs)
let mut di = 0
while di < nd {
    if tot_depth_of(tree_dfs[di]) == 2 { dfs_d2 = dfs_d2 + 1 }
    di = di + 1
}
check("dfs depth=2 leaves == 4", dfs_d2 == 4)

// ── test 14: combine_best picks highest score ───────────────────
let best = tot_combine_best([a_node, b_node, c_node])
check("combine_best picks max score", approx(tot_score_of(best), 3.0, 0.0001))

// ── test 15: combine_majority picks most common suffix ──────────
let leaf1 = tot_make_node(10, 0, 2, "Q -> step -> yes", 1.0)
let leaf2 = tot_make_node(11, 0, 2, "Q -> hmm -> yes",  0.9)
let leaf3 = tot_make_node(12, 0, 2, "Q -> ok  -> no",   0.5)
let leaves = [leaf1, leaf2, leaf3]
let maj = tot_combine_majority(leaves, 2)
check("combine_majority = yes", maj == "yes")

// ── test 16: tot_solve bfs + best end-to-end ─────────────────────
let solve_bfs = tot_solve("Q", ["good", "bad"], ["good"], 2, 2, 2, "bfs", "best")
let best_leaf = solve_bfs[0]
let total_visited_bfs = solve_bfs[2]
check("solve bfs returns best leaf", len(best_leaf) == 5)
check("solve bfs best leaf is depth 2", tot_depth_of(best_leaf) == 2)
check("solve bfs visited > 0", total_visited_bfs > 0)

// ── test 17: tot_solve dfs + majority end-to-end ────────────────
let solve_dfs = tot_solve("Q", ["good", "good", "bad"], ["good"], 2, 3, 1, "dfs", "majority")
let label_dfs = solve_dfs[1]
check("solve dfs majority label non-empty", len(label_dfs) > 0)
// with 2 'good' and 1 'bad' in suffixes, majority at depth 2 should be 'good'
check("solve dfs majority == good", label_dfs == "good")

// ── test 18: last_suffix extraction ─────────────────────────────
check("last_suffix root has no arrow", tot_last_suffix("Q") == "Q")
check("last_suffix trailing",          tot_last_suffix("Q -> step -> ans") == "ans")

println("")
println("=== tree_of_thoughts test summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
println("TOTAL: " + to_string(pass_count + fail_count))
if fail_count == 0 {
    println("ALL TREE-OF-THOUGHTS TESTS PASSED")
} else {
    println("SOME TESTS FAILED")
}
