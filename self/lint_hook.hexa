// self/lint_hook.hexa — PostToolUse hook: .hexa 파일 편집 시 자동 lint
// stdin: Claude Code hook JSON {"tool_name":"Edit|Write","tool_input":{"file_path":"...",...}}

let HOME = env("HOME")
let HEXA = HOME + "/Dev/hexa-lang/target/release/hexa-bin-actual"
let LINTER = HOME + "/Dev/hexa-lang/self/linter.hexa"

let stdin_data = read_stdin()
if len(stdin_data) == 0 { exit(0) }

// file_path 추출 (간단한 JSON 파싱)
let key = "\"file_path\":\""
let idx = stdin_data.index_of(key)
if idx < 0 { exit(0) }

let after = stdin_data.substring(idx + len(key), len(stdin_data))
let end_idx = after.index_of("\"")
if end_idx < 0 { exit(0) }

let file_path = after.substring(0, end_idx)

// .hexa 파일만 lint
if !ends_with(file_path, ".hexa") { exit(0) }

// linter 자체 편집 중이면 skip (무한 루프 방지)
if contains(file_path, "lint_hook.hexa") { exit(0) }
if contains(file_path, "linter.hexa") { exit(0) }

// lint 실행
let mut result = ""
try {
    result = to_string(exec(HEXA + " " + LINTER + " " + file_path + " 2>/dev/null"))
} catch e {
    exit(0)
}

let trimmed = result.trim()
if len(trimmed) > 0 && !ends_with(trimmed, "-- clean") {
    println(trimmed)
}
