// ═══════════════════════════════════════════════════════════
//  test_ai_native_v3.hexa — AI-native @attr v3 extension tests
//  Tests: @lazy, @cache, @profile, @specialize, @inline,
//         @autograd, @quantize (7 new AI-native attrs)
//
//  Validates runtime-neutral semantics: the @attr annotations
//  are recognized by parser + ai_native_pass, runtime behavior
//  must be identical to unannotated code.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA AI-Native @attr v3 Tests")
println("  @lazy @cache @profile @specialize @inline @autograd @quantize")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. @lazy — deferred evaluation (thunk wrapping) ─────────

println("--- @lazy ---")

@pure @lazy fn lazy_const() -> int { return 99 }
@pure @lazy fn lazy_sum_10() -> int {
    let mut s = 0
    let mut i = 0
    while i < 10 {
        s = s + i
        i = i + 1
    }
    return s
}
@pure @lazy fn lazy_greeting() -> string { return "hello" }
@pure @lazy fn lazy_product() -> int { return 6 * 7 }
@pure @lazy fn lazy_neg() -> int { return 0 - 1 }

let t1 = lazy_const()
let t2 = lazy_sum_10()
let t3 = lazy_greeting()
let t4 = lazy_product()
let t5 = lazy_neg()

check("@lazy const force", t1(), 99)
check("@lazy sum_10 force", t2(), 45)
check("@lazy greeting force", t3(), "hello")
check("@lazy product force", t4(), 42)
check("@lazy neg force", t5(), -1)
check("@lazy idempotent", t1() == t1(), true)
check("@lazy stable", t2() == t2(), true)

// ── 2. @cache — LRU bounded memoize ────────────────────────

println("")
println("--- @cache ---")

@cache fn cached_square(x: int) -> int { return x * x }
@cache fn cached_add(a: int, b: int) -> int { return a + b }
// decreases n — structural
@cache fn cached_fib(n: int) -> int {
    if n <= 1 { return n }
    return cached_fib(n - 1) + cached_fib(n - 2)
}
@cache fn cached_neg(x: int) -> int { return 0 - x }
@cache fn cached_id(x: int) -> int { return x }

check("@cache square(5)", cached_square(5), 25)
check("@cache square(0)", cached_square(0), 0)
check("@cache square(12)", cached_square(12), 144)
check("@cache add(3,4)", cached_add(3, 4), 7)
check("@cache add(10,20)", cached_add(10, 20), 30)
check("@cache fib(10)", cached_fib(10), 55)
check("@cache fib(0)", cached_fib(0), 0)
check("@cache neg(7)", cached_neg(7), -7)
check("@cache id(42)", cached_id(42), 42)

// ── 3. @profile — call-count/timing wrapper ─────────────────

println("")
println("--- @profile ---")

@profile fn prof_double(x: int) -> int { return x * 2 }
@profile fn prof_sum_n(n: int) -> int {
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + i
        i = i + 1
    }
    return s
}
@profile fn prof_noop() -> int { return 0 }
@profile fn prof_identity(x: int) -> int { return x }

check("@profile double(5)", prof_double(5), 10)
check("@profile double(0)", prof_double(0), 0)
check("@profile sum_n(100)", prof_sum_n(100), 4950)
check("@profile sum_n(0)", prof_sum_n(0), 0)
check("@profile noop", prof_noop(), 0)
check("@profile identity(99)", prof_identity(99), 99)

// ── 4. @specialize — type-specialized code gen ──────────────

println("")
println("--- @specialize ---")

@specialize fn spec_triple(x: int) -> int { return x * 3 }
@specialize fn spec_offset(x: int, off: int) -> int { return x + off }
@specialize fn spec_abs(x: int) -> int {
    if x < 0 { return 0 - x }
    return x
}
@specialize fn spec_pow2(n: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

check("@specialize triple(7)", spec_triple(7), 21)
check("@specialize triple(0)", spec_triple(0), 0)
check("@specialize offset(10,5)", spec_offset(10, 5), 15)
check("@specialize abs(-3)", spec_abs(-3), 3)
check("@specialize abs(3)", spec_abs(3), 3)
check("@specialize pow2(8)", spec_pow2(8), 256)

// ── 5. @inline — function body inlining ─────────────────────

println("")
println("--- @inline ---")

@inline fn inl_inc(x: int) -> int { return x + 1 }
@inline fn inl_dec(x: int) -> int { return x - 1 }
@inline fn inl_zero() -> int { return 0 }
@inline fn inl_min(a: int, b: int) -> int {
    if a < b { return a }
    return b
}
@inline fn inl_max(a: int, b: int) -> int {
    if a > b { return a }
    return b
}

check("@inline inc(41)", inl_inc(41), 42)
check("@inline dec(43)", inl_dec(43), 42)
check("@inline zero", inl_zero(), 0)
check("@inline min(3,7)", inl_min(3, 7), 3)
check("@inline max(3,7)", inl_max(3, 7), 7)
check("@inline min(10,10)", inl_min(10, 10), 10)

// ── 6. @autograd — automatic differentiation (forward mode) ─

println("")
println("--- @autograd ---")

// Forward mode: f(x) = 3x + 5  => f'(x) = 3
// Runtime semantics: just compute the function value
@autograd fn ag_linear(x: int) -> int { return 3 * x + 5 }
// f(x) = x * x => f'(x) = 2x
@autograd fn ag_square(x: int) -> int { return x * x }
// f(x) = 2*x*x + x => f'(x) = 4x + 1
@autograd fn ag_poly(x: int) -> int { return 2 * x * x + x }
@autograd fn ag_const(x: int) -> int { return 42 }
@autograd fn ag_neg(x: int) -> int { return 0 - x }

check("@autograd linear(10)", ag_linear(10), 35)
check("@autograd linear(0)", ag_linear(0), 5)
check("@autograd square(5)", ag_square(5), 25)
check("@autograd square(0)", ag_square(0), 0)
check("@autograd poly(3)", ag_poly(3), 21)
check("@autograd poly(0)", ag_poly(0), 0)
check("@autograd const(7)", ag_const(7), 42)
check("@autograd neg(5)", ag_neg(5), -5)

// ── 7. @quantize — int8/int4 quantization simulation ────────

println("")
println("--- @quantize ---")

// Quantize semantics: runtime values remain normal (simulation only)
@quantize fn quant_scale(x: int) -> int { return x * 127 }
@quantize fn quant_add(a: int, b: int) -> int { return a + b }
@quantize fn quant_clamp(x: int) -> int {
    if x > 127 { return 127 }
    if x < -128 { return -128 }
    return x
}
@quantize fn quant_relu(x: int) -> int {
    if x < 0 { return 0 }
    return x
}
@quantize fn quant_shift(x: int) -> int { return x / 4 }

check("@quantize scale(1)", quant_scale(1), 127)
check("@quantize scale(2)", quant_scale(2), 254)
check("@quantize add(50,77)", quant_add(50, 77), 127)
check("@quantize clamp(200)", quant_clamp(200), 127)
check("@quantize clamp(-200)", quant_clamp(-200), -128)
check("@quantize clamp(50)", quant_clamp(50), 50)
check("@quantize relu(-5)", quant_relu(-5), 0)
check("@quantize relu(10)", quant_relu(10), 10)
check("@quantize shift(100)", quant_shift(100), 25)

// ── 8. Combinations ─────────────────────────────────────────

println("")
println("--- combinations ---")

@pure @cache fn pure_cached(x: int) -> int { return x * x + 1 }
@inline @specialize fn inl_spec(x: int) -> int { return x * 5 }
@pure @inline fn pure_inl(x: int) -> int { return x + x }

check("@pure @cache square+1(6)", pure_cached(6), 37)
check("@pure @cache square+1(0)", pure_cached(0), 1)
check("@inline @specialize mul5(9)", inl_spec(9), 45)
check("@pure @inline double(7)", pure_inl(7), 14)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL AI-NATIVE v3 TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
