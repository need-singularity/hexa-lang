// =====================================================================
//  test_parser_full.hexa -- Mega Parser Coverage Test
//  Covers: literals, operators, variables, control flow, functions,
//          structs, enums, impl, match, closures, arrays, maps,
//          strings, try/catch/throw, for/while/break/continue,
//          type annotations, @attrs, scoping, recursion, etc.
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_bool(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("=====================================================================")
println("  HEXA Mega Parser Coverage Test")
println("=====================================================================")
println("")

// =====================================================================
// SECTION 1: Literal Expressions (20 tests)
// =====================================================================
println("--- 1. Literals ---")

check("int literal", 42, 42)
check("zero literal", 0, 0)
check("negative int", -7, -7)
check("large int", 1000000, 1000000)
check("float literal", 3.14, 3.14)
check("float zero", 0.0, 0.0)
check("negative float", -2.5, -2.5)
check("string literal", "hello", "hello")
check("empty string", "", "")
check("string with spaces", "hello world", "hello world")
check("bool true", true, true)
check("bool false", false, false)
check("array literal", to_string([1, 2, 3]), to_string([1, 2, 3]))
check("empty array", to_string([]), to_string([]))
check("nested array", to_string([[1, 2], [3, 4]]), to_string([[1, 2], [3, 4]]))
check("map literal", to_string(#{"a": 1}), to_string(#{"a": 1}))
check("empty map", to_string(#{}), to_string(#{}))
check("single elem array", to_string([42]), to_string([42]))
check("float precision", 1.5, 1.5)
check("string special chars", "a\tb", "a\tb")

// =====================================================================
// SECTION 2: Operator Precedence & Arithmetic (20 tests)
// =====================================================================
println("")
println("--- 2. Operators & Precedence ---")

check("add", 2 + 3, 5)
check("sub", 10 - 3, 7)
check("mul", 6 * 7, 42)
check("div", 15 / 3, 5)
check("mod", 10 % 3, 1)
check("precedence mul before add", 2 + 3 * 4, 14)
check("precedence parens", (2 + 3) * 4, 20)
check("nested parens", ((2 + 3) * (4 - 1)), 15)
check("neg mul", -5 * 3, -15)
check("neg mul neg", -5 * -5, 25)
check("chain add", 1 + 2 + 3 + 4, 10)
check("chain mul", 2 * 3 * 4, 24)
check("mixed chain", 2 + 3 * 4 - 1, 13)
check("div truncate", 7 / 2, 3)
check("mod zero result", 9 % 3, 0)
check("float add", 1.5 + 2.5, 4.0)
check("float mul", 2.5 * 4.0, 10.0)
check("int float coerce", 3 + 2.5, 5.5)
check("complex expr", (10 + 5) * 2 - 3 * 4, 18)
check("zero mul", 0 * 9999, 0)

// =====================================================================
// SECTION 3: Comparison & Logical Operators (20 tests)
// =====================================================================
println("")
println("--- 3. Comparison & Logic ---")

check("eq int", 5 == 5, true)
check("neq int", 5 != 3, true)
check("lt", 3 < 5, true)
check("gt", 5 > 3, true)
check("le", 5 <= 5, true)
check("ge", 5 >= 5, true)
check("le strict", 3 <= 5, true)
check("ge strict", 7 >= 5, true)
check("not lt", 5 < 3, false)
check("not gt", 3 > 5, false)
check("and TT", true && true, true)
check("and TF", true && false, false)
check("and FF", false && false, false)
check("or TT", true || true, true)
check("or TF", true || false, true)
check("or FF", false || false, false)
check("not true", !true, false)
check("not false", !false, true)
check("string eq", "abc" == "abc", true)
check("string neq", "abc" != "xyz", true)

// =====================================================================
// SECTION 4: Variable Declarations (15 tests)
// =====================================================================
println("")
println("--- 4. Variables ---")

let x1 = 42
check("let immutable", x1, 42)

let mut x2 = 10
x2 = x2 + 5
check("let mut modify", x2, 15)

let x3 = "hello"
check("let string", x3, "hello")

let x4 = true
check("let bool", x4, true)

let x5 = [1, 2, 3]
check("let array", len(x5), 3)

let x6 = 3.14
check("let float", x6, 3.14)

let mut counter = 0
counter = counter + 1
counter = counter + 1
counter = counter + 1
check("mut increment 3x", counter, 3)

let a1 = 10
let a2 = 20
let a3 = a1 + a2
check("let from expr", a3, 30)

let mut s = ""
s = s + "a"
s = s + "b"
s = s + "c"
check("mut string build", s, "abc")

let composed = to_string(42) + " is the answer"
check("let composed expr", composed, "42 is the answer")

// Type annotations
let typed_int: int = 99
check("typed int", typed_int, 99)

let typed_str: string = "typed"
check("typed string", typed_str, "typed")

let typed_bool: bool = true
check("typed bool", typed_bool, true)

let typed_float: float = 2.71
check("typed float", typed_float, 2.71)

let typed_arr: array = [1, 2]
check("typed array", len(typed_arr), 2)

// =====================================================================
// SECTION 5: If/Else (15 tests)
// =====================================================================
println("")
println("--- 5. If/Else ---")

let mut r = 0
if true { r = 1 }
check("if true", r, 1)

let mut r2 = 0
if false { r2 = 1 } else { r2 = 2 }
check("if false else", r2, 2)

fn classify(n) {
    if n > 0 { return "positive" }
    if n < 0 { return "negative" }
    return "zero"
}
check("classify positive", classify(5), "positive")
check("classify negative", classify(-3), "negative")
check("classify zero", classify(0), "zero")

fn max2(a, b) {
    if a > b { return a } else { return b }
}
check("max2(3,7)", max2(3, 7), 7)
check("max2(9,2)", max2(9, 2), 9)
check("max2(5,5)", max2(5, 5), 5)

fn fizzbuzz(n) {
    if n % 15 == 0 { return "fizzbuzz" }
    if n % 3 == 0 { return "fizz" }
    if n % 5 == 0 { return "buzz" }
    return to_string(n)
}
check("fizzbuzz 15", fizzbuzz(15), "fizzbuzz")
check("fizzbuzz 9", fizzbuzz(9), "fizz")
check("fizzbuzz 10", fizzbuzz(10), "buzz")
check("fizzbuzz 7", fizzbuzz(7), "7")

// Nested if
fn nested_if(x) {
    if x > 0 {
        if x > 10 {
            return "big"
        } else {
            return "small"
        }
    } else {
        return "non-positive"
    }
}
check("nested if big", nested_if(20), "big")
check("nested if small", nested_if(5), "small")

// =====================================================================
// SECTION 6: While Loop (10 tests)
// =====================================================================
println("")
println("--- 6. While ---")

let mut wsum = 0
let mut wi = 1
while wi <= 10 {
    wsum = wsum + wi
    wi = wi + 1
}
check("while sum 1..10", wsum, 55)

let mut factorial = 1
let mut fi = 1
while fi <= 5 {
    factorial = factorial * fi
    fi = fi + 1
}
check("while factorial 5", factorial, 120)

// Nested while
let mut nw = 0
let mut ni = 0
while ni < 3 {
    let mut nj = 0
    while nj < 4 {
        nw = nw + 1
        nj = nj + 1
    }
    ni = ni + 1
}
check("nested while 3x4", nw, 12)

// While with break
let mut bv = 0
let mut bi = 0
while bi < 100 {
    if bi == 5 { break }
    bv = bv + bi
    bi = bi + 1
}
check("while break", bv, 10)
check("while break index", bi, 5)

// While with continue
let mut cv = 0
let mut ci = 0
while ci < 10 {
    ci = ci + 1
    if ci % 2 == 0 { continue }
    cv = cv + ci
}
check("while continue odd sum", cv, 25)

// While countdown
let mut cd = 10
let mut cd_steps = 0
while cd > 0 {
    cd = cd - 1
    cd_steps = cd_steps + 1
}
check("while countdown", cd_steps, 10)
check("while countdown final", cd, 0)

// While with complex condition
let mut wc_a = 0
let mut wc_b = 1
let mut wc_steps = 0
while wc_a < 50 && wc_b < 100 {
    let temp = wc_a + wc_b
    wc_a = wc_b
    wc_b = temp
    wc_steps = wc_steps + 1
}
check_bool("while complex cond fib", wc_b >= 100 || wc_a >= 50)

// =====================================================================
// SECTION 7: For Loop (10 tests)
// =====================================================================
println("")
println("--- 7. For ---")

let mut fsum = 0
for x in [10, 20, 30] {
    fsum = fsum + x
}
check("for in array", fsum, 60)

let mut fstr = ""
for w in ["hello", " ", "world"] {
    fstr = fstr + w
}
check("for in strings", fstr, "hello world")

let mut rsum = 0
let mut i = 0

while i < 5 {
    rsum = rsum + i
}
check("for range 0..5", rsum, 10)

let mut rsum2 = 0
let mut i = 1

while i < 4 {
    rsum2 = rsum2 + i
}
check("for range 1..4", rsum2, 6)

// For with empty
let mut fempty = 0
for x in [] {
    fempty = fempty + 1
}
check("for empty array", fempty, 0)

// For nested
let mut nested_sum = 0
for row in [[1, 2], [3, 4], [5, 6]] {
    for val in row {
        nested_sum = nested_sum + val
    }
}
check("for nested arrays", nested_sum, 21)

// For with index pattern
let mut idx_sum = 0
let mut i = 0

while i < 10 {
    if i % 2 == 0 {
        idx_sum = idx_sum + i
    }
}
check("for even sum", idx_sum, 20)

// For collecting
let mut collected = []
let mut i = 0

while i < 5 {
    collected.push(i * i)
}
check("for collect squares", to_string(collected), to_string([0, 1, 4, 9, 16]))

// For with break
let mut fb = 0
let mut i = 0

while i < 100 {
    if i == 5 { break }
    fb = fb + i
}
check("for break", fb, 10)

// For with continue (skip multiples of 3: skip 0,3,6,9 -> sum 1+2+4+5+7+8=27)
let mut fc_sum = 0
let mut i = 0

while i < 10 {
    if i % 3 == 0 { continue }
    fc_sum = fc_sum + i
}
check("for continue", fc_sum, 27)

// =====================================================================
// SECTION 8: Functions (15 tests)
// =====================================================================
println("")
println("--- 8. Functions ---")

fn add_fn(a, b) { return a + b }
fn sub_fn(a, b) { return a - b }
fn mul_fn(a, b) { return a * b }
check("fn add", add_fn(3, 4), 7)
check("fn sub", sub_fn(10, 3), 7)
check("fn mul", mul_fn(6, 7), 42)

fn no_args_fn() { return 42 }
check("fn no args", no_args_fn(), 42)

fn multi_return(x) {
    if x > 0 { return "pos" }
    if x < 0 { return "neg" }
    return "zero"
}
check("fn multi return pos", multi_return(5), "pos")
check("fn multi return neg", multi_return(-1), "neg")

// Recursive
fn fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}
check("fn fib(0)", fib(0), 0)
check("fn fib(1)", fib(1), 1)
check("fn fib(6)", fib(6), 8)
check("fn fib(10)", fib(10), 55)

// Mutual-like via helper
fn is_even_r(n) {
    if n == 0 { return true }
    return is_odd_r(n - 1)
}
fn is_odd_r(n) {
    if n == 0 { return false }
    return is_even_r(n - 1)
}
check("mutual even 4", is_even_r(4), true)
check("mutual odd 5", is_odd_r(5), true)
check("mutual even 7", is_even_r(7), false)

// Function as value
fn apply_fn(f, x) { return f(x) }
fn triple(x) { return x * 3 }
check("fn as value", apply_fn(triple, 10), 30)

// =====================================================================
// SECTION 9: Closures & Lambdas (15 tests)
// =====================================================================
println("")
println("--- 9. Closures ---")

let double_l = |x| x * 2
check("lambda double", double_l(6), 12)

let add_l = |a, b| a + b
check("lambda add", add_l(3, 4), 7)

let identity_l = |x| x
check("lambda identity", identity_l(42), 42)

// Block body lambda
let calc_l = |x, y| {
    let sum = x + y
    return sum * 2
}
check("block lambda", calc_l(3, 4), 14)

// Capture
let factor = 6
let mul_l = |x| x * factor
check("closure capture", mul_l(7), 42)

let base = 100
let offset = 5
let compute_l = |x| base + x * offset
check("closure multi capture", compute_l(3), 115)

// Lambda stored in variable and called
let sq_fn = |z| z * z
check("lambda stored call", sq_fn(5), 25)

// Lambda in array
let ops = [|x| x + 1, |x| x * 2, |x| x - 3]
check("lambda array[0]", ops[0](10), 11)
check("lambda array[1]", ops[1](10), 20)
check("lambda array[2]", ops[2](10), 7)

// Closure returning closure
fn make_adder(n) {
    return |x| x + n
}
let add5 = make_adder(5)
let add10 = make_adder(10)
check("closure factory add5", add5(3), 8)
check("closure factory add10", add10(3), 13)

// Immediate invoke
check("immediate lambda", (|x| x * x)(9), 81)

// Lambda with conditional
let abs_l = |x| { if x < 0 { return 0 - x } else { return x } }
check("lambda abs(-5)", abs_l(-5), 5)

// =====================================================================
// SECTION 10: Match Expression (15 tests)
// =====================================================================
println("")
println("--- 10. Match ---")

let m1 = match 2 {
    1 -> "one",
    2 -> "two",
    3 -> "three",
    _ -> "other"
}
check("match int", m1, "two")

let m2 = match 99 {
    1 -> "one",
    _ -> "default"
}
check("match wildcard", m2, "default")

fn greet_lang(lang) {
    return match lang {
        "en" -> "hello",
        "ko" -> "annyeong",
        "jp" -> "konnichiwa",
        _ -> "hi"
    }
}
check("match str en", greet_lang("en"), "hello")
check("match str ko", greet_lang("ko"), "annyeong")
check("match str default", greet_lang("xx"), "hi")

// Match bool
fn bool_to_str(b) {
    return match b {
        true -> "yes",
        false -> "no"
    }
}
check("match bool true", bool_to_str(true), "yes")
check("match bool false", bool_to_str(false), "no")

// Match with block
let m3 = match 3 {
    1 -> { let a = 10; a + 1 },
    3 -> {
        let a = 100
        let b = 200
        a + b
    },
    _ -> 0
}
check("match block body", m3, 300)

// Match in function
fn day_kind(d) {
    return match d {
        "Mon" -> "weekday",
        "Sat" -> "weekend",
        "Sun" -> "weekend",
        _ -> "weekday"
    }
}
check("match day Mon", day_kind("Mon"), "weekday")
check("match day Sat", day_kind("Sat"), "weekend")

// Match chained
fn letter_grade(s) {
    if s >= 90 { return "A" }
    if s >= 80 { return "B" }
    if s >= 70 { return "C" }
    return "F"
}
check("grade 95", letter_grade(95), "A")
check("grade 85", letter_grade(85), "B")
check("grade 75", letter_grade(75), "C")
check("grade 50", letter_grade(50), "F")

// =====================================================================
// SECTION 11: Struct & Impl (20 tests)
// =====================================================================
println("")
println("--- 11. Struct & Impl ---")

struct Point {
    x: int,
    y: int
}

let p1 = Point { x: 3, y: 4 }
check("struct field x", p1.x, 3)
check("struct field y", p1.y, 4)

struct Person {
    name: string,
    age: int,
    active: bool
}

let alice = Person { name: "Alice", age: 30, active: true }
check("struct name", alice.name, "Alice")
check("struct age", alice.age, 30)
check("struct bool field", alice.active, true)

// Struct in expressions
check("field arith", p1.x + p1.y, 7)
check("field compare", p1.x < p1.y, true)

// Impl methods
struct Rect {
    w: int,
    h: int
}

impl Rect {
    fn area(self) {
        return self.w * self.h
    }
    fn perimeter(self) {
        return 2 * (self.w + self.h)
    }
    fn is_square(self) {
        return self.w == self.h
    }
}

let rect1 = Rect { w: 5, h: 3 }
check("impl area", rect1.area(), 15)
check("impl perimeter", rect1.perimeter(), 16)
check("impl is_square false", rect1.is_square(), false)

let sq = Rect { w: 4, h: 4 }
check("impl is_square true", sq.is_square(), true)

// Impl with params
impl Point {
    fn dist_sq(self, other) {
        let dx = self.x - other.x
        let dy = self.y - other.y
        return dx * dx + dy * dy
    }
    fn to_str(self) {
        return "(" + to_string(self.x) + ", " + to_string(self.y) + ")"
    }
}

let origin = Point { x: 0, y: 0 }
let pt34 = Point { x: 3, y: 4 }
check("impl dist_sq", origin.dist_sq(pt34), 25)
check("impl to_str", pt34.to_str(), "(3, 4)")

// Struct as return
fn make_point(x, y) {
    return Point { x: x, y: y }
}
let mp = make_point(10, 20)
check("struct return x", mp.x, 10)
check("struct return y", mp.y, 20)

// Struct in array
let mut points = []
points.push(Point { x: 1, y: 1 })
points.push(Point { x: 2, y: 4 })
check("struct array len", len(points), 2)
check("struct array field", points[0].x, 1)
check("struct array field2", points[1].y, 4)

// =====================================================================
// SECTION 12: Enum & Pattern Match (10 tests)
// =====================================================================
println("")
println("--- 12. Enum ---")

enum Color { Red, Green, Blue }

let c1 = Color::Red
let c2 = Color::Green
let c3 = Color::Blue
check_bool("enum Red created", true)

fn color_name(c) {
    return match c {
        Color::Red -> "red",
        Color::Green -> "green",
        Color::Blue -> "blue",
        _ -> "unknown"
    }
}
check("enum match Red", color_name(c1), "red")
check("enum match Green", color_name(c2), "green")
check("enum match Blue", color_name(c3), "blue")

// Enum with single payload
enum Shape {
    Circle(Int),
    Unit,
}

fn shape_area(s) {
    return match s {
        Shape::Circle(r) -> r * r * 3,
        Shape::Unit -> 0,
    }
}
check("enum Circle area", shape_area(Shape::Circle(2)), 12)
check("enum Unit area", shape_area(Shape::Unit), 0)

// Enum in array
let shapes = [Shape::Circle(5), Shape::Unit]
check("enum array len", len(shapes), 2)
check("enum array area[0]", shape_area(shapes[0]), 75)
check("enum array area[1]", shape_area(shapes[1]), 0)

