// SECTION 15: String Operations (10 tests)
// =====================================================================
println("")
println("--- 15. Strings ---")

check("str concat", "hello" + " " + "world", "hello world")
check("str len", len("hello"), 5)
check("str empty len", len(""), 0)
check("str eq", "abc" == "abc", true)

let parts = "hello world foo".split(" ")
check("str split len", len(parts), 3)
