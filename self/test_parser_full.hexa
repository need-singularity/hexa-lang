// =====================================================================
// SECTION 16: Try/Catch/Throw (10 tests)
// =====================================================================
println("")
println("--- 16. Try/Catch ---")

let mut tc1 = 0
try {
    tc1 = 42
} catch e {
    tc1 = -1
}
check("try no error", tc1, 42)

let mut tc2 = 0
try {
    throw "boom"
    tc2 = 99
} catch e {
    tc2 = -1
}
check("throw caught", tc2, -1)

let mut tc3 = 0
try {
    tc3 = tc3 + 10
    tc3 = tc3 + 20
    throw "stop"
    tc3 = tc3 + 100
} catch e {
    tc3 = tc3 + 1
}
check("partial + catch", tc3, 31)

fn safe_div(a, b) {
    if b == 0 { throw "div by zero" }
    return a / b
}

let mut tc4 = 0
try { tc4 = safe_div(10, 2) } catch e { tc4 = -1 }
check("safe_div ok", tc4, 5)

let mut tc5 = 0
try { tc5 = safe_div(10, 0) } catch e { tc5 = -1 }
check("safe_div error", tc5, -1)

// Nested try
let mut tc6 = 0
try {
    try {
        throw "inner"
    } catch e {
        tc6 = 1
    }
    tc6 = tc6 + 10
} catch e {
    tc6 = -99
}
check("nested try", tc6, 11)

// Try in loop
let mut tc7 = 0
let mut ti = 0
while ti < 5 {
    try {
        if ti == 3 { throw "skip" }
        tc7 = tc7 + ti
    } catch e {
        // skip
    }
    ti = ti + 1
}
check("try in loop", tc7, 7)

// Catch error message
let mut tc8 = ""
try {
    throw "custom error"
} catch e {
    tc8 = to_string(e)
}
check_bool("catch error msg", len(tc8) > 0)

// Multiple throws pick first
let mut tc9 = 0
try {
    throw "first"
    throw "second"
} catch e {
    tc9 = 1
}
check("first throw caught", tc9, 1)

// Try with no throw in function
fn safe_fn() { return 42 }
let mut tc10 = 0
try { tc10 = safe_fn() } catch e { tc10 = -1 }
check("try safe fn", tc10, 42)

// =====================================================================
// SECTION 17: Scoping (5 tests)
// =====================================================================
println("")
println("--- 17. Scoping ---")

let sc_a = 10
if true {
    let sc_a = 20
    check("inner shadow", sc_a, 20)
}
check("outer preserved", sc_a, 10)

fn scope_test() {
    let local = 42
    return local
}
check("fn scope", scope_test(), 42)

let mut sc_b = 0
let mut sci = 0
while sci < 3 {
    let local = sci * 10
    sc_b = sc_b + local
    sci = sci + 1
}
check("while scope accum", sc_b, 30)

// Closure scope
let outer_val = 99
let sc_fn = |x| x + outer_val
check("closure scope", sc_fn(1), 100)

