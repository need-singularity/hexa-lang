// =====================================================================
// SECTION 19: @attr Attributes (5 tests)
// =====================================================================
println("")
println("--- 19. Attributes ---")

@pure fn attr_square(x: int) -> int { x * x }
check("@pure square", attr_square(7), 49)
check("@pure consistent", attr_square(7) == attr_square(7), true)

@memoize fn attr_fib(n: int) -> int {
    if n <= 1 { return n }
    return attr_fib(n - 1) + attr_fib(n - 2)
}
check("@memoize fib(10)", attr_fib(10), 55)
check("@memoize fib(0)", attr_fib(0), 0)

@inline fn attr_inc(x: int) -> int { x + 1 }
check("@inline inc", attr_inc(41), 42)

// =====================================================================
// SECTION 20: Complex / Combined Patterns (10 tests)
// =====================================================================
println("")
println("--- 20. Combined Patterns ---")

// Fibonacci iterative
fn fib_iter(n) {
    let mut a = 0
    let mut b = 1
    let mut i = 0
    while i < n {
        let temp = a + b
        a = b
        b = temp
        i = i + 1
    }
    return a
}
check("fib_iter(10)", fib_iter(10), 55)
check("fib_iter(0)", fib_iter(0), 0)
check("fib_iter(1)", fib_iter(1), 1)

// Bubble sort
fn bsort(arr) {
    let mut a = []
    let mut i = 0
    while i < len(arr) {
        a.push(arr[i])
        i = i + 1
    }
    let mut n = len(a)
    let mut si = 0
    while si < n {
        let mut sj = 0
        while sj < n - si - 1 {
            if a[sj] > a[sj + 1] {
                let tmp = a[sj]
                a[sj] = a[sj + 1]
                a[sj + 1] = tmp
            }
            sj = sj + 1
        }
        si = si + 1
    }
    return a
}
check("sort result", to_string(bsort([3, 1, 4, 1, 5])), to_string([1, 1, 3, 4, 5]))

// GCD
fn gcd(a, b) {
    if b == 0 { return a }
    return gcd(b, a % b)
}
check("gcd(12,8)", gcd(12, 8), 4)
check("gcd(7,3)", gcd(7, 3), 1)

// Power
fn power(base, exp) {
    let mut result = 1
    let mut i = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}
check("power(2,10)", power(2, 10), 1024)

// Struct + method + closure combined
struct Counter {
    val: int
}

impl Counter {
    fn get(self) { return self.val }
}

let c = Counter { val: 42 }
let getter = |c| c.get()
check("struct+impl+closure", getter(c), 42)

// Map + for + accumulate
let scores = #{"math": 90, "sci": 85, "eng": 95}
let mut total = 0
for k in ["math", "sci", "eng"] {
    total = total + scores[k]
}
check("map accumulate", total, 270)

