// ═══════════════════════════════════════════════════════════════════
//  test_string_ops_suite.hexa — comprehensive string operation tests
//  Covers: len, concat, split, trim, substring, index, comparison
//  Last verified: 2026-04-11
// ═══════════════════════════════════════════════════════════════════

// ── Length ──────────────────────────────────────────────────

proof s001_len_empty { assert "".len() == 0 }
proof s002_len_single { assert "x".len() == 1 }
proof s003_len_abc { assert "abc".len() == 3 }
proof s004_len_hello { assert "hello".len() == 5 }
proof s005_len_hexa { assert "hexa".len() == 4 }
proof s006_len_n6 { assert "nnnnnn".len() == 6 }
proof s007_len_space { assert " ".len() == 1 }
proof s008_len_phrase { assert "hello world".len() == 11 }
proof s009_len_long { assert "0123456789".len() == 10 }
proof s010_len_func { assert len("hexa") == 4 }

// ── Concatenation ───────────────────────────────────────────

proof s011_concat_empty_l { assert "" + "x" == "x" }
proof s012_concat_empty_r { assert "x" + "" == "x" }
proof s013_concat_two { assert "ab" + "cd" == "abcd" }
proof s014_concat_three { assert "a" + "b" + "c" == "abc" }
proof s015_concat_len { assert ("foo" + "bar").len() == 6 }
proof s016_concat_hello { assert "hel" + "lo" == "hello" }
proof s017_concat_space { assert "hi" + " " + "world" == "hi world" }
proof s018_concat_hexa_ns { assert "hexa" + " n=" + "6" == "hexa n=6" }
proof s019_concat_same { assert "x" + "x" == "xx" }
proof s020_concat_long { assert "aa" + "bb" + "cc" + "dd" == "aabbccdd" }

// ── Split ───────────────────────────────────────────────────

proof s021_split_empty_str { assert len("".split(",")) == 1 }
proof s022_split_single { assert len("abc".split(",")) == 1 }
proof s023_split_two { assert len("a,b".split(",")) == 2 }
proof s024_split_three { assert len("a,b,c".split(",")) == 3 }
proof s025_split_hexa { assert len("h.e.x.a".split(".")) == 4 }
proof s026_split_first { assert "a,b,c".split(",")[0] == "a" }
proof s027_split_middle { assert "a,b,c".split(",")[1] == "b" }
proof s028_split_last { assert "a,b,c".split(",")[2] == "c" }
proof s029_split_space { assert len("a b c d".split(" ")) == 4 }
proof s030_split_n6 { assert len("1 2 3 4 5 6".split(" ")) == 6 }

// ── Trim ────────────────────────────────────────────────────

proof s031_trim_none { assert "abc".trim() == "abc" }
proof s032_trim_left { assert "  abc".trim() == "abc" }
proof s033_trim_right { assert "abc  ".trim() == "abc" }
proof s034_trim_both { assert "  abc  ".trim() == "abc" }
proof s035_trim_only_space { assert "   ".trim() == "" }
proof s036_trim_empty { assert "".trim() == "" }
proof s037_trim_middle_keep { assert "  a b c  ".trim() == "a b c" }
proof s038_trim_tab { assert "\tx\t".trim() == "x" }
proof s039_trim_newline { assert "\ny\n".trim() == "y" }
proof s040_trim_len { assert "  z  ".trim().len() == 1 }

// ── Comparison ──────────────────────────────────────────────

proof s041_eq_same { assert "abc" == "abc" }
proof s042_eq_empty { assert "" == "" }
proof s043_ne_diff { assert "abc" != "abd" }
proof s044_ne_len { assert "ab" != "abc" }
proof s045_case_sensitive { assert "ABC" != "abc" }
proof s046_eq_hexa { assert "hexa" == "hexa" }
proof s047_ne_prefix { assert "hex" != "hexa" }
proof s048_ne_suffix { assert "exa" != "hexa" }
proof s049_eq_space { assert " " == " " }
proof s050_ne_space_empty { assert " " != "" }

// ── to_string / conversion ──────────────────────────────────

proof s051_to_string_0 { assert to_string(0) == "0" }
proof s052_to_string_6 { assert to_string(6) == "6" }
proof s053_to_string_12 { assert to_string(12) == "12" }
proof s054_to_string_neg { assert to_string(0 - 5) == "-5" }
proof s055_to_string_big { assert to_string(1000) == "1000" }
proof s056_concat_int { assert "n=" + to_string(6) == "n=6" }
proof s057_concat_sigma { assert "sigma(" + to_string(6) + ")=" + to_string(12) == "sigma(6)=12" }
proof s058_str_repr_24 { assert to_string(24) == "24" }
proof s059_str_repr_36 { assert to_string(36) == "36" }
proof s060_str_repr_120 { assert to_string(120) == "120" }

// ── Substring / indexing (if available) ─────────────────────

proof s061_substring_full { assert "hexa".substring(0, 4) == "hexa" }
proof s062_substring_first { assert "hexa".substring(0, 1) == "h" }
proof s063_substring_last { assert "hexa".substring(3, 4) == "a" }
proof s064_substring_mid { assert "hexa".substring(1, 3) == "ex" }
proof s065_substring_empty { assert "hexa".substring(2, 2) == "" }

// ── Contains ────────────────────────────────────────────────

proof s066_contains_self { assert "hexa".contains("hexa") }
proof s067_contains_prefix { assert "hexa".contains("hex") }
proof s068_contains_suffix { assert "hexa".contains("exa") }
proof s069_contains_middle { assert "hexa".contains("ex") }
proof s070_contains_single { assert "hexa".contains("h") }
proof s071_not_contains { assert !"hexa".contains("z") }
proof s072_not_contains_longer { assert !"abc".contains("abcd") }
proof s073_contains_empty { assert "hexa".contains("") }
proof s074_contains_space { assert "a b".contains(" ") }
proof s075_contains_phrase { assert "hello world".contains("world") }

// ── Replace ─────────────────────────────────────────────────

proof s076_replace_simple { assert "hexa".replace("h", "H") == "Hexa" }
proof s077_replace_none { assert "abc".replace("x", "y") == "abc" }
proof s078_replace_empty_target { assert "abc".replace("", "") == "abc" }
proof s079_replace_full { assert "hexa".replace("hexa", "HEXA") == "HEXA" }
proof s080_replace_multi { assert "aaa".replace("a", "b") == "bbb" }

println("[test_string_ops_suite] 80 proofs declared — run with --test")
