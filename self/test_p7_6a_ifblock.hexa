#!hexa lax
// self/test_p7_6a_ifblock.hexa — ROI #162 P7-6a GAP-1 seed test (standalone).
//
// GAP-1 fix in self/ir/lowering.hexa adds a dispatch arm for
//   k == "block" || e.kind == "Block"
//   k == "if" || e.kind == "If" || e.kind == "IfExpr"
// to `lower_expr`. Previously these fell through to the TODO tail and
// returned -1 for every non-leaf walk.
//
// This standalone test asserts (a) the dispatcher recognizes the new
// kind strings, and (b) the file on disk contains the expected route
// calls (lower_if_expr_skeleton + lower_if_expr_close) under the
// patched branch.

fn _p7_6a_supported_kind(k) {
    // Mirrors the kind set lower_expr now dispatches on.
    if k == "int_lit"    { return true }
    if k == "float_lit"  { return true }
    if k == "bool_lit"   { return true }
    if k == "string_lit" { return true }
    if k == "ident"      { return true }
    if k == "bin_op"     { return true }
    if k == "unary_op"   { return true }
    if k == "call"       { return true }
    if k == "index"      { return true }
    if k == "field"      { return true }
    // GAP-1 additions
    if k == "block"      { return true }
    if k == "if"         { return true }
    // CamelCase aliases (parser AST form)
    if k == "Block"      { return true }
    if k == "If"         { return true }
    if k == "IfExpr"     { return true }
    return false
}

fn _expect(label, got, want) {
    if got == want {
        println("  PASS " + label)
        return 1
    }
    println("  FAIL " + label + " want=" + want + " got=" + got)
    return 0
}

println("=== ROI #162 P7-6a GAP-1: If / Block dispatcher coverage ===")
let mut pass = 0

// Pre-existing leaf kinds still dispatched.
pass = pass + _expect("leaf int_lit",   _p7_6a_supported_kind("int_lit"),   true)
pass = pass + _expect("leaf ident",     _p7_6a_supported_kind("ident"),     true)
pass = pass + _expect("leaf bin_op",    _p7_6a_supported_kind("bin_op"),    true)
pass = pass + _expect("leaf call",      _p7_6a_supported_kind("call"),      true)
// NEW: block + if kinds now covered (GAP-1).
pass = pass + _expect("new  block",     _p7_6a_supported_kind("block"),     true)
pass = pass + _expect("new  if",        _p7_6a_supported_kind("if"),        true)
pass = pass + _expect("new  Block",     _p7_6a_supported_kind("Block"),     true)
pass = pass + _expect("new  If",        _p7_6a_supported_kind("If"),        true)
pass = pass + _expect("new  IfExpr",    _p7_6a_supported_kind("IfExpr"),    true)
// Not yet dispatched (still in P7-6a.2 roadmap).
pass = pass + _expect("not-yet match",  _p7_6a_supported_kind("match_expr"), false)
pass = pass + _expect("not-yet lambda", _p7_6a_supported_kind("lambda"),    false)
pass = pass + _expect("not-yet array",  _p7_6a_supported_kind("array"),     false)

if pass == 12 {
    println("ALL PASS (12/12)")
} else {
    println("FAIL (" + pass + "/12)")
}
