// ═══════════════════════════════════════════════════════════════════
//  test_tensor_shape.hexa — scaffold tests for ROI #175
//  Verifies @tensor<N,D,...> shape-annotation parsing + minimal type check.
// ═══════════════════════════════════════════════════════════════════

// Pull in the module under test.
use "self/parser_tensor_shape"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name
            + " — expected: " + to_string(expected)
            + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_true(name, val) {
    check(name, val, true)
}

fn check_false(name, val) {
    check(name, val, false)
}

println("═══════════════════════════════════════════════════════")
println("  ROI #175: @tensor<N,D> shape-annotation parser")
println("═══════════════════════════════════════════════════════")
println("")

// ── Case 1: symbolic 2-D shape ──────────────────────────────────────
let n1 = tensor_shape_parse("N, D")
let n1c = tensor_shape_check(n1)
check("1a.kind",      n1c.kind, "TensorShape")
check("1b.rank",      n1c.rank, 2)
check("1c.dims[0]",   n1c.dims[0], "N")
check("1d.dims[1]",   n1c.dims[1], "D")
check("1e.kind[0]",   n1c.dim_kinds[0], "ident")
check("1f.kind[1]",   n1c.dim_kinds[1], "ident")
check_true("1g.ok",   n1c.ok)
check("1h.display",   tensor_shape_to_string(n1c), "@tensor<N,D>")

// ── Case 2: fully concrete shape ────────────────────────────────────
let n2 = tensor_shape_check(tensor_shape_parse("3, 4"))
check("2a.rank",      n2.rank, 2)
check("2b.kind[0]",   n2.dim_kinds[0], "int")
check("2c.kind[1]",   n2.dim_kinds[1], "int")
check_true("2d.ok",   n2.ok)

// ── Case 3: rank-3 batch-seq-dim ────────────────────────────────────
let n3 = tensor_shape_check(tensor_shape_parse("B, S, D"))
check("3a.rank",      n3.rank, 3)
check_true("3b.ok",   n3.ok)

// ── Case 4: dynamic dim ('?') ───────────────────────────────────────
let n4 = tensor_shape_check(tensor_shape_parse("N, ?"))
check("4a.rank",      n4.rank, 2)
check("4b.kind[1]",   n4.dim_kinds[1], "dyn")
check_true("4c.ok",   n4.ok)

// ── Case 5: parse from head form "@tensor<N,D>" ─────────────────────
let h1 = tensor_shape_parse_head("@tensor<N, D>")
check("5a.kind",      h1.kind, "TensorShape")
check("5b.rank",      h1.rank, 2)
check_true("5c.ok",   h1.ok)

// ── Case 6: error — bad token ───────────────────────────────────────
let bad = tensor_shape_parse("N, 2x")
let badc = tensor_shape_check(bad)
check_false("6a.ok",  badc.ok)
check_true("6b.has_err", len(badc.errors) > 0)

// ── Case 7: error — empty inner ─────────────────────────────────────
let empty = tensor_shape_check(tensor_shape_parse(""))
check_false("7a.ok",  empty.ok)

// ── Case 8: error — missing '>' in head form ────────────────────────
let h_bad = tensor_shape_parse_head("@tensor<N,D")
check_false("8a.ok",  h_bad.ok)

// ── Case 9: rank equality predicate ─────────────────────────────────
let a = tensor_shape_check(tensor_shape_parse("N, D"))
let b = tensor_shape_check(tensor_shape_parse("B, S"))
let c = tensor_shape_check(tensor_shape_parse("X, Y, Z"))
check_true("9a.rank_eq.match",   tensor_shape_rank_eq(a, b))
check_false("9b.rank_eq.mismatch", tensor_shape_rank_eq(a, c))

// ── summary ─────────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Summary: " + to_string(pass_count) + " passed, "
    + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("FAIL")
} else {
    println("OK")
}
