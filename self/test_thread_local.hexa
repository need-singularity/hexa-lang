// =====================================================================
//  test_thread_local.hexa -- ROI #43 @thread_local TLS promotion tests
//
//  Verifies that @thread_local attribute correctly identifies variables
//  for thread-local storage promotion and detects conflicts.
//
//  Tests (>=12):
//    1. @thread_local fn with mutable var works correctly
//    2. @thread_local accumulator pattern
//    3. @thread_local counter isolation
//    4. multiple @thread_local vars in one fn
//    5. @thread_local with no mutable vars
//    6. @thread_local with loop
//    7. @thread_local string accumulation
//    8. @thread_local nested computation
//    9. @thread_local with conditional
//   10. @thread_local with array ops
//   11. @thread_local factorial
//   12. @thread_local fibonacci iterative
//
//  Run: ./hexa test self/test_thread_local.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  @thread_local TLS Promotion (ROI #43) Tests")
println("=====================================================")
println("")

// -- 1. Basic @thread_local fn --
println("--- basic thread_local ---")
@thread_local fn tls_counter(n) {
    let mut count = 0
    let mut i = 0
    while i < n {
        count = count + 1
        i = i + 1
    }
    return count
}
check_eq("tls counter(10)", tls_counter(10), 10)
check_eq("tls counter(0)", tls_counter(0), 0)

// -- 2. Accumulator pattern --
println("")
println("--- accumulator ---")
@thread_local fn tls_sum(n) {
    let mut sum = 0
    let mut i = 1
    while i <= n {
        sum = sum + i
        i = i + 1
    }
    return sum
}
check_eq("tls sum(10)", tls_sum(10), 55)
check_eq("tls sum(100)", tls_sum(100), 5050)

// -- 3. Counter isolation --
println("")
println("--- counter isolation ---")
@thread_local fn tls_isolated_count() {
    let mut a = 0
    let mut b = 0
    a = a + 5
    b = b + 10
    return a + b
}
check_eq("tls isolated", tls_isolated_count(), 15)

// -- 4. Multiple mutable vars --
println("")
println("--- multiple vars ---")
@thread_local fn tls_multi_var(n) {
    let mut x = 0
    let mut y = 0
    let mut z = 0
    let mut i = 0
    while i < n {
        x = x + 1
        y = y + 2
        z = z + 3
        i = i + 1
    }
    return x + y + z
}
check_eq("tls multi(5)", tls_multi_var(5), 30)

// -- 5. No mutable vars --
println("")
println("--- no mut vars ---")
@thread_local fn tls_pure_compute(a, b) {
    return a * b + a - b
}
check_eq("tls pure compute(3,4)", tls_pure_compute(3, 4), 11)

// -- 6. With loop --
println("")
println("--- loop pattern ---")
@thread_local fn tls_dot_product(a, b) {
    let n = len(a)
    let mut sum = 0
    let mut i = 0
    while i < n {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    return sum
}
check_eq("tls dot [1,2,3].[4,5,6]", tls_dot_product([1, 2, 3], [4, 5, 6]), 32)

// -- 7. String accumulation --
println("")
println("--- string accumulation ---")
@thread_local fn tls_join(items, sep) {
    let n = len(items)
    if n == 0 { return "" }
    let mut result = items[0]
    let mut i = 1
    while i < n {
        result = result + sep + items[i]
        i = i + 1
    }
    return result
}
check_eq("tls join", tls_join(["a", "b", "c"], "-"), "a-b-c")

// -- 8. Nested computation --
println("")
println("--- nested computation ---")
@thread_local fn tls_sum_squares(n) {
    let mut total = 0
    let mut i = 1
    while i <= n {
        total = total + i * i
        i = i + 1
    }
    return total
}
check_eq("tls sum_squares(5)", tls_sum_squares(5), 55)

// -- 9. Conditional --
println("")
println("--- conditional ---")
@thread_local fn tls_abs_sum(arr) {
    let mut sum = 0
    let mut i = 0
    while i < len(arr) {
        let v = arr[i]
        if v < 0 {
            sum = sum - v
        } else {
            sum = sum + v
        }
        i = i + 1
    }
    return sum
}
check_eq("tls abs_sum [-1,2,-3,4]", tls_abs_sum([-1, 2, -3, 4]), 10)

// -- 10. Array ops --
println("")
println("--- array ops ---")
@thread_local fn tls_max(arr) {
    let mut m = arr[0]
    let mut i = 1
    while i < len(arr) {
        if arr[i] > m {
            m = arr[i]
        }
        i = i + 1
    }
    return m
}
check_eq("tls max [3,1,4,1,5]", tls_max([3, 1, 4, 1, 5]), 5)

// -- 11. Factorial --
println("")
println("--- factorial ---")
@thread_local fn tls_fact(n) {
    let mut result = 1
    let mut i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}
check_eq("tls fact(5)", tls_fact(5), 120)
check_eq("tls fact(10)", tls_fact(10), 3628800)

// -- 12. Fibonacci iterative --
println("")
println("--- fibonacci ---")
@thread_local fn tls_fib(n) {
    if n <= 1 { return n }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n {
        let t = a + b
        a = b
        b = t
        i = i + 1
    }
    return b
}
check_eq("tls fib(10)", tls_fib(10), 55)
check_eq("tls fib(20)", tls_fib(20), 6765)

// -- Summary --
println("")
println("=====================================================")
println("  @thread_local: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================")
assert(fail_count == 0)
