// self/attrs/exitcodes.hexa — @exit_codes meta attr (process exit-code semantics)
//
// PURPOSE
//   Optional companion to @tool: documents what each exit code from this
//   tool means (e.g. "0=PASS, 1=FAIL"). Free-form text, captured verbatim.
//
// FORM
//   @exit_codes(<free-form text>)
//
// NAMING
//   The attr is exposed as `@exit_codes` (with underscore) at the call site
//   for readability — manifest_scan recognizes the underscore form. Internal
//   meta/check fn names use `exitcodes` (no underscore) to satisfy
//   self/attrs/_naming.hexa (single-word lowercase requirement).

use "self/attrs/core"

fn meta_exitcodes() {
    let mut m = empty_meta()
    m.name = "exitcodes"
    m.category = "meta"
    m.purpose = "exit-code semantics doc for @tool entries — free-form, captured verbatim"
    m.cost_rule = "@exit_codes(<text>) — single line; e.g. '0=PASS, 1=FAIL'"
    m.example = "// @exit_codes(0=PASS, 1=violations found)"
    m.implemented = false
    return m
}

fn check_exitcodes(source: string, lines: [string]) {
    return []
}
