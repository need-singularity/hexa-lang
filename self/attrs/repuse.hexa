// self/attrs/repuse.hexa — @repuse hostname-allowlist guard
//
// 부착된 함수는 허용된 호스트 (ubu/ubu2/hetzner/htz/runpod) 외에서
// 실행 시 refuse. Mac/local 차단이 @refuse 의 Darwin-only 가드보다
// 더 정확한 dispatch 강제 — Darwin 아닌 로컬(e.g. WSL dev-box)도 막음.
//
// 동작: runtime 진입 시 hostname -s 검사 → allowlist 비교.
//       우회: HEXA_REPUSE_OK=1 또는 HEXA_HOST_CLASS=remote.
//
// 구현: fn_attrs_set 에서 bit 16 (65536) 세팅 →
//       call_fn pre-body gate 가 host_name_short() + repuse_host_allowed()
//       로 검사 후 throw.

use "self/attrs/core"

fn meta_repuse() -> AttrMeta {
    let mut m = empty_meta()
    m.name        = "repuse"
    m.category    = "platform"
    m.purpose     = "hostname allowlist — 원격 호스트 (ubu/ubu2/htz/runpod) 에서만 실행 허용"
    m.cost_rule   = "runtime 진입 시 hostname -s 검사 → 허용 외 exit(77)"
    m.side_effect = "허용 외 호스트에서 refuse — dispatch 강제"
    m.requires    = "host_name_short() + repuse_host_allowed() helpers (hexa_full)"
    m.auto_test   = "Mac 에서 @repuse fn 호출 → throw; HEXA_REPUSE_OK=1 우회 → 실행"
    m.example     = "@repuse\nfn heavy_train() { /* ubu 전용 */ }"
    m.implemented = true
    return m
}

// Runtime attr — source-level static check 는 no-op.
// 실제 enforcement 는 call_fn pre-body bit 16 gate 가 담당.
fn check_repuse(source: string, lines: [string]) {
    return []
}
