// self/attrs/parallel.hexa — for-loop body has no cross-iter dep → parallelizable

use "self/attrs/core"

fn meta_parallel() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "parallel"
    m.category = "performance"
    m.purpose = "for-loop body has no cross-iter dependency → parallelizable"
    m.cost_rule = "n >= 2 * core_count AND body_time > dispatch_overhead (~5us)"
    m.auto_test = "serial vs parallel result equality check"
    m.example = "@parallel\nfor x in xs { process(x) }"
    return m
}

fn check_parallel(source: string, lines: [string]) {
    return []
}
