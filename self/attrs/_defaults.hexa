// self/attrs/_defaults.hexa — HX11 (갱신안) 전역 default 규칙 (Phase 3 에서 채움)
//
// 이 파일은 project.hexa 와 동일한 `@<attr>_rules[(selector)]` + `let _<name> = #{...}`
// 문법을 사용한다. project.hexa 에 매칭 블록이 없을 때 find_attr_rules_v2 가
// 이 파일을 parse_project_hexa_file 로 읽어 2차 fallback 을 제공한다.
//
// Phase 1 (본 세션) 은 스텁만 제공하여 find_global_defaults() 가 정상 동작하도록
// 한다. 실제 default 는 Phase 3 에서 nexus/shared/config/*.json 5 종을 여기로
// 이관하며 채운다.
//
// 예시 (주석 처리 — 실제 활성화는 Phase 3):
//
//   @doc_rules(type="paper")
//   let _doc_rules_paper = #{
//       "sections": ["WHY", "COMPARE", "REQUIRES", "STRUCT", "FLOW", "EVOLVE", "VERIFY"],
//       "require_ascii_check": false,
//       "require_verify": false,
//       "require_mk_history": false
//   }
//
//   @readme_rules(scope="root")
//   let _readme_rules_root = #{
//       "sections": ["Overview", "Install", "Usage", "License"],
//       "require_codeblock": false,
//       "require_sealed": false
//   }

// Phase 1 placeholder — intentionally empty.
// find_attr_rules_v2 가 이 파일에서 블록 0 개 읽으면 legacy JSON 폴백으로 넘어간다.

@rules_meta
let _rules_meta = #{
    "inherit": false,
    "version": 0,
    "updated": "2026-04-18",
    "status": "stub",
    "note": "Phase 1 scaffold. Phase 3 에서 nexus/shared/config/*.json 5종 이관 예정."
}
