// self/attrs/stable.hexa — @stable evolution attr
// redefinition warning — API ossified

use "self/attrs/core"

fn meta_stable() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "stable"
    m.category = "evolution"
    m.purpose = "API 골화 선언 — redefinition 시 경고, signature 변경 금지"
    m.cost_rule = "signature 해시 변경 감지 시 warn; 삭제 시 error"
    m.side_effect = "downstream 브레이킹 체인지 방지"
    m.auto_test = "signature diff — 이전 해시와 다르면 violation"
    m.example = "@stable\npub fn exported_api(x: int) -> int { return x }"
    m.implemented = true
    return m
}

// @stable fn 은 pub 이어야 유의미 — private stable 은 의미 없음
fn check_stable(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "stable")
    for pair in pairs {
        let attr_line = pair[0]
        let fn_line = pair[1]
        let idx = fn_line - 1
        if idx < 0 || idx >= len(lines) { continue }
        let t = trim(lines[idx])
        if !starts_with(t, "pub ") && !contains(t, " pub ") {
            out = out.push(mk_msg("stable", "warn", attr_line,
                "@stable on non-pub fn has no effect (no external callers to protect)"))
        }
    }
    return out
}
