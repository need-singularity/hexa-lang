// self/attrs/example.hexa — @example meta attr (free-form usage scenario)
//
// PURPOSE
//   Optional companion to @tool: a representative scenario describing
//   when/why the tool is invoked. Free-form text, captured verbatim.
//
// FORM
//   @example(<free-form text>)
//
// CONVENTION
//   · Optional. One @example per @tool max (first occurrence wins).
//   · Free-form prose; manifest_scan emits the captured text into
//     manifest.json `example` field.

use "self/attrs/core"

fn meta_example() {
    let mut m = empty_meta()
    m.name = "example"
    m.category = "meta"
    m.purpose = "free-form usage scenario for @tool entries — optional companion to @usage"
    m.cost_rule = "@example(<text>) — free-form, single line"
    m.example = "// @example(run pre-commit to catch missing frontmatter on new docs/**/*.md files)"
    m.implemented = false
    return m
}

fn check_example(source: string, lines: [string]) {
    return []
}
