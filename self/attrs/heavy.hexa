// self/attrs/heavy.hexa — @heavy advisory attr
//
// 부착된 함수는 >1GB RSS 또는 >30s 실행 가능성 선언.
// 파서/린터가 Mac 로컬 실행 경로에서 만나면 경고 (refuse 는 @refuse 책임).
//
// 목적:
//   (1) RSS/time budget 예측 — 호출자가 dispatch 결정을 내릴 때 힌트
//   (2) @refuse 없이 선언만으로도 코드 리딩 시 "주의" 신호
//   (3) 향후 profile/limit attr 과 결합하여 자동 원격 dispatch 트리거
//
// Phase B (2026-04-20): AUTO-IMPLY — fn_attrs_set 에서 @heavy 감지 시
// @refuse + @watchdog bits 를 자동 세팅. 이제 @heavy 만 붙여도
// Mac 차단 + RSS/time cap 동시 적용. 별도 @refuse 작성 불필요.

use "self/attrs/core"

fn meta_heavy() -> AttrMeta {
    let mut m = empty_meta()
    m.name        = "heavy"
    m.category    = "performance"
    m.purpose     = "heavy compute 선언 — RSS/time budget 예측 가능하게 힌트"
    m.cost_rule   = "RSS > 1GB OR wall > 30s 예상 시 부착 — Mac 로컬 실행 비권장"
    m.side_effect = "advisory only — refuse 동작 없음 (@refuse 조합 권장)"
    m.requires    = "없음 (선언적 마커)"
    m.auto_test   = "profile 결과와 교차 검증 — 부착된 fn 중 80%+ 가 실제 RSS>1GB 충족"
    m.example     = "@heavy\n@refuse\nfn native_compile_all() { /* ... */ }"
    m.implemented = true
    return m
}

// Advisory attr — static check 는 no-op.
fn check_heavy(source: string, lines: [string]) {
    return []
}
