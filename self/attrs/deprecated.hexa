// self/attrs/deprecated.hexa — warn on call, API planned for removal

use "self/attrs/core"

fn meta_deprecated() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "deprecated"
    m.category = "evolution"
    m.purpose = "warn on call — API planned for removal"
    m.example = "@deprecated(since=\"0.9\", use=\"new_fn\")\nfn old_fn() { ... }"
    return m
}

fn check_deprecated(source: string, lines: [string]) {
    return []
}
