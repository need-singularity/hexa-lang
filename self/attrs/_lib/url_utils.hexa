// self/attrs/_lib/url_utils.hexa — github URL 검증 + git tag 파싱

use "self/attrs/core"

// github.com/{org}/{repo}/blob/{tag}/{path} 형식 검증
fn is_github_blob_url(url: string) {
    if !url.starts_with("https://github.com/") { return false }
    if !url.contains("/blob/") { return false }
    return true
}

// github.com/{org}/{repo}/compare/{tagA}...{tagB} 형식 검증
fn is_github_compare_url(url: string) {
    if !url.starts_with("https://github.com/") { return false }
    if !url.contains("/compare/") { return false }
    if !url.contains("...") { return false }
    return true
}

// github.com/{org}/{repo}/releases/tag/{tag} 형식 검증
fn is_github_release_url(url: string) {
    if !url.starts_with("https://github.com/") { return false }
    if !url.contains("/releases/tag/") { return false }
    return true
}

// URL 에서 git tag 추출 (blob 또는 releases/tag)
fn extract_git_tag(url: string) {
    let blob_idx = url.index_of("/blob/")
    if blob_idx >= 0 {
        let after = url.substring(blob_idx + 6, len(url))
        let slash = after.index_of("/")
        if slash >= 0 { return after.substring(0, slash) }
        return after
    }
    let rel_idx = url.index_of("/releases/tag/")
    if rel_idx >= 0 {
        let after = url.substring(rel_idx + 14, len(url))
        let slash = after.index_of("/")
        if slash >= 0 { return after.substring(0, slash) }
        return after
    }
    return ""
}

// 로컬 git tag 존재 확인 (offline 모드 호환)
// offline=true 면 skip (remote ls-remote 안 씀)
fn git_tag_exists_local(tag: string) {
    let out = to_string(exec("git tag --list '" + tag + "' 2>/dev/null")).trim()
    return out == tag
}
