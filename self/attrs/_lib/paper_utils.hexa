// self/attrs/_lib/paper_utils.hexa — paper/doc 공통 primitive
// 다른 attr 재사용 가능 (holographic — bulk 공유)

use "self/attrs/core"

// 라인 배열에서 `## SECTION` 헤더 존재 여부
fn has_section(lines, section_name: string) {
    let pattern = "## " + section_name
    for line in lines {
        let t = line.trim()
        if t.starts_with(pattern) { return true }
        if t.starts_with("## §") && t.contains(section_name) { return true }
    }
    return false
}

// 섹션 body 라인 범위: [start_1based, end_1based]
// start = 해당 ## 라인 다음, end = 다음 ## 또는 파일 끝
fn section_body_range(lines, section_name: string) {
    let mut i = 0
    let mut found_start = -1
    let mut found_end = len(lines)
    for line in lines {
        i = i + 1
        let t = line.trim()
        if found_start < 0 {
            if t.starts_with("## ") && t.contains(section_name) {
                found_start = i + 1
            }
        } else {
            if t.starts_with("## ") {
                found_end = i - 1
                break
            }
        }
    }
    return [found_start, found_end]
}

// 섹션 본문 비어있지 않은 라인 수
fn count_body_lines(lines, section_name: string) {
    let range = section_body_range(lines, section_name)
    let start = range[0]
    let end = range[1]
    if start < 0 { return 0 }
    let mut count = 0
    let mut i = start
    while i <= end && i <= len(lines) {
        let idx = i - 1
        if idx >= 0 && idx < len(lines) {
            let t = lines[idx].trim()
            if t != "" && !t.starts_with("//") { count = count + 1 }
        }
        i = i + 1
    }
    return count
}

// 특정 문자 N개 이상 등장 감지 (바차트 █, 화살표 → 등)
fn count_char_in_lines(lines, ch: string) {
    let mut total = 0
    for line in lines {
        let mut i = 0
        let n = len(line)
        while i < n {
            if line.substring(i, i+1) == ch { total = total + 1 }
            i = i + 1
        }
    }
    return total
}

// 파이썬 블록 개수
fn count_python_blocks(lines) {
    let mut count = 0
    let mut inside = false
    for line in lines {
        let t = line.trim()
        if t.starts_with("```python") { inside = true; count = count + 1 }
        else if t == "```" && inside { inside = false }
    }
    return count
}

// frontmatter (---...---) 내 key: value 추출
fn frontmatter_get(lines, key: string) {
    if len(lines) < 2 { return "" }
    let first = lines[0].trim()
    if first != "---" { return "" }
    let mut i = 1
    while i < len(lines) {
        let t = lines[i].trim()
        if t == "---" { break }
        let colon = t.index_of(":")
        if colon > 0 {
            let k = t.substring(0, colon).trim()
            if k == key {
                return t.substring(colon + 1, len(t)).trim()
            }
        }
        i = i + 1
    }
    return ""
}

// 체크박스 `- [ ]` / `- [x]` 개수
fn count_checkboxes(lines) {
    let mut count = 0
    for line in lines {
        let t = line.trim()
        if t.starts_with("- [ ]") || t.starts_with("- [x]") || t.starts_with("- [X]") {
            count = count + 1
        }
    }
    return count
}
