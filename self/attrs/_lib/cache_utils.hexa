// self/attrs/_lib/cache_utils.hexa — lint 결과 캐싱 (mtime/hash 기반)
// 비싼 check (python 실행, 원격 URL, 대용량 md) 결과 .attr-generated/_cache.json 에 저장

use "self/attrs/core"

// 파일 mtime 획득 (linux/mac 호환)
fn file_mtime(path: string) {
    let linux = to_string(exec("stat -c %Y '" + path + "' 2>/dev/null")).trim()
    if linux != "" { return linux }
    let mac = to_string(exec("stat -f %m '" + path + "' 2>/dev/null")).trim()
    return mac
}

// 파일 SHA256 hash (앞 12자)
// Precedence swap (ω-runner-2 2026-04-26): prefer sha256sum (linux
// coreutils — present in hexa-runner image post-perl-removal), fall
// back to `shasum -a 256` (macOS default — perl/Digest::SHA).
fn file_hash_short(path: string) {
    let out = to_string(exec("sha256sum '" + path + "' 2>/dev/null | cut -c1-12")).trim()
    if out != "" { return out }
    let alt = to_string(exec("shasum -a 256 '" + path + "' 2>/dev/null | cut -c1-12")).trim()
    return alt
}

// 캐시 hit 여부 — path 의 mtime 이 cached_mtime 이상이면 stale
fn cache_stale(path: string, cached_mtime: string) {
    let current = file_mtime(path)
    if current == "" || cached_mtime == "" { return true }
    return current != cached_mtime
}

// 캐시 파일 경로 (.attr-generated/_cache.json)
fn cache_path(project_root: string) {
    return project_root + "/.attr-generated/_cache.json"
}
