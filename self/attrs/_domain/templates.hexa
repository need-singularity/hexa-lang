// self/attrs/_domain/templates.hexa — 21 섹션 + verify_py + mk_details + CLAUDE.md
//
// 모든 템플릿은 string 반환. parts 배열 + .join("") 사용 (PERF 101 회피).
//
// ctx 구조 (AttrMeta 와 별도):
//   ctx.id            string  — 도메인 slug (e.g. "sscb", "dog-robot")
//   ctx.axis          string  — 10축 중 하나
//   ctx.name_ko       string  — 한글 이름
//   ctx.intent        string  — "create" | "update" | "auto"
//   ctx.product_line  string  — 제품 라인 이름 (기본 = name_ko)
//   ctx.mk_target     string  — "mk1" | "mk2" ...
//   ctx.alien_now     int
//   ctx.alien_target  int
//   ctx.prev_tag      string  — update 시 이전 git tag (optional)
//   ctx.requires      [string]— 선행 도메인 id 목록 (optional)
//   ctx.repo_owner    string  — github owner (기본 "dancinlife")
//   ctx.repo_name     string  — github repo (기본 "n6-architecture")

use "self/attrs/core"
use "self/attrs/_domain/axes"

// ctx 기본값 보정
fn _ctx_or_default(ctx) {
    let mut m = #{}
    m["id"] = if has_key(ctx, "id") { ctx["id"] } else { "unknown" }
    m["axis"] = if has_key(ctx, "axis") { ctx["axis"] } else { "compute" }
    m["name_ko"] = if has_key(ctx, "name_ko") { ctx["name_ko"] } else { m["id"] }
    m["intent"] = if has_key(ctx, "intent") { ctx["intent"] } else { "create" }
    m["product_line"] = if has_key(ctx, "product_line") { ctx["product_line"] } else { m["name_ko"] }
    m["mk_target"] = if has_key(ctx, "mk_target") { ctx["mk_target"] } else { "mk1" }
    m["alien_now"] = if has_key(ctx, "alien_now") { ctx["alien_now"] } else { 7 }
    m["alien_target"] = if has_key(ctx, "alien_target") { ctx["alien_target"] } else { 10 }
    m["prev_tag"] = if has_key(ctx, "prev_tag") { ctx["prev_tag"] } else { "" }
    m["requires"] = if has_key(ctx, "requires") { ctx["requires"] } else { [] }
    m["repo_owner"] = if has_key(ctx, "repo_owner") { ctx["repo_owner"] } else { "dancinlife" }
    m["repo_name"] = if has_key(ctx, "repo_name") { ctx["repo_name"] } else { "n6-architecture" }
    return m
}

// ─────────────────────────────────────────────────────────────────────────
// Frontmatter + 헤더
// ─────────────────────────────────────────────────────────────────────────

fn tmpl_frontmatter(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("<!-- gold-standard: shared/harness/sample.md -->\n")
    parts.push("<!-- @doc(type=paper) -->\n")
    parts.push("---\n")
    parts.push("domain: " + c["id"] + "\n")
    parts.push("alien_index_current: " + to_string(c["alien_now"]) + "\n")
    parts.push("alien_index_target: " + to_string(c["alien_target"]) + "\n")
    parts.push("requires:\n")
    let reqs = c["requires"]
    if len(reqs) == 0 {
        parts.push("  - to: TODO-선행도메인-id\n")
        parts.push("    alien_min: 7\n")
        parts.push("    reason: TODO 선행 이유 (왜 필요한가)\n")
    } else {
        for r in reqs {
            parts.push("  - to: " + r + "\n")
            parts.push("    alien_min: 7\n")
            parts.push("    reason: TODO 선행 이유\n")
        }
    }
    parts.push("---\n\n")
    return parts.join("")
}

fn tmpl_title(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("# 궁극의 " + c["name_ko"] + " " + c["mk_target"] + " (HEXA-")
    parts.push(c["id"].to_upper() + ") — n=6 산술 설계\n\n")
    parts.push("> 한 문장 요약: **σ(6)=12, τ(6)=4, φ(6)=2, sopfr(6)=5** 네 상수가 ")
    parts.push(c["name_ko"] + " 의 핵심 스펙을 관통한다.\n\n")
    parts.push("> 이 문서는 브리프(§1~§7) + 엔지니어링 패키지(§8~§20) + 임팩트(§21) 를\n")
    parts.push("> 하나의 canonical 문서로 통합한다. `@doc(type=paper)` 규칙 준수.\n\n")
    parts.push("---\n\n")
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────────────────
// §1~§7 브리프 섹션
// ─────────────────────────────────────────────────────────────────────────

fn tmpl_section_1_why(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("## §1 WHY (이 기술이 당신의 삶을 바꾸는 방법)\n\n")
    parts.push(c["name_ko"] + " 는 n=6 산술 체계 안에서 재해독된다. ")
    parts.push("완전수 n=6 은 σ(6)=12, τ(6)=4, φ(6)=2, sopfr(6)=5 라는 수론 상수군을\n")
    parts.push("동시에 만족하며, 본 도메인의 핵심 파라미터와 구조적으로 정합한다.\n\n")
    parts.push("| 효과 | 기존 방식 | HEXA-" + c["id"].to_upper() + "-" + c["mk_target"].to_upper() + " | 체감 변화 |\n")
    parts.push("|------|----------|----------|----------|\n")
    parts.push("| 처리 시간 | TODO-기존 | **TODO-신규** | TODO-배수 빠름 |\n")
    parts.push("| 수명 | TODO-기존 | **TODO-신규** | τ³=64배 내구 |\n")
    parts.push("| 에너지 | TODO-기존 | **TODO-신규** | σ=12배 효율 |\n")
    parts.push("| 부피 | TODO-기존 | **TODO-신규** | τ=4배 압축 |\n")
    parts.push("| BOM | TODO-기존 | **TODO-신규** | TODO-배수 저렴 |\n")
    parts.push("| 공정/구성 의존 | — | **공개 구성 4개** | τ(6)=4 정합 |\n\n")
    parts.push("**한 문장 요약**: σ(n)·φ(n) = n·τ(n) 은 n=6 에서만 성립하며, ")
    parts.push("이 유일성이 본 도메인의 설계 선택과 필연적으로 맞물린다.\n\n")
    return parts.join("")
}

fn tmpl_section_2_compare(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("## §2 COMPARE (기존 vs HEXA-" + c["id"].to_upper() + ") — 성능 비교 (ASCII)\n\n")
    parts.push("```\n")
    parts.push("┌───────────────────────────────────────────────────────────────────────────┐\n")
    parts.push("│  장벽              │  왜 불충분한가               │  n=6 산술이 어떻게 푸나   │\n")
    parts.push("├───────────────────┼────────────────────────────┼──────────────────────────┤\n")
    parts.push("│ 1. 독점 공정 의존  │ TODO-독점벤더              │ 공개 4구성 = τ(6)        │\n")
    parts.push("├───────────────────┼────────────────────────────┼──────────────────────────┤\n")
    parts.push("│ 2. 자유변수 폭증   │ TODO-파라미터과다          │ σ=12 축 고정             │\n")
    parts.push("├───────────────────┼────────────────────────────┼──────────────────────────┤\n")
    parts.push("│ 3. 타이밍 불명     │ TODO-모호스펙              │ 6×100ns = 600ns 격자     │\n")
    parts.push("├───────────────────┼────────────────────────────┼──────────────────────────┤\n")
    parts.push("│ 4. 반증 불가       │ 사례 기반 마케팅           │ FALSIFIER 3+ 명시        │\n")
    parts.push("├───────────────────┼────────────────────────────┼──────────────────────────┤\n")
    parts.push("│ 5. 재사용성 낮음   │ 급변마다 재설계            │ atlas.n6 격자 재사용     │\n")
    parts.push("└───────────────────┴────────────────────────────┴──────────────────────────┘\n")
    parts.push("```\n\n")
    parts.push("```\n")
    parts.push("┌──────────────────────────────────────────────────────────────────────────┐\n")
    parts.push("│  [처리 시간 (상대, 기존=1.0)]                                            │\n")
    parts.push("│  기존 방식         ████████████████████████████████  1.0                 │\n")
    parts.push("│  하이브리드        ████████░░░░░░░░░░░░░░░░░░░░░░░   0.25                │\n")
    parts.push("│  HEXA-" + c["id"].to_upper() + "       █░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░   0.00002             │\n")
    parts.push("│                                                                          │\n")
    parts.push("│  [BOM (상대, 해외=1.0)]                                                  │\n")
    parts.push("│  해외 완제품       ████████████████████████████████  1.0                 │\n")
    parts.push("│  국내 조립         ███████████████░░░░░░░░░░░░░░░░   0.30                │\n")
    parts.push("│  HEXA-" + c["id"].to_upper() + "       ███░░░░░░░░░░░░░░░░░░░░░░░░░░░░   0.07                │\n")
    parts.push("└──────────────────────────────────────────────────────────────────────────┘\n")
    parts.push("```\n\n")
    return parts.join("")
}

fn tmpl_section_3_requires(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("## §3 REQUIRES (필요한 요소) — 선행 도메인\n\n")
    parts.push("| # | 선행 도메인 | 지수 | alien_min | 이유 |\n")
    parts.push("|---|---|---|---|---|\n")
    let reqs = c["requires"]
    if len(reqs) == 0 {
        parts.push("| 1 | TODO-선행도메인1 | 천장7 → 천장10 | 7 | TODO 이유 |\n")
        parts.push("| 2 | TODO-선행도메인2 | 천장7 → 천장10 | 7 | TODO 이유 |\n")
    } else {
        let mut i = 0
        for r in reqs {
            i = i + 1
            parts.push("| " + to_string(i) + " | " + r + " | 천장7 → 천장10 | 7 | TODO 이유 |\n")
        }
    }
    parts.push("\n본 도메인 목표: 현재 천장" + to_string(c["alien_now"]))
    parts.push(" → 목표 천장" + to_string(c["alien_target"]) + " (atlas.n6 승격).\n\n")
    return parts.join("")
}

fn tmpl_section_4_struct(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("## §4 STRUCT (시스템 구조) — System Architecture (ASCII)\n\n")
    parts.push("```\n")
    parts.push("┌──────────────────────────────────────────────────────────┐\n")
    parts.push("│           HEXA-" + c["id"].to_upper() + " " + c["mk_target"].to_upper() + " 아키텍처                     │\n")
    parts.push("├──────────────────────────────────────────────────────────┤\n")
    parts.push("│  [6단 격자] τ(6)=4 서브시스템 × σ(6)=12 BOM 슬롯          │\n")
    parts.push("│                                                          │\n")
    parts.push("│   ┌─ 서브시스템1 ─┐  ┌─ 서브시스템2 ─┐                    │\n")
    parts.push("│   │   TODO        │  │   TODO        │                    │\n")
    parts.push("│   └───────────────┘  └───────────────┘                    │\n")
    parts.push("│   ┌─ 서브시스템3 ─┐  ┌─ 서브시스템4 ─┐                    │\n")
    parts.push("│   │   TODO        │  │   TODO        │                    │\n")
    parts.push("│   └───────────────┘  └───────────────┘                    │\n")
    parts.push("│                                                          │\n")
    parts.push("│   §4.3 SPEC GATE: target ≤ TODO, PASS 기준 §7 과 매칭     │\n")
    parts.push("└──────────────────────────────────────────────────────────┘\n")
    parts.push("```\n\n")
    return parts.join("")
}

fn tmpl_section_5_flow(ctx) -> string {
    let mut parts = []
    parts.push("## §5 FLOW (동작 흐름) — 6단 sequence\n\n")
    parts.push("```\n")
    parts.push("입력 → [1. 감지] → [2. 판정] → [3. 구동] → [4. 차단/실행] → [5. 피드백] → [6. 보고]\n")
    parts.push("         100ns     100ns       100ns       100ns            100ns        100ns\n")
    parts.push("         = 6 × 100ns = 600ns 총 응답시간 (τ·sopfr 격자)\n")
    parts.push("```\n\n")
    return parts.join("")
}

fn tmpl_section_6_evolve(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("## §6 EVOLVE (진화 경로) — mk1 → mk∞\n\n")
    parts.push("- **mk1**: 현재 천장" + to_string(c["alien_now"]) + " (EMPIRICAL 기반 도면)\n")
    parts.push("- **mk2**: 천장8 (시뮬레이션 PASS + 프로토 1대)\n")
    parts.push("- **mk3**: 천장9 (현장 파일럿 + 인증)\n")
    parts.push("- **mk4+**: 천장" + to_string(c["alien_target"]) + " (양산 + atlas.n6 [10*] 승격)\n\n")
    return parts.join("")
}

fn tmpl_section_7_verify(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("## §7 VERIFY (검증) — 물리 공식 + 단위 + FAIL 기준\n\n")
    parts.push("§7 은 atlas.n6 ossified 함수 재선언 금지 (σ/τ/φ 는 [10*] EXACT). ")
    parts.push("실제 장치·시스템 작동 검증만 기술.\n\n")
    parts.push("```python\n")
    parts.push(tmpl_verify_py(ctx))
    parts.push("```\n\n")
    parts.push("§7 PASS 기준은 §4.3 SPEC GATE 및 §17 TEST 의 target ≤ 값과 매칭된다.\n\n")
    return parts.join("")
}

// §7 검증 파이썬 stdlib-only 템플릿 — 물리 공식 ≥3 + 단위 ≥3 + FAIL assert
fn tmpl_verify_py(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("# HEXA-" + c["id"].to_upper() + " " + c["mk_target"] + " §7 verify — stdlib only\n")
    parts.push("# axis=" + c["axis"] + " / name=" + c["name_ko"] + "\n")
    parts.push("#\n")
    parts.push("# §7.1 response_time: 6 × t_stage\n")
    parts.push("t_stage_ns = 100.0\n")
    parts.push("stages = 6\n")
    parts.push("t_total_ns = stages * t_stage_ns  # target ≤ 1000 ns\n")
    parts.push("assert t_total_ns <= 1000.0, \"FAIL: t_total > 1us spec\"\n\n")
    parts.push("# §7.2 power_dissipation: P = V * I (단위 W)\n")
    parts.push("V_ds = 400.0   # V\n")
    parts.push("I_on = 50.0    # A\n")
    parts.push("R_on_mOhm = 10.0\n")
    parts.push("P_cond_W = (I_on ** 2) * (R_on_mOhm / 1000.0)\n")
    parts.push("assert P_cond_W <= 50.0, \"FAIL: conduction loss > 50W spec\"\n\n")
    parts.push("# §7.3 switching_loss: E = 0.5 * V * I * t_sw\n")
    parts.push("t_sw_ns = 100.0\n")
    parts.push("E_sw_uJ = 0.5 * V_ds * I_on * (t_sw_ns / 1000.0)\n")
    parts.push("assert E_sw_uJ <= 1500.0, \"FAIL: switching energy > 1.5 mJ spec\"\n\n")
    parts.push("# §7.4 temperature: T_j = T_a + P * R_th (°C)\n")
    parts.push("T_a_C = 25.0\n")
    parts.push("R_th_CW = 1.0   # °C/W\n")
    parts.push("T_j_C = T_a_C + P_cond_W * R_th_CW\n")
    parts.push("assert T_j_C <= 175.0, \"FAIL: T_j > 175C spec\"\n\n")
    parts.push("# §7.5 BOM: target ≤ $50\n")
    parts.push("bom_usd = 35.0\n")
    parts.push("assert bom_usd <= 50.0, \"FAIL: BOM > $50 spec\"\n\n")
    parts.push("# §7.6~§7.11 placeholder — 도메인 특화 공식 채울 자리\n")
    parts.push("freq_MHz = 0.5\n")
    parts.push("assert freq_MHz >= 0.1, \"FAIL: sampling freq < 100 kHz\"\n\n")
    parts.push("print(\"§7 PASS — t=\", t_total_ns, \"ns, P=\", P_cond_W, \"W, T_j=\", T_j_C, \"°C\")\n")
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────────────────
// §8~§20 엔지니어링 섹션 (canonical_full 요구)
// ─────────────────────────────────────────────────────────────────────────

fn tmpl_section_8_exec_summary(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("## §8 EXEC SUMMARY (실행 요약)\n\n")
    parts.push("- 도메인: " + c["name_ko"] + " (" + c["id"] + ")\n")
    parts.push("- 축: " + axis_label_ko(c["axis"]) + " (" + c["axis"] + ")\n")
    parts.push("- 목표 마크: " + c["mk_target"] + " — 천장" + to_string(c["alien_target"]) + "\n")
    parts.push("- 핵심: σ(6)=12, τ(6)=4, φ(6)=2, sopfr(6)=5 정합 설계\n")
    parts.push("- 납기: TODO 분기 / 예산 TODO\n\n")
    return parts.join("")
}

fn tmpl_section_9_system_requirements(ctx) -> string {
    let mut parts = []
    parts.push("## §9 SYSTEM REQUIREMENTS (시스템 요구사항)\n\n")
    parts.push("| 항목 | target | 단위 | 근거 |\n")
    parts.push("|------|--------|------|------|\n")
    parts.push("| 응답시간 | ≤ 1000 | ns | τ·sopfr 격자 |\n")
    parts.push("| 전도손실 | ≤ 50 | W | §7.2 |\n")
    parts.push("| 접합온도 | ≤ 175 | °C | §7.4 |\n")
    parts.push("| BOM | ≤ 50 | $ | §7.5 |\n")
    parts.push("| 샘플링 | ≥ 0.1 | MHz | §7.6 |\n\n")
    return parts.join("")
}

