fn tmpl_section_13_firmware(ctx) -> string {
    let mut parts = []
    parts.push("## §13 FIRMWARE (펌웨어)\n\n")
    parts.push("- MCU: Cortex-M4 @ 168MHz, FPU on\n")
    parts.push("- ISR: 500kHz 샘플 / 차단 결정 ≤ 2μs\n")
    parts.push("- 알고리즘: Σ-Δ 필터 → di/dt + I²t 합성\n")
    parts.push("- 펌웨어 빌드: hexa self-host (Python/bash 배제)\n\n")
    return parts.join("")
}

