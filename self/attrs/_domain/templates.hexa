// ─────────────────────────────────────────────────────────────────────────
// §21 IMPACT per Mk — mk_history 규칙 준수 블록
// ─────────────────────────────────────────────────────────────────────────

// 한 개의 <details> 블록 (mk_history.hexa 체커 규칙 정합)
//   - 최신 mk → <details open>, summary 에 github /blob/ 링크
//   - 과거 mk → <details>, summary 에 /compare/ 또는 /blob/ 링크
//   - #### 안 바뀌는 것 (③) ≥ 3 항목
fn tmpl_mk_details(mk: string, prev_tag: string, is_latest: bool, ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("### §21." + mk + " IMPACT\n\n")
    let tag_open = if is_latest { "<details open>" } else { "<details>" }
    parts.push(tag_open + "\n")
    let repo = "https://github.com/" + c["repo_owner"] + "/" + c["repo_name"]
    let link = if is_latest {
        repo + "/blob/main/domains/" + c["axis"] + "/" + c["id"] + "/" + c["id"] + ".md"
    } else {
        if prev_tag != "" {
            repo + "/compare/" + prev_tag + "...main"
        } else {
            repo + "/blob/main/domains/" + c["axis"] + "/" + c["id"] + "/"
        }
    }
    parts.push("<summary>" + mk + " — ")
    parts.push("<a href=\"" + link + "\">github.com/" + c["repo_owner"] + "/" + c["repo_name"] + " (" + mk + ")</a>")
    parts.push("</summary>\n\n")
    parts.push("#### ① 바뀌는 것\n")
    parts.push("- TODO 핵심 스펙 변경점\n")
    parts.push("- TODO BOM 증감\n\n")
    parts.push("#### ② 일정/리스크\n")
    parts.push("- 일정Δ: TODO 개월\n")
    parts.push("- 리스크: TODO (완화책 명시)\n\n")
    parts.push("#### ③ 안 바뀌는 것 (정직)\n")
    parts.push("- 기존 SiC MOSFET 의존도 — 여전히 해외 파운드리\n")
    parts.push("- 500kHz 샘플링 상한 — 아날로그 노이즈 한계\n")
    parts.push("- 차단 내구 100,000 사이클 — 반도체 열피로 한계\n\n")
    parts.push("#### ④ 검증 게이트\n")
    parts.push("- §7 VERIFY 전 항목 PASS\n")
    parts.push("- §16 TEST double-break 실측\n\n")
    parts.push("</details>\n\n")
    return parts.join("")
}

// §21 IMPACT 전체 (mk_target 단일 블록 — create 시)
fn tmpl_section_21_impact(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("## §21 IMPACT (영향) — per Mk\n\n")
    parts.push("각 mk 블록은 역시간순 (최신 상단). 최신은 <details open>, ")
    parts.push("과거는 collapsed. summary 에 github 링크 노출.\n\n")
    parts.push(tmpl_mk_details(c["mk_target"], c["prev_tag"], true, ctx))
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────────────────
// CLAUDE.md — 도메인 디렉토리 규칙 (짧게)
// ─────────────────────────────────────────────────────────────────────────

fn tmpl_claude_md(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let mut parts = []
    parts.push("# " + c["name_ko"] + " 도메인 설계 규칙\n\n")
    parts.push("## 정체성\n")
    parts.push("- id: `" + c["id"] + "`\n")
    parts.push("- 축: " + axis_label_ko(c["axis"]) + " (" + c["axis"] + ")\n")
    parts.push("- 목표: mk∞ 천장" + to_string(c["alien_target"]) + "\n\n")
    parts.push("## 문서 규칙\n")
    parts.push("- 본문: `" + c["id"] + ".md` — `@doc(type=paper)` 강제.\n")
    parts.push("- §1~§21 canonical_full 구조 준수. §7 은 atlas.n6 ossified 함수 재선언 금지.\n")
    parts.push("- §21 은 mk 역시간순 + <details> 접힘 규칙 + github 링크.\n\n")
    parts.push("## 제품 라인 단일화\n")
    parts.push("- products.json 의 `" + c["product_line"] + "` 라인은 1개만 유지.\n")
    parts.push("- v1/v2 는 git 로 관리, 새 파일 생성 금지.\n\n")
    parts.push("## 확장 방법\n")
    parts.push("- 새 mk → `@domain(intent=\"update\", mk_target=\"mkN\", prev_tag=\"...\")` 로만.\n")
    parts.push("- 한글 필수. 영어 혼용 금지.\n")
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────────────────
// 전체 생성 (create 시): frontmatter + title + §1~§21
// ─────────────────────────────────────────────────────────────────────────

fn tmpl_full_md(ctx) -> string {
    let mut parts = []
    parts.push(tmpl_frontmatter(ctx))
    parts.push(tmpl_title(ctx))
    parts.push(tmpl_section_1_why(ctx))
    parts.push(tmpl_section_2_compare(ctx))
    parts.push(tmpl_section_3_requires(ctx))
    parts.push(tmpl_section_4_struct(ctx))
    parts.push(tmpl_section_5_flow(ctx))
    parts.push(tmpl_section_6_evolve(ctx))
    parts.push(tmpl_section_7_verify(ctx))
    parts.push(tmpl_section_8_exec_summary(ctx))
    parts.push(tmpl_section_9_system_requirements(ctx))
    parts.push(tmpl_section_10_architecture(ctx))
    parts.push(tmpl_section_11_circuit_design(ctx))
    parts.push(tmpl_section_12_pcb_design(ctx))
    parts.push(tmpl_section_13_firmware(ctx))
    parts.push(tmpl_section_14_mechanical(ctx))
    parts.push(tmpl_section_15_manufacturing(ctx))
    parts.push(tmpl_section_16_test(ctx))
    parts.push(tmpl_section_17_bom(ctx))
    parts.push(tmpl_section_18_vendor(ctx))
    parts.push(tmpl_section_19_acceptance(ctx))
    parts.push(tmpl_section_20_appendix(ctx))
    parts.push(tmpl_section_21_impact(ctx))
    return parts.join("")
}
