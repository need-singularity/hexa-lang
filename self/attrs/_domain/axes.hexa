// self/attrs/_domain/axes.hexa — 10축 enum + 유효성 + 경로 매핑
//
// @domain(axis=...) 에 쓰이는 10개 축 SSOT.
// n6-architecture 의 domains/<axis>/<id>/ 구조와 정합.
// 새 축 추가 시 이 파일만 수정.

use "self/attrs/core"

// 10축 리스트 (영문 slug — kebab 허용, 디렉토리명 그대로)
fn axis_list() {
    return [
        "physics",
        "life",
        "energy",
        "compute",
        "materials",
        "space",
        "infra",
        "cognitive",
        "culture",
        "sf-ufo"
    ]
}

// 축 한글 설명 (리포트용)
fn axis_label_ko(a: string) -> string {
    if a == "physics"   { return "물리" }
    if a == "life"      { return "생명" }
    if a == "energy"    { return "에너지" }
    if a == "compute"   { return "계산" }
    if a == "materials" { return "재료" }
    if a == "space"     { return "우주" }
    if a == "infra"     { return "인프라" }
    if a == "cognitive" { return "인지" }
    if a == "culture"   { return "문화" }
    if a == "sf-ufo"    { return "SF-UFO" }
    return "unknown"
}

// 유효 축 여부
fn axis_valid(a: string) -> bool {
    for v in axis_list() {
        if v == a { return true }
    }
    return false
}

// 축 → domains/<axis>/ 루트 경로 (trailing slash 포함)
fn axis_to_path(a: string) -> string {
    return "domains/" + a + "/"
}

// 위반 사유 ("" = OK)
fn axis_reason(a: string) -> string {
    if a == "" { return "axis empty" }
    if !axis_valid(a) {
        let mut hint = ""
        let mut first = true
        for v in axis_list() {
            if !first { hint = hint + "|" }
            hint = hint + v
            first = false
        }
        return "unknown axis '" + a + "' (valid: " + hint + ")"
    }
    return ""
}
