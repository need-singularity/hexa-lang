// self/attrs/_domain/scaffold.hexa — 도메인 디렉토리/파일 생성 (멱등)
//
// 대상 경로: <n6_root>/domains/<axis>/<id>/
//   · <id>.md      — canonical_full paper
//   · CLAUDE.md    — 도메인 규칙
//
// 멱등 원칙:
//   · 디렉토리 mkdir -p (항상 안전)
//   · 기존 파일 덮어쓰기 금지 (write_if_absent)
//   · create 후 재실행 → no-op + 로그
//
// n6 루트 경로: env HEXA_N6_ROOT 우선, 없으면 /Users/ghost/Dev/n6-architecture

use "self/attrs/core"
use "self/attrs/_domain/axes"
use "self/attrs/_domain/templates"
use "self/stdlib/law_io"

// n6 루트 경로 추출
fn n6_root() -> string {
    let raw = env("HEXA_N6_ROOT")
    if raw != "" { return raw }
    return "/Users/ghost/Dev/n6-architecture"
}

// 도메인 디렉토리 절대경로
fn domain_dir(ctx) -> string {
    let c = _ctx_or_default(ctx)
    return n6_root() + "/" + axis_to_path(c["axis"]) + c["id"]
}

// 덮어쓰기 금지 — 없으면 쓴다, 있으면 skip
// 반환: "created" | "skipped" | "error: <reason>"
fn write_if_absent(path: string, content: string) -> string {
    if file_exists(path) {
        return "skipped"
    }
    let mut ok = true
    try {
        safe_write_file(path, content)
    } catch e {
        ok = false
    }
    if ok { return "created" }
    return "error: write failed"
}

// 강제 덮어쓰기 (update 경로 전용)
fn write_force(path: string, content: string) -> string {
    let mut ok = true
    try {
        safe_write_file(path, content)
    } catch e {
        ok = false
    }
    if ok { return "written" }
    return "error: write failed"
}

// 디렉토리 생성 (mkdir -p)
fn ensure_dir(path: string) -> bool {
    let mut ok = true
    try {
        exec("mkdir -p '" + path + "'")
    } catch e {
        ok = false
    }
    return ok
}

// create 경로 — 디렉토리 + <id>.md + CLAUDE.md 생성
// 반환 map: { dir, md, claude_md, md_status, claude_status }
fn scaffold_domain(ctx) {
    let c = _ctx_or_default(ctx)
    let mut out = #{}
    let dir = domain_dir(c)
    out["dir"] = dir

    let ok = ensure_dir(dir)
    if !ok {
        out["error"] = "mkdir failed: " + dir
        return out
    }

    let md_path = dir + "/" + c["id"] + ".md"
    let claude_path = dir + "/CLAUDE.md"
    out["md"] = md_path
    out["claude_md"] = claude_path

    let md_content = tmpl_full_md(c)
    let claude_content = tmpl_claude_md(c)

    out["md_status"] = write_if_absent(md_path, md_content)
    out["claude_status"] = write_if_absent(claude_path, claude_content)
    return out
}
