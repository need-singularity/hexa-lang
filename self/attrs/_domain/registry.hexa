// self/attrs/_domain/registry.hexa — domains.json R/W (SSOT)
//
// 경로: $HEXA_N6_ROOT/n6shared/n6/docs/domains.json (다른 agent 가 생성 예정)
//       또는 fallback: $HEXA_N6_ROOT/n6shared/n6/docs/domains.json
//       (env HEXA_DOMAINS_JSON 로도 override)
//
// 스키마 (다른 agent 와 맞추기):
//   {
//     "_meta": {"schema": "n6_domains/1.0", "updated": "<iso-date>"},
//     "entries": [
//       {
//         "id": "sscb",
//         "axis": "compute",
//         "name_ko": "반도체 차단기",
//         "product_line": "SSCB",
//         "mk_current": "mk1",
//         "mk_target":  "mk1",
//         "alien_now": 7,
//         "alien_target": 10,
//         "path": "domains/compute/sscb/sscb.md",
//         "requires": ["chip-design-ladder", ...],
//         "history": [
//           {"mk": "mk1", "tag": "sscb-mk1-v1.0", "at": "2026-04-15"}
//         ]
//       }
//     ]
//   }
//
// 파일 없으면 빈 entries 로 시작. 멱등.

use "self/attrs/core"
use "self/attrs/_domain/axes"
use "self/attrs/_domain/templates"
use "self/attrs/_domain/scaffold"
use "self/stdlib/law_io"

fn domains_json_path() -> string {
    let raw = env("HEXA_DOMAINS_JSON")
    if raw != "" { return raw }
    return n6_root() + "/n6shared/n6/docs/domains.json"
}

// load — 파일 없거나 파싱 실패 시 빈 구조 반환
fn load_domains_json() {
    let path = domains_json_path()
    let mut raw = ""
    if file_exists(path) {
        try { raw = read_file(path) } catch e { raw = "" }
    }
    if raw == "" {
        let mut empty = #{}
        empty["_meta"] = #{"schema": "n6_domains/1.0", "updated": ""}
        empty["entries"] = []
        return empty
    }
    let mut parsed = #{}
    let mut ok = true
    try { parsed = json_parse(raw) } catch e { ok = false }
    if !ok {
        let mut empty = #{}
        empty["_meta"] = #{"schema": "n6_domains/1.0", "updated": ""}
        empty["entries"] = []
        return empty
    }
    // 정상화
    if !has_key(parsed, "_meta") {
        parsed["_meta"] = #{"schema": "n6_domains/1.0", "updated": ""}
    }
    if !has_key(parsed, "entries") {
        parsed["entries"] = []
    }
    return parsed
}

fn save_domains_json(data) -> string {
    let path = domains_json_path()
    // 상위 디렉토리 보장
    let parts = path.split("/")
    let mut parent = ""
    let mut i = 0
    let n = len(parts) - 1
    while i < n {
        parent = parent + parts[i]
        if i < n - 1 { parent = parent + "/" }
        i = i + 1
    }
    ensure_dir(parent)

    let mut raw = ""
    let mut ok = true
    try { raw = json_stringify(data) } catch e { ok = false }
    if !ok { return "error: json_stringify failed" }

    try { safe_write_file(path, raw) } catch e { ok = false }
    if !ok { return "error: write failed at " + path }
    return "saved: " + path
}

// entries 에서 id 찾기 — 인덱스 반환 (-1 = 없음)
fn _find_entry_index(entries, id: string) -> int {
    let mut i = 0
    let n = len(entries)
    while i < n {
        let e = entries[i]
        if has_key(e, "id") && e["id"] == id { return i }
        i = i + 1
    }
    return -1
}

fn _ctx_to_entry(ctx) {
    let c = _ctx_or_default(ctx)
    let mut e = #{}
    e["id"] = c["id"]
    e["axis"] = c["axis"]
    e["name_ko"] = c["name_ko"]
    e["product_line"] = c["product_line"]
    e["mk_current"] = c["mk_target"]
    e["mk_target"] = c["mk_target"]
    e["alien_now"] = c["alien_now"]
    e["alien_target"] = c["alien_target"]
    e["path"] = axis_to_path(c["axis"]) + c["id"] + "/" + c["id"] + ".md"
    e["requires"] = c["requires"]
    e["history"] = []
    return e
}

// create 경로: 새 entry 추가. 이미 있으면 no-op + status 반환
// 반환: "created" | "exists" | "error: ..."
fn append_entry(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let data = load_domains_json()
    let entries = data["entries"]
    let idx = _find_entry_index(entries, c["id"])
    if idx >= 0 { return "exists" }

    let entry = _ctx_to_entry(c)
    let new_entries = entries.push(entry)
    data["entries"] = new_entries
    data["_meta"]["updated"] = now()
    let r = save_domains_json(data)
    if r.starts_with("error") { return r }
    return "created"
}

// update 경로: mk_current 갱신 + history 추가
// 반환: "patched" | "missing" | "error: ..."
fn patch_entry(ctx) -> string {
    let c = _ctx_or_default(ctx)
    let data = load_domains_json()
    let entries = data["entries"]
    let idx = _find_entry_index(entries, c["id"])
    if idx < 0 { return "missing" }

    let mut entry = entries[idx]
    entry["mk_current"] = c["mk_target"]
    // mk_target 도 최대치로 전진 (비교는 단순 문자열 — mk 번호만 비교)
    let old_mk = if has_key(entry, "mk_target") { entry["mk_target"] } else { "mk1" }
    if c["mk_target"] > old_mk { entry["mk_target"] = c["mk_target"] }

    let hist = if has_key(entry, "history") { entry["history"] } else { [] }
    let mut h = #{}
    h["mk"] = c["mk_target"]
    h["tag"] = c["prev_tag"]
    h["at"] = now()
    entry["history"] = hist.push(h)

    entries[idx] = entry
    data["entries"] = entries
    data["_meta"]["updated"] = now()
    let r = save_domains_json(data)
    if r.starts_with("error") { return r }
    return "patched"
}

// 존재 여부
fn entry_exists(id: string) -> bool {
    let data = load_domains_json()
    return _find_entry_index(data["entries"], id) >= 0
}
