// self/attrs/autograd.hexa — compute gradients via reverse-mode AD

use "self/attrs/core"

fn meta_autograd() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "autograd"
    m.category = "ml"
    m.purpose = "compute gradients via reverse-mode automatic differentiation"
    m.requires = "@pure (재현성 필요)"
    m.example = "@pure\n@autograd\nfn loss(w, x, y) -> f32 { ... }"
    return m
}

fn check_autograd(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "autograd")
    for pair in pairs {
        let attr_line = pair[0]
        let fn_line = pair[1]
        let mut has_pure = false
        let mut k = attr_line - 3
        if k < 1 { k = 1 }
        while k <= fn_line {
            let idx = k - 1
            if idx >= 0 && idx < len(lines) {
                if contains(trim(lines[idx]), "@pure") { has_pure = true; break }
            }
            k = k + 1
        }
        if !has_pure {
            out = out.push(mk_msg("autograd", "warn", attr_line,
                "@autograd on non-@pure fn — gradient may be incorrect with side effects"))
        }
    }
    return out
}
