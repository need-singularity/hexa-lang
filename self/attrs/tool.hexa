// self/attrs/tool.hexa — @tool meta attr (CLI-invocable hexa script marker)
//
// PURPOSE
//   `tool/*.hexa` scripts that are intended to be invoked from the command
//   line (`hexa <path>`) declare themselves with @tool(slug=, desc=) at the
//   top of the file. The hive manifest (HEXA_TOOLS injection) is generated
//   from these declarations by `tool/manifest_scan.hexa` — replacing the
//   previously hand-maintained list.
//
// FORM
//   @tool(slug="<short-name>", desc="<one-line description>")
//
// CONVENTION
//   · ONE @tool per script (the script's own entry declaration).
//   · Place at the very top of the file, before any code.
//   · Pair with @usage(<canonical command>); optionally @example, @exit_codes.
//   · slug = short identifier reused as the hive HEXA_TOOLS key.
//   · desc = single sentence; what governance concern this tool owns.
//
// INTERACTION
//   The hexa parser does not currently enforce @tool annotations — they are
//   recognized as documentation markers, scanned via regex by
//   tool/manifest_scan.hexa. Future work: turn @tool into a load-bearing
//   parser-level attr that validates required keys.
//
// EXAMPLE
//   // @tool(slug="doc_lint", desc="validate .doc + docs/**/*.md frontmatter")
//   // @usage(hexa tool/doc_lint.hexa [--list])
//   // tool/doc_lint.hexa — .doc enforcer

use "self/attrs/core"

fn meta_tool() {
    let mut m = empty_meta()
    m.name = "tool"
    m.category = "meta"
    m.purpose = "CLI-invocable hexa script marker — declares slug + desc for manifest extraction"
    m.cost_rule = "@tool(slug=\"...\", desc=\"...\") — slug is short identifier, desc is one-line description"
    m.side_effect = "tool/manifest_scan.hexa picks this up; emits to manifest.json for hive HEXA_TOOLS injection"
    m.example = "// @tool(slug=\"doc_lint\", desc=\"validate .doc + docs/**/*.md frontmatter\")"
    m.implemented = false
    return m
}

fn check_tool(source: string, lines: [string]) {
    // Documentation-only marker for now; manifest_scan.hexa is the consumer.
    // Returning [] means: no lint diagnostics surfaced here.
    return []
}
