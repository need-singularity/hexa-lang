// self/attrs/watchdog.hexa — @watchdog runtime resource cap attr
//
// 선언된 함수가 실행 중 RSS/wall-time 임계 초과 시 SIGKILL.
// 2026-04-18 Mac panic 재발 방지 — ai_native_lint 등 heavy fn 에 필수.
//
// Phase B (2026-04-20): ENFORCEMENT LIVE — call_fn pre-body 에서 shell
// watchdog 자식 spawn, getrusage/ps 폴링 500ms + SIGKILL 실행.
// fn 종료 시 watchdog_stop(name) 으로 자식 프로세스 kill.
// args: @watchdog(rss_mb=N, time_s=T) — 파싱은 attr_arg_int 가 담당.

use "self/attrs/core"

struct WatchdogPolicy {
    rss_mb: int,       // resident set size cap (MB). default 4096
    time_s: int,       // wall time cap (seconds). default 300
    on_breach: string, // "kill" (SIGKILL) | "warn" (stderr only) | "return"
}

fn watchdog_default() -> WatchdogPolicy {
    return WatchdogPolicy { rss_mb: 4096, time_s: 300, on_breach: "kill" }
}

fn meta_watchdog() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "watchdog"
    m.category = "runtime"
    m.purpose = "runtime RSS/time cap — 임계 초과 시 kill/warn (Mac panic 재발 방지)"
    m.cost_rule = "함수 진입 시 parent fork → ps 폴링 500ms + kill -KILL"
    m.side_effect = "자식 fork + 주기 폴링 overhead (~100μs/poll)"
    m.auto_test = "@watchdog(rss_mb=100, time_s=1) fn t() { large_alloc(200mb) } → SIGKILL"
    m.example = "@watchdog(rss_mb=4096, time_s=300, on_breach=\"kill\")\nfn ai_lint_main() { ... }"
    m.implemented = true  // Phase A advisory; Phase B runtime 예정
    return m
}

// Phase A: advisory. @heavy_compute 부착된 fn 에 @watchdog 없으면 warn.
// 현재는 no-op (런타임이 @heavy_compute 까지 다 landed 된 후 활성화).
fn check_watchdog(source: string, lines: [string]) {
    return []
}
