// self/attrs/fallback.hexa — catch errors, return void on failure

use "self/attrs/core"

fn meta_fallback() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "fallback"
    m.category = "safety"
    m.purpose = "catch errors, return void or user-specified default on failure"
    m.example = "@fallback(default=0)\nfn parse_int(s: string) -> int { ... }"
    return m
}

fn check_fallback(source: string, lines: [string]) {
    return []
}
