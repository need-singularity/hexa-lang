// self/attrs/paper.hexa — 단일 규칙. preset 폐기, 설정 0건.
// @paper marker 감지 시 §1-§20 + §21.mkN (감지된 만큼) 전부 강제.

use "self/attrs/core"
use "self/attrs/_paper/sections"
use "self/attrs/_paper/ascii"
use "self/attrs/_paper/verify"
use "self/attrs/_paper/mk_history"

fn meta_paper() {
    let mut m = empty_meta()
    m.name = "paper"
    m.category = "meta"
    m.purpose = "논문/문서 canonical 단일 규칙 — preset 없음, sscb 수준 강제"
    m.cost_rule = "모든 검증 항상 실행 (sections + ascii + verify + mk_history)"
    m.side_effect = "§1-§20 전부 required. §21.mkN 헤더 자동 감지 → prev_link + ③≥3 강제"
    m.auto_test = "sscb.md hexa-ufo.md 도메인 문서"
    m.example = "<!-- @paper -->"
    m.implemented = true
    return m
}

// @paper 마커 감지 (코멘트 3종 지원)
fn _has_paper_marker(lines) {
    let mut i = 0
    for line in lines {
        i = i + 1
        if i > 50 { break }
        let t = line.trim()
        let is_comment = t.starts_with("//") || t.starts_with("<!--") || t.starts_with("#")
        if !is_comment { continue }
        if t.contains("@paper") { return true }
    }
    return false
}

// §21.mkN 헤더에서 mk 이름 자동 감지
fn _detect_mks(lines) {
    let mut found = []
    for line in lines {
        let t = line.trim()
        if t.starts_with("### ") && t.contains("mk") {
            let mut i = 0
            let n = len(t)
            while i < n {
                if t.substring(i, i+2) == "mk" {
                    let mut j = i + 2
                    while j < n {
                        let c = char_code(t.substring(j, j+1), 0)
                        let is_digit = c >= 48 && c <= 57
                        if !is_digit { break }
                        j = j + 1
                    }
                    if j > i + 2 {
                        let name = t.substring(i, j)
                        let mut dup = false
                        for f in found { if f == name { dup = true } }
                        if !dup { found = found.push(name) }
                    }
                    i = j
                } else {
                    i = i + 1
                }
            }
        }
    }
    return found
}

fn check_paper(source: string, lines: [string]) {
    let mut out = []
    if !_has_paper_marker(lines) { return out }

    // 1. 섹션 — §1-§20 전부 + §21 IMPACT (always "all")
    let s_msgs = check_paper_sections(lines, "all")
    for m in s_msgs { out = out.push(m) }

    // 2. ASCII 통일성
    let a_msgs = check_paper_ascii(lines)
    for m in a_msgs { out = out.push(m) }

    // 3. VERIFY — 실제 물리/수학 공식 (n=6 수론 재선언 금지, 공식 ≥3, 단위 ≥3종, FAIL, spec gate)
    let v_msgs = check_paper_verify(lines, "all")
    for m in v_msgs { out = out.push(m) }

    // 4. IMPACT — mk 헤더 자동 감지, prev_link 필수 (mk1 제외), ③ 안 바뀌는 것 ≥3건
    let mks = _detect_mks(lines)
    if len(mks) > 0 {
        let h_msgs = check_paper_mk_history(lines, mks, true, 3)
        for m in h_msgs { out = out.push(m) }
    }

    return out
}
