#!hexa lax
// self/attrs/deterministic.hexa — @deterministic 계약 attr
// fn output depends only on arguments — no time, PRNG, env reads
// weaker than @pure (allows logging + explicit state mutation), stronger than nothing

use "self/attrs/core"

fn meta_deterministic() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "deterministic"
    m.category = "contract"
    m.purpose = "fn output depends only on arguments — no time, PRNG, env reads"
    m.cost_rule = "enables reproducible runs, memoization across sessions, stable property testing"
    m.side_effect = "forbids clock, uncontrolled PRNG, env reads"
    m.auto_test = "AST scan for non-deterministic builtins; 3× same-args equivalence check"
    m.example = "@deterministic\nfn pure_step(x: int, seed: int) -> int {\n    return (x * 1103515245 + seed) & 0x7FFFFFFF\n}"
    m.implemented = true
    return m
}

// 비결정적 소스 빌트인 목록
// 시계 / uncontrolled PRNG / env / stdin — argv 는 per-run deterministic 이라 제외
fn _deterministic_forbidden_builtins() {
    return [
        "now(", "now_iso(", "time(", "timestamp(", "monotonic(",
        "random(", "rand(", "randint(", "randf(", "uuid(",
        "env(", "getenv(", "hostname(", "pid(",
        "read_stdin("
    ]
}

// @deterministic fn 본문에 비결정적 빌트인 있으면 error
fn check_deterministic(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "deterministic")
    let forbidden = _deterministic_forbidden_builtins()
    for pair in pairs {
        let fn_line = pair[1]
        let body_range = fn_body_range(lines, fn_line)
        let body_start = body_range[0]
        let body_end = body_range[1]
        let mut i = body_start
        while i <= body_end {
            let idx = i - 1
            if idx < 0 || idx >= len(lines) { i = i + 1; continue }
            let t = lines[idx].trim()
            if t.starts_with("//") { i = i + 1; continue }
            for fb in forbidden {
                if t.contains(fb) {
                    out = out.push(mk_msg("deterministic", "error", i,
                        "@deterministic fn body contains non-deterministic builtin: " + fb))
                }
            }
            i = i + 1
        }
    }
    return out
}
