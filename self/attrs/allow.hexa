// self/attrs/allow.hexa — @allow(token[:scope]) safety attr
// @forbid 의 대칭 짝 — 특정 경로/파일에서 forbid 면제

use "self/attrs/core"

fn meta_allow() {
    let mut m = empty_meta()
    m.name = "allow"
    m.category = "safety"
    m.purpose = "@forbid 예외 선언 — scope 표현식으로 특정 경로/파일 면제"
    m.cost_rule = "allow 매칭 우선; forbid 토큰 매칭 전에 평가"
    m.example = "// .hexa-attrs\nallow = [\"hook:shared/harness/*\", \"skill:experiments/**\"]\n// 또는 파일 상단: // @allow(hook)"
    m.implemented = false
    return m
}

// 파일 상단 `// @allow(hook)` 또는 `// @allow-hook` 토큰 인식
fn check_allow(source: string, lines: [string]) {
    let mut out = []
    let mut i = 0
    for line in lines {
        i = i + 1
        if i > 20 { break }
        let t = trim(line)
        if !starts_with(t, "//") { continue }
        // @allow(token) 또는 @allow-token
        let p1 = t.index_of("@allow(")
        let p2 = t.index_of("@allow-")
        if p1 < 0 && p2 < 0 { continue }
        let mut token = ""
        if p1 >= 0 {
            let after = t.substring(p1 + 7, len(t))
            let cp = after.index_of(")")
            if cp >= 0 { token = trim(after.substring(0, cp)) }
        } else {
            let after = t.substring(p2 + 7, len(t))
            let mut j = 0
            let chars = after.chars()
            for ch in chars {
                let c = char_code(to_string(ch), 0)
                let is_alpha = (c >= 97 && c <= 122) || c == 95 || c == 45
                if is_alpha { token = token + to_string(ch) }
                else { break }
            }
        }
        if token == "" { continue }
        // @allow 는 대체로 @forbid 위반이 없으면 쓸모 없음 — silent
        // 오직 정당화 코멘트 부재 시 hint
        let mut rest_start = 0
        if p1 >= 0 { rest_start = p1 + 8 } else { rest_start = p2 + 7 }
        let rest = t.substring(rest_start, len(t))
        let has_reason = contains(rest, "—") || contains(rest, "--") || contains(rest, "reason=")
        if !has_reason {
            out = out.push(mk_msg("allow", "warn", i,
                "@allow(" + token + ") 정당화 코멘트 권장 (예: `// @allow-hook — harness 전용`)"))
        }
    }
    return out
}
