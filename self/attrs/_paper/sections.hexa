// self/attrs/_paper/sections.hexa — @paper sections 검증 (brief/engineering/impact/all)

use "self/attrs/core"
use "self/attrs/_lib/paper_utils"

// level 별 필수 섹션 세트
fn paper_sections_for_level(level: string) {
    if level == "brief" {
        return ["WHY", "COMPARE", "REQUIRES", "STRUCT", "FLOW", "EVOLVE", "VERIFY"]
    }
    if level == "engineering" {
        return ["EXEC SUMMARY", "SYSTEM REQUIREMENTS", "ARCHITECTURE", "CIRCUIT DESIGN",
                "PCB DESIGN", "FIRMWARE", "MECHANICAL", "MANUFACTURING", "TEST",
                "BOM", "VENDOR", "ACCEPTANCE", "APPENDIX"]
    }
    if level == "impact" {
        return ["IMPACT"]  // impact 내부 구조는 별도 attr
    }
    if level == "all" {
        // brief + engineering + impact 전부
        return ["WHY", "COMPARE", "REQUIRES", "STRUCT", "FLOW", "EVOLVE", "VERIFY",
                "EXEC SUMMARY", "SYSTEM REQUIREMENTS", "ARCHITECTURE", "CIRCUIT DESIGN",
                "PCB DESIGN", "FIRMWARE", "MECHANICAL", "MANUFACTURING", "TEST",
                "BOM", "VENDOR", "ACCEPTANCE", "APPENDIX", "IMPACT"]
    }
    return []
}

fn check_paper_sections(lines, level: string) {
    let mut out = []
    let required = paper_sections_for_level(level)
    let mut missing = []
    for sec in required {
        if !has_section(lines, sec) { missing = missing.push(sec) }
    }
    if len(missing) > 0 {
        out = out.push(mk_msg("paper_sections", "error", 1,
            "level=" + level + " missing: " + join(missing, ", ")))
    }
    return out
}
