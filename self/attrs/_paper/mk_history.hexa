// self/attrs/_paper/mk_history.hexa — mk 버전 히스토리 + github 링크 체인
//
// @doc(type=paper) §21 IMPACT per Mk 검증 규칙:
//   1. mk 섹션 존재 감지 (### §21.mkN)
//   2. 순서: 최신 Mk 가 상단, mk1 이 맨 하단 (역시간순)
//   3. 접힘: 최신 Mk 만 <details open>, 나머지 <details> (접힘)
//   4. 접힌 블록의 <summary> 는 github blob/compare/release 링크 노출
//   5. 펼치면 변화점·BOMΔ·일정Δ·리스크·①②③·검증게이트 출력
//   6. ③ 안 바뀌는 것 항목 ≥ unchanged_min (과대포장 방지)

use "self/attrs/core"
use "self/attrs/_lib/error_catalog"
use "self/attrs/_lib/paper_utils"
use "self/attrs/_lib/url_utils"

// §21.mkN 섹션 감지 — 본문 등장 순서대로 반환
fn _detect_mk_sections(lines) {
    let mut found = []
    for line in lines {
        let t = line.trim()
        if t.starts_with("### ") && t.contains("mk") {
            let mut i = 0
            let n = len(t)
            while i < n {
                if t.substring(i, i+2) == "mk" {
                    let mut j = i + 2
                    while j < n {
                        let c = char_code(t.substring(j, j+1), 0)
                        let is_digit = c >= 48 && c <= 57
                        if !is_digit { break }
                        j = j + 1
                    }
                    if j > i + 2 {
                        let name = t.substring(i, j)
                        let mut dup = false
                        for f in found { if f == name { dup = true } }
                        if !dup { found.push(name) }
                    }
                    i = j
                } else {
                    i = i + 1
                }
            }
        }
    }
    return found
}

// mk 이름 ("mk3") → 숫자 (3)
fn _mk_number(mk_name: string) {
    if len(mk_name) <= 2 { return 0 }
    let digits = mk_name.substring(2, len(mk_name))
    return to_int(digits)
}

// 순서 검증: 최신 (가장 큰 번호) 이 문서 상단에 나와야 함
// 감지된 순서가 내림차순 (예: mk5, mk4, mk3, mk2, mk1) 이면 OK
fn _mks_in_desc_order(found) {
    let n = len(found)
    if n <= 1 { return true }
    let mut i = 0
    while i < n - 1 {
        let a = _mk_number(found[i])
        let b = _mk_number(found[i+1])
        if a < b { return false }
        i = i + 1
    }
    return true
}

// 각 mk 섹션의 body 에서 <details> 블록 속성 파악
// 반환: "open" | "collapsed" | "none"
fn _mk_details_mode(lines, mk_name: string) {
    let mut in_mk = false
    let mut in_details = false
    let mut is_open = false
    for line in lines {
        let t = line.trim()
        let is_h3 = t.starts_with("### ") && !t.starts_with("#### ")
        if is_h3 {
            if in_mk { break }    // 다음 mk 로 넘어가면 종료 (첫 매치만)
            if t.contains(mk_name) {
                in_mk = true
                continue
            }
        }
        if !in_mk { continue }
        // <details ...> 탐지
        if t.contains("<details") {
            in_details = true
            if t.contains("open") { is_open = true }
        }
    }
    if !in_details { return "none" }
    if is_open { return "open" }
    return "collapsed"
}

// 각 mk 섹션의 <summary> 안에 github 링크 (blob/compare/releases) 존재?
// summary 위치: <details> ... <summary>...</summary> ... </details>
fn _mk_summary_has_link(lines, mk_name: string) {
    let mut in_mk = false
    let mut in_summary = false
    let mut found_link = false
    for line in lines {
        let t = line.trim()
        let is_h3 = t.starts_with("### ") && !t.starts_with("#### ")
        if is_h3 {
            if in_mk { break }
            if t.contains(mk_name) {
                in_mk = true
                continue
            }
        }
        if !in_mk { continue }
        if t.contains("<summary") { in_summary = true }
        if in_summary && t.contains("github.com") {
            let has_blob = t.contains("/blob/")
            let has_compare = t.contains("/compare/")
            let has_release = t.contains("/releases/")
            if has_blob || has_compare || has_release { found_link = true }
        }
        if t.contains("</summary>") { in_summary = false }
    }
    return found_link
}

// 각 mk 섹션 body 에 github blob/compare 링크 존재 감지 (summary 포함 전체)
fn _mk_has_prev_link(lines, mk_name: string) {
    let mut in_section = false
    let mut has_link = false
    for line in lines {
        let t = line.trim()
        if t.starts_with("### ") && t.contains(mk_name) {
            in_section = true
            continue
        }
        if in_section {
            if t.starts_with("### ") { break }
            if t.contains("github.com") && (t.contains("/blob/") || t.contains("/compare/")) {
                has_link = true
            }
        }
    }
    return has_link
}

// "안 바뀌는 것" 층 (③) 항목 수 — h4 헤더 + - 또는 * 항목
// 동일 mk_name 을 포함한 h3 가 여러 개일 수 있어 누적
fn _mk_unchanged_count(lines, mk_name: string) {
    let mut in_mk = false
    let mut in_unch = false
    let mut count = 0
    for line in lines {
        let t = line.trim()
        let is_h3 = t.starts_with("### ") && !t.starts_with("#### ")
        if is_h3 {
            in_mk = t.contains(mk_name)
            in_unch = false
            continue
        }
        if !in_mk { continue }
        let is_h4 = t.starts_with("#### ")
        if is_h4 {
            let is_unch_header = t.contains("안 바뀌") || t.contains("unchanged") || t.contains("정직") || t.contains("③")
            in_unch = is_unch_header
            continue
        }
        if in_unch {
            if t.starts_with("- ") || t.starts_with("* ") {
                count = count + 1
            }
        }
    }
    return count
}

// 메인 검증 디스패치
fn check_paper_mk_history(lines, mk_versions, require_prev_link: bool, unchanged_min: int, source: string) {
    let mut out = []
    let found = _detect_mk_sections(lines)

    // 1. 기대된 mk 전부 존재?
    for mk in mk_versions {
        let mut exists = false
        for f in found { if f == mk { exists = true } }
        if !exists {
            out.push(mk_msg_k("paper_mk_history", "error", source, 1,
                "mk 섹션 누락: " + mk,
                "paper_mk_missing"))
        }
    }

    // 2. 순서: 최신이 상단 (역시간순)
    if !_mks_in_desc_order(found) {
        let mut names = ""
        let mut first = true
        for f in found {
            if !first { names = names + ", " }
            names = names + f
            first = false
        }
        out.push(mk_msg_k("paper_mk_history", "error", source, 1,
            "mk 배치 순서 오류 — 최신 Mk 가 상단이어야 함 (역시간순). 현재: " + names,
            "paper_mk_desc_order"))
    }

    // 3. 접힘 규칙: 최신 = open, 나머지 = collapsed
    //    found[0] 이 가장 먼저 등장 (desc 순서면 최신)
    let latest = if len(found) > 0 { found[0] } else { "" }
    for mk in found {
        let mode = _mk_details_mode(lines, mk)
        if mode == "none" {
            out.push(mk_msg_k("paper_mk_history", "error", source, 1,
                mk + " 섹션에 <details> 래퍼 없음 — 접힘 구조 필요",
                "paper_mk_details_wrapper_missing"))
            continue
        }
        let is_latest = mk == latest
        if is_latest && mode != "open" {
            out.push(mk_msg_k("paper_mk_history", "error", source, 1,
                mk + " (최신) 은 <details open> 으로 펼쳐져야 함. 현재: " + mode,
                "paper_mk_latest_not_open"))
        }
        if !is_latest && mode == "open" {
            out.push(mk_msg_k("paper_mk_history", "error", source, 1,
                mk + " (과거) 는 <details> (collapsed) 로 접혀야 함. 현재: open",
                "paper_mk_past_open"))
        }
    }

    // 4. <summary> 내 github 링크 노출 (접힌 상태에서 보임)
    for mk in found {
        if !_mk_summary_has_link(lines, mk) {
            let hint = if mk == "mk1" { "/releases/tag/ 또는 /blob/ 초기 태그" }
                       else { "/blob/ 또는 /compare/ 또는 /releases/" }
            out.push(mk_msg_k("paper_mk_history", "warn", source, 1,
                mk + " <summary> 에 github 링크 노출 권장 (" + hint + ")",
                "paper_mk_summary_link_missing"))
        }
    }

    // 5. 기존 prev_link 규칙 (mk1 제외, body 내 github blob/compare)
    for mk in mk_versions {
        let mut exists = false
        for f in found { if f == mk { exists = true } }
        if !exists { continue }
        if require_prev_link && mk != "mk1" {
            if !_mk_has_prev_link(lines, mk) {
                out.push(mk_msg_k("paper_mk_history", "error", source, 1,
                    mk + " 섹션에 github.com/.../blob|compare/ prev link 누락",
                    "paper_mk_prev_link_missing"))
            }
        }
    }

    // 6. ③ 안 바뀌는 것 ≥ unchanged_min
    for mk in mk_versions {
        let mut exists = false
        for f in found { if f == mk { exists = true } }
        if !exists { continue }
        let unchanged = _mk_unchanged_count(lines, mk)
        if unchanged < unchanged_min {
            out.push(mk_msg_k("paper_mk_history", "warn", source, 1,
                mk + " '안 바뀌는 것' 항목 " + to_string(unchanged) + " < 필요 " + to_string(unchanged_min) + " — 과대포장 방지",
                "paper_mk_unchanged_shortage"))
        }
    }

    return out
}
