// self/attrs/_paper/mk_history.hexa — mk 버전 히스토리 + github 링크 체인

use "self/attrs/core"
use "self/attrs/_lib/paper_utils"
use "self/attrs/_lib/url_utils"

// §21.mkN 섹션 감지 — "mk1", "mk2" 등 서브섹션 존재
fn _detect_mk_sections(lines) {
    let mut found = []
    for line in lines {
        let t = line.trim()
        if t.starts_with("### ") && t.contains("mk") {
            // "### §21.mk1 — ..." 또는 "### mk1" 형식에서 mk 이름 추출
            let mut i = 0
            let n = len(t)
            while i < n {
                if t.substring(i, i+2) == "mk" {
                    // mk + 숫자 추출
                    let mut j = i + 2
                    while j < n {
                        let c = char_code(t.substring(j, j+1), 0)
                        let is_digit = c >= 48 && c <= 57
                        if !is_digit { break }
                        j = j + 1
                    }
                    if j > i + 2 {
                        let name = t.substring(i, j)
                        let mut dup = false
                        for f in found { if f == name { dup = true } }
                        if !dup { found = found.push(name) }
                    }
                    i = j
                } else {
                    i = i + 1
                }
            }
        }
    }
    return found
}

// 각 mk 섹션 body 에 github blob/compare 링크 존재 감지
fn _mk_has_prev_link(lines, mk_name: string) {
    let mut in_section = false
    let mut has_link = false
    for line in lines {
        let t = line.trim()
        if t.starts_with("### ") && t.contains(mk_name) {
            in_section = true
            continue
        }
        if in_section {
            if t.starts_with("### ") { break }   // 다음 mk 로 이동
            if t.contains("github.com") && t.contains("/blob/") {
                has_link = true
            }
        }
    }
    return has_link
}

// "안 바뀌는 것" 층 (정직성) 항목 수
// 인식 패턴: "안 바뀌" / "unchanged" / "정직" 키워드를 포함한 #### 헤더 다음의 - 또는 * 항목
// 주의: 여러 h3 가 동일 mk_name 포함할 수 있음 (개요 섹션 + §21 임팩트 섹션).
//       break 하지 않고 모든 매칭 h3 섹션을 누적 집계.
fn _mk_unchanged_count(lines, mk_name: string) {
    let mut in_mk = false
    let mut in_unch = false
    let mut count = 0
    for line in lines {
        let t = line.trim()
        let is_h3 = t.starts_with("### ") && !t.starts_with("#### ")
        if is_h3 {
            // h3 만나면 mk_name 포함 여부로 상태 재판정
            in_mk = t.contains(mk_name)
            in_unch = false
            continue
        }
        if !in_mk { continue }
        // "안 바뀌는 것" 층 진입: #### 헤더 + 키워드 (③ 또는 안 바뀌/unchanged/정직)
        let is_h4 = t.starts_with("#### ")
        if is_h4 {
            let is_unch_header = t.contains("안 바뀌") || t.contains("unchanged") || t.contains("정직") || t.contains("③")
            in_unch = is_unch_header
            continue
        }
        // 항목 카운트
        if in_unch {
            if t.starts_with("- ") || t.starts_with("* ") {
                count = count + 1
            }
        }
    }
    return count
}

fn check_paper_mk_history(lines, mk_versions, require_prev_link: bool, unchanged_min: int) {
    let mut out = []
    let found = _detect_mk_sections(lines)

    // mk_versions 배열에 있는 각 mk 가 섹션 존재하는지
    for mk in mk_versions {
        let mut exists = false
        for f in found { if f == mk { exists = true } }
        if !exists {
            out = out.push(mk_msg("paper_mk_history", "error", 1,
                "mk 섹션 누락: " + mk))
            continue
        }
        // prev link (mk1 은 최초 버전이라 선택적)
        if require_prev_link && mk != "mk1" {
            if !_mk_has_prev_link(lines, mk) {
                out = out.push(mk_msg("paper_mk_history", "error", 1,
                    mk + " 섹션에 github.com/.../blob/ prev link 누락"))
            }
        }
        // 안 바뀌는 것 (정직성)
        let unchanged = _mk_unchanged_count(lines, mk)
        if unchanged < unchanged_min {
            out = out.push(mk_msg("paper_mk_history", "warn", 1,
                mk + " '안 바뀌는 것' 항목 " + to_string(unchanged) + " < 필요 " + to_string(unchanged_min) + " — 과대포장 방지"))
        }
    }
    return out
}
