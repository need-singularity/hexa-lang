// self/attrs/_paper/ascii.hexa — ASCII 스타일 통일성

use "self/attrs/core"
use "self/attrs/_lib/error_catalog"
use "self/attrs/_lib/ascii_utils"

fn check_paper_ascii(lines, source: string) {
    let mut out = []
    let report = ascii_uniformity_report(lines)
    if report[0] {
        out.push(mk_msg_k("paper_ascii", "error", source, 1,
            "box 문자 혼재 (unicode ┌─┐ vs ascii7 +-| 등 2종 이상 사용)",
            "paper_ascii_box_mix"))
    }
    if report[1] {
        out.push(mk_msg_k("paper_ascii", "error", source, 1,
            "bar 문자 혼재 (█ ■ # ● 중 2종 이상)",
            "paper_ascii_bar_mix"))
    }
    if report[2] {
        out.push(mk_msg_k("paper_ascii", "error", source, 1,
            "화살표 혼재 (→↓↑← vs -> <-)",
            "paper_ascii_arrow_mix"))
    }
    if report[3] {
        out.push(mk_msg_k("paper_ascii", "warn", source, 1,
            "트리 문자 혼재 (├└│ vs |-- \\--)",
            "paper_ascii_tree_mix"))
    }
    return out
}
