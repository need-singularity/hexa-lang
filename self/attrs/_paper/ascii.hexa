// self/attrs/_paper/ascii.hexa — ASCII 스타일 통일성

use "self/attrs/core"
use "self/attrs/_lib/ascii_utils"

fn check_paper_ascii(lines) {
    let mut out = []
    let report = ascii_uniformity_report(lines)
    if report[0] {
        out = out.push(mk_msg("paper_ascii", "error", 1,
            "box 문자 혼재 (unicode ┌─┐ vs ascii7 +-| 등 2종 이상 사용)"))
    }
    if report[1] {
        out = out.push(mk_msg("paper_ascii", "error", 1,
            "bar 문자 혼재 (█ ■ # ● 중 2종 이상)"))
    }
    if report[2] {
        out = out.push(mk_msg("paper_ascii", "error", 1,
            "화살표 혼재 (→↓↑← vs -> <-)"))
    }
    if report[3] {
        out = out.push(mk_msg("paper_ascii", "warn", 1,
            "트리 문자 혼재 (├└│ vs |-- \\--)"))
    }
    return out
}
