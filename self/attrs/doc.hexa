// self/attrs/doc.hexa — 모든 문서 유형 단일 진입점
// @doc(type=paper|rfc|adr|spec|whitepaper) — type 별 검증 디스패치
// @paper 중복 폐기 — type=paper 에 canonical_full 규칙 직결
//
// HX11 AI-native SELF-FORMAT — type 별 섹션 리스트 + 추가 토글 은
// `.doc-rules.json` (프로젝트 root, source 에서 상위로 탐색) 또는 글로벌 fallback
// `/Users/ghost/Dev/nexus/shared/config/doc_rules.json` 에서 로드. 하드코딩 금지.
// 둘 다 실패할 때만 내장 builtin 으로 안전 fallback.
//
// ─── Phase 3 (2026-04-19) — @doc(type=paper) legacy SOFT-DEPRECATION ───
// @own(sections=[...], strict, order, prefix) 하네스가 self-hosting 대체 경로.
// 신규 paper 는 @doc(type=paper) + @own 병기 필수. @own 없는 @doc(type=paper) 는
// legacy path 로 계속 동작하지만 deprecation warning 을 emit 한다. 기능 제거 없음.
// 전환 완료 시점: Phase 4 (legacy path 제거 — 별도 릴리스).
// deprecated_by="@own", migration_phase=3, deprecation_date="2026-04-19".

use "self/attrs/core"
use "self/attrs/_lib/error_catalog"
use "self/attrs/_lib/paper_utils"
use "self/attrs/_lib/rules_loader"
use "self/attrs/_lib/project_parser"
use "self/attrs/_paper/sections"
use "self/attrs/_paper/ascii"
use "self/attrs/_paper/verify"
use "self/attrs/_paper/mk_history"

fn meta_doc() {
    let mut m = empty_meta()
    m.name = "doc"
    m.category = "meta"
    m.purpose = "모든 문서 유형 단일 진입점. 섹션/토글 = .doc-rules.json 주입 (HX11)"
    m.cost_rule = "type 별 sections + require_ascii_check/verify/mk_history 토글. JSON 주도."
    m.side_effect = "type 미지정은 no-op. @paper 마커 별도 폐기. 프로젝트 `.doc-rules.json` 있으면 우선. Phase 3 (2026-04-19): type=paper legacy path 는 @own 병기 권장, 없으면 deprecation warning emit (deprecated_by=@own)."
    m.auto_test = "sscb.md hexa-ufo.md + .doc-rules.json 주입 테스트"
    m.example = "// @doc(type=paper)\n// @doc(type=adr)\n// @doc(type=rfc, status=draft)"
    m.implemented = true
    return m
}

fn _global_doc_rules_path() -> string {
    return "/Users/ghost/Dev/nexus/shared/config/doc_rules.json"
}

// 내장 fallback (JSON 둘 다 실패일 때만 사용)
fn _doc_builtin_rules() {
    let mut r = #{}
    let mut meta = #{}
    meta["project"] = "_builtin"
    meta["version"] = 1
    meta["inherit"] = false
    r["_meta"] = meta

    let mut rules = #{}

    let mut paper = #{}
    paper["sections"] = ["WHY", "COMPARE", "REQUIRES", "STRUCT", "FLOW", "EVOLVE", "VERIFY",
                         "EXEC SUMMARY", "SYSTEM REQUIREMENTS", "ARCHITECTURE", "CIRCUIT DESIGN",
                         "PCB DESIGN", "FIRMWARE", "MECHANICAL", "MANUFACTURING", "TEST",
                         "BOM", "VENDOR", "ACCEPTANCE", "APPENDIX", "IMPACT"]
    paper["require_ascii_check"] = true
    paper["require_verify"] = true
    paper["require_mk_history"] = true
    paper["mk_history_min_lines"] = 3
    rules["paper"] = paper

    let mut rfc = #{}
    rfc["sections"] = ["Status", "Abstract", "Introduction", "Requirements", "Security Considerations"]
    rules["rfc"] = rfc

    let mut adr = #{}
    adr["sections"] = ["Context", "Decision", "Consequences"]
    rules["adr"] = adr

    let mut spec = #{}
    spec["sections"] = ["Overview", "Interface", "Behavior", "Errors", "Examples"]
    rules["spec"] = spec

    let mut wp = #{}
    wp["sections"] = ["Executive Summary", "Problem", "Solution", "Architecture", "Validation"]
    rules["whitepaper"] = wp

    r["rules"] = rules
    return r
}

// 규칙 로드 — HX11 (갱신안): project.hexa 의 @doc_rules(type=...) 블록 우선.
// 1) project.hexa 블록 (type 별 scan)
// 2) 전역 _defaults.hexa 블록
// 3) legacy `nexus/shared/config/doc_rules.json`
// 4) 내장 builtin
pub fn find_doc_rules(source: string) {
    // (1) project.hexa 전부 파싱 후 type 별 블록 재구성
    let proj_path = find_project_hexa(source)
    if proj_path != "" {
        let blocks = parse_project_hexa_file(proj_path)
        if len(blocks) > 0 {
            let mut rmap = #{}
            for b in blocks {
                if b["attr"] != "doc" { continue }
                let sel = b["selector"]
                if !has_key(sel, "type") { continue }
                rmap[sel["type"]] = b["body"]
            }
            if len(keys(rmap)) > 0 {
                let mut out = #{}
                out["_meta"] = #{"source": "project.hexa"}
                out["rules"] = rmap
                return out
            }
        }
    }
    // (2) 전역 _defaults.hexa 동일 scan
    let hl = env("HEXA_LANG")
    let root = if hl != "" { hl } else { "/Users/ghost/Dev/hexa-lang" }
    let def_path = root + "/self/attrs/_defaults.hexa"
    let def_exists = to_string(exec("test -f '" + def_path + "' && printf 1 || printf 0")).trim()
    if def_exists == "1" {
        let blocks = parse_project_hexa_file(def_path)
        if len(blocks) > 0 {
            let mut rmap = #{}
            for b in blocks {
                if b["attr"] != "doc" { continue }
                let sel = b["selector"]
                if !has_key(sel, "type") { continue }
                rmap[sel["type"]] = b["body"]
            }
            if len(keys(rmap)) > 0 {
                let mut out = #{}
                out["_meta"] = #{"source": "global.hexa"}
                out["rules"] = rmap
                return out
            }
        }
    }
    // (3) legacy JSON — v1 로더 통해 불러옴 (deprecated 경고 1회 출력)
    let loaded = find_attr_rules(source, "doc", _global_doc_rules_path())
    if has_key(loaded, "rules") { return loaded }
    // (4) builtin
    return _doc_builtin_rules()
}

// rules → type 별 sections 배열 (신규 API — 하드코딩 제거)
pub fn doc_required_sections_from_rules(rules, doc_type: string) {
    if !has_key(rules, "rules") { return [] }
    let rmap = rules["rules"]
    if !has_key(rmap, doc_type) { return [] }
    let tcfg = rmap[doc_type]
    if !has_key(tcfg, "sections") { return [] }
    return tcfg["sections"]
}

// 기존 호출자 호환 — builtin 기준으로 질의 (rules 파라미터 없는 레거시)
fn doc_required_sections(doc_type: string) {
    return doc_required_sections_from_rules(_doc_builtin_rules(), doc_type)
}

// cfg bool/int getter
fn _dcfg_bool(cfg, key: string, def: bool) -> bool {
    if !has_key(cfg, key) { return def }
    let v = cfg[key]
    if v == true { return true }
    if v == false { return false }
    return def
}

fn _dcfg_int(cfg, key: string, def: int) -> int {
    if !has_key(cfg, key) { return def }
    let v = cfg[key]
    let mut n = def
    try { n = to_int(v) } catch e { n = def }
    return n
}

// 파일 상단 @doc(type=X) 선언 감지 → type 반환
// 코멘트 3종 지원: `//` / `<!--` / `#`
fn detect_doc_type(lines) {
    let mut i = 0
    for line in lines {
        i = i + 1
        if i > 50 { break }
        let t = line.trim()
        let is_comment = t.starts_with("//") || t.starts_with("<!--") || t.starts_with("#")
        if !is_comment { continue }
        let idx = t.index_of("@doc(")
        if idx < 0 { continue }
        let after = t.substring(idx + 5, len(t))
        let cp = after.index_of(")")
        if cp < 0 { continue }
        let body = after.substring(0, cp)
        let parts = body.split(",")
        for p in parts {
            let kv = p.trim()
            if kv.starts_with("type=") {
                return kv.substring(5, len(kv)).trim()
            }
        }
    }
    return ""
}

// §21.mkN 헤더 자동 감지 (paper type 전용)
fn _detect_mks(lines) {
    let mut found = []
    for line in lines {
        let t = line.trim()
        if t.starts_with("### ") && t.contains("mk") {
            let mut i = 0
            let n = len(t)
            while i < n {
                if t.substring(i, i+2) == "mk" {
                    let mut j = i + 2
                    while j < n {
                        let c = char_code(t.substring(j, j+1), 0)
                        let is_digit = c >= 48 && c <= 57
                        if !is_digit { break }
                        j = j + 1
                    }
                    if j > i + 2 {
                        let name = t.substring(i, j)
                        let mut dup = false
                        for f in found { if f == name { dup = true } }
                        if !dup { found = found.push(name) }
                    }
                    i = j
                } else {
                    i = i + 1
                }
            }
        }
    }
    return found
}

pub fn check_doc(source: string, lines: [string]) {
    let mut out = []
    let doc_type = detect_doc_type(lines)
    if doc_type == "" { return out }   // @doc 선언 없으면 skip

    // 규칙 로드 (프로젝트 > 글로벌 > builtin) — HX11
    let rules = find_doc_rules(source)
    let rmap = if has_key(rules, "rules") { rules["rules"] } else { #{} }

    // type 유효성 — 로드된 rules 의 key 목록 기준 (프로젝트별 확장 허용)
    let mut valid_types = []
    for k in keys(rmap) { valid_types = valid_types.push(k) }
    let mut is_valid = false
    for v in valid_types { if v == doc_type { is_valid = true } }
    if !is_valid {
        let valid_str = join(valid_types, "|")
        out = out.push(mk_msg_k("doc", "error", source, 1,
            "unknown @doc type: '" + doc_type + "' (valid: " + valid_str + ")",
            "doc_unknown_type"))
        return out
    }
    let tcfg = rmap[doc_type]

    // 공통: 필수 섹션 누락 검사 (JSON 주도)
    let required = doc_required_sections_from_rules(rules, doc_type)
    let mut missing = []
    for sec in required {
        if !has_section(lines, sec) { missing = missing.push(sec) }
    }
    if len(missing) > 0 {
        out = out.push(mk_msg_k("doc", "error", source, 1,
            "@doc(type=" + doc_type + ") missing required sections: " + join(missing, ", "),
            "doc_sections_missing"))
    }

    // type 별 추가 검증 토글 (JSON) — ASCII / physics verify / mk_history
    let rq_ascii = _dcfg_bool(tcfg, "require_ascii_check", false)
    let rq_verify = _dcfg_bool(tcfg, "require_verify", false)
    let rq_mk = _dcfg_bool(tcfg, "require_mk_history", false)
    let mk_min = _dcfg_int(tcfg, "mk_history_min_lines", 3)

    // Phase 3 soft-deprecation (2026-04-19): @doc(type=paper) 는 @own 병기 권장.
    // @own 선언 없으면 warn (error 아님 — legacy 동작 계속). Phase 4 에서 제거 예정.
    if doc_type == "paper" {
        let mut has_own = false
        let mut li = 0
        for line in lines {
            li = li + 1
            if li > 50 { break }
            if line.index_of("@own(") >= 0 { has_own = true; break }
        }
        if !has_own {
            out = out.push(mk_msg_k("doc", "warn", source, 1,
                "@doc(type=paper) without @own — legacy path (Phase 3 deprecated 2026-04-19, removal planned Phase 4). Add <!-- @own(sections=[...], strict=false, order=sequential, prefix=\"§\") --> header.",
                "doc_paper_own_missing"))
        }
    }

    if rq_ascii {
        let a_msgs = check_paper_ascii(lines, source)
        for m in a_msgs { out = out.push(m) }
    }
    if rq_verify {
        let v_msgs = check_paper_verify(lines, "all", source)
        for m in v_msgs { out = out.push(m) }
    }
    if rq_mk {
        let mks = _detect_mks(lines)
        if len(mks) > 0 {
            let h_msgs = check_paper_mk_history(lines, mks, true, mk_min, source)
            for m in h_msgs { out = out.push(m) }
        }
    }

    return out
}
