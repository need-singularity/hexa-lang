// self/attrs/doc.hexa — 상위 문서 유형 추상화
// @doc(type=paper|rfc|adr|spec|whitepaper) — @paper 는 type=paper 특화

use "self/attrs/core"
use "self/attrs/_lib/paper_utils"

fn meta_doc() {
    let mut m = empty_meta()
    m.name = "doc"
    m.category = "meta"
    m.purpose = "상위 문서 유형 추상화 — 각 type 별 기본 섹션 + 공통 검증. @paper/@rfc/@adr 의 부모"
    m.cost_rule = "type 별 preset 선택 → 서브 attr 디스패치"
    m.side_effect = "미지정 type 은 skip (no-op)"
    m.example = "// @doc(type=paper, preset=canonical_full)\n// @doc(type=adr)\n// @doc(type=rfc, status=draft)"
    m.implemented = true
    return m
}

// type 별 필수 섹션
fn doc_required_sections(doc_type: string) {
    if doc_type == "paper" {
        // brief 7섹션 기본. engineering/impact preset 은 @paper 가 확장
        return ["WHY", "COMPARE", "REQUIRES", "STRUCT", "FLOW", "EVOLVE", "VERIFY"]
    }
    if doc_type == "rfc" {
        // IETF RFC 스타일
        return ["Status", "Abstract", "Introduction", "Requirements", "Security Considerations"]
    }
    if doc_type == "adr" {
        // Architecture Decision Record (Michael Nygard 포맷)
        return ["Context", "Decision", "Consequences"]
    }
    if doc_type == "spec" {
        // API/CLI 명세
        return ["Overview", "Interface", "Behavior", "Errors", "Examples"]
    }
    if doc_type == "whitepaper" {
        // 제품/기술 백서
        return ["Executive Summary", "Problem", "Solution", "Architecture", "Validation"]
    }
    return []
}

// 파일 상단 @doc(type=X) 선언 감지 → type 반환
// 코멘트 3종 지원: `//` / `<!--` / `#`
fn detect_doc_type(lines) {
    let mut i = 0
    for line in lines {
        i = i + 1
        if i > 50 { break }
        let t = line.trim()
        let is_comment = t.starts_with("//") || t.starts_with("<!--") || t.starts_with("#")
        if !is_comment { continue }
        let idx = t.index_of("@doc(")
        if idx < 0 { continue }
        let after = t.substring(idx + 5, len(t))
        let cp = after.index_of(")")
        if cp < 0 { continue }
        let body = after.substring(0, cp)
        let parts = body.split(",")
        for p in parts {
            let kv = p.trim()
            if kv.starts_with("type=") {
                return kv.substring(5, len(kv)).trim()
            }
        }
    }
    return ""
}

fn check_doc(source: string, lines: [string]) {
    let mut out = []
    let doc_type = detect_doc_type(lines)
    if doc_type == "" { return out }   // @doc 선언 없으면 skip

    // type 유효성
    let valid = ["paper", "rfc", "adr", "spec", "whitepaper"]
    let mut is_valid = false
    for v in valid { if v == doc_type { is_valid = true } }
    if !is_valid {
        out = out.push(mk_msg("doc", "error", 1,
            "unknown @doc type: '" + doc_type + "' (valid: paper|rfc|adr|spec|whitepaper)"))
        return out
    }

    // 필수 섹션 누락 검사
    let required = doc_required_sections(doc_type)
    let mut missing = []
    for sec in required {
        if !has_section(lines, sec) { missing = missing.push(sec) }
    }
    if len(missing) > 0 {
        out = out.push(mk_msg("doc", "error", 1,
            "@doc(type=" + doc_type + ") missing required sections: " + join(missing, ", ")))
    }
    return out
}
