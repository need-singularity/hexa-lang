// self/attrs/own.hexa — @own 1급 attr (self-hosting doc harness)
//
// 문서가 자기 구조를 직접 선언 → hexa-lang 하네스가 그 선언만 검증.
// project `.doc-rules.json` / 전역 fallback / builtin 3경로 미경유.
//
// 사용:
//   <!-- @own(sections=[WHY, IMPACT], strict=true, order=sequential) -->
//
// L2 파서 / L3 3 검증기는 self/attrs/_own/ 서브모듈.

use "self/attrs/core"
use "self/attrs/_lib/error_catalog"
use "self/attrs/_own/harness"

fn meta_own() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "own"
    m.category = "meta"
    m.purpose = "문서 자기구조 선언 + hexa 하네스 저수준 강제 (self-hosting)"
    m.cost_rule = "@own(sections=[...], strict, order, depth, prefix) — 선언만으로 검증"
    m.side_effect = "@own 선언 있으면 project JSON / global fallback 미경유. low-level 강제."
    m.auto_test = "examples/paper/own_*.md 6 fixture"
    m.example = "<!-- @own(sections=[WHY, IMPACT], strict=true) -->"
    m.implemented = true
    return m
}

fn check_own(source: string, lines: [string]) {
    let decl = parse_own_decl(lines)
    let mut out = []
    if !decl["found"] { return out }
    if decl["malformed"] {
        out = out.push(mk_msg_k("own", "error", source, decl["decl_start"], "@own(...) declaration malformed: " + decl["reason"], "own_decl_malformed"))
        return out
    }
    let sm = check_own_sections(lines, decl, source)
    for m in sm { out = out.push(m) }
    let st = check_own_strict(lines, decl, source)
    for m in st { out = out.push(m) }
    let od = check_own_order(lines, decl, source)
    for m in od { out = out.push(m) }
    return out
}
