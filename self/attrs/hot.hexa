// self/attrs/hot.hexa — @hot hint attr
// mark fn as performance-critical — JIT/codegen prioritizes

use "self/attrs/core"

fn meta_hot() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "hot"
    m.category = "hint"
    m.purpose = "mark fn as performance-critical — codegen prioritizes (__attribute__((hot)))"
    m.cost_rule = "사용 빈도 top-10% self-time 검증 — 아니면 오명"
    m.auto_test = "profile: 해당 fn self-time 이 상위 10% 안에 있어야 유효"
    m.example = "@hot\nfn inner_loop(a: f64, b: f64) -> f64 { return a * b + 1.0 }"
    m.implemented = true
    return m
}

// @hot 은 hint 라 strict violation 없음. 단, @cold 와 동시 지정 불가.
fn check_hot(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "hot")
    for pair in pairs {
        let attr_line = pair[0]
        let fn_line = pair[1]
        let mut has_cold = false
        let mut k = attr_line - 3
        if k < 1 { k = 1 }
        while k <= fn_line {
            let idx = k - 1
            if idx >= 0 && idx < len(lines) {
                let t = lines[idx].trim()
                if t.contains("@cold") { has_cold = true; break }
            }
            k = k + 1
        }
        if has_cold {
            out = out.push(mk_msg("hot", "error", attr_line,
                "@hot + @cold on same fn is contradictory"))
        }
    }
    return out
}
