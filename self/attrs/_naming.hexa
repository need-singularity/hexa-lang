// self/attrs/_naming.hexa — @attr 명명 컨벤션 SSOT (SELF-HOST)
//
// 목적: 신규 @attr 이름 선정 시 이 파일이 유일한 기준.
// JSON/markdown 복제 금지 — 모든 룰 본문은 아래 .hexa 함수에서 반환.

use "self/attrs/core"

// 명명 형식 요구
fn naming_form() -> string {
    return "single lowercase English word (verb or adjective)"
}

fn naming_length_max() -> int {
    return 10
}

fn naming_forbidden() {
    return [
        "hyphen (-)",
        "underscore (_)",
        "compound words",
        "camelCase / PascalCase",
        "digits (except suffix like v2, and even then avoid)"
    ]
}

// 허용 카테고리 — shared/hexa-lang/attrs.json 동기
fn naming_allowed_categories() {
    return [
        "contract",
        "performance",
        "safety",
        "evolution",
        "rewrite",
        "memory",
        "ml",
        "workflow",
        "hint",
        "meta"
    ]
}

// 신규 @attr 만들 때 수행할 순서
fn naming_process() {
    return [
        "1. ls self/attrs/*.hexa → 기존 이름 전체 스캔, 의미 겹침 금지",
        "2. grep 관련 도메인 키워드 in self/attrs/*.hexa",
        "3. shared/hexa-lang/attrs.json _meta.naming_convention 컨벤션 준수",
        "4. 3+ 후보 제시 + 각 후보의 본뜻/뉘앙스 차이 명시",
        "5. 사용자 확정 후 3지점 동시 반영:",
        "   · self/attrs/<name>.hexa (meta_<name> + check_<name>)",
        "   · self/attrs/_registry.hexa (use + all_attr_names + meta_by_name + check_by_name)",
        "   · shared/hexa-lang/attrs.json (카탈로그 entry)"
    ]
}

// 예약어 — 명명 충돌 차단 (hexa 키워드 + 빌트인)
fn naming_reserved_words() -> [string] {
    return [
        "fn", "let", "mut", "const", "struct", "enum", "trait", "impl",
        "pub", "use", "return", "if", "else", "while", "for", "in",
        "break", "continue", "match", "true", "false", "null",
        "self", "this", "new", "as", "is", "try", "catch", "throw",
        "async", "await", "yield", "defer", "effect",
        "int", "float", "bool", "string", "char", "void", "any",
        "print", "println", "eprintln", "exit", "args", "env",
        "attr", "attrs"
    ]
}

fn naming_is_reserved(name: string) -> bool {
    for w in naming_reserved_words() {
        if w == name { return true }
    }
    return false
}

// 명명 검증 — 후보 name 이 컨벤션 부합 여부 bool 반환
fn naming_is_valid(name: string) -> bool {
    return naming_reason(name) == ""
}

// 위반 사유 — "" 이면 valid, 아니면 reason string
fn naming_reason(name: string) -> string {
    if len(name) == 0 { return "empty name" }
    if len(name) > naming_length_max() {
        return "exceeds max length " + to_string(naming_length_max())
                + " (got " + to_string(len(name)) + ")"
    }
    let chars = name.chars()
    let mut idx = 0
    for ch in chars {
        let s = to_string(ch)
        let c = char_code(s, 0)
        let is_lower = c >= 97 && c <= 122
        if !is_lower {
            if c == 95 { return "underscore '_' forbidden (single word only)" }
            if c == 45 { return "hyphen '-' forbidden" }
            if c >= 65 && c <= 90 { return "capital letter forbidden (lowercase only)" }
            if c >= 48 && c <= 57 { return "digit forbidden (avoid v2-style suffixes)" }
            return "non-lowercase-alpha char at index " + to_string(idx)
        }
        idx = idx + 1
    }
    if naming_is_reserved(name) { return "reserved word collision" }
    return ""
}

// 직렬화 — 디렉티브 텍스트 (attr_cli/CLAUDE.md 참조용)
fn naming_directive_text() -> string {
    let mut out = ""
    out = out + "─ @attr 명명 컨벤션 (self/attrs/_naming.hexa) ─\n"
    out = out + "형식: " + naming_form() + "\n"
    out = out + "최대 길이: " + to_string(naming_length_max()) + " chars\n\n"

    out = out + "금지:\n"
    for f in naming_forbidden() {
        out = out + "  ✗ " + f + "\n"
    }
    out = out + "\n허용 카테고리:\n"
    for c in naming_allowed_categories() {
        out = out + "  · " + c + "\n"
    }
    out = out + "\n순서:\n"
    for p in naming_process() {
        out = out + "  " + p + "\n"
    }
    return out
}
