// self/attrs/reduce.hexa — closed-form reduction

use "self/attrs/core"

fn meta_reduce() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "reduce"
    m.category = "rewrite"
    m.purpose = "closed-form reduction — e.g. sum 1..n = n*(n+1)/2"
    m.auto_test = "randomized N 값에서 원본 loop vs closed-form 동치 검증"
    m.example = "@reduce\nfn sum_to_n(n: int) -> int { let mut s = 0; for i in range(1,n+1) { s=s+i }; return s }"
    return m
}

fn check_reduce(source: string, lines: [string]) {
    return []
}
