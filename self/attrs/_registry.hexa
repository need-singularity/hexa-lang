fn all_attr_names() {
    return [
        "lint",
        "pure", "memoize", "lazy", "hot", "parallel",
        "fuse", "specialize", "inline", "cache",
        "limit", "retry", "fallback", "guard",
        "stable", "track", "deprecated",
        "optimize", "reduce", "approx", "algebraic",
        "compact", "profile", "autograd", "quantize",
        "test", "bench", "skip",
        "forbid", "allow", "sealed",
        "generated", "drift",
        "doc", "paper", "readme",
        "publish",
        "domain",
        "dispatch",
        "ossify",
        "refuse",
        "heavy",
        "watchdog",
        "monitor"
    ]
}

fn meta_by_name(name: string) -> AttrMeta {
    if name == "lint"        { return meta_lint() }
    if name == "pure"        { return meta_pure() }
    if name == "memoize"     { return meta_memoize() }
    if name == "lazy"        { return meta_lazy() }
    if name == "hot"         { return meta_hot() }
    if name == "parallel"    { return meta_parallel() }
    if name == "fuse"        { return meta_fuse() }
    if name == "specialize"  { return meta_specialize() }
    if name == "inline"      { return meta_inline() }
    if name == "cache"       { return meta_cache() }
    if name == "limit"       { return meta_limit() }
    if name == "retry"       { return meta_retry() }
    if name == "fallback"    { return meta_fallback() }
    if name == "guard"       { return meta_guard() }
    if name == "stable"      { return meta_stable() }
    if name == "track"       { return meta_track() }
    if name == "deprecated"  { return meta_deprecated() }
    if name == "optimize"    { return meta_optimize() }
    if name == "reduce"      { return meta_reduce() }
    if name == "approx"      { return meta_approx() }
    if name == "algebraic"   { return meta_algebraic() }
    if name == "compact"     { return meta_compact() }
    if name == "profile"     { return meta_profile() }
    if name == "autograd"    { return meta_autograd() }
    if name == "quantize"    { return meta_quantize() }
    if name == "test"        { return meta_test() }
    if name == "bench"       { return meta_bench() }
    if name == "skip"        { return meta_skip() }
    if name == "forbid"      { return meta_forbid() }
    if name == "allow"       { return meta_allow() }
    if name == "sealed"      { return meta_sealed() }
    if name == "generated"   { return meta_generated() }
    if name == "drift"       { return meta_drift() }
    if name == "doc"         { return meta_doc() }
    if name == "paper"       { return meta_paper() }
    if name == "readme"      { return meta_readme() }
    if name == "publish"     { return meta_publish() }
    if name == "domain"      { return meta_domain() }
    if name == "dispatch"    { return meta_dispatch() }
    if name == "ossify"      { return meta_ossify() }
    if name == "refuse"      { return meta_refuse() }
    if name == "heavy"       { return meta_heavy() }
    if name == "watchdog"    { return meta_watchdog() }
    if name == "monitor"     { return meta_monitor() }
    return empty_meta()
}

fn check_by_name(name: string, source: string, lines: [string]) {
    if name == "lint"        { return check_lint(source, lines) }
    if name == "pure"        { return check_pure(source, lines) }
    if name == "memoize"     { return check_memoize(source, lines) }
    if name == "lazy"        { return check_lazy(source, lines) }
    if name == "hot"         { return check_hot(source, lines) }
    if name == "parallel"    { return check_parallel(source, lines) }
    if name == "fuse"        { return check_fuse(source, lines) }
    if name == "specialize"  { return check_specialize(source, lines) }
    if name == "inline"      { return check_inline(source, lines) }
    if name == "cache"       { return check_cache(source, lines) }
    if name == "limit"       { return check_limit(source, lines) }
    if name == "retry"       { return check_retry(source, lines) }
    if name == "fallback"    { return check_fallback(source, lines) }
    if name == "guard"       { return check_guard(source, lines) }
    if name == "stable"      { return check_stable(source, lines) }
    if name == "track"       { return check_track(source, lines) }
    if name == "deprecated"  { return check_deprecated(source, lines) }
    if name == "optimize"    { return check_optimize(source, lines) }
    if name == "reduce"      { return check_reduce(source, lines) }
    if name == "approx"      { return check_approx(source, lines) }
    if name == "algebraic"   { return check_algebraic(source, lines) }
    if name == "compact"     { return check_compact(source, lines) }
    if name == "profile"     { return check_profile(source, lines) }
    if name == "autograd"    { return check_autograd(source, lines) }
    if name == "quantize"    { return check_quantize(source, lines) }
    if name == "test"        { return check_test(source, lines) }
    if name == "bench"       { return check_bench(source, lines) }
    if name == "skip"        { return check_skip(source, lines) }
    if name == "forbid"      { return check_forbid(source, lines) }
    if name == "allow"       { return check_allow(source, lines) }
    if name == "sealed"      { return check_sealed(source, lines) }
    if name == "generated"   { return check_generated(source, lines) }
    if name == "drift"       { return check_drift(source, lines) }
    if name == "doc"         { return check_doc(source, lines) }
    if name == "paper"       { return check_paper(source, lines) }
    if name == "readme"      { return check_readme(source, lines) }
    if name == "publish"     { return check_publish(source, lines) }
    if name == "domain"      { return check_domain(source, lines) }
    if name == "dispatch"    { return check_dispatch(source, lines) }
    if name == "ossify"      { return check_ossify(source, lines) }
    if name == "refuse"      { return check_refuse(source, lines) }
    if name == "heavy"       { return check_heavy(source, lines) }
    if name == "watchdog"    { return check_watchdog(source, lines) }
    if name == "monitor"     { return check_monitor(source, lines) }
    return []
}

// 모든 등록된 attr 이름이 _naming 규칙을 지키는지 자체 감사
// 반환: [[name, reason], ...] — 위반 목록 (empty = all pass)
fn check_naming_all() {
    let mut viol = []
    let names = all_attr_names()
    for n in names {
        let reason = naming_reason(n)
        if reason != "" {
            viol = viol.push([n, reason])
        }
    }
    return viol
}

// 파일에 실제로 사용된 @attr 만 추출 (전체 스캔 최적화)
fn attrs_used_in(lines: [string]) {
    let mut used = []
    let all = all_attr_names()
    for name in all {
        let marker = "@" + name
        let mut found = false
        for line in lines {
            let t = line.trim()
            if t.starts_with("//") { continue }
            if t.contains(marker) { found = true; break }
        }
        if found { used = used.push(name) }
    }
    return used
}

// 미등록 @xxx 감지 + 가장 가까운 등록된 이름 제안 (레벤슈타인 간소화)
fn unknown_attrs_in(lines: [string]) {
    let mut unknowns = []
    let all = all_attr_names()
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = line.trim()
        if t.starts_with("//") { continue }
        let at_idx = t.index_of("@")
        if at_idx < 0 { continue }
        // 간이 파싱: @ 뒤 word char 만
        let after = t.substring(at_idx + 1, len(t))
        let mut name = ""
        let chars = after.chars()
        for ch in chars {
            let c = char_code(to_string(ch), 0)
            let is_alpha = (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95
            let is_digit = c >= 48 && c <= 57
            if is_alpha || (name != "" && is_digit) {
                name = name + to_string(ch)
            } else {
                break
            }
        }
        if name == "" { continue }
        let mut is_known = false
        for k in all { if k == name { is_known = true; break } }
        if is_known { continue }
        // 내장 (pub, fn, etc 아닌 @-prefix 만)
        let hint = _suggest_closest(name, all)
        unknowns = unknowns.push([to_string(i), name, hint])
    }
    return unknowns
}

// 간이 유사도 — prefix match + 길이 차이
fn _suggest_closest(name: string, pool: [string]) -> string {
    let mut best = ""
    let mut best_score = 0
    for cand in pool {
        let mut score = 0
        let nlen = len(name)
        let clen = len(cand)
        let m = if nlen < clen { nlen } else { clen }
        let mut i = 0
        while i < m {
            if name.substring(i, i+1) == cand.substring(i, i+1) { score = score + 1 }
            i = i + 1
        }
        if score > best_score { best_score = score; best = cand }
    }
    if best_score < 2 { return "" }
    return best
}
