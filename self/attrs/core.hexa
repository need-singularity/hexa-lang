// self/attrs/core.hexa — attr 시스템 공통 타입 + scan 헬퍼
//
// LintMsg 확장 (2026-04-18):
//   기존 4-field (rule, level, line, msg) 유지 + path/col/hint/fix/ref 추가
//   → CLI (Claude Code) 가 machine-parse 하기 용이하도록 상세화
//
// 포맷터 2종:
//   · fmt_msg_human(m)  사람 읽기용 (multi-line, hint/fix/ref 들여쓰기)
//   · fmt_msg_json(m)   JSONL 한 줄 (기계 parse)
//   · fmt_msg(m)        = fmt_msg_human (기존 호출 호환)
//
// 호환 시그니처:
//   · mk_msg4(rule, level, line, msg)                             — 기존 4-arg 호출
//   · mk_msg (rule, level, path, line, col, msg, hint, fix, ref)  — 확장 9-arg
//   · 기존 code 의 `mk_msg(rule, level, line, msg)` 호출은 overload 로 받지 않음
//     (hexa-lang 은 default/overload 미지원). 기존 호출부는 mk_msg4 로 교체해야 함.

use "self/attrs/_lib/error_catalog"

struct AttrMeta {
    name: string,
    category: string,
    purpose: string,
    cost_rule: string,
    side_effect: string,
    requires: string,
    auto_test: string,
    example: string,
    synonym_of: string,
    implemented: bool
}

// 확장 LintMsg — 기존 4 필드 보존 + path/col/hint/fix/ref 추가
struct LintMsg {
    rule: string,
    level: string,
    line: int,
    msg: string,
    path: string,
    col: int,
    hint: string,
    fix: string,
    ref: string
}

fn empty_meta() -> AttrMeta {
    return AttrMeta {
        name: "", category: "", purpose: "", cost_rule: "",
        side_effect: "", requires: "", auto_test: "",
        example: "", synonym_of: "", implemented: false
    }
}

// ─── mk_msg 변종 ──────────────────────────────────────────────
// 9-arg 확장. 모든 신규 호출부는 이 시그니처 사용 권장.
fn mk_msg(rule: string, level: string, path: string, line: int, col: int,
          msg: string, hint: string, fix: string, ref: string) -> LintMsg {
    return LintMsg {
        rule: rule, level: level, line: line, msg: msg,
        path: path, col: col, hint: hint, fix: fix, ref: ref
    }
}

// 4-arg backward compat — 기존 `mk_msg(rule, level, line, msg)` 호출을
// 점진 마이그레이션하는 동안 사용. path/col/hint/fix/ref 는 빈 값.
fn mk_msg4(rule: string, level: string, line: int, msg: string) -> LintMsg {
    return mk_msg(rule, level, "", line, 0, msg, "", "", "")
}

// 카탈로그 lookup 기반 헬퍼 — error_catalog(key) → (hint, fix, ref) 자동 주입
// 사용: mk_msg_k("paper_verify", "error", source_path, line, "§7 에 atlas 재선언...", "paper_verify_atlas_reassert")
fn mk_msg_k(rule: string, level: string, path: string, line: int,
            msg: string, catalog_key: string) -> LintMsg {
    let trip = error_catalog(catalog_key)
    let hint = if len(trip) > 0 { trip[0] } else { "" }
    let fix  = if len(trip) > 1 { trip[1] } else { "" }
    let ref  = if len(trip) > 2 { trip[2] } else { "" }
    return mk_msg(rule, level, path, line, 0, msg, hint, fix, ref)
}

// ─── JSON escape (stdlib 부재, 수동) ──────────────────────────
fn _json_escape(s: string) -> string {
    let mut out = ""
    let chars = s.chars()
    for ch in chars {
        let c = to_string(ch)
        if c == "\\" { out = out + "\\\\" }
        else if c == "\"" { out = out + "\\\"" }
        else if c == "\n" { out = out + "\\n" }
        else if c == "\r" { out = out + "\\r" }
        else if c == "\t" { out = out + "\\t" }
        else { out = out + c }
    }
    return out
}

// ─── 포맷터 ───────────────────────────────────────────────────
// human: multi-line, 주 한 줄 + hint/fix/ref 들여쓰기
fn fmt_msg_human(m: LintMsg) -> string {
    let mut parts = []
    let path_seg = if m.path != "" { m.path } else { "" }
    let line_seg = if m.line > 0 { to_string(m.line) } else { "0" }
    let col_seg  = if m.col  > 0 { to_string(m.col)  } else { "0" }
    let locus = if path_seg != "" {
        path_seg + ":" + line_seg + ":" + col_seg
    } else {
        "line " + line_seg
    }
    parts = parts.push(m.level + "[@" + m.rule + "] " + locus + ": " + m.msg)
    if m.hint != "" { parts = parts.push("  hint: " + m.hint) }
    if m.fix  != "" { parts = parts.push("  fix:  " + m.fix)  }
    if m.ref  != "" { parts = parts.push("  ref:  " + m.ref)  }
    return parts.join("\n")
}

// json: JSONL 1 line (CLI machine parse)
fn fmt_msg_json(m: LintMsg) -> string {
    let mut parts = []
    parts = parts.push("\"severity\":\"" + _json_escape(m.level) + "\"")
    parts = parts.push("\"attr\":\"" + _json_escape(m.rule) + "\"")
    parts = parts.push("\"path\":\"" + _json_escape(m.path) + "\"")
    parts = parts.push("\"line\":" + to_string(m.line))
    parts = parts.push("\"col\":" + to_string(m.col))
    parts = parts.push("\"text\":\"" + _json_escape(m.msg) + "\"")
    parts = parts.push("\"hint\":\"" + _json_escape(m.hint) + "\"")
    parts = parts.push("\"fix\":\"" + _json_escape(m.fix) + "\"")
    parts = parts.push("\"ref\":\"" + _json_escape(m.ref) + "\"")
    return "{" + parts.join(",") + "}"
}

// 기존 이름 호환 — fmt_msg == fmt_msg_human
fn fmt_msg(m: LintMsg) -> string {
    return fmt_msg_human(m)
}

// ─── 포맷 분기 (환경 변수 HEXA_ATTR_FMT=json|human) ──────────
fn fmt_msg_auto(m: LintMsg) -> string {
    let mut mode = ""
    try { mode = env_var("HEXA_ATTR_FMT") } catch e { mode = "" }
    if mode == "json" { return fmt_msg_json(m) }
    return fmt_msg_human(m)
}

// error_catalog 는 self/attrs/_lib/error_catalog.hexa 에서 정의.
// mk_msg_k 는 호출부에서 use "self/attrs/_lib/error_catalog" 가 선행되어야 함.

// @<name> 마커가 있는 라인과 그 다음 fn 시그니처 라인을 짝으로 리턴 ([[attr_line, fn_line], ...])
fn find_attr_fn_pairs(lines: [string], attr_name: string) {
    let mut pairs = []
    let marker = "@" + attr_name
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = line.trim()
        if t.starts_with("//") { continue }
        if !t.contains(marker) { continue }
        let mut j = i
        while j < len(lines) {
            let nt = lines[j].trim()
            if nt.starts_with("fn ") || nt.starts_with("pub fn ") {
                pairs = pairs.push([i, j + 1])
                break
            }
            if nt != "" && !nt.starts_with("@") && !nt.starts_with("//") {
                break
            }
            j = j + 1
        }
    }
    return pairs
}

// fn 본문 라인 범위 (brace-balanced): [start_1based, end_1based]
fn fn_body_range(lines: [string], fn_line_1based: int) {
    let start_idx = fn_line_1based - 1
    let mut depth = 0
    let mut seen_open = false
    let mut i = start_idx
    while i < len(lines) {
        let ln = lines[i]
        let chars = ln.chars()
        for ch in chars {
            if ch == '{' { depth = depth + 1 }
            if ch == '{' { seen_open = true }
            if ch == '}' { depth = depth - 1 }
        }
        if seen_open && depth <= 0 {
            return [fn_line_1based, i + 1]
        }
        i = i + 1
    }
    return [fn_line_1based, len(lines)]
}
