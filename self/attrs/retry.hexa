// self/attrs/retry.hexa — retry on failure up to N times

use "self/attrs/core"

fn meta_retry() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "retry"
    m.category = "safety"
    m.purpose = "retry on failure up to N times (default 3)"
    m.side_effect = "idempotent assumption — 부작용 fn 에 쓰면 중복 발생"
    m.example = "@retry(5)\nfn fetch(url: string) -> string { ... }"
    return m
}

fn check_retry(source: string, lines: [string]) {
    return []
}
