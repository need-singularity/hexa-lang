// self/attrs/test.hexa — @test execution attr (grammar.jsonl group 3)
//
// 역할: `hexa test <file>` 러너가 본 attr 이 붙은 fn 을 자동 수집·실행.
//   · fn 이름 prefix 권장: `test_` OR `t_` (짧은 관행 허용)
//   · 조합: `@test @skip fn t_pending()` — 러너가 skip 카운트로 리포트
//   · 기대: fn 이 예외 없이 종료 = PASS, assert 실패 / throw / 비정상 종료 = FAIL
//
// SSOT: self/test_runner.hexa (수집+실행+리포트 로직)
// CLI : `hexa test <file>`  (self/main.hexa 디스패처)

use "self/attrs/core"

fn meta_test() {
    let mut m = empty_meta()
    m.name = "test"
    m.category = "execution"
    m.purpose = "테스트 fn 표시 — hexa test 러너가 수집·실행"
    m.side_effect = "런타임 프로세스 분리 + 기대값 비교"
    m.auto_test = "N/A (자기 자신이 테스트)"
    m.example = "@test\nfn test_add() { assert(1 + 1 == 2) }"
    m.implemented = true
    return m
}

fn check_test(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "test")
    for pair in pairs {
        let fn_line = pair[1]
        let idx = fn_line - 1
        if idx < 0 || idx >= len(lines) { continue }
        let t = lines[idx].trim()
        // @test fn 이름은 `test_` 또는 `t_` prefix 권장
        let ok = t.contains("fn test_")
                 || t.contains("pub fn test_")
                 || t.contains("fn t_")
                 || t.contains("pub fn t_")
        if !ok {
            out = out.push(mk_msg4("test", "warn", fn_line,
                "@test fn 이름 권장: `test_<what>` or `t_<what>` prefix"))
        }
    }
    return out
}

// Runner 가 사용하는 수집 helper — @test fn 이름 목록 추출.
// 반환: [[fn_name, is_skip], ...]  (is_skip = 1 if @skip 도 같이 붙음)
fn collect_test_fns(lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "test")
    for pair in pairs {
        let attr_line = pair[0]
        let fn_line = pair[1]
        let idx = fn_line - 1
        if idx < 0 || idx >= len(lines) { continue }
        let t = lines[idx].trim()
        // 이름 파싱: "fn NAME(" or "pub fn NAME("
        let mut body = t
        if body.starts_with("pub fn ") { body = body.substring(7, len(body)) }
        else if body.starts_with("fn ") { body = body.substring(3, len(body)) }
        else { continue }
        let paren = body.index_of("(")
        if paren <= 0 { continue }
        let name = body.substring(0, paren).trim()
        if len(name) == 0 { continue }
        // @skip 감지 — attr_line 부터 fn_line 사이에 @skip marker
        let mut skip = 0
        let mut j = attr_line - 1
        while j < idx {
            let lt = lines[j].trim()
            if lt.contains("@skip") { skip = 1; break }
            j = j + 1
        }
        out = out.push([name, to_string(skip)])
    }
    return out
}
