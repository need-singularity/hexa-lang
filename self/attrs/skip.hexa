// self/attrs/skip.hexa — @skip execution attr (grammar.jsonl group 3)

use "self/attrs/core"

fn meta_skip() {
    let mut m = empty_meta()
    m.name = "skip"
    m.category = "execution"
    m.purpose = "일시적 실행 제외 — @test/@bench 과 조합하여 해당 러너가 skip"
    m.side_effect = "해당 fn 런타임 호출 건너뜀 (reason 기록)"
    m.example = "@test\n@skip(\"flaky in CI\")\nfn test_network_x() { ... }"
    return m
}

fn check_skip(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "skip")
    for pair in pairs {
        let attr_line = pair[0]
        let fn_line = pair[1]
        // @skip 은 @test 나 @bench 와 함께 있어야 의미 있음
        let mut has_companion = false
        let mut k = attr_line - 3
        if k < 1 { k = 1 }
        while k <= fn_line {
            let idx = k - 1
            if idx >= 0 && idx < len(lines) {
                let t = lines[idx].trim()
                if t.contains("@test") || t.contains("@bench") {
                    has_companion = true
                }
            }
            k = k + 1
        }
        if !has_companion {
            out.push(mk_msg("skip", "warn", attr_line,
                "@skip without @test/@bench companion has no effect"))
        }
    }
    return out
}
