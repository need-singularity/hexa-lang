// self/attrs/nonblock.hexa — tool-dispatch 단위 sync 블로킹 raw 차단
//
// 배경 (2026-04-18, /Users/ghost/loss/fix.txt):
//   · CLAUDE.md soft rule "대화 블로킹 절대 금지" 8회 반복 → 76회 Interrupt 재현
//   · 하네스 instruction 레벨로는 Claude 가 sync Bash/Agent 호출을 계속 함
//   · 원인: 텍스트 지시는 모델이 무시 가능. tool_input 레벨 machine gate 필요.
//
// 설계 (G hybrid):
//   · SSOT         — .hexa-attrs 의 `nonblock = Bash, Agent, Task`
//   · codegen #1   — PreToolUse bash hook (jq 파싱 → permissionDecision=deny)
//   · codegen #2   — .claude/settings.json hooks.PreToolUse entry (matcher=Bash|Agent|Task)
//   · drift 차단   — 두 산출물 모두 @generated 헤더, 수동 편집 불가
//
// 차후 (HX10 P7-6 이후):
//   · Claude Code CLI hook 의존성 제거 목표
//   · hexa 런타임 내장 dispatcher 가 tool 호출 직접 검증 → 본 codegen 은 bridge
//
// 대비 (기존 attr):
//   · @forbid(hook,skill) — 파일 Write/Edit 경로 차단 (정적)
//   · @refuse             — 함수 진입 시 exit(77) (runtime, fn 단위)
//   · @nonblock (this)    — tool dispatch 단위 runtime gate (tool 호출 전 REJECT)

use "self/attrs/core"

fn meta_nonblock() -> AttrMeta {
    let mut m = empty_meta()
    m.name        = "nonblock"
    m.category    = "safety"
    m.purpose     = "tool-dispatch 단위 sync 블로킹 raw 차단 — PreToolUse hook 자동 생성"
    m.cost_rule   = "대상 tool 호출 직전 JSON 파싱 → run_in_background!=true 면 deny"
    m.side_effect = ".attr-generated/pre_tool_nonblock.sh 생성 + settings.json hooks.PreToolUse entry (수동 merge)"
    m.requires    = "jq (hook runtime), .hexa-attrs nonblock 선언"
    m.auto_test   = "Bash run_in_background=false 샘플 JSON 입력 → permissionDecision=deny 확인"
    m.example     = "// .hexa-attrs\nnonblock = Bash, Agent, Task\n// → 세 tool 의 sync 호출 전부 raw 차단"
    m.implemented = true
    return m
}

// 선언적 marker. 정적 source lint 는 no-op — 실제 enforcement 는 codegen hook.
fn check_nonblock(source: string, lines: [string]) {
    return []
}

// ─── codegen helpers ───
// .hexa-attrs 의 `nonblock = ...` 토큰 리스트를 runtime 산출물로 변환

fn _nonblock_default_tools() {
    return ["Bash", "Agent", "Task"]
}

fn _nonblock_reject_reason() {
    return "BLOCKING REJECTED by @nonblock — run_in_background=true 또는 Agent fan-out 필수. 근거: /Users/ghost/loss/fix.txt 2026-04-18 76x interrupt."
}

// 입력 토큰 리스트 → PreToolUse bash hook 본문
// hook 은 stdin 으로 받은 tool_use JSON 을 jq 로 파싱,
// tool_name 이 매칭되고 run_in_background != "true" 이면
// {"hookSpecificOutput": {"permissionDecision":"deny", ...}} 반환 후 exit 0.
fn compile_nonblock_pretool_hook(tokens) {
    let mut list = tokens
    if len(list) == 0 { list = _nonblock_default_tools() }
    let reason = _nonblock_reject_reason()

    let mut arms = []
    for t in list {
        let arm = "    " + t + ")\n" +
                  "      bg=$(printf '%s' \"$payload\" | jq -r '.tool_input.run_in_background // false')\n" +
                  "      if [ \"$bg\" != \"true\" ]; then\n" +
                  "        jq -n --arg r '" + reason + "' '{hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"deny\",permissionDecisionReason:$r}}'\n" +
                  "        exit 0\n" +
                  "      fi\n" +
                  "      ;;"
        arms.push(arm)
    }

    let body = "# source tokens: " + join(list, ",") + "\n" +
               "set -eu\n" +
               "payload=$(cat)\n" +
               "tool=$(printf '%s' \"$payload\" | jq -r '.tool_name // empty')\n" +
               "case \"$tool\" in\n" +
               join(arms, "\n") + "\n" +
               "  *) ;;\n" +
               "esac\n" +
               "exit 0"
    return body
}

// Claude Code settings.json 에 merge 할 PreToolUse entry (JSON 스니펫)
fn compile_nonblock_settings_entry(tokens) {
    let mut list = tokens
    if len(list) == 0 { list = _nonblock_default_tools() }
    let matcher = join(list, "|")
    let entry = "{\n" +
                "  \"_source\": \".hexa-attrs\",\n" +
                "  \"_merge_into\": \".claude/settings.json#/hooks/PreToolUse\",\n" +
                "  \"PreToolUse\": [\n" +
                "    {\n" +
                "      \"matcher\": \"" + matcher + "\",\n" +
                "      \"hooks\": [\n" +
                "        {\n" +
                "          \"type\": \"command\",\n" +
                "          \"command\": \"bash ${CLAUDE_PROJECT_DIR}/.attr-generated/pre_tool_nonblock.sh\"\n" +
                "        }\n" +
                "      ]\n" +
                "    }\n" +
                "  ]\n" +
                "}"
    return entry
}
