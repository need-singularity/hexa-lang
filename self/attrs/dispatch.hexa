// self/attrs/dispatch.hexa — @dispatch workflow attr (self-host SSOT)
//
// Policy: independent work is fanned out to parallel background subagents.
// The main conversation never blocks. This file is the sole SSOT — no JSON
// duplication. Consumers (CLAUDE.md, attr_cli, guards) read typed data from
// the functions below, never copy strings.

use "self/attrs/core"

// ─── Typed policy surface ──────────────────────────────────────

struct DispatchPolicy {
    triggers: [string],
    principles: [string],
    anti_patterns: [string],
    correct_pattern: string,
    subagent_routing: [[string]],
    bg_threshold_seconds: int,
    bg_threshold_queries: int,
    bg_threshold_bytes: int
}

fn dispatch_policy() -> DispatchPolicy {
    return DispatchPolicy {
        triggers: [
            "go", "keep", "loop",
            "progress", "status",
            "parallel", "background", "subagent", "concurrent"
        ],
        principles: [
            "two or more independent tasks → single message with multiple Agent tool blocks",
            "long-running or high-context tasks → run_in_background=true",
            "main conversation thread stays responsive — never block on subagent result",
            "route by intent — exploration→Explore, planning→Plan, generic→general-purpose"
        ],
        anti_patterns: [
            "sequential chain of independent tasks (A then B then C)",
            "single Agent call followed by report, then next call (round-trip burn)",
            "foreground execution of work expected to exceed 30 seconds",
            "one-at-a-time processing when >=2 independent work items exist"
        ],
        correct_pattern: "single message: Agent A bg=true; Agent B bg=true; Agent C bg=true",
        subagent_routing: [
            ["exploration", "Explore"],
            ["planning",    "Plan"],
            ["generic",     "general-purpose"]
        ],
        bg_threshold_seconds: 30,
        bg_threshold_queries: 3,
        bg_threshold_bytes:   2048
    }
}

// ─── attr meta (catalog surface) ───────────────────────────────

fn meta_dispatch() -> AttrMeta {
    let mut m = empty_meta()
    m.name        = "dispatch"
    m.category    = "workflow"
    m.purpose     = "independent task MUST be fanned out as parallel background subagent — main conversation never blocks"
    m.cost_rule   = "task has no dep on current context AND (runs > 30s OR spans > 3 queries OR output > 2KB)"
    m.side_effect = "spawns Agent tool call; main context stays unblocked"
    m.requires    = "Agent tool + run_in_background=true for long tasks"
    m.auto_test   = "dispatch_policy() structural self-check"
    m.example     = "@dispatch(\"Explore\", bg=true)\nfn audit_repo() { /* spawned as bg Explore agent */ }"
    m.implemented = true
    return m
}

// ─── check — linter entry ──────────────────────────────────────
// Workflow attr: source-level static check is a no-op. Enforcement
// happens at the Agent tool dispatch layer (agent_ledger), not in .hexa text.

fn check_dispatch(source: string, lines: [string]) {
    return []
}
