// self/attrs/manual_main.hexa — @manual_main opt-out marker
//
// 배경 (2026-04-26, silent-failure-enforcement Class 1):
//   · hexa-strict 는 `fn main()` 을 자동 호출 — codegen_c2 T34 (line 940) +
//     hexa_full T49 (line 18289).
//   · 사용자가 `fn main()` 정의 + 톱-레벨 `main()` 호출을 동시에 작성하면:
//       - codegen_c2 T34: explicit 호출 감지 시 auto-call 억제 → 1회 실행
//       - hexa_full T49: deliberately double-call ("user's responsibility")
//     인터프리터 경로에서 silent double-execution 발생.
//   · 위 silent-double 의 실제 witness: be77e0c30 (`created: <path>` 두 번 출력).
//
// 설계:
//   · parser._check_main_double_invoke() 가 (FnDecl name=main) +
//     (top-level `main()` ExprStmt) 동시 발견 시 hard-fail.
//   · `@manual_main` attr 부착 시 검사 통과 — 의도적 explicit-invoke 패턴
//     (CLI scaffold 등) 보존.
//
// 등록 이름: "manual_main" (snake_case, _naming 규칙 준수)
// 인식 마커: `@manual_main` (canonical only)

use "self/attrs/core"

fn meta_manual_main() -> AttrMeta {
    let mut m = empty_meta()
    m.name        = "manual_main"
    m.category    = "safety"
    m.purpose     = "fn main() 의 auto-invoke 를 opt-out — 명시적 main() 호출과의 중복 검사 통과"
    m.cost_rule   = "parser._check_main_double_invoke() 가 (fn main + top-level main()) 동시 발견 시 fail; @manual_main 부착 시 skip"
    m.side_effect = "declarative marker. 런타임 동작 변경 없음 — 단순히 silent-failure-enforcement Class 1 검사를 우회"
    m.requires    = "self/parser.hexa _check_main_double_invoke (parser-level enforcement)"
    m.auto_test   = "fn main() {} \\n main()  → block; @manual_main fn main() {} \\n main()  → pass"
    m.example     = "// @manual_main — CLI scaffold needs explicit invoke order\n@manual_main\nfn main() { setup(); main_loop() }\nmain()"
    m.implemented = true
    return m
}

// ─── check (parser-side; this file is the SSOT for the marker) ─────────
// 실제 검사 로직은 self/parser.hexa _check_main_double_invoke 에 인라인.
// 본 attr 는 marker 등록 + meta SSOT 만 담당 — _registry 에 이름 등록 시
// unknown_attrs_in 에서 미인식 attr 경고가 사라진다.
fn check_manual_main(source: string, lines: [string]) {
    // attr 자체는 declarative — check 는 parser 가 이미 수행.
    // 본 fn 은 _registry dispatch shape 만족용 stub.
    let mut out = []
    return out
}
