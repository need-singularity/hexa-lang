// self/attrs/inline.hexa — force inline (bypass call overhead)

use "self/attrs/core"

fn meta_inline() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "inline"
    m.category = "performance"
    m.purpose = "force inline — bypass call overhead (__attribute__((always_inline)))"
    m.cost_rule = "fn_size < 50 LOC AND call_count > 10"
    m.example = "@inline\nfn clamp(x: int, lo: int, hi: int) -> int { ... }"
    m.implemented = true
    return m
}

fn check_inline(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "inline")
    for pair in pairs {
        let attr_line = pair[0]
        let fn_line = pair[1]
        let body_range = fn_body_range(lines, fn_line)
        let body_lines = body_range[1] - body_range[0]
        if body_lines > 80 {
            out.push(mk_msg("inline", "warn", attr_line,
                "@inline on large fn (" + to_string(body_lines) + " lines) — likely code bloat"))
        }
    }
    return out
}
