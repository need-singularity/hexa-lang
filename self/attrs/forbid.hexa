// self/attrs/forbid.hexa — @forbid(token) safety attr
// 프로젝트 루트 .hexa-attrs 또는 파일 상단 `// @forbid(hook, skill)` 선언

use "self/attrs/core"

fn meta_forbid() {
    let mut m = empty_meta()
    m.name = "forbid"
    m.category = "safety"
    m.purpose = "프로젝트/파일 스코프 패턴 차단 — hook/skill/settings_edit 등 bulk 카테고리"
    m.cost_rule = "Write/Edit 도달 전 pre_tool_guard 가 질의 → REJECT + alternate path 제시"
    m.side_effect = "위반 시 exit 1 (lint)/REJECT (pre-tool). 패턴 사전은 forbid_patterns.json"
    m.auto_test = "샘플 hook 파일 Write → REJECT 확인, bypass 토큰 있으면 통과"
    m.example = "// .hexa-attrs\nforbid = [\"hook\", \"skill\"]\nallow  = [\"hook:shared/harness/*\"]"
    m.implemented = false
    return m
}

// ─── 패턴 사전 (forbid_patterns.json 의 hexa 반영) ───
// 각 token → [[kind, value], ...] 형태로 리턴

fn _forbid_patterns_for(token: string) {
    if token == "hook" {
        return [
            ["path_prefix", ".claude/hooks/"],
            ["path_prefix", "shared/hooks/"],
            ["path_prefix", ".githooks/"],
            ["path_prefix", ".git/hooks/"],
            ["content_keyword", "PostToolUse"],
            ["content_keyword", "PreToolUse"],
            ["content_keyword", "UserPromptSubmit"]
        ]
    }
    if token == "skill" {
        return [
            ["path_prefix", ".claude/skills/"],
            ["path_prefix", "shared/skills/"],
            ["path_suffix", ".skill.json"]
        ]
    }
    if token == "settings_edit" {
        return [
            ["path_suffix", "settings.json"],
            ["path_suffix", "settings.local.json"]
        ]
    }
    if token == "env_export" {
        return [
            ["path_contains", ".claude/settings.json"],
            ["path_contains", ".claude/CLAUDE.md"]
        ]
    }
    if token == "destructive_git" {
        return [
            ["content_keyword", "git reset --hard"],
            ["content_keyword", "git push --force"],
            ["content_keyword", "git push -f "],
            ["content_keyword", "git branch -D"],
            ["content_keyword", "git clean -f"]
        ]
    }
    if token == "rlimit_cap" {
        return [
            ["content_keyword", "RLIMIT_AS"],
            ["content_keyword", "RLIMIT_DATA"],
            ["content_keyword", "RLIMIT_RSS"],
            ["content_keyword", "setrlimit("],
            ["content_keyword", "ulimit -v"],
            ["content_keyword", "ulimit -m"],
            ["content_keyword", "ulimit -d"]
        ]
    }
    return []
}

fn _forbid_alternates_for(token: string) {
    if token == "hook" {
        return [
            "shared/harness/entry.hexa 자율 서브커맨드로 훅 기능 추가",
            "shared/harness/post_edit.hexa 확장 (post-commit 시점)",
            "loop-guard.hexa 정기 스캔 추가"
        ]
    }
    if token == "skill" {
        return [
            "기존 skill 확장 (description/args 추가)",
            "프로젝트 CLI 서브커맨드로 대체 (attr_cli.hexa 같은 패턴)"
        ]
    }
    if token == "settings_edit" {
        return [
            "shared/config/permissions_ssot.json 에 추가 (nexus)",
            "update-config skill 호출"
        ]
    }
    if token == "env_export" {
        return [
            "프로젝트 루트 CLAUDE.md 에 로컬 지시 추가",
            "shared/CLAUDE.md 공통 지시 수정 (nexus)"
        ]
    }
    if token == "destructive_git" {
        return [
            "git revert 로 수정 커밋 생성",
            "git checkout 개별 파일 복구",
            "백업 브랜치 생성 후 실험"
        ]
    }
    if token == "rlimit_cap" {
        return [
            "launchd plist HardResourceLimits + jetsam 태그 (Mac 전용)",
            "외부 watchdog: pid_tree BFS + sum_rss_kb aggregation (stage0 child 포함)",
            "safe_hexa_launchd 래퍼 — tree RSS 감시 후 SIGKILL",
            "Linux 전용 스크립트는 // @allow-rlimit-cap 주석으로 면제"
        ]
    }
    return []
}

fn _forbid_doc_for(token: string) {
    if token == "hook"           { return "CLAUDE.md H-NOHOOK, shared/rules/lockdown.json L0" }
    if token == "skill"          { return "CLAUDE.md L0 Guard — ~/.claude 전역 변경 금지" }
    if token == "settings_edit"  { return "L0 Guard — settings.json SSOT harness 전용" }
    if token == "env_export"     { return "L0 Guard — shared/rules/lockdown.json" }
    if token == "destructive_git"{ return "CLAUDE.md Git Safety Protocol" }
    if token == "rlimit_cap"     { return "feedback_macos_setrlimit_einval — macOS 15.6 user-space RLIMIT_AS/DATA/RSS 거부 class (91306 panic)" }
    return ""
}

fn _forbid_bypass_for(token: string) {
    return "// @allow-" + token + " (정당화 코멘트 필수)"
}

// ─── AOT compile emitters ───
// 각 token → Claude Code permissions.deny 엔트리 배열

fn compile_claude_permissions_for(token: string) {
    if token == "hook" {
        return [
            "Write(**/.claude/hooks/**)",
            "Edit(**/.claude/hooks/**)",
            "Write(**/shared/hooks/**)",
            "Edit(**/shared/hooks/**)",
            "Write(**/.githooks/**)",
            "Write(**/.git/hooks/**)"
        ]
    }
    if token == "skill" {
        return [
            "Write(**/.claude/skills/**)",
            "Edit(**/.claude/skills/**)",
            "Write(**/shared/skills/**)",
            "Write(**/*.skill.json)"
        ]
    }
    if token == "settings_edit" {
        return [
            "Write(**/settings.json)",
            "Write(**/settings.local.json)"
        ]
    }
    if token == "env_export" {
        return [
            "Write(~/.claude/**)",
            "Edit(~/.claude/**)"
        ]
    }
    // destructive_git 은 Bash 카테고리 (deny 대신 Bash 차단 별도 처리)
    return []
}

// git pre-commit shim 라인 생성 (bash)
// 각 token → staged 파일 중 매칭되면 exit 1 + 유도 메시지
fn compile_git_precommit_for(token: string) {
    if token == "hook" {
        return "git diff --cached --name-only | grep -E '^(\\.claude/hooks/|shared/hooks/|\\.githooks/)' && { echo 'REJECT: @forbid(hook) — use shared/harness/entry.hexa instead'; exit 1; } || true"
    }
    if token == "skill" {
        return "git diff --cached --name-only | grep -E '^(\\.claude/skills/|shared/skills/|.*\\.skill\\.json$)' && { echo 'REJECT: @forbid(skill) — extend existing skills or use project CLI'; exit 1; } || true"
    }
    if token == "settings_edit" {
        return "git diff --cached --name-only | grep -E '(^|/)settings(\\.local)?\\.json$' && { echo 'WARN: settings.json edit staged — verify @allow-settings-edit marker exists'; } || true"
    }
    if token == "destructive_git" {
        return "# destructive_git: no staged-file check needed (covered by pre-push)"
    }
    if token == "rlimit_cap" {
        return "git diff --cached --name-only -z | xargs -0 -I{} grep -lE 'RLIMIT_(AS|DATA|RSS)|setrlimit\\(|ulimit -[vmd]' {} 2>/dev/null | grep -v '@allow-rlimit-cap' && { echo 'REJECT: @forbid(rlimit_cap) — macOS setrlimit RLIMIT_AS/DATA/RSS 는 user-space EINVAL. watchdog 패턴으로 대체 (feedback_macos_setrlimit_einval).'; exit 1; } || true"
    }
    return ""
}

// target_path 에 대해 어떤 패턴이 매칭되는지 확인
// return: 매칭된 [kind, value] 배열 (없으면 [])
fn forbid_match(token: string, target_path: string) {
    let patterns = _forbid_patterns_for(token)
    let mut hits = []
    for pat in patterns {
        let kind = pat[0]
        let value = pat[1]
        let mut matched = false
        if kind == "path_prefix" {
            if target_path.starts_with(value) { matched = true }
        } else if kind == "path_suffix" {
            if target_path.ends_with(value) { matched = true }
        } else if kind == "path_contains" {
            if target_path.contains(value) { matched = true }
        } else if kind == "content_keyword" {
            // content_keyword 는 파일 읽고 검사 필요 — caller 가 처리
            // 여기선 path 기반만 처리
        }
        if matched { hits = hits.push(pat) }
    }
    return hits
}

// 파일 상단 `// @forbid(token1, token2)` 선언 검사
// 프로젝트 .hexa-attrs 는 attr_cli.hexa policy 서브커맨드가 별도 처리
fn check_forbid(source: string, lines: [string]) {
    let mut out = []
    let mut i = 0
    for line in lines {
        i = i + 1
        if i > 20 { break }
        let t = line.trim()
        if !t.starts_with("//") { continue }
        let idx = t.index_of("@forbid")
        if idx < 0 { continue }
        let after = t.substring(idx + 7, len(t))
        let op = after.index_of("(")
        let cp = after.index_of(")")
        if op < 0 || cp < 0 {
            out = out.push(mk_msg("forbid", "warn", i,
                "@forbid missing '(...)' token list"))
            continue
        }
        let body = after.substring(op + 1, cp)
        let toks = split(body, ",")
        let valid = ["hook", "skill", "settings_edit", "env_export", "destructive_git", "rlimit_cap"]
        for tok in toks {
            let tt = tok.trim()
            if tt == "" { continue }
            let mut is_valid = false
            for v in valid { if v == tt { is_valid = true } }
            if !is_valid {
                out = out.push(mk_msg("forbid", "warn", i,
                    "unknown @forbid token: '" + tt + "' (valid: hook|skill|settings_edit|env_export|destructive_git|rlimit_cap)"))
            }
        }
    }
    return out
}
