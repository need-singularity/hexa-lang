// self/attrs/generated.hexa — @generated 메타 attr
// attr_cli compile 산출물 헤더 마커. "이 파일은 생성물이며 수동 편집 금지"

use "self/attrs/core"

fn meta_generated() {
    let mut m = empty_meta()
    m.name = "generated"
    m.category = "meta"
    m.purpose = "compile 산출물 마커 — attr_cli 가 소스로부터 생성한 파일 표시"
    m.cost_rule = "overwrite 안전 확보: 마커 존재 시 attr_cli 가 자유롭게 재생성"
    m.side_effect = "수동 편집하면 drift 감지 대상"
    m.example = "// @generated by hexa self/attr_cli.hexa compile\n// DO NOT EDIT — source: .hexa-attrs"
    m.implemented = true
    return m
}

// 생성 헤더 렌더 (확장자별 주석 스타일)
fn generated_header(source_path: string, comment_prefix: string) {
    return comment_prefix + " @generated by hexa self/attr_cli.hexa compile\n" +
           comment_prefix + " DO NOT EDIT — source: " + source_path + "\n" +
           comment_prefix + " regenerate: `hexa self/attr_cli.hexa compile`\n"
}

// @generated 마커 검출 — attr_cli 가 overwrite 해도 안전한지 확인
fn has_generated_marker(path: string) {
    let mut source = ""
    try {
        source = to_string(read_file(path))
    } catch e { return false }
    let head = source
    if len(source) > 500 { head = source.substring(0, 500) }
    return head.contains("@generated by hexa")
}

fn check_generated(source: string, lines: [string]) {
    // @generated 파일은 린트 대상 제외 (소스가 진실)
    return []
}
