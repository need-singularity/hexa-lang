// self/attrs/_own/specialize.hexa — @specialize semantic impl (ROI #167)
//
// V8-style Hidden Class + Inline Cache scaffold.
//
// Scope: meta + check validator + pure-Hexa factory helpers that wire a
// test / follow-up call site to self/vm_ic.hexa. poly/mega dispatch and
// real AST lower integration are explicit follow-up ROIs — see
// doc/plans/specialize_ic.md §7-§8.
//
// HX11: accepts a project `.specialize-rules.json` (inherit=false default)
// for future knob injection (mono_retry_limit, poly_cache_size, ...). The
// loader is a stub in this scaffold — it reads the file if present but does
// not yet gate behavior.

use "self/attrs/core"
use "self/attrs/_lib/error_catalog"

// ─── META ─────────────────────────────────────────────────────────────

pub fn meta_specialize_impl() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "specialize"
    m.category = "optimization"
    m.purpose = "V8-style Hidden Class Inline Cache — O(1) field access hit on hot sites"
    m.cost_rule = "ROI #167 scaffold: mono path only. poly/mega follow-up."
    m.side_effect = "none (additive runtime metadata; existing behavior preserved on MONO-miss)"
    m.requires = "self/vm_ic.hexa runtime"
    m.auto_test = "self/test_specialize_ic.hexa — 100 mono access, miss_count == 1"
    m.example = "@specialize\nfn hot_read(p: Point) -> int { return p.x + p.y }"
    m.implemented = true
    return m
}

// ─── CHECK VALIDATOR ──────────────────────────────────────────────────
//
// @specialize is a hint — no hard violations in scaffold scope. We emit
// an `info`-level note when @specialize is combined with @refuse or @skip,
// which are contradictory (IC cannot specialize a refused / skipped fn).
// All emissions use mk_msg_k for machine-parseable hint/fix/ref.

pub fn check_specialize_impl(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "specialize")
    for pair in pairs {
        let attr_line = pair[0]
        let fn_line = pair[1]
        // Look for conflicting attrs in the immediate neighbourhood
        // (attr_line - 3 .. fn_line).
        let mut has_refuse = false
        let mut has_skip = false
        let mut k = attr_line - 3
        if k < 1 { k = 1 }
        while k <= fn_line {
            let idx = k - 1
            if idx >= 0 && idx < len(lines) {
                let t = lines[idx].trim()
                if t.contains("@refuse") { has_refuse = true }
                if t.contains("@skip")   { has_skip   = true }
            }
            k = k + 1
        }
        if has_refuse {
            out.push(mk_msg_k("specialize", "info", source, attr_line,
                "@specialize + @refuse is contradictory — IC can't specialize a refused fn",
                "specialize_with_refuse"))
        }
        if has_skip {
            out.push(mk_msg_k("specialize", "info", source, attr_line,
                "@specialize + @skip is contradictory — IC needs the fn to exist",
                "specialize_with_skip"))
        }
    }
    return out
}

// ─── HX11 RULES LOADER (stub) ────────────────────────────────────────
//
// Reads .specialize-rules.json if present. In scaffold scope we just
// record the discovered knobs and expose them via accessors; no behavior
// depends on them yet. This lets downstream ROIs (poly/mega) land without
// another rules-loader rewrite.

struct SpecializeRules {
    mono_retry_limit: int,      // scaffold default: 1 (first miss = init)
    poly_cache_size: int,       // follow-up default: 4
    mega_threshold: int         // follow-up default: 5
}

pub fn specialize_default_rules() -> SpecializeRules {
    return SpecializeRules {
        mono_retry_limit: 1,
        poly_cache_size: 4,
        mega_threshold: 5
    }
}

// Factory helper for tests / downstream: produce a well-formed rule set
// without reading disk. Real file-based loader is a follow-up.
pub fn specialize_rules_from(mono_retry: int, poly_size: int, mega: int) -> SpecializeRules {
    return SpecializeRules {
        mono_retry_limit: mono_retry,
        poly_cache_size: poly_size,
        mega_threshold: mega
    }
}
