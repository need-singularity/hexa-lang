// self/attrs/_own/symbolic.hexa вҖ” @symbolic лҢҖмҲҳ лӢЁмҲңнҷ” attr (ROI #151)
//
// Design
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// @symbolic мқҖ compile-time (AST/IR) peephole лЎң fn body лӮҙ мҲҳмӢқмқ„ лӢЁмҲңнҷ”н•ңлӢӨ.
//  (a) x * 2^n  (n in 1..max)  вҶ’  x << n        (shl strength reduction)
//  (b) x / 2^n  (n in 1..max)  вҶ’  x >> n        (ashr strength reduction)
//  (c) x * 1  / 1 * x  / x + 0  / 0 + x   вҶ’  x  (identity)
//  (d) x * 0  / 0 * x                      вҶ’  0 (annihilation)
//
// кё°мЎҙ ARM64 peephole (self/codegen/peephole.hexa) мқҖ post-codegen л°”мқҙл„ҲлҰ¬ мҲҳмӨҖ.
// @symbolic мқҖ pre-codegen AST/IR lowering pass вҖ” л Ҳмқҙм–ҙк°Җ лӢӨлҘҙлӢӨ.
//
// ліё нҢҢмқјмқҖ (1) meta, (2) check validator, (3) HX11 rules loader,
// (4) AST peephole apply_symbolic, (5) pow2/log2 helper м ңкіө.
//
// HX11: `.symbolic-rules.json` мңјлЎң max_shift_bits / enable_identity /
//        enable_annihilation мЈјмһ… к°ҖлҠҘ. _meta.inherit=false кё°ліё.
//
// мЈјмқҳ
//   В· float н”јм—°мӮ°мһҗм—җлҠ” м Ғмҡ©н•ҳм§Җ м•ҠмқҢ (signed-int semantics н•ңм •)
//   В· x / pow2 лҠ” ashr (signed arithmetic shift right) лЎң lowering вҖ” мқҢмҲҳ round
//     лҸҷмһ‘ C/hexa divide мҷҖ лҸҷмқј (toward zero) vs ashr (toward -inf) лҜём„ё м°Ёмқҙ
//     лҠ” нҳём¶ңмһҗ(ai_native_pass)к°Җ type/sign м •ліҙлЎң нҢҗлӢЁ. ліё apply лҠ” non-
//     negative м„ м—җм„ң м•Ҳм „.

use "self/attrs/core"
use "self/attrs/_lib/rules_loader"

// в”Җв”Җв”Җ META в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

fn meta_symbolic() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "symbolic"
    m.category = "rewrite"
    m.purpose = "лҢҖмҲҳ лӢЁмҲңнҷ” peephole вҖ” x*2^nвҶ’shl, x/2^nвҶ’ashr, x*1/x+0вҶ’x, x*0вҶ’0 (pre-codegen AST/IR)"
    m.cost_rule = "mul/div pow2 вҶ’ shift (5-10x integer arithmetic); identity/annihilation 1 insn м ңкұ°"
    m.side_effect = "compile-time н•ңм •. signed integer semantics ліҙмЎҙ. float лҜём Ғмҡ©."
    m.requires = "integer operand нғҖмһ… м¶”лЎ  мҷ„лЈҢ нӣ„ мӢӨн–ү (pre-codegen lowering pass)"
    m.auto_test = "self/test_symbolic.hexa вҖ” 15 cases (x*2/4/8/16, x/4, x%8, x**2, x*1, x*0, nested)"
    m.example = "@symbolic\nfn mul2(x: int) -> int { return x * 2 }  // lowers to x << 1"
    m.implemented = true
    return m
}

// в”Җв”Җв”Җ HX11 RULES LOADER в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

fn _global_symbolic_rules_path() -> string {
    return "/Users/ghost/Dev/nexus/tool/config/symbolic_rules.json"
}

fn _symbolic_builtin_rules() {
    let mut r = #{}
    let mut meta = #{}
    meta["project"] = "_builtin"
    meta["version"] = 1
    meta["inherit"] = false
    r["_meta"] = meta

    let mut rules = #{}
    rules["max_shift_bits"] = 8
    rules["enable_identity"] = true
    rules["enable_annihilation"] = true
    r["rules"] = rules
    return r
}

pub fn find_symbolic_rules(source: string) {
    let loaded = find_attr_rules(source, "symbolic", _global_symbolic_rules_path())
    if has_key(loaded, "rules") { return loaded }
    return _symbolic_builtin_rules()
}

fn _scfg_int(cfg, key: string, def: int) -> int {
    if !has_key(cfg, key) { return def }
    let v = cfg[key]
    let mut n = def
    try { n = to_int(v) } catch e { n = def }
    return n
}

fn _scfg_bool(cfg, key: string, def: bool) -> bool {
    if !has_key(cfg, key) { return def }
    return cfg[key] == true
}

// rules вҶ’ max shift bit width (default 8 вҖ” x * 2^1 ..= 2^8)
pub fn symbolic_max_shift_bits(rules) -> int {
    if !has_key(rules, "rules") { return 8 }
    return _scfg_int(rules["rules"], "max_shift_bits", 8)
}

// rules вҶ’ identity peephole нҷңм„ұ (x*1 / x+0, default true)
pub fn symbolic_enable_identity(rules) -> bool {
    if !has_key(rules, "rules") { return true }
    return _scfg_bool(rules["rules"], "enable_identity", true)
}

// rules вҶ’ annihilation peephole нҷңм„ұ (x*0 вҶ’ 0, default true)
pub fn symbolic_enable_annihilation(rules) -> bool {
    if !has_key(rules, "rules") { return true }
    return _scfg_bool(rules["rules"], "enable_annihilation", true)
}

// в”Җв”Җв”Җ INTEGER HELPERS (shift-free, stage0-safe) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

fn _is_pow2(n: int) -> bool {
    if n <= 0 { return false }
    return (n & (n - 1)) == 0
}

fn _log2_int(n: int) -> int {
    let mut count = 0
    let mut v = n
    while v > 1 {
        v = v / 2
        count = count + 1
    }
    return count
}

// 2^n мғҒн•ң (n = max_shift_bits)
fn _pow2_limit(n: int) -> int {
    let mut v = 1
    let mut i = 0
    while i < n {
        v = v * 2
        i = i + 1
    }
    return v
}

// в”Җв”Җв”Җ AST HELPERS (lightweight map-based IR) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// нҳём¶ңл¶Җ (ai_native_pass нҶөн•© мӢң) лҠ” parser AST кө¬мЎ°м—җ л§һкІҢ лһҳнҚј м¶”к°Җ.
// ліё нҢҢмқјмқҖ map кё°л°ҳ н‘ңнҳ„ (kind / op / lhs / rhs / value) мқ„ к°Җм •.

fn _is_int_lit(node) -> bool {
    if !has_key(node, "kind") { return false }
    return node["kind"] == "IntLit"
}

fn _int_lit_val(node) -> int {
    if !has_key(node, "value") { return 0 }
    let mut v = 0
    try { v = to_int(node["value"]) } catch e { v = 0 }
    return v
}

fn _mk_int_lit(v: int) {
    return #{"kind": "IntLit", "value": to_string(v)}
}

fn _mk_shl(operand, n: int) {
    return #{"kind": "BinOp", "op": "<<", "lhs": operand, "rhs": _mk_int_lit(n)}
}

fn _mk_ashr(operand, n: int) {
    return #{"kind": "BinOp", "op": ">>", "lhs": operand, "rhs": _mk_int_lit(n)}
}

// в”Җв”Җв”Җ APPLY (AST/IR peephole) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// нҳём¶ңл¶Җк°Җ BinOp л…ёл“ң л°©л¬ё мӢң мқҙ fn мқ„ нҳём¶ң.
// node = map with "op" вҲҲ {"+", "-", "*", "/", "%"}, "lhs", "rhs"
// rules = find_symbolic_rules(source)
// л°ҳнҷҳ: ліҖнҷҳлҗң AST node (ліҖнҷҳ л¶Ҳк°Җл©ҙ мӣҗліё к·ёлҢҖлЎң)

pub fn apply_symbolic(node, rules) {
    if !has_key(node, "op") { return node }
    let op = node["op"]
    let lhs = node["lhs"]
    let rhs = node["rhs"]

    // (c-1) identity: x + 0 вҶ’ x, 0 + x вҶ’ x
    if symbolic_enable_identity(rules) && op == "+" {
        if _is_int_lit(rhs) && _int_lit_val(rhs) == 0 { return lhs }
        if _is_int_lit(lhs) && _int_lit_val(lhs) == 0 { return rhs }
    }

    if op == "*" {
        // (c-2) x * 1 вҶ’ x, 1 * x вҶ’ x
        if symbolic_enable_identity(rules) {
            if _is_int_lit(rhs) && _int_lit_val(rhs) == 1 { return lhs }
            if _is_int_lit(lhs) && _int_lit_val(lhs) == 1 { return rhs }
        }
        // (d) x * 0 вҶ’ 0, 0 * x вҶ’ 0
        if symbolic_enable_annihilation(rules) {
            if _is_int_lit(rhs) && _int_lit_val(rhs) == 0 { return _mk_int_lit(0) }
            if _is_int_lit(lhs) && _int_lit_val(lhs) == 0 { return _mk_int_lit(0) }
        }
        // (a) x * 2^n вҶ’ x << n
        let max_n = symbolic_max_shift_bits(rules)
        let max_v = _pow2_limit(max_n)
        if _is_int_lit(rhs) {
            let c = _int_lit_val(rhs)
            if c >= 2 && c <= max_v && _is_pow2(c) {
                return _mk_shl(lhs, _log2_int(c))
            }
        }
        if _is_int_lit(lhs) {
            let c = _int_lit_val(lhs)
            if c >= 2 && c <= max_v && _is_pow2(c) {
                return _mk_shl(rhs, _log2_int(c))
            }
        }
    }

    // (b) x / 2^n вҶ’ x >> n  (ashr вҖ” signed)
    if op == "/" {
        let max_n = symbolic_max_shift_bits(rules)
        let max_v = _pow2_limit(max_n)
        if _is_int_lit(rhs) {
            let c = _int_lit_val(rhs)
            if c >= 2 && c <= max_v && _is_pow2(c) {
                return _mk_ashr(lhs, _log2_int(c))
            }
        }
    }

    return node
}

// в”Җв”Җв”Җ CHECK (lint) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// @symbolic мқҖ non-invasive rewrite вҖ” мҳӨлҘҳ лҢҖмӢ  м •ліҙм„ұ к°җм§Җ мҲҳн–ү.
//   В· fn body м—җ peephole лҢҖмғҒ(mul/div by literal, +0, *1) 0 кұҙмқҙл©ҙ no-op warn
pub fn check_symbolic(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "symbolic")
    for pair in pairs {
        let attr_line = pair[0]
        let fn_line = pair[1]

        let body_range = fn_body_range(lines, fn_line)
        let bs = body_range[0]
        let be = body_range[1]
        let mut has_target = false
        let mut i = bs
        while i <= be {
            let idx = i - 1
            if idx >= 0 && idx < len(lines) {
                let t = lines[idx]
                // к°„мқҙ к°җм§Җ вҖ” literal кіј * / + к·јм ‘ л“ұмһҘ
                if t.contains("* 2") || t.contains("* 4") || t.contains("* 8") ||
                   t.contains("* 16") || t.contains("* 1") || t.contains("* 0") ||
                   t.contains("/ 2") || t.contains("/ 4") || t.contains("/ 8") ||
                   t.contains("+ 0") {
                    has_target = true; break
                }
            }
            i = i + 1
        }
        if !has_target {
            out.push(mk_msg4("symbolic", "warn", attr_line,
                "@symbolic on fn with no peephole-targetable expr вҖ” no-op"))
        }
    }
    return out
}
