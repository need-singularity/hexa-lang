// self/attrs/compact.hexa — struct-of-arrays transform (data layout)

use "self/attrs/core"

fn meta_compact() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "compact"
    m.category = "memory"
    m.purpose = "struct-of-arrays transform (AoS → SoA) 데이터 레이아웃 최적화"
    m.cost_rule = "sequential access pattern + large N"
    m.example = "@compact\nstruct Particle { x: f32, y: f32, z: f32 }"
    return m
}

