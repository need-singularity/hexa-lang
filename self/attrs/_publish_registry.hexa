// self/attrs/_publish/registry.hexa — domains.json 레지스트리 R/W
//
// ─────────────────────────────────────────────────────────────────────────
// [DEPRECATED 2026-04-28] @publish paper 분기 폐기에 따라 미사용
// ─────────────────────────────────────────────────────────────────────────
// 사용자 directive (2026-04-28): "모든 프로젝트에 paper 관련 배포 방법은 폐기".
// 본 레지스트리는 publish.hexa 의 paper 자동 배포 분기에서만 호출되었으며,
// run_publish 가 즉시 abort 하므로 더이상 R/W 가 발생하지 않음.
// 파일은 history preservation 목적으로 보존 (raw 16 self-host fixpoint
// 영향 없음 — _registry.hexa 는 use 만 하고 path 자체는 호출하지 않음).
// 후속 진입점: /Users/ghost/core/papers/upload_all_unpublished.hexa
// ─────────────────────────────────────────────────────────────────────────
//
// 경로: <n6_root>/shared/n6/docs/domains.json
//   (n6_root 는 HEXA_N6_ROOT env 또는 nexus 공유 레포)
//
// 엔트리 스키마:
//   {
//     "id": "dog-robot",
//     "axis": "life",
//     "name_ko": "강아지 로봇",
//     "path": "domains/life/dog-robot/dog-robot.md",
//     "mk_target": "mk1",
//     "alien_target": 10,
//     "registered_at": <unix_ts>,
//     "last_publish_at": <unix_ts>
//   }
//
// 구조:
//   {
//     "_meta": { "version": 1, "total": N, "updated_at": <ts> },
//     "entries": [ { id, axis, ... }, ... ]
//   }
//
// 멱등 규칙: id 중복 시 append 대신 update (last_publish_at 갱신).

use "self/attrs/core"
use "self/stdlib/law_io"

// nexus 공유 SSOT 경로 — domains.json 이 사는 곳
// env_var 를 기본으로 하고 env() fallback (interpreter 빌드 차이 흡수)
fn _domains_json_path() -> string {
    let mut raw = ""
    try { raw = to_string(env_var("HEXA_DOMAINS_JSON")) } catch e { raw = "" }
    if raw != "" { return raw }
    // shell fallback — env_var 미지원 빌드 대비
    let sh = to_string(exec("printf '%s' \"$HEXA_DOMAINS_JSON\" 2>/dev/null")).trim()
    if sh != "" { return sh }
    return "/Users/ghost/Dev/nexus/n6/docs/domains.json"
}

// 파일 로드 — 없으면 기본 구조 반환 (_meta + entries[])
fn _load_registry() {
    let path = _domains_json_path()
    if !file_exists(path) {
        let mut m = #{}
        m["_meta"] = #{ "version": 1, "total": 0, "updated_at": 0 }
        m["entries"] = []
        return m
    }
    let mut raw = ""
    try {
        raw = to_string(read_file(path))
    } catch e {
        raw = ""
    }
    if raw == "" {
        let mut m = #{}
        m["_meta"] = #{ "version": 1, "total": 0, "updated_at": 0 }
        m["entries"] = []
        return m
    }
    let mut parsed = #{}
    try {
        parsed = json_parse(raw)
    } catch e {
        parsed = #{}
    }
    if !has_key(parsed, "_meta") {
        parsed["_meta"] = #{ "version": 1, "total": 0, "updated_at": 0 }
    }
    if !has_key(parsed, "entries") {
        parsed["entries"] = []
    }
    return parsed
}

// 저장 — json_stringify + write_file
// 반환: "ok" | "error: <reason>"
fn _save_registry(reg) -> string {
    let path = _domains_json_path()
    // 부모 디렉토리 보장
    let parts = path.split("/")
    let mut dir = ""
    let mut i = 0
    let n = len(parts)
    while i < n - 1 {
        if parts[i] != "" { dir = dir + "/" + parts[i] }
        i = i + 1
    }
    if dir != "" { exec("mkdir -p '" + dir + "'") }

    let mut raw = ""
    try {
        raw = json_stringify(reg)
    } catch e {
        return "error: stringify failed"
    }
    let mut ok = true
    try {
        safe_write_file(path, raw)
    } catch e {
        ok = false
    }
    if !ok { return "error: write failed" }
    return "ok"
}

// ctx 로부터 레지스트리 엔트리 맵 빌드
fn _build_entry(ctx) {
    let mut e = #{}
    e["id"] = if has_key(ctx, "id") { ctx["id"] } else { "unknown" }
    e["axis"] = if has_key(ctx, "axis") { ctx["axis"] } else { "compute" }
    e["name_ko"] = if has_key(ctx, "name_ko") { ctx["name_ko"] } else { e["id"] }
    e["path"] = if has_key(ctx, "md_rel_path") {
        ctx["md_rel_path"]
    } else {
        "domains/" + e["axis"] + "/" + e["id"] + "/" + e["id"] + ".md"
    }
    e["mk_target"] = if has_key(ctx, "mk_target") { ctx["mk_target"] } else { "mk1" }
    e["alien_target"] = if has_key(ctx, "alien_target") { ctx["alien_target"] } else { 10 }
    e["registered_at"] = timestamp()
    e["last_publish_at"] = timestamp()
    return e
}

// id 기준 upsert — 존재하면 update, 없으면 append
// 반환: "created" | "updated"
fn registry_upsert(ctx) -> string {
    let mut reg = _load_registry()
    let new_e = _build_entry(ctx)
    let id = new_e["id"]
    let mut entries = reg["entries"]
    let mut found = -1
    let mut i = 0
    let n = len(entries)
    while i < n {
        let cur = entries[i]
        if has_key(cur, "id") && cur["id"] == id {
            found = i
            break
        }
        i = i + 1
    }

    let mut status = "created"
    if found >= 0 {
        // update 는 registered_at 유지, last_publish_at 만 갱신
        let old = entries[found]
        if has_key(old, "registered_at") {
            new_e["registered_at"] = old["registered_at"]
        }
        entries[found] = new_e
        status = "updated"
    } else {
        entries.push(new_e)
    }
    reg["entries"] = entries

    let mut meta = reg["_meta"]
    meta["total"] = len(entries)
    meta["updated_at"] = timestamp()
    reg["_meta"] = meta

    let save_rv = _save_registry(reg)
    if save_rv != "ok" { return save_rv }
    return status
}

// id 조회 (dry-run 에서 사용)
fn registry_has(id: string) -> bool {
    let reg = _load_registry()
    let entries = reg["entries"]
    for e in entries {
        if has_key(e, "id") && e["id"] == id { return true }
    }
    return false
}
