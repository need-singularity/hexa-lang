// self/attrs/fuse.hexa — merge back-to-back ops into single kernel

use "self/attrs/core"

fn meta_fuse() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "fuse"
    m.category = "performance"
    m.purpose = "merge back-to-back ops (matmul+add 등) into single kernel"
    m.example = "@fuse\nfn mm_add(a, b, c) -> Tensor { return matmul(a, b) + c }"
    return m
}

fn check_fuse(source: string, lines: [string]) {
    return []
}
