// self/attrs/guard.hexa — monitor + detect + resolve (timing + fallback combo)

use "self/attrs/core"

fn meta_guard() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "guard"
    m.category = "safety"
    m.purpose = "monitor + detect + resolve — timing budget + fallback 통합"
    m.example = "@guard(timeout=5s, on_fail=log)\nfn http_call() -> Response { ... }"
    return m
}

