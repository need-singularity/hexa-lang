// self/attrs/bench.hexa — @bench execution attr (grammar.jsonl group 3)

use "self/attrs/core"

fn meta_bench() {
    let mut m = empty_meta()
    m.name = "bench"
    m.category = "execution"
    m.purpose = "벤치마크 fn 표시 — hexa bench 러너가 반복 실행·타이밍 수집"
    m.cost_rule = "@bench(bound=\"compute\"|\"memory\"|\"io\") 병목 분류"
    m.side_effect = "timer start/stop + stats emit"
    m.example = "@bench(bound=\"compute\")\nfn bench_matmul() { matmul(a, b) }"
    return m
}

fn check_bench(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "bench")
    for pair in pairs {
        let fn_line = pair[1]
        let idx = fn_line - 1
        if idx < 0 || idx >= len(lines) { continue }
        let t = trim(lines[idx])
        if !contains(t, "fn bench_") && !contains(t, "pub fn bench_") {
            out = out.push(mk_msg("bench", "warn", fn_line,
                "@bench fn 이름 권장: `bench_<what>` prefix"))
        }
    }
    return out
}
