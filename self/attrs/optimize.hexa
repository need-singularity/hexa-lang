// self/attrs/optimize.hexa — AST rewrite hint (e.g. bubble→merge)

use "self/attrs/core"

fn meta_optimize() -> AttrMeta {
    let mut m = empty_meta()
    m.name = "optimize"
    m.category = "rewrite"
    m.purpose = "AST rewrite hint — e.g. bubble→merge, linear→binary"
    m.requires = "@pure + benchmark gate"
    m.example = "@pure\n@optimize\nfn sort(xs) { ... }"
    return m
}

fn check_optimize(source: string, lines: [string]) {
    let mut out = []
    let pairs = find_attr_fn_pairs(lines, "optimize")
    for pair in pairs {
        let attr_line = pair[0]
        let fn_line = pair[1]
        let mut has_pure = false
        let mut k = attr_line - 3
        if k < 1 { k = 1 }
        while k <= fn_line {
            let idx = k - 1
            if idx >= 0 && idx < len(lines) {
                if lines[idx].trim().contains("@pure") { has_pure = true; break }
            }
            k = k + 1
        }
        if !has_pure {
            out = out.push(mk_msg("optimize", "error", attr_line,
                "@optimize requires @pure (AST rewrites must preserve semantics)"))
        }
    }
    return out
}
