// self/attrs/usage.hexa — @usage meta attr (canonical CLI invocation)
//
// PURPOSE
//   Pairs with @tool: declares the canonical command line to invoke this
//   script. Read by tool/manifest_scan.hexa for the hive manifest.
//
// FORM
//   @usage(<command line — verbatim>)
//
// CONVENTION
//   · One @usage per @tool. Place immediately after the @tool line.
//   · Use the absolute path the manifest consumer needs, OR the relative
//     `tool/<name>.hexa` path — manifest_scan documents both modes.
//   · No quotes around the command — the entire parenthesized payload is
//     captured verbatim.
//
// EXAMPLE
//   // @tool(slug="doc_lint", desc="...")
//   // @usage(hexa tool/doc_lint.hexa [--list])

use "self/attrs/core"

fn meta_usage() {
    let mut m = empty_meta()
    m.name = "usage"
    m.category = "meta"
    m.purpose = "canonical CLI invocation example for @tool entries — manifest_scan extracts verbatim"
    m.cost_rule = "@usage(<command>) — single-line invocation"
    m.example = "// @usage(hexa tool/doc_lint.hexa [--list])"
    m.implemented = false
    return m
}

fn check_usage(source: string, lines: [string]) {
    return []
}
