// self/test_base64_pure.hexa -- Tests for self/runtime/base64_pure.hexa
//
// Reference vectors: `printf %s "hello" | base64` -> "aGVsbG8="

let B64_ALPHABET = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

fn _b64_char_at(idx) { B64_ALPHABET.substring(idx, idx + 1) }

fn _b64_decode_char(c) {
    let o = ord(c)
    if o >= 65 && o <= 90  { return o - 65 }
    if o >= 97 && o <= 122 { return o - 97 + 26 }
    if o >= 48 && o <= 57  { return o - 48 + 52 }
    if o == 43 { return 62 }
    if o == 47 { return 63 }
    -1
}

fn base64_encode_pure(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i + 3 <= n {
        let b0 = ord(s.substring(i, i + 1))
        let b1 = ord(s.substring(i + 1, i + 2))
        let b2 = ord(s.substring(i + 2, i + 3))
        let t = (b0 * 65536) + (b1 * 256) + b2
        out = out + _b64_char_at((t / 262144) % 64)
        out = out + _b64_char_at((t / 4096) % 64)
        out = out + _b64_char_at((t / 64) % 64)
        out = out + _b64_char_at(t % 64)
        i = i + 3
    }
    if i < n {
        let rem = n - i
        let b0 = ord(s.substring(i, i + 1))
        let mut t = b0 * 65536
        if rem == 2 {
            t = t + ord(s.substring(i + 1, i + 2)) * 256
        }
        out = out + _b64_char_at((t / 262144) % 64)
        out = out + _b64_char_at((t / 4096) % 64)
        if rem == 2 {
            out = out + _b64_char_at((t / 64) % 64)
        } else {
            out = out + "="
        }
        out = out + "="
    }
    out
}

fn base64_decode_pure(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    let mut out_chars = []
    let mut bits = 0
    let mut vbits = 0
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "=" {
            i = n
        } else {
            let v = _b64_decode_char(c)
            if v >= 0 {
                bits = bits * 64 + v
                vbits = vbits + 6
                if vbits >= 8 {
                    vbits = vbits - 8
                    let mut sc = 1
                    let mut p = 0
                    while p < vbits {
                        sc = sc * 2
                        p = p + 1
                    }
                    let byte = (bits / sc) % 256
                    out_chars = out_chars.push(from_char_code(byte))
                    bits = bits % sc
                }
            }
            i = i + 1
        }
    }
    out_chars.join("")
}

// ── test harness ──────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  base64_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── encode known vectors ────────────────────────────────────
println("")
println("--- base64_encode_pure ---")
check("empty", base64_encode_pure(""), "")
check("'f'", base64_encode_pure("f"), "Zg==")
check("'fo'", base64_encode_pure("fo"), "Zm8=")
check("'foo'", base64_encode_pure("foo"), "Zm9v")
check("'foob'", base64_encode_pure("foob"), "Zm9vYg==")
check("'fooba'", base64_encode_pure("fooba"), "Zm9vYmE=")
check("'foobar'", base64_encode_pure("foobar"), "Zm9vYmFy")
check("'hello'", base64_encode_pure("hello"), "aGVsbG8=")
check("'Man'", base64_encode_pure("Man"), "TWFu")
check("non-string", base64_encode_pure(42), "")

// ── decode known vectors ────────────────────────────────────
println("")
println("--- base64_decode_pure ---")
check("empty", base64_decode_pure(""), "")
check("Zg==", base64_decode_pure("Zg=="), "f")
check("Zm8=", base64_decode_pure("Zm8="), "fo")
check("Zm9v", base64_decode_pure("Zm9v"), "foo")
check("Zm9vYg==", base64_decode_pure("Zm9vYg=="), "foob")
check("Zm9vYmE=", base64_decode_pure("Zm9vYmE="), "fooba")
check("Zm9vYmFy", base64_decode_pure("Zm9vYmFy"), "foobar")
check("aGVsbG8=", base64_decode_pure("aGVsbG8="), "hello")
check("TWFu", base64_decode_pure("TWFu"), "Man")
check("non-string", base64_decode_pure(42), "")

// ── roundtrip ───────────────────────────────────────────────
println("")
println("--- roundtrip ---")
let rt1 = base64_decode_pure(base64_encode_pure("hello world"))
check("hello world rt", rt1, "hello world")
let rt2 = base64_decode_pure(base64_encode_pure("The quick brown fox"))
check("pangram rt", rt2, "The quick brown fox")

// ── ignore garbage ──────────────────────────────────────────
println("")
println("--- decode ignores whitespace ---")
check("with newline", base64_decode_pure("aGVs\nbG8="), "hello")
check("with spaces", base64_decode_pure("aGVs bG8="), "hello")

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
