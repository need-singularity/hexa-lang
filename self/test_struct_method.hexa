//  test_p2_6_struct_method.hexa — P2-6 Struct Method Dispatch
//  Phase 2 bootstrapping blocker: comprehensive coverage
//  Tests: struct creation, field access, impl methods, self binding,
//         multi-method structs, method chaining via return, factory
//         patterns, nested structs, enum, edge cases
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  P2-6: Struct Method Dispatch — Comprehensive Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic struct creation & field access ───────────────

println("--- 1. Basic Struct ---")

struct Point { x: int, y: int }

let p1 = Point { x: 3, y: 4 }
check("1.1 struct field x", p1.x, 3)
check("1.2 struct field y", p1.y, 4)

let p2 = Point { x: -5, y: 10 }
check("1.3 negative field", p2.x, -5)
check("1.4 field arithmetic", p1.x + p1.y, 7)
check("1.5 cross-struct arithmetic", p1.x + p2.y, 13)

// ── 2. Impl with single method ───────────────────────────

println("")
println("--- 2. Single Method Impl ---")

impl Point {
    fn distance_sq(self, other) {
        let dx = self.x - other.x
        let dy = self.y - other.y
        return dx * dx + dy * dy
    }
}

check("2.1 distance_sq origin", Point { x: 0, y: 0 }.distance_sq(Point { x: 3, y: 4 }), 25)
check("2.2 distance_sq same", p1.distance_sq(p1), 0)
check("2.3 distance_sq negative", p1.distance_sq(p2), 100)

// ── 3. Multiple methods in one impl ──────────────────────

println("")
println("--- 3. Multiple Methods ---")

struct Rect { w: int, h: int }

impl Rect {
    fn area(self) {
        return self.w * self.h
    }

    fn perimeter(self) {
        return 2 * (self.w + self.h)
    }

    fn is_square(self) {
        return self.w == self.h
    }

    fn scale(self, factor) {
        return Rect { w: self.w * factor, h: self.h * factor }
    }

    fn describe(self) {
        return to_string(self.w) + "x" + to_string(self.h)
    }
}

let r1 = Rect { w: 5, h: 3 }
check("3.1 rect area", r1.area(), 15)
check("3.2 rect perimeter", r1.perimeter(), 16)
check("3.3 rect is_square false", r1.is_square(), false)
check("3.4 rect describe", r1.describe(), "5x3")

let sq = Rect { w: 4, h: 4 }
check("3.5 square is_square true", sq.is_square(), true)
check("3.6 square area", sq.area(), 16)

// ── 4. Method returning new struct (immutable chaining) ──

println("")
println("--- 4. Method Returning Struct ---")

let r2 = r1.scale(2)
check("4.1 scaled w", r2.w, 10)
check("4.2 scaled h", r2.h, 6)
check("4.3 scaled area", r2.area(), 60)
check("4.4 original unchanged w", r1.w, 5)

let r3 = r1.scale(3).scale(2)
check("4.5 double scale w", r3.w, 30)
check("4.6 double scale h", r3.h, 18)

// ── 5. Methods with different parameter counts ───────────

println("")
println("--- 5. Varied Parameter Counts ---")

struct Vec2 { x: int, y: int }

impl Vec2 {
    fn mag_sq(self) {
        return self.x * self.x + self.y * self.y
    }

    fn add(self, other) {
        return Vec2 { x: self.x + other.x, y: self.y + other.y }
    }

    fn add_xy(self, dx, dy) {
        return Vec2 { x: self.x + dx, y: self.y + dy }
    }

    fn clamp(self, min_val, max_val) {
        let mut cx = self.x
        let mut cy = self.y
        if cx < min_val { cx = min_val }
        if cx > max_val { cx = max_val }
        if cy < min_val { cy = min_val }
        if cy > max_val { cy = max_val }
        return Vec2 { x: cx, y: cy }
    }
}

let v1 = Vec2 { x: 3, y: 4 }
check("5.1 zero-param mag_sq", v1.mag_sq(), 25)

let v2 = v1.add(Vec2 { x: 1, y: 2 })
check("5.2 one-param add x", v2.x, 4)
check("5.3 one-param add y", v2.y, 6)

let v3 = v1.add_xy(10, 20)
check("5.4 two-param add_xy x", v3.x, 13)
check("5.5 two-param add_xy y", v3.y, 24)

let v4 = Vec2 { x: -5, y: 100 }.clamp(0, 10)
check("5.6 clamp x from negative", v4.x, 0)
check("5.7 clamp y from above", v4.y, 10)

// ── 6. Factory / constructor pattern (free functions) ────

println("")
println("--- 6. Factory Pattern ---")

struct Counter { value: int, step: int }

impl Counter {
    fn current(self) {
        return self.value
    }

    fn inc(self) {
        return Counter { value: self.value + self.step, step: self.step }
    }

    fn dec(self) {
        return Counter { value: self.value - self.step, step: self.step }
    }

    fn reset(self) {
        return Counter { value: 0, step: self.step }
    }
}

fn counter_new(step) {
    return Counter { value: 0, step: step }
}

let mut c = counter_new(5)
check("6.1 factory init", c.current(), 0)
c = c.inc()
check("6.2 inc once", c.current(), 5)
c = c.inc()
check("6.3 inc twice", c.current(), 10)
c = c.dec()
check("6.4 dec", c.current(), 5)
c = c.reset()
check("6.5 reset", c.current(), 0)

// chain: inc().inc().inc()
c = counter_new(3).inc().inc().inc()
check("6.6 chained 3 incs", c.current(), 9)

// ── 7. Nested struct (field is another struct) ───────────

println("")
println("--- 7. Nested Structs ---")

struct Color { r: int, g: int, b: int }

impl Color {
    fn to_str(self) {
        return "rgb(" + to_string(self.r) + "," + to_string(self.g) + "," + to_string(self.b) + ")"
    }

    fn is_black(self) {
        return self.r == 0 && self.g == 0 && self.b == 0
    }
}

struct Circle {
    center: any,
    radius: int,
    color: any
}

impl Circle {
    fn area_approx(self) {
        // 314 * r^2 / 100 (integer approx of pi*r^2)
        return 314 * self.radius * self.radius / 100
    }

    fn describe(self) {
        return "circle r=" + to_string(self.radius) + " at (" + to_string(self.center.x) + "," + to_string(self.center.y) + ") " + self.color.to_str()
    }
}

let red = Color { r: 255, g: 0, b: 0 }
let origin = Point { x: 0, y: 0 }
let circ = Circle { center: origin, radius: 10, color: red }

check("7.1 nested center.x", circ.center.x, 0)
check("7.2 nested center.y", circ.center.y, 0)
check("7.3 nested color.r", circ.color.r, 255)
check("7.4 color to_str", circ.color.to_str(), "rgb(255,0,0)")
check("7.5 color is_black", circ.color.is_black(), false)
check("7.6 black is_black", Color { r: 0, g: 0, b: 0 }.is_black(), true)
check("7.7 circle area_approx", circ.area_approx(), 314)
check("7.8 circle describe", circ.describe(), "circle r=10 at (0,0) rgb(255,0,0)")

// ── 8. Struct with string fields and methods ─────────────

println("")
println("--- 8. String-Field Struct ---")

struct Person {
    name: string,
    age: int,
    active: bool
}

impl Person {
    fn greet(self) {
        return "Hello, I'm " + self.name
    }

    fn is_adult(self) {
        return self.age >= 18
    }

    fn summary(self) {
        let status = "inactive"
        if self.active { status = "active" }
        return self.name + " (age " + to_string(self.age) + ", " + status + ")"
    }

    fn birthday(self) {
        return Person { name: self.name, age: self.age + 1, active: self.active }
    }
}

let alice = Person { name: "Alice", age: 30, active: true }
check("8.1 greet", alice.greet(), "Hello, I'm Alice")
check("8.2 is_adult true", alice.is_adult(), true)
check("8.3 summary", alice.summary(), "Alice (age 30, active)")

let bob = Person { name: "Bob", age: 16, active: false }
check("8.4 is_adult false", bob.is_adult(), false)
check("8.5 summary inactive", bob.summary(), "Bob (age 16, inactive)")

let older_bob = bob.birthday().birthday().birthday()
check("8.6 chained birthday", older_bob.age, 19)
check("8.7 birthday is_adult", older_bob.is_adult(), true)

// ── 9. Single-field struct ───────────────────────────────

println("")
println("--- 9. Single-Field Struct ---")

struct Wrapper { value: int }

impl Wrapper {
    fn get(self) {
        return self.value
    }

    fn double(self) {
        return Wrapper { value: self.value * 2 }
    }

    fn add(self, n) {
        return Wrapper { value: self.value + n }
    }
}

let w = Wrapper { value: 7 }
check("9.1 wrapper get", w.get(), 7)
check("9.2 wrapper double", w.double().get(), 14)
check("9.3 wrapper add", w.add(3).get(), 10)
check("9.4 wrapper chain", w.double().add(1).get(), 15)

// ── 10. Method calls in expressions ──────────────────────

println("")
println("--- 10. Methods in Expressions ---")

let r10 = Rect { w: 6, h: 4 }
let r11 = Rect { w: 3, h: 8 }

check("10.1 sum of areas", r10.area() + r11.area(), 48)
check("10.2 area comparison", r10.area() == r11.area(), true)
check("10.3 method in if cond", r10.is_square() == false, true)

let bigger = r10.area()
if bigger < r11.area() {
    bigger = r11.area()
}
check("10.4 method result in if", bigger, 24)

// ── 11. Struct in array + method calls ───────────────────

println("")
println("--- 11. Struct Array Methods ---")

let mut rects = []
rects.push(Rect { w: 1, h: 1 })
rects.push(Rect { w: 2, h: 3 })
rects.push(Rect { w: 5, h: 5 })

let mut total_area = 0
for r in rects {
    total_area = total_area + r.area()
}
check("11.1 total area", total_area, 32)

check("11.2 array[0] area", rects[0].area(), 1)
check("11.3 array[1] perimeter", rects[1].perimeter(), 10)
check("11.4 array[2] is_square", rects[2].is_square(), true)

// ── 12. Multiple separate impl blocks ────────────────────

println("")
println("--- 12. Multiple Impl Blocks ---")

impl Point {
    fn to_str(self) {
        return "(" + to_string(self.x) + ", " + to_string(self.y) + ")"
    }

    fn manhattan(self, other) {
        let dx = self.x - other.x
        let dy = self.y - other.y
        if dx < 0 { dx = 0 - dx }
        if dy < 0 { dy = 0 - dy }
        return dx + dy
    }

    fn origin() {
        return Point { x: 0, y: 0 }
    }
}

let pa = Point { x: 3, y: 4 }
let pb = Point { x: 0, y: 0 }
check("12.1 to_str", pa.to_str(), "(3, 4)")
check("12.2 manhattan", pa.manhattan(pb), 7)
// original method from first impl still works
check("12.3 distance_sq still works", pa.distance_sq(pb), 25)

// ── 13. Method calling another method ────────────────────

println("")
println("--- 13. Method Calling Method ---")

struct Box {
    width: int,
    height: int,
    depth: int
}

impl Box {
    fn volume(self) {
        return self.width * self.height * self.depth
    }

    fn surface_area(self) {
        let wh = self.width * self.height
        let wd = self.width * self.depth
        let hd = self.height * self.depth
        return 2 * (wh + wd + hd)
    }

    fn is_cube(self) {
        return self.width == self.height && self.height == self.depth
    }

    fn describe(self) {
        let shape = "box"
        if self.is_cube() { shape = "cube" }
        return shape + " " + to_string(self.width) + "x" + to_string(self.height) + "x" + to_string(self.depth)
    }
}

let b1 = Box { width: 3, height: 4, depth: 5 }
check("13.1 volume", b1.volume(), 60)
check("13.2 surface_area", b1.surface_area(), 94)
check("13.3 is_cube false", b1.is_cube(), false)
check("13.4 describe box", b1.describe(), "box 3x4x5")

let cube = Box { width: 3, height: 3, depth: 3 }
check("13.5 cube volume", cube.volume(), 27)
check("13.6 is_cube true", cube.is_cube(), true)
check("13.7 describe cube", cube.describe(), "cube 3x3x3")

// ── 14. Struct passed as function argument ───────────────

println("")
println("--- 14. Struct as Function Arg ---")

fn bigger_rect(a, b) {
    if a.area() >= b.area() {
        return a
    }
    return b
}

fn sum_areas(rects) {
    let mut total = 0
    for r in rects {
        total = total + r.area()
    }
    return total
}

let ra = Rect { w: 10, h: 2 }
let rb = Rect { w: 3, h: 8 }
let result = bigger_rect(ra, rb)
check("14.1 bigger_rect", result.area(), 24)
check("14.2 sum_areas", sum_areas([ra, rb]), 44)

// ── 15. Struct returned from conditional ─────────────────

println("")
println("--- 15. Conditional Struct Return ---")

fn make_shape(kind) {
    if kind == "tall" {
        return Rect { w: 2, h: 10 }
    }
    if kind == "wide" {
        return Rect { w: 10, h: 2 }
    }
    return Rect { w: 5, h: 5 }
}

check("15.1 tall area", make_shape("tall").area(), 20)
check("15.2 wide area", make_shape("wide").area(), 20)
check("15.3 default is_square", make_shape("default").is_square(), true)

// ── 16. Enum basic ───────────────────────────────────────

println("")
println("--- 16. Enum ---")

enum Direction { North, South, East, West }

let dir = Direction::North
check("16.1 enum variant north", to_string(dir), "Direction::North")
let dir2 = Direction::West
check("16.2 enum variant west", to_string(dir2), "Direction::West")

// ── 17. Stack data structure with methods ────────────────

println("")
println("--- 17. Stack ADT ---")

struct Stack { items: array }

impl Stack {
    fn size(self) {
        return len(self.items)
    }

    fn is_empty(self) {
        return len(self.items) == 0
    }

// decreases self — structural
    fn push(self, val) {
        return Stack { items: self.items.push(val) }
    }

    fn peek(self) {
        if len(self.items) == 0 { return -1 }
        return self.items[len(self.items) - 1]
    }

    fn pop(self) {
        if len(self.items) == 0 { return self }
        let mut new_items = []
        let mut i = 0
        while i < len(self.items) - 1 {
            new_items.push(self.items[i])
            i = i + 1
        }
        return Stack { items: new_items }
    }
}

let mut stk = Stack { items: [] }
check("17.1 empty size", stk.size(), 0)
check("17.2 is_empty", stk.is_empty(), true)

stk.push(10).push(20).push(30)
check("17.3 size after push", stk.size(), 3)
check("17.4 peek", stk.peek(), 30)
check("17.5 is_empty false", stk.is_empty(), false)

stk = stk.pop()
check("17.6 pop peek", stk.peek(), 20)
check("17.7 pop size", stk.size(), 2)

// ── 18. Pair / Tuple-like struct ─────────────────────────

println("")
println("--- 18. Pair Struct ---")

struct Pair { first: any, second: any }

impl Pair {
    fn swap(self) {
        return Pair { first: self.second, second: self.first }
    }

    fn map_first(self, f) {
        return Pair { first: f(self.first), second: self.second }
    }
}

let pr = Pair { first: 1, second: 2 }
check("18.1 first", pr.first, 1)
check("18.2 second", pr.second, 2)
let swapped = pr.swap()
check("18.3 swap first", swapped.first, 2)
check("18.4 swap second", swapped.second, 1)
check("18.5 double swap", pr.swap().swap().first, 1)

// ── 19. Builder pattern ──────────────────────────────────

println("")
println("--- 19. Builder Pattern ---")

struct Config {
    width: int,
    height: int,
    title: string,
    fullscreen: bool
}

fn config_default() {
    return Config { width: 800, height: 600, title: "Untitled", fullscreen: false }
}

impl Config {
    fn set_width(self, w) {
        return Config { width: w, height: self.height, title: self.title, fullscreen: self.fullscreen }
    }

    fn set_height(self, h) {
        return Config { width: self.width, height: h, title: self.title, fullscreen: self.fullscreen }
    }

    fn set_title(self, t) {
        return Config { width: self.width, height: self.height, title: t, fullscreen: self.fullscreen }
    }

    fn set_fullscreen(self, f) {
        return Config { width: self.width, height: self.height, title: self.title, fullscreen: f }
    }
}

let cfg = config_default().set_width(1920).set_height(1080).set_title("Game").set_fullscreen(true)
check("19.1 builder width", cfg.width, 1920)
check("19.2 builder height", cfg.height, 1080)
check("19.3 builder title", cfg.title, "Game")
check("19.4 builder fullscreen", cfg.fullscreen, true)

// ── 20. Loop building structs ────────────────────────────

println("")
println("--- 20. Loop + Struct ---")

let mut points = []
let mut i = 0
while i < 5 {
    points.push(Point { x: i, y: i * i })
    i = i + 1
}

check("20.1 points len", len(points), 5)
check("20.2 points[0].x", points[0].x, 0)
check("20.3 points[2].y", points[2].y, 4)
check("20.4 points[4].y", points[4].y, 16)

let mut y_sum = 0
for p in points {
    y_sum = y_sum + p.y
}
check("20.5 sum of y values", y_sum, 30)

// ── 21. Method with complex logic ────────────────────────

println("")
println("--- 21. Complex Method Logic ---")

struct Range { start: int, end_val: int }

impl Range {
    fn len(self) {
        if self.end_val > self.start {
            return self.end_val - self.start
        }
        return 0
    }

    fn contains(self, n) {
        return n >= self.start && n < self.end_val
    }

    fn sum(self) {
        let mut total = 0
        let mut i = self.start
        while i < self.end_val {
            total = total + i
            i = i + 1
        }
        return total
    }

    fn overlaps(self, other) {
        return self.start < other.end_val && other.start < self.end_val
    }
}

let rng = Range { start: 1, end_val: 6 }
check("21.1 range len", rng.len(), 5)
check("21.2 contains 3", rng.contains(3), true)
check("21.3 contains 6", rng.contains(6), false)
check("21.4 contains 0", rng.contains(0), false)
check("21.5 range sum", rng.sum(), 15)

let rng2 = Range { start: 4, end_val: 8 }
check("21.6 overlaps true", rng.overlaps(rng2), true)

let rng3 = Range { start: 10, end_val: 20 }
check("21.7 overlaps false", rng.overlaps(rng3), false)

let empty_rng = Range { start: 5, end_val: 5 }
check("21.8 empty range len", empty_rng.len(), 0)
check("21.9 empty range sum", empty_rng.sum(), 0)

