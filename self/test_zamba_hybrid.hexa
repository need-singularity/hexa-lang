// ═══════════════════════════════════════════════════════════════════
//  test_zamba_hybrid.hexa — Zamba Hybrid (#210) verification
//
//  Tests (32):
//    #1  config dict has all keys (n_layers, dim, etc.)
//    #2  zam_create_shared_attn returns 4 weight matrices
//    #3  shared attn W_q rows == proj_dim
//    #4  shared attn W_q cols == dim
//    #5  shared attn W_o shape inverted (dim x proj_dim)
//    #6  per_layer_proj W_in/W_out are dim x dim
//    #7  layer plan length == n_layers
//    #8  layer plan layer 0 is mamba (never attn)
//    #9  layer plan inserts shared_attn at every Kth layer
//    #10 zam_count_attn_layers matches plan
//    #11 mamba_block_forward output shape == dim
//    #12 mamba_block state updates (state != initial when x != 0)
//    #13 mamba_block zero input -> zero state advance
//    #14 shared_attn_forward output shape [seq_len, dim]
//    #15 shared_attn_forward zero input -> zero output (no biases)
//    #16 zam_softmax_row sums to 1
//    #17 zam_softmax_row positive everywhere
//    #18 zam_softmax_row uniform on uniform input
//    #19 zam_residual_add y + 0 = y (additive identity)
//    #20 zam_residual_add commutative on simple input
//    #21 layer_forward output x_seq shape [seq_len, dim]
//    #22 layer_forward updates state
//    #23 layer_forward attn slot adds skip vs no-attn slot
//    #24 zam_forward output shape [seq_len, dim]
//    #25 zam_forward zero input -> zero output (no biases)
//    #26 zam_forward deterministic (same input same output)
//    #27 shared params reused across attn layers (object identity)
//    #28 unique-param count < full-attn-per-layer count (sharing wins)
//    #29 unique-param count > 0
//    #30 attn output rows count == seq_len
//    #31 mamba block output respects seq position when run twice
//    #32 zam_forward includes residual (output != input on nonzero)
//
//  Run: PATH=$HOME/.cargo/bin:$PATH ./hexa self/test_zamba_hybrid.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ═══════════════════════════════════════════════════════════════════
//  Inlined copy of self/ml/zamba_hybrid.hexa
// ═══════════════════════════════════════════════════════════════════

fn zam_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn zam_max_f(a, b) {
    if a > b { return a }
    return b
}

fn zam_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn zam_sigmoid(x) {
    if x > 20.0 { return 1.0 }
    if x < -20.0 { return 0.0 }
    return 1.0 / (1.0 + zam_exp(0.0 - x))
}

fn zam_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..30 { g = (g + x / g) / 2.0 }
    return g
}

fn zam_hash(seed, i, j) {
    let h = ((seed * 2654435761 + i * 1315423911 + j * 731) % 10007)
    return to_float(h) / 10007.0 - 0.5
}

fn zam_zeros_1d(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn zam_zeros_2d(r, c) {
    let mut m = []
    for _i in 0..r {
        let mut row = []
        for _j in 0..c { row = row + [0.0] }
        m = m + [row]
    }
    return m
}

fn zam_init_matrix(rows, cols, seed) {
    let mut m = []
    for i in 0..rows {
        let mut row = []
        for j in 0..cols {
            row = row + [zam_hash(seed, i, j) * 0.1]
        }
        m = m + [row]
    }
    return m
}

fn zam_matvec(W, v, rows, cols) {
    let mut out = []
    let mut i = 0
    while i < rows {
        let mut s = 0.0
        let mut j = 0
        while j < cols {
            s = s + W[i][j] * v[j]
            j = j + 1
        }
        out = out + [s]
        i = i + 1
    }
    return out
}

fn zam_softmax_row(row, n) {
    if n <= 0 { return [] }
    let mut m = row[0]
    let mut i = 1
    while i < n {
        if row[i] > m { m = row[i] }
        i = i + 1
    }
    let mut exps = []
    let mut k = 0
    let mut total = 0.0
    while k < n {
        let e = zam_exp(row[k] - m)
        exps = exps + [e]
        total = total + e
        k = k + 1
    }
    if total <= 0.0 { return exps }
    let mut out = []
    let mut q = 0
    while q < n {
        out = out + [exps[q] / total]
        q = q + 1
    }
    return out
}

fn zam_residual_add(x, y, n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [x[i] + y[i]]
        i = i + 1
    }
    return out
}

fn zam_create_config(n_layers, shared_attn_every, dim, d_head, n_heads) {
    return #{
        "n_layers": n_layers,
        "shared_attn_every": shared_attn_every,
        "dim": dim,
        "d_head": d_head,
        "n_heads": n_heads
    }
}

fn zam_create_shared_attn(dim, d_head, n_heads) {
    let proj_dim = n_heads * d_head
    let W_q = zam_init_matrix(proj_dim, dim, 11)
    let W_k = zam_init_matrix(proj_dim, dim, 22)
    let W_v = zam_init_matrix(proj_dim, dim, 33)
    let W_o = zam_init_matrix(dim, proj_dim, 44)
    return #{
        "W_q": W_q,
        "W_k": W_k,
        "W_v": W_v,
        "W_o": W_o,
        "dim": dim,
        "d_head": d_head,
        "n_heads": n_heads,
        "proj_dim": proj_dim
    }
}

fn zam_per_layer_proj(dim) {
    let W_in = zam_init_matrix(dim, dim, 55)
    let W_out = zam_init_matrix(dim, dim, 66)
    let mut Wi = W_in
    let mut Wo = W_out
    let mut k = 0
    while k < dim {
        Wi[k][k] = Wi[k][k] + 1.0
        Wo[k][k] = Wo[k][k] + 1.0
        k = k + 1
    }
    return #{
        "W_in": Wi,
        "W_out": Wo,
        "dim": dim
    }
}

fn zam_mamba_block_forward(state, x, dim) {
    let decay = 0.9
    let mut new_state = []
    let mut y = []
    let mut i = 0
    while i < dim {
        let s = decay * state[i] + x[i]
        new_state = new_state + [s]
        let g = zam_sigmoid(s)
        y = y + [g * x[i]]
        i = i + 1
    }
    return #{
        "state": new_state,
        "y": y
    }
}

fn zam_shared_attn_forward(x_seq, attn_params, seq_len, d_head, n_heads) {
    let dim = attn_params["dim"]
    let proj_dim = attn_params["proj_dim"]
    let W_q = attn_params["W_q"]
    let W_k = attn_params["W_k"]
    let W_v = attn_params["W_v"]
    let W_o = attn_params["W_o"]

    let mut Q = []
    let mut K = []
    let mut V = []
    let mut t = 0
    while t < seq_len {
        Q = Q + [zam_matvec(W_q, x_seq[t], proj_dim, dim)]
        K = K + [zam_matvec(W_k, x_seq[t], proj_dim, dim)]
        V = V + [zam_matvec(W_v, x_seq[t], proj_dim, dim)]
        t = t + 1
    }

    let scale = 1.0 / zam_sqrt(to_float(d_head))

    let mut ctx = []
    let mut ti = 0
    while ti < seq_len {
        let mut row = []
        let mut tj = 0
        while tj < seq_len {
            let mut s = 0.0
            let mut k = 0
            while k < proj_dim {
                s = s + Q[ti][k] * K[tj][k]
                k = k + 1
            }
            row = row + [s * scale]
            tj = tj + 1
        }
        let probs = zam_softmax_row(row, seq_len)
        let mut acc = zam_zeros_1d(proj_dim)
        let mut tj2 = 0
        while tj2 < seq_len {
            let p = probs[tj2]
            let mut k2 = 0
            while k2 < proj_dim {
                acc[k2] = acc[k2] + p * V[tj2][k2]
                k2 = k2 + 1
            }
            tj2 = tj2 + 1
        }
        ctx = ctx + [acc]
        ti = ti + 1
    }

    let mut out_seq = []
    let mut tt = 0
    while tt < seq_len {
        out_seq = out_seq + [zam_matvec(W_o, ctx[tt], dim, proj_dim)]
        tt = tt + 1
    }
    return out_seq
}

fn zam_build_layer_plan(config) {
    let n = config["n_layers"]
    let k = config["shared_attn_every"]
    let mut plan = []
    let mut i = 0
    while i < n {
        if k > 0 {
            if i > 0 {
                if (i % k) == 0 {
                    plan = plan + ["shared_attn"]
                } else {
                    plan = plan + ["mamba"]
                }
            } else {
                plan = plan + ["mamba"]
            }
        } else {
            plan = plan + ["mamba"]
        }
        i = i + 1
    }
    return plan
}

fn zam_count_attn_layers(plan) {
    let mut c = 0
    let mut i = 0
    while i < len(plan) {
        if plan[i] == "shared_attn" { c = c + 1 }
        i = i + 1
    }
    return c
}

fn zam_layer_forward(layer_idx, x_seq, state, config, attn_params, layer_params) {
    let dim = config["dim"]
    let d_head = config["d_head"]
    let n_heads = config["n_heads"]
    let k = config["shared_attn_every"]
    let seq_len = len(x_seq)

    let mut cur_state = state
    let mut mamba_seq = []
    let mut t = 0
    while t < seq_len {
        let r = zam_mamba_block_forward(cur_state, x_seq[t], dim)
        cur_state = r["state"]
        mamba_seq = mamba_seq + [r["y"]]
        t = t + 1
    }

    let mut after_mamba = []
    let mut tr = 0
    while tr < seq_len {
        after_mamba = after_mamba + [zam_residual_add(x_seq[tr], mamba_seq[tr], dim)]
        tr = tr + 1
    }

    let needs_attn = (k > 0) && (layer_idx > 0) && ((layer_idx % k) == 0)

    if needs_attn {
        let W_in = layer_params["W_in"]
        let W_out = layer_params["W_out"]
        let mut adapted = []
        let mut s = 0
        while s < seq_len {
            adapted = adapted + [zam_matvec(W_in, after_mamba[s], dim, dim)]
            s = s + 1
        }
        let attn_out = zam_shared_attn_forward(adapted, attn_params, seq_len, d_head, n_heads)
        let mut out_seq = []
        let mut t2 = 0
        while t2 < seq_len {
            let back = zam_matvec(W_out, attn_out[t2], dim, dim)
            out_seq = out_seq + [zam_residual_add(after_mamba[t2], back, dim)]
            t2 = t2 + 1
        }
        return #{
            "x_seq": out_seq,
            "state": cur_state
        }
    }

    return #{
        "x_seq": after_mamba,
        "state": cur_state
    }
}

fn zam_forward(config, attn_params, per_layer_params, x_seq, seq_len, dim) {
    let n = config["n_layers"]
    let mut states = []
    let mut i0 = 0
    while i0 < n {
        states = states + [zam_zeros_1d(dim)]
        i0 = i0 + 1
    }
    let mut cur = x_seq
    let mut layer = 0
    while layer < n {
        let r = zam_layer_forward(layer, cur, states[layer], config, attn_params, per_layer_params[layer])
        cur = r["x_seq"]
        states[layer] = r["state"]
        layer = layer + 1
    }
    return cur
}

fn zam_count_unique_params(config, shared_attn_params, per_layer_params) {
    let dim = config["dim"]
    let proj_dim = shared_attn_params["proj_dim"]
    let attn_unique = 4 * proj_dim * dim
    let n_layers = config["n_layers"]
    let adapter_per_layer = 2 * dim * dim
    let total_adapter = adapter_per_layer * n_layers
    return attn_unique + total_adapter
}

fn zam_count_full_attn_params(config, shared_attn_params, plan) {
    let dim = config["dim"]
    let proj_dim = shared_attn_params["proj_dim"]
    let n_attn = zam_count_attn_layers(plan)
    let attn_per_layer = 4 * proj_dim * dim
    return attn_per_layer * n_attn
}

// ═══════════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════════

println("=== Zamba Hybrid Tests (SSOT #210) ===")

// Common config: 6 layers, attn every 3 layers, dim=4, d_head=2, 2 heads
let cfg = zam_create_config(6, 3, 4, 2, 2)
let attn = zam_create_shared_attn(4, 2, 2)
let mut per_layer = []
for _i in 0..6 {
    per_layer = per_layer + [zam_per_layer_proj(4)]
}

// #1 config has all keys
check("#1 config has n_layers", cfg["n_layers"] == 6)
check("#1 config has dim", cfg["dim"] == 4)

// #2 shared attn returns 4 matrices
let has_q = len(attn["W_q"]) > 0
let has_k = len(attn["W_k"]) > 0
let has_v = len(attn["W_v"]) > 0
let has_o = len(attn["W_o"]) > 0
check("#2 shared_attn has W_q,W_k,W_v,W_o", has_q && has_k && has_v && has_o)

// #3 shared attn W_q rows == proj_dim (n_heads*d_head=4)
check("#3 W_q rows == proj_dim", len(attn["W_q"]) == 4)

// #4 shared attn W_q cols == dim
check("#4 W_q cols == dim", len(attn["W_q"][0]) == 4)

// #5 W_o is dim x proj_dim
check("#5 W_o rows == dim", len(attn["W_o"]) == 4)
check("#5 W_o cols == proj_dim", len(attn["W_o"][0]) == 4)

// #6 per_layer_proj has dim x dim adapters
let lp0 = per_layer[0]
check("#6 W_in dim x dim", len(lp0["W_in"]) == 4 && len(lp0["W_in"][0]) == 4)
check("#6 W_out dim x dim", len(lp0["W_out"]) == 4 && len(lp0["W_out"][0]) == 4)

// #7 layer plan length == n_layers
let plan = zam_build_layer_plan(cfg)
check("#7 plan length == n_layers", len(plan) == 6)

// #8 layer plan layer 0 is mamba
check("#8 plan[0] == mamba", plan[0] == "mamba")

// #9 layer plan inserts shared_attn at every Kth layer (3, 6 ...)
//    For n=6, k=3: indices 3 should be attn (and only 3, since i=6 not in range)
check("#9 plan[3] == shared_attn", plan[3] == "shared_attn")
check("#9 plan[1] == mamba", plan[1] == "mamba")
check("#9 plan[2] == mamba", plan[2] == "mamba")

// #10 zam_count_attn_layers matches plan
let attn_count = zam_count_attn_layers(plan)
check("#10 attn count matches plan", attn_count == 1)

// #11 mamba block output shape == dim
let init_state = zam_zeros_1d(4)
let xs0 = [0.5, 0.3, 0.1, 0.2]
let mb = zam_mamba_block_forward(init_state, xs0, 4)
check("#11 mamba output dim == 4", len(mb["y"]) == 4)
check("#11 mamba state dim == 4", len(mb["state"]) == 4)

// #12 mamba state updates when x != 0
let any_nonzero = (zam_abs(mb["state"][0]) + zam_abs(mb["state"][1]) + zam_abs(mb["state"][2]) + zam_abs(mb["state"][3])) > 1.0e-6
check("#12 mamba state updates", any_nonzero)

// #13 mamba zero input -> zero state advance (state stays at 0)
let zero_x = zam_zeros_1d(4)
let mb_zero = zam_mamba_block_forward(init_state, zero_x, 4)
let zero_state_sum = zam_abs(mb_zero["state"][0]) + zam_abs(mb_zero["state"][1]) + zam_abs(mb_zero["state"][2]) + zam_abs(mb_zero["state"][3])
check("#13 mamba zero input -> zero state", zero_state_sum < 1.0e-9)

// #14 shared_attn_forward output shape [seq_len, dim]
let xseq = [
    [0.1, 0.2, 0.3, 0.4],
    [0.4, 0.3, 0.2, 0.1],
    [0.5, 0.5, 0.5, 0.5]
]
let attn_out = zam_shared_attn_forward(xseq, attn, 3, 2, 2)
check("#14 attn out seq len == 3", len(attn_out) == 3)
check("#14 attn out dim == 4", len(attn_out[0]) == 4)

// #15 shared_attn zero input -> zero output (no biases)
let xseq_zero = [
    zam_zeros_1d(4),
    zam_zeros_1d(4),
    zam_zeros_1d(4)
]
let attn_out_zero = zam_shared_attn_forward(xseq_zero, attn, 3, 2, 2)
let mut zero_attn_sum = 0.0
let mut zai = 0
while zai < 3 {
    let mut zaj = 0
    while zaj < 4 {
        zero_attn_sum = zero_attn_sum + zam_abs(attn_out_zero[zai][zaj])
        zaj = zaj + 1
    }
    zai = zai + 1
}
check("#15 attn zero input -> zero output", zero_attn_sum < 1.0e-9)

// #16 softmax sums to 1
let row1 = [1.0, 2.0, 3.0, 0.5]
let sm1 = zam_softmax_row(row1, 4)
let sm1_sum = sm1[0] + sm1[1] + sm1[2] + sm1[3]
check("#16 softmax sums to 1", approx(sm1_sum, 1.0, 1.0e-6))

// #17 softmax positive everywhere
let mut sm_pos = true
let mut spi = 0
while spi < 4 {
    if sm1[spi] <= 0.0 { sm_pos = false }
    spi = spi + 1
}
check("#17 softmax all positive", sm_pos)

// #18 softmax uniform on uniform input
let row_u = [2.0, 2.0, 2.0, 2.0]
let sm_u = zam_softmax_row(row_u, 4)
check("#18 softmax uniform == 0.25", approx(sm_u[0], 0.25, 1.0e-6) && approx(sm_u[3], 0.25, 1.0e-6))

// #19 residual_add y + 0 = y
let yvec = [1.0, 2.0, 3.0, 4.0]
let zvec = zam_zeros_1d(4)
let r19 = zam_residual_add(yvec, zvec, 4)
check("#19 y + 0 == y", approx(r19[0], 1.0, 1.0e-9) && approx(r19[3], 4.0, 1.0e-9))

// #20 residual_add commutative
let avec = [0.1, 0.2, 0.3, 0.4]
let bvec = [0.5, 0.6, 0.7, 0.8]
let ab = zam_residual_add(avec, bvec, 4)
let ba = zam_residual_add(bvec, avec, 4)
check("#20 residual_add commutative", approx(ab[0], ba[0], 1.0e-9) && approx(ab[3], ba[3], 1.0e-9))

// #21 layer_forward output shape
let lf = zam_layer_forward(0, xseq, zam_zeros_1d(4), cfg, attn, per_layer[0])
check("#21 layer_forward seq len == 3", len(lf["x_seq"]) == 3)
check("#21 layer_forward dim == 4", len(lf["x_seq"][0]) == 4)

// #22 layer_forward updates state
let st_sum = zam_abs(lf["state"][0]) + zam_abs(lf["state"][1]) + zam_abs(lf["state"][2]) + zam_abs(lf["state"][3])
check("#22 layer_forward state updated", st_sum > 1.0e-6)

// #23 layer_forward attn slot adds skip vs no-attn slot
//     layer 0 = no attn, layer 3 = attn (with same input)
let lf_no = zam_layer_forward(1, xseq, zam_zeros_1d(4), cfg, attn, per_layer[1])
let lf_yes = zam_layer_forward(3, xseq, zam_zeros_1d(4), cfg, attn, per_layer[3])
let mut diff_sum = 0.0
let mut di = 0
while di < 3 {
    let mut dj = 0
    while dj < 4 {
        diff_sum = diff_sum + zam_abs(lf_no["x_seq"][di][dj] - lf_yes["x_seq"][di][dj])
        dj = dj + 1
    }
    di = di + 1
}
check("#23 attn slot differs from non-attn slot", diff_sum > 1.0e-6)

// #24 zam_forward output shape
let fwd = zam_forward(cfg, attn, per_layer, xseq, 3, 4)
check("#24 forward seq len == 3", len(fwd) == 3)
check("#24 forward dim == 4", len(fwd[0]) == 4)

// #25 zam_forward zero input -> zero output (no biases anywhere)
let xseq_zero2 = [zam_zeros_1d(4), zam_zeros_1d(4), zam_zeros_1d(4)]
let fwd_zero = zam_forward(cfg, attn, per_layer, xseq_zero2, 3, 4)
let mut fz_sum = 0.0
let mut fzi = 0
while fzi < 3 {
    let mut fzj = 0
    while fzj < 4 {
        fz_sum = fz_sum + zam_abs(fwd_zero[fzi][fzj])
        fzj = fzj + 1
    }
    fzi = fzi + 1
}
check("#25 zero input -> zero output", fz_sum < 1.0e-9)

// #26 deterministic — same input same output
let fwd2 = zam_forward(cfg, attn, per_layer, xseq, 3, 4)
let mut det_diff = 0.0
let mut deti = 0
while deti < 3 {
    let mut detj = 0
    while detj < 4 {
        det_diff = det_diff + zam_abs(fwd[deti][detj] - fwd2[deti][detj])
        detj = detj + 1
    }
    deti = deti + 1
}
check("#26 deterministic", det_diff < 1.0e-12)

// #27 shared params reused across attn layers (object identity / equal arrays)
//     Re-running zam_layer_forward at TWO different attn slots with the
//     SAME attn dict should produce attention that uses the same W_q.
//     We assert by sampling W_q[0][0] from the dict before and after.
let before_wq = attn["W_q"][0][0]
let _ignore = zam_layer_forward(3, xseq, zam_zeros_1d(4), cfg, attn, per_layer[3])
let after_wq = attn["W_q"][0][0]
check("#27 shared attn params unchanged across uses", approx(before_wq, after_wq, 1.0e-15))

// Additional identity check: build a 9-layer config so attn fires twice
let cfg9 = zam_create_config(9, 3, 4, 2, 2)
let plan9 = zam_build_layer_plan(cfg9)
let attn9_count = zam_count_attn_layers(plan9)
// indices 3 and 6 fire (i>0 && i%3==0), so 2 attn slots
check("#27 multi-attn count == 2", attn9_count == 2)

// #28 unique-param count < full-attn-per-layer count
//     With 9 layers and 2 attn slots, full duplication would need
//     2 * (4 * proj_dim * dim) attn params, sharing needs only one copy.
let mut per9 = []
for _ll in 0..9 { per9 = per9 + [zam_per_layer_proj(4)] }
let unique_p = zam_count_unique_params(cfg9, attn, per9)
let full_p = zam_count_full_attn_params(cfg9, attn, plan9)
// Sharing wins: shared attn (1 copy) < duplicated attn (2 copies)
let attn_only_unique = 4 * attn["proj_dim"] * cfg9["dim"]
check("#28 shared attn < full attn", attn_only_unique < full_p)

// #29 unique param count > 0
check("#29 unique params > 0", unique_p > 0)

// #30 attn output rows count == seq_len
let xseq5 = [
    [0.1, 0.2, 0.3, 0.4],
    [0.4, 0.3, 0.2, 0.1],
    [0.5, 0.5, 0.5, 0.5],
    [0.2, 0.2, 0.2, 0.2],
    [0.7, 0.1, 0.1, 0.1]
]
let attn_out5 = zam_shared_attn_forward(xseq5, attn, 5, 2, 2)
check("#30 attn out rows == seq_len 5", len(attn_out5) == 5)

// #31 mamba block respects sequence position when run twice
//     First call from zero state; second call from result state.
//     The accumulated state must be larger in magnitude.
let m_a = zam_mamba_block_forward(zam_zeros_1d(4), [0.5, 0.5, 0.5, 0.5], 4)
let m_b = zam_mamba_block_forward(m_a["state"], [0.5, 0.5, 0.5, 0.5], 4)
let sum_a = zam_abs(m_a["state"][0]) + zam_abs(m_a["state"][1]) + zam_abs(m_a["state"][2]) + zam_abs(m_a["state"][3])
let sum_b = zam_abs(m_b["state"][0]) + zam_abs(m_b["state"][1]) + zam_abs(m_b["state"][2]) + zam_abs(m_b["state"][3])
check("#31 mamba state grows over steps", sum_b > sum_a)

// #32 zam_forward includes residual (output != input on nonzero)
let mut diff_residual = 0.0
let mut dri = 0
while dri < 3 {
    let mut drj = 0
    while drj < 4 {
        diff_residual = diff_residual + zam_abs(fwd[dri][drj] - xseq[dri][drj])
        drj = drj + 1
    }
    dri = dri + 1
}
check("#32 forward output differs from input", diff_residual > 1.0e-6)

// ═══════════════════════════════════════════════════════════════════
//  Summary
// ═══════════════════════════════════════════════════════════════════

println("")
println("=== Zamba Hybrid (#210) test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
