// ═══════════════════════════════════════════════════════════════════
//  test_fused_adam.hexa — ROI #94 correctness suite
//
//  Validates self/ai_native/fused_adam.hexa:
//    T1   bias_correction(b,1) = 1 − b
//    T2   bias_correction(b,0) = 1  (identity / pre-first-step)
//    T3   bias_correction(1.0, t) = 0  (β=1 freeze)
//    T4   lr=0 is the identity on p
//    T5   lr=0 still updates m and v
//    T6   t=0 keeps mhat=m (no-op rescale)
//    T7   ε > 0 guards sqrt(0)
//    T8   N=0 empty input → empty output
//    T9   fused == naive, seed=1, N=8
//    T10  fused == naive, seed=2, N=16
//    T11  fused == naive, seed=3, N=32
//    T12  fused == naive, seed=4, N=64
//    T13  fused == naive, seed=5, N=128
//    T14  β1=0 → m = g (no memory)
//    T15  β2=0 → v = g²
//    T16  β1=β2=1 (frozen state) — m,v unchanged
//    T17  AST detect three loops POS
//    T18  AST detect different-index NEG
//    T19  AST detect wrong-order NEG
//    T20  AST rewrite collapses to fused_adam_loop
//    T21  pass-count accounting 3 vs 1
//    T22  convergence on quadratic loss N=100 steps
//    T23  max_abs_diff across all random seeds ≤ 1e-7
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ai_native/fused_adam.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ai_native/fused_adam.hexa — AI-native ROI #94
//
//  @fused_adam — fuse the three separate passes of AdamW (m-update,
//  v-update, param-update) into a single parameter sweep. The naive
//  reference implementation runs three independent loops, reading and
//  writing every slot three times per optimizer step. The fused kernel
//  reads each slot once, performs all three state transitions with
//  scalar-local temporaries, and writes each slot once.
//
//  Training speed-up ≈ 3× on the optimizer step (memory-bound; AdamW
//  is O(params), not O(flops)) and ≈ 1/3 of the write-back bandwidth.
//
//  Public API
//  ──────────
//      adam_step_naive(p, g, m, v, t, lr, b1, b2, eps)  -> {p,m,v}
//      adam_step_fused(p, g, m, v, t, lr, b1, b2, eps)  -> {p,m,v}
//          • p[i], g[i], m[i], v[i]   : [float] of equal length N
//          • t                        : int ≥ 1 (step count)
//          • lr                       : float (learning rate)
//          • b1                       : float in (0,1)   first-moment decay
//          • b2                       : float in (0,1)   second-moment decay
//          • eps                      : float > 0        divide-by-zero guard
//          • returns map #{p, m, v}   — updated copies
//
//      bias_correction(b, t)          -> float
//          • 1 − b^t  (used by both the m-hat and v-hat rescales)
//          • t = 0 is treated as step-before-first-update: returns 1
//            so that mhat = m / 1 = m (a no-op on the identity path).
//
//      detect_adam_three_loops(prog) -> bool
//          • AST-level predicate: returns true iff `prog` is a list of
//            exactly three for-loops whose bodies are (in order) the
//            m-update, the v-update, and the param-update on the same
//            parameter index.
//
//      rewrite_fuse_adam(prog)       -> Program
//          • If detect_adam_three_loops(prog) is true, replaces the
//            three-loop segment with a single "fused_adam_loop" node.
//            Otherwise returns `prog` unchanged.
//
//      naive_pass_count()             -> int   (=3)
//      fused_pass_count()             -> int   (=1)
//
//  Numerical contract
//  ──────────────────
//      For every (p, g, m, v, t, lr, b1, b2, eps) with t ≥ 1 and
//      eps > 0, and for every i:
//          adam_step_fused(...).p[i] == adam_step_naive(...).p[i]
//          ... .m[i] == naive .m[i]
//          ... .v[i] == naive .v[i]
//      element-wise within tol 1e-7. (Identical arithmetic, identical
//      order: the fused loop performs exactly the same scalar ops per
//      slot that the three naive loops do in sequence.)
//
//  AdamW mathematical reference
//  ────────────────────────────
//      m_t  = b1 · m_{t-1} + (1 - b1) · g
//      v_t  = b2 · v_{t-1} + (1 - b2) · g²
//      mhat = m_t / (1 - b1^t)
//      vhat = v_t / (1 - b2^t)
//      p_t  = p_{t-1} − lr · mhat / (√vhat + eps)
//
//  Edge cases
//  ──────────
//      • N = 0              → returns {p, m, v} unchanged (copies).
//      • lr = 0             → param update is the identity on p.
//                             m, v still receive their new values.
//      • t = 0              → bias_correction returns 1 (no-op), so
//                             mhat = m, vhat = v. This is the "step 0"
//                             identity path used before the first
//                             optimizer.step() call in some schedules.
//      • eps > 0            → divide-by-zero on sqrt(vhat)=0 is
//                             impossible; eps is the guard.
//      • b1 = 1, b2 = 1     → m and v freeze at their prior value
//                             (1 − b = 0). bias_correction(1, t) = 0;
//                             we guard against the resulting 0/0 by
//                             treating a 0 denominator as 1 (no rescale).
//      • b1 = 0             → m_t = g (EMA with 0 memory).
//
//  Pattern detect / rewrite
//  ────────────────────────
//  The AST side follows the same kind-tagged-struct approach used in
//  graph_pattern.hexa (#84). Three consecutive "for" nodes carrying
//  the body kinds "m_update", "v_update", "param_update" over the
//  same index variable collapse into one "fused_adam_loop" node.
//
//  Grammar cautions (HX3 pitfalls)
//  ──────────────────────────────
//      - no struct-literal head inside `if` → maps/structs returned
//        at tail of arm
//      - no `and`/`or` → `&&` / `||`
//      - no enum → string tags
//      - abs → use abs_pure from math_pure.hexa
//      - pow(x, t) for integer t handled by loop multiply (t ≤ 10⁶
//        typical; avoids fp-pow domain issues at boundary cases)
//
//  AI-native attrs
//  ───────────────
//      @hot        — optimizer step is called every training iteration
//      @fused_adam — marker: 3-pass → 1-pass fusion
//      @pure       — returns new state; does not mutate caller arrays
//      @parallel   — the inner sweep is independent across i
// ═══════════════════════════════════════════════════════════════════

// ── numeric helpers ────────────────────────────────────────────────

// fa94_fabs → abs_pure (math_pure.hexa)

@pure
fn fa94_zeros_1d(n) {
    let mut v = []
    let mut _i = 0
    while _i < n {
        v.push(0.0)
        _i = _i + 1
    }
    return v
}

@pure
fn fa94_copy_1d(a) {
    let n = len(a)
    let mut out = fa94_zeros_1d(n)
    let mut i = 0
    while i < n {
        out[i] = a[i]
        i = i + 1
    }
    return out
}

// Integer-exponent power.  b^t computed by t-many multiplications.
// Exact on floats for the t that appears in real training (≤ 10⁶).
// We avoid pow(b, t) here to sidestep any fp-pow rounding and to make
// b1=1 / b2=1 behave as exact 1 (pow may return 1 − ε).
@pure
fn fa94_ipow(b, t) {
    if t <= 0 { return 1.0 }
    let mut r = 1.0
    let mut _i = 0
    while _i < t {
        r = r * b
        _i = _i + 1
    }
    return r
}

// ═══════════════════════════════════════════════════════════════════
//  bias_correction(b, t) — returns (1 − b^t).
//  Convention: t = 0 → 1 (no rescale). Some training loops evaluate
//  the optimizer "before" the first step for diagnostic reasons.
// ═══════════════════════════════════════════════════════════════════
@pure
fn bias_correction_impl(b, t) {
    if t <= 0 { return 1.0 }
    let bt = fa94_ipow(b, t)
    return 1.0 - bt
}

pub fn bias_correction(b, t) {
    return bias_correction_impl(b, t)
}

// Small helper: divide by a possibly-zero bias-correction denominator.
// When b=1 the correction is 0; we fall back to a no-op rescale.
@pure
fn fa94_safe_div(num, den) {
    if abs_pure(den) < 1.0e-30 { return num }
    return num / den
}

// ═══════════════════════════════════════════════════════════════════
//  adam_step_naive(p, g, m, v, t, lr, b1, b2, eps)
//
//  Reference three-pass implementation. Each state array is iterated
//  independently; three reads + three writes per slot.
// ═══════════════════════════════════════════════════════════════════
@pure
fn adam_step_naive_impl(p, g, m, v, t, lr, b1, b2, eps) {
    let n = len(p)
    let mc = fa94_copy_1d(m)
    let vc = fa94_copy_1d(v)
    let pc = fa94_copy_1d(p)
    if n == 0 {
        return #{
            "p": pc,
            "m": mc,
            "v": vc
        }
    }

    let one_minus_b1 = 1.0 - b1
    let one_minus_b2 = 1.0 - b2
    let bc1 = bias_correction(b1, t)
    let bc2 = bias_correction(b2, t)

    // Pass 1 — m-update
    let mut i = 0
    while i < n {
        mc[i] = b1 * mc[i] + one_minus_b1 * g[i]
        i = i + 1
    }
    // Pass 2 — v-update
    let mut i = 0
    while i < n {
        vc[i] = b2 * vc[i] + one_minus_b2 * g[i] * g[i]
        i = i + 1
    }
    // Pass 3 — param-update
    let mut i = 0
    while i < n {
        let mhat = fa94_safe_div(mc[i], bc1)
        let vhat = fa94_safe_div(vc[i], bc2)
        let denom = sqrt(vhat) + eps
        pc[i] = pc[i] - lr * mhat / denom
        i = i + 1
    }

    return #{
        "p": pc,
        "m": mc,
        "v": vc
    }
}

pub fn adam_step_naive(p, g, m, v, t, lr, b1, b2, eps) {
    return adam_step_naive_impl(p, g, m, v, t, lr, b1, b2, eps)
}

// ═══════════════════════════════════════════════════════════════════
//  adam_step_fused(p, g, m, v, t, lr, b1, b2, eps)
//
//  Single-pass fused kernel. Reads (p,g,m,v)[i] once, writes (p,m,v)[i]
//  once. All scalar math is held in local registers; no intermediate
//  array allocations beyond the three output copies.
//
//  The arithmetic per slot is byte-for-byte identical to the naive
//  sequence:
//      m'   = b1 · m + (1 − b1) · g
//      v'   = b2 · v + (1 − b2) · g²
//      mhat = m' / (1 − b1^t)
//      vhat = v' / (1 − b2^t)
//      p'   = p − lr · mhat / (√vhat + eps)
//  Hence the fused result equals the naive result bit-for-bit on an
//  IEEE-754 machine (tol 1e-7 is a generous engineering margin).
// ═══════════════════════════════════════════════════════════════════
@hot @fused_adam @parallel @pure
fn adam_step_fused_impl(p, g, m, v, t, lr, b1, b2, eps) {
    let n = len(p)
    let pc = fa94_copy_1d(p)
    let mc = fa94_copy_1d(m)
    let vc = fa94_copy_1d(v)
    if n == 0 {
        return #{
            "p": pc,
            "m": mc,
            "v": vc
        }
    }

    // Hoist loop-invariants once.
    let one_minus_b1 = 1.0 - b1
    let one_minus_b2 = 1.0 - b2
    let bc1 = bias_correction(b1, t)
    let bc2 = bias_correction(b2, t)

    // Single fused sweep.
    let mut i = 0
    while i < n {
        let gi = g[i]
        let mi = b1 * mc[i] + one_minus_b1 * gi
        let vi = b2 * vc[i] + one_minus_b2 * gi * gi
        mc[i] = mi
        vc[i] = vi
        let mhat = fa94_safe_div(mi, bc1)
        let vhat = fa94_safe_div(vi, bc2)
        let denom = sqrt(vhat) + eps
        pc[i] = pc[i] - lr * mhat / denom
        i = i + 1
    }

    return #{
        "p": pc,
        "m": mc,
        "v": vc
    }
}

pub fn adam_step_fused(p, g, m, v, t, lr, b1, b2, eps) {
    return adam_step_fused_impl(p, g, m, v, t, lr, b1, b2, eps)
}

// ═══════════════════════════════════════════════════════════════════
//  AST side — pattern detect / rewrite
//
//  The representation mirrors graph_pattern.hexa: a tagged-kind struct.
//  A Program is a list of Stmts; each Stmt is either a single for-loop
//  body marker or the fused marker the rewrite produces.
//
//  Stmt.kind ∈ {
//      "for_m_update", "for_v_update", "for_param_update",
//      "fused_adam_loop", "other"
//  }
//  Stmt.index : string — the loop index variable name, used to confirm
//               that all three loops iterate the same parameter vector.
//  Stmt.param : string — the parameter-vector name ("p" typically).
// ═══════════════════════════════════════════════════════════════════
struct AdamStmt {
    kind: string
    index: string
    param: string
}

pub fn adam_stmt(kind, index, param) {
    return AdamStmt{kind: kind, index: index, param: param}
}

pub fn adam_stmt_for_m(index, param)     { return adam_stmt("for_m_update",     index, param) }
pub fn adam_stmt_for_v(index, param)     { return adam_stmt("for_v_update",     index, param) }
pub fn adam_stmt_for_param(index, param) { return adam_stmt("for_param_update", index, param) }
pub fn adam_stmt_fused(index, param)     { return adam_stmt("fused_adam_loop",  index, param) }
pub fn adam_stmt_other()                 { return adam_stmt("other", "", "") }

// A "Program" is simply a list of AdamStmt in execution order.

@pure
fn detect_adam_three_loops_impl(prog) {
    if len(prog) < 3 { return false }
    let s0 = prog[0]
    let s1 = prog[1]
    let s2 = prog[2]
    if s0.kind != "for_m_update"     { return false }
    if s1.kind != "for_v_update"     { return false }
    if s2.kind != "for_param_update" { return false }
    // All three must iterate the same index over the same parameter.
    if s0.index != s1.index { return false }
    if s1.index != s2.index { return false }
    if s0.param != s1.param { return false }
    if s1.param != s2.param { return false }
    return true
}

pub fn detect_adam_three_loops(prog) {
    return detect_adam_three_loops_impl(prog)
}

@pure
fn rewrite_fuse_adam_impl(prog) {
    if !detect_adam_three_loops(prog) { return prog }
    let s0 = prog[0]
    let fused = adam_stmt_fused(s0.index, s0.param)
    let mut out = [fused]
    // Keep any statements that followed the three fused ones.
    let mut i = 3
    while i < len(prog) {
        out.push(prog[i])
        i = i + 1
    }
    return out
}

pub fn rewrite_fuse_adam(prog) {
    return rewrite_fuse_adam_impl(prog)
}

// ═══════════════════════════════════════════════════════════════════
//  Pass-count accounting (exposed for tests / benches).
//      naive path runs 3 loops over the params.
//      fused path runs 1 loop.
// ═══════════════════════════════════════════════════════════════════
pub fn naive_pass_count() { return 3 }
pub fn fused_pass_count() { return 1 }


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0
let mut max_abs_diff_global = 0.0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_t(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_close(a, b, eps) {
    if len(a) != len(b) { return false }
    let mut i = 0

    while i < len(a) {
        if fabs_t(a[i] - b[i]) > eps { return false }
    }
    return true
}

fn vec_max_diff(a, b) {
    let mut mx = 0.0
    let mut i = 0

    while i < len(a) {
        let d = fabs_t(a[i] - b[i])
        if d > mx { mx = d }
    }
    return mx
}

fn update_global_max(d) {
    if d > max_abs_diff_global { max_abs_diff_global = d }
}

// deterministic LCG
fn lcg_step(state) {
    let a = 1103515245
    let c = 12345
    let m = 2147483648
    return (state * a + c) % m
}

fn rand_vec(n, seed) {
    let mut state = seed
    let mut v = []
    let mut _i = 0

    while _i < n {
        state = lcg_step(state)
        let r = (state % 1000) * 0.004 - 2.0
        v = v + [r]
    }
    return v
}

fn zeros_vec(n) {
    let mut v = []
    let mut _i = 0

    while _i < n {
        v = v + [0.0]
    }
    return v
}

fn copy_vec(a) {
    let mut out = []
    let mut i = 0

    while i < len(a) {
        out = out + [a[i]]
    }
    return out
}

// ══════════════════════════════════════════════════════════════════
println("═══════════════════════════════════════════════════════")
println("  ROI #94 AdamW 3-pass → 1-pass Fusion — correctness")
println("═══════════════════════════════════════════════════════")

let tol = 1.0e-7

// ── T1  bias_correction(b,1) = 1 − b ─────────────────────────────
let bc_1_b09 = bias_correction(0.9, 1)
check("T1 bias_correction(0.9,1) == 0.1",
      fabs_t(bc_1_b09 - 0.1) < tol)

// ── T2  bias_correction(b,0) = 1 ─────────────────────────────────
let bc_0 = bias_correction(0.9, 0)
check("T2 bias_correction(0.9,0) == 1.0",
      fabs_t(bc_0 - 1.0) < tol)

// ── T3  bias_correction(1.0, t) = 0 (β=1 freeze) ─────────────────
let bc_one = bias_correction(1.0, 5)
check("T3 bias_correction(1.0,5) == 0.0",
      fabs_t(bc_one - 0.0) < tol)

// ── T4  lr=0 is the identity on p ────────────────────────────────
let p4 = rand_vec(10, 101)
let g4 = rand_vec(10, 102)
let m4 = zeros_vec(10)
let v4 = zeros_vec(10)
let p4_copy = copy_vec(p4)
let res4 = adam_step_fused(p4, g4, m4, v4, 1, 0.0, 0.9, 0.999, 1.0e-8)
check("T4 lr=0 → p unchanged", vec_close(res4["p"], p4_copy, tol))

// ── T5  lr=0 still updates m and v ───────────────────────────────
// With m=v=0 prior and b1=0.9, b2=0.999:
//   m'[i] = 0.1 · g[i]
//   v'[i] = 0.001 · g[i]²
let mut expect_m5 = []
let mut expect_v5 = []
let mut i = 0

while i < 10 {
    expect_m5 = expect_m5 + [0.1 * g4[i]]
    expect_v5 = expect_v5 + [0.001 * g4[i] * g4[i]]
}
check("T5 lr=0 → m updated", vec_close(res4["m"], expect_m5, tol))
check("T5 lr=0 → v updated", vec_close(res4["v"], expect_v5, tol))

// ── T6  t=0 → mhat=m (bias_correction denom = 1) ─────────────────
// With t=0, bias_correction returns 1, so mhat=m and vhat=v.
// Using m=v=0 input, one step of g=1 gives:
//   m' = 0.1, v' = 0.001
//   mhat = 0.1 / 1 = 0.1
//   vhat = 0.001 / 1 = 0.001
//   p' = p - 0.01 · 0.1 / (√0.001 + 1e-8)
let p6 = [0.5]
let g6 = [1.0]
let m6 = [0.0]
let v6 = [0.0]
let res6 = adam_step_fused(p6, g6, m6, v6, 0, 0.01, 0.9, 0.999, 1.0e-8)
let expect6_p0 = 0.5 - 0.01 * 0.1 / (sqrt(0.001) + 1.0e-8)
check("T6 t=0 mhat=m path matches closed form",
      fabs_t(res6["p"][0] - expect6_p0) < tol)
check("T6 t=0 m updated to 0.1", fabs_t(res6["m"][0] - 0.1) < tol)
check("T6 t=0 v updated to 0.001", fabs_t(res6["v"][0] - 0.001) < tol)

// ── T7  ε > 0 guards divide-by-zero when vhat = 0 ────────────────
// If g=0 and v_prev=0 then vhat=0 and sqrt(0)=0; eps keeps denom>0.
let p7 = [1.0]
let g7 = [0.0]
let m7 = [0.0]
let v7 = [0.0]
let res7 = adam_step_fused(p7, g7, m7, v7, 1, 0.01, 0.9, 0.999, 1.0e-8)
check("T7 eps guards 0/0 (p finite)", fabs_t(res7["p"][0] - 1.0) < tol)

// ── T8  N=0 empty input → empty output ───────────────────────────
let empty = []
let res8 = adam_step_fused(empty, empty, empty, empty, 5, 0.01, 0.9, 0.999, 1.0e-8)
check("T8 N=0 p length 0",  len(res8["p"]) == 0)
check("T8 N=0 m length 0",  len(res8["m"]) == 0)
check("T8 N=0 v length 0",  len(res8["v"]) == 0)

// ── T9..T13  fused == naive × 5 seeds / varying N ─────────────────
let seeds = [1, 2, 3, 4, 5]
let sizes = [8, 16, 32, 64, 128]
let tc_names = ["T9 ", "T10", "T11", "T12", "T13"]
let mut k = 0

while k < 5 {
    let n = sizes[k]
    let seed = seeds[k]
    let p = rand_vec(n, seed * 11)
    let g = rand_vec(n, seed * 13)
    let m = rand_vec(n, seed * 17)
    let v = rand_vec(n, seed * 19)
    // v must be non-negative (it is an EMA of g²).  Square it here
    // to keep the test physically plausible; the code still handles
    // negative v formally, but sqrt would go imaginary.
    let mut v_pos = []
    let mut i = 0

    while i < n {
        v_pos = v_pos + [v[i] * v[i]]
    }
    let ref_out = adam_step_naive(p, g, m, v_pos, seed, 0.01, 0.9, 0.999, 1.0e-8)
    let fus_out = adam_step_fused(p, g, m, v_pos, seed, 0.01, 0.9, 0.999, 1.0e-8)
    let dp = vec_max_diff(ref_out["p"], fus_out["p"])
    let dm = vec_max_diff(ref_out["m"], fus_out["m"])
    let dv = vec_max_diff(ref_out["v"], fus_out["v"])
    update_global_max(dp)
    update_global_max(dm)
    update_global_max(dv)
    let ok_p = dp <= tol
    let ok_m = dm <= tol
    let ok_v = dv <= tol
    let name = tc_names[k] + " fused==naive N=" + to_string(n) + " seed=" + to_string(seed)
    check(name, ok_p && ok_m && ok_v)
}

// ── T14  β1=0 → m = g (no first-moment memory) ───────────────────
let pA = [1.0, 2.0, 3.0]
let gA = [0.5, -0.5, 1.5]
let mA = [0.0, 0.0, 0.0]
let vA = [0.0, 0.0, 0.0]
let resA = adam_step_fused(pA, gA, mA, vA, 1, 0.01, 0.0, 0.999, 1.0e-8)
check("T14 β1=0 → m == g", vec_close(resA["m"], gA, tol))

// ── T15  β2=0 → v = g² ────────────────────────────────────────────
let resB = adam_step_fused(pA, gA, mA, vA, 1, 0.01, 0.9, 0.0, 1.0e-8)
let mut g_sq = []
let mut i = 0

while i < len(gA) {
    g_sq = g_sq + [gA[i] * gA[i]]
}
check("T15 β2=0 → v == g²", vec_close(resB["v"], g_sq, tol))

// ── T16  β1=β2=1 (frozen) — m and v unchanged ────────────────────
// (1-b) factor is 0, so m_new = b·m = m, v_new = v.
let mInit = [0.2, 0.3]
let vInit = [0.01, 0.02]
let resC = adam_step_fused([0.0, 0.0], [1.0, -1.0], mInit, vInit,
                           3, 0.01, 1.0, 1.0, 1.0e-8)
check("T16 β1=1 freezes m", vec_close(resC["m"], mInit, tol))
check("T16 β2=1 freezes v", vec_close(resC["v"], vInit, tol))

// ── T17  AST detect: positive three-loop match ────────────────────
let prog_ok = [
    adam_stmt_for_m("i", "theta"),
    adam_stmt_for_v("i", "theta"),
    adam_stmt_for_param("i", "theta")
]
check("T17 AST detect three-loop POS", detect_adam_three_loops(prog_ok))

// ── T18  AST detect: different index → NEG ───────────────────────
let prog_bad_idx = [
    adam_stmt_for_m("i", "theta"),
    adam_stmt_for_v("j", "theta"),
    adam_stmt_for_param("i", "theta")
]
check("T18 AST detect different-index NEG",
      !detect_adam_three_loops(prog_bad_idx))

// ── T19  AST detect: wrong order → NEG ────────────────────────────
let prog_wrong_order = [
    adam_stmt_for_param("i", "theta"),
    adam_stmt_for_m("i", "theta"),
    adam_stmt_for_v("i", "theta")
]
check("T19 AST detect wrong-order NEG",
      !detect_adam_three_loops(prog_wrong_order))

// ── T20  AST rewrite collapses three loops to one fused node ─────
let prog_rw = rewrite_fuse_adam(prog_ok)
let ok20 = len(prog_rw) == 1 && prog_rw[0].kind == "fused_adam_loop"
check("T20 rewrite → [fused_adam_loop]", ok20)

// Also: rewrite is identity on non-matching programs.
let prog_rw_neg = rewrite_fuse_adam(prog_wrong_order)
let ok20b = len(prog_rw_neg) == 3
check("T20b rewrite identity on NEG", ok20b)

// ── T21  pass-count accounting ───────────────────────────────────
check("T21 naive_pass_count == 3", naive_pass_count() == 3)
check("T21 fused_pass_count == 1", fused_pass_count() == 1)

// ── T22  convergence on quadratic loss N=100 steps ───────────────
// Loss  f(p) = Σ_i p_i²   → gradient g_i = 2 p_i
// Adam should drive p toward 0. Start from p = rand in [-2, 2].
let pN = 8
let mut p22 = rand_vec(pN, 12345)
let mut m22 = zeros_vec(pN)
let mut v22 = zeros_vec(pN)
let lr22 = 0.05
let mut loss_start = 0.0
let mut i = 0

while i < pN {
    loss_start = loss_start + p22[i] * p22[i]
}
let mut t = 1

while t < 101 {
    let mut g22 = []
    let mut i = 0

    while i < pN {
        g22 = g22 + [2.0 * p22[i]]
    }
    let step = adam_step_fused(p22, g22, m22, v22, t, lr22, 0.9, 0.999, 1.0e-8)
    p22 = step["p"]
    m22 = step["m"]
    v22 = step["v"]
}
let mut loss_end = 0.0
let mut i = 0

while i < pN {
    loss_end = loss_end + p22[i] * p22[i]
}
check("T22 quadratic loss decreases (100 steps)",
      loss_end < loss_start * 0.1)

// ── T23  global max_abs_diff across all random seeds ≤ 1e-7 ──────
check("T23 global max_abs_diff ≤ 1e-7",
      max_abs_diff_global <= tol)

// ══════════════════════════════════════════════════════════════════
println("═══════════════════════════════════════════════════════")
println("  max_abs_diff = " + to_string(max_abs_diff_global))
println("  Results: " + to_string(pass_count) + " PASS / "
        + to_string(fail_count) + " FAIL")
println("═══════════════════════════════════════════════════════")

if fail_count == 0 {
    println("[ALL PASS] ROI #94 fused_adam verified")
}
