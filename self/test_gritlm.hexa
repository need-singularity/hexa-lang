//    #24 cosine_similarity in [-1, 1]
//    #25 contrastive_loss >= 0
//    #26 contrastive_loss pos closer -> lower
//    #27 combined_loss alpha=1 -> gen_only
//    #28 combined_loss alpha=0 -> emb_only
//    #29 combined_loss alpha=0.5 -> average
//    #30 mode_select embed
//    #31 mode_select gen
//    #32 mode_select query
