// ═══════════════════════════════════════════════════════════
//  test_map_chain_fusion.hexa — M987 .map(f).map(g) fusion
//  (ROI #138)  Verifies that the hand-written fused form of each
//  chain variant is semantically equivalent to the original chain.
//  This mirrors what the ai_native_pass M987 AST rewrite produces.
//
//  Covered variants (per ROI #138):
//   1. .map(f).map(g)   — fused to .map(|x| g(f(x)))       [M987]
//   2. .map(f).filter(p) — fused to single-loop             [M965]
//   3. .filter(p).map(f) — fused to single-loop             [M965]
//   4. non-pure (.map with println) — MUST NOT be fused     [M987 gate]
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        println("[FAIL] " + name + " — len mismatch: " + to_string(len(actual)) + " vs " + to_string(len(expected)))
        fail_count = fail_count + 1
        return
    }
    let mut ok = true
    let mut i = 0
    while i < len(actual) {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — actual: " + to_string(actual) + ", expected: " + to_string(expected))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  M987: map chain fusion — .map(f).map(g) tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. .map.map — the primary M987 target ───────────────────
// Original: two separate .map calls, two traversals + intermediate array.
fn orig_map_map(src) {
    return src.map(|x| x + 1).map(|y| y * 3)
}

// Fused: what M987 produces — single .map with composed lambda.
// Rewrite: .map(|x| x+1).map(|y| y*3) → .map(|x| (x+1) * 3)
fn fused_map_map(src) {
    return src.map(|x| (x + 1) * 3)
}

// ── 2. .map.filter — M965 handles this (loop fusion) ────────
// Original: .map(f).filter(p).
fn orig_map_filter(src) {
    return src.map(|x| x * 2).filter(|y| y > 4)
}

// Fused-loop form (mirrors M965 output shape).
fn fused_map_filter(src) {
    let mut result = []
    let __fsrc0 = src
    let mut __fi0 = 0
    while __fi0 < __fsrc0.len() {
        let __fx0 = __fsrc0[__fi0]
        let __fm0_0 = __fx0 * 2
        if __fm0_0 > 4 {
            result.push(__fm0_0)
        }
        __fi0 = __fi0 + 1
    }
    return result
}

// ── 3. .filter.map — M965 handles this (loop fusion) ────────
fn orig_filter_map(src) {
    return src.filter(|x| x % 2 == 0).map(|y| y + 100)
}

fn fused_filter_map(src) {
    let mut result = []
    let __fsrc0 = src
    let mut __fi0 = 0
    while __fi0 < __fsrc0.len() {
        let __fx0 = __fsrc0[__fi0]
        if __fx0 % 2 == 0 {
            let __fm0_1 = __fx0 + 100
            result.push(__fm0_1)
        }
        __fi0 = __fi0 + 1
    }
    return result
}

// ── 4. non-pure: MUST NOT be fused ──────────────────────────
// A map chain where one lambda has a side effect (println).  M987
// explicitly refuses to fuse impure lambdas, because compose ordering
// would change the observable print interleaving.  Semantic contract:
// whether or not the optimizer rewrites, the final array must still
// match the naive two-pass result.  We verify this here by comparing
// against a hand-written two-pass form (no fusion applied).
let mut __nonpure_trace = []
fn nonpure_side_effect(v) {
    // Side-effecting helper — records into a module-level trace.
    __nonpure_trace.push(v)
    return v
}

fn orig_nonpure_chain(src) {
    // Lambda body calls impure helper — M987 must NOT fuse this.
    return src.map(|x| nonpure_side_effect(x)).map(|y| y * 2)
}

// "Two-pass" reference — produces the SAME final array and the SAME
// trace length as the original (order of side effects preserved).
fn twopass_nonpure_chain(src) {
    let mut step1 = []
    let mut i = 0
    while i < len(src) {
        step1.push(nonpure_side_effect(src[i]))
        i = i + 1
    }
    let mut step2 = []
    let mut j = 0
    while j < len(step1) {
        step2.push(step1[j] * 2)
        j = j + 1
    }
    return step2
}

// ── Equivalence checks ──────────────────────────────────────

let inputs = [
    [],
    [1],
    [0],
    [1, 2, 3, 4, 5],
    [-3, -1, 0, 2, 4, 6],
    [10, 20, 30],
    [2, 4, 6, 8, 10, 12]
]

println("--- case 1: .map.map (M987 primary target) ---")
let mut i = 0
while i < len(inputs) {
    let inp = inputs[i]
    check_arr("map.map #" + to_string(i), fused_map_map(inp), orig_map_map(inp))
    i = i + 1
}
println("")

println("--- case 2: .map.filter (M965 handles) ---")
i = 0
while i < len(inputs) {
    let inp = inputs[i]
    check_arr("map.filter #" + to_string(i), fused_map_filter(inp), orig_map_filter(inp))
    i = i + 1
}
println("")

println("--- case 3: .filter.map (M965 handles) ---")
i = 0
while i < len(inputs) {
    let inp = inputs[i]
    check_arr("filter.map #" + to_string(i), fused_filter_map(inp), orig_filter_map(inp))
    i = i + 1
}
println("")

println("--- case 4: non-pure (M987 MUST NOT fuse) ---")
// Both runs must produce the same final array AND the same trace length.
// If M987 wrongly fused the chain, the print order or trace would change;
// the simpler observable is array equality (trace len is also asserted).
i = 0
while i < len(inputs) {
    let inp = inputs[i]
    // Reset trace before each run
    __nonpure_trace = []
    let expected = twopass_nonpure_chain(inp)
    let expected_trace_len = len(__nonpure_trace)
    __nonpure_trace = []
    let actual = orig_nonpure_chain(inp)
    let actual_trace_len = len(__nonpure_trace)
    check_arr("nonpure #" + to_string(i), actual, expected)
    if actual_trace_len != expected_trace_len {
        println("[FAIL] nonpure trace-len #" + to_string(i) + " — " + to_string(actual_trace_len) + " vs " + to_string(expected_trace_len))
        fail_count = fail_count + 1
    } else {
        println("[PASS] nonpure trace-len #" + to_string(i) + " (" + to_string(actual_trace_len) + " calls)")
        pass_count = pass_count + 1
    }
    i = i + 1
}
println("")

// ── Summary ─────────────────────────────────────────────────
println("═══════════════════════════════════════════════════════")
if fail_count == 0 {
    println("  ALL " + to_string(pass_count) + " TESTS PASS")
} else {
    println("  FAILED: " + to_string(fail_count) + " / " + to_string(pass_count + fail_count))
}
println("═══════════════════════════════════════════════════════")
println(to_string(pass_count) + " passed")
