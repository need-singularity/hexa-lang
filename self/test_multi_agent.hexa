// ===================================================================
//  test_multi_agent.hexa — Multi-Agent Orchestration tests
//
//  Tests:
//    1.  create_orchestrator
//    2.  register_agent
//    3.  list_agents
//    4.  get_agent
//    5.  unregister_agent
//    6.  route_task keyword matching
//    7.  route_task_top_n
//    8.  send_message
//    9.  broadcast_message
//   10.  get_messages
//   11.  subscribe + publish
//   12.  consensus (majority vote)
//   13.  weighted_consensus
//   14.  run_task end-to-end
//   15.  run_task_consensus
//
//  Run: hexa self/test_multi_agent.hexa
// ===================================================================
import "ml/multi_agent.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

// ── 1. create_orchestrator ──────────────────────────────────────
let mut orch = create_orchestrator()
check("create_orchestrator returns map", len(keys(orch)) > 0)
check("create_orchestrator has agents", len(orch["agent_names"]) >= 0)

// ── 2. register_agent ───────────────────────────────────────────
orch = register_agent(orch, "coder", "writes code and fixes bugs", ["code", "debug", "test"], "gpt-4")
orch = register_agent(orch, "researcher", "searches documents and papers", ["search", "summarize"], "claude")
orch = register_agent(orch, "designer", "creates UI and visual design", ["design", "mockup", "css"], "gemini")

check("register 3 agents", len(list_agents(orch)) == 3)

// ── 3. list_agents ──────────────────────────────────────────────
let names = list_agents(orch)
check("list_agents contains coder", names[0] == "coder")
check("list_agents contains researcher", names[1] == "researcher")

// ── 4. get_agent ────────────────────────────────────────────────
let coder = get_agent(orch, "coder")
check("get_agent name", coder["name"] == "coder")
check("get_agent model", coder["model"] == "gpt-4")
check("get_agent tools len", len(coder["tools"]) == 3)

// ── 5. unregister_agent ─────────────────────────────────────────
orch = register_agent(orch, "temp", "temporary agent", [], "test")
check("before unregister count", len(list_agents(orch)) == 4)
orch = unregister_agent(orch, "temp")
check("after unregister count", len(list_agents(orch)) == 3)

// ── 6. route_task — keyword matching ────────────────────────────
let routed1 = route_task(orch, "fix the bug in code")
check("route code task to coder", routed1 == "coder")

let routed2 = route_task(orch, "search papers about AI")
check("route search task to researcher", routed2 == "researcher")

let routed3 = route_task(orch, "design a new UI mockup")
check("route design task to designer", routed3 == "designer")

// ── 7. route_task_top_n ─────────────────────────────────────────
let top2 = route_task_top_n(orch, "debug and test code", 2)
check("route_top_n returns 2", len(top2) == 2)
check("route_top_n first is coder", top2[0] == "coder")

// ── 8. send_message ─────────────────────────────────────────────
orch = send_message(orch, "coder", "researcher", "please search for X")
let r_msgs = get_messages(orch, "researcher")
check("send_message delivered", len(r_msgs) == 1)
check("send_message content", r_msgs[0]["content"] == "please search for X")
check("send_message from field", r_msgs[0]["from"] == "coder")

// ── 9. broadcast_message ────────────────────────────────────────
orch = broadcast_message(orch, "coder", "meeting in 5 min")
let res_msgs = get_messages(orch, "researcher")
let des_msgs = get_messages(orch, "designer")
check("broadcast to researcher", len(res_msgs) == 2)
check("broadcast to designer", len(des_msgs) == 1)

// ── 10. clear_messages ──────────────────────────────────────────
orch = clear_messages(orch, "researcher")
let cleared = get_messages(orch, "researcher")
check("clear_messages works", len(cleared) == 0)

// ── 11. subscribe + publish ─────────────────────────────────────
orch = subscribe(orch, "coder", "deployments")
orch = subscribe(orch, "designer", "deployments")
orch = publish(orch, "deployments", "v2.0 deployed")
let coder_topics = get_topic_messages(orch, "coder")
let designer_topics = get_topic_messages(orch, "designer")
check("pub/sub coder received", len(coder_topics) == 1)
check("pub/sub designer received", len(designer_topics) == 1)
check("pub/sub topic correct", coder_topics[0]["topic"] == "deployments")
check("pub/sub content correct", coder_topics[0]["content"] == "v2.0 deployed")

// ── 12. consensus — majority vote ───────────────────────────────
let votes1 = ["yes", "no", "yes", "yes", "no"]
let winner1 = consensus(orch, votes1)
check("consensus majority yes", winner1 == "yes")

let votes2 = ["A", "B", "B", "C", "B"]
let winner2 = consensus(orch, votes2)
check("consensus majority B", winner2 == "B")

let votes3 = ["solo"]
let winner3 = consensus(orch, votes3)
check("consensus single vote", winner3 == "solo")

// ── 13. weighted_consensus ──────────────────────────────────────
let w_votes = ["A", "B", "A"]
let w_weights = [1.0, 5.0, 1.0]
let w_winner = weighted_consensus(orch, w_votes, w_weights)
check("weighted consensus B wins", w_winner == "B")

let w_votes2 = ["X", "Y", "X"]
let w_weights2 = [3.0, 1.0, 3.0]
let w_winner2 = weighted_consensus(orch, w_votes2, w_weights2)
check("weighted consensus X wins", w_winner2 == "X")

// ── 14. run_task end-to-end ─────────────────────────────────────
fn mock_executor(agent_name, task) {
    return "done by " + agent_name
}

let result1 = run_task(orch, "fix code bug", mock_executor)
check("run_task routes and executes", result1 == "done by coder")

// ── 15. consensus with multiple identical responses ─────────────
let multi_responses = ["result_42", "result_42", "result_42"]
let cons_result = consensus(orch, multi_responses)
check("consensus all same returns that value", cons_result == "result_42")

// ── Summary ─────────────────────────────────────────────────────
println("")
println("========================================")
println("  multi_agent tests: " + str(pass) + " passed, " + str(fail) + " failed")
println("========================================")
