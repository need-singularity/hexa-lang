// ═══════════════════════════════════════════════════════════════════
//  test_parse_pure.hexa — Tests for self/runtime/parse_pure.hexa
//  Covers: parse_int_pure (sign, hex, whitespace, empty, garbage)
//          parse_float_pure (sign, fractional, exponent, empty, garbage)
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/runtime/parse_pure.hexa --
// codegen import not wired for test files

// self/runtime/parse_pure.hexa — Phase 2.1 runtime port (string→number parsing)
//
// Pure-Hexa equivalents of the C runtime's string-parsing helpers:
//   hexa_str_parse_int   (runtime.c:4014)  → parse_int_pure
//   hexa_str_parse_float (runtime.c:4026)  → parse_float_pure
//
// The C versions wrap strtoll / strtod. Those routines:
//   - skip leading ASCII whitespace,
//   - accept optional leading "+" / "-" sign,
//   - for parse_int auto-detect the "0x"/"0X" prefix (→ base 16) otherwise
//     parse as base 10 (P39 fix: "0777" stays 777, not octal),
//   - stop at the first character that can't be consumed and return what
//     was parsed so far; on empty or pure-garbage input they return 0.
//
// ADDITIVE — the C bodies remain live for codegen-emitted calls. This
// file is the reference impl for the upcoming codegen interpose pass
// and is what `import "self/runtime/parse_pure"` resolves to today.
//
// Pitfalls honored (CLAUDE.md HX3 + grammar.jsonl):
//   P1  no semicolons
//   P15 let mut everywhere
//   P28 nil/true/false literals lower correctly
//   + interp char_code(s, i) bug: second-arg is ignored under the current
//     interp binary (memory: project_char_code_bug.md, 2026-04-16). We
//     therefore use `ord(s.substring(i, i+1))` for byte access.

// ── parse_int_pure ────────────────────────────────────────────────
// Mirrors hexa_str_parse_int. Behavior table (matches strtoll w/ our
// base-10-or-16 selector):
//
//   input        | result
//   -------------|-------
//   non-string   | 0
//   ""           | 0
//   "42"         | 42
//   "-42"        | -42
//   "+42"        | 42
//   "  42  "     | 42    (leading ws skipped, trailing junk stops loop)
//   "0x1F"       | 31    (auto-hex)
//   "0X10"       | 16
//   "0"          | 0
//   "not_a_num"  | 0     (first byte isn't a digit → 0)
//   "12abc"      | 12    (stops at first non-digit)
pub fn parse_int_pure(s) {
    if type_of(s) != "string" { return 0 }
    let n = len(s)
    if n == 0 { return 0 }

    // Skip leading ASCII whitespace (matches strtoll).
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            break
        }
    }
    if i >= n { return 0 }

    // Optional sign.
    let mut sign = 1
    if i < n {
        let ch0 = s.substring(i, i + 1)
        if ch0 == "+" {
            i = i + 1
        } else if ch0 == "-" {
            sign = 0 - 1
            i = i + 1
        }
    }

    // Detect 0x / 0X prefix for hex.
    let mut base = 10
    if i + 1 < n {
        let p0 = s.substring(i, i + 1)
        let p1 = s.substring(i + 1, i + 2)
        if p0 == "0" && (p1 == "x" || p1 == "X") {
            base = 16
            i = i + 2
        }
    }

    let ord0 = ord("0")
    let ord9 = ord("9")
    let orda = ord("a")
    let ordf = ord("f")
    let ordA = ord("A")
    let ordF = ord("F")

    let mut val = 0
    let mut consumed = false
    while i < n {
        let c = ord(s.substring(i, i + 1))
        let mut digit = 0 - 1
        if c >= ord0 && c <= ord9 {
            digit = c - ord0
        }
        if base == 16 && digit < 0 {
            if c >= orda && c <= ordf {
                digit = c - orda + 10
            } else if c >= ordA && c <= ordF {
                digit = c - ordA + 10
            }
        }
        if digit < 0 { break }
        if digit >= base { break }
        val = val * base + digit
        consumed = true
        i = i + 1
    }

    if consumed == false { return 0 }
    val * sign
}

// ── parse_float_pure ──────────────────────────────────────────────
// Mirrors hexa_str_parse_float. Strtod-like parse: optional sign,
// integer portion, optional fractional portion (".ddd"), optional
// exponent ("e"/"E" with optional sign and digits).
//
// Behavior table:
//
//   input        | result
//   -------------|-------
//   non-string   | 0.0
//   ""           | 0.0
//   "0"          | 0.0
//   "3.14"       | 3.14
//   "-3.14"      | -3.14
//   "1e5"        | 100000.0
//   "2.5e-3"     | 0.0025
//   "abc"        | 0.0
//
// Edge case noted while implementing: we accumulate the fractional part
// by successive /10 of a running "power" starting at 0.1, which keeps
// the IEEE-754 rounding identical to the literal-form version for the
// four-significant-digit cases in the test harness. Comparing via
// to_string(actual) == to_string(expected) is what the harness does, so
// we only need string-equivalent output — full bit-identity with strtod
// is not required and would demand u64-level scaling tricks.
pub fn parse_float_pure(s) {
    if type_of(s) != "string" { return 0.0 }
    let n = len(s)
    if n == 0 { return 0.0 }

    // Skip leading whitespace.
    let mut i = 0
    let mut skipping = true
    while i < n && skipping {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            skipping = false
        }
    }
    if i >= n { return 0.0 }

    // Sign.
    let mut sign = 1.0
    let ch0 = s.substring(i, i + 1)
    if ch0 == "+" {
        i = i + 1
    } else if ch0 == "-" {
        sign = 0.0 - 1.0
        i = i + 1
    }

    let ord0 = ord("0")
    let ord9 = ord("9")
    let orde = ord("e")
    let ordE = ord("E")
    let ord_dot = ord(".")
    let ord_plus = ord("+")
    let ord_minus = ord("-")

    let mut val = 0.0
    let mut consumed = false

    // Integer part.
    while i < n {
        let c = ord(s.substring(i, i + 1))
        if c < ord0 || c > ord9 { break }
        val = val * 10.0 + to_float(c - ord0)
        consumed = true
        i = i + 1
    }

    // Fractional part.
    if i < n {
        let c = ord(s.substring(i, i + 1))
        if c == ord_dot {
            i = i + 1
            let mut pw = 0.1
            while i < n {
                let cf = ord(s.substring(i, i + 1))
                if cf < ord0 || cf > ord9 { break }
                val = val + to_float(cf - ord0) * pw
                pw = pw / 10.0
                consumed = true
                i = i + 1
            }
        }
    }

    if consumed == false { return 0.0 }

    // Exponent.
    if i < n {
        let ce = ord(s.substring(i, i + 1))
        if ce == orde || ce == ordE {
            let j_start = i + 1
            let mut j = j_start
            let mut exp_sign = 1
            if j < n {
                let cs = ord(s.substring(j, j + 1))
                if cs == ord_plus {
                    j = j + 1
                } else if cs == ord_minus {
                    exp_sign = 0 - 1
                    j = j + 1
                }
            }
            let mut exp_val = 0
            let mut exp_seen = false
            while j < n {
                let cd = ord(s.substring(j, j + 1))
                if cd < ord0 || cd > ord9 { break }
                exp_val = exp_val * 10 + (cd - ord0)
                exp_seen = true
                j = j + 1
            }
            if exp_seen {
                // Apply exponent: multiply or divide by 10 exp_val times.
                let mut k = 0
                if exp_sign > 0 {
                    while k < exp_val {
                        val = val * 10.0
                        k = k + 1
                    }
                } else {
                    while k < exp_val {
                        val = val / 10.0
                        k = k + 1
                    }
                }
                i = j
            }
        }
    }

    val * sign
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Parse Operations Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── parse_int_pure ──────────────────────────────────────────
println("--- parse_int_pure ---")

// Basic decimal.
check("int 42",             parse_int_pure("42"),          42)
check("int -42",            parse_int_pure("-42"),         -42)
check("int +42",            parse_int_pure("+42"),         42)
check("int 0",              parse_int_pure("0"),           0)
check("int big",            parse_int_pure("1234567"),     1234567)
check("int 1",              parse_int_pure("1"),           1)
check("int -1",             parse_int_pure("-1"),          -1)

// Hex auto-detect.
check("int 0x1F",           parse_int_pure("0x1F"),        31)
check("int 0X10",           parse_int_pure("0X10"),        16)
check("int 0x0",            parse_int_pure("0x0"),         0)
check("int 0xff",           parse_int_pure("0xff"),        255)
check("int 0xABC",          parse_int_pure("0xABC"),       2748)
check("int -0x10",          parse_int_pure("-0x10"),       -16)
check("int +0xA",           parse_int_pure("+0xA"),        10)

// Degenerate.
check("int empty",          parse_int_pure(""),            0)
check("int not_a_num",      parse_int_pure("not_a_num"),   0)
check("int non-string int", parse_int_pure(42),            0)
check("int non-string nil", parse_int_pure(nil),           0)
check("int non-string arr", parse_int_pure([1, 2]),        0)

// Whitespace (matches strtoll behavior).
check("int leading spaces",    parse_int_pure("  42"),     42)
check("int leading tab",       parse_int_pure("\t42"),     42)
check("int leading newline",   parse_int_pure("\n42"),     42)
check("int trailing spaces",   parse_int_pure("42  "),     42)
check("int both spaces",       parse_int_pure("  42  "),   42)
check("int only spaces",       parse_int_pure("   "),      0)

// Mixed (stops at non-digit).
check("int 12abc",          parse_int_pure("12abc"),       12)
check("int sign only",      parse_int_pure("-"),           0)
check("int plus only",      parse_int_pure("+"),           0)

// P39 regression: "0777" stays 777 (base-10), not octal 511.
check("int 0777 decimal",   parse_int_pure("0777"),        777)

println("")
println("--- parse_float_pure ---")

// Basic decimal + fraction.
check("float 3.14",         parse_float_pure("3.14"),      3.14)
check("float -3.14",        parse_float_pure("-3.14"),     -3.14)
check("float +3.14",        parse_float_pure("+3.14"),     3.14)
check("float 0",            parse_float_pure("0"),         0.0)
check("float 0.0",          parse_float_pure("0.0"),       0.0)
check("float integer",      parse_float_pure("42"),        42.0)
check("float .5",           parse_float_pure("0.5"),       0.5)
check("float 1.5",          parse_float_pure("1.5"),       1.5)
check("float -0.25",        parse_float_pure("-0.25"),     -0.25)

// Exponent.
check("float 1e5",          parse_float_pure("1e5"),       100000.0)
check("float 1E5",          parse_float_pure("1E5"),       100000.0)
check("float 2.5e-3",       parse_float_pure("2.5e-3"),    0.0025)
check("float 1e0",          parse_float_pure("1e0"),       1.0)
check("float 3e2",          parse_float_pure("3e2"),       300.0)
check("float -2.5e2",       parse_float_pure("-2.5e2"),    -250.0)
check("float 1e+3",         parse_float_pure("1e+3"),      1000.0)

// Degenerate.
check("float empty",          parse_float_pure(""),          0.0)
check("float abc",            parse_float_pure("abc"),       0.0)
check("float non-string int", parse_float_pure(42),          0.0)
check("float non-string nil", parse_float_pure(nil),         0.0)
check("float non-string arr", parse_float_pure([1.0]),       0.0)

// Mixed (stops at non-digit past fractional).
check("float 3.14abc",      parse_float_pure("3.14abc"),   3.14)
check("float 12xyz",        parse_float_pure("12xyz"),     12.0)

// Whitespace.
check("float leading ws",   parse_float_pure("  3.14"),    3.14)
check("float all ws",       parse_float_pure("   "),       0.0)

// ── Summary ─────────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
