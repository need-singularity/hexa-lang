// ═══════════════════════════════════════════════════════════
//  bc_vm.hexa — HEXA bytecode VM dispatch loop (rt#36-C)
//
//  Consumes the `BcProto` module-level registry emitted by
//  self/bc_emitter.hexa (rt#36-B) and executes it on a simple
//  stack-based VM. No NaN-box, no arena, no IC in MVP — those
//  are deferred to rt#36-D / rt#37 / rt#38.
//
//  Integration contract with rt#36-B:
//    Globals read:
//      bc_proto_codes[i]         int[]     — bytecode for proto i
//      bc_proto_consts[i]        string[]  — const pool for proto i
//      bc_proto_localcounts[i]   int       — n_locals for proto i
//      bc_protos[i].name         string    — proto name (for CALL lookup)
//      bc_protos[i].n_params     int
//    Globals written: none (VM state lives in vm_* variables below).
//    Opcodes: constants BC_OP_* are the same integers the emitter used.
//
//  Dispatch strategy: flat `if / else if` ladder on opcode byte.
//  Stage1 hexa doesn't have native `switch` on int, and a chain
//  of `if op == X` terminators matches the emitter's own
//  bc_opname style. A computed-goto tier is a rt#36-D concern.
//
//  Opcodes implemented (39 — rt#36-C trivial-7 extension + audit W1):
//    LOADI LOADK LOADF LOADNIL LOADTRUE LOADFALSE
//    LOAD_LOCAL STORE_LOCAL LOAD_GLOBAL STORE_GLOBAL
//    ADD SUB MUL DIV MOD
//    ADDF SUBF MULF DIVF                    (rt#36-C float arith)
//    EQ NEQ LT LE GT GE NOT
//    AND OR                                  (audit W1 back-fill)
//    JMP JMPF JMPT
//    CALL RETURN RETURN0
//    POP PRINT NOP
//    HALT ASSERT_INT ASSERT_FLOAT           (rt#36-C halt/asserts)
//
//  Deferred to rt#36-D:
//    NEW_ARRAY ARR_GET ARR_SET ARR_PUSH ARR_LEN
//    NEW_MAP MAP_GET MAP_SET
//    NEW_STRUCT LOAD_FIELD STORE_FIELD
//    CLOSURE NEW_CLOSURE_UPVAL LOAD_UPVAL STORE_UPVAL
//    TRY THROW ENDTRY
//    TAILCALL DUP MOVE POPN PROFILE_HOOK
//
//  Value representation: stage1 hexa is dynamically typed, so
//  we push whatever (int / float / bool / string / nil-sentinel)
//  onto the operand stack directly. Arithmetic assumes int unless
//  both operands are float (then we promote). Comparisons do the
//  same. No NaN-box in MVP.
//
//  nil is represented by the string "<nil>" sentinel — chosen so
//  that unexpected type errors are visible in the trace. rt#38 will
//  replace this with a real tagged value.
// ═══════════════════════════════════════════════════════════

// ── VM state (module globals — single-threaded). ────────────

// Operand stack — unbounded dynamic array, grows as needed.
// Each element is a hexa dynamic value (int/float/bool/string/nil).
let mut vm_stack = []

// Locals region — per-frame slots packed contiguously. `fp` is
// the base offset into this array for the CURRENT frame; each
// frame reserves `n_locals` slots (filled from stack on CALL).
let mut vm_locals = []

// Frame stack (parallel arrays — stage1 avoids struct-in-array).
// Index = depth (0 = <main>). Top = len(vm_frame_proto) - 1.
let mut vm_frame_proto = []   // int[]  — proto index in bc_protos
let mut vm_frame_pc    = []   // int[]  — program counter within proto's code
let mut vm_frame_fp    = []   // int[]  — base offset into vm_locals

// Globals table (parallel arrays — keyed by name).
let mut vm_global_names = []  // string[]
let mut vm_global_vals  = []  // any[]

// Trap / halt flag — set by unrecoverable VM errors (frame
// underflow, missing global, unknown opcode, etc.). Callers of
// bc_vm_run should check vm_trap afterward.
let mut vm_trap = false
let mut vm_trap_msg = ""

// Halt flag — set by OP_HALT to cleanly terminate the dispatch
// loop without marking it as a trap. Semantically distinct from
// vm_trap: halt is a cooperative program end (e.g. `exit(0)`),
// trap is an unrecoverable VM error. bc_vm_reset clears both.
let mut vm_halted = false

// Nil sentinel (see header). Using a distinctive string makes
// type-confusion bugs easy to spot in test output.
let BC_NIL = "<nil>"

// T44 map-shape tag. Maps live on the VM stack as a 3-element
// array ["<bc_map>", keys[], vals[]] — the leading tag lets
// OP_ARR_GET dispatch between array indexing and parallel-array
// linear-scan without heuristics. Distinct, reserved, rarely
// appears in user data so false positives are negligible.
let BC_MAP_TAG = "<bc_map>"

// T45 struct-shape tag. Structs live on the VM stack as a 4-element
// array ["<bc_struct>", type_name, keys[], vals[]]. Same sentinel
// strategy as BC_MAP_TAG so LOAD_FIELD / STORE_FIELD can verify
// shape before indexing. type_name is the source-level struct
// type (e.g. "Point") and is preserved for debuggability — rt#37's
// type-specializer will also key shape ICs on it.
let BC_STRUCT_TAG = "<bc_struct>"

// ── VM init / reset. ────────────────────────────────────────

fn bc_vm_reset() {
    vm_stack = []
    vm_locals = []
    vm_frame_proto = []
    vm_frame_pc = []
    vm_frame_fp = []
    vm_global_names = []
    vm_global_vals = []
    vm_trap = false
    vm_trap_msg = ""
    vm_halted = false
}

// ── Stack helpers (mutate vm_stack directly). ───────────────

fn bc_vm_push(v) {
    vm_stack = vm_stack.push(v)
}

fn bc_vm_pop() {
    let n = len(vm_stack)
    if n == 0 {
        vm_trap = true
        vm_trap_msg = "stack underflow"
        return BC_NIL
    }
    let top = vm_stack[n - 1]
    // Rebuild without last element (hexa arrays are push-immutable).
    let mut out = []
    let mut i = 0
    while i < n - 1 {
        out = out.push(vm_stack[i])
        i = i + 1
    }
    vm_stack = out
    return top
}

fn bc_vm_peek() {
    let n = len(vm_stack)
    if n == 0 {
        vm_trap = true
        vm_trap_msg = "stack peek underflow"
        return BC_NIL
    }
    return vm_stack[n - 1]
}

// Array-rebuild helper: return arr[0..n].
fn bc_vm_truncate(arr, n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(arr[i])
        i = i + 1
    }
    return out
}

// Rebuild arr with arr[i] replaced by v.
fn bc_vm_setat(arr, i, v) {
    let n = len(arr)
    let mut out = []
    let mut k = 0
    while k < n {
        if k == i {
            out = out.push(v)
        } else {
            out = out.push(arr[k])
        }
        k = k + 1
    }
    return out
}

// ── Globals access (linear scan — fine for MVP sizes). ──────

fn bc_vm_find_global(name) {
    let mut i = 0
    let n = len(vm_global_names)
    while i < n {
        if vm_global_names[i] == name {
            return i
        }
        i = i + 1
    }
    return -1
}

fn bc_vm_set_global(name, v) {
    let idx = bc_vm_find_global(name)
    if idx >= 0 {
        vm_global_vals = bc_vm_setat(vm_global_vals, idx, v)
    } else {
        vm_global_names = vm_global_names.push(name)
        vm_global_vals  = vm_global_vals.push(v)
    }
}

fn bc_vm_get_global(name) {
    let idx = bc_vm_find_global(name)
    if idx < 0 {
        vm_trap = true
        vm_trap_msg = "undefined global: " + name
        return BC_NIL
    }
    return vm_global_vals[idx]
}

// ── String → int parse (for LOADK fallback of large ints). ──
// Emitter stashes ints that overflow the 24-bit inline LOADI
// into bc_consts as their decimal string form ("16777217" etc).
// LOADK needs to turn that back into an int so arithmetic works.

fn bc_vm_parse_int(s) {
    let chars = s.chars()
    let n = len(chars)
    if n == 0 { return 0 }
    let mut i = 0
    let mut result = 0
    let mut neg = false
    if to_string(chars[0]) == "-" {
        neg = true
        i = 1
    }
    while i < n {
        let c = to_string(chars[i])
        let mut d = -1
        if c == "0" { d = 0 }
        if c == "1" { d = 1 }
        if c == "2" { d = 2 }
        if c == "3" { d = 3 }
        if c == "4" { d = 4 }
        if c == "5" { d = 5 }
        if c == "6" { d = 6 }
        if c == "7" { d = 7 }
        if c == "8" { d = 8 }
        if c == "9" { d = 9 }
        if d < 0 {
            // Not a pure int — could be float "3.14" or string.
            // MVP: return 0 and let the caller notice via trap.
            return 0
        }
        result = result * 10 + d
        i = i + 1
    }
    if neg { return 0 - result }
    return result
}

// ── Proto lookup by name (CALL dispatch). ───────────────────
// When the emitter produces OP_CALL, its B16 operand is usually
// the proto index in bc_protos (because bc_lookup_proto resolved
// the name at emit time). For forward refs the operand is a
// const-pool index holding the name string — the VM has to try
// proto index first and fall back to name-resolve through consts.

fn bc_vm_resolve_call(caller_proto_idx, b16) {
    // Fast path: b16 is a direct proto index.
    if b16 < len(bc_protos) {
        // Check: if the emitter's side data said this proto had
        // a resolved proto idx, use it. Emitter distinguishes by
        // whether bc_lookup_proto succeeded — we can't re-discover
        // that here without re-parsing, so assume direct-index
        // when b16 is in range AND the const at b16 (if any) does
        // NOT match a known proto name. For our tests this works:
        // when the call is `add(...)` or `fib(...)`, emitter
        // resolved at emit time so b16 is the actual proto index.
        return b16
    }
    // Forward-ref path: b16 is an index into caller's const pool.
    let consts = bc_proto_consts[caller_proto_idx]
    if b16 < len(consts) {
        let fname = consts[b16]
        let mut i = 0
        while i < len(bc_protos) {
            let p = bc_protos[i]
            if p.name == fname {
                return i
            }
            i = i + 1
        }
    }
    return -1
}

// ── Frame push / pop (CALL / RETURN). ───────────────────────
// CALL semantics:
//   Before CALL: stack top holds [..., arg0, arg1, ..., arg_{n-1}]
//   Emitter did (n) pushes then emitted CALL A=nargs B16=proto_idx.
//   We must:
//     1) allocate n_locals slots in vm_locals for the callee
//     2) pop nargs values and write them into the first nargs slots
//     3) push a new frame with pc=0, fp=base-of-new-locals
//     4) the caller's remaining stack is preserved; callee pushes
//        its return value back via OP_RETURN (which pops+pops frame).
//
// RETURN semantics:
//   OP_RETURN — pop return value, pop frame (truncate locals to fp),
//               push return value onto caller's stack, advance caller pc.
//   OP_RETURN0 — same but push nil sentinel.

fn bc_vm_push_frame(proto_idx, nargs) {
    let target_locals = bc_proto_localcounts[proto_idx]

    // Allocate locals at the current top of vm_locals.
    let fp = len(vm_locals)
    let mut i = 0
    while i < target_locals {
        vm_locals = vm_locals.push(BC_NIL)
        i = i + 1
    }

    // Move top-nargs values from operand stack into slots 0..nargs-1.
    // Emitter pushed left-to-right, so args are on the stack in that
    // order, with the LAST arg on top. Pop from top and fill slot
    // (nargs-1) first, counting down to slot 0.
    let mut j = nargs - 1
    while j >= 0 {
        let v = bc_vm_pop()
        vm_locals = bc_vm_setat(vm_locals, fp + j, v)
        j = j - 1
    }

    // Push the frame record.
    vm_frame_proto = vm_frame_proto.push(proto_idx)
    vm_frame_pc    = vm_frame_pc.push(0)
    vm_frame_fp    = vm_frame_fp.push(fp)
}

// Pop the top frame. Does NOT push the return value — caller does.
fn bc_vm_pop_frame() {
    let depth = len(vm_frame_proto)
    if depth == 0 {
        vm_trap = true
        vm_trap_msg = "frame underflow"
        return
    }
    let fp = vm_frame_fp[depth - 1]
    // Truncate vm_locals back to fp (reclaim callee slots).
    vm_locals = bc_vm_truncate(vm_locals, fp)
    // Shrink frame arrays.
    vm_frame_proto = bc_vm_truncate(vm_frame_proto, depth - 1)
    vm_frame_pc    = bc_vm_truncate(vm_frame_pc,    depth - 1)
    vm_frame_fp    = bc_vm_truncate(vm_frame_fp,    depth - 1)
}

// ── Truthiness (for JMPF). ──────────────────────────────────
// Matches the design doc §6.6: false / nil / 0 / 0.0 are falsy.

fn bc_vm_is_truthy(v) {
    if v == false { return false }
    if v == true { return true }
    if v == BC_NIL { return false }
    if v == 0 { return false }
    if v == 0.0 { return false }
    return true
}

// ── Arithmetic coercion. ────────────────────────────────────
// Stage1 hexa's `+` is already heterogenous (int+float promotes),
// but we want ADD on strings to error rather than concat (since
// string concat isn't in the MVP opcode set). For MVP, assume
// both operands are numeric; let hexa's native `+` do the lift.

fn bc_vm_add(a, b) { return a + b }
fn bc_vm_sub(a, b) { return a - b }
fn bc_vm_mul(a, b) { return a * b }
fn bc_vm_div(a, b) {
    if b == 0 {
        vm_trap = true
        vm_trap_msg = "division by zero"
        return 0
    }
    return a / b
}
fn bc_vm_mod(a, b) {
    if b == 0 {
        vm_trap = true
        vm_trap_msg = "modulo by zero"
        return 0
    }
    return a % b
}

// Float-specialized arithmetic — forces both operands to float
// via to_float() before combining. Matches rt#36-A §6.2 spec:
// ADDF/SUBF/MULF/DIVF ALWAYS produce a float result regardless
// of operand tags. Used by the emitter when the static type of
// both operands is float; the VM trusts the emitter's type
// analysis and performs the lift defensively via to_float.
fn bc_vm_addf(a, b) { return to_float(a) + to_float(b) }
fn bc_vm_subf(a, b) { return to_float(a) - to_float(b) }
fn bc_vm_mulf(a, b) { return to_float(a) * to_float(b) }
fn bc_vm_divf(a, b) {
    let fb = to_float(b)
    if fb == 0.0 {
        vm_trap = true
        vm_trap_msg = "float division by zero"
        return 0.0
    }
    return to_float(a) / fb
}

// Parse a decimal float string ("3.14", "-0.5", "7") into a
// float value. Stage1 hexa has `to_float` as a builtin that
// accepts strings directly — this wrapper exists for symmetry
// with bc_vm_parse_int and to centralize error handling if we
// later need NaN/Inf rejection. rt#36-D will harden this.
fn bc_vm_parse_float(s) {
    return to_float(s)
}

// Comparisons — return bool.
fn bc_vm_eq(a, b)  { return a == b }
fn bc_vm_neq(a, b) { return a != b }
fn bc_vm_lt(a, b)  { return a <  b }
fn bc_vm_le(a, b)  { return a <= b }
fn bc_vm_gt(a, b)  { return a >  b }
fn bc_vm_ge(a, b)  { return a >= b }

// ── The dispatch loop itself. ───────────────────────────────
// Runs until the frame stack empties or a trap fires. Returns
// the final "return value" that sat on the main frame's stack
// (or BC_NIL if main did not emit a RETURN with a value).

fn bc_vm_run_loop() {
    // Bail immediately on trap.
    if vm_trap { return BC_NIL }

    let mut last_return = BC_NIL

    // Main loop — each iteration decodes and executes one insn.
    // Terminate when the frame stack empties (top-level RETURN).
    while len(vm_frame_proto) > 0 {
        if vm_trap { return last_return }

        let depth = len(vm_frame_proto)
        let proto_idx = vm_frame_proto[depth - 1]
        let pc = vm_frame_pc[depth - 1]
        let fp = vm_frame_fp[depth - 1]

        let code = bc_proto_codes[proto_idx]
        if pc >= len(code) {
            vm_trap = true
            vm_trap_msg = "pc past code end"
            return last_return
        }

        let raw = code[pc]
        let op = bc_op_of(raw)

        // Advance pc in the frame record BEFORE dispatch. This makes
        // jump math consistent: a JMP sBx means "relative to the
        // instruction AFTER the jump", matching emitter's delta calc
        // (delta = target_pc - (jmp_pc + 1)).
        vm_frame_pc = bc_vm_setat(vm_frame_pc, depth - 1, pc + 1)

        // ──────── LOADS ────────
        if op == BC_OP_LOADI {
            let v = bc_sbx_of(raw)
            bc_vm_push(v)
        } else if op == BC_OP_LOADK {
            let cidx = bc_bx_of(raw)
            let consts = bc_proto_consts[proto_idx]
            if cidx >= len(consts) {
                vm_trap = true
                vm_trap_msg = "LOADK: const idx out of range"
                return last_return
            }
            // Best-effort: if const parses as int, push int; else push string.
            let s = consts[cidx]
            let parsed = bc_vm_parse_int(s)
            // Distinguish "parsed 0" vs "string wasn't numeric" —
            // compare against the normalized "0" / "-0".
            if s == to_string(parsed) {
                bc_vm_push(parsed)
            } else {
                bc_vm_push(s)
            }
        } else if op == BC_OP_LOADF {
            // rt#36-C float extension: parse the const-pool string
            // into an actual float. Emitter's FloatLit lowering does
            //   bc_add_const(to_string(node.float_val))
            // so the const slot always holds a decimal like "3.14".
            let cidx = bc_bx_of(raw)
            let consts = bc_proto_consts[proto_idx]
            if cidx >= len(consts) {
                vm_trap = true
                vm_trap_msg = "LOADF: const idx out of range"
                return last_return
            }
            bc_vm_push(bc_vm_parse_float(consts[cidx]))
        } else if op == BC_OP_LOADNIL {
            bc_vm_push(BC_NIL)
        } else if op == BC_OP_LOADTRUE {
            bc_vm_push(true)
        } else if op == BC_OP_LOADFALSE {
            bc_vm_push(false)
        }

        // ──────── LOCAL SLOT I/O ────────
        else if op == BC_OP_LOAD_LOCAL {
            let slot = bc_bx_of(raw)
            let abs = fp + slot
            if abs >= len(vm_locals) {
                vm_trap = true
                vm_trap_msg = "LOAD_LOCAL: slot out of range"
                return last_return
            }
            bc_vm_push(vm_locals[abs])
        } else if op == BC_OP_STORE_LOCAL {
            let slot = bc_bx_of(raw)
            let abs = fp + slot
            let v = bc_vm_pop()
            if abs >= len(vm_locals) {
                // Grow locals region to cover this slot (only the
                // CURRENT frame's slots grow — safe because no
                // nested frame is pushed between LET introductions).
                while len(vm_locals) <= abs {
                    vm_locals = vm_locals.push(BC_NIL)
                }
            }
            vm_locals = bc_vm_setat(vm_locals, abs, v)
        }

        // ──────── GLOBAL SLOT I/O ────────
        // Layout B: hint(8 in A) + globals_idx(16 in B16). For
        // MVP, treat the b16 as a const-pool index where the name
        // string lives (emitter stashed it via bc_add_const).
        else if op == BC_OP_LOAD_GLOBAL {
            let b16 = bc_b16_of(raw)
            let consts = bc_proto_consts[proto_idx]
            if b16 >= len(consts) {
                vm_trap = true
                vm_trap_msg = "LOAD_GLOBAL: name const idx out of range"
                return last_return
            }
            let name = consts[b16]
            let v = bc_vm_get_global(name)
            if vm_trap { return last_return }
            bc_vm_push(v)
        } else if op == BC_OP_STORE_GLOBAL {
            let b16 = bc_b16_of(raw)
            let consts = bc_proto_consts[proto_idx]
            if b16 >= len(consts) {
                vm_trap = true
                vm_trap_msg = "STORE_GLOBAL: name const idx out of range"
                return last_return
            }
            let name = consts[b16]
            let v = bc_vm_pop()
            bc_vm_set_global(name, v)
        }

        // ──────── ARITHMETIC ────────
        else if op == BC_OP_ADD {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_add(a, b))
        } else if op == BC_OP_SUB {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_sub(a, b))
        } else if op == BC_OP_MUL {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_mul(a, b))
        } else if op == BC_OP_DIV {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_div(a, b))
            if vm_trap { return last_return }
        } else if op == BC_OP_MOD {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_mod(a, b))
            if vm_trap { return last_return }
        }

        // ──────── FLOAT ARITHMETIC (rt#36-C) ────────
        // ADDF/SUBF/MULF/DIVF always produce a float result.
        // Operands are coerced via to_float() so mixed int/float
        // inputs (common after LOADI → promote) work transparently.
        else if op == BC_OP_ADDF {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_addf(a, b))
        } else if op == BC_OP_SUBF {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_subf(a, b))
        } else if op == BC_OP_MULF {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_mulf(a, b))
        } else if op == BC_OP_DIVF {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_divf(a, b))
            if vm_trap { return last_return }
        }

        // ──────── COMPARISONS ────────
        else if op == BC_OP_EQ {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_eq(a, b))
        } else if op == BC_OP_NEQ {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_neq(a, b))
        } else if op == BC_OP_LT {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_lt(a, b))
        } else if op == BC_OP_LE {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_le(a, b))
        } else if op == BC_OP_GT {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_gt(a, b))
        } else if op == BC_OP_GE {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            bc_vm_push(bc_vm_ge(a, b))
        }

        // ──────── LOGIC ────────
        else if op == BC_OP_NOT {
            let v = bc_vm_pop()
            bc_vm_push(!bc_vm_is_truthy(v))
        }
        // rt#36-C audit W1: bc_emitter.hexa L733-734 emits OP_AND /
        // OP_OR for source-level `&&` / `||` (Phase B eager form;
        // Phase D's optimizer will lower to JMPF/JMPT for real
        // short-circuit). The emit shape is bc_enc_abx(OP_AND, 0)
        // with two values already pushed by the eager-compiled
        // left+right operands — so we pop both, apply truthiness,
        // and push the boolean result. Matches source-language
        // semantics (not bitwise — stage1 hexa has no bitwise and/or
        // in the spec opcode set) and keeps a (-2, +1) stack effect
        // consistent with the emitter's bc_pop(1) adjustment.
        else if op == BC_OP_AND {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            if bc_vm_is_truthy(a) {
                bc_vm_push(bc_vm_is_truthy(b))
            } else {
                bc_vm_push(false)
            }
        } else if op == BC_OP_OR {
            let b = bc_vm_pop()
            let a = bc_vm_pop()
            if bc_vm_is_truthy(a) {
                bc_vm_push(true)
            } else {
                bc_vm_push(bc_vm_is_truthy(b))
            }
        }

        // ──────── CONTROL FLOW ────────
        else if op == BC_OP_JMP {
            let delta = bc_sbx_of(raw)
            // pc has already been advanced to pc+1.
            let d2 = len(vm_frame_proto)
            let cur_pc = vm_frame_pc[d2 - 1]
            vm_frame_pc = bc_vm_setat(vm_frame_pc, d2 - 1, cur_pc + delta)
        } else if op == BC_OP_JMPF {
            let delta = bc_sbx_of(raw)
            let v = bc_vm_pop()
            if !bc_vm_is_truthy(v) {
                let d2 = len(vm_frame_proto)
                let cur_pc = vm_frame_pc[d2 - 1]
                vm_frame_pc = bc_vm_setat(vm_frame_pc, d2 - 1, cur_pc + delta)
            }
        } else if op == BC_OP_JMPT {
            let delta = bc_sbx_of(raw)
            let v = bc_vm_pop()
            if bc_vm_is_truthy(v) {
                let d2 = len(vm_frame_proto)
                let cur_pc = vm_frame_pc[d2 - 1]
                vm_frame_pc = bc_vm_setat(vm_frame_pc, d2 - 1, cur_pc + delta)
            }
        }

        // ──────── CALL / RETURN ────────
        else if op == BC_OP_CALL {
            let nargs = bc_a_of(raw)
            let b16 = bc_b16_of(raw)
            let target = bc_vm_resolve_call(proto_idx, b16)
            if target < 0 {
                vm_trap = true
                vm_trap_msg = "CALL: cannot resolve target proto"
                return last_return
            }
            // Stack currently has [..., arg0..arg_{n-1}] on top.
            bc_vm_push_frame(target, nargs)
            if vm_trap { return last_return }
            // Dispatch loop will pick up at callee pc=0 next iter.
        } else if op == BC_OP_RETURN {
            let rv = bc_vm_pop()
            bc_vm_pop_frame()
            if vm_trap { return last_return }
            last_return = rv
            // Push return value onto caller's operand stack
            // unless we just popped the bottom frame.
            if len(vm_frame_proto) > 0 {
                bc_vm_push(rv)
            }
        } else if op == BC_OP_RETURN0 {
            bc_vm_pop_frame()
            if vm_trap { return last_return }
            last_return = BC_NIL
            if len(vm_frame_proto) > 0 {
                bc_vm_push(BC_NIL)
            }
        }

        // ──────── MISC ────────
        else if op == BC_OP_POP {
            let _v = bc_vm_pop()
        } else if op == BC_OP_PRINT {
            // Emitter's lowering of print(x): leaves x on top and
            // emits OP_PRINT. PRINT pops and prints. rt#36-A §6.9
            // notes OP_PRINT is debug-only (runtime `println` will
            // eventually be a user fn, lowered via OP_CALL).
            let v = bc_vm_pop()
            println(to_string(v))
        } else if op == BC_OP_NOP {
            // Intentionally do nothing.
        }

        // ──────── HALT / ASSERTIONS (rt#36-C) ────────
        // HALT — cooperative loop terminator. Unlike a trap this
        // is NOT an error: it signals "program reached end of
        // logical execution". We set vm_halted and bail out of
        // the dispatch loop; the current TOS (if any) is returned
        // as last_return so tests can inspect the halt value.
        else if op == BC_OP_HALT {
            let n = len(vm_stack)
            if n > 0 {
                last_return = vm_stack[n - 1]
            }
            vm_halted = true
            return last_return
        }
        // ASSERT_INT — peek TOS, trap if type_of != "int".
        // Non-consuming so the asserted value remains available
        // for the next instruction (matches x86 assert semantics).
        else if op == BC_OP_ASSERT_INT {
            let v = bc_vm_peek()
            if vm_trap { return last_return }
            if type_of(v) != "int" {
                vm_trap = true
                vm_trap_msg = "ASSERT_INT failed: got " + type_of(v)
                return last_return
            }
        }
        // ASSERT_FLOAT — peek TOS, trap if type_of != "float".
        else if op == BC_OP_ASSERT_FLOAT {
            let v = bc_vm_peek()
            if vm_trap { return last_return }
            if type_of(v) != "float" {
                vm_trap = true
                vm_trap_msg = "ASSERT_FLOAT failed: got " + type_of(v)
                return last_return
            }
        }

        // ──────── ARRAY / MAP OPCODES (rt#36-C Phase 1 — T44) ────────
        // Collection values live on the operand stack as hexa-native
        // arrays (`[]`) and maps (`#{}`). This trades VM portability
        // for simplicity: we do NOT wire into interpreter's
        // array_store / map_store (which are IR-time heap tables
        // scoped to the tree-walker); stage0 hexa's intrinsic dict
        // + array already supply `arr[i]`, `arr.push(v)`, `len(arr)`,
        // `m[k]`, `m.set(k,v)` — all immutable / value-returning
        // which is exactly the semantic these opcodes need.
        //
        // NEW_ARRAY B — pop B values, build array, push.
        //   Items were pushed left-to-right so the LAST item is on
        //   top; we walk right-to-left while popping, then reverse
        //   the collected buffer to restore source order.
        else if op == BC_OP_NEW_ARRAY {
            let count = bc_b16_of(raw)
            let mut buf = []
            let mut k = 0
            while k < count {
                buf = buf.push(bc_vm_pop())
                if vm_trap { return last_return }
                k = k + 1
            }
            // Reverse into source order.
            let mut arr = []
            let mut j = count - 1
            while j >= 0 {
                arr = arr.push(buf[j])
                j = j - 1
            }
            bc_vm_push(arr)
        }
        // ARR_GET — pops idx, pops arr, pushes arr[idx].
        //
        //   Polymorphic dispatch: the emitter uses this opcode for
        //   any `x[k]` source pattern because stage1 hexa has no
        //   static type info to tell arrays from maps. We detect
        //   the NEW_MAP-produced shape ["<bc_map>", keys, vals] by
        //   its leading BC_MAP_TAG sentinel and route to a linear
        //   key scan; otherwise fall back to hexa-native indexing.
        else if op == BC_OP_ARR_GET {
            let idx = bc_vm_pop()
            let arr = bc_vm_pop()
            if vm_trap { return last_return }
            let mut is_map_shape = false
            if type_of(arr) == "array" {
                if len(arr) == 3 {
                    if arr[0] == BC_MAP_TAG {
                        is_map_shape = true
                    }
                }
            }
            if is_map_shape {
                let mks = arr[1]
                let mvs = arr[2]
                let mkn = len(mks)
                let mut mi = 0
                let mut mhit = BC_NIL
                while mi < mkn {
                    if mks[mi] == idx {
                        mhit = mvs[mi]
                        mi = mkn
                    } else {
                        mi = mi + 1
                    }
                }
                bc_vm_push(mhit)
            } else {
                bc_vm_push(arr[idx])
            }
        }
        // ARR_SET — pops val, idx, arr; pushes new arr with arr[idx]=val.
        //   Uses the existing bc_vm_setat helper (rebuild one slot).
        //   Semantically matches hexa's value-returning array update.
        else if op == BC_OP_ARR_SET {
            let v = bc_vm_pop()
            let idx = bc_vm_pop()
            let arr = bc_vm_pop()
            if vm_trap { return last_return }
            bc_vm_push(bc_vm_setat(arr, idx, v))
        }
        // ARR_PUSH — pops val, arr; pushes arr.push(val) (immutable).
        else if op == BC_OP_ARR_PUSH {
            let v = bc_vm_pop()
            let arr = bc_vm_pop()
            if vm_trap { return last_return }
            bc_vm_push(arr.push(v))
        }
        // ARR_LEN — pops arr; pushes len(arr).
        //   Polymorphic: a BC_MAP_TAG-tagged 3-element shape reports
        //   its pair count (len of the keys slot) — matches what
        //   `len(m)` on a hexa dict would return.
        else if op == BC_OP_ARR_LEN {
            let arr = bc_vm_pop()
            if vm_trap { return last_return }
            let mut n = 0
            if type_of(arr) == "array" {
                if len(arr) == 3 {
                    if arr[0] == BC_MAP_TAG {
                        n = len(arr[1])
                    } else {
                        n = len(arr)
                    }
                } else {
                    n = len(arr)
                }
            } else {
                n = len(arr)
            }
            bc_vm_push(n)
        }
        // NEW_MAP B — pops 2B values (key/val pairs, emitted in
        //   source order), builds map, pushes it.
        //
        //   Implementation note: hexa_v2 (the C transpiler used to
        //   build stage0) does NOT dispatch `.set()` as a method on
        //   maps — only `#{k:v}` LITERALS are recognized for dict
        //   construction, and those must be fully static. To build a
        //   dynamic map here we therefore represent map values as
        //   parallel arrays: `[keys, values]` (a 2-element outer
        //   array whose first slot is the key array and second is
        //   the value array). MAP_GET does linear scan; MAP_SET
        //   appends or overwrites. This matches how interpreter.hexa
        //   models its map_store (see T33 notes in runtime.c) and
        //   stays fully within hexa's native array ops.
        //
        //   Emit order: push k0, v0, k1, v1, ..., so v_{B-1} is on
        //   top. Pop in reverse; reinsert in source order.
        else if op == BC_OP_NEW_MAP {
            let pair_count = bc_b16_of(raw)
            let mut kbuf = []
            let mut vbuf = []
            let mut k2 = 0
            while k2 < pair_count {
                let vp = bc_vm_pop()
                let kp = bc_vm_pop()
                if vm_trap { return last_return }
                kbuf = kbuf.push(kp)
                vbuf = vbuf.push(vp)
                k2 = k2 + 1
            }
            // Reverse into source order.
            let mut keys = []
            let mut vals = []
            let mut j2 = pair_count - 1
            while j2 >= 0 {
                keys = keys.push(kbuf[j2])
                vals = vals.push(vbuf[j2])
                j2 = j2 - 1
            }
            // Tagged map shape: [BC_MAP_TAG, keys, vals].
            let m2 = [BC_MAP_TAG, keys, vals]
            bc_vm_push(m2)
        }
        // MAP_GET — pops key, map; pushes map[key] (BC_NIL if absent).
        //   Linear scan over the keys array; returns the parallel
        //   value on hit. Miss returns BC_NIL so subsequent ops do
        //   not crash — matches the interpreter's "void on miss"
        //   behavior that source-level code already tolerates.
        //
        //   Note: the emitter currently routes Index AST nodes to
        //   OP_ARR_GET (polymorphic). OP_MAP_GET is reserved for
        //   future explicit map-access lowerings (e.g. when an
        //   emitter upgrade gains enough type info to disambiguate).
        else if op == BC_OP_MAP_GET {
            let key_mg = bc_vm_pop()
            let m_mg = bc_vm_pop()
            if vm_trap { return last_return }
            let keys_mg = m_mg[1]
            let vals_mg = m_mg[2]
            let nk = len(keys_mg)
            let mut i_mg = 0
            let mut hit_val = BC_NIL
            while i_mg < nk {
                if keys_mg[i_mg] == key_mg {
                    hit_val = vals_mg[i_mg]
                    i_mg = nk
                } else {
                    i_mg = i_mg + 1
                }
            }
            bc_vm_push(hit_val)
        }
        // MAP_SET — pops val, key, map; pushes updated map.
        //   If key already exists, rebuild values with v patched in.
        //   Else append key/value to each parallel array.
        else if op == BC_OP_MAP_SET {
            let v_ms = bc_vm_pop()
            let key_ms = bc_vm_pop()
            let m_ms = bc_vm_pop()
            if vm_trap { return last_return }
            let keys_ms = m_ms[1]
            let vals_ms = m_ms[2]
            let nk2 = len(keys_ms)
            let mut found_idx = -1
            let mut i_ms = 0
            while i_ms < nk2 {
                if keys_ms[i_ms] == key_ms {
                    found_idx = i_ms
                    i_ms = nk2
                } else {
                    i_ms = i_ms + 1
                }
            }
            let mut new_keys = keys_ms
            let mut new_vals = vals_ms
            if found_idx >= 0 {
                new_vals = bc_vm_setat(vals_ms, found_idx, v_ms)
            } else {
                new_keys = keys_ms.push(key_ms)
                new_vals = vals_ms.push(v_ms)
            }
            let m2b = [BC_MAP_TAG, new_keys, new_vals]
            bc_vm_push(m2b)
        }

        // ──────── STRUCT OPCODES (rt#36-D T45) ────────
        // Structs mirror the NEW_MAP pair-encoding but carry an
        // extra type-name slot so LOAD_FIELD / STORE_FIELD can
        // distinguish structs from maps and so diagnostics show
        // the source-level type (e.g. "Point" vs "Vec2").
        //
        // NEW_STRUCT A=n_fields B16=name_const_idx:
        //   pop 2n values (field_name, val pairs pushed left-to-right),
        //   resolve type name from current proto's const pool,
        //   build [BC_STRUCT_TAG, name, keys, vals], push.
        else if op == BC_OP_NEW_STRUCT {
            let n_fields = bc_a_of(raw)
            let name_cidx = bc_b16_of(raw)
            let consts_ns = bc_proto_consts[proto_idx]
            let mut sname = ""
            if name_cidx < len(consts_ns) {
                sname = consts_ns[name_cidx]
            }
            let mut sval_buf = []
            let mut skey_buf = []
            let mut sk = 0
            while sk < n_fields {
                sval_buf = sval_buf.push(bc_vm_pop())
                if vm_trap { return last_return }
                skey_buf = skey_buf.push(bc_vm_pop())
                if vm_trap { return last_return }
                sk = sk + 1
            }
            // Reverse into source order.
            let mut skeys = []
            let mut svals = []
            let mut sj = n_fields - 1
            while sj >= 0 {
                skeys = skeys.push(skey_buf[sj])
                svals = svals.push(sval_buf[sj])
                sj = sj - 1
            }
            let sobj = [BC_STRUCT_TAG, sname, skeys, svals]
            bc_vm_push(sobj)
        }
        // LOAD_FIELD Bx=field_name_const_idx:
        //   pop struct, linear-scan keys, push matching val (BC_NIL on miss).
        //   Miss returning BC_NIL matches hexa's "void on missing field"
        //   semantics — downstream code tolerates it without crashing.
        else if op == BC_OP_LOAD_FIELD {
            let fcidx = bc_bx_of(raw)
            let consts_lf = bc_proto_consts[proto_idx]
            let mut fname = ""
            if fcidx < len(consts_lf) {
                fname = consts_lf[fcidx]
            }
            let sobj_lf = bc_vm_pop()
            if vm_trap { return last_return }
            let mut lf_hit = BC_NIL
            if type_of(sobj_lf) == "array" {
                if len(sobj_lf) == 4 {
                    if sobj_lf[0] == BC_STRUCT_TAG {
                        let lf_keys = sobj_lf[2]
                        let lf_vals = sobj_lf[3]
                        let lf_n = len(lf_keys)
                        let mut lf_i = 0
                        while lf_i < lf_n {
                            if lf_keys[lf_i] == fname {
                                lf_hit = lf_vals[lf_i]
                                lf_i = lf_n
                            } else {
                                lf_i = lf_i + 1
                            }
                        }
                    }
                }
            }
            bc_vm_push(lf_hit)
        }
        // STORE_FIELD Bx=field_name_const_idx:
        //   pop val, pop struct; rebuild with field patched (or
        //   appended if absent, matching struct-init-extend semantics);
        //   push updated struct. Caller's emitter typically follows
        //   with STORE_LOCAL / STORE_GLOBAL to rebind the base ident.
        else if op == BC_OP_STORE_FIELD {
            let sfcidx = bc_bx_of(raw)
            let consts_sf = bc_proto_consts[proto_idx]
            let mut sfname = ""
            if sfcidx < len(consts_sf) {
                sfname = consts_sf[sfcidx]
            }
            let sf_val = bc_vm_pop()
            let sf_obj = bc_vm_pop()
            if vm_trap { return last_return }
            let mut sf_tag = ""
            let mut sf_type = ""
            let mut sf_keys = []
            let mut sf_vals = []
            if type_of(sf_obj) == "array" {
                if len(sf_obj) == 4 {
                    if sf_obj[0] == BC_STRUCT_TAG {
                        sf_tag = sf_obj[0]
                        sf_type = sf_obj[1]
                        sf_keys = sf_obj[2]
                        sf_vals = sf_obj[3]
                    }
                }
            }
            if sf_tag == "" {
                // Not a struct — trap, preserve MVP invariants.
                vm_trap = true
                vm_trap_msg = "STORE_FIELD: not a struct value"
                return last_return
            }
            let sf_nk = len(sf_keys)
            let mut sf_hitidx = -1
            let mut sf_i = 0
            while sf_i < sf_nk {
                if sf_keys[sf_i] == sfname {
                    sf_hitidx = sf_i
                    sf_i = sf_nk
                } else {
                    sf_i = sf_i + 1
                }
            }
            let mut sf_new_keys = sf_keys
            let mut sf_new_vals = sf_vals
            if sf_hitidx >= 0 {
                sf_new_vals = bc_vm_setat(sf_vals, sf_hitidx, sf_val)
            } else {
                sf_new_keys = sf_keys.push(sfname)
                sf_new_vals = sf_vals.push(sf_val)
            }
            let sf_out = [BC_STRUCT_TAG, sf_type, sf_new_keys, sf_new_vals]
            bc_vm_push(sf_out)
        }

        // ──────── UNIMPLEMENTED OPCODES ────────
        // Anything else — trap with the opcode name for debuggability.
        else {
            vm_trap = true
            vm_trap_msg = "unimplemented opcode: " + bc_opname(op) + " (" + to_string(op) + ")"
            return last_return
        }
    }

    return last_return
}

// ── Top-level entry: run the `<main>` proto if present,
//    else the first proto in the registry. ──────────────────
// bc_compile_root must have been called beforehand — it
// populates bc_protos / bc_proto_codes / bc_proto_consts etc.

fn bc_vm_run() {
    bc_vm_reset()

    // Find the main proto — the emitter always names it "<main>"
    // when it emits top-level non-FnDecl stmts. If no "<main>",
    // fall back to the last proto (empty-top-level case).
    let mut main_idx = -1
    let mut i = 0
    while i < len(bc_protos) {
        let p = bc_protos[i]
        if p.name == "<main>" {
            main_idx = i
        }
        i = i + 1
    }
    if main_idx < 0 {
        // No main — nothing to run. This is legal (a module of
        // pure fn defs). Return nil.
        return BC_NIL
    }

    // Push main frame with no arguments.
    bc_vm_push_frame(main_idx, 0)
    if vm_trap { return BC_NIL }

    return bc_vm_run_loop()
}

// ── Debug accessor for tests. ──────────────────────────────

fn bc_vm_trap_hit() { return vm_trap }
fn bc_vm_trap_reason() { return vm_trap_msg }
fn bc_vm_halted_hit() { return vm_halted }

// ── Run-and-return-top helper (for tests that want the
//    final TOS, e.g. plain-arith tests that end with ExprStmt
//    — but Phase B always wraps those with OP_POP). We give a
//    secondary entry that runs a specific proto by name,
//    with no args, and returns its OP_RETURN value directly. ──

fn bc_vm_call_by_name(name) {
    bc_vm_reset()
    let mut target = -1
    let mut i = 0
    while i < len(bc_protos) {
        let p = bc_protos[i]
        if p.name == name {
            target = i
        }
        i = i + 1
    }
    if target < 0 {
        vm_trap = true
        vm_trap_msg = "bc_vm_call_by_name: no such proto: " + name
        return BC_NIL
    }
    bc_vm_push_frame(target, 0)
    if vm_trap { return BC_NIL }
    return bc_vm_run_loop()
}
