// ═══════════════════════════════════════════════════════════
//  self/test_string_intern.hexa — String Interning Tests
//
//  Validates the pure HEXA string intern implementation
//  (self/core/string_intern.hexa) — port of runtime.c Opt #11.
//
//  Run:
//    hexa_v2 self/test_string_intern.hexa /tmp/_test_si.c && \
//    clang -O2 -I self /tmp/_test_si.c -o /tmp/_test_si -lm && \
//    /tmp/_test_si
//
// EXPECTED: ALL PASS
// ═══════════════════════════════════════════════════════════

// ── Inline the string_intern module ──
// (stage0 `use` resolves relative to CWD; for standalone testing,
//  we include the implementation directly.)

// ═══ string_intern.hexa (inlined) ═══
let SI_HASH_MOD = 1000000007
let SI_INIT_CAP = 64
let SI_LOAD_MAX = 75

let mut _si_keys = []
let mut _si_ids = []
let mut _si_hashes = []
let mut _si_cap = 0
let mut _si_count = 0
let mut _si_next_id = 0
let mut _si_rev = []

fn _si_hash_loop(s, n, h, i) {
    if i >= n { return h }
    let c = char_code(s, i)
    let nh = (h * 33 + c) % SI_HASH_MOD
    return _si_hash_loop(s, n, nh, i + 1)
}

fn si_hash(s) {
    let h = _si_hash_loop(s, len(s), 5381, 0)
    if h < 0 { return h + SI_HASH_MOD }
    return h
}

fn _si_fill_arr(arr, size, val, i) {
    if i >= size { return arr }
    arr.push(val)
    return _si_fill_arr(arr, size, val, i + 1)
}

fn _si_init() {
    _si_cap = SI_INIT_CAP
    _si_count = 0
    _si_next_id = 1
    _si_keys = _si_fill_arr([], SI_INIT_CAP, "", 0)
    _si_ids = _si_fill_arr([], SI_INIT_CAP, 0, 0)
    _si_hashes = _si_fill_arr([], SI_INIT_CAP, 0, 0)
    _si_rev = [""]
}

fn _si_probe(h, s, idx, start, wrapped) {
    if wrapped > 0 {
        if idx == start { return 0 - idx - 1 }
    }
    if _si_ids[idx] == 0 { return 0 - idx - 1 }
    if _si_hashes[idx] == h {
        if _si_keys[idx] == s { return _si_ids[idx] }
    }
    let next = (idx + 1) % _si_cap
    return _si_probe(h, s, next, start, 1)
}

fn _si_find_empty(idx) {
    if _si_ids[idx] == 0 { return idx }
    return _si_find_empty((idx + 1) % _si_cap)
}

fn _si_reinsert(ok, oi, oh, oc, j) {
    if j >= oc { return 0 }
    if oi[j] > 0 {
        let idx = _si_find_empty(oh[j] % _si_cap)
        _si_keys[idx] = ok[j]
        _si_ids[idx] = oi[j]
        _si_hashes[idx] = oh[j]
    }
    return _si_reinsert(ok, oi, oh, oc, j + 1)
}

fn _si_grow() {
    let oc = _si_cap
    let ok = _si_keys
    let oi = _si_ids
    let oh = _si_hashes
    let nc = oc * 2
    _si_cap = nc
    _si_keys = _si_fill_arr([], nc, "", 0)
    _si_ids = _si_fill_arr([], nc, 0, 0)
    _si_hashes = _si_fill_arr([], nc, 0, 0)
    _si_reinsert(ok, oi, oh, oc, 0)
}

fn intern(s) {
    if _si_cap == 0 { _si_init() }
    let h = si_hash(s)
    let start_idx = h % _si_cap
    let probe_result = _si_probe(h, s, start_idx, start_idx, 0)
    if probe_result > 0 { return probe_result }
    if _si_count * 100 / _si_cap >= SI_LOAD_MAX {
        _si_grow()
    }
    let idx = _si_find_empty(h % _si_cap)
    let id = _si_next_id
    _si_next_id = _si_next_id + 1
    _si_keys[idx] = s
    _si_ids[idx] = id
    _si_hashes[idx] = h
    _si_rev.push(s)
    _si_count = _si_count + 1
    return id
}

fn intern_lookup(id) {
    if id <= 0 { return "" }
    if id >= len(_si_rev) { return "" }
    return _si_rev[id]
}

fn intern_count() {
    return _si_count
}

fn intern_has(s) {
    if _si_cap == 0 { return false }
    let h = si_hash(s)
    let start_idx = h % _si_cap
    let probe_result = _si_probe(h, s, start_idx, start_idx, 0)
    return probe_result > 0
}

// ═══ End inlined module ═══

// ── Test harness ──
let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  String Intern Tests (pure HEXA)")
println("═══════════════════════════════════════════════════════")

// ── T1: Same string returns same id (deduplication) ──
let id_a1 = intern("hello")
let id_a2 = intern("hello")
check("T1 same string => same id", id_a1 == id_a2)

// ── T2: Different strings return different ids ──
let id_b = intern("world")
check("T2 different strings => different ids", id_a1 != id_b)

// ── T3: Reverse lookup ──
let s_a = intern_lookup(id_a1)
check("T3a lookup hello => hello", s_a == "hello")
let s_b = intern_lookup(id_b)
check("T3b lookup world => world", s_b == "world")

// ── T4: Empty string interning ──
let id_e1 = intern("")
let id_e2 = intern("")
check("T4a empty string dedup", id_e1 == id_e2)
let s_e = intern_lookup(id_e1)
check("T4b empty string lookup", s_e == "")

// ── T5: ID monotonicity (first interned has lower id) ──
let id_first = intern("alpha")
let id_second = intern("beta")
check("T5 id ordering", id_first < id_second)

// ── T6: intern_has check ──
check("T6a intern_has hello", intern_has("hello"))
check("T6b intern_has unknown", intern_has("never_interned") == false)

// ── T7: Many strings (force table growth) ──
let count_before = intern_count()
let mut i = 0
while i < 120 {
    intern("str_" + to_string(i))
    i = i + 1
}
let count_after = intern_count()
check("T7a 120 strings interned", count_after >= count_before + 120)

// ── T8: Dedup after growth ──
let id_s50a = intern("str_50")
let id_s50b = intern("str_50")
check("T8a dedup after growth", id_s50a == id_s50b)
let s_s50 = intern_lookup(id_s50a)
check("T8b lookup after growth", s_s50 == "str_50")

// ── T9: Pre-growth strings still valid ──
let id_hello_post = intern("hello")
check("T9 pre-growth string still valid", id_hello_post == id_a1)

// ── T10: Long string ──
let long_str = "abcdefghijklmnopqrstuvwxyz_0123456789_ABCDEFGHIJKLMNOPQRSTUVWXYZ_abcdefghijklmnopqrstuvwxyz"
let id_long1 = intern(long_str)
let id_long2 = intern(long_str)
check("T10a long string dedup", id_long1 == id_long2)
check("T10b long string lookup", intern_lookup(id_long1) == long_str)

// ── T11: Invalid id lookup returns empty ──
check("T11a negative id", intern_lookup(-1) == "")
check("T11b zero id", intern_lookup(0) == "")
check("T11c huge id", intern_lookup(999999) == "")

// ── T12: Hash consistency ──
let h1 = si_hash("test_string")
let h2 = si_hash("test_string")
check("T12a hash deterministic", h1 == h2)
let h3 = si_hash("other_string")
check("T12b hash differs for different strings", h1 != h3)

// ── T13: Single-character strings ──
let id_x = intern("x")
let id_y = intern("y")
let id_x2 = intern("x")
check("T13a single char dedup", id_x == id_x2)
check("T13b single chars differ", id_x != id_y)

// ── T14: Numbers as strings ──
let id_n1 = intern("42")
let id_n2 = intern("42")
let id_n3 = intern("43")
check("T14a numeric string dedup", id_n1 == id_n2)
check("T14b different numbers differ", id_n1 != id_n3)

// ── T15: Stress test — 200 more unique strings ──
let count_pre = intern_count()
let mut j = 0
while j < 200 {
    intern("stress_" + to_string(j))
    j = j + 1
}
let count_post = intern_count()
check("T15 stress 200 strings", count_post >= count_pre + 200)

// ── T16: All stress strings still accessible ──
let id_s100 = intern("stress_100")
let s_s100 = intern_lookup(id_s100)
check("T16 stress lookup", s_s100 == "stress_100")

// ── Summary ──
println("")
println("═══════════════════════════════════════════════════════")
println("  RESULT: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("  Total interned: " + to_string(intern_count()) + " unique strings")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL PASS")
}
