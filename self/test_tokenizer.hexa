// ═══════════════════════════════════════════════════════════════
//  test_tokenizer.hexa — Tokenizer BPE + Unigram tests (#148)
//
//  Tests (35):
//    T1  special token IDs correct
//    T2  special token strings correct
//    T3  is_special_id for BOS/EOS/PAD/UNK
//    T4  is_special_id false for non-special
//    T5  pre-tokenize splits on whitespace
//    T6  pre-tokenize attaches leading space
//    T7  pre-tokenize separates punctuation
//    T8  pre-tokenize empty string
//    T9  word_to_chars produces correct chars
//    T10 build_vocab_map has correct IDs
//    T11 build_merge_ranks correct ordering
//    T12 apply_bpe merges correctly
//    T13 bpe_encode produces valid IDs
//    T14 bpe_encode_special wraps with BOS/EOS
//    T15 bpe_decode reconstructs text
//    T16 bpe_decode stops at EOS
//    T17 bpe_decode skips BOS and PAD
//    T18 unknown tokens map to UNK
//    T19 count_pairs finds adjacent pairs
//    T20 best_pair picks most frequent
//    T21 merge_in_words applies merge
//    T22 train_bpe produces vocab and merges
//    T23 train_bpe vocab contains specials
//    T24 train_bpe merges are valid pairs
//    T25 trained BPE roundtrip encode/decode
//    T26 unigram train produces vocab/scores
//    T27 unigram encode produces valid IDs
//    T28 unigram decode reconstructs text
//    T29 unigram encode_special wraps BOS/EOS
//    T30 pad_sequence pads to length
//    T31 pad_sequence truncates if longer
//    T32 truncate shortens sequence
//    T33 batch_encode encodes multiple texts
//    T34 vocab_size returns correct count
//    T35 id_to_str and str_to_id roundtrip
//
//  Run: cargo run --release -- self/test_tokenizer.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ── inline helpers (from tokenizer.hexa) ────────────────────────

fn tok_log(x) {
    if x <= 0.0 { return -999.0 }
    return log(x)
}

fn tok_min_int(a, b) {
    if a < b { return a }
    return b
}

fn tok_bos_id() { return 0 }
fn tok_eos_id() { return 1 }
fn tok_pad_id() { return 2 }
fn tok_unk_id() { return 3 }

fn tok_bos_str() { return "<bos>" }
fn tok_eos_str() { return "<eos>" }
fn tok_pad_str() { return "<pad>" }
fn tok_unk_str() { return "<unk>" }

fn tok_special_id(kind) {
    if kind == "bos" { return 0 }
    if kind == "eos" { return 1 }
    if kind == "pad" { return 2 }
    if kind == "unk" { return 3 }
    return -1
}

fn tok_special_str(kind) {
    if kind == "bos" { return "<bos>" }
    if kind == "eos" { return "<eos>" }
    if kind == "pad" { return "<pad>" }
    if kind == "unk" { return "<unk>" }
    return ""
}

fn tok_is_special_id(id) {
    if id >= 0 {
        if id <= 3 { return true }
    }
    return false
}

fn tok_num_specials() { return 4 }

fn tok_is_letter(code) {
    if code >= 65 {
        if code <= 90 { return true }
    }
    if code >= 97 {
        if code <= 122 { return true }
    }
    return false
}

fn tok_is_digit(code) {
    if code >= 48 {
        if code <= 57 { return true }
    }
    return false
}

fn tok_is_whitespace(code) {
    if code == 32 { return true }
    if code == 9 { return true }
    if code == 10 { return true }
    if code == 13 { return true }
    return false
}

fn tok_is_punct(code) {
    if tok_is_letter(code) { return false }
    if tok_is_digit(code) { return false }
    if tok_is_whitespace(code) { return false }
    return true
}

fn tok_pre_tokenize(text) {
    let n = len(text)
    if n == 0 { return [] }
    let mut words = []
    let mut current = ""
    let mut i = 0
    while i < n {
        let code = char_code(text, i)
        let ch = chr(code)
        if tok_is_whitespace(code) {
            if len(current) > 0 {
                words = words + [current]
                current = ""
            }
            current = " "
        } else {
            if tok_is_punct(code) {
                if len(current) > 0 {
                    words = words + [current]
                    current = ""
                }
                words = words + [ch]
            } else {
                current = current + ch
            }
        }
        i = i + 1
    }
    if len(current) > 0 {
        words = words + [current]
    }
    return words
}

fn tok_word_to_chars(word) {
    let n = len(word)
    let mut chars = []
    let mut i = 0
    while i < n {
        let code = char_code(word, i)
        chars = chars + [chr(code)]
        i = i + 1
    }
    return chars
}

fn tok_count_pairs(corpus_words) {
    let mut counts = #{}
    let nw = len(corpus_words)
    let mut wi = 0
    while wi < nw {
        let syms = corpus_words[wi]
        let ns = len(syms)
        let mut si = 0
        while si < ns - 1 {
            let key = syms[si] + " " + syms[si + 1]
            if has_key(counts, key) {
                counts[key] = counts[key] + 1
            } else {
                counts[key] = 1
            }
            si = si + 1
        }
        wi = wi + 1
    }
    return counts
}

fn tok_best_pair(pair_counts) {
    let ks = keys(pair_counts)
    let nk = len(ks)
    if nk == 0 { return [] }
    let mut best_key = ks[0]
    let mut best_count = pair_counts[ks[0]]
    let mut i = 1
    while i < nk {
        let c = pair_counts[ks[i]]
        if c > best_count {
            best_count = c
            best_key = ks[i]
        }
        i = i + 1
    }
    let parts = best_key.split(" ")
    return [parts[0], parts[1]]
}

fn tok_merge_in_words(corpus_words, pair_a, pair_b) {
    let merged = pair_a + pair_b
    let nw = len(corpus_words)
    let mut result = []
    let mut wi = 0
    while wi < nw {
        let syms = corpus_words[wi]
        let ns = len(syms)
        let mut new_syms = []
        let mut si = 0
        while si < ns {
            if si < ns - 1 {
                if syms[si] == pair_a {
                    if syms[si + 1] == pair_b {
                        new_syms = new_syms + [merged]
                        si = si + 2
                        continue
                    }
                }
            }
            new_syms = new_syms + [syms[si]]
            si = si + 1
        }
        result = result + [new_syms]
        wi = wi + 1
    }
    return result
}

fn tok_collect_symbols(corpus_words) {
    let mut seen = #{}
    let nw = len(corpus_words)
    let mut wi = 0
    while wi < nw {
        let syms = corpus_words[wi]
        let ns = len(syms)
        let mut si = 0
        while si < ns {
            seen[syms[si]] = 1
            si = si + 1
        }
        wi = wi + 1
    }
    return keys(seen)
}

fn tok_train_bpe(corpus, vocab_size) {
    let mut corpus_words = []
    let nc = len(corpus)
    let mut ci = 0
    while ci < nc {
        let words = tok_pre_tokenize(corpus[ci])
        let nw = len(words)
        let mut wi = 0
        while wi < nw {
            let chars = tok_word_to_chars(words[wi])
            corpus_words = corpus_words + [chars]
            wi = wi + 1
        }
        ci = ci + 1
    }
    let mut vocab = [tok_bos_str(), tok_eos_str(), tok_pad_str(), tok_unk_str()]
    let init_syms = tok_collect_symbols(corpus_words)
    let mut sym_set = #{}
    let nis = len(init_syms)
    let mut si = 0
    while si < nis {
        let s = init_syms[si]
        if sym_set.has(s) == false {
            vocab = vocab + [s]
            sym_set[s] = 1
        }
        si = si + 1
    }
    let mut merges = []
    let max_merges = vocab_size - len(vocab)
    let mut iter = 0
    while iter < max_merges {
        let pair_counts = tok_count_pairs(corpus_words)
        let best = tok_best_pair(pair_counts)
        if len(best) == 0 { break }
        let pa = best[0]
        let pb = best[1]
        let merged = pa + pb
        corpus_words = tok_merge_in_words(corpus_words, pa, pb)
        merges = merges + [[pa, pb]]
        if sym_set.has(merged) == false {
            vocab = vocab + [merged]
            sym_set[merged] = 1
        }
        iter = iter + 1
    }
    return [vocab, merges]
}

fn tok_build_vocab_map(vocab) {
    let mut m = #{}
    let n = len(vocab)
    let mut i = 0
    while i < n {
        m[vocab[i]] = i
        i = i + 1
    }
    return m
}

fn tok_build_merge_ranks(merges) {
    let mut m = #{}
    let n = len(merges)
    let mut i = 0
    while i < n {
        let key = merges[i][0] + " " + merges[i][1]
        m[key] = i
        i = i + 1
    }
    return m
}

fn tok_apply_bpe(symbols, merge_ranks) {
    let mut syms = symbols
    let mut changed = true
    // @partial — Stage 0: pre-witness acknowledgement
    while changed {
        changed = false
        let n = len(syms)
        if n < 2 { return syms }
        let mut best_rank = 999999999
        let mut best_idx = -1
        let mut i = 0
        while i < n - 1 {
            let key = syms[i] + " " + syms[i + 1]
            if has_key(merge_ranks, key) {
                let rank = merge_ranks[key]
                if rank < best_rank {
                    best_rank = rank
                    best_idx = i
                }
            }
            i = i + 1
        }
        if best_idx >= 0 {
            let merged = syms[best_idx] + syms[best_idx + 1]
            let mut new_syms = []
            let mut j = 0
            while j < n {
                if j == best_idx {
                    new_syms = new_syms + [merged]
                    j = j + 2
                } else {
                    new_syms = new_syms + [syms[j]]
                    j = j + 1
                }
            }
            syms = new_syms
            changed = true
        }
    }
    return syms
}

fn tok_bpe_encode(text, vocab, merges) {
    let vocab_map = tok_build_vocab_map(vocab)
    let merge_ranks = tok_build_merge_ranks(merges)
    let words = tok_pre_tokenize(text)
    let mut token_ids = []
    let n_words = len(words)
    let mut wi = 0
    while wi < n_words {
        let word = words[wi]
        let chars = tok_word_to_chars(word)
        let bpe_tokens = tok_apply_bpe(chars, merge_ranks)
        let n_toks = len(bpe_tokens)
        let mut ti = 0
        while ti < n_toks {
            let tok = bpe_tokens[ti]
            if has_key(vocab_map, tok) {
                token_ids = token_ids + [vocab_map[tok]]
            } else {
                token_ids = token_ids + [tok_unk_id()]
            }
            ti = ti + 1
        }
        wi = wi + 1
    }
    return token_ids
}

fn tok_bpe_encode_special(text, vocab, merges) {
    let ids = tok_bpe_encode(text, vocab, merges)
    return [tok_bos_id()] + ids + [tok_eos_id()]
}

fn tok_bpe_decode(ids, vocab) {
    let n = len(ids)
    let vs = len(vocab)
    let mut result = ""
    let mut i = 0
    while i < n {
        let id = ids[i]
        if id == tok_bos_id() {
            // skip BOS
        } else {
            if id == tok_eos_id() {
                return result
            } else {
                if id == tok_pad_id() {
                    // skip PAD
                } else {
                    if id >= 0 {
                        if id < vs {
                            result = result + vocab[id]
                        } else {
                            result = result + tok_unk_str()
                        }
                    } else {
                        result = result + tok_unk_str()
                    }
                }
            }
        }
        i = i + 1
    }
    return result
}

fn tok_bpe_decode_raw(ids, vocab) {
    let n = len(ids)
    let vs = len(vocab)
    let mut result = ""
    let mut i = 0
    while i < n {
        let id = ids[i]
        if id >= 0 {
            if id < vs {
                result = result + vocab[id]
            } else {
                result = result + tok_unk_str()
            }
        } else {
            result = result + tok_unk_str()
        }
        i = i + 1
    }
    return result
}

fn tok_uni_build_initial_vocab(corpus, max_piece_len) {
    let mut freq = #{}
    let nc = len(corpus)
    let mut ci = 0
    while ci < nc {
        let text = corpus[ci]
        let tlen = len(text)
        let mut start = 0
        while start < tlen {
            let mut end = start + 1
            let mut elimit = start + max_piece_len
            if elimit > tlen { elimit = tlen }
            while end <= elimit {
                let piece = text.substring(start, end)
                if has_key(freq, piece) {
                    freq[piece] = freq[piece] + 1
                } else {
                    freq[piece] = 1
                }
                end = end + 1
            }
            start = start + 1
        }
        ci = ci + 1
    }
    return freq
}

fn tok_uni_train(corpus, vocab_size, n_iter) {
    let max_piece = 8
    let freq = tok_uni_build_initial_vocab(corpus, max_piece)
    let all_pieces = keys(freq)
    let mut total = 0
    let nap = len(all_pieces)
    let mut pi = 0
    while pi < nap {
        total = total + freq[all_pieces[pi]]
        pi = pi + 1
    }
    let mut vocab = [tok_bos_str(), tok_eos_str(), tok_pad_str(), tok_unk_str()]
    let mut scores = [-999.0, -999.0, -999.0, -999.0]
    let mut char_set = #{}
    let nc = len(corpus)
    let mut ci = 0
    while ci < nc {
        let text = corpus[ci]
        let tl = len(text)
        let mut ti = 0
        while ti < tl {
            let code = char_code(text, ti)
            let ch = chr(code)
            if char_set.has(ch) == false {
                char_set[ch] = 1
                let f = freq[ch]
                let sc = tok_log(to_float(f) / to_float(total))
                vocab = vocab + [ch]
                scores = scores + [sc]
            }
            ti = ti + 1
        }
        ci = ci + 1
    }
    let n_single = len(vocab)
    let mut multi_pieces = []
    let mut multi_scores = []
    pi = 0
    while pi < nap {
        let p = all_pieces[pi]
        if len(p) > 1 {
            let f = freq[p]
            if f >= 2 {
                let sc = tok_log(to_float(f) / to_float(total))
                multi_pieces = multi_pieces + [p]
                multi_scores = multi_scores + [sc]
            }
        }
        pi = pi + 1
    }
    let nmp = len(multi_pieces)
    let mut mi = 0
    while mi < nmp - 1 {
        let mut best_j = mi
        let mut mj = mi + 1
        while mj < nmp {
            if multi_scores[mj] > multi_scores[best_j] {
                best_j = mj
            }
            mj = mj + 1
        }
        if best_j != mi {
            let tmp_p = multi_pieces[mi]
            let tmp_s = multi_scores[mi]
            multi_pieces[mi] = multi_pieces[best_j]
            multi_scores[mi] = multi_scores[best_j]
            multi_pieces[best_j] = tmp_p
            multi_scores[best_j] = tmp_s
        }
        mi = mi + 1
    }
    let add_limit = (vocab_size - n_single) * 2
    let mut add_count = tok_min_int(nmp, add_limit)
    let mut ai = 0
    while ai < add_count {
        vocab = vocab + [multi_pieces[ai]]
        scores = scores + [multi_scores[ai]]
        ai = ai + 1
    }
    let mut it = 0
    while it < n_iter {
        if len(vocab) <= vocab_size { break }
        let mut worst_idx = -1
        let mut worst_score = 999.0
        let mut wi = n_single
        while wi < len(vocab) {
            if scores[wi] < worst_score {
                worst_score = scores[wi]
                worst_idx = wi
            }
            wi = wi + 1
        }
        if worst_idx < 0 { break }
        let mut new_vocab = []
        let mut new_scores = []
        let mut ri = 0
        while ri < len(vocab) {
            if ri != worst_idx {
                new_vocab = new_vocab + [vocab[ri]]
                new_scores = new_scores + [scores[ri]]
            }
            ri = ri + 1
        }
        vocab = new_vocab
        scores = new_scores
        it = it + 1
    }
    if len(vocab) > vocab_size {
        let mut tv = []
        let mut ts = []
        let mut ti = 0
        while ti < vocab_size {
            tv = tv + [vocab[ti]]
            ts = ts + [scores[ti]]
            ti = ti + 1
        }
        vocab = tv
        scores = ts
    }
    return [vocab, scores]
}

fn tok_uni_encode(text, vocab, scores) {
    let tlen = len(text)
    if tlen == 0 { return [] }
    let vs = len(vocab)
    let mut piece_map = #{}
    let mut vi = 0
    while vi < vs {
        let p = vocab[vi]
        if piece_map.has(p) == false {
            piece_map[p] = vi
        }
        vi = vi + 1
    }
    let mut best = []
    let mut back = []
    let mut bi = 0
    while bi <= tlen {
        best = best + [-999999.0]
        back = back + [0]
        bi = bi + 1
    }
    best[0] = 0.0
    let mut pos = 0
    while pos < tlen {
        if best[pos] <= -999998.0 {
            pos = pos + 1
            continue
        }
        let mut plen = 1
        let max_p = tlen - pos
        let mut plimit = max_p
        if plimit > 16 { plimit = 16 }
        while plen <= plimit {
            let piece = text.substring(pos, pos + plen)
            if piece_map.has(piece) {
                let pid = piece_map[piece]
                let sc = scores[pid]
                let candidate = best[pos] + sc
                if candidate > best[pos + plen] {
                    best[pos + plen] = candidate
                    back[pos + plen] = plen
                }
            }
            plen = plen + 1
        }
        pos = pos + 1
    }
    let mut pieces_rev = []
    let mut bp = tlen
    while bp > 0 {
        let pl = back[bp]
        if pl <= 0 {
            pieces_rev = pieces_rev + [tok_unk_id()]
            bp = bp - 1
        } else {
            let piece = text.substring(bp - pl, bp)
            if piece_map.has(piece) {
                pieces_rev = pieces_rev + [piece_map[piece]]
            } else {
                pieces_rev = pieces_rev + [tok_unk_id()]
            }
            bp = bp - pl
        }
    }
    let nr = len(pieces_rev)
    let mut result = []
    let mut ri = nr - 1
    while ri >= 0 {
        result = result + [pieces_rev[ri]]
        ri = ri - 1
    }
    return result
}

fn tok_uni_encode_special(text, vocab, scores) {
    let ids = tok_uni_encode(text, vocab, scores)
    return [tok_bos_id()] + ids + [tok_eos_id()]
}

fn tok_uni_decode(ids, vocab) {
    let n = len(ids)
    let vs = len(vocab)
    let mut result = ""
    let mut i = 0
    while i < n {
        let id = ids[i]
        if id == tok_bos_id() {
            // skip
        } else {
            if id == tok_eos_id() {
                return result
            } else {
                if id == tok_pad_id() {
                    // skip
                } else {
                    if id >= 0 {
                        if id < vs {
                            result = result + vocab[id]
                        } else {
                            result = result + tok_unk_str()
                        }
                    } else {
                        result = result + tok_unk_str()
                    }
                }
            }
        }
        i = i + 1
    }
    return result
}

fn tok_pad_sequence(ids, max_len) {
    let n = len(ids)
    if n >= max_len {
        let mut out = []
        let mut i = 0
        while i < max_len {
            out = out + [ids[i]]
            i = i + 1
        }
        return out
    }
    let mut out = ids
    let mut i = n
    while i < max_len {
        out = out + [tok_pad_id()]
        i = i + 1
    }
    return out
}

fn tok_truncate(ids, max_len) {
    let n = len(ids)
    if n <= max_len { return ids }
    let mut out = []
    let mut i = 0
    while i < max_len {
        out = out + [ids[i]]
        i = i + 1
    }
    return out
}

fn tok_bpe_batch_encode(texts, vocab, merges) {
    let n = len(texts)
    let mut batch = []
    let mut i = 0
    while i < n {
        let ids = tok_bpe_encode(texts[i], vocab, merges)
        batch = batch + [ids]
        i = i + 1
    }
    return batch
}

fn tok_vocab_size(vocab) {
    return len(vocab)
}

fn tok_id_to_str(id, vocab) {
    if id >= 0 {
        if id < len(vocab) {
            return vocab[id]
        }
    }
    return tok_unk_str()
}

fn tok_str_to_id(token, vocab) {
    let m = tok_build_vocab_map(vocab)
    if has_key(m, token) {
        return m[token]
    }
    return tok_unk_id()
}

fn tok_make_test_vocab() {
    let mut vocab = [tok_bos_str(), tok_eos_str(), tok_pad_str(), tok_unk_str()]
    let mut code = 32
    while code <= 126 {
        vocab = vocab + [chr(code)]
        code = code + 1
    }
    vocab = vocab + ["he"]
    vocab = vocab + ["ll"]
    vocab = vocab + ["lo"]
    vocab = vocab + [" w"]
    vocab = vocab + ["or"]
    vocab = vocab + ["ld"]
    vocab = vocab + ["hel"]
    vocab = vocab + ["hell"]
    vocab = vocab + ["hello"]
    vocab = vocab + [" wo"]
    vocab = vocab + ["orl"]
    vocab = vocab + ["orld"]
    vocab = vocab + [" world"]
    return vocab
}

fn tok_make_test_merges() {
    let merges = [
        ["h", "e"],
        ["l", "l"],
        ["l", "o"],
        [" ", "w"],
        ["o", "r"],
        ["l", "d"],
        ["he", "l"],
        ["hel", "l"],
        ["hell", "o"],
        [" w", "o"],
        ["or", "l"],
        ["orl", "d"],
        [" wo", "rld"]
    ]
    return merges
}

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

// -- setup --
let test_vocab = tok_make_test_vocab()
let test_merges = tok_make_test_merges()

// T1: special token IDs
check("T1 BOS ID = 0", tok_special_id("bos") == 0)
check("T1b EOS ID = 1", tok_special_id("eos") == 1)
check("T1c PAD ID = 2", tok_special_id("pad") == 2)
check("T1d UNK ID = 3", tok_special_id("unk") == 3)

// T2: special token strings
check("T2 BOS str", tok_special_str("bos") == "<bos>")
check("T2b EOS str", tok_special_str("eos") == "<eos>")

// T3: is_special_id true for 0-3
check("T3 is_special 0", tok_is_special_id(0) == true)
check("T3b is_special 3", tok_is_special_id(3) == true)

// T4: is_special_id false for non-special
check("T4 not special 4", tok_is_special_id(4) == false)
check("T4b not special -1", tok_is_special_id(-1) == false)

// T5: pre-tokenize splits on whitespace
let pt5 = tok_pre_tokenize("hello world")
check("T5 pre_tokenize word count", len(pt5) == 2)
check("T5b first word", pt5[0] == "hello")

// T6: pre-tokenize attaches leading space
check("T6 second word has leading space", pt5[1] == " world")

// T7: pre-tokenize separates punctuation
let pt7 = tok_pre_tokenize("hello, world!")
let mut has_comma = false
let mut has_excl = false
let np7 = len(pt7)
let mut i7 = 0
while i7 < np7 {
    if pt7[i7] == "," { has_comma = true }
    if pt7[i7] == "!" { has_excl = true }
    i7 = i7 + 1
}
check("T7 comma separated", has_comma)
check("T7b exclamation separated", has_excl)

// T8: pre-tokenize empty string
let pt8 = tok_pre_tokenize("")
check("T8 empty -> empty array", len(pt8) == 0)

// T9: word_to_chars
let chars9 = tok_word_to_chars("abc")
check("T9 word_to_chars len", len(chars9) == 3)
check("T9b first char", chars9[0] == "a")
check("T9c last char", chars9[2] == "c")

// T10: build_vocab_map
let vmap = tok_build_vocab_map(test_vocab)
check("T10 vocab_map BOS=0", vmap["<bos>"] == 0)
check("T10b vocab_map has 'hello'", has_key(vmap, "hello"))

// T11: build_merge_ranks
let mranks = tok_build_merge_ranks(test_merges)
check("T11 merge rank 'h e' = 0", mranks["h e"] == 0)
check("T11b merge rank 'l l' = 1", mranks["l l"] == 1)

// T12: apply_bpe merges correctly
// "h","e","l","l","o" -> "he","ll","o" (he via rank 0, ll via rank 1; no further merge)
let syms12 = ["h", "e", "l", "l", "o"]
let merged12 = tok_apply_bpe(syms12, mranks)
check("T12 apply_bpe merges 'he' pair", merged12[0] == "he")
check("T12b apply_bpe merges 'll' pair", merged12[1] == "ll")

// T13: bpe_encode produces valid IDs
let ids13 = tok_bpe_encode("hello", test_vocab, test_merges)
check("T13 encode produces non-empty", len(ids13) > 0)
let mut all_valid_13 = true
let n13 = len(ids13)
let mut i13 = 0
while i13 < n13 {
    if ids13[i13] < 0 { all_valid_13 = false }
    i13 = i13 + 1
}
check("T13b all IDs >= 0", all_valid_13)

// T14: bpe_encode_special wraps with BOS/EOS
let ids14 = tok_bpe_encode_special("hello", test_vocab, test_merges)
check("T14 starts with BOS", ids14[0] == tok_bos_id())
check("T14b ends with EOS", ids14[len(ids14) - 1] == tok_eos_id())

// T15: bpe_decode reconstructs text
let decoded15 = tok_bpe_decode(ids13, test_vocab)
check("T15 decode reconstructs 'hello'", decoded15 == "hello")

// T16: bpe_decode stops at EOS
let ids16 = [tok_bos_id()] + ids13 + [tok_eos_id(), 50, 60]
let decoded16 = tok_bpe_decode(ids16, test_vocab)
check("T16 decode stops at EOS", decoded16 == "hello")

// T17: bpe_decode skips BOS and PAD
let ids17 = [tok_bos_id(), tok_pad_id()] + ids13
let decoded17 = tok_bpe_decode(ids17, test_vocab)
check("T17 decode skips BOS+PAD", decoded17 == "hello")

// T18: unknown tokens map to UNK
let ids18 = tok_bpe_encode("hello", test_vocab, test_merges)
// Manually add an out-of-range ID
let ids18b = ids18 + [99999]
let decoded18 = tok_bpe_decode_raw(ids18b, test_vocab)
check("T18 unknown ID produces UNK string", decoded18.contains("<unk>"))

// T19: count_pairs finds adjacent pairs
let words19 = [["a", "b", "c"], ["a", "b"]]
let pc19 = tok_count_pairs(words19)
check("T19 pair 'a b' count = 2", pc19["a b"] == 2)
check("T19b pair 'b c' count = 1", pc19["b c"] == 1)

// T20: best_pair picks most frequent
let bp20 = tok_best_pair(pc19)
check("T20 best pair is [a, b]", bp20[0] == "a")
check("T20b best pair second is b", bp20[1] == "b")

// T21: merge_in_words applies merge
let merged21 = tok_merge_in_words(words19, "a", "b")
check("T21 merged word 0 has 'ab'", merged21[0][0] == "ab")
check("T21b merged word 0 len = 2", len(merged21[0]) == 2)

// T22: train_bpe produces vocab and merges
let corpus22 = ["the cat sat", "the cat hat", "the bat sat"]
let result22 = tok_train_bpe(corpus22, 30)
let trained_vocab = result22[0]
let trained_merges = result22[1]
check("T22 trained vocab non-empty", len(trained_vocab) > 4)
check("T22b trained merges non-empty", len(trained_merges) > 0)

// T23: train_bpe vocab contains specials
check("T23 vocab[0] is BOS", trained_vocab[0] == tok_bos_str())
check("T23b vocab[1] is EOS", trained_vocab[1] == tok_eos_str())
check("T23c vocab[2] is PAD", trained_vocab[2] == tok_pad_str())
check("T23d vocab[3] is UNK", trained_vocab[3] == tok_unk_str())

// T24: train_bpe merges are valid pairs
let m24 = trained_merges[0]
check("T24 merge[0] has 2 elements", len(m24) == 2)
check("T24b merge[0][0] is string", len(m24[0]) > 0)

// T25: trained BPE roundtrip encode/decode
let enc25 = tok_bpe_encode("the cat", trained_vocab, trained_merges)
let dec25 = tok_bpe_decode(enc25, trained_vocab)
check("T25 trained BPE roundtrip", dec25 == "the cat")

// T26: unigram train produces vocab/scores
let corpus26 = ["hello world", "hello there", "world hello"]
let uni26 = tok_uni_train(corpus26, 30, 50)
let uni_vocab = uni26[0]
let uni_scores = uni26[1]
check("T26 unigram vocab non-empty", len(uni_vocab) > 4)
check("T26b scores same len as vocab", len(uni_scores) == len(uni_vocab))

// T27: unigram encode produces valid IDs
let uids27 = tok_uni_encode("hello", uni_vocab, uni_scores)
check("T27 unigram encode non-empty", len(uids27) > 0)
let mut all_valid_27 = true
let n27 = len(uids27)
let mut i27 = 0
while i27 < n27 {
    if uids27[i27] < 0 { all_valid_27 = false }
    i27 = i27 + 1
}
check("T27b all unigram IDs >= 0", all_valid_27)

// T28: unigram decode reconstructs text
let udec28 = tok_uni_decode(uids27, uni_vocab)
check("T28 unigram decode reconstructs 'hello'", udec28 == "hello")

// T29: unigram encode_special wraps BOS/EOS
let uids29 = tok_uni_encode_special("hello", uni_vocab, uni_scores)
check("T29 uni starts with BOS", uids29[0] == tok_bos_id())
check("T29b uni ends with EOS", uids29[len(uids29) - 1] == tok_eos_id())

// T30: pad_sequence pads to length
let padded30 = tok_pad_sequence([10, 20], 5)
check("T30 padded len = 5", len(padded30) == 5)
check("T30b pad tokens are PAD_ID", padded30[2] == tok_pad_id())
check("T30c original preserved", padded30[0] == 10)

// T31: pad_sequence truncates if longer
let trunc31 = tok_pad_sequence([10, 20, 30, 40, 50], 3)
check("T31 truncated len = 3", len(trunc31) == 3)
check("T31b first preserved", trunc31[0] == 10)

// T32: truncate shortens sequence
let trunc32 = tok_truncate([1, 2, 3, 4, 5], 2)
check("T32 truncate len = 2", len(trunc32) == 2)
check("T32b truncate preserves order", trunc32[1] == 2)

// T33: batch_encode encodes multiple texts
let batch33 = tok_bpe_batch_encode(["hello", "world"], test_vocab, test_merges)
check("T33 batch has 2 entries", len(batch33) == 2)
check("T33b first entry non-empty", len(batch33[0]) > 0)

// T34: vocab_size returns correct count
check("T34 vocab_size", tok_vocab_size(test_vocab) == len(test_vocab))

// T35: id_to_str and str_to_id roundtrip
let id35 = tok_str_to_id("hello", test_vocab)
let str35 = tok_id_to_str(id35, test_vocab)
check("T35 str_to_id -> id_to_str roundtrip", str35 == "hello")

// ═══════════════════════════════════════════════════════════════
println("")
println("=== tokenizer test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
