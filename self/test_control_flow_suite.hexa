// ═══════════════════════════════════════════════════════════════════
//  test_control_flow_suite.hexa — control flow construct proofs
//  if/else, while, for, break/continue, early return, function calls.
//  Last verified: 2026-04-11
// ═══════════════════════════════════════════════════════════════════

// ── Basic if/else ───────────────────────────────────────────

proof cf001_if_true {
    let x = if true { 1 } else { 0 }
    assert x == 1
}
proof cf002_if_false {
    let x = if false { 1 } else { 0 }
    assert x == 0
}
proof cf003_if_compare {
    let n = 6
    let cls = if n < 5 { "low" } else { "high" }
    assert cls == "high"
}
proof cf004_if_equal {
    let n = 6
    let is_six = if n == 6 { true } else { false }
    assert is_six
}
proof cf005_if_nested {
    let n = 6
    let result = if n < 5 { 1 } else { if n < 10 { 2 } else { 3 } }
    assert result == 2
}
proof cf006_if_else_if {
    let n = 12
    let cls = if n == 6 { "six" } else { if n == 12 { "twelve" } else { "other" } }
    assert cls == "twelve"
}
proof cf007_if_in_fn {
    fn sign(x) { if x > 0 { return 1 } else { if x < 0 { return -1 } else { return 0 } } }
    assert sign(5) == 1
}
proof cf008_if_no_else {
    let mut x = 0
    if true { x = 42 }
    assert x == 42
}
proof cf009_if_chain_else {
    let n = 100
    let cls = if n < 10 { "s" } else { if n < 100 { "m" } else { "l" } }
    assert cls == "l"
}
proof cf010_if_bool_var {
    let flag = true
    let val = if flag { 6 } else { 0 }
    assert val == 6
}

// ── While loops ─────────────────────────────────────────────

proof cf011_while_count {
    let mut i = 0
    while i < 10 { i = i + 1 }
    assert i == 10
        i = i + 1
}
proof cf012_while_sum {
    let mut s = 0
    let mut i = 1
    while i <= 10 { s = s + i; i = i + 1 }
    assert s == 55
}
proof cf013_while_zero {
    let mut i = 0
    while i < 0 { i = i + 1 }
    assert i == 0
        i = i + 1
}
proof cf014_while_product {
    let mut p = 1
    let mut i = 1
    while i <= 5 { p = p * i; i = i + 1 }
    assert p == 120
}
proof cf015_while_countdown {
    let mut i = 10
    while i > 0 { i = i - 1 }
    assert i == 0
}
proof cf016_while_factorial {
    let mut f = 1
    let mut i = 1
    while i <= 6 { f = f * i; i = i + 1 }
    assert f == 720
}
proof cf017_while_n6 {
    let mut s = 0
    let mut i = 1
    while i <= 6 { s = s + i; i = i + 1 }
    assert s == 21
}
proof cf018_while_divisors_6 {
    let mut s = 0
    let mut i = 1
    while i <= 6 {
        if 6 % i == 0 { s = s + i }
        i = i + 1
    }
    assert s == 12
}
proof cf019_while_even_sum {
    let mut s = 0
    let mut i = 0
    while i <= 10 {
        if i % 2 == 0 { s = s + i }
        i = i + 1
    }
    assert s == 30
}
proof cf020_while_odd_sum {
    let mut s = 0
    let mut i = 1
    while i <= 10 {
        if i % 2 == 1 { s = s + i }
        i = i + 1
    }
    assert s == 25
}

// ── For-in loops on arrays ──────────────────────────────────

proof cf021_for_count {
    let mut c = 0
    for v in [10, 20, 30] { c = c + 1 }
    assert c == 3
}
proof cf022_for_sum {
    let mut s = 0
    for v in [1, 2, 3, 4, 5] { s = s + v }
    assert s == 15
}
proof cf023_for_mul {
    let mut p = 1
    for v in [1, 2, 3, 4] { p = p * v }
    assert p == 24
}
proof cf024_for_max {
    let mut m = -999
    for v in [3, 1, 4, 1, 5, 9, 2, 6] { if v > m { m = v } }
    assert m == 9
}
proof cf025_for_min {
    let mut m = 999
    for v in [3, 1, 4, 1, 5, 9, 2, 6] { if v < m { m = v } }
    assert m == 1
}
proof cf026_for_with_cond {
    let mut count = 0
    for v in [1, 2, 3, 4, 5, 6] { if v > 3 { count = count + 1 } }
    assert count == 3
}
proof cf027_for_nested_sum {
    let mut s = 0
    for i in [1, 2, 3] {
        for j in [1, 2, 3] {
            s = s + i * j
        }
    }
    assert s == 36
}
proof cf028_for_six {
    let mut s = 0
    for v in [1, 2, 3, 4, 5, 6] { s = s + v }
    assert s == 21
}
proof cf029_for_strings {
    let mut total_len = 0
    for v in ["a", "bb", "ccc"] { total_len = total_len + v.len() }
    assert total_len == 6
}
proof cf030_for_on_singleton {
    let mut sum = 0
    for v in [42] { sum = sum + v }
    assert sum == 42
}

// ── Range for loops ─────────────────────────────────────────

proof cf031_range_count_10 {
    let mut c = 0
    let mut i = 0

    while i < 10 { c = c + 1 }
    assert c == 10
}
proof cf032_range_sum_6 {
    let mut s = 0
    let mut i = 0

    while i < 6 { s = s + i }
    assert s == 15
}
proof cf033_range_sum_100 {
    let mut s = 0
    let mut i = 0

    while i < 100 { s = s + i }
    assert s == 4950
}
proof cf034_range_offset {
    let mut s = 0
    let mut i = 10

    while i < 20 { s = s + i }
    assert s == 145
}
proof cf035_range_empty {
    let mut c = 0
    let mut i = 5

    while i < 5 { c = c + 1 }
    assert c == 0
}
proof cf036_range_single {
    let mut c = 0
    let mut i = 0

    while i < 1 { c = c + 1 }
    assert c == 1
}
proof cf037_range_cnt_large {
    let mut c = 0
    let mut i = 0

    while i < 1000 { c = c + 1 }
    assert c == 1000
}
proof cf038_range_sq_sum {
    let mut s = 0
    let mut i = 1

    while i < 7 { s = s + i * i }
    assert s == 91
}
proof cf039_range_cube_sum {
    let mut s = 0
    let mut i = 1

    while i < 7 { s = s + i * i * i }
    assert s == 441
}
proof cf040_range_double_sum {
    let mut s = 0
    let mut i = 0

    while i < 10 { s = s + 2 * i }
    assert s == 90
}

// ── Early return ────────────────────────────────────────────

fn find_first_even(arr) {
    for v in arr {
        if v % 2 == 0 { return v }
    }
    return -1
}

fn find_greater_than(arr, threshold) {
    for v in arr {
        if v > threshold { return v }
    }
    return -1
}

proof cf041_early_return_found { assert find_first_even([1, 3, 4, 5]) == 4 }
proof cf042_early_return_missing { assert find_first_even([1, 3, 5, 7]) == -1 }
proof cf043_early_return_first { assert find_first_even([2, 4, 6]) == 2 }
proof cf044_threshold_found { assert find_greater_than([1, 2, 3, 4, 5], 3) == 4 }
proof cf045_threshold_missing { assert find_greater_than([1, 2, 3], 10) == -1 }

// ── Nested control ──────────────────────────────────────────

proof cf046_nested_while_if {
    let mut s = 0
    let mut i = 0
    while i < 10 {
        if i % 2 == 0 { s = s + i }
        i = i + 1
    }
    assert s == 20
}
proof cf047_triple_nested {
    let mut c = 0
    let mut i = 0

    while i < 3 {
        let mut j = 0

        while j < 3 {
            let mut k = 0

            while k < 3 {
                c = c + 1
            }
        }
    }
    assert c == 27
}
proof cf048_while_in_for {
    let mut total = 0
    for v in [1, 2, 3] {
        let mut k = 0
        while k < v { k = k + 1; total = total + 1 }
            k = k + 1
    }
    assert total == 6
}
proof cf049_for_in_while {
    let mut s = 0
    let mut outer = 0
    while outer < 3 {
        for v in [1, 2, 3] { s = s + v }
        outer = outer + 1
    }
    assert s == 18
}
proof cf050_nested_3_levels {
    let mut s = 0
    let mut i = 1

    while i < 4 {
        let mut j = 1

        while j < 4 {
            s = s + i * j
        }
    }
    // (1+2+3)*(1+2+3) = 36
    assert s == 36
}

// ── Recursive function proofs ───────────────────────────────

// decreases n — structural
fn factorial_rec(n) {
    if n <= 1 { return 1 }
    return n * factorial_rec(n - 1)
}

// decreases n — structural
fn fib_rec(n) {
    if n <= 1 { return n }
    return fib_rec(n - 1) + fib_rec(n - 2)
}

// decreases n — structural
fn sum_rec(n) {
    if n <= 0 { return 0 }
    return n + sum_rec(n - 1)
}

proof cf051_fact_rec_0 { assert factorial_rec(0) == 1 }
proof cf052_fact_rec_1 { assert factorial_rec(1) == 1 }
proof cf053_fact_rec_2 { assert factorial_rec(2) == 2 }
proof cf054_fact_rec_3 { assert factorial_rec(3) == 6 }
proof cf055_fact_rec_4 { assert factorial_rec(4) == 24 }
proof cf056_fact_rec_5 { assert factorial_rec(5) == 120 }
proof cf057_fact_rec_6 { assert factorial_rec(6) == 720 }
proof cf058_fib_rec_6 { assert fib_rec(6) == 8 }
proof cf059_fib_rec_7 { assert fib_rec(7) == 13 }
proof cf060_sum_rec_6 { assert sum_rec(6) == 21 }
proof cf061_sum_rec_10 { assert sum_rec(10) == 55 }
proof cf062_sum_rec_0 { assert sum_rec(0) == 0 }

// ── Mutation semantics ──────────────────────────────────────

proof cf063_let_mut_basic {
    let mut x = 5
    x = x + 1
    assert x == 6
}
proof cf064_let_mut_loop {
    let mut x = 0
    let mut i = 0

    while i < 6 { x = x + i }
    assert x == 15
}
proof cf065_let_mut_cond {
    let mut x = 0
    if true { x = 42 }
    assert x == 42
}
proof cf066_let_mut_fn {
    fn increment(n) { return n + 1 }
    let mut x = 5
    x = increment(x)
    assert x == 6
}
proof cf067_let_mut_chain {
    let mut x = 1
    x = x + 1
    x = x * 2
    x = x - 3
    assert x == 1    // (1+1)*2-3 = 1
}

// ── Complex control flow ────────────────────────────────────

proof cf068_classify_n6 {
    let n = 6
    let cls = if n < 0 { "negative" } else { if n == 0 { "zero" } else { if n < 10 { "single" } else { "big" } } }
    assert cls == "single"
}
proof cf069_find_6_in_arr {
    let arr = [1, 2, 3, 4, 5, 6, 7, 8]
    let mut found = false
    for v in arr { if v == 6 { found = true } }
    assert found
}
proof cf070_count_even_to_20 {
    let mut c = 0
    let mut i = 0
    while i <= 20 {
        if i % 2 == 0 { c = c + 1 }
        i = i + 1
    }
    assert c == 11    // 0,2,4,...,20
}
proof cf071_count_divisors_of_12 {
    let mut c = 0
    let mut i = 1
    while i <= 12 {
        if 12 % i == 0 { c = c + 1 }
        i = i + 1
    }
    assert c == 6    // tau(12)=6
}
proof cf072_sum_divisors_of_24 {
    let mut s = 0
    let mut i = 1
    while i <= 24 {
        if 24 % i == 0 { s = s + i }
        i = i + 1
    }
    assert s == 60    // sigma(24)=60
}
proof cf073_first_n_primes {
    fn is_prime_local(n) {
        if n < 2 { return false }
        if n == 2 { return true }
        if n % 2 == 0 { return false }
        let mut j = 3
        while j * j <= n {
            if n % j == 0 { return false }
            j = j + 2
        }
        return true
    }
    let mut c = 0
    let mut i = 2
    while i <= 30 { if is_prime_local(i) { c = c + 1 }; i = i + 1 }
    assert c == 10    // primes 2..29
}
proof cf074_fib_via_loop {
    let mut a = 0
    let mut b = 1
    let mut i = 0
    while i < 6 {
        let c = a + b
        a = b
        b = c
        i = i + 1
    }
    assert b == 13    // F_7 = 13
}
proof cf075_collatz_6 {
    // Collatz from 6: 6→3→10→5→16→8→4→2→1 (length 8)
    let mut n = 6
    let mut steps = 0
    while n != 1 {
        if n % 2 == 0 { n = n / 2 } else { n = 3 * n + 1 }
        steps = steps + 1
    }
    assert steps == 8
}
proof cf076_collatz_4 {
    let mut n = 4
    let mut steps = 0
    while n != 1 {
        if n % 2 == 0 { n = n / 2 } else { n = 3 * n + 1 }
        steps = steps + 1
    }
    assert steps == 2    // 4→2→1
}
proof cf077_collatz_5 {
    let mut n = 5
    let mut steps = 0
    while n != 1 {
        if n % 2 == 0 { n = n / 2 } else { n = 3 * n + 1 }
        steps = steps + 1
    }
    assert steps == 5    // 5→16→8→4→2→1
}
proof cf078_find_first_abundant {
    fn sigma_n(n) {
        let mut s = 0
        let mut i = 1
        while i <= n { if n % i == 0 { s = s + i }; i = i + 1 }
        return s
    }
    let mut i = 1
    let mut found = 0
    while i <= 20 {
        if sigma_n(i) > 2 * i && found == 0 { found = i }
        i = i + 1
    }
    assert found == 12    // 12 is first abundant
}
proof cf079_find_first_perfect {
    fn sigma_n(n) {
        let mut s = 0
        let mut i = 1
        while i <= n { if n % i == 0 { s = s + i }; i = i + 1 }
        return s
    }
    let mut i = 1
    let mut found = 0
    while i <= 30 {
        if sigma_n(i) == 2 * i && found == 0 { found = i }
        i = i + 1
    }
    assert found == 6    // 6 is first perfect
}
proof cf080_count_perfect_under_500 {
    fn sigma_n(n) {
        let mut s = 0
        let mut i = 1
        while i <= n { if n % i == 0 { s = s + i }; i = i + 1 }
        return s
    }
    let mut cnt = 0
    let mut i = 1
    while i <= 500 {
        if sigma_n(i) == 2 * i { cnt = cnt + 1 }
        i = i + 1
    }
    assert cnt == 3    // 6, 28, 496
}

println("[test_control_flow_suite] 80 proofs declared")
