// ═══════════════════════════════════════════════════════════════════
//  test_reducer_pure.hexa — coverage for self/runtime/reducer_pure.hexa
//
//  Tests: checked_sum_pure, min_by_pure, max_by_pure,
//         group_consecutive_pure, pairwise_pure
//
//  (codegen import not wired for test files; inline the module body,
//   same pattern as test_bitops_pure.hexa / test_bit_pure.hexa.)
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from self/runtime/reducer_pure.hexa ──

@pure
fn _reducer_i64_max() { return 9223372036854775807 }

@pure
fn _reducer_i64_min() { return 0 - 9223372036854775807 - 1 }

@pure
fn _reducer_checked_add(a, b) {
    let hi = _reducer_i64_max()
    let lo = _reducer_i64_min()
    if b > 0 {
        if a > hi - b { return nil }
    }
    if b < 0 {
        if a < lo - b { return nil }
    }
    return a + b
}

@pure
fn checked_sum_pure(arr) {
    if type_of(arr) != "array" { return 0 }
    let mut s = 0
    let n = len(arr)
    let mut i = 0
    while i < n {
        let next = _reducer_checked_add(s, arr[i])
        if type_of(next) == "void" { return nil }
        s = next
        i = i + 1
    }
    return s
}

@pure
fn min_by_pure(arr, key_fn) {
    if type_of(arr) != "array" { return nil }
    let n = len(arr)
    if n == 0 { return nil }
    let mut best_val = arr[0]
    let mut best_key = key_fn(best_val)
    let mut i = 1
    while i < n {
        let v = arr[i]
        let k = key_fn(v)
        if k < best_key {
            best_val = v
            best_key = k
        }
        i = i + 1
    }
    return [best_val, best_key]
}

@pure
fn max_by_pure(arr, key_fn) {
    if type_of(arr) != "array" { return nil }
    let n = len(arr)
    if n == 0 { return nil }
    let mut best_val = arr[0]
    let mut best_key = key_fn(best_val)
    let mut i = 1
    while i < n {
        let v = arr[i]
        let k = key_fn(v)
        if k > best_key {
            best_val = v
            best_key = k
        }
        i = i + 1
    }
    return [best_val, best_key]
}

@pure
fn group_consecutive_pure(arr, eq_fn) {
    let mut out = []
    if type_of(arr) != "array" { return out }
    let n = len(arr)
    if n == 0 { return out }
    let mut cur = [arr[0]]
    let mut i = 1
    while i < n {
        let v = arr[i]
        let prev = arr[i - 1]
        if eq_fn(prev, v) {
            cur.push(v)
        } else {
            out.push(cur)
            cur = [v]
        }
        i = i + 1
    }
    out.push(cur)
    return out
}

@pure
fn pairwise_pure(arr) {
    let mut out = []
    if type_of(arr) != "array" { return out }
    let n = len(arr)
    if n < 2 { return out }
    let mut i = 0
    while i < n - 1 {
        out.push([arr[i], arr[i + 1]])
        i = i + 1
    }
    return out
}

// ── END inlined ────────────────────────────────────────────────────

// ── tiny key/eq helpers (top-level fns; closures avoided for interp
//    stability — see pitfall P13 on closure capture of mutables) ──
@pure
fn key_identity(x) { return x }

@pure
fn key_negate(x) { return 0 - x }

@pure
fn key_abs(x) { if x < 0 { return 0 - x } else { return x } }

@pure
fn key_len(s) { return len(s) }

@pure
fn eq_int(a, b) { return a == b }

@pure
fn eq_parity(a, b) {
    let ap = a - (a / 2) * 2
    let bp = b - (b / 2) * 2
    return ap == bp
}

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_nil(name, actual) {
    if type_of(actual) == "void" {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected nil, got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Reducer / Iterator Tests")
println("═══════════════════════════════════════════════════════")
println("")

let I64_MAX = 9223372036854775807
let I64_MIN = 0 - 9223372036854775807 - 1

// ── checked_sum_pure ───────────────────────────────────────────────
println("--- checked_sum_pure ---")
check("sum []",             checked_sum_pure([]),                 0)
check("sum [42]",           checked_sum_pure([42]),               42)
check("sum [1,2,3,4,5]",    checked_sum_pure([1, 2, 3, 4, 5]),    15)
check("sum [-1,-2,-3]",     checked_sum_pure([-1, -2, -3]),       -6)
check("sum mixed",          checked_sum_pure([10, -5, 7, -2]),    10)
check("sum zeros",          checked_sum_pure([0, 0, 0, 0]),       0)
check("sum MAX+0",          checked_sum_pure([I64_MAX, 0]),       I64_MAX)
check("sum MAX-1 then 1",   checked_sum_pure([I64_MAX - 1, 1]),   I64_MAX)
check_nil("sum MAX+1 overflow",    checked_sum_pure([I64_MAX, 1]))
check_nil("sum 1+MAX overflow",    checked_sum_pure([1, I64_MAX]))
check_nil("sum MIN+-1 underflow",  checked_sum_pure([I64_MIN, -1]))
check_nil("sum MAX+MAX overflow",  checked_sum_pure([I64_MAX, I64_MAX]))
check("sum non-array -> 0",  checked_sum_pure("not an array"),     0)

// ── min_by_pure ────────────────────────────────────────────────────
println("")
println("--- min_by_pure ---")
check_nil("min_by []",  min_by_pure([], key_identity))
check("min_by [5]",             min_by_pure([5], key_identity),              [5, 5])
check("min_by [3,1,4,1,5,9]",   min_by_pure([3, 1, 4, 1, 5, 9], key_identity), [1, 1])
check("min_by negate (argmax)", min_by_pure([3, 1, 4, 1, 5, 9], key_negate), [9, -9])
check("min_by abs on signed",   min_by_pure([-5, 3, -2, 7], key_abs),        [-2, 2])
check("min_by length (strings)", min_by_pure(["apple", "pi", "kiwi", "fig"], key_len), ["pi", 2])
check("min_by ties keep first", min_by_pure([2, 1, 3, 1], key_identity),     [1, 1])
check_nil("min_by non-array",   min_by_pure(42, key_identity))

// ── max_by_pure ────────────────────────────────────────────────────
println("")
println("--- max_by_pure ---")
check_nil("max_by []",  max_by_pure([], key_identity))
check("max_by [5]",             max_by_pure([5], key_identity),              [5, 5])
check("max_by [3,1,4,1,5,9]",   max_by_pure([3, 1, 4, 1, 5, 9], key_identity), [9, 9])
check("max_by negate (argmin)", max_by_pure([3, 1, 4, 1, 5, 9], key_negate), [1, -1])
check("max_by abs on signed",   max_by_pure([-5, 3, -2, 7], key_abs),        [7, 7])
check("max_by length (strings)", max_by_pure(["apple", "pi", "kiwi", "fig"], key_len), ["apple", 5])
check("max_by ties keep first", max_by_pure([2, 5, 3, 5], key_identity),     [5, 5])
check_nil("max_by non-array",   max_by_pure(42, key_identity))

// ── group_consecutive_pure ─────────────────────────────────────────
println("")
println("--- group_consecutive_pure ---")
check("group []",            group_consecutive_pure([], eq_int),  [])
check("group [7]",           group_consecutive_pure([7], eq_int), [[7]])
check("group all equal",     group_consecutive_pure([2, 2, 2, 2], eq_int), [[2, 2, 2, 2]])
check("group all distinct",  group_consecutive_pure([1, 2, 3], eq_int),    [[1], [2], [3]])
check("group classic run",   group_consecutive_pure([1, 1, 2, 2, 2, 3, 1, 1], eq_int),
                             [[1, 1], [2, 2, 2], [3], [1, 1]])
check("group by parity",     group_consecutive_pure([1, 3, 5, 2, 4, 7], eq_parity),
                             [[1, 3, 5], [2, 4], [7]])
check("group non-array",     group_consecutive_pure(42, eq_int),           [])

// ── pairwise_pure ──────────────────────────────────────────────────
println("")
println("--- pairwise_pure ---")
check("pairwise []",          pairwise_pure([]),           [])
check("pairwise [7]",         pairwise_pure([7]),          [])
check("pairwise [1,2]",       pairwise_pure([1, 2]),       [[1, 2]])
check("pairwise [1,2,3,4]",   pairwise_pure([1, 2, 3, 4]), [[1, 2], [2, 3], [3, 4]])
check("pairwise dup",         pairwise_pure([5, 5, 5]),    [[5, 5], [5, 5]])
check("pairwise strings",     pairwise_pure(["a", "b", "c"]), [["a", "b"], ["b", "c"]])
check("pairwise non-array",   pairwise_pure(42),           [])

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
