// ═══════════════════════════════════════════════════════════════════
//  self/test_matmul_fused.hexa — @matmul_fused prototype tests
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ml/matmul_fused.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/matmul_fused.hexa — @matmul_fused prototype (pure .hexa)
//
//  AI-native CPU optimization P2: matmul + activation kernel fusion.
//  Single-pass loop computes dot-product then applies activation
//  inline, eliminating the intermediate [M x N] tensor allocation
//  that a separate `matmul -> activation` pipeline would create.
//
//  API:
//    matmul_relu(A, B, M, K, N)          -> Tensor [M x N]
//    matmul_silu(A, B, M, K, N)          -> Tensor [M x N]   (x * sigmoid(x))
//    matmul_gelu(A, B, M, K, N)          -> Tensor [M x N]   (tanh approx)
//    fused_mm_act(A, B, kind, M, K, N)   -> Tensor [M x N]
//        kind: 0=relu, 1=silu, 2=gelu
//
//  The @matmul_fused attribute is parser-accepted for forward
//  compatibility; fusion here is provided explicitly in .hexa.
// ═══════════════════════════════════════════════════════════════════

// ── scalar activation helpers (inlined by interpreter) ─────────
fn _act_relu(x) {
    if x > 0.0 { x } else { 0.0 }
}

fn _act_silu(x) {
    let s = 1.0 / (1.0 + exp(-1.0 * x))
    x * s
}

// GELU (tanh approximation):
//   0.5 * x * (1 + tanh( sqrt(2/pi) * (x + 0.044715 * x^3) ))
fn _act_gelu(x) {
    let c = 0.7978845608028654   // sqrt(2/pi)
    let x3 = x * x * x
    let u = c * (x + 0.044715 * x3)
    let e_pos = exp(u)
    let e_neg = exp(-1.0 * u)
    let th = (e_pos - e_neg) / (e_pos + e_neg)
    0.5 * x * (1.0 + th)
}

// ── matmul + ReLU fused ────────────────────────────────────────
fn matmul_relu(A, B, M, K, N) {
    let mut out = []
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                acc = acc + A[i * K + k] * B[k * N + j]
                k = k + 1
            }
            out = out.push(_act_relu(acc))
            j = j + 1
        }
        i = i + 1
    }
    tensor(out, [M, N])
}

// ── matmul + SiLU fused ────────────────────────────────────────
fn matmul_silu(A, B, M, K, N) {
    let mut out = []
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                acc = acc + A[i * K + k] * B[k * N + j]
                k = k + 1
            }
            out = out.push(_act_silu(acc))
            j = j + 1
        }
        i = i + 1
    }
    tensor(out, [M, N])
}

// ── matmul + GELU fused ────────────────────────────────────────
fn matmul_gelu(A, B, M, K, N) {
    let mut out = []
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                acc = acc + A[i * K + k] * B[k * N + j]
                k = k + 1
            }
            out = out.push(_act_gelu(acc))
            j = j + 1
        }
        i = i + 1
    }
    tensor(out, [M, N])
}

// ── Dispatch: fused matmul+activation ──────────────────────────
// act_kind: 0=relu, 1=silu, 2=gelu
@matmul_fused
fn fused_mm_act(A, B, act_kind, M, K, N) {
    if act_kind == 0 { return matmul_relu(A, B, M, K, N) }
    if act_kind == 1 { return matmul_silu(A, B, M, K, N) }
    if act_kind == 2 { return matmul_gelu(A, B, M, K, N) }
    // default: plain matmul wrapped as tensor
    let result_arr = matmul(A, B, M, K, N)
    tensor(result_arr, [M, N])
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn approx_eq(a, b) {
    let d = a - b
    let ad = if d < 0.0 { -1.0 * d } else { d }
    ad < 0.000001
}

fn tensors_equal(a, b) {
    if len(a) != len(b) { return false }
    let n = len(a)
    let mut i = 0
    while i < n {
        if !approx_eq(a[i], b[i]) { return false }
        i = i + 1
    }
    true
}

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// Reference activations (scalar, identical formulas)
fn ref_relu(x) {
    if x > 0.0 { x } else { 0.0 }
}
fn ref_silu(x) {
    let s = 1.0 / (1.0 + exp(-1.0 * x))
    x * s
}
fn ref_gelu(x) {
    let c = 0.7978845608028654
    let x3 = x * x * x
    let u = c * (x + 0.044715 * x3)
    let e_pos = exp(u)
    let e_neg = exp(-1.0 * u)
    let th = (e_pos - e_neg) / (e_pos + e_neg)
    0.5 * x * (1.0 + th)
}

// Dense matmul baseline then apply activation -> flat array -> tensor
fn baseline_mm_act(A, B, M, K, N, kind) {
    let flat = matmul(A, B, M, K, N)
    let total = M * N
    let mut out = []
    let mut i = 0
    while i < total {
        let v = flat[i]
        if kind == 0 { out = out.push(ref_relu(v)) }
        if kind == 1 { out = out.push(ref_silu(v)) }
        if kind == 2 { out = out.push(ref_gelu(v)) }
        i = i + 1
    }
    tensor(out, [M, N])
}

println("═══════════════════════════════════════════════════════")
println("  @matmul_fused prototype tests")
println("═══════════════════════════════════════════════════════")

// ── Test matrices ──────────────────────────────────────────────
// A: 2x3, B: 3x2, result 2x2
// Values chosen to yield both positive and negative entries so
// ReLU actually activates.
let A = [
    1.0, -2.0, 0.5,
    -0.5, 1.5, 2.0
]
let B = [
    0.5, -1.0,
    1.0, 0.5,
    -2.0, 1.5
]
let M = 2
let K = 3
let N = 2

// ── ReLU fused ─────────────────────────────────────────────────
let ref_r = baseline_mm_act(A, B, M, K, N, 0)
let fus_r = matmul_relu(A, B, M, K, N)
check("matmul_relu == baseline (ReLU)", tensors_equal(fus_r, ref_r))

// ── SiLU fused ─────────────────────────────────────────────────
let ref_s = baseline_mm_act(A, B, M, K, N, 1)
let fus_s = matmul_silu(A, B, M, K, N)
check("matmul_silu == baseline (SiLU)", tensors_equal(fus_s, ref_s))

// ── GELU fused ─────────────────────────────────────────────────
let ref_g = baseline_mm_act(A, B, M, K, N, 2)
let fus_g = matmul_gelu(A, B, M, K, N)
check("matmul_gelu == baseline (GELU)", tensors_equal(fus_g, ref_g))

// ── Dispatch: fused_mm_act ─────────────────────────────────────
let disp_r = fused_mm_act(A, B, 0, M, K, N)
check("fused_mm_act(kind=0) == ReLU baseline", tensors_equal(disp_r, ref_r))

let disp_s = fused_mm_act(A, B, 1, M, K, N)
check("fused_mm_act(kind=1) == SiLU baseline", tensors_equal(disp_s, ref_s))

let disp_g = fused_mm_act(A, B, 2, M, K, N)
check("fused_mm_act(kind=2) == GELU baseline", tensors_equal(disp_g, ref_g))

// ── Shape check ────────────────────────────────────────────────
check("fused result length == M*N", len(fus_r) == M * N)

// ── ReLU zero-clamp sanity: all outputs >= 0 ───────────────────
fn all_non_negative(t) {
    let n = len(t)
    let mut i = 0
    let mut ok = true
    while i < n {
        if t[i] < 0.0 { ok = false }
        i = i + 1
    }
    ok
}
check("matmul_relu output >= 0", all_non_negative(fus_r))

println("═══════════════════════════════════════════════════════")
println("  PASS: " + str(pass_count) + "  FAIL: " + str(fail_count))
println("═══════════════════════════════════════════════════════")
println(to_string(pass_count) + " passed")
