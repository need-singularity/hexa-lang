// ═══════════════════════════════════════════════════════════
//  test_ownership_lifecycle.hexa — Ownership & Lifecycle Tests
//  Tests: own, borrow, move, drop, copy semantics, reference
//         counting patterns, lifecycle tracking, scope-based cleanup
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Ownership & Lifecycle Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Own keyword ───────────────────────────────────────

println("--- own keyword ---")

let v1 = 42
own v1
check("own int value", v1, 42)

let v2 = "hello"
own v2
check("own string value", v2, "hello")

let v3 = [1, 2, 3]
own v3
check("own array value", to_string(v3), to_string([1, 2, 3]))

let v4 = true
own v4
check("own bool value", v4, true)

// ── 2. Borrow keyword ───────────────────────────────────

println("")
println("--- borrow keyword ---")

let b1 = 100
borrow b1
check("borrow int", b1, 100)

let b2 = "world"
borrow b2
check("borrow string", b2, "world")

let b3 = [10, 20, 30]
borrow b3
check("borrow array len", len(b3), 3)
check("borrow array access", b3[1], 20)

// ── 3. Move keyword ─────────────────────────────────────

println("")
println("--- move keyword ---")

// After move, original is inaccessible — verify via try/catch
let m1 = [1, 2, 3]
let m1_len = len(m1)
move m1
let mut m1_moved = false
try {
    let x = m1[0]
} catch e {
    m1_moved = true
}
check("move array invalidates", m1_moved, true)
check("move array had len 3", m1_len, 3)

let m2 = "moved_str"
let m2_copy = m2
move m2
let mut m2_moved = false
try {
    let x = m2 + "!"
} catch e {
    m2_moved = true
}
check("move string invalidates", m2_moved, true)
check("pre-move copy survives", m2_copy, "moved_str")

let m3 = 999
move m3
let mut m3_moved = false
try {
    let x = m3 + 1
} catch e {
    m3_moved = true
}
check("move int invalidates", m3_moved, true)

// ── 4. Drop keyword ─────────────────────────────────────

println("")
println("--- drop keyword ---")

let d1 = "temporary"
drop d1
check("drop executed", true, true)

let d2 = [1, 2, 3, 4, 5]
drop d2
check("drop array executed", true, true)

let d3 = #{"key": "value"}
drop d3
check("drop map executed", true, true)

// ── 5. Simulated RC lifecycle ────────────────────────────

println("")
println("--- RC Lifecycle Simulation ---")

let mut rc_vals = []
let mut rc_refs = []
let mut rc_live = []

fn rc_new(val) {
    let idx = len(rc_vals)
    rc_vals = rc_vals.push(val)
    rc_refs = rc_refs.push(1)
    rc_live = rc_live.push(true)
    return idx
}

fn rc_clone(h) {
    if h >= 0 && h < len(rc_refs) && rc_live[h] {
        rc_refs[h] = rc_refs[h] + 1
    }
}

fn rc_drop(h) {
    if h >= 0 && h < len(rc_refs) && rc_live[h] {
        rc_refs[h] = rc_refs[h] - 1
        if rc_refs[h] <= 0 {
            rc_live[h] = false
        }
    }
}

fn rc_get(h) {
    if h >= 0 && h < len(rc_vals) && rc_live[h] {
        return rc_vals[h]
    }
    return "dead"
}

fn rc_count(h) {
    if h >= 0 && h < len(rc_refs) && rc_live[h] {
        return rc_refs[h]
    }
    return 0
}

let h0 = rc_new("alpha")
check("rc new refcount", rc_count(h0), 1)
check("rc new value", rc_get(h0), "alpha")

rc_clone(h0)
check("rc clone refcount", rc_count(h0), 2)

rc_drop(h0)
check("rc drop once", rc_count(h0), 1)
check("rc still alive", rc_get(h0), "alpha")

rc_drop(h0)
check("rc fully dropped", rc_count(h0), 0)
check("rc dead value", rc_get(h0), "dead")

// ── 6. Multiple handles ──────────────────────────────────

println("")
println("--- Multiple Handles ---")

let ha = rc_new("first")
let hb = rc_new("second")
let hc = rc_new("third")

check("multi handle a", rc_get(ha), "first")
check("multi handle b", rc_get(hb), "second")
check("multi handle c", rc_get(hc), "third")

rc_clone(hb)
rc_clone(hb)
check("multi b refcount", rc_count(hb), 3)

rc_drop(ha)
check("a dropped, b alive", rc_get(hb), "second")
check("a dropped, c alive", rc_get(hc), "third")
check("a dead", rc_get(ha), "dead")

// ── 7. Scope-based lifecycle ─────────────────────────────

println("")
println("--- Scope Lifecycle ---")

let mut lifecycle_log = []

fn tracked_work() {
    lifecycle_log = lifecycle_log.push("create")
    let val = 42
    lifecycle_log = lifecycle_log.push("use")
    let result = val * 2
    lifecycle_log = lifecycle_log.push("done")
    return result
}

let tw = tracked_work()
check("tracked result", tw, 84)
check("lifecycle steps", len(lifecycle_log), 3)
check("lifecycle[0]", lifecycle_log[0], "create")
check("lifecycle[1]", lifecycle_log[1], "use")
check("lifecycle[2]", lifecycle_log[2], "done")

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL OWNERSHIP LIFECYCLE TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
