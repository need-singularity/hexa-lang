// -- inlined from self/ml/moe_active.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/moe_active.hexa — @moe_active(k, n) MoE routing prototype
//
//  Mixture of Experts with active top-k routing.
//  n개 expert 중 router score 상위 top_k만 활성화 → forward → softmax 가중합.
//
//  AI-native P2: dense MoE 대비 k/n 비율만큼 FLOPs 절감.
//    @moe_active(k, n) — 파서 수용(스텁), 실제 라우팅은 moe_forward()가 담당.
//
//  API:
//    router_scores(x, W_gate, d, n_experts)            -> [float]
//    topk(scores, k)                                   -> ([int], [float])
//    expert_forward(x, W_expert, d_in, d_out)          -> Tensor [d_out]
//    moe_forward(x, W_gate, experts_list, d, n_exp, k) -> Tensor [d]
//
//  표현:
//    x             : flat [d]
//    W_gate        : flat [n_experts x d]  row-major
//    experts_list  : [[flat [d x d]], ...]  (expert당 가중치 2D flat)
// ═══════════════════════════════════════════════════════════════════

// ── router: linear gate  scores[e] = sum_j W_gate[e,j] * x[j] ───
fn router_scores(x, W_gate, d, n_experts) {
    let mut out = []
    let mut e = 0
    while e < n_experts {
        let mut acc = 0.0
        let mut j = 0
        while j < d {
            acc = acc + W_gate[e * d + j] * x[j]
            j = j + 1
        }
        out = out.push(acc)
        e = e + 1
    }
    out
}

// ── top-k indices + softmax weights over selected ─────────────
// Returns [idx_array, weight_array] — parser-friendly pair.
fn topk(scores, k) {
    let n = len(scores)
    // track "taken" mask
    let mut taken = []
    let mut t = 0
    while t < n { taken = taken.push(false); t = t + 1 }

    let mut idxs = []
    let mut vals = []
    let mut picked = 0
    while picked < k {
        let mut best_i = -1
        let mut best_v = 0.0
        let mut i = 0
        while i < n {
            if !taken[i] {
                let v = scores[i]
                if best_i == -1 {
                    best_i = i
                    best_v = v
                } else {
                    if v > best_v {
                        best_i = i
                        best_v = v
                    }
                }
            }
            i = i + 1
        }
        taken[best_i] = true
        idxs = idxs.push(best_i)
        vals = vals.push(best_v)
        picked = picked + 1
    }

    // softmax over selected vals (numerically stable)
    let mut max_v = vals[0]
    let mut m = 1
    while m < k {
        if vals[m] > max_v { max_v = vals[m] }
        m = m + 1
    }
    let mut exps = []
    let mut sum_e = 0.0
    let mut p = 0
    while p < k {
        let e_v = exp(vals[p] - max_v)
        exps = exps.push(e_v)
        sum_e = sum_e + e_v
        p = p + 1
    }
    let mut weights = []
    let mut q = 0
    while q < k {
        weights = weights.push(exps[q] / sum_e)
        q = q + 1
    }
    [idxs, weights]
}

// ── single expert forward: y = W_expert @ x  (row-major [d_out x d_in]) ──
fn expert_forward(x, W_expert, d_in, d_out) {
    let mut out = []
    let mut i = 0
    while i < d_out {
        let mut acc = 0.0
        let mut j = 0
        while j < d_in {
            acc = acc + W_expert[i * d_in + j] * x[j]
            j = j + 1
        }
        out = out.push(acc)
        i = i + 1
    }
    tensor(out, [d_out])
}

// ── MoE forward: route → top-k → gather → weighted sum ────────
@moe_active(2, 8)
fn moe_forward(x, W_gate, experts_list, d, n_experts, top_k) {
    let scores = router_scores(x, W_gate, d, n_experts)
    let tk = topk(scores, top_k)
    let idxs = tk[0]
    let weights = tk[1]

    // accumulator of length d
    let mut y = []
    let mut z = 0
    while z < d {
        y = y.push(0.0)
        z = z + 1
    }

    let mut s = 0
    while s < top_k {
        let eid = idxs[s]
        let w_s = weights[s]
        let W_e = experts_list[eid]
        let ye = expert_forward(x, W_e, d, d)
        let mut j = 0
        while j < d {
            y[j] = y[j] + w_s * ye[j]
            j = j + 1
        }
        s = s + 1
    }
    tensor(y, [d])
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn approx_eq(a, b) {
    let d = a - b
    let ad = if d < 0.0 { -1.0 * d } else { d }
    ad < 0.00001
}

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  @moe_active MoE routing prototype tests")
println("═══════════════════════════════════════════════════════")

// ── toy config: d=4, n_experts=4, top_k=2 ───────────────────
let d = 4
let n_experts = 4
let top_k = 2

// x = [1, 1, 1, 1]
let x = [1.0, 1.0, 1.0, 1.0]

// W_gate [4 x 4] chosen so router_scores(x) = [0.1, 0.2, 10.0, 9.0]
// (each row's sum equals the target score)
let W_gate = [
    0.025, 0.025, 0.025, 0.025,
    0.05,  0.05,  0.05,  0.05,
    2.5,   2.5,   2.5,   2.5,
    2.25,  2.25,  2.25,  2.25
]

// ── Test 1: router scores ───────────────────────────────────
let scores = router_scores(x, W_gate, d, n_experts)
check("router scores length == n_experts", len(scores) == 4)
check("router score[0] ~= 0.1", approx_eq(scores[0], 0.1))
check("router score[2] ~= 10.0", approx_eq(scores[2], 10.0))
check("router score[3] ~= 9.0", approx_eq(scores[3], 9.0))

// ── Test 2: top-k selection ─────────────────────────────────
let tk = topk(scores, top_k)
let idxs = tk[0]
let weights = tk[1]
check("topk returns 2 indices", len(idxs) == 2)
check("topk[0] == 2 (highest score)", idxs[0] == 2)
check("topk[1] == 3 (second)", idxs[1] == 3)

// softmax(10, 9) stable: exps = [e^0, e^-1], sum = 1 + e^-1
// w0 = 1/(1+e^-1), w1 = e^-1/(1+e^-1)
let inv_e = exp(-1.0)
let denom = 1.0 + inv_e
let w0_expect = 1.0 / denom
let w1_expect = inv_e / denom
check("topk softmax weight[0]", approx_eq(weights[0], w0_expect))
check("topk softmax weight[1]", approx_eq(weights[1], w1_expect))

// weights sum to 1
let wsum = weights[0] + weights[1]
check("topk weights sum to 1", approx_eq(wsum, 1.0))

// ── Test 3: expert_forward (scaled identity) ────────────────
// expert_k is scale k identity [d x d]
fn make_scaled_identity(d, s) {
    let mut w = []
    let mut i = 0
    while i < d {
        let mut j = 0
        while j < d {
            if i == j {
                w = w.push(s)
            } else {
                w = w.push(0.0)
            }
            j = j + 1
        }
        i = i + 1
    }
    w
}

let E0 = make_scaled_identity(d, 1.0)
let E1 = make_scaled_identity(d, 2.0)
let E2 = make_scaled_identity(d, 3.0)
let E3 = make_scaled_identity(d, 4.0)

let y2 = expert_forward(x, E2, d, d)
check("expert_forward scale=3 -> [3,3,3,3]", approx_eq(y2[0], 3.0) && approx_eq(y2[3], 3.0))

// ── Test 4: moe_forward end-to-end ──────────────────────────
// Selected experts = E2 (scale 3), E3 (scale 4)
// y = w0 * 3 * x + w1 * 4 * x = (3*w0 + 4*w1) * x
let experts_list = [E0, E1, E2, E3]
let y = moe_forward(x, W_gate, experts_list, d, n_experts, top_k)

let expected_scale = 3.0 * w0_expect + 4.0 * w1_expect
check("moe_forward y length == d", len(y) == 4)
check("moe_forward y[0] matches expected", approx_eq(y[0], expected_scale))
check("moe_forward y[3] matches expected", approx_eq(y[3], expected_scale))
check("moe_forward output uniform across dims", approx_eq(y[0], y[1]) && approx_eq(y[1], y[2]))

println("═══════════════════════════════════════════════════════")
println("  PASS: " + to_string(pass_count) + "  FAIL: " + to_string(fail_count))
println("═══════════════════════════════════════════════════════")
println(to_string(pass_count) + " passed")
