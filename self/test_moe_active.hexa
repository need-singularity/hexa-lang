// ═══════════════════════════════════════════════════════════════════
//  self/test_moe_active.hexa — @moe_active routing tests
// ═══════════════════════════════════════════════════════════════════

import "ml/moe_active.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn approx_eq(a, b) {
    let d = a - b
    let ad = if d < 0.0 { -1.0 * d } else { d }
    ad < 0.00001
}

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  @moe_active MoE routing prototype tests")
println("═══════════════════════════════════════════════════════")

// ── toy config: d=4, n_experts=4, top_k=2 ───────────────────
let d = 4
let n_experts = 4
let top_k = 2

// x = [1, 1, 1, 1]
let x = [1.0, 1.0, 1.0, 1.0]

// W_gate [4 x 4] chosen so router_scores(x) = [0.1, 0.2, 10.0, 9.0]
// (each row's sum equals the target score)
let W_gate = [
    0.025, 0.025, 0.025, 0.025,
    0.05,  0.05,  0.05,  0.05,
    2.5,   2.5,   2.5,   2.5,
    2.25,  2.25,  2.25,  2.25
]

// ── Test 1: router scores ───────────────────────────────────
let scores = router_scores(x, W_gate, d, n_experts)
check("router scores length == n_experts", len(scores) == 4)
check("router score[0] ~= 0.1", approx_eq(scores[0], 0.1))
check("router score[2] ~= 10.0", approx_eq(scores[2], 10.0))
check("router score[3] ~= 9.0", approx_eq(scores[3], 9.0))

// ── Test 2: top-k selection ─────────────────────────────────
let tk = topk(scores, top_k)
let idxs = tk[0]
let weights = tk[1]
check("topk returns 2 indices", len(idxs) == 2)
check("topk[0] == 2 (highest score)", idxs[0] == 2)
check("topk[1] == 3 (second)", idxs[1] == 3)

// softmax(10, 9) stable: exps = [e^0, e^-1], sum = 1 + e^-1
// w0 = 1/(1+e^-1), w1 = e^-1/(1+e^-1)
let inv_e = exp(-1.0)
let denom = 1.0 + inv_e
let w0_expect = 1.0 / denom
let w1_expect = inv_e / denom
check("topk softmax weight[0]", approx_eq(weights[0], w0_expect))
check("topk softmax weight[1]", approx_eq(weights[1], w1_expect))

// weights sum to 1
let wsum = weights[0] + weights[1]
check("topk weights sum to 1", approx_eq(wsum, 1.0))

// ── Test 3: expert_forward (scaled identity) ────────────────
// expert_k is scale k identity [d x d]
fn make_scaled_identity(d, s) {
    let mut w = []
    let mut i = 0
    while i < d {
        let mut j = 0
        while j < d {
            if i == j {
                w = w.push(s)
            } else {
                w = w.push(0.0)
            }
            j = j + 1
        }
        i = i + 1
    }
    w
}

let E0 = make_scaled_identity(d, 1.0)
let E1 = make_scaled_identity(d, 2.0)
let E2 = make_scaled_identity(d, 3.0)
let E3 = make_scaled_identity(d, 4.0)

let y2 = expert_forward(x, E2, d, d)
check("expert_forward scale=3 -> [3,3,3,3]", approx_eq(y2[0], 3.0) && approx_eq(y2[3], 3.0))

// ── Test 4: moe_forward end-to-end ──────────────────────────
// Selected experts = E2 (scale 3), E3 (scale 4)
// y = w0 * 3 * x + w1 * 4 * x = (3*w0 + 4*w1) * x
let experts_list = [E0, E1, E2, E3]
let y = moe_forward(x, W_gate, experts_list, d, n_experts, top_k)

let expected_scale = 3.0 * w0_expect + 4.0 * w1_expect
check("moe_forward y length == d", len(y) == 4)
check("moe_forward y[0] matches expected", approx_eq(y[0], expected_scale))
check("moe_forward y[3] matches expected", approx_eq(y[3], expected_scale))
check("moe_forward output uniform across dims", approx_eq(y[0], y[1]) && approx_eq(y[1], y[2]))

println("═══════════════════════════════════════════════════════")
println("  PASS: " + to_string(pass_count) + "  FAIL: " + to_string(fail_count))
println("═══════════════════════════════════════════════════════")
println(to_string(pass_count) + " passed")
