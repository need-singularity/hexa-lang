// Debug: exactly where does fn call fail?
fn self_run(src) {
    let toks = tokenize(src)
    let ast = parse(toks)
    println("  parsed " + to_string(len(ast)) + " stmts")
    for s in ast {
        println("  -> " + s.kind)
    }
    interpret(ast)
}

println("═══ HEXA SELF-HOSTING ═══")

println("T1: println(42)")
self_run("println(42)")

println("T2: let + println")
self_run("let x = 30\nprintln(x)")

println("T3: fn decl only")
self_run("fn add(a, b) {\n  return a + b\n}")

println("T4: fn + call (the failing case)")
self_run("fn add(a, b) {\n  return a + b\n}\nprintln(add(3, 4))")
