// HEXA self-hosting pipeline verification
// Source → tokenize → parse → interpret — all in .hexa

fn self_run(src) {
    interpret(parse(tokenize(src)))
}

println("═══ HEXA SELF-HOSTING PIPELINE ═══")

println("1. println(42)")
self_run("println(42)")

println("2. let + arithmetic")
self_run("let x = 10 + 20\nprintln(x)")

println("3. function call")
self_run("fn add(a, b) {\n  return a + b\n}\nprintln(add(3, 4))")

println("4. if-else")
self_run("let x = 10\nif x > 5 {\n  println(x)\n}")

println("5. while loop")
self_run("let mut i = 0\nlet mut s = 0\nwhile i < 5 {\n  s = s + i\n  i = i + 1\n}\nprintln(s)")

println("6. recursive fibonacci")
self_run("fn fib(n) {\n  if n <= 1 {\n    return n\n  }\n  return fib(n - 1) + fib(n - 2)\n}\nprintln(fib(10))")

println("═══ ALL TESTS PASSED — HEXA RUNS HEXA ═══")
