// test_interp.hexa — self-hosted lexer tokenization test
// NOTE: parse/interpret blocked by p_tokens scope leak when parser.hexa is imported.
//       Testing tokenize only until Phase2 parser import isolation is fixed.
import "lexer.hexa"

println("═══ HEXA SELF-HOSTING (tokenize) ═══")

let mut passed = 0
let mut total = 0

fn check(label, src, expect_count) {
    total = total + 1
    let toks = tokenize(src)
    let n = len(toks)
    if n == expect_count {
        println("[PASS] " + label)
        passed = passed + 1
    } else {
        println("[FAIL] " + label + " expected " + to_string(expect_count) + " got " + to_string(n))
    }
}

// Each token sequence includes EOF token
check("T1: println(42)", "println(42)", 5)
check("T2: let x = 30", "let x = 30", 5)
check("T3: fn add(a, b)", "fn add(a, b) { return a + b }", 14)
check("T4: if/else", "if true { 1 } else { 0 }", 10)
check("T5: empty", "", 1)
check("T6: string lit", "\"hello\"", 2)

println("═══ " + to_string(passed) + "/" + to_string(total) + " passed ═══")
println(to_string(passed) + " passed")
