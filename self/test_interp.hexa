// test_interp.hexa — self-hosted lexer + parser test
// Sprint fix(self/parser): parser.hexa module vars are now `pub let mut`,
// so parse() can be called via import. See commit history for diagnosis.
import "lexer.hexa"
import "parser.hexa"

println("═══ HEXA SELF-HOSTING (tokenize + parse) ═══")

let mut passed = 0
let mut total = 0

fn check(label, src, expect_count) {
    total = total + 1
    let toks = tokenize(src)
    let n = len(toks)
    if n == expect_count {
        println("[PASS] " + label)
        passed = passed + 1
    } else {
        println("[FAIL] " + label + " expected " + to_string(expect_count) + " got " + to_string(n))
    }
}

// Each token sequence includes EOF token
check("T1: println(42)", "println(42)", 5)
check("T2: let x = 30", "let x = 30", 5)
check("T3: fn add(a, b)", "fn add(a, b) { return a + b }", 14)
check("T4: if/else", "if true { 1 } else { 0 }", 10)
check("T5: empty", "", 1)
check("T6: string lit", "\"hello\"", 2)

// ── Parser import tests (fix verification) ───────────────────
fn check_parse(label, src, expect_stmts) {
    total = total + 1
    let toks = tokenize(src)
    let stmts = parse(toks)
    let n = len(stmts)
    if n == expect_stmts {
        println("[PASS] " + label)
        passed = passed + 1
    } else {
        println("[FAIL] " + label + " expected " + to_string(expect_stmts) + " got " + to_string(n))
    }
}

check_parse("P1: let x = 42", "let x = 42", 1)
check_parse("P2: two lets", "let x = 1\nlet y = 2", 2)
check_parse("P3: fn + call", "fn id(a) { return a }\nprintln(id(7))", 2)

println("═══ " + to_string(passed) + "/" + to_string(total) + " passed ═══")
println(to_string(passed) + " passed")
