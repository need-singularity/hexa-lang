// shape 4: (128, 4096, 16384) — FFN up D=4096 (7B)
let M4 = 128
let K4 = 4096
let N4 = 16384

let A4 = tensor_zeros(M4 * K4)
let B4 = tensor_zeros(K4 * N4)
let _w4 = matmul(A4, B4, M4, K4, N4)
