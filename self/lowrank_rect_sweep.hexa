}
let s4b = clock()
let dense4_each = (s4b - s4a) / 3.0
let dense4_ms = dense4_each * 1000.0

let mut best4_r = 0
let mut best4_speedup = 0.0
let mut r4i = 0
let ranks4 = [8, 16, 32]
while r4i < 3 {
    let R = ranks4[r4i]
    let U = tensor_zeros(K4 * R)
    let V = tensor_zeros(R * N4)
    let _wa = matmul(A4, U, M4, K4, R)
    let _wb = matmul(_wa, V, M4, R, N4)
    let t0 = clock()
    let mut ii = 0
    while ii < ITERS {
        let T = matmul(A4, U, M4, K4, R)
        let _ = matmul(T, V, M4, R, N4)
        ii = ii + 1
    }
    let t1 = clock()
    let lr_each = (t1 - t0) / 3.0
    let lr_ms = lr_each * 1000.0
    let sp = dense4_each / lr_each
    let mut line = "{"
    line = line + "\"shape\":\"128x4096x16384\""
    line = line + ",\"M\":" + str(M4)
