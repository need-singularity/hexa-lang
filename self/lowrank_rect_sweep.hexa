    line = line + ",\"lowrank_ms\":" + str(lr_ms)
    line = line + ",\"speedup\":" + str(sp)
    line = line + "}"
    println(line)
    if sp > best4_speedup {
        best4_speedup = sp
        best4_r = R
    }
    r4i = r4i + 1
}

// global best
let mut best_shape = "128x768x768"
let mut best_r = best1_r
let mut best_speedup = best1_speedup
if best2_speedup > best_speedup {
    best_speedup = best2_speedup
    best_r = best2_r
    best_shape = "128x768x32000"
}
if best3_speedup > best_speedup {
    best_speedup = best3_speedup
    best_r = best3_r
    best_shape = "128x4096x4096"
}
if best4_speedup > best_speedup {
    best_speedup = best4_speedup
    best_r = best4_r
    best_shape = "128x4096x16384"
}

let mut summary = "{"
summary = summary + "\"summary\":\"rect_sweep\""
summary = summary + ",\"best_shape\":\"" + best_shape + "\""
summary = summary + ",\"best_r\":" + str(best_r)
summary = summary + ",\"best_speedup\":" + str(best_speedup)
summary = summary + "}"
println(summary)
