// lowrank_rect_sweep.hexa — 비대칭 matmul (M, K, N) × rank r ∈ {8,16,32} sweep
// 4 shape (QKV D=768, LM head, QKV D=4096, FFN up) × 3 rank = 12 실측
// dense: A(M×K) · B(K×N)  |  lowrank: A·U(K×R)·V(R×N) = (A·U)·V

let ITERS = 3

// shape 1: (128, 768, 768) — QKV D=768
let M1 = 128
let K1 = 768
let N1 = 768

let A1 = tensor_zeros(M1 * K1)
let B1 = tensor_zeros(K1 * N1)
let _w1 = matmul(A1, B1, M1, K1, N1)
let s1a = clock()
let mut i1 = 0
while i1 < ITERS {
    let _ = matmul(A1, B1, M1, K1, N1)
    i1 = i1 + 1
}
let s1b = clock()
let dense1_each = (s1b - s1a) / 3.0
let dense1_ms = dense1_each * 1000.0

let mut best1_r = 0
let mut best1_speedup = 0.0
let mut r1i = 0
let ranks1 = [8, 16, 32]
while r1i < 3 {
    let R = ranks1[r1i]
    let U = tensor_zeros(K1 * R)
    let V = tensor_zeros(R * N1)
    let _wa = matmul(A1, U, M1, K1, R)
    let _wb = matmul(_wa, V, M1, R, N1)
    let t0 = clock()
    let mut ii = 0
    while ii < ITERS {
        let T = matmul(A1, U, M1, K1, R)
        let _ = matmul(T, V, M1, R, N1)
        ii = ii + 1
    }
    let t1 = clock()
    let lr_each = (t1 - t0) / 3.0
    let lr_ms = lr_each * 1000.0
    let sp = dense1_each / lr_each
    let mut line = "{"
    line = line + "\"shape\":\"128x768x768\""
    line = line + ",\"M\":" + str(M1)
    line = line + ",\"K\":" + str(K1)
    line = line + ",\"N\":" + str(N1)
    line = line + ",\"R\":" + str(R)
    line = line + ",\"dense_ms\":" + str(dense1_ms)
    line = line + ",\"lowrank_ms\":" + str(lr_ms)
    line = line + ",\"speedup\":" + str(sp)
    line = line + "}"
    println(line)
    if sp > best1_speedup {
        best1_speedup = sp
        best1_r = R
    }
    r1i = r1i + 1
}

