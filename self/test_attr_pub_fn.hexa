// ═══════════════════════════════════════════════════════════
//  test_attr_pub_fn.hexa — ROI #158 G39 regression guard
//
//  Purpose: lock the parser shape for `@attr pub fn ...` combos.
//
//  Background:
//    - 2026-04-16 parser.hexa:714 G39 fix — absorb `Pub` after the
//      @attr collection loop so `@pure pub fn` parses cleanly.
//    - 2026-04-17 encoding agent re-reported regression via interp
//      (three-source drift: parser.hexa vs hexa_cc.c vs hexa_full.hexa).
//    - This test locks the behaviour end-to-end so any drift fails CI.
//
//  Coverage (10+ cases):
//    1.  @pure pub fn            — single attr + pub
//    2.  @doc("x") pub fn         — annotation + pub
//    3.  @cli("z") pub fn         — cli annotation + pub
//    4.  @pure @doc("d") pub fn   — two attrs + pub (combo)
//    5.  @hot pub fn              — generic attr + pub
//    6.  @inline pub fn           — generic attr + pub
//    7.  @memoize pub fn          — generic attr + pub
//    8.  @pure @inline pub fn     — two plain attrs + pub
//    9.  @doc("a") @pure pub fn   — annotation then plain attr + pub
//    10. @pure pub fn w/ newline  — newline separated @attr then pub
//    11. @pure pub fn no-args     — zero arg variant
//    12. @pure pub fn recursive   — self-call in body
//
//  Each case defines a `@attr... pub fn` and calls it, asserting the
//  return value. If the parser rejects the declaration the file fails
//  to load (exit != 0); if it accepts but mis-emits, the assertions
//  trip and the runner prints FAIL.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
        fail_count = fail_count + 1
    }
}

// ── Case 1: @pure pub fn ──────────────────────────────────────
@pure pub fn tg_add(x: int, y: int) -> int { return x + y }

// ── Case 2: @doc(...) pub fn ─────────────────────────────────
@doc("double the input") pub fn tg_double(x: int) -> int { return x * 2 }

// ── Case 3: @cli(...) pub fn ─────────────────────────────────
@cli("tg-neg") pub fn tg_neg(x: int) -> int { return 0 - x }

// ── Case 4: @pure @doc(...) pub fn (two-attr combo) ──────────
@pure @doc("ans") pub fn tg_combo() -> int { return 42 }

// ── Case 5: @hot pub fn ──────────────────────────────────────
@hot pub fn tg_hot(x: int) -> int { return x + 100 }

// ── Case 6: @inline pub fn ───────────────────────────────────
@inline pub fn tg_inline(x: int) -> int { return x * 3 }

// ── Case 7: @memoize pub fn ──────────────────────────────────
@memoize pub fn tg_memo(x: int) -> int { return x - 1 }

// ── Case 8: @pure @inline pub fn (two plain attrs) ───────────
@pure @inline pub fn tg_pure_inline(x: int) -> int { return x * x }

// ── Case 9: @doc(...) @pure pub fn (annotation first) ────────
@doc("mix") @pure pub fn tg_doc_pure(x: int) -> int { return x + 7 }

// ── Case 10: @pure on its own line, then `pub fn` next line ──
@pure
pub fn tg_newline(x: int) -> int { return x + 11 }

// ── Case 11: @pure pub fn with no args ───────────────────────
@pure pub fn tg_noargs() -> int { return 99 }

// ── Case 12: @pure pub fn recursive self-call ────────────────
// decreases n — structural
@pure pub fn tg_fact(n: int) -> int {
    if n <= 1 { return 1 }
    return n * tg_fact(n - 1)
}

// ── Module-level driver (mirrors test_pure_strict.hexa pattern) ──────
println("═══════════════════════════════════════════════════════")
println("  ROI #158 — G39 @attr pub fn regression guard")
println("═══════════════════════════════════════════════════════")

check("1. @pure pub fn add(3,4)", tg_add(3, 4), 7)
check("2. @doc pub fn double(5)", tg_double(5), 10)
check("3. @cli pub fn neg(6)", tg_neg(6), -6)
check("4. @pure @doc pub fn combo()", tg_combo(), 42)
check("5. @hot pub fn hot(2)", tg_hot(2), 102)
check("6. @inline pub fn inline(4)", tg_inline(4), 12)
check("7. @memoize pub fn memo(10)", tg_memo(10), 9)
check("8. @pure @inline pub fn pure_inline(5)", tg_pure_inline(5), 25)
check("9. @doc @pure pub fn doc_pure(3)", tg_doc_pure(3), 10)
check("10. @pure then pub fn newline(4)", tg_newline(4), 15)
check("11. @pure pub fn noargs()", tg_noargs(), 99)
check("12. @pure pub fn fact(5)", tg_fact(5), 120)

println("───────────────────────────────────────────────────────")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
// Guard: require all 12 cases to pass. A regression in G39 would either
// cause a hard parse abort (exit != 0, stops before here) or a fn that
// silently degrades — both cases miss the 12/0 contract below.
if fail_count > 0 || pass_count != 12 {
    println("RESULT: FAIL")
} else {
    println("RESULT: PASS")
}
