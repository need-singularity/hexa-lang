// ═══════════════════════════════════════════════════════════
//  test_bitfield.hexa — @bitfield attribute: bit-packing tests
//  ROI id=30, P3, effect 2x — bool/small-enum bit-level pack
//  Tests:
//    1. @bitfield fn with bool fields → detected + packed
//    2. @bitfield fn without bool fields → violation
//    3. Bit-level access via mask/shift simulation
//    4. Multiple bool fields packed into single int
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA @bitfield Tests — Bit Packing (ROI #30)")
println("═══════════════════════════════════════════════════════")
println("")

// ── Test 1: @bitfield fn with bool conditions ────────────

@bitfield fn classify_flags(a, b, c) {
    let flag_a = a > 0
    let flag_b = b > 0
    let flag_c = c > 0
    // Pack 3 bools into a single int
    let mut packed = 0
    if flag_a { packed = packed + 1 }
    if flag_b { packed = packed + 2 }
    if flag_c { packed = packed + 4 }
    return packed
}

check("bitfield pack 0,0,0", classify_flags(0, 0, 0), 0)
check("bitfield pack 1,0,0", classify_flags(1, 0, 0), 1)
check("bitfield pack 0,1,0", classify_flags(0, 1, 0), 2)
check("bitfield pack 1,1,0", classify_flags(1, 1, 0), 3)
check("bitfield pack 1,1,1", classify_flags(1, 1, 1), 7)

// ── Test 2: Manual bit extraction ────────────────────────

fn get_bit(packed, bit) {
    // Extract bit at position `bit` from packed int
    let shifted = packed / pow(2, bit)
    return shifted % 2
}

fn set_bit(packed, bit, val) {
    let mask = pow(2, bit)
    if val > 0 {
        return packed + mask
    } else {
        return packed
    }
}

let packed = classify_flags(1, 0, 1)
check("bitfield get_bit 0", get_bit(packed, 0), 1)
check("bitfield get_bit 1", get_bit(packed, 1), 0)
check("bitfield get_bit 2", get_bit(packed, 2), 1)

// ── Test 3: @bitfield with no bool fields (violation) ────

@bitfield fn no_bools(x) {
    return x * 2
}

check("bitfield no_bools result", no_bools(5), 10)

// ── Test 4: @bitfield with loop and bool checks ──────────

@bitfield fn count_positive(arr) {
    let mut count = 0
    let mut i = 0
    while i < len(arr) {
        let is_pos = arr[i] > 0
        if is_pos { count = count + 1 }
        i = i + 1
    }
    return count
}

check("bitfield count_positive", count_positive([1, -2, 3, -4, 5]), 3)
check("bitfield count_positive all neg", count_positive([-1, -2, -3]), 0)
check("bitfield count_positive all pos", count_positive([1, 2, 3, 4]), 4)

// ── Test 5: Multi-bit packing for small enums ────────────

@bitfield fn pack_color_flags(r, g, b, alpha) {
    // Each flag is 0 or 1 (bool), pack into 4 bits
    let mut packed = 0
    let r_on = r > 0
    let g_on = g > 0
    let b_on = b > 0
    let a_on = alpha > 0
    if r_on { packed = packed + 1 }
    if g_on { packed = packed + 2 }
    if b_on { packed = packed + 4 }
    if a_on { packed = packed + 8 }
    return packed
}

check("bitfield RGBA 1,1,1,1", pack_color_flags(1, 1, 1, 1), 15)
check("bitfield RGBA 1,0,0,0", pack_color_flags(1, 0, 0, 0), 1)
check("bitfield RGBA 0,0,0,1", pack_color_flags(0, 0, 0, 1), 8)

// ── Summary ──────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  @bitfield: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
