// self/bootstrap.hexa -- HEXA bootstrap compiler pipeline (Stage 5 of self-hosting)
// Ties together: lexer -> parser -> type_checker -> compiler
// Can compile a .hexa file to bytecodes and disassemble the output.
//
// Since HEXA doesn't have a module system yet, all components are
// inlined into this single file. When modules land, this becomes:
//   use self::lexer::tokenize
//   use self::parser::parse
//   use self::type_checker::type_check
//   use self::compiler::compile

// ==============================================================
// Shared structs
// ==============================================================

struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

struct TypeError {
    message: string,
    name: string
}

struct Instruction {
    op: string,
    operand: string
}

struct CompiledFn {
    name: string,
    arity: int,
    param_names: string,
    code: string,
    local_count: int
}

