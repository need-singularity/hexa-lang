// ══════════════════════════════════════════════════════════════
// STAGE 4: Compiler (from compiler.hexa)
// ══════════════════════════════════════════════════════════════

fn instr(op, operand) {
    return Instruction { op: op, operand: operand }
}

fn instr_op(op) {
    return Instruction { op: op, operand: "" }
}

let mut c_code = []
let mut c_const_values = []
let mut c_local_names = []
let mut c_local_depths = []
let mut c_depth = 0
let mut c_next_local = 0
let mut c_functions = []

fn c_add_const(val) {
    let mut i = 0
    while i < len(c_const_values) {
        if c_const_values[i] == val { return i }
        i = i + 1
    }
    c_const_values = c_const_values.push(val)
    return len(c_const_values) - 1
}

fn c_emit(op, operand) {
    c_code = c_code.push(instr(op, operand))
    return len(c_code) - 1
}

fn c_emit_op(op) {
    c_code = c_code.push(instr_op(op))
    return len(c_code) - 1
}

fn c_current_pos() { return len(c_code) }

fn c_patch_jump(pos, target) {
    let old = c_code[pos]
    c_code[pos] = Instruction { op: old.op, operand: to_string(target) }
}

fn c_push_scope() { c_depth = c_depth + 1 }

fn c_pop_scope() {
    let mut nn = []
    let mut nd = []
    let mut i = 0
    while i < len(c_local_names) {
        if c_local_depths[i] < c_depth {
            nn = nn.push(c_local_names[i])
            nd = nd.push(c_local_depths[i])
        }
        i = i + 1
    }
    c_local_names = nn
    c_local_depths = nd
    c_depth = c_depth - 1
}

fn c_define_local(name) {
    let slot = c_next_local
    c_local_names = c_local_names.push(name)
    c_local_depths = c_local_depths.push(c_depth)
    c_next_local = c_next_local + 1
    return slot
}

fn c_resolve_local(name) {
    let mut i = len(c_local_names) - 1
    while i >= 0 {
        if c_local_names[i] == name { return i }
        i = i - 1
    }
    return -1
}

fn c_compile_expr(node) {
    if node == "" {
        c_emit_op("VOID")
        return
    }
    let k = node.kind
    if k == "IntLit" || k == "FloatLit" || k == "BoolLit" || k == "StringLit" {
        let idx = c_add_const(node.value)
        c_emit("CONST", to_string(idx))
        return
    }
    if k == "Ident" {
        let slot = c_resolve_local(node.name)
        if slot >= 0 {
            c_emit("GET_LOCAL", to_string(slot))
        } else {
            c_emit("GET_GLOBAL", node.name)
        }
        return
    }
    if k == "BinOp" {
        c_compile_expr(node.left)
        c_compile_expr(node.right)
        if node.op == "+" { c_emit_op("ADD") }
        if node.op == "-" { c_emit_op("SUB") }
        if node.op == "*" { c_emit_op("MUL") }
        if node.op == "/" { c_emit_op("DIV") }
        if node.op == "%" { c_emit_op("MOD") }
        if node.op == "==" { c_emit_op("EQ") }
        if node.op == "!=" { c_emit_op("NE") }
        if node.op == "<" { c_emit_op("LT") }
        if node.op == ">" { c_emit_op("GT") }
        if node.op == "<=" { c_emit_op("LE") }
        if node.op == ">=" { c_emit_op("GE") }
        if node.op == "&&" { c_emit_op("AND") }
        if node.op == "||" { c_emit_op("OR") }
        return
    }
    if k == "UnaryOp" {
        c_compile_expr(node.left)
        if node.op == "-" { c_emit_op("NEG") }
        if node.op == "!" { c_emit_op("NOT") }
        return
    }
    if k == "Call" {
        let arg_count = len(node.args)
        let mut i = 0
        while i < arg_count {
            c_compile_expr(node.args[i])
            i = i + 1
        }
        if node.left != "" && node.left.kind == "Ident" {
            let fname = node.left.name
            if fname == "println" {
                c_emit("PRINTLN", to_string(arg_count))
                return
            }
            if fname == "print" {
                c_emit("PRINT", to_string(arg_count))
                return
            }
            if fname == "format" {
                c_emit("BUILTIN", "format:" + to_string(arg_count))
                return
            }
            if fname == "len" {
                c_emit("BUILTIN", "len:1")
                return
            }
            if fname == "to_string" {
                c_emit("BUILTIN", "to_string:1")
                return
            }
            c_emit("CALL", fname + ":" + to_string(arg_count))
            return
        }
        if node.left != "" && node.left.kind == "Field" {
            c_compile_expr(node.left.left)
            c_emit("CALL_METHOD", node.left.name + ":" + to_string(arg_count))
            return
        }
        c_emit("CALL_INDIRECT", to_string(arg_count))
        return
    }
    if k == "Field" {
        c_compile_expr(node.left)
        c_emit("GET_FIELD", node.name)
        return
    }
    if k == "Index" {
        c_compile_expr(node.left)
        c_compile_expr(node.right)
        c_emit_op("INDEX")
        return
    }
    if k == "Array" {
        let count = len(node.items)
        let mut i = 0
        while i < count {
            c_compile_expr(node.items[i])
            i = i + 1
        }
        c_emit("MAKE_ARRAY", to_string(count))
        return
    }
    if k == "IfExpr" {
        c_compile_expr(node.cond)
        let jf = c_emit("JUMP_IF_FALSE", "0")
        c_compile_stmts(node.then_body)
        if node.else_body != "" && len(node.else_body) > 0 {
            let je = c_emit("JUMP", "0")
            c_patch_jump(jf, c_current_pos())
            c_compile_stmts(node.else_body)
            c_patch_jump(je, c_current_pos())
        } else {
            c_patch_jump(jf, c_current_pos())
        }
        return
    }
    if k == "StructInit" {
        let count = len(node.fields)
        let mut i = 0
        while i < count {
            let f = node.fields[i]
            let ni = c_add_const(f.name)
            c_emit("CONST", to_string(ni))
            c_compile_expr(f.left)
            i = i + 1
        }
        c_emit("MAKE_STRUCT", node.name + ":" + to_string(count))
        return
    }
    if k == "Range" {
        c_compile_expr(node.left)
        c_compile_expr(node.right)
        c_emit("MAKE_RANGE", node.value)
        return
    }
    c_emit_op("VOID")
}

fn c_compile_stmt(node) {
    let k = node.kind
    if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
        c_compile_expr(node.left)
        let slot = c_define_local(node.name)
        c_emit("SET_LOCAL", to_string(slot))
        return
    }
    if k == "FnDecl" {
        let saved_code = c_code
        let saved_locals = c_local_names
        let saved_depths = c_local_depths
        let saved_depth = c_depth
        let saved_next = c_next_local
        c_code = []
        c_local_names = []
        c_local_depths = []
        c_depth = 0
        c_next_local = 0
        let pc = len(node.params)
        let mut pnames = []
        let mut i = 0
        while i < pc {
            pnames = pnames.push(node.params[i].name)
            c_define_local(node.params[i].name)
            i = i + 1
        }
        c_compile_stmts(node.body)
        c_emit_op("VOID")
        c_emit_op("RETURN")
        let fn_code = c_code
        let fn_locals = c_next_local
        c_code = saved_code
        c_local_names = saved_locals
        c_local_depths = saved_depths
        c_depth = saved_depth
        c_next_local = saved_next
        c_functions = c_functions.push(CompiledFn {
            name: node.name, arity: pc, param_names: pnames,
            code: fn_code, local_count: fn_locals
        })
        return
    }
    if k == "StructDecl" { return }
    if k == "ReturnStmt" {
        if node.left != "" {
            c_compile_expr(node.left)
        } else {
            c_emit_op("VOID")
        }
        c_emit_op("RETURN")
        return
    }
    if k == "AssignStmt" {
        c_compile_expr(node.right)
        if node.left != "" && node.left.kind == "Ident" {
            let slot = c_resolve_local(node.left.name)
            if slot >= 0 {
                c_emit("SET_LOCAL", to_string(slot))
            } else {
                c_emit("SET_GLOBAL", node.left.name)
            }
        }
        return
    }
    if k == "ExprStmt" {
        c_compile_expr(node.left)
        c_emit_op("POP")
        return
    }
    if k == "WhileStmt" {
        let ls = c_current_pos()
        c_compile_expr(node.cond)
        let ej = c_emit("JUMP_IF_FALSE", "0")
        c_push_scope()
        c_compile_stmts(node.body)
        c_pop_scope()
        c_emit("JUMP", to_string(ls))
        c_patch_jump(ej, c_current_pos())
        return
    }
    if k == "ForStmt" {
        c_compile_expr(node.iter_expr)
        c_push_scope()
        let is = c_define_local("__iter__")
        c_emit("SET_LOCAL", to_string(is))
        let ix = c_define_local("__idx__")
        let zi = c_add_const("0")
        c_emit("CONST", to_string(zi))
        c_emit("SET_LOCAL", to_string(ix))
        let vs = c_define_local(node.name)
        let ls = c_current_pos()
        c_emit("GET_LOCAL", to_string(ix))
        c_emit("GET_LOCAL", to_string(is))
        c_emit("BUILTIN", "len:1")
        c_emit_op("LT")
        let ej = c_emit("JUMP_IF_FALSE", "0")
        c_emit("GET_LOCAL", to_string(is))
        c_emit("GET_LOCAL", to_string(ix))
        c_emit_op("INDEX")
        c_emit("SET_LOCAL", to_string(vs))
        c_compile_stmts(node.body)
        c_emit("GET_LOCAL", to_string(ix))
        let oi = c_add_const("1")
        c_emit("CONST", to_string(oi))
        c_emit_op("ADD")
        c_emit("SET_LOCAL", to_string(ix))
        c_emit("JUMP", to_string(ls))
        c_patch_jump(ej, c_current_pos())
        c_pop_scope()
        return
    }
    if k == "AssertStmt" {
        c_compile_expr(node.left)
        c_emit_op("ASSERT")
        return
    }
}

fn c_compile_stmts(stmts) {
    if stmts == "" { return }
    let mut i = 0
    while i < len(stmts) {
        c_compile_stmt(stmts[i])
        i = i + 1
    }
}

fn compile_program(stmts) {
    c_code = []
    c_const_values = []
    c_local_names = []
    c_local_depths = []
    c_depth = 0
    c_next_local = 0
    c_functions = []
    c_compile_stmts(stmts)
    return c_code
}

// ══════════════════════════════════════════════════════════════
// Disassembler
// ══════════════════════════════════════════════════════════════

fn disassemble(code, constants) {
    println("=== Bytecode ===")
    let mut i = 0
    while i < len(code) {
        let ins = code[i]
        if ins.operand != "" {
            println(format("  {:4}  {} {}", i, ins.op, ins.operand))
        } else {
            println(format("  {:4}  {}", i, ins.op))
        }
        i = i + 1
    }
    println("")
    println("=== Constants ===")
    let mut j = 0
    while j < len(constants) {
        println(format("  [{}] {}", j, constants[j]))
        j = j + 1
    }
}

fn disassemble_fn(func) {
    println(format("=== Function: {} (arity={}, locals={}) ===", func.name, func.arity, func.local_count))
    let mut i = 0
    while i < len(func.code) {
        let ins = func.code[i]
        if ins.operand != "" {
            println(format("  {:4}  {} {}", i, ins.op, ins.operand))
        } else {
            println(format("  {:4}  {}", i, ins.op))
        }
        i = i + 1
    }
}

// ══════════════════════════════════════════════════════════════
// Bootstrap pipeline: source -> tokens -> AST -> typecheck -> bytecodes
// ══════════════════════════════════════════════════════════════

fn bootstrap_compile(source) {
    println("=== HEXA Bootstrap Compiler ===")
    println("")

    // Stage 1: Lex
    println("[1/4] Lexing...")
    let tokens = tokenize(source)
    let tok_count = len(tokens)
    println(format("  {} tokens", tok_count))

    // Stage 2: Parse
    println("[2/4] Parsing...")
    let ast = parse(tokens)
    let stmt_count = len(ast)
    println(format("  {} top-level statements", stmt_count))

    // Stage 3: Type check
    println("[3/4] Type checking...")
    let errors = type_check(ast)
    let err_count = len(errors)
    if err_count > 0 {
        println(format("  {} type errors:", err_count))
        let mut i = 0
        while i < err_count {
            println(format("    - {}", errors[i].message))
            i = i + 1
        }
    } else {
        println("  No type errors")
    }

    // Stage 4: Compile
    println("[4/4] Compiling to bytecode...")
    let code = compile_program(ast)
    let instr_count = len(code)
    let const_count = len(c_const_values)
    let fn_count = len(c_functions)
    println(format("  {} instructions, {} constants, {} functions", instr_count, const_count, fn_count))
    println("")

    // Disassemble
    disassemble(code, c_const_values)
    println("")

    // Disassemble functions
    let mut i = 0
    while i < fn_count {
        disassemble_fn(c_functions[i])
        println("")
        i = i + 1
    }

    println("=== Bootstrap compilation complete ===")
    return code
}
