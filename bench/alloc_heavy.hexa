// bench/alloc_heavy.hexa — array allocation pressure.
// Spec asked for "map 4-key 10K iter" but interp's `{ "k": v }` literal
// has limited support and hangs in this build. We substitute a
// 4-element array allocated 10,000 times — same allocation pressure
// against array_new/push/grow counters in HEXA_ALLOC_STATS.
// (When map literal lands, swap back to map for map_new/map_set.)

let N = 10000
let mut i = 0
let mut last = 0
while i < N {
    let a = [i, i + 1, i + 2, i + 3]
    last = a[3]
    i = i + 1
}
println("alloc_heavy N=" + N + " last=" + last)
