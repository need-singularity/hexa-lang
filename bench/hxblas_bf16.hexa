// ══════════════════════════════════════════════════════════════
//  bench/hxblas_bf16.hexa — bf16 NEON vs f32 BLAS benchmark
//
//  Compares bf16 NEON matmul/matvec against f32 BLAS (cblas_sgemm)
//  at multiple sizes. Reports ms/op, GFLOPS, and L2 error vs f32.
//
//  Build & run (macOS ARM64):
//    hexa build bench/hxblas_bf16.hexa -o /tmp/bench_bf16
//    DYLD_LIBRARY_PATH=self/native/build /tmp/bench_bf16
//
//  Build & run (Linux aarch64):
//    hexa build bench/hxblas_bf16.hexa -o /tmp/bench_bf16
//    LD_LIBRARY_PATH=self/native/build /tmp/bench_bf16
//
//  Expected results (M4 16GB):
//    bf16 NEON should approach 2x throughput vs f32 for large sizes
//    where memory bandwidth dominates (512^2+).
//    L2 error vs f32 reference: < 0.02 (bf16 has 7-bit mantissa).
// ══════════════════════════════════════════════════════════════

// ── f32 BLAS extern (existing) ───────────────────────────────
@link("hxblas")
extern fn hxblas_sgemm(order: int, transA: int, transB: int, M: int, N: int, K: int, alpha: float, A: int, lda: int, B: int, ldb: int, beta: float, C: int, ldc: int)

@link("hxblas")
extern fn hxblas_matmul_scalar(M: int, K: int, N: int, A: int, B: int, C: int)

@link("hxblas")
extern fn hxblas_version() -> int

// ── bf16 NEON extern ─────────────────────────────────────────
@link("hxblas")
extern fn hxblas_bgemm(M: int, K: int, N: int, A: int, B: int, C: int)

@link("hxblas")
extern fn hxblas_bgemv(M: int, K: int, A: int, x: int, y: int)

@link("hxblas")
extern fn hxblas_f32_to_bf16(n: int, src: int, dst: int)

@link("hxblas")
extern fn hxblas_bf16_to_f32(n: int, src: int, dst: int)

@link("hxblas")
extern fn hxblas_bf16_version() -> int

// ── Helpers ──────────────────────────────────────────────────

fn fill_f32(ptr, n, v) {
    let mut i = 0
    while i < n {
        write_f32(ptr, i * 4, v)
        i = i + 1
    }
}

fn fill_f32_rand(ptr, n) {
    // Deterministic pseudo-random fill for reproducibility
    let mut seed = 42
    let mut i = 0
    while i < n {
        seed = (seed * 1103515245 + 12345) % 2147483648
        let v = to_float(seed % 1000) / 1000.0 - 0.5
        write_f32(ptr, i * 4, v)
        i = i + 1
    }
}

fn get_f32(ptr, i) {
    return deref_f32(ptr, i * 4)
}

// ── L2 relative error ────────────────────────────────────────

fn l2_rel_error(ref_ptr, test_ptr, n) {
    let mut err_sq = 0.0
    let mut ref_sq = 0.0
    let mut i = 0
    while i < n {
        let r = get_f32(ref_ptr, i)
        let t = get_f32(test_ptr, i)
        let d = t - r
        err_sq = err_sq + d * d
        ref_sq = ref_sq + r * r
        i = i + 1
    }
    if ref_sq < 0.000001 {
        return 0.0
    }
    return sqrt(err_sq / ref_sq)
}

// ── ABI smoke test ───────────────────────────────────────────

fn smoke_abi() {
    let v = hxblas_version()
    let bv = hxblas_bf16_version()
    println("hxblas ABI version=" + to_string(v))
    println("hxblas bf16 ABI version=" + to_string(bv))
    if bv >= 1 {
        println("  BF16_ABI_SMOKE=PASS")
    } else {
        println("  BF16_ABI_SMOKE=FAIL")
    }
}

// ── Correctness check: bf16 matmul vs f32 scalar ─────────────

fn correctness_check(sz) {
    let n = sz * sz
    // Create f32 matrices with pseudo-random data
    let a_f32 = alloc_raw(n * 4)
    let b_f32 = alloc_raw(n * 4)
    fill_f32_rand(a_f32, n)
    fill_f32_rand(b_f32, n)

    // f32 reference (scalar)
    let c_ref = alloc_raw(n * 4)
    hxblas_matmul_scalar(sz, sz, sz, a_f32, b_f32, c_ref)

    // Pack to bf16
    let a_bf16 = alloc_raw(n * 2)
    let b_bf16 = alloc_raw(n * 2)
    hxblas_f32_to_bf16(n, a_f32, a_bf16)
    hxblas_f32_to_bf16(n, b_f32, b_bf16)

    // bf16 matmul
    let c_bf16 = alloc_raw(n * 4)
    hxblas_bgemm(sz, sz, sz, a_bf16, b_bf16, c_bf16)

    // L2 error
    let err = l2_rel_error(c_ref, c_bf16, n)
    let pass = err < 0.02

    println("  correctness " + to_string(sz) + "x" + to_string(sz) + " L2_rel_err=" + to_string(err) + " " + if pass { "PASS" } else { "FAIL (>0.02)" })

    free_raw(a_f32, n * 4)
    free_raw(b_f32, n * 4)
    free_raw(c_ref, n * 4)
    free_raw(a_bf16, n * 2)
    free_raw(b_bf16, n * 2)
    free_raw(c_bf16, n * 4)
    return pass
}

// ── GEMV correctness ─────────────────────────────────────────

fn correctness_gemv(M, K) {
    // W[M x K] bf16, x[K] f32 -> y[M] f32
    let w_f32 = alloc_raw(M * K * 4)
    let x_f32 = alloc_raw(K * 4)
    fill_f32_rand(w_f32, M * K)
    fill_f32_rand(x_f32, K)

    // f32 reference: y_ref[i] = sum_k(W[i,k] * x[k])
    let y_ref = alloc_raw(M * 4)
    let mut i = 0
    while i < M {
        let mut sum = 0.0
        let mut k = 0
        while k < K {
            sum = sum + get_f32(w_f32, i * K + k) * get_f32(x_f32, k)
            k = k + 1
        }
        write_f32(y_ref, i * 4, sum)
        i = i + 1
    }

    // Pack weights to bf16
    let w_bf16 = alloc_raw(M * K * 2)
    hxblas_f32_to_bf16(M * K, w_f32, w_bf16)

    // bf16 matvec
    let y_bf16 = alloc_raw(M * 4)
    hxblas_bgemv(M, K, w_bf16, x_f32, y_bf16)

    let err = l2_rel_error(y_ref, y_bf16, M)
    let pass = err < 0.02

    println("  gemv " + to_string(M) + "x" + to_string(K) + " L2_rel_err=" + to_string(err) + " " + if pass { "PASS" } else { "FAIL (>0.02)" })

    free_raw(w_f32, M * K * 4)
    free_raw(x_f32, K * 4)
    free_raw(y_ref, M * 4)
    free_raw(w_bf16, M * K * 2)
    free_raw(y_bf16, M * 4)
    return pass
}

// ── Pack/unpack roundtrip ────────────────────────────────────

fn correctness_pack_roundtrip(n) {
    let src = alloc_raw(n * 4)
    fill_f32_rand(src, n)

    let bf16 = alloc_raw(n * 2)
    hxblas_f32_to_bf16(n, src, bf16)

    let dst = alloc_raw(n * 4)
    hxblas_bf16_to_f32(n, bf16, dst)

    let err = l2_rel_error(src, dst, n)
    let pass = err < 0.005

    println("  pack_roundtrip n=" + to_string(n) + " L2_rel_err=" + to_string(err) + " " + if pass { "PASS" } else { "FAIL (>0.005)" })

    free_raw(src, n * 4)
    free_raw(bf16, n * 2)
    free_raw(dst, n * 4)
    return pass
}

// ── Benchmark: bf16 GEMM vs f32 BLAS ─────────────────────────

fn bench_bgemm(sz) {
    let n = sz * sz
    let a_f32 = alloc_raw(n * 4)
    let b_f32 = alloc_raw(n * 4)
    fill_f32(a_f32, n, 1.0)
    fill_f32(b_f32, n, 1.0)

    // Pack to bf16
    let a_bf16 = alloc_raw(n * 2)
    let b_bf16 = alloc_raw(n * 2)
    hxblas_f32_to_bf16(n, a_f32, a_bf16)
    hxblas_f32_to_bf16(n, b_f32, b_bf16)

    let c_f32 = alloc_raw(n * 4)
    let c_bf16 = alloc_raw(n * 4)

    // Warmup
    hxblas_bgemm(sz, sz, sz, a_bf16, b_bf16, c_bf16)

    // Bench bf16
    let iters = if sz <= 128 { 50 } else { if sz <= 256 { 20 } else { if sz <= 512 { 5 } else { 2 } } }
    let t0 = clock()
    let mut iter = 0
    while iter < iters {
        hxblas_bgemm(sz, sz, sz, a_bf16, b_bf16, c_bf16)
        iter = iter + 1
    }
    let t1 = clock()
    let bf16_sec = (t1 - t0) / to_float(iters)
    let bf16_ms = bf16_sec * 1000.0

    // Bench f32 scalar (reference)
    let t2 = clock()
    iter = 0
    while iter < iters {
        hxblas_matmul_scalar(sz, sz, sz, a_f32, b_f32, c_f32)
        iter = iter + 1
    }
    let t3 = clock()
    let f32_sec = (t3 - t2) / to_float(iters)
    let f32_ms = f32_sec * 1000.0

    // GFLOPS: 2*M*N*K FLOPs for matmul
    let flops = 2.0 * to_float(sz) * to_float(sz) * to_float(sz)
    let bf16_gflops = if bf16_sec > 0.0 { flops / bf16_sec / 1000000000.0 } else { 0.0 }
    let f32_gflops = if f32_sec > 0.0 { flops / f32_sec / 1000000000.0 } else { 0.0 }

    let speedup = if bf16_ms > 0.0 { f32_ms / bf16_ms } else { 0.0 }

    // Bandwidth: bf16 reads 2*M*K*2 + 2*K*N*2 bytes (bf16), writes M*N*4 (f32)
    let bf16_bytes = to_float(2 * n * 2 + 2 * n * 2 + n * 4)
    let bf16_bw = if bf16_sec > 0.0 { bf16_bytes / bf16_sec / 1000000000.0 } else { 0.0 }

    println("  " + to_string(sz) + "^2  bf16=" + to_string(bf16_ms) + "ms  f32_scalar=" + to_string(f32_ms) + "ms  speedup=" + to_string(speedup) + "x  bf16_GFLOPS=" + to_string(bf16_gflops) + "  bw=" + to_string(bf16_bw) + "GB/s")

    free_raw(a_f32, n * 4)
    free_raw(b_f32, n * 4)
    free_raw(a_bf16, n * 2)
    free_raw(b_bf16, n * 2)
    free_raw(c_f32, n * 4)
    free_raw(c_bf16, n * 4)
}

// ── Benchmark: bf16 GEMV ─────────────────────────────────────

fn bench_bgemv(M, K) {
    let w_f32 = alloc_raw(M * K * 4)
    let x_f32 = alloc_raw(K * 4)
    fill_f32(w_f32, M * K, 0.01)
    fill_f32(x_f32, K, 1.0)

    let w_bf16 = alloc_raw(M * K * 2)
    hxblas_f32_to_bf16(M * K, w_f32, w_bf16)

    let y = alloc_raw(M * 4)

    // Warmup
    hxblas_bgemv(M, K, w_bf16, x_f32, y)

    let iters = if M * K <= 256 * 256 { 100 } else { if M * K <= 1024 * 1024 { 20 } else { 5 } }
    let t0 = clock()
    let mut iter = 0
    while iter < iters {
        hxblas_bgemv(M, K, w_bf16, x_f32, y)
        iter = iter + 1
    }
    let t1 = clock()
    let sec = (t1 - t0) / to_float(iters)
    let ms = sec * 1000.0

    // Bandwidth: read M*K*2 (bf16 weights) + K*4 (f32 x) + write M*4 (f32 y)
    let bytes = to_float(M * K * 2 + K * 4 + M * 4)
    let bw = if sec > 0.0 { bytes / sec / 1000000000.0 } else { 0.0 }

    println("  gemv " + to_string(M) + "x" + to_string(K) + "  " + to_string(ms) + "ms  bw=" + to_string(bw) + "GB/s")

    free_raw(w_f32, M * K * 4)
    free_raw(x_f32, K * 4)
    free_raw(w_bf16, M * K * 2)
    free_raw(y, M * 4)
}

// ── Main ─────────────────────────────────────────────────────

fn main() {
    println("=== hxblas bf16 NEON benchmark ===")
    println("")

    smoke_abi()
    println("")

    println("--- correctness: pack/unpack roundtrip ---")
    correctness_pack_roundtrip(1024)
    correctness_pack_roundtrip(65536)
    println("")

    println("--- correctness: bf16 GEMM vs f32 scalar ---")
    correctness_check(8)
    correctness_check(32)
    correctness_check(64)
    correctness_check(128)
    println("")

    println("--- correctness: bf16 GEMV vs f32 scalar ---")
    correctness_gemv(64, 64)
    correctness_gemv(256, 256)
    correctness_gemv(1024, 512)
    println("")

    println("--- bench: bf16 GEMM vs f32 scalar ---")
    bench_bgemm(128)
    bench_bgemm(256)
    bench_bgemm(512)
    bench_bgemm(1024)
    println("")

    println("--- bench: bf16 GEMV (inference critical path) ---")
    bench_bgemv(128, 128)
    bench_bgemv(256, 256)
    bench_bgemv(512, 512)
    bench_bgemv(1024, 1024)
    bench_bgemv(4096, 4096)
    println("")

    println("done")
}

main()
