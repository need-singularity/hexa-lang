// bench/snapshots/builtin_mangling.hexa — roadmap 68 (M2) exit_criteria (3).
//
// Snapshot harness pinning the AOT-emission contract for the builtin
// identifiers historically routed through `#define` shims at
// self/runtime.c:6840-6846 (setenv, exec_capture, now, push) plus the
// adjacent free-function / zero-arg surface that codegen_c2.hexa now
// dispatches to typed `hexa_*` wrappers.
//
// Each call exercises a name that, under the legacy hexa_v2 codegen,
// leaked as a bare identifier and only compiled because of the shim.
// After roadmap 66 (Phase C.2 regen) + 2361bc25 (now/push dispatch),
// every name below should be emitted as `hexa_<canonical>` in AOT and
// resolved natively under interp/AOT/stage0/native — identical result.
//
// Usage: hexa run bench/snapshots/builtin_mangling.hexa
// Exit 0 on PASS, 1 on FAIL.

let mut fails = 0
let mut checks = 0

fn check(name, ok) {
    checks = checks + 1
    if !ok {
        println("FAIL " + name)
        fails = fails + 1
    }
}

// 1. now() — was `#define now timestamp` shim, now codegen → hexa_timestamp().
let t = now()
check("now", t > 0)

// 2. timestamp() — direct dispatch, sanity that aliasing didn't break it.
let t2 = timestamp()
check("timestamp", t2 > 0)

// 3. free-function push(arr, v) — was `#define push hx_push` shim,
//    now codegen → hexa_array_push().
let mut a = []
push(a, "x")
push(a, "y")
check("push_free_fn", len(a) == 2 && a[0] == "x" && a[1] == "y")

// 4. method push — sanity that the legacy method dispatch still works.
let mut b = []
b.push("z")
check("push_method", len(b) == 1 && b[0] == "z")

// 5. append(arr, v) — companion to push, predates roadmap 68.
let mut c = []
append(c, "p")
check("append_free_fn", len(c) == 1 && c[0] == "p")

// 6. setenv(k, v) — was `#define setenv hx_setenv`. Already routed
//    via codegen_c2:3362 → hexa_setenv. Verify round-trip via env_var.
setenv("HXA_M2_PROBE_K", "v123")
check("setenv", env_var("HXA_M2_PROBE_K") == "v123")

// 7. exec_capture(cmd) — was `#define exec_capture hx_exec_capture`.
//    codegen_c2:2971 → hexa_exec_capture. Returns (out, status).
let r = exec_capture("printf %s ok")
check("exec_capture", r[0] == "ok")

// 8. exec(cmd) — adjacent in the exec_* family, no shim but cross-mode
//    parity is part of the same surface.
let s = exec("printf %s yo")
check("exec", s == "yo")

// 9. time_ms() — FIX-A builtin, monotonic millisecond clock.
let m = time_ms()
check("time_ms", m > 0)

// 10. byte_len(s) — FIX-A builtin, byte-length of a string.
check("byte_len", byte_len("abc") == 3)

// 11. random() — zero-arg builtin in the same dispatch family as
//     timestamp/now (codegen_c2:3292). Returns a bounded numeric.
let rv = random()
check("random", rv >= 0)

// 12. u_floor(a, b) — FIX-A builtin, unsigned floor division.
check("u_floor", u_floor(10, 3) == 3)

if fails == 0 {
    println("PASS builtin_mangling: " + to_string(checks) + "/" + to_string(checks))
    exit(0)
}
println("FAIL builtin_mangling: " + to_string(fails) + "/" + to_string(checks) + " failed")
exit(1)
