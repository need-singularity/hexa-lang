// bench/snapshots/string_method_coverage.hexa — anima roadmap M4 exit criterion
// (hxa-20260423-003 결손-E).
//
// Covers the string methods whose codegen dispatch landed between commits
// 968900b8 (Phase C.2 fixpoint) and now. Keep assertions tight — the
// bootstrap loop reads failures here to detect codegen regressions.
//
// Usage: hexa run bench/snapshots/string_method_coverage.hexa
// Exit 0 on PASS, 1 on FAIL.

fn assert_eq(label, got, want) {
    if got == want { return }
    println("FAIL " + label + ": got=[" + got + "] want=[" + want + "]")
    exit(1)
}

fn assert_int_eq(label, got, want) {
    if got == want { return }
    println("FAIL " + label + ": got=" + str(got) + " want=" + str(want))
    exit(1)
}

fn main() {
    let s = "hello/world/foo.txt"
    assert_int_eq("last_index_of('/')", s.last_index_of("/"), 11)
    assert_int_eq("rfind('/')",        s.rfind("/"),          11)
    assert_int_eq("find('/')",         s.find("/"),           5)
    assert_int_eq("index_of('/')",     s.index_of("/"),       5)
    assert_int_eq("last_index_of('.')", s.last_index_of("."), 15)

    // pad_start / pad_end — JS/Python naming aliases reusing the runtime
    // hexa_str_pad_left / hexa_str_pad_right primitives.
    assert_eq("pad_start 5,'0'",  "42".pad_start(5, "0"),   "00042")
    assert_eq("pad_end 5,'*'",    "42".pad_end(5, "*"),     "42***")
    assert_eq("pad_start short",  "hi".pad_start(1, "0"),   "hi")
    assert_eq("pad_end multi",    "ab".pad_end(6, "xy"),    "abxyxy")

    println("PASS string_method_coverage")
}
