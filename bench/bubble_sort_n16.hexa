// bench/bubble_sort_n16.hexa — bubble sort over 16 ints, 1000 reps.
// S-2b cost-learner fixture. Matches registry needle "bubble".
// Deterministic LCG seed so sort actually does work (descending tendency).

let N = 16
let REPS = 1000

let mut out_first = 0
let mut out_last  = 0

let mut r = 0
while r < REPS {
    // Build input via LCG — new data each rep prevents the JIT/interp
    // from short-circuiting an "already sorted" best case.
    let mut arr = []
    let mut seed = 1234567 + r
    let mut fill = 0
    while fill < N {
        seed = (seed * 1103515245 + 12345) % 2147483648
        arr = arr + [seed % 1000]
        fill = fill + 1
    }

    // Classic bubble sort, O(N^2) compare+swap.
    let mut i = 0
    while i < N - 1 {
        let mut j = 0
        while j < N - 1 - i {
            if arr[j] > arr[j + 1] {
                let t = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = t
            }
            j = j + 1
        }
        i = i + 1
    }

    if r == REPS - 1 {
        out_first = arr[0]
        out_last  = arr[N - 1]
    }
    r = r + 1
}

println("bubble_sort_n16 first=" + str(out_first) + " last=" + str(out_last))
