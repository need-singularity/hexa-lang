// bench/import_alias_e2e.hexa — RFC-016 P1 (I1-IMPORT-ALIAS) end-to-end smoke
//
// Imports stdlib/path.hexa under alias `pp` and calls one of its public
// functions. The module_loader prefixes pub decls with __mod_pp__ and
// rewrites caller-side `pp.fn(x)` to `__mod_pp__fn(x)` before the parser
// sees the flat source.

import "stdlib/path.hexa" as pp

let result = pp.path_join("a", "b")
println("e2e " + result)
