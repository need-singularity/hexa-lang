// bench/merge_sort_n256.hexa — merge sort over 256 ints, 10 reps.
// S-2b cost-learner fixture. Matches registry needle "merge".
// Classic top-down merge sort with O(n log n) compares and O(n) aux array.
// Recursive; passes array + index bounds. Returns the merged array.

fn merge_sort(arr) {
    let n = len(arr)
    if n <= 1 {
        return arr
    }
    let mid = n / 2

    // Left half
    let mut left = []
    let mut i = 0
    while i < mid {
        left = left + [arr[i]]
        i = i + 1
    }
    // Right half
    let mut right = []
    let mut j = mid
    while j < n {
        right = right + [arr[j]]
        j = j + 1
    }

    let ls = merge_sort(left)
    let rs = merge_sort(right)

    // Merge ls and rs into out.
    let ln = len(ls)
    let rn = len(rs)
    let mut out = []
    let mut a = 0
    let mut b = 0
    while a < ln && b < rn {
        if ls[a] <= rs[b] {
            out = out + [ls[a]]
            a = a + 1
        } else {
            out = out + [rs[b]]
            b = b + 1
        }
    }
    while a < ln {
        out = out + [ls[a]]
        a = a + 1
    }
    while b < rn {
        out = out + [rs[b]]
        b = b + 1
    }
    return out
}

let N = 256
let REPS = 10

let mut out_first = 0
let mut out_last  = 0

let mut r = 0
while r < REPS {
    let mut arr = []
    let mut seed = 9876543 + r * 23
    let mut fill = 0
    while fill < N {
        seed = (seed * 1103515245 + 12345) % 2147483648
        arr = arr + [seed % 100000]
        fill = fill + 1
    }

    let sorted = merge_sort(arr)

    if r == REPS - 1 {
        out_first = sorted[0]
        out_last  = sorted[N - 1]
    }
    r = r + 1
}

println("merge_sort_n256 first=" + str(out_first) + " last=" + str(out_last))
