// bench/import_searchpath_e2e.hexa — RFC-016 P2 (I2-IMPORT-PATH) e2e
//
// Exercises:
//   1. Extension-less import: "stdlib/path"   resolves to stdlib/path.hexa
//   2. mod.hexa fallback:    "stdlib/regex" resolves to stdlib/regex/mod.hexa
//
// HEXA_PATH search (colon-separated user roots) is exercised via
// self/test_module_search_path.hexa with a synthetic fixture under /tmp.

import "stdlib/path"        as pp
import "stdlib/regex"       as rg

let joined = pp.path_join("a", "b")
println("ext-less " + joined)

// Direct call into stdlib/regex/mod.hexa — function name varies by what
// regex/mod.hexa exposes. Use regex_test (POSIX ERE wrapper) as the canary.
// Pattern uses POSIX ERE [0-9] (not PCRE \d); semantics testing is out of
// scope here — what matters is that the function was *found* (i.e. the
// mod.hexa fallback successfully resolved the package).
let matched = rg.regex_test("ab[0-9]", "ab9")
println("mod.hexa matched=" + to_string(matched))
