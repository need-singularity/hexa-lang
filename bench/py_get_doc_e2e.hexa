// bench/py_get_doc_e2e.hexa — LP5-PY-IMPORT-HOVER scaffold smoke
//
// Invokes stdlib/python_ffi.py_get_doc on a well-known builtin
// (math.sqrt) and verifies a non-empty first-line docstring comes back.
// LSP hover handler will wrap this with a 250ms timeout (handler-side,
// not the helper) before placing it in textDocument/hover responses.

use "stdlib/python_ffi"

let doc = py_get_doc("math", "sqrt")
if len(doc) == 0 {
    println("LP5-FAIL empty doc")
    exit(1)
}
println("LP5-OK " + doc)
