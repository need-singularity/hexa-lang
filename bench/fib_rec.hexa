// bench/fib_rec.hexa — recursive fibonacci.
// Exercises function call dispatch (push/pop scope, bind args, return).
// fib(30) = 832040. With memoization disabled this is ~2.7M calls.

fn fib(n) {
    if n < 2 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

let r = fib(30)
println("fib(30)=" + str(r))
