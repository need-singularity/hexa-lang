// bench/native_int_specialize.hexa — C1 (native int codegen) bench target.
//
// Purpose: measure boxed-int vs native-int path for range `for` loops.
// Pre-C1: counter materialized as HexaVal each iteration; end bound
// re-evaluated via hexa_as_num() per step, and .i field incremented on a
// 3-word struct (even though clang -O2 keeps it in registers).
// Post-C1: native int64_t counter + pre-computed end bound in a scoped
// block. Body still sees HexaVal <name> — materialized once per iteration
// from the native counter — so semantics are unchanged.
//
// To make the optimization visible past -O2 we use a NON-constant bound
// expression (arr.length()) that forces clang to re-evaluate it per step
// in the pre-C1 code but is pre-computed in the post-C1 code.

// ── A) counter-heavy empty body, non-trivial bound ──
let lens = [100, 200, 300, 400, 500, 600]
let mut ticks = 0
// Access lens[5] via arithmetic; each iteration the iter_expr is re-evaluated.
for outer in 0..500 {
    for i in 0..lens[5] {
        ticks = ticks + 1
    }
}
println("counter_heavy ticks=" + str(ticks))

// ── B) arithmetic-heavy body ──
let NB = 300
let mut acc = 0
for i in 0..NB {
    for j in 0..NB {
        for k in 0..NB {
            acc = acc + i + j - k
        }
    }
}
println("arith_heavy NB=" + str(NB) + " acc=" + str(acc))
