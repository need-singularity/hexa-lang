// bench/import_chain.hexa — module loader cold path.
// Spec asked for `use training/nn_core + corpus_loader` but those
// modules don't exist in this repo (they live in anima). We instead
// chain two real self-host modules — lexer + parser — through the
// `import` mechanism, which exercises the same module_loader.hexa
// preprocessing pass that bt 39/rt 33 instrumented.
//
// The point is to time module resolution + concatenation + reparse
// of a multi-thousand-line transitive import set, not the module
// content itself.

import "self/lexer.hexa"
import "self/parser.hexa"

println("import_chain ok")
