// bench/quick_sort_n256.hexa — quick sort over 256 ints, 10 reps.
// S-2b cost-learner fixture. Matches registry needle "quick".
// Lomuto partition variant — simple, recursive on both halves.
// In-place via index bounds; pivot = arr[hi].

fn qsort(arr, lo, hi) {
    if lo >= hi {
        return arr
    }
    // Partition (Lomuto): pivot = arr[hi]; i tracks boundary of <=pivot.
    let pivot = arr[hi]
    let mut i = lo - 1
    let mut j = lo
    while j < hi {
        if arr[j] <= pivot {
            i = i + 1
            let t = arr[i]
            arr[i] = arr[j]
            arr[j] = t
        }
        j = j + 1
    }
    // Place pivot at i+1.
    let pivot_idx = i + 1
    let t2 = arr[pivot_idx]
    arr[pivot_idx] = arr[hi]
    arr[hi] = t2

    let mut a2 = qsort(arr, lo, pivot_idx - 1)
    a2 = qsort(a2, pivot_idx + 1, hi)
    return a2
}

let N = 256
let REPS = 10

let mut out_first = 0
let mut out_last  = 0

let mut r = 0
while r < REPS {
    let mut arr = []
    let mut seed = 55443322 + r * 41
    let mut fill = 0
    while fill < N {
        seed = (seed * 1103515245 + 12345) % 2147483648
        arr = arr + [seed % 100000]
        fill = fill + 1
    }

    arr = qsort(arr, 0, N - 1)

    if r == REPS - 1 {
        out_first = arr[0]
        out_last  = arr[N - 1]
    }
    r = r + 1
}

println("quick_sort_n256 first=" + str(out_first) + " last=" + str(out_last))
