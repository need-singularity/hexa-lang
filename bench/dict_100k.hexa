// bench/dict_100k.hexa — 100K string->int insert + lookup.
// Matches rust_baseline/dict_100k.rs.

let N = 100000
let mut m = #{}

let mut i = 0
while i < N {
    let key = "k" + str(i)
    m[key] = i * i
    i = i + 1
}

let mut acc = 0
let mut j = 0
while j < N {
    let key = "k" + str(j)
    acc = acc + m[key]
    j = j + 1
}

println("dict_100k N=" + str(N) + " len=" + str(len(m)) + " acc=" + str(acc))
