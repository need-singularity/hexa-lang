// bench/simple_loop.hexa — 100K arithmetic loop.
// Pure interpreter dispatch micro: BinOp + Assign + while header in a
// tight 100,000-iteration loop. No allocations after warmup.
// Best test for ns/op of the eval_expr hot path.

let N = 100000
let mut i = 0
let mut acc = 0
while i < N {
    acc = acc + i * 3 - 1
    i = i + 1
}
println("simple_loop N=" + str(N) + " acc=" + str(acc))
