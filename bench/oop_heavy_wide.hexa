// bench/oop_heavy_wide.hexa — rt#37 IC stress test on wide struct
// 10-field struct; read the LAST field in a hot loop. Baseline linear-scan
// walks 10 strcmps per access; IC is O(1) after warmup.

struct Wide {
    a: int,
    b: int,
    c: int,
    d: int,
    e: int,
    f: int,
    g: int,
    h: int,
    i_: int,
    j: int
}

fn sum_last(w, n) {
    let mut s = 0
    let mut k = 0
    while k < n {
        s = s + w.j
        k = k + 1
    }
    return s
}

let w = Wide { a: 1, b: 2, c: 3, d: 4, e: 5, f: 6, g: 7, h: 8, i_: 9, j: 10 }
let r1 = sum_last(w, 5000000)
let r2 = sum_last(w, 5000000)
let r3 = sum_last(w, 5000000)
let r4 = sum_last(w, 5000000)
let total = r1 + r2 + r3 + r4
println("total:", total)
println("done")
