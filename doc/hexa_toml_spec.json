{
  "id": "hexa-toml-spec",
  "kind": "package_manifest_spec",
  "version": "1.0.0",
  "updated": "2026-04-11",
  "role": "HEXA-LANG 자체 패키지 매니페스트 규격 (self-host, Rust/cargo 대체)",
  "rationale": "src/ 완전 삭제 + Cargo.toml 제거 후 hexa-lang은 cargo 생태계에서 이탈. 자체 패키지 매니페스트 포맷 필요. TOML 문법을 재사용하되, 필드 스키마는 HEXA-LANG의 n=6 설계 원칙(σ·τ+sopfr=53, J₂=24, σ-τ=8)에 맞춰 새로 정의.",
  "filename": "hexa.toml",
  "comparison_to_cargo": {
    "cargo.toml": "Rust 크레이트, 컴파일러/런타임 Rust, crates.io 중앙 registry",
    "hexa.toml": "HEXA 패키지, 컴파일러/런타임 HEXA self-host, pkg/hx 분산 registry (hx tap user/repo)"
  },
  "sections": {
    "package": {
      "required": ["name", "version", "entry"],
      "optional": ["description", "license", "authors", "repository", "homepage", "keywords", "categories", "readme"],
      "fields": {
        "name": {"type": "string", "format": "kebab-case", "example": "anima"},
        "version": {"type": "string", "format": "semver", "example": "0.1.0"},
        "entry": {"type": "string", "description": "main .hexa file (relative path)", "example": "main.hexa"},
        "description": {"type": "string", "max_length": 140},
        "license": {"type": "string", "format": "SPDX identifier", "example": "MIT"},
        "authors": {"type": "array<string>", "example": ["박민우 <nerve011235@gmail.com>"]},
        "repository": {"type": "string", "format": "URL"},
        "homepage": {"type": "string", "format": "URL"},
        "keywords": {"type": "array<string>", "max_items": 6, "n6": "keywords count mirrors σ(6)=12 / 2 = 6"},
        "categories": {"type": "array<string>", "max_items": 4, "n6": "τ(6)=4 categories max"}
      }
    },
    "dependencies": {
      "type": "map<name, version_spec>",
      "version_spec": {
        "simple": "^0.1.0",
        "full": {
          "version": "^0.1.0",
          "source": "registry | git | local",
          "repo": "https://github.com/user/repo (if source=git)",
          "path": "./vendored/lib (if source=local)",
          "features": ["feat1", "feat2"]
        }
      },
      "example": {
        "anima-core": "^0.1.0",
        "nexus": {"version": "^2.0", "source": "git", "repo": "https://github.com/need-singularity/nexus"},
        "local-lib": {"source": "local", "path": "./vendored/local-lib"}
      }
    },
    "build": {
      "optional": true,
      "fields": {
        "script": {"type": "string", "default": "build_hexa.hexa", "description": "hexa build entry script"},
        "artifacts": {"type": "array<string>", "description": "output file paths", "example": ["./hexa", "./hexa_test"]},
        "stages": {"type": "array<string>", "default": ["stage1", "stage2", "stage3"], "description": "build_hexa.hexa stages"}
      }
    },
    "targets": {
      "optional": true,
      "description": "cross-compilation targets (host → device)",
      "fields": {
        "host": {"type": "string", "default": "aarch64-apple-darwin"},
        "targets": {
          "type": "array<object>",
          "example": [
            {"name": "esp32", "arch": "xtensa", "codegen": "self/codegen_esp32.hexa"},
            {"name": "wgsl", "arch": "gpu", "codegen": "self/codegen_wgsl.hexa"},
            {"name": "verilog", "arch": "fpga", "codegen": "self/codegen_verilog.hexa"}
          ]
        }
      }
    },
    "features": {
      "optional": true,
      "description": "conditional compilation flags",
      "fields": {
        "default": {"type": "array<string>", "example": ["blas", "jit"]},
        "all": {"type": "map<name, array<string>>"}
      }
    },
    "bin": {
      "optional": true,
      "description": "executable entry points (multiple binaries)",
      "fields": {
        "type": "array<object>",
        "schema": {"name": "string", "path": "string"},
        "example": [
          {"name": "hexa", "path": "self/main.hexa"},
          {"name": "hexa_test", "path": "self/test_runner.hexa"}
        ]
      }
    },
    "lib": {
      "optional": true,
      "description": "library target (for importable module)",
      "fields": {
        "entry": {"type": "string", "default": "self/lib.hexa"},
        "exports": {"type": "array<string>", "description": "public module names"}
      }
    },
    "test": {
      "optional": true,
      "fields": {
        "runner": {"type": "string", "default": "hexa --test"},
        "files": {"type": "array<string>", "default": ["self/test_*.hexa"]},
        "baseline": {"type": "int", "description": "expected passing count (for regression detection)"}
      }
    },
    "workspace": {
      "optional": true,
      "description": "multi-package workspace (monorepo)",
      "fields": {
        "members": {"type": "array<string>", "example": ["pkg/hx", "playground", "editors/jetbrains"]}
      }
    }
  },
  "example_minimal": "[package]\nname = \"anima\"\nversion = \"0.1.0\"\nentry = \"main.hexa\"\n",
  "example_full": "[package]\nname = \"anima\"\nversion = \"0.1.0\"\ndescription = \"AI consciousness substrate — anima-core/body/engines\"\nlicense = \"MIT\"\nauthors = [\"박민우 <nerve011235@gmail.com>\"]\nrepository = \"https://github.com/need-singularity/anima\"\nkeywords = [\"consciousness\", \"ai\", \"hexa\", \"n6\", \"anima\", \"singularity\"]\ncategories = [\"ai\", \"consciousness\", \"language\", \"n6\"]\nentry = \"anima/launch.hexa\"\nreadme = \"README.md\"\n\n[dependencies]\nnexus = { version = \"^2.0\", source = \"git\", repo = \"https://github.com/need-singularity/nexus\" }\nhexa-lang = \"^1.0\"\n\n[build]\nscript = \"build_hexa.hexa\"\nartifacts = [\"./anima\"]\nstages = [\"stage1\", \"stage2\", \"stage3\"]\n\n[features]\ndefault = [\"blas\", \"jit\"]\n\n[bin]\nname = \"anima\"\npath = \"anima/launch.hexa\"\n\n[test]\nrunner = \"hexa --test\"\nfiles = [\"self/test_*.hexa\"]\nbaseline = 205\n",
  "migration_from_cargo": {
    "step_1": "Cargo.toml → hexa.toml (field rename: package, dependencies, build, etc.)",
    "step_2": "src/ → self/ (all .rs → .hexa ports)",
    "step_3": "cargo build → ./hexa (precompiled) or build_hexa.hexa (bootstrap)",
    "step_4": "cargo install → hx install <pkg> (via pkg/hx manager)",
    "step_5": "crates.io → pkg/hx registry + hx tap <user>/<repo> for distributed tapping",
    "completion": "src/ deleted → Cargo.toml deleted → .cargo/ deleted → Rust-free"
  },
  "tooling": {
    "parser": "self/hexa_toml_parser.hexa (TBD — TOML subset parser self-host)",
    "validator": "self/hexa_toml_validator.hexa (TBD — schema validation)",
    "package_manager": "pkg/hx (pure bash, zero deps; self-host hexa port TBD)",
    "build_driver": "build_hexa.hexa (existing; cargo-free pipeline)"
  },
  "n6_alignment": {
    "section_count": 9,
    "rationale": "9 sections = τ(9)=3×3 minor, but near σ(6)=12/τ(6)=3 ratio",
    "primitive_types": "string/int/array/map/bool/URL/semver/path — 8 primitives = σ-τ (matches hexa lang primitives)",
    "max_keywords": 6,
    "max_categories": 4
  },
  "status": "draft-1.0.0",
  "next_steps": [
    "implement self/hexa_toml_parser.hexa (TOML subset)",
    "write hexa.toml for hexa-lang repo itself (replaces deleted Cargo.toml)",
    "port pkg/hx to self-host hexa",
    "update build_hexa.hexa to consume hexa.toml",
    "document hexa.toml format in docs/spec.md"
  ]
}
