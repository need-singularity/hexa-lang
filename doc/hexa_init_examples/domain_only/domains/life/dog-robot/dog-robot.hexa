// domains/life/dog-robot/dog-robot.hexa
// preset=domain_only — 기존 프로젝트에 도메인 하나만 추가.
// project.hexa 는 수정하지 않음. domains/<axis>/<id>/ 디렉토리만 신규.

// ─────────────────────────────────────────────────────────────
// @domain attr — 도메인 seed. hexa self/attr_cli.hexa lint 로 검증.
// ─────────────────────────────────────────────────────────────

// @domain(id="dog-robot", axis="life", mk_target="mk1", alien_now=7, alien_target=10, intent="create")

// ─────────────────────────────────────────────────────────────
// 도메인 메타 정의
// ─────────────────────────────────────────────────────────────

struct DomainMeta {
    id:           string,
    axis:         string,
    name_ko:      string,
    summary:      string,
    mk_target:    string,
    alien_now:    int,
    alien_target: int
}

fn domain_meta() -> DomainMeta {
    return DomainMeta {
        id:           "dog-robot",
        axis:         "life",
        name_ko:      "개 로봇",
        summary:      "반려견 수준 동반 로봇 설계 — 감각/움직임/소통 3축",
        mk_target:    "mk1",
        alien_now:    7,
        alien_target: 10
    }
}

// ─────────────────────────────────────────────────────────────
// mk history — mk1 첫 버전 (3 줄 이상 필수)
// ─────────────────────────────────────────────────────────────

fn mk_history() -> [string] {
    return [
        "mk1 (2026-04-18): 초기 seed. 4 다리 + 센서 8 종 + 음성 합성 기본.",
        "다음(mk2): 감정 표현 (꼬리/귀 움직임) 추가 예정.",
        "다음(mk3): 학습형 행동 (주인 습관 학습) 예정."
    ]
}
