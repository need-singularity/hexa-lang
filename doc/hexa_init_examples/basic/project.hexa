// project.hexa — hexa project (preset=basic)
//
// basic preset = project.hexa + README.md + .gitignore 3 파일.
// Claude Code/인간 onboarding 에 충분한 최소 세트.
// @readme_rules 기본 블록 1 개로 README.md 가 lint 통과.

@project(
    name      = "example-project",
    version   = "0.1.0",
    hexa_lang = "/Users/ghost/core/hexa-lang"
)

@rules_meta {
    inherit = false
    version = 1
    updated = "2026-04-18"
}

@readme_rules(scope="root") {
    sections = ["Overview", "Quick Start", "Architecture", "Contributing", "License"]
    require_codeblock = false
    require_mdlink    = false
    require_sealed    = false
}

// 기존 호환성 — ProjectMeta struct 도 병기 (기존 툴 호환)
struct ProjectMeta {
    name: string,
    hexa_lang: string,
    ssot_attrs: [string],
    local_overrides: [string]
}

fn project_meta() -> ProjectMeta {
    return ProjectMeta {
        name: "example-project",
        hexa_lang: "/Users/ghost/core/hexa-lang",
        ssot_attrs: ["dispatch", "naming", "self_host", "ai_native"],
        local_overrides: []
    }
}

// 추가 규칙은 @<attr>_rules 블록으로:
//   @doc_rules(type="spec") { sections = [...] }
//   @sealed_rules { hash_algorithm = "sdbm+len" }
