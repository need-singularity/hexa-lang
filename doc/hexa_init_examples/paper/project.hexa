// project.hexa — hexa project (preset=paper)
//
// paper preset = 논문·도메인 중심. n6-arch/anima 류.
// §1-21 canonical paper 섹션 + 10 축 도메인 + publish 규칙 전부 포함.

@project(
    name      = "example-paper-project",
    version   = "1.0",
    hexa_lang = "/Users/ghost/core/hexa-lang"
)

@rules_meta {
    inherit = false
    version = 1
    updated = "2026-04-18"
}

// ─────────────────────────────────────────────────────────────
// @doc_rules — paper/rfc/adr 3 종 type 지원
// ─────────────────────────────────────────────────────────────

@doc_rules(type="paper") {
    sections = ["WHY", "COMPARE", "REQUIRES", "STRUCT", "FLOW", "EVOLVE", "VERIFY",
                "EXEC SUMMARY", "SYSTEM REQUIREMENTS", "ARCHITECTURE",
                "CIRCUIT DESIGN", "PCB DESIGN", "FIRMWARE", "MECHANICAL",
                "MANUFACTURING", "TEST", "BOM", "VENDOR", "ACCEPTANCE",
                "APPENDIX", "IMPACT"]
    require_ascii_check  = true
    require_verify       = true
    require_mk_history   = true
    mk_history_min_lines = 3
}

@doc_rules(type="rfc") {
    sections = ["Status", "Abstract", "Introduction", "Requirements",
                "Security Considerations"]
}

@doc_rules(type="adr") {
    sections = ["Context", "Decision", "Consequences"]
}

// ─────────────────────────────────────────────────────────────
// @readme_rules — root + project + domain 3 scope
// ─────────────────────────────────────────────────────────────

@readme_rules(scope="root") {
    sections = ["Overview", "Quick Start", "Architecture", "Domains",
                "Contributing", "License"]
    require_codeblock = false
    require_sealed    = true
}

@readme_rules(scope="domain") {
    sections       = []
    require_mdlink = true
    _domain_hints  = true
}

// ─────────────────────────────────────────────────────────────
// @domain_rules — 10 축 default
// ─────────────────────────────────────────────────────────────

@domain_rules {
    axes = ["compute", "life", "energy", "material", "space",
            "number", "signal", "bio", "chem", "sf-ufo"]
    required_fields  = ["id", "axis"]
    id_max_length    = 40
    intent_values    = ["create", "update", "auto"]
    intent_default   = "create"
    mk_target_default    = "mk1"
    alien_now_default    = 7
    alien_target_default = 10
    require_prev_tag_when_not_mk1 = true
}

// ─────────────────────────────────────────────────────────────
// @sealed_rules — sdbm+len, info 최초
// ─────────────────────────────────────────────────────────────

@sealed_rules {
    hash_algorithm      = "sdbm+len"
    sidecar_suffix      = ".sealed.hash"
    first_seal_severity = "info"
    mismatch_severity   = "error"
    max_lines_for_file_decl = 50
}

// ─────────────────────────────────────────────────────────────
// @publish_rules — main branch only, 한글 커밋
// ─────────────────────────────────────────────────────────────

@publish_rules {
    allowed_branches  = ["main"]
    remote            = "origin"
    default_auto      = false
    default_push      = false
    create_template   = "feat({axis}): {name_ko} 도메인 신규 등록 (@publish)"
    update_template   = "chore({axis}): {entry_id} {mk_target} 업데이트 (@publish)"
    encoding          = "utf-8"
    language          = "ko"
}

// 기존 호환성
struct ProjectMeta {
    name: string,
    hexa_lang: string,
    ssot_attrs: [string],
    local_overrides: [string]
}

fn project_meta() -> ProjectMeta {
    return ProjectMeta {
        name: "example-paper-project",
        hexa_lang: "/Users/ghost/core/hexa-lang",
        ssot_attrs: ["dispatch", "naming", "self_host", "ai_native"],
        local_overrides: []
    }
}
