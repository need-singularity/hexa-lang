// project.hexa — hexa project (preset=hub)
//
// hub preset = 여러 프로젝트가 참조하는 공용 허브 리포. nexus 스타일.
// shared/config/, shared/rules/, shared/harness/ 3 서브디렉토리가 관례.

@project(
    name      = "example-hub",
    version   = "1.0",
    hexa_lang = "/Users/ghost/Dev/hexa-lang"
)

@rules_meta {
    inherit = false
    version = 1
    updated = "2026-04-18"
}

// ─────────────────────────────────────────────────────────────
// @doc_rules — 허브는 RFC/ADR 중심
// ─────────────────────────────────────────────────────────────

@doc_rules(type="rfc") {
    sections = ["Status", "Abstract", "Introduction", "Requirements",
                "Security Considerations"]
}

@doc_rules(type="adr") {
    sections = ["Context", "Decision", "Consequences"]
}

// ─────────────────────────────────────────────────────────────
// @readme_rules — root + module (하위 서브리포)
// ─────────────────────────────────────────────────────────────

@readme_rules(scope="root") {
    sections = ["Overview", "Architecture", "Projects", "Shared Rules",
                "Contributing", "License"]
    require_codeblock = true
    require_sealed    = true      // 허브 root README 엄격 봉인
}

@readme_rules(scope="module") {
    sections = ["Purpose", "Dependencies", "API", "Usage", "Safety"]
    require_codeblock = true
}

// ─────────────────────────────────────────────────────────────
// @sealed_rules — 허브는 엄격 봉인 (변경 차단)
// ─────────────────────────────────────────────────────────────

@sealed_rules {
    hash_algorithm      = "sdbm+len"
    sidecar_suffix      = ".sealed.hash"
    first_seal_severity = "warn"       // 허브는 최초 봉인도 warn
    mismatch_severity   = "error"
    max_lines_for_file_decl = 50
}

// ─────────────────────────────────────────────────────────────
// @publish_rules — 허브는 main push 금지, develop 브랜치
// ─────────────────────────────────────────────────────────────

@publish_rules {
    allowed_branches = ["develop"]
    remote           = "origin"
    default_auto     = false
    default_push     = false
}

// 기존 호환성
struct ProjectMeta {
    name: string,
    hexa_lang: string,
    ssot_attrs: [string],
    local_overrides: [string]
}

fn project_meta() -> ProjectMeta {
    return ProjectMeta {
        name: "example-hub",
        hexa_lang: "/Users/ghost/Dev/hexa-lang",
        ssot_attrs: ["dispatch", "naming", "self_host", "ai_native"],
        local_overrides: []
    }
}
