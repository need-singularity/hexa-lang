// n6-architecture.project.hexa — n6-arch 전용 project.hexa 초안 (옵션 β)
//
// 역할: n6-architecture 는 **논문·도메인 중심** 프로젝트.
//       §1-§21 full paper + 295 도메인 scaffold + git publish 정책 전부 담김.
//
// 문법: self_format_architecture.md §5-3-3 옵션 β 채택.
//   @<attr>_rules[(selector)]
//   let _<attr>_<suffix> = #{...hexa map literal...}
//
// 배치: /Users/ghost/Dev/n6-architecture/project.hexa (기존 36줄 → 이 내용으로 교체)

@project(
    name      = "n6-architecture",
    version   = "1.0",
    hexa_lang = "/Users/ghost/Dev/hexa-lang"
)
let _project_meta = #{
    "name": "n6-architecture",
    "version": "1.0",
    "hexa_lang": "/Users/ghost/Dev/hexa-lang"
}

@rules_meta
let _rules_meta = #{
    "inherit": false,
    "version": 1,
    "updated": "2026-04-18"
}

// ─────────────────────────────────────────────────────────────
// @doc_rules — §1-§21 canonical paper 강제
// ─────────────────────────────────────────────────────────────

@doc_rules(type="paper")
let _doc_rules_paper = #{
    "sections": ["WHY", "COMPARE", "REQUIRES", "STRUCT", "FLOW", "EVOLVE", "VERIFY",
                 "EXEC SUMMARY", "SYSTEM REQUIREMENTS", "ARCHITECTURE",
                 "CIRCUIT DESIGN", "PCB DESIGN", "FIRMWARE", "MECHANICAL",
                 "MANUFACTURING", "TEST", "BOM", "VENDOR", "ACCEPTANCE",
                 "APPENDIX", "IMPACT"],
    "require_ascii_check": true,
    "require_verify": true,
    "require_mk_history": true,
    "mk_history_min_lines": 3
}

@doc_rules(type="rfc")
let _doc_rules_rfc = #{
    "sections": ["Status", "Abstract", "Introduction", "Requirements",
                 "Security Considerations"]
}

@doc_rules(type="adr")
let _doc_rules_adr = #{
    "sections": ["Context", "Decision", "Consequences"]
}

// ─────────────────────────────────────────────────────────────
// @readme_rules — root + 서브 프로젝트 + 295 도메인
// ─────────────────────────────────────────────────────────────

@readme_rules(scope="root")
let _readme_rules_root = #{
    "sections": ["Overview", "Quick Start", "Architecture", "Domains",
                 "Contributing", "License"],
    "require_codeblock": false,
    "require_mdlink": false,
    "require_sealed": true
}

@readme_rules(scope="project")
let _readme_rules_project = #{
    "sections": ["Purpose", "Usage", "Structure", "Dependencies", "Test", "License"],
    "require_codeblock": true,
    "require_sealed": false
}

@readme_rules(scope="domain")
let _readme_rules_domain = #{
    "sections": [],
    "require_mdlink": true,
    "_domain_hints": true
}

// ─────────────────────────────────────────────────────────────
// @domain_rules — 10축 고정, mk1~mk5 규약
// ─────────────────────────────────────────────────────────────

@domain_rules
let _domain_rules = #{
    "axes": ["compute", "life", "energy", "material", "space",
             "number", "signal", "bio", "chem", "sf-ufo"],
    "required_fields": ["id", "axis"],
    "id_max_length": 40,
    "id_pattern": "lowercase-kebab",
    "intent_values": ["create", "update", "auto"],
    "intent_default": "create",
    "mk_target_default": "mk1",
    "alien_now_default": 7,
    "alien_target_default": 10,
    "registry_path": "n6shared/n6/docs/domains.json",
    "scaffold_files": ["<id>.md", "CLAUDE.md"],
    "require_prev_tag_when_not_mk1": true
}

// ─────────────────────────────────────────────────────────────
// @sealed_rules — sdbm+len, info 최초 봉인
// ─────────────────────────────────────────────────────────────

@sealed_rules
let _sealed_rules = #{
    "hash_algorithm": "sdbm+len",
    "sidecar_suffix": ".sealed.hash",
    "first_seal_severity": "info",
    "mismatch_severity": "error",
    "max_lines_for_file_decl": 50
    // 기본: 모든 수정 차단. 도메인 md 는 @domain,@doc 경유 허용.
}

// ─────────────────────────────────────────────────────────────
// @publish_rules — main branch only, 한글 커밋
// ─────────────────────────────────────────────────────────────

@publish_rules
let _publish_rules = #{
    "allowed_branches": ["main"],
    "remote": "origin",
    "default_auto": false,
    "default_push": false,
    "require_doc_zero_violations": true,
    "dirty_check_allow_only_target": true,
    "create_template": "feat({axis}): {name_ko} 도메인 신규 등록 (@publish)",
    "update_template": "chore({axis}): {entry_id} {mk_target} 업데이트 (@publish)",
    "body_lines": ["- @doc(type=paper) 위반 0 확인",
                   "- domains.json entry id: {entry_id}",
                   "- md: {md_rel}",
                   "- 자동 실행: @publish(auto=true) attr"],
    "encoding": "utf-8",
    "language": "ko",
    "registry_path": "/Users/ghost/Dev/nexus/shared/n6/docs/domains.json"
}

// ─── 로컬 fn — n6-arch 전용 규칙 유도 ───────────────────────

fn local_alien_target_for_axis(axis: string) -> int {
    // 축별 외계인 지수 목표 (특정 축은 더 높게)
    if axis == "compute" { return 12 }
    if axis == "number"  { return 12 }
    return 10
}
