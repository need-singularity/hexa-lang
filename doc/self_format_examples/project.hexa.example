// project.hexa.example — hexa-lang self-format 최종 추천안 (옵션 β)
//
// 이 파일은 템플릿이다. 새 프로젝트를 시작할 때 이 파일을 복사하여
// <project_root>/project.hexa 로 두고 필요한 블록만 채운다.
//
// 규칙:
//   - JSON 금지 (.{attr}-rules.json 사용 금지)
//   - 이 파일이 프로젝트의 단일 SSOT
//   - @<attr>_rules 블록이 없으면 글로벌 default ($HEXA_LANG/self/attrs/_defaults.hexa) 사용
//   - @<attr>_rules 블록이 있으면 _meta.inherit=false (default) 로 단독 사용
//
// 문법 (옵션 β — self_format_architecture.md §5-3-3 구현 주석):
//   @<attr>_rules[(selector)]
//   let _<attr>_<suffix> = #{...hexa map literal...}
//
// 이렇게 선언하면 project.hexa 전체가 valid hexa 파일이 되어 `hexa parse` 통과.
// 원 설계안의 body-block (`@<attr>_rules { k = v }`) 은 파서 확장 필요했으나,
// β 는 기존 hexa 파서 0 수정으로 바로 동작. 본 파서(project_parser.hexa)는
// 텍스트 스캔으로 attribute + `let _<name> = #{...}` 쌍을 추출.

// ─────────────────────────────────────────────────────────────
// 1) 프로젝트 헤더 (@project) — 필수 1회
// ─────────────────────────────────────────────────────────────

@project(
    name      = "example-project",
    version   = "0.1.0",
    hexa_lang = "/Users/ghost/Dev/hexa-lang"
)
let _project_meta = #{
    "name": "example-project",
    "version": "0.1.0",
    "hexa_lang": "/Users/ghost/Dev/hexa-lang"
}

// ─────────────────────────────────────────────────────────────
// 2) 상속 여부 (@rules_meta) — 선택. 생략 시 inherit=false.
// ─────────────────────────────────────────────────────────────

@rules_meta
let _rules_meta = #{
    "inherit": false,
    "version": 1,
    "updated": "2026-04-18"
}

// ─────────────────────────────────────────────────────────────
// 3) @doc_rules — 문서 type 별 필수 섹션
//    selector: type="paper|rfc|adr|spec|whitepaper"
// ─────────────────────────────────────────────────────────────

@doc_rules(type="paper")
let _doc_rules_paper = #{
    "sections": ["WHY", "COMPARE", "REQUIRES", "STRUCT", "FLOW", "EVOLVE", "VERIFY",
                 "EXEC SUMMARY", "SYSTEM REQUIREMENTS", "ARCHITECTURE", "CIRCUIT DESIGN",
                 "PCB DESIGN", "FIRMWARE", "MECHANICAL", "MANUFACTURING", "TEST",
                 "BOM", "VENDOR", "ACCEPTANCE", "APPENDIX", "IMPACT"],
    "require_ascii_check": true,
    "require_verify": true,
    "require_mk_history": true,
    "mk_history_min_lines": 3
}

@doc_rules(type="rfc")
let _doc_rules_rfc = #{
    "sections": ["Status", "Abstract", "Introduction", "Requirements",
                 "Security Considerations"],
    "require_ascii_check": false,
    "require_verify": false,
    "require_mk_history": false
}

@doc_rules(type="adr")
let _doc_rules_adr = #{
    "sections": ["Context", "Decision", "Consequences"]
}

// ─────────────────────────────────────────────────────────────
// 4) @readme_rules — scope 별 README 양식
//    selector: scope="root|project|domain|attr-doc|..."
// ─────────────────────────────────────────────────────────────

@readme_rules(scope="root")
let _readme_rules_root = #{
    "sections": ["Overview", "Quick Start", "Architecture", "Contributing", "License"],
    "require_codeblock": false,
    "require_mdlink": false,
    "require_sealed": false
}

@readme_rules(scope="project")
let _readme_rules_project = #{
    "sections": ["Purpose", "Usage", "Structure", "Dependencies", "Test", "License"],
    "require_codeblock": true,
    "require_sealed": false
}

@readme_rules(scope="domain")
let _readme_rules_domain = #{
    "sections": [],
    "require_mdlink": true,
    "_domain_hints": true
}

// ─────────────────────────────────────────────────────────────
// 5) @domain_rules — 도메인 scaffold 규약
// ─────────────────────────────────────────────────────────────

@domain_rules
let _domain_rules = #{
    "axes": ["compute", "life", "energy", "material", "space",
             "number", "signal", "bio", "chem", "sf-ufo"],
    "required_fields": ["id", "axis"],
    "id_max_length": 40,
    "intent_values": ["create", "update", "auto"],
    "intent_default": "create",
    "mk_target_default": "mk1",
    "alien_now_default": 7,
    "alien_target_default": 10,
    "registry_path": "n6shared/n6/docs/domains.json",
    "require_prev_tag_when_not_mk1": true
}

// ─────────────────────────────────────────────────────────────
// 6) @sealed_rules — 봉인 알고리즘 / severity
// ─────────────────────────────────────────────────────────────

@sealed_rules
let _sealed_rules = #{
    "hash_algorithm": "sdbm+len",
    "sidecar_suffix": ".sealed.hash",
    "first_seal_severity": "info",
    "mismatch_severity": "error",
    "max_lines_for_file_decl": 50
}

// ─────────────────────────────────────────────────────────────
// 7) @publish_rules — git commit/push 정책
// ─────────────────────────────────────────────────────────────

@publish_rules
let _publish_rules = #{
    "allowed_branches": ["main"],
    "remote": "origin",
    "default_auto": false,
    "default_push": false,
    "create_template": "feat({axis}): {name_ko} 도메인 신규 등록 (@publish)",
    "update_template": "chore({axis}): {entry_id} {mk_target} 업데이트 (@publish)",
    "encoding": "utf-8",
    "language": "ko"
}

// ─────────────────────────────────────────────────────────────
// 8) (선택) 프로젝트 로컬 fn — 규칙 유도용
//    @attr 체크가 호출 가능한 fn 을 여기 선언.
// ─────────────────────────────────────────────────────────────

fn local_doc_sections_for(paper_type: string) -> [string] {
    // 예: preprint 은 brief 만, camera-ready 는 full
    if paper_type == "preprint" {
        return ["WHY", "COMPARE", "VERIFY"]
    }
    return []   // empty → @doc_rules 기본 sections 사용
}
