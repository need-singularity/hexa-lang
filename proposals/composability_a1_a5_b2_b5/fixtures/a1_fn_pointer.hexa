// proposals/composability_a1_a5_b2_b5/fixtures/a1_fn_pointer.hexa
//
// A1 first-class fn-pointer contract fixture (§6 of a1_first_class_fn_pointers.md).
//
// 7 cases covering the §2 contract table:
//   1. Direct invoke through typed slot
//   2. Pass typed slot as fn arg (higher-order)
//   3. Return typed slot from a fn (factory)
//   4. Store in array of fn-pointers
//   5. Closure env-capture survives slot lifetime
//   6. Compose: return-from-fn into pass-as-arg
//   7. type_of(typed slot) is non-"unknown"
//
// IMPORTANT — current runtime gap (verified 2026-05-02):
//   `let cb = handler_double` (bare-named-fn → value coercion) currently silently
//   aborts the interpreter (exit 0, zero stdout). This is exactly the gap A1 RFC §0
//   describes — closures work, but bare-named-fn coercion does not.
//
//   This fixture works around the gap by wrapping bare fn refs in lambdas
//   (`|x| handler_double(x)`), which IS supported today. Post-A1-impl, the
//   fixture should be UPDATED to drop the wrappers and exercise the bare form
//   directly — that is the falsifier surface for §2 contract row 1.
//
// Fixture status under current runtime:
//   - All 7 cases PASS via lambda-wrapper baseline form
//   - Post-impl: drop wrappers; same 7 cases must continue to PASS

fn handler_double(n: int) -> int { return n * 2 }
fn handler_inc(n: int) -> int    { return n + 1 }

fn apply_fn(f, x: int) -> int { return f(x) }

fn make_handler() {
    return |n| handler_double(n)
}

fn main() {
    let mut pass: i64 = 0
    let mut fail: i64 = 0

    // Case 1: direct invoke through typed slot (lambda baseline)
    let cb1 = |x| handler_double(x)
    if cb1(7) == 14 { pass = pass + 1 } else {
        println("FAIL a1.case1 direct_invoke: expected 14"); fail = fail + 1
    }

    // Case 2: pass typed slot as fn arg
    let cb2 = |x| handler_inc(x)
    if apply_fn(cb2, 41) == 42 { pass = pass + 1 } else {
        println("FAIL a1.case2 pass_as_arg: expected 42"); fail = fail + 1
    }

    // Case 3: return typed slot from fn (factory)
    let factored = make_handler()
    if factored(5) == 10 { pass = pass + 1 } else {
        println("FAIL a1.case3 return_from_fn: expected 10"); fail = fail + 1
    }

    // Case 4: store in array of fn-pointers (lambda form works today)
    let arr = [|x| handler_double(x), |x| handler_inc(x)]
    let v = arr[0](6)
    if v == 12 { pass = pass + 1 } else {
        println("FAIL a1.case4 array_store: expected 12"); fail = fail + 1
    }

    // Case 5: closure env-capture survives slot lifetime
    let factor = 3
    let cb5 = |x| x * factor
    if cb5(4) == 12 { pass = pass + 1 } else {
        println("FAIL a1.case5 closure_env_capture: expected 12"); fail = fail + 1
    }

    // Case 6: composability — return-from-fn into pass-as-arg
    let cb6 = make_handler()
    if apply_fn(cb6, 11) == 22 { pass = pass + 1 } else {
        println("FAIL a1.case6 compose_return_then_apply: expected 22"); fail = fail + 1
    }

    // Case 7: type_of must not be "unknown" (locked by 0adac579)
    let cb7 = |x| handler_double(x)
    let t = type_of(cb7)
    if t != "unknown" { pass = pass + 1 } else {
        println("FAIL a1.case7 type_of_unknown_regression: " + t); fail = fail + 1
    }

    println("__A1_FN_POINTER_FIXTURE__ pass=" + to_string(pass) + " fail=" + to_string(fail) + " of=7")
    if fail == 0 {
        println("__A1_FN_POINTER_FIXTURE__ verdict=PASS")
    } else {
        println("__A1_FN_POINTER_FIXTURE__ verdict=FAIL")
    }
}
