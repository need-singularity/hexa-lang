// proposals/composability_a1_a5_b2_b5/fixtures/a5_parallel_block.hexa
//
// A5 real parallel block + worker pool fixture (§6 of a5_real_parallel_block.md).
//
// 6 cases:
//   1. Join barrier — bindings inside `parallel { }` are well-defined after the block
//   2. Scope hoisting — `let` inside the block is visible outside
//   3. Sequential degradation — HEXA_PARALLEL_WORKERS=1 produces same result as no parallel
//   4. Pool init — first parallel{} block lazy-inits the pool without crash
//   5. Side-effect non-determinism (within) — order of println inside is unspecified (we do NOT assert order)
//   6. Side-effect determinism (across) — println after the block always appears after all units complete
//
// Status under current runtime:
//   - `parallel { }` block keyword is NOT yet recognized by parser (per spec)
//   - This fixture compiles only after A5 lexer+parser+codegen lands
//   - Stub form below uses comments to mark the eventual surface; runtime falls back to
//     sequential form for the unmodified-runtime baseline (cases 1, 2, 3, 6 all PASS
//     under sequential exec; cases 4, 5 are no-ops under sequential)
//
// To exercise pre-impl baseline: run as-is — fixture exits PASS via sequential paths.
// Post-impl: parser will accept `parallel { }` directly; replace stubs.

fn cube(n: int) -> int { return n * n * n }

fn main() {
    let mut pass: i64 = 0
    let mut fail: i64 = 0

    // Case 1 — join barrier (sequential baseline form; replace with `parallel { }` post-impl)
    let mut a: i64 = 0
    let mut b: i64 = 0
    let mut c: i64 = 0
    // PARALLEL_BLOCK_BEGIN
    a = cube(2)
    b = cube(3)
    c = cube(4)
    // PARALLEL_BLOCK_END_JOIN
    if a == 8 && b == 27 && c == 64 { pass = pass + 1 } else {
        println("FAIL a5.case1 join_barrier"); fail = fail + 1
    }

    // Case 2 — scope hoisting
    let sum = a + b + c
    if sum == 99 { pass = pass + 1 } else {
        println("FAIL a5.case2 scope_hoisting: expected 99 got " + to_string(sum)); fail = fail + 1
    }

    // Case 3 — sequential degradation (HEXA_PARALLEL_WORKERS=1 simulated by stubbed form)
    let mut total: i64 = 0
    let mut i: i64 = 0
    while i < 10 {
        // PARALLEL_UNIT
        total = total + i
        i = i + 1
    }
    if total == 45 { pass = pass + 1 } else {
        println("FAIL a5.case3 sequential_degradation"); fail = fail + 1
    }

    // Case 4 — pool init (no-op pre-impl; post-impl asserts pool is initialized w/o crash)
    // Pre-impl baseline: trivially PASS.
    pass = pass + 1

    // Case 5 — side-effect non-determinism within block (do NOT assert; just run)
    let mut counter: i64 = 0
    counter = counter + 1
    counter = counter + 1
    counter = counter + 1
    if counter == 3 { pass = pass + 1 } else {
        println("FAIL a5.case5 within_block_count"); fail = fail + 1
    }

    // Case 6 — across-block determinism: this println MUST appear after the block work
    let after_marker = "after_join_marker"
    if after_marker == "after_join_marker" { pass = pass + 1 } else {
        println("FAIL a5.case6 across_block_determinism"); fail = fail + 1
    }

    println("__A5_PARALLEL_BLOCK_FIXTURE__ pass=" + to_string(pass) + " fail=" + to_string(fail) + " of=6")
    if fail == 0 {
        println("__A5_PARALLEL_BLOCK_FIXTURE__ verdict=PASS")
    } else {
        println("__A5_PARALLEL_BLOCK_FIXTURE__ verdict=FAIL")
    }
}
