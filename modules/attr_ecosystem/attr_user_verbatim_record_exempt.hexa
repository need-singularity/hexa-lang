#!hexa strict
// @tool(slug="attr_user_verbatim_record_exempt", desc="hexa-lang @user-verbatim-record-exempt(reason) — formalized exemption marker for record JSON lint")
// @sentinel(__ATTR_USER_VERBATIM_RECORD_EXEMPT__ <PASS|FAIL> mode=<selftest>)
// @usage(hexa hexa-lang/modules/attr_ecosystem/attr_user_verbatim_record_exempt.hexa)
// @resolver-bypass(reason="local module selftest, no network/heavy compute")
//
// hexa-lang/modules/attr_ecosystem/attr_user_verbatim_record_exempt.hexa
//   B6 @user-verbatim-record-exempt(reason)
//
// SPEC (signature)
//   @user-verbatim-record-exempt(reason="<>= 12 chars rationale>")
//
// SEMANTICS
//   Marks a declaration / file as exempt from the BR-NO-USER-VERBATIM
//   lint rule that forbids verbatim user-prompt text in tracked
//   artifacts (record JSON, handoff docs, markers).
//
//   The presence of this attr signals that the surrounding text is
//   either (a) test fixture intentionally containing prompt-like
//   text, or (b) a documented session-record snapshot that has gone
//   through legal/policy review.
//
//   The reason= field is REQUIRED and must be >= 12 chars to deter
//   reflexive use of the exemption.
//
// LINT INTEGRATION
//   The record-JSON lint pipeline:
//     1. Scans tracked artifacts for prompt-like phrases.
//     2. For each candidate hit, walks back to the nearest decl
//        boundary and looks for `// @user-verbatim-record-exempt(...)`.
//     3. If present + valid → suppress the issue.
//     4. If absent → emit a `verbatim-leak` warning.
//   The lint pipeline is NOT in this module; this module is the
//   attr enforcer (parse + validate + emit) only.
//
// RAW#10 CAVEATS
//   (1) reason= is enforced by validate(). The attr is INTENTIONALLY
//       expensive to write so that contributors think before applying.
//   (2) This module does NOT inspect the artifact body for actual
//       verbatim leaks — that is the lint pipeline's job. We only
//       formalize the exemption marker.
//   (3) Cross-repo: the attr name uses dashes for readability;
//       internal storage normalizes to underscore_name in AttrDecl.

// ── Mirror shapes ────────────────────────────────────────────

struct AttrFormatMeta {
    name:                 str,
    version:              int,
    form:                 str,
    phase:                str,
    status:               str,
    supports_composition: int,
    supports_typing:      int,
    catalog_size:         int,
    spec_doc:             str,
    notes:                str
}

struct AttrDecl {
    name:         str,
    params:       [str],
    line:         int,
    col:          int,
    mode:         str,
    form_version: str
}

struct AttrParseResult {
    ok:       int,
    n_decls:  int,
    decls:    [AttrDecl],
    message:  str
}

struct AttrIssue {
    severity:  str,
    attr_name: str,
    line:      int,
    msg:       str
}

struct AttrValidateResult {
    ok:        int,
    n_issues:  int,
    issues:    [AttrIssue],
    message:   str
}

// ── Helpers ──────────────────────────────────────────────────

fn _uvre_decl(params: [str], line: int) -> AttrDecl {
    return AttrDecl {
        name: "user_verbatim_record_exempt",
        params: params,
        line: line,
        col: 1,
        mode: "decl",
        form_version: "ecosystem_b6"
    }
}

fn _uvre_issue(sev: str, line: int, msg: str) -> AttrIssue {
    return AttrIssue { severity: sev, attr_name: "user_verbatim_record_exempt", line: line, msg: msg }
}

// Find substring index of needle in haystack, -1 if missing.
fn _uvre_index(haystack: str, needle: str) -> int {
    let mut i = 0
    while i + len(needle) <= len(haystack) {
        if haystack.substring(i, i + len(needle)) == needle { return i }
        i = i + 1
    }
    return -1
}

fn _uvre_extract_payload_for(trimmed: str, marker: str) -> str {
    let idx = _uvre_index(trimmed, marker)
    if idx < 0 { return "" }
    let after = trimmed.substring(idx + len(marker), len(trimmed))
    let mut depth = 1
    let mut j = 0
    while j < len(after) {
        let c = after.substring(j, j + 1)
        if c == "(" { depth = depth + 1 }
        if c == ")" {
            depth = depth - 1
            if depth == 0 { return after.substring(0, j) }
        }
        j = j + 1
    }
    return ""
}

fn _uvre_split_kv(payload: str) -> [str] {
    let mut out = []
    let mut cur = ""
    let mut in_str = 0
    let mut i = 0
    while i < len(payload) {
        let c = payload.substring(i, i + 1)
        if c == "\"" {
            if in_str == 1 { in_str = 0 } else { in_str = 1 }
            cur = cur + c
        } else if c == "," {
            if in_str == 0 {
                let t = cur.trim()
                if len(t) > 0 { out = out.push(t) }
                cur = ""
            } else {
                cur = cur + c
            }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    let t2 = cur.trim()
    if len(t2) > 0 { out = out.push(t2) }
    return out
}

fn _uvre_kv_key(pair: str) -> str {
    let eq = pair.index_of("=")
    if eq < 0 { return pair.trim() }
    return pair.substring(0, eq).trim()
}

fn _uvre_kv_value(pair: str) -> str {
    let eq = pair.index_of("=")
    if eq < 0 { return "" }
    let mut v = pair.substring(eq + 1, len(pair)).trim()
    if len(v) >= 2 {
        let first = v.substring(0, 1)
        let last  = v.substring(len(v) - 1, len(v))
        if first == "\"" {
            if last == "\"" { v = v.substring(1, len(v) - 1) }
        }
    }
    return v
}

// ── Public API ───────────────────────────────────────────────

fn attr_user_verbatim_record_exempt_meta() -> AttrFormatMeta {
    return AttrFormatMeta {
        name:                 "user_verbatim_record_exempt",
        version:              1,
        form:                 "comment",
        phase:                "ecosystem_mk2",
        status:               "WRAPPED",
        supports_composition: 0,
        supports_typing:      1,
        catalog_size:         1,
        spec_doc:             "hexa-lang/docs/hexa_lang_attr_ecosystem_b3_b4_b6_b7_b9_landed_2026_05_02.ai.md",
        notes:                "B6 @user-verbatim-record-exempt(reason) — record-lint exemption marker"
    }
}

// Parse: accept both dashed canonical and underscore variant.
fn attr_user_verbatim_record_exempt_parse(src: str) -> AttrParseResult {
    if len(src) < 1 {
        return AttrParseResult { ok: 0, n_decls: 0, decls: [], message: "empty source" }
    }
    let lines = src.split("\n")
    let mut decls = []
    let m1 = "@user-verbatim-record-exempt("
    let m2 = "@user_verbatim_record_exempt("
    let mut i = 0
    while i < len(lines) {
        let trimmed = lines[i].trim()
        let mut payload = ""
        let mut hit = 0
        if trimmed.contains(m1) {
            payload = _uvre_extract_payload_for(trimmed, m1)
            hit = 1
        }
        if hit == 0 {
            if trimmed.contains(m2) {
                payload = _uvre_extract_payload_for(trimmed, m2)
                hit = 1
            }
        }
        if hit == 1 {
            let pairs = _uvre_split_kv(payload)
            decls = decls.push(_uvre_decl(pairs, i + 1))
        }
        i = i + 1
    }
    return AttrParseResult { ok: 1, n_decls: len(decls), decls: decls, message: "uvre: " + str(len(decls)) + " decl(s)" }
}

fn attr_user_verbatim_record_exempt_validate(decls: [AttrDecl]) -> AttrValidateResult {
    let mut issues = []
    let mut i = 0
    while i < len(decls) {
        let d = decls[i]
        let mut have_reason = 0
        let mut short_reason = ""
        let mut empty_reason = 0
        let mut k = 0
        while k < len(d.params) {
            let key = _uvre_kv_key(d.params[k])
            let val = _uvre_kv_value(d.params[k])
            if key == "reason" {
                have_reason = 1
                if len(val) == 0 { empty_reason = 1 }
                if len(val) > 0 {
                    if len(val) < 12 { short_reason = val }
                }
            }
            k = k + 1
        }
        if have_reason == 0 {
            issues = issues.push(_uvre_issue("error", d.line, "missing required key `reason`"))
        }
        if empty_reason == 1 {
            issues = issues.push(_uvre_issue("error", d.line, "reason is empty"))
        }
        if len(short_reason) > 0 {
            issues = issues.push(_uvre_issue("error", d.line, "reason `" + short_reason + "` too short — require >= 12 chars"))
        }
        i = i + 1
    }
    let mut any_error = 0
    let mut e = 0
    while e < len(issues) {
        if issues[e].severity == "error" { any_error = 1 }
        e = e + 1
    }
    let okv = if any_error == 1 { 0 } else { 1 }
    return AttrValidateResult { ok: okv, n_issues: len(issues), issues: issues, message: "uvre: " + str(len(issues)) + " issue(s)" }
}

// Apply exemption → returns 1 when caller should suppress a lint
// `verbatim-leak` issue on the line range of the decl. Caller has
// already located a candidate verbatim hit at `hit_line`. If any
// validated exemption exists with line in [hit_line - window, hit_line]
// we suppress.
fn attr_user_verbatim_record_exempt_applies(decls: [AttrDecl], hit_line: int, window: int) -> int {
    let mut i = 0
    while i < len(decls) {
        let d = decls[i]
        if d.line >= hit_line - window {
            if d.line <= hit_line { return 1 }
        }
        i = i + 1
    }
    return 0
}

fn attr_user_verbatim_record_exempt_emit(pr: AttrParseResult) -> str {
    let mut parts = []
    parts = parts.push("@user-verbatim-record-exempt emit: " + str(pr.n_decls) + " exemption(s)")
    let mut i = 0
    while i < len(pr.decls) {
        let d = pr.decls[i]
        parts = parts.push("  L" + str(d.line) + " params=" + str(len(d.params)))
        i = i + 1
    }
    return parts.join("\n")
}

// ── Selftest ─────────────────────────────────────────────────

fn _selftest() -> int {
    // 1. meta
    let m = attr_user_verbatim_record_exempt_meta()
    if m.name != "user_verbatim_record_exempt" { return 0 }
    // 2. parse 0
    let pr0 = attr_user_verbatim_record_exempt_parse("// nothing\n")
    if pr0.n_decls != 0 { return 0 }
    // 3. parse dashed valid
    let s1 = "// @user-verbatim-record-exempt(reason=\"reviewed test fixture rationale\")\n"
    let pr1 = attr_user_verbatim_record_exempt_parse(s1)
    if pr1.n_decls != 1 { return 0 }
    let vr1 = attr_user_verbatim_record_exempt_validate(pr1.decls)
    if vr1.ok != 1 { return 0 }
    // 4. parse underscore variant
    let s2 = "// @user_verbatim_record_exempt(reason=\"long enough rationale here\")\n"
    let pr2 = attr_user_verbatim_record_exempt_parse(s2)
    if pr2.n_decls != 1 { return 0 }
    let vr2 = attr_user_verbatim_record_exempt_validate(pr2.decls)
    if vr2.ok != 1 { return 0 }
    // 5. parse missing reason
    let s3 = "// @user-verbatim-record-exempt()\n"
    let pr3 = attr_user_verbatim_record_exempt_parse(s3)
    let vr3 = attr_user_verbatim_record_exempt_validate(pr3.decls)
    if vr3.ok != 0 { return 0 }
    // 6. parse short reason
    let s4 = "// @user-verbatim-record-exempt(reason=\"too short\")\n"
    let pr4 = attr_user_verbatim_record_exempt_parse(s4)
    let vr4 = attr_user_verbatim_record_exempt_validate(pr4.decls)
    if vr4.ok != 0 { return 0 }
    // 7. parse empty reason value
    let s5 = "// @user-verbatim-record-exempt(reason=\"\")\n"
    let pr5 = attr_user_verbatim_record_exempt_parse(s5)
    let vr5 = attr_user_verbatim_record_exempt_validate(pr5.decls)
    if vr5.ok != 0 { return 0 }
    // 8. applies window — exemption on line 3 should cover hit on line 5 with window=3
    let s6 = "// header\n// header\n// @user-verbatim-record-exempt(reason=\"covers hit at L5 fixture\")\nfn f() {}\nlet some_text = \"verbatim probe\"\n"
    let pr6 = attr_user_verbatim_record_exempt_parse(s6)
    if pr6.n_decls != 1 { return 0 }
    let app1 = attr_user_verbatim_record_exempt_applies(pr6.decls, 5, 3)
    if app1 != 1 { return 0 }
    // 9. applies window — same decl should not cover line 1 (decl is below)
    let app2 = attr_user_verbatim_record_exempt_applies(pr6.decls, 1, 3)
    if app2 != 0 { return 0 }
    // 10. emit non-empty
    let em = attr_user_verbatim_record_exempt_emit(pr6)
    if len(em) < 10 { return 0 }
    return 1
}

fn main() {
    println("[attr_ecosystem/user-verbatim-record-exempt] B6 reason= guard")
    if _selftest() == 1 {
        println("[attr_ecosystem/user-verbatim-record-exempt] SELFTEST PASS")
        println("__ATTR_USER_VERBATIM_RECORD_EXEMPT__ PASS mode=selftest")
    } else {
        println("[attr_ecosystem/user-verbatim-record-exempt] SELFTEST FAIL")
        println("__ATTR_USER_VERBATIM_RECORD_EXEMPT__ FAIL mode=selftest")
    }
}
