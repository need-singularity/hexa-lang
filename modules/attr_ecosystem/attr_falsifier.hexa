#!hexa strict
// @tool(slug="attr_falsifier", desc="hexa-lang @falsifier(id, desc, observable, action_on_fail) — inline preregistered falsification clause (raw 92 spirit, mk2 new)")
// @sentinel(__ATTR_FALSIFIER__ <PASS|FAIL> mode=<selftest>)
// @usage(hexa hexa-lang/modules/attr_ecosystem/attr_falsifier.hexa)
// @resolver-bypass(reason="local module selftest, no network/heavy compute")
//
// hexa-lang/modules/attr_ecosystem/attr_falsifier.hexa — B3 @falsifier
//
// SPEC (signature)
//   @falsifier(id="<short-id>", desc="<one-line>",
//              observable="<measurable>",
//              action_on_fail="warn" | "block" | "quarantine")
//
// SEMANTICS
//   Inline pre-registration of a falsification clause attached to a
//   declaration (fn / struct / file). Each falsifier captures four
//   required keys:
//     id              — short slug, [a-z0-9_]{2,40}
//     desc            — one-line description (>= 8 chars)
//     observable      — what would be measured to detect failure
//     action_on_fail  — one of: warn | block | quarantine
//   This attr is a static contract. The runtime semantics are
//   enforced by sister tooling (action_on_fail dispatch is owned
//   by lint pipeline). The attr enforcer here only validates the
//   parameter shape and emits machine-readable issues.
//
// RAW#10 CAVEATS
//   (1) Inline-only: this module parses string source. Cross-file
//       falsifier aggregation is deferred (will land via a sister
//       tool that consumes parse() output).
//   (2) action_on_fail=block does NOT actually block in this attr
//       module. The lint pipeline reads parse() decls and decides.
//   (3) observable= is free-form; v2 may add a typed schema.

// ── Mirror of attr_format AttrFormatMeta + AttrDecl shapes ────

struct AttrFormatMeta {
    name:                 str,
    version:              int,
    form:                 str,
    phase:                str,
    status:               str,
    supports_composition: int,
    supports_typing:      int,
    catalog_size:         int,
    spec_doc:             str,
    notes:                str
}

struct AttrDecl {
    name:         str,
    params:       [str],
    line:         int,
    col:          int,
    mode:         str,
    form_version: str
}

struct AttrParseResult {
    ok:       int,
    n_decls:  int,
    decls:    [AttrDecl],
    message:  str
}

struct AttrIssue {
    severity:  str,
    attr_name: str,
    line:      int,
    msg:       str
}

struct AttrValidateResult {
    ok:        int,
    n_issues:  int,
    issues:    [AttrIssue],
    message:   str
}

// ── Helpers ───────────────────────────────────────────────────

fn _fals_decl_make(name: str, params: [str], line: int) -> AttrDecl {
    return AttrDecl { name: name, params: params, line: line, col: 1, mode: "decl", form_version: "ecosystem_b3" }
}

fn _fals_issue(severity: str, line: int, msg: str) -> AttrIssue {
    return AttrIssue { severity: severity, attr_name: "falsifier", line: line, msg: msg }
}

fn _fals_parse_ok(decls: [AttrDecl], msg: str) -> AttrParseResult {
    return AttrParseResult { ok: 1, n_decls: len(decls), decls: decls, message: msg }
}

fn _fals_parse_fail(reason: str) -> AttrParseResult {
    return AttrParseResult { ok: 0, n_decls: 0, decls: [], message: reason }
}

fn _fals_validate(issues: [AttrIssue], msg: str) -> AttrValidateResult {
    let mut any_error = 0
    let mut i = 0
    while i < len(issues) {
        if issues[i].severity == "error" { any_error = 1 }
        i = i + 1
    }
    let okv = if any_error == 1 { 0 } else { 1 }
    return AttrValidateResult { ok: okv, n_issues: len(issues), issues: issues, message: msg }
}

// Extract the substring inside the first matching `(...)` after `@falsifier`
// on a given trimmed line. Returns "" when not found / unbalanced.
fn _fals_extract_payload(trimmed: str) -> str {
    let marker = "@falsifier("
    let mut idx = -1
    let mut i = 0
    while i + len(marker) <= len(trimmed) {
        if trimmed.substring(i, i + len(marker)) == marker {
            idx = i
            i = len(trimmed) + 1
        } else {
            i = i + 1
        }
    }
    if idx < 0 { return "" }
    let after = trimmed.substring(idx + len(marker), len(trimmed))
    let mut depth = 1
    let mut j = 0
    while j < len(after) {
        let c = after.substring(j, j + 1)
        if c == "(" { depth = depth + 1 }
        if c == ")" {
            depth = depth - 1
            if depth == 0 { return after.substring(0, j) }
        }
        j = j + 1
    }
    return ""
}

// Naive key=value comma split, respecting quoted strings. Returns
// list of "key=value" pairs (value may contain `=` if quoted).
fn _fals_split_kv(payload: str) -> [str] {
    let mut out = []
    let mut cur = ""
    let mut in_str = 0
    let mut i = 0
    while i < len(payload) {
        let c = payload.substring(i, i + 1)
        if c == "\"" {
            if in_str == 1 { in_str = 0 } else { in_str = 1 }
            cur = cur + c
        } else if c == "," {
            if in_str == 0 {
                let t = cur.trim()
                if len(t) > 0 { out = out.push(t) }
                cur = ""
            } else {
                cur = cur + c
            }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    let t2 = cur.trim()
    if len(t2) > 0 { out = out.push(t2) }
    return out
}

fn _fals_kv_key(pair: str) -> str {
    let eq = pair.index_of("=")
    if eq < 0 { return pair.trim() }
    return pair.substring(0, eq).trim()
}

fn _fals_kv_value(pair: str) -> str {
    let eq = pair.index_of("=")
    if eq < 0 { return "" }
    let mut v = pair.substring(eq + 1, len(pair)).trim()
    if len(v) >= 2 {
        let first = v.substring(0, 1)
        let last  = v.substring(len(v) - 1, len(v))
        if first == "\"" {
            if last == "\"" { v = v.substring(1, len(v) - 1) }
        }
    }
    return v
}

fn _fals_action_ok(action: str) -> int {
    if action == "warn"       { return 1 }
    if action == "block"      { return 1 }
    if action == "quarantine" { return 1 }
    return 0
}

// ── Public API ────────────────────────────────────────────────

fn attr_falsifier_meta() -> AttrFormatMeta {
    return AttrFormatMeta {
        name:                 "falsifier",
        version:              1,
        form:                 "comment",
        phase:                "ecosystem_mk2",
        status:               "WRAPPED",
        supports_composition: 0,
        supports_typing:      1,
        catalog_size:         1,
        spec_doc:             "hexa-lang/docs/hexa_lang_attr_ecosystem_b3_b4_b6_b7_b9_landed_2026_05_02.ai.md",
        notes:                "B3 @falsifier(id, desc, observable, action_on_fail) — inline preregister"
    }
}

// Parse a source string and emit one AttrDecl per `@falsifier(...)` site.
fn attr_falsifier_parse(src: str) -> AttrParseResult {
    if len(src) < 1 { return _fals_parse_fail("empty source") }
    let lines = src.split("\n")
    let mut decls = []
    let mut i = 0
    while i < len(lines) {
        let trimmed = lines[i].trim()
        if trimmed.contains("@falsifier(") {
            let payload = _fals_extract_payload(trimmed)
            let pairs = _fals_split_kv(payload)
            let d = _fals_decl_make("falsifier", pairs, i + 1)
            decls = decls.push(d)
        }
        i = i + 1
    }
    return _fals_parse_ok(decls, "falsifier: extracted " + str(len(decls)) + " decl(s)")
}

// Validate that every parsed @falsifier carries 4 required keys with
// well-formed values.
fn attr_falsifier_validate(decls: [AttrDecl]) -> AttrValidateResult {
    let mut issues = []
    let mut i = 0
    while i < len(decls) {
        let d = decls[i]
        let mut have_id     = 0
        let mut have_desc   = 0
        let mut have_obs    = 0
        let mut have_action = 0
        let mut bad_action  = ""
        let mut bad_id      = ""
        let mut short_desc  = ""
        let mut k = 0
        while k < len(d.params) {
            let key = _fals_kv_key(d.params[k])
            let val = _fals_kv_value(d.params[k])
            if key == "id" {
                have_id = 1
                // id check: [a-z0-9_], len 2..40
                let mut ok = 1
                if len(val) < 2 { ok = 0 }
                if len(val) > 40 { ok = 0 }
                let mut p = 0
                while p < len(val) {
                    let c = val.substring(p, p + 1)
                    let lower = (c == "a") || (c == "b") || (c == "c") || (c == "d") || (c == "e") || (c == "f") || (c == "g") || (c == "h") || (c == "i") || (c == "j") || (c == "k") || (c == "l") || (c == "m") || (c == "n") || (c == "o") || (c == "p") || (c == "q") || (c == "r") || (c == "s") || (c == "t") || (c == "u") || (c == "v") || (c == "w") || (c == "x") || (c == "y") || (c == "z")
                    let digit = (c == "0") || (c == "1") || (c == "2") || (c == "3") || (c == "4") || (c == "5") || (c == "6") || (c == "7") || (c == "8") || (c == "9")
                    let under = c == "_"
                    if lower == false {
                        if digit == false {
                            if under == false { ok = 0 }
                        }
                    }
                    p = p + 1
                }
                if ok == 0 { bad_id = val }
            }
            if key == "desc" {
                have_desc = 1
                if len(val) < 8 { short_desc = val }
            }
            if key == "observable" { have_obs = 1 }
            if key == "action_on_fail" {
                have_action = 1
                if _fals_action_ok(val) == 0 { bad_action = val }
            }
            k = k + 1
        }
        if have_id     == 0 { issues = issues.push(_fals_issue("error", d.line, "missing required key `id`")) }
        if have_desc   == 0 { issues = issues.push(_fals_issue("error", d.line, "missing required key `desc`")) }
        if have_obs    == 0 { issues = issues.push(_fals_issue("error", d.line, "missing required key `observable`")) }
        if have_action == 0 { issues = issues.push(_fals_issue("error", d.line, "missing required key `action_on_fail`")) }
        if len(bad_id) > 0 {
            issues = issues.push(_fals_issue("error", d.line, "id `" + bad_id + "` invalid — require [a-z0-9_]{2,40}"))
        }
        if len(short_desc) > 0 {
            issues = issues.push(_fals_issue("warn", d.line, "desc too short (< 8 chars): `" + short_desc + "`"))
        }
        if len(bad_action) > 0 {
            issues = issues.push(_fals_issue("error", d.line, "action_on_fail `" + bad_action + "` not in {warn, block, quarantine}"))
        }
        i = i + 1
    }
    if len(issues) == 0 {
        return _fals_validate(issues, "falsifier: " + str(len(decls)) + " decl(s) validated")
    }
    return _fals_validate(issues, "falsifier: " + str(len(issues)) + " issue(s)")
}

// Emit a short human summary for a parse result (machine-readable line per decl)
fn attr_falsifier_emit(pr: AttrParseResult) -> str {
    let mut parts = []
    parts = parts.push("@falsifier emit: " + str(pr.n_decls) + " decl(s)")
    let mut i = 0
    while i < len(pr.decls) {
        let d = pr.decls[i]
        parts = parts.push("  L" + str(d.line) + " params=" + str(len(d.params)))
        i = i + 1
    }
    return parts.join("\n")
}

// ── Selftest ──────────────────────────────────────────────────

fn _selftest() -> int {
    // 1. meta sanity
    let m = attr_falsifier_meta()
    if m.name != "falsifier" { return 0 }
    if m.status != "WRAPPED" { return 0 }
    // 2. parse 0 → empty result
    let pr0 = attr_falsifier_parse("// nothing here\nfn x() {}\n")
    if pr0.ok != 1 { return 0 }
    if pr0.n_decls != 0 { return 0 }
    // 3. parse 1 valid falsifier
    let synth1 = "// @falsifier(id=\"f_one\", desc=\"detect drift longer\", observable=\"sha256(out)\", action_on_fail=\"warn\")\nfn target() {}\n"
    let pr1 = attr_falsifier_parse(synth1)
    if pr1.ok != 1 { return 0 }
    if pr1.n_decls != 1 { return 0 }
    let vr1 = attr_falsifier_validate(pr1.decls)
    if vr1.ok != 1 { return 0 }
    if vr1.n_issues != 0 { return 0 }
    // 4. parse with bad action
    let synth2 = "// @falsifier(id=\"f_two\", desc=\"detect drift longer\", observable=\"x\", action_on_fail=\"explode\")\n"
    let pr2 = attr_falsifier_parse(synth2)
    let vr2 = attr_falsifier_validate(pr2.decls)
    if vr2.ok != 0 { return 0 }
    if vr2.n_issues < 1 { return 0 }
    // 5. parse with missing keys
    let synth3 = "// @falsifier(id=\"f_three\")\n"
    let pr3 = attr_falsifier_parse(synth3)
    let vr3 = attr_falsifier_validate(pr3.decls)
    if vr3.ok != 0 { return 0 }
    if vr3.n_issues < 3 { return 0 }
    // 6. parse with invalid id chars
    let synth4 = "// @falsifier(id=\"BAD-ID\", desc=\"detect drift longer\", observable=\"x\", action_on_fail=\"block\")\n"
    let pr4 = attr_falsifier_parse(synth4)
    let vr4 = attr_falsifier_validate(pr4.decls)
    if vr4.ok != 0 { return 0 }
    // 7. parse 2 falsifiers same file
    let synth5 = "// @falsifier(id=\"a1\", desc=\"long enough\", observable=\"o\", action_on_fail=\"warn\")\n// @falsifier(id=\"a2\", desc=\"long enough\", observable=\"o\", action_on_fail=\"quarantine\")\n"
    let pr5 = attr_falsifier_parse(synth5)
    if pr5.n_decls != 2 { return 0 }
    let vr5 = attr_falsifier_validate(pr5.decls)
    if vr5.ok != 1 { return 0 }
    // 8. emit produces non-empty
    let em = attr_falsifier_emit(pr5)
    if len(em) < 10 { return 0 }
    // 9. empty source → fail
    let pr_e = attr_falsifier_parse("")
    if pr_e.ok != 0 { return 0 }
    return 1
}

fn main() {
    println("[attr_ecosystem/falsifier] B3 @falsifier(id, desc, observable, action_on_fail)")
    if _selftest() == 1 {
        println("[attr_ecosystem/falsifier] SELFTEST PASS")
        println("__ATTR_FALSIFIER__ PASS mode=selftest")
    } else {
        println("[attr_ecosystem/falsifier] SELFTEST FAIL")
        println("__ATTR_FALSIFIER__ FAIL mode=selftest")
    }
}
