#!hexa strict
// hexa-lang/modules/grammar_format/grammar_v2.hexa — Phase beta (mk2) STUB-FROM-SPEC
//
// @tool(slug="grammar_v2", desc="Phase beta L1 @attr AST + L2 strict mode + L10 attr typing (spec stub)")
// @sentinel(__GRAMMAR_V2__ <PASS|FAIL> mode=selftest)
// @usage(hexa run hexa-lang/modules/grammar_format/grammar_v2.hexa)
//
// Status: STUB-FROM-SPEC
// Phase: beta
// Shebang triggers: #!hexa strict (canonical), #!hexa v2 (alias)
// Spec source: hexa-lang/docs/phase_beta_parser_ext_spec.ai.md (sha ee34720855dc07b3)
//
// Grammar surface (per Phase β spec):
//   L1 — @attr first-class AST decorator (replaces lint-level // @tool comment grep)
//        New AST nodes: AttrDecl{name, params, line, col, mode}, FileAttrs{attrs}
//   L2 — #!hexa strict compile-mode flag (file-level @tool required if strict)
//   L10 — attr parameter typing (schema-driven via stdlib/attrs/<name>.hexa)
//
// Impl status: parser/lexer changes deferred to Phase β impl-1/impl-2/impl-3 cycle
// (~14-19 days estimate per spec §6.4). This module is a SPEC-ONLY STUB:
//   - schema metadata exposed correctly (grammar_meta_v2 returns full GrammarSchema)
//   - parse stub returns ok=0 with sentinel message pointing to spec doc
//   - validate_strict stub returns L1/L2/L10 placeholder issues per spec §3-§5
//
// raw#9 hexa-only strict. raw#10 caveats:
//   (1) parser/lexer changes NOT made — self/parser.hexa (4404L) + self/lexer.hexa
//       (784L) remain byte-identical. v2 grammar surface is pure spec until
//       impl cycle.
//   (2) validate_strict_v2 returns CANONICAL spec-derived issue codes, not
//       runtime-detected ones. For real validation, use grammar_v1 + spec
//       cross-link review until v2 impl lands.
//   (3) Backward compat policy: v2 deprecates `// @tool(...)` comment-form
//       in favor of bare `@tool(...)`; 30-day warn ramp per spec §7.

// ── struct mirror (SSOT: hexa-lang/core/grammar_format/source.hexa) ────

struct GrammarSchema {
    name:             str,
    version:          int,
    phase:            str,
    status:           str,
    shebang_trigger:  str,
    breaking_changes: int,
    spec_source:      str,
    description:      str
}

struct AST {
    ok:      int,
    repr:    str,
    version: int,
    message: str
}

struct Token {
    kind:  str,
    value: str,
    line:  int,
    col:   int
}

struct Issue {
    severity: str,
    code:     str,
    line:     int,
    col:      int,
    msg:      str
}

fn grammar_schema_make(
    name: str, version: int, phase: str, status: str,
    shebang_trigger: str, breaking_changes: int,
    spec_source: str, description: str
) -> GrammarSchema {
    return GrammarSchema {
        name:             name,
        version:          version,
        phase:            phase,
        status:           status,
        shebang_trigger:  shebang_trigger,
        breaking_changes: breaking_changes,
        spec_source:      spec_source,
        description:      description
    }
}

fn grammar_ast_stub(version: int, message: str) -> AST {
    return AST { ok: 0, repr: "STUB", version: version, message: message }
}

// ── Required CONTRACT exports (per source.hexa) ─────────────

fn grammar_meta_v2() -> GrammarSchema {
    return grammar_schema_make(
        "grammar_v2", 2, "beta", "STUB-FROM-SPEC",
        "#!hexa strict", 0,
        "hexa-lang/docs/phase_beta_parser_ext_spec.ai.md",
        "Phase beta: L1 @attr first-class AST + L2 strict mode + L10 attr typing"
    )
}

fn grammar_parse_v2(source: str) -> AST {
    // Spec stub — real parse impl deferred to Phase β impl cycle
    let n = len(source)
    return grammar_ast_stub(
        2,
        "grammar_v2 (Phase beta) STUB-FROM-SPEC: parse not yet implemented (source len=" + str(n) + "); see hexa-lang/docs/phase_beta_parser_ext_spec.ai.md §3-§6"
    )
}

fn grammar_lex_v2(source: str) -> [Token] {
    // Spec stub — would emit ShebangMode token + AttrDecl preserved per spec §4.2
    let mut tokens = []
    if len(source) > 0 {
        tokens = tokens.push(Token { kind: "SpecStubV2", value: "ShebangMode+AttrDecl pending impl", line: 1, col: 1 })
    }
    return tokens
}

fn grammar_validate_strict_v2(ast: AST) -> [Issue] {
    // Spec stub — emits canonical Phase β issue codes per spec §3-§5
    let mut issues = []
    issues = issues.push(Issue {
        severity: "info",
        code:     "L1_ATTR_AST_PENDING",
        line:     0, col: 0,
        msg:      "Phase β L1 (@attr first-class AST) impl pending — see spec §3"
    })
    issues = issues.push(Issue {
        severity: "info",
        code:     "L2_STRICT_MODE_PENDING",
        line:     0, col: 0,
        msg:      "Phase β L2 (#!hexa strict compile-mode) impl pending — see spec §4"
    })
    issues = issues.push(Issue {
        severity: "info",
        code:     "L10_ATTR_TYPING_PENDING",
        line:     0, col: 0,
        msg:      "Phase β L10 (attr parameter typing) impl pending — see spec §5"
    })
    return issues
}

fn grammar_compat_v2(target_version: int) -> int {
    // v2 is backward-compat with v1 (per spec §7) and forward with itself
    if target_version == 1 { return 1 }
    if target_version == 2 { return 1 }
    return 0
}

// ── Selftest ────────────────────────────────────────────────

fn _selftest_v2() -> int {
    // 1. meta returns valid schema
    let m = grammar_meta_v2()
    if m.name != "grammar_v2" { return 0 }
    if m.version != 2 { return 0 }
    if m.status != "STUB-FROM-SPEC" { return 0 }
    if m.phase != "beta" { return 0 }
    if m.spec_source.contains("phase_beta") == false { return 0 }
    // 2. parse always returns stub
    let a = grammar_parse_v2("fn main() {}")
    if a.ok != 0 { return 0 }
    if a.version != 2 { return 0 }
    if a.repr != "STUB" { return 0 }
    if a.message.contains("phase_beta") == false { return 0 }
    // 3. lex returns spec-stub token
    let toks = grammar_lex_v2("fn main() {}")
    if len(toks) != 1 { return 0 }
    if toks[0].kind != "SpecStubV2" { return 0 }
    // 4. validate_strict returns 3 spec-canonical info issues (L1+L2+L10)
    let issues = grammar_validate_strict_v2(grammar_ast_stub(2, "test"))
    if len(issues) != 3 { return 0 }
    let mut found_l1 = 0
    let mut found_l2 = 0
    let mut found_l10 = 0
    let mut i = 0
    while i < len(issues) {
        if issues[i].code == "L1_ATTR_AST_PENDING" { found_l1 = 1 }
        if issues[i].code == "L2_STRICT_MODE_PENDING" { found_l2 = 1 }
        if issues[i].code == "L10_ATTR_TYPING_PENDING" { found_l10 = 1 }
        i = i + 1
    }
    if found_l1 != 1 { return 0 }
    if found_l2 != 1 { return 0 }
    if found_l10 != 1 { return 0 }
    // 5. compat: v2 supports v1 + v2, not v3+
    if grammar_compat_v2(1) != 1 { return 0 }
    if grammar_compat_v2(2) != 1 { return 0 }
    if grammar_compat_v2(3) != 0 { return 0 }
    return 1
}

fn main() {
    println("[grammar_v2] STUB-FROM-SPEC Phase beta (mk2) module")
    if _selftest_v2() == 1 {
        println("[grammar_v2] SELFTEST PASS")
        println("[grammar_v2] __GRAMMAR_V2__ PASS")
    } else {
        println("[grammar_v2] SELFTEST FAIL")
        println("[grammar_v2] __GRAMMAR_V2__ FAIL")
    }
}
