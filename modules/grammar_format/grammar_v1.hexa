#!hexa strict
// hexa-lang/modules/grammar_format/grammar_v1.hexa — current free-form (mk1) WRAPPER
//
// @tool(slug="grammar_v1", desc="Wrapper around canonical self/lexer.hexa + self/parser.hexa (mk1)")
// @sentinel(__GRAMMAR_V1__ <PASS|FAIL> mode=selftest)
// @usage(hexa run hexa-lang/modules/grammar_format/grammar_v1.hexa)
//
// Status: WRAPPED
// Phase: alpha
// Shebang trigger: #!hexa  (or no shebang, default)
//
// This module is a thin wrapper around hexa-lang's canonical lexer/parser:
//   /Users/<user>/core/hexa-lang/self/lexer.hexa  (784 LOC, sha 2324afcc)
//   /Users/<user>/core/hexa-lang/self/parser.hexa (4404 LOC, sha c0f951d1)
//
// Those files are PRESERVED — this module does NOT modify them. The wrapper
// produces a sentinel "WRAPPED-V1(len=N)" repr; actual parsing happens via
// the canonical hexa CLI (`hexa run <file>`). This module exists to satisfy
// the grammar_format core+module pattern (Level 3a recursive dogfooding).
//
// raw#9 hexa-only strict. raw#10 caveats:
//   (1) Wrapper does NOT invoke the canonical parser (stage0 has no
//       cross-file fn import). Real parsing remains in self/lexer.hexa
//       + self/parser.hexa.
//   (2) repr format "WRAPPED-V1(len=N)" is a stable sentinel for testing —
//       not a serialized AST.
//   (3) For full v1 parse semantics, use `hexa run <file>` directly.

// ── struct mirror (SSOT: hexa-lang/core/grammar_format/source.hexa) ────

struct GrammarSchema {
    name:             str,
    version:          int,
    phase:            str,
    status:           str,
    shebang_trigger:  str,
    breaking_changes: int,
    spec_source:      str,
    description:      str
}

struct AST {
    ok:      int,
    repr:    str,
    version: int,
    message: str
}

struct Token {
    kind:  str,
    value: str,
    line:  int,
    col:   int
}

struct Issue {
    severity: str,
    code:     str,
    line:     int,
    col:      int,
    msg:      str
}

fn grammar_schema_make(
    name: str, version: int, phase: str, status: str,
    shebang_trigger: str, breaking_changes: int,
    spec_source: str, description: str
) -> GrammarSchema {
    return GrammarSchema {
        name:             name,
        version:          version,
        phase:            phase,
        status:           status,
        shebang_trigger:  shebang_trigger,
        breaking_changes: breaking_changes,
        spec_source:      spec_source,
        description:      description
    }
}

fn grammar_ast_ok(repr: str, version: int, message: str) -> AST {
    return AST { ok: 1, repr: repr, version: version, message: message }
}

fn grammar_ast_stub(version: int, message: str) -> AST {
    return AST { ok: 0, repr: "STUB", version: version, message: message }
}

// ── Required CONTRACT exports (per source.hexa) ─────────────

fn grammar_meta_v1() -> GrammarSchema {
    return grammar_schema_make(
        "grammar_v1", 1, "alpha", "WRAPPED",
        "#!hexa", 0,
        "",
        "current free-form (mk1) — wraps self/lexer.hexa (784L) + self/parser.hexa (4404L)"
    )
}

fn grammar_parse_v1(source: str) -> AST {
    let n = len(source)
    if n < 1 {
        return grammar_ast_stub(1, "v1: empty source")
    }
    // Wrapper sentinel — real parse happens via canonical hexa CLI
    return grammar_ast_ok(
        "WRAPPED-V1(len=" + str(n) + ")",
        1,
        "v1: ok (wrapper sentinel; real parse via canonical hexa CLI)"
    )
}

fn grammar_lex_v1(source: str) -> [Token] {
    // Wrapper does not actually lex — returns empty token list as sentinel.
    // Real lexing happens via self/lexer.hexa.
    let mut tokens = []
    if len(source) > 0 {
        tokens = tokens.push(Token { kind: "WrappedSentinel", value: "v1", line: 1, col: 1 })
    }
    return tokens
}

fn grammar_validate_strict_v1(ast: AST) -> [Issue] {
    // v1 does not support strict mode (mk1 = pre-strict). Returns empty.
    let mut issues = []
    if ast.ok == 0 {
        issues = issues.push(Issue {
            severity: "info",
            code:     "V1_NO_STRICT",
            line:     0,
            col:      0,
            msg:      "v1 (mk1) does not support strict mode — see grammar_v2 (Phase beta)"
        })
    }
    return issues
}

fn grammar_compat_v1(target_version: int) -> int {
    // v1 is compatible with itself only (mk1 baseline)
    if target_version == 1 { return 1 }
    return 0
}

// ── Selftest ────────────────────────────────────────────────

fn _selftest_v1() -> int {
    // 1. meta returns valid schema
    let m = grammar_meta_v1()
    if m.name != "grammar_v1" { return 0 }
    if m.version != 1 { return 0 }
    if m.status != "WRAPPED" { return 0 }
    if m.phase != "alpha" { return 0 }
    // 2. parse non-empty source returns ok=1
    let a1 = grammar_parse_v1("fn main() {}")
    if a1.ok != 1 { return 0 }
    if a1.version != 1 { return 0 }
    if a1.repr.contains("WRAPPED-V1") == false { return 0 }
    // 3. parse empty source returns stub
    let a2 = grammar_parse_v1("")
    if a2.ok != 0 { return 0 }
    // 4. lex returns sentinel token
    let toks = grammar_lex_v1("fn main() {}")
    if len(toks) != 1 { return 0 }
    if toks[0].kind != "WrappedSentinel" { return 0 }
    // 5. lex empty returns no tokens
    let toks0 = grammar_lex_v1("")
    if len(toks0) != 0 { return 0 }
    // 6. validate_strict returns info-level for failed AST
    let stub_ast = grammar_ast_stub(1, "test")
    let issues = grammar_validate_strict_v1(stub_ast)
    if len(issues) != 1 { return 0 }
    if issues[0].severity != "info" { return 0 }
    if issues[0].code != "V1_NO_STRICT" { return 0 }
    // 7. validate_strict returns empty for ok AST
    let ok_ast = grammar_ast_ok("test", 1, "ok")
    let issues2 = grammar_validate_strict_v1(ok_ast)
    if len(issues2) != 0 { return 0 }
    // 8. compat: v1 -> v1 = 1, v1 -> other = 0
    if grammar_compat_v1(1) != 1 { return 0 }
    if grammar_compat_v1(2) != 0 { return 0 }
    if grammar_compat_v1(3) != 0 { return 0 }
    return 1
}

fn main() {
    println("[grammar_v1] WRAPPED current free-form (mk1) module")
    if _selftest_v1() == 1 {
        println("[grammar_v1] SELFTEST PASS")
        println("[grammar_v1] __GRAMMAR_V1__ PASS")
    } else {
        println("[grammar_v1] SELFTEST FAIL")
        println("[grammar_v1] __GRAMMAR_V1__ FAIL")
    }
}
