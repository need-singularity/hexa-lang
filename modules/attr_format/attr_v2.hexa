#!hexa strict
// @tool(slug="attr_format_v2", desc="hexa-lang attr-format v2 module — AST-level @attr first-class (Phase β L1 spec, impl deferred)")
// @sentinel(__ATTR_FORMAT_V2__ <PASS|FAIL> mode=<selftest>)
// @usage(hexa hexa-lang/modules/attr_format/attr_v2.hexa)
// @resolver-bypass(reason="local module selftest, no network/heavy compute")
//
// hexa-lang/modules/attr_format/attr_v2.hexa — v2 AST first-class (SPEC-STUB)
//
// Spec source: hexa-lang/docs/phase_beta_parser_ext_spec.ai.md §3 (L1)
//
// What v2 introduces over v1:
//   - Bare `@tool(...)` without leading `//` — parser-recognized
//   - AttrDecl AST node with structured params [(key, value, kind)]
//   - File-level vs decl-level placement explicit (FileAttrs struct)
//   - Backward-compat: comment-form still parsed, emits deprecation warn
//
// IMPL STATUS: STUB-FROM-SPEC. Schema/contract surface only.
// parse/validate return SPEC-PENDING; meta describes the target shape.
//
// PRESERVED: hexa-lang/self/parser.hexa is NOT modified by this module.
// When v2 lands, parser.hexa lines 591-865 (per-attr inline switch) get
// replaced by `parse_attr_decl()` returning AttrDecl. That impl is the
// scope of Phase β implementation cycle.
//
// raw#10:
//   (1) parse() returns SPEC-PENDING — no AST hook in stage0.
//   (2) Meta is correct; consumers can dispatch on m.supports_typing/
//       m.supports_composition without depending on impl.

// ── struct mirror ──────────────────────────────────────────────

struct AttrFormatMeta {
    name:                 str,
    version:              int,
    form:                 str,
    phase:                str,
    status:               str,
    supports_composition: int,
    supports_typing:      int,
    catalog_size:         int,
    spec_doc:             str,
    notes:                str
}

struct AttrDecl {
    name:         str,
    params:       [str],
    line:         int,
    col:          int,
    mode:         str,
    form_version: str
}

struct AttrParseResult {
    ok:       int,
    n_decls:  int,
    decls:    [AttrDecl],
    message:  str
}

struct AttrIssue {
    severity:  str,
    attr_name: str,
    line:      int,
    msg:       str
}

struct AttrValidateResult {
    ok:        int,
    n_issues:  int,
    issues:    [AttrIssue],
    message:   str
}

struct AttrExpandResult {
    ok:       int,
    n_decls:  int,
    decls:    [AttrDecl],
    message:  str
}

fn _v2_parse_fail(reason: str) -> AttrParseResult {
    return AttrParseResult { ok: 0, n_decls: 0, decls: [], message: reason }
}

fn _v2_validate_with_issues(issues: [AttrIssue], message: str) -> AttrValidateResult {
    let mut any_error = 0
    let mut i = 0
    while i < len(issues) {
        if issues[i].severity == "error" { any_error = 1 }
        i = i + 1
    }
    let okv = if any_error == 1 { 0 } else { 1 }
    return AttrValidateResult { ok: okv, n_issues: len(issues), issues: issues, message: message }
}

fn _v2_issue_make(severity: str, attr_name: str, line: int, msg: str) -> AttrIssue {
    return AttrIssue { severity: severity, attr_name: attr_name, line: line, msg: msg }
}

fn _v2_expand_fail(reason: str) -> AttrExpandResult {
    return AttrExpandResult { ok: 0, n_decls: 0, decls: [], message: reason }
}

// ── Meta ───────────────────────────────────────────────────────

fn attr_format_meta_v2() -> AttrFormatMeta {
    return AttrFormatMeta {
        name:                 "v2",
        version:              2,
        form:                 "ast",
        phase:                "beta",
        status:               "SPEC-STUB",
        supports_composition: 0,
        supports_typing:      0,
        catalog_size:         24,
        spec_doc:             "hexa-lang/docs/phase_beta_parser_ext_spec.ai.md#L1",
        notes:                "AST-level @attr first-class — parse_attr_decl() replaces per-attr inline switch (parser.hexa:591-865); impl deferred to Phase β"
    }
}

// ── Parse: SPEC-STUB ──────────────────────────────────────────

fn attr_format_parse_v2(src: str) -> AttrParseResult {
    return _v2_parse_fail("v2: SPEC-STUB — Phase β L1 AST `parse_attr_decl()` not implemented (spec at " + attr_format_meta_v2().spec_doc + ")")
}

// ── Validate: SPEC-STUB ───────────────────────────────────────

fn attr_format_validate_v2(decls: [AttrDecl]) -> AttrValidateResult {
    let iss = _v2_issue_make("info", "", 0, "v2: SPEC-STUB — validation pass deferred to Phase β L1 impl cycle")
    return _v2_validate_with_issues([iss], "v2: SPEC-PENDING")
}

// ── Expand: SPEC-STUB (no composition at v2) ──────────────────

fn attr_format_expand_v2(decls: [AttrDecl]) -> AttrExpandResult {
    return _v2_expand_fail("v2: no composition support (composition lands at v4)")
}

// ── Catalog (24 inherited from v1) ────────────────────────────

fn attr_format_catalog_v2() -> [str] {
    let mut a = []
    a = a.push("hot")
    a = a.push("cold")
    a = a.push("fuse")
    a = a.push("memo")
    a = a.push("bench")
    a = a.push("profile")
    a = a.push("inline")
    a = a.push("noinline")
    a = a.push("simd")
    a = a.push("parallel")
    a = a.push("allocate")
    a = a.push("align")
    a = a.push("unroll")
    a = a.push("hxblas")
    a = a.push("trace")
    a = a.push("audit")
    a = a.push("self_replay")
    a = a.push("idempotent")
    a = a.push("retry")
    a = a.push("timeout")
    a = a.push("checkpoint")
    a = a.push("invariant")
    a = a.push("triad")
    a = a.push("deprecated")
    return a
}

// ── Selftest ───────────────────────────────────────────────────

fn _selftest_v2() -> int {
    let m = attr_format_meta_v2()
    if m.name != "v2" { return 0 }
    if m.version != 2 { return 0 }
    if m.status != "SPEC-STUB" { return 0 }
    if m.phase != "beta" { return 0 }
    if m.form != "ast" { return 0 }
    // catalog inherits 24 from v1
    let cat = attr_format_catalog_v2()
    if len(cat) != 24 { return 0 }
    // parse returns SPEC-PENDING
    let pr = attr_format_parse_v2("anything")
    if pr.ok != 0 { return 0 }
    // validate returns ok=1 with info-level issue (no errors)
    let vr = attr_format_validate_v2([])
    if vr.ok != 1 { return 0 }
    if vr.n_issues != 1 { return 0 }
    if vr.issues[0].severity != "info" { return 0 }
    // expand fails (no composition at v2)
    let er = attr_format_expand_v2([])
    if er.ok != 0 { return 0 }
    return 1
}

fn main() {
    println("[attr_format/v2] AST first-class @attr (Phase β L1, SPEC-STUB)")
    if _selftest_v2() == 1 {
        println("[attr_format/v2] SELFTEST PASS")
        println("__ATTR_FORMAT_V2__ PASS mode=selftest")
    } else {
        println("[attr_format/v2] SELFTEST FAIL")
        println("__ATTR_FORMAT_V2__ FAIL mode=selftest")
    }
}
