// gate/claude_statusline_4panel.hexa — 4-panel Claude Code statusLine.
// Panels: CONTEXT (맥락) · SESSION (세션) · EMERGENCE (창발) · ECONOMY (경제)
// Spec: airgenome/docs/statusline_4panel.md
// Step 1 prototype — CONTEXT + SESSION live, EMERGENCE/ECONOMY stubbed with `—`.
// Stdin: CC pipes JSON with {session_id, transcript_path, cwd, model.display_name, …}.
// Stdout: single line. Runs every turn, must stay under 300ms.
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox

let SEP = " ·· "     // panel separator
let DASH = "—"       // stubbed panel placeholder
let HEXA_LANG = env("HEXA_LANG")

fn jq_field(input_sh: str, expr: str) -> str {
    let cmd = "printf '%s' '" + input_sh + "' | jq -r '" + expr + " // empty' 2>/dev/null"
    return to_string(exec(cmd)).trim()  // @allow-bare-exec
}

// CONTEXT — git branch + dirty count. Cwd-scoped; silent outside a repo.
fn panel_context(cwd: str) -> str {
    if cwd.len() == 0 { return "" }
    let cwd_sh = cwd.replace("'", "'\\''")
    // Single git call: branch + ahead/behind + porcelain. parse in awk.
    let cmd = "cd '" + cwd_sh + "' 2>/dev/null && git status --porcelain=v2 --branch --ahead-behind 2>/dev/null"
    let raw = to_string(exec(cmd))  // @allow-bare-exec
    if raw.len() == 0 { return "" }

    let branch = to_string(exec("printf '%s' '" + raw.replace("'", "'\\''") + "' | awk '/^# branch.head/ {print $3; exit}'")).trim()  // @allow-bare-exec
    if branch.len() == 0 { return "" }
    if branch == "(detached)" { return "⎇ (detached)" }

    let dirty = to_string(exec("printf '%s' '" + raw.replace("'", "'\\''") + "' | awk '/^[12u?]/ {n++} END {print n+0}'")).trim()  // @allow-bare-exec
    let ab = to_string(exec("printf '%s' '" + raw.replace("'", "'\\''") + "' | awk '/^# branch.ab/ {print $3, $4; exit}'")).trim()  // @allow-bare-exec

    let mut out = "⎇ " + branch
    if dirty != "0" && dirty.len() > 0 { out = out + " ±" + dirty }
    if ab.len() > 0 {
        // ab = "+N -M" — ahead N, behind M
        let ahead = to_string(exec("echo '" + ab + "' | awk '{print $1}' | tr -d +")).trim()  // @allow-bare-exec
        let behind = to_string(exec("echo '" + ab + "' | awk '{print $2}' | tr -d -")).trim()  // @allow-bare-exec
        if ahead != "0" && ahead.len() > 0 { out = out + " ↑" + ahead }
        if behind != "0" && behind.len() > 0 { out = out + " ↓" + behind }
    }
    return out
}

// SESSION — ctx% · model · turn. ctx% is approximate (last assistant usage / window).
fn panel_session(input_sh: str, model_name: str, transcript_path: str) -> str {
    let model_short = if model_name.len() > 0 { model_name } else { "?" }

    let mut turn = "?"
    let mut ctx_pct = "?"
    if transcript_path.len() > 0 && file_exists(transcript_path) {
        let tp_sh = transcript_path.replace("'", "'\\''")
        // turn = assistant message count
        let t = to_string(exec("grep -c '\"role\":\"assistant\"' '" + tp_sh + "' 2>/dev/null")).trim()  // @allow-bare-exec
        if t.len() > 0 { turn = t }
        // ctx% from last assistant usage: input + cache_read + cache_creation
        // Context window: opus/sonnet/haiku default 200K (1m variant 1M).
        let window = if model_name.contains("1m") || model_name.contains("1M") { "1000000" } else { "200000" }
        let used = to_string(exec("tail -n 200 '" + tp_sh + "' | jq -r 'select(.type==\"assistant\") | ((.message.usage.input_tokens // 0) + (.message.usage.cache_read_input_tokens // 0) + (.message.usage.cache_creation_input_tokens // 0))' 2>/dev/null | tail -1")).trim()  // @allow-bare-exec
        if used.len() > 0 && used != "0" {
            let pct = to_string(exec("echo 'scale=0; " + used + " * 100 / " + window + "' | bc 2>/dev/null")).trim()  // @allow-bare-exec
            if pct.len() > 0 { ctx_pct = pct }
        }
    }

    return "🧠 " + ctx_pct + "% · " + model_short + " · t" + turn
}

// Format elapsed seconds as a short age: "5s" "12m" "3h" "2d".
fn fmt_age(secs: str) -> str {
    let cmd = "awk -v s=" + secs + " 'BEGIN{if(s<60)printf \"%ds\",s;else if(s<3600)printf \"%dm\",s/60;else if(s<86400)printf \"%dh\",s/3600;else printf \"%dd\",s/86400}'"
    return to_string(exec(cmd)).trim()  // @allow-bare-exec
}

// EMERGENCE — S-tier novelty only: latest raw#N + age. Returns DASH if unresolvable.
// Extension points (future): cert count, rig_trend cp, anomaly axis.
fn panel_emergence() -> str {
    if HEXA_LANG.len() == 0 { return DASH }
    let raw_path = HEXA_LANG + "/.raw"
    if file_exists(raw_path) == false { return DASH }

    let rp_sh = raw_path.replace("'", "'\\''")
    let n = to_string(exec("awk '/^raw [0-9]+ / {n=$2} END {print n}' '" + rp_sh + "'")).trim()  // @allow-bare-exec
    if n.len() == 0 { return DASH }

    let mtime = to_string(exec("stat -f %m '" + rp_sh + "' 2>/dev/null")).trim()  // @allow-bare-exec
    if mtime.len() == 0 { return "🌱 raw#" + n }
    let now = to_string(exec("date +%s")).trim()  // @allow-bare-exec
    let elapsed = to_string(exec("awk 'BEGIN{print " + now + " - " + mtime + "}'")).trim()  // @allow-bare-exec
    let age = fmt_age(elapsed)
    if age.len() == 0 { return "🌱 raw#" + n }
    return "🌱 raw#" + n + " ·" + age
}

// Model pricing — $/Mtoken for [input, output, cache_read, cache_write].
// Returned as a 4-number space-separated string for awk consumption.
fn model_rates(name: str) -> str {
    if name.contains("Opus") || name.contains("opus")   { return "15 75 1.50 18.75" }
    if name.contains("Haiku") || name.contains("haiku") { return "0.25 1.25 0.025 0.30" }
    return "3 15 0.30 3.75"   // default: Sonnet tier
}

// ECONOMY — idle since last user turn + cumulative session cost.
fn panel_economy(transcript_path: str, model_name: str) -> str {
    if transcript_path.len() == 0 { return DASH }
    if file_exists(transcript_path) == false { return DASH }
    let tp_sh = transcript_path.replace("'", "'\\''")

    // idle: last user-type timestamp → epoch → age
    let mut idle_str = "?"
    // jq's fromdateiso8601 rejects fractional seconds (".298Z") — strip them first.
    let last_user_epoch = to_string(exec("jq -r 'select(.type==\"user\") | .timestamp // empty | sub(\"\\\\.[0-9]+Z$\"; \"Z\") | fromdateiso8601' '" + tp_sh + "' 2>/dev/null | tail -1")).trim()  // @allow-bare-exec
    if last_user_epoch.len() > 0 {
        let now = to_string(exec("date +%s")).trim()  // @allow-bare-exec
        let elapsed = to_string(exec("awk 'BEGIN{print " + now + " - " + last_user_epoch + "}'")).trim()  // @allow-bare-exec
        let age = fmt_age(elapsed)
        if age.len() > 0 { idle_str = age }
    }

    // cost: accumulate usage across assistant turns, multiply by model rates
    let mut cost_str = "?"
    let sums = to_string(exec("jq -r 'select(.type==\"assistant\") | .message.usage // empty | [(.input_tokens//0),(.output_tokens//0),(.cache_read_input_tokens//0),(.cache_creation_input_tokens//0)] | @tsv' '" + tp_sh + "' 2>/dev/null | awk '{i+=$1; o+=$2; cr+=$3; cw+=$4} END {printf \"%d %d %d %d\", i+0, o+0, cr+0, cw+0}'")).trim()  // @allow-bare-exec
    if sums.len() > 0 {
        let rates = model_rates(model_name)
        let cost = to_string(exec("echo '" + sums + " " + rates + "' | awk '{printf \"%.2f\", ($1*$5 + $2*$6 + $3*$7 + $4*$8)/1e6}'")).trim()  // @allow-bare-exec
        if cost.len() > 0 { cost_str = cost }
    }

    return "⏱ " + idle_str + " · 💸 $" + cost_str
}

fn main() {
    let input = read_stdin()
    if input.len() == 0 {
        println("📁 statusline · no-stdin")
        return
    }
    let input_sh = input.replace("'", "'\\''")

    let cwd = jq_field(input_sh, ".cwd")
    let transcript_path = jq_field(input_sh, ".transcript_path")
    let model_name = jq_field(input_sh, ".model.display_name")

    let ctx = panel_context(cwd)
    let sess = panel_session(input_sh, model_name, transcript_path)
    let emrg = panel_emergence()
    let econ = panel_economy(transcript_path, model_name)

    // Join non-empty panels with SEP.
    let mut parts: [str] = []
    if ctx.len() > 0 { parts.push(ctx) }
    if sess.len() > 0 { parts.push(sess) }
    parts.push(emrg)
    parts.push(econ)

    let mut line = ""
    let mut i = 0
    while i < parts.len() {
        if i > 0 { line = line + SEP }
        line = line + parts[i]
        i = i + 1
    }
    println(line)
}

main()
