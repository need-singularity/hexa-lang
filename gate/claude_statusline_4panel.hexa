// gate/claude_statusline_4panel.hexa — 4-panel Claude Code statusLine.
// Panels: CONTEXT (맥락) · SESSION (세션) · EMERGENCE (창발) · ECONOMY (경제)
// Spec: airgenome/docs/statusline_4panel.md
// Stdin: CC pipes JSON with {session_id, transcript_path, cwd, model.display_name, …}.
// Stdout: single line. Runs every turn, must stay under 300ms.
// Fork budget: 4 exec calls total (stdin, CONTEXT, EMERGENCE, transcript bundle).
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox

// Separators — one place to change if the visual convention shifts.
let SEP  = " ·· "   // panel-to-panel divider
let FSEP = " · "    // inner field divider (within a panel)
let DOT  = "·"      // age / compact prefix (no surrounding spaces)
let DASH = "—"      // panel placeholder when unresolvable
let HEXA_LANG = env("HEXA_LANG")

// CONTEXT — one shell pipe: git status → awk formats the whole ⎇ expression.
// tier: "full" | "compact" | "narrow". Narrow truncates branch + drops ↑↓.
fn panel_context(cwd: str, tier: str) -> str {
    if cwd.len() == 0 { return "" }
    let cwd_sh = cwd.replace("'", "'\\''")
    let cmd = "cd '" + cwd_sh + "' 2>/dev/null && git status --porcelain=v2 --branch --ahead-behind 2>/dev/null | awk -v tier='" + tier + "' '" +
        "/^# branch.head/ {br=$3} " +
        "/^# branch.ab/ {ah=$3; bh=$4} " +
        "/^[12u?]/ {n++} " +
        "END {" +
        "  if (!br) exit;" +
        "  if (tier == \"narrow\") {" +
        "    slash = index(br, \"/\");" +
        "    if (slash > 0) br = substr(br, 1, slash - 1);" +
        "    if (length(br) > 8) br = substr(br, 1, 8);" +
        "  }" +
        "  out = \"⎇ \" br;" +
        "  if (n>0) out = out \" ±\" n;" +
        "  if (tier != \"narrow\") {" +
        "    gsub(/^\\+/,\"\",ah); if (ah>0) out = out \" ↑\" ah;" +
        "    gsub(/^-/,\"\",bh); if (bh>0) out = out \" ↓\" bh;" +
        "  }" +
        "  print out" +
        "}'"
    return to_string(exec(cmd)).trim()  // @allow-bare-exec
}

// EMERGENCE — collect candidates across raw/cert/cp/host_offline axes,
// rank by weight × exp(-Δt/halflife), render top-1 with age suffix.
// Per spec §18 (source matrix) + §19 (ranker).
// Script is written once per run to /tmp to sidestep multi-level quoting.
fn panel_emergence(cwd: str, tier: str, session_id: str) -> str {
    if HEXA_LANG.len() == 0 && cwd.len() == 0 { return DASH }

    let script = "NOW=$(date +%s)\n" +
        "STATE_FILE=\"/tmp/sl-state-${SESSION_ID:-default}\"\n" +
        "LAST_TYPE=\"\"\n" +
        "[ -f \"$STATE_FILE\" ] && LAST_TYPE=$(cat \"$STATE_FILE\" 2>/dev/null)\n" +
        "PHASE=\"\"\n" +
        "[ -f \"$CWD/.roadmap\" ] && PHASE=$(awk '/^# - active \\[P[0-9]\\]/ {match($0, /P[0-9]/); print substr($0, RSTART, RLENGTH); exit}' \"$CWD/.roadmap\" 2>/dev/null)\n" +
        "{\n" +
        "  if [ -n \"$HEXA_LANG\" ] && [ -f \"$HEXA_LANG/.raw\" ]; then\n" +
        "    n=$(awk '/^raw [0-9]+ / {n=$2} END {print n}' \"$HEXA_LANG/.raw\")\n" +
        "    m=$(stat -f %m \"$HEXA_LANG/.raw\" 2>/dev/null)\n" +
        "    [ -n \"$n\" ] && [ -n \"$m\" ] && printf 'raw\\t%s\\t%s\\t4\\t86400\\n' \"$n\" \"$m\"\n" +
        "  fi\n" +
        "  if [ -n \"$HEXA_LANG\" ] && [ -d \"$HEXA_LANG/.meta2-cert\" ]; then\n" +
        "    stat -f '%m %N' \"$HEXA_LANG/.meta2-cert\"/*.json 2>/dev/null | awk -v now=\"$NOW\" '\n" +
        "      { m=$1; n=$2; cnt++; if (m > newest) newest = m\n" +
        "        if (n ~ /\\/transfer_[^\\/]+$/) { tcnt++; if (m > txnewest) txnewest = m } }\n" +
        "      END { if (cnt > 0)  printf \"cert\\t%d\\t%d\\t3\\t259200\\n\", cnt, newest\n" +
        "            if (tcnt > 0) printf \"transfer\\t%d\\t%d\\t1.5\\t259200\\n\", tcnt, txnewest }'\n" +
        "  fi\n" +
        "  if [ -n \"$HEXA_LANG\" ] && [ -f \"$HEXA_LANG/.raw-audit\" ]; then\n" +
        "    sc=$(grep -c 'SAME_STRUCTURE' \"$HEXA_LANG/.raw-audit\" 2>/dev/null)\n" +
        "    if [ \"$sc\" -gt 0 ] 2>/dev/null; then\n" +
        "      sm=$(stat -f %m \"$HEXA_LANG/.raw-audit\" 2>/dev/null)\n" +
        "      [ -n \"$sm\" ] && printf 'same_structure\\t%s\\t%s\\t2\\t259200\\n' \"$sc\" \"$sm\"\n" +
        "    fi\n" +
        "  fi\n" +
        "  if [ -f \"$HOME/.claude/settings.json\" ]; then\n" +
        "    fl=$(stat -f %f \"$HOME/.claude/settings.json\" 2>/dev/null)\n" +
        "    if [ -n \"$fl\" ] && [ $((fl & 2)) -eq 0 ]; then\n" +
        "      printf 'uchg_drift\\tsettings\\t%s\\t12\\t3600\\n' \"$NOW\"\n" +
        "    fi\n" +
        "  fi\n" +
        "  if [ -f \"$CWD/state/rig_trend_history.jsonl\" ]; then\n" +
        "    len=$(tail -1 \"$CWD/state/rig_trend_history.jsonl\" 2>/dev/null | jq -r '.critical_path_len // empty' 2>/dev/null)\n" +
        "    m=$(stat -f %m \"$CWD/state/rig_trend_history.jsonl\" 2>/dev/null)\n" +
        "    [ -n \"$len\" ] && [ -n \"$m\" ] && printf 'cp\\t%s\\t%s\\t1\\t3600\\n' \"$len\" \"$m\"\n" +
        "  fi\n" +
        "  if [ -f \"$CWD/infra_state.json\" ]; then\n" +
        "    off=$(jq -r '.hosts // {} | to_entries[]? | select(.value.status != \"active\") | .key' \"$CWD/infra_state.json\" 2>/dev/null | head -1)\n" +
        "    if [ -n \"$off\" ]; then\n" +
        "      m=$(stat -f %m \"$CWD/infra_state.json\" 2>/dev/null)\n" +
        "      [ -n \"$m\" ] && printf 'host_offline\\t%s\\t%s\\t20\\t3600\\n' \"$off\" \"$m\"\n" +
        "    fi\n" +
        "  fi\n" +
        "} | awk -v now=\"$NOW\" -v dot=\"$DOT\" -v tier=\"$TIER\" -v last_type=\"$LAST_TYPE\" -v state_file=\"$STATE_FILE\" -v phase=\"$PHASE\" '\n" +
        "BEGIN {\n" +
        "  best = -1\n" +
        "  pref[\"cert\"]=\"P1\"; pref[\"same_structure\"]=\"P1\"\n" +  // §19 phase_relevance
        "  pref[\"transfer\"]=\"P2\"; pref[\"cp\"]=\"P2\"\n" +
        "}\n" +
        "{ type=$1; label=$2; ts=$3; w=$4; h=$5\n" +
        "  dt = now - ts; if (dt < 0) dt = 0\n" +
        "  rel = (phase != \"\" && pref[type] == phase) ? 1.5 : 1.0\n" +
        "  score = w * exp(-dt/h) * rel\n" +
        "  if (type == last_type) score = score * 1.1\n" +  // hysteresis
        "  if (score > best) { best = score; bt = type; bl = label; bts = ts } }\n" +
        "END {\n" +
        "  if (best < 0) exit\n" +
        "  if (state_file != \"\") { print bt > state_file; close(state_file) }\n" +
        "  s = now - bts\n" +
        "  if (s < 60) age = s \"s\"\n" +
        "  else if (s < 3600) age = int(s/60) \"m\"\n" +
        "  else if (s < 86400) age = int(s/3600) \"h\"\n" +
        "  else age = int(s/86400) \"d\"\n" +
        "  if (tier == \"narrow\") {\n" +
        "    if (bt == \"raw\")              printf \"🌱 #%s\", bl\n" +
        "    else if (bt == \"cert\")       printf \"🔬 ×%s\", bl\n" +
        "    else if (bt == \"transfer\")   printf \"🔁 ×%s\", bl\n" +
        "    else if (bt == \"same_structure\") printf \"🧩 %s\", bl\n" +
        "    else if (bt == \"cp\")         printf \"🛰 %s\", bl\n" +
        "    else if (bt == \"host_offline\")   printf \"\\033[31m⚠ %s\\033[0m\", bl\n" +
        "    else if (bt == \"uchg_drift\") printf \"\\033[31m⚠ uchg\\033[0m\"\n" +
        "  } else {\n" +
        "    if (bt == \"raw\")              printf \"🌱 raw#%s %s%s\", bl, dot, age\n" +
        "    else if (bt == \"cert\")       printf \"🔬 cert×%s %s%s\", bl, dot, age\n" +
        "    else if (bt == \"transfer\")   printf \"🔁 transfer×%s %s%s\", bl, dot, age\n" +
        "    else if (bt == \"same_structure\") printf \"🧩 same×%s %s%s\", bl, dot, age\n" +
        "    else if (bt == \"cp\")         printf \"🛰 CP=%s %s%s\", bl, dot, age\n" +
        "    else if (bt == \"host_offline\")   printf \"\\033[31m⚠ %s offline %s%s\\033[0m\", bl, dot, age\n" +
        "    else if (bt == \"uchg_drift\") printf \"\\033[31m⚠ uchg drift %s%s\\033[0m\", dot, age\n" +
        "  }\n" +
        "}'\n"

    let tmp = "/tmp/sl_emerge.sh"
    try { write_file(tmp, script) } catch e { return DASH }

    let cwd_sh = cwd.replace("'", "'\\''")
    let hl_sh = HEXA_LANG.replace("'", "'\\''")
    let sid_sh = session_id.replace("'", "'\\''")
    let cmd = "CWD='" + cwd_sh + "' HEXA_LANG='" + hl_sh + "' DOT='" + DOT + "' TIER='" + tier + "' SESSION_ID='" + sid_sh + "' sh '" + tmp + "'"
    let out = to_string(exec(cmd)).trim()  // @allow-bare-exec
    if out.len() == 0 { return DASH }
    return out
}

// Model pricing — $/Mtoken for input, output, cache_read, cache_write.
fn model_rates(name: str) -> str {
    if name.contains("Opus") || name.contains("opus")   { return "15 75 1.50 18.75" }
    if name.contains("Haiku") || name.contains("haiku") { return "0.25 1.25 0.025 0.30" }
    return "3 15 0.30 3.75"
}

fn ctx_window(name: str) -> str {
    if name.contains("1m") || name.contains("1M") { return "1000000" }
    return "200000"
}

// Collapse "Opus 4.7" → "opus" etc. for compact/narrow tiers.
fn model_short(name: str) -> str {
    if name.contains("Opus") || name.contains("opus")     { return "opus" }
    if name.contains("Sonnet") || name.contains("sonnet") { return "sonnet" }
    if name.contains("Haiku") || name.contains("haiku")   { return "haiku" }
    return name
}

// Terminal column count — env COLUMNS if present, else 100 (safe compact default).
fn get_cols() -> str {
    let c = env("COLUMNS")
    if c.len() > 0 { return c }
    return "100"
}

// Map a column count to tier (full ≥120, compact 90-119, narrow <90).
fn tier_from_cols(cs: str) -> str {
    return to_string(exec("awk -v c=" + cs + " 'BEGIN{c+=0; if(c>=120)print \"full\"; else if(c>=90)print \"compact\"; else print \"narrow\"}'")).trim()  // @allow-bare-exec
}

fn main() {
    // Capture start epoch-ms (gdate from coreutils). On systems without
    // gdate render_ms stays "?" — non-fatal.
    let start_ms = to_string(exec("gdate +%s%3N 2>/dev/null")).trim()  // @allow-bare-exec

    let input = read_stdin()
    if input.len() == 0 {
        println("📁 statusline · no-stdin")
        return
    }
    let input_sh = input.replace("'", "'\\''")

    // [1/4] stdin parse — one jq call, TSV out, hexa splits.
    let parsed = to_string(exec("printf '%s' '" + input_sh + "' | jq -r '[.cwd // \"\", .transcript_path // \"\", .model.display_name // \"\", .session_id // \"\"] | @tsv' 2>/dev/null")).trim()  // @allow-bare-exec
    let fields = parsed.split("\t")
    let cwd = if fields.len() > 0 { fields[0] } else { "" }
    let transcript_path = if fields.len() > 1 { fields[1] } else { "" }
    let model_name = if fields.len() > 2 { fields[2] } else { "" }
    let session_id = if fields.len() > 3 { fields[3] } else { "" }

    // Tier detection (full ≥120, compact 90-119, narrow <90).
    let cols_str = get_cols()
    let tier = tier_from_cols(cols_str)

    // [2/4] CONTEXT
    let ctx = panel_context(cwd, tier)

    // [3/4] EMERGENCE
    let emrg = panel_emergence(cwd, tier, session_id)

    // [4/4] Transcript bundle — one jq -s produces TSV: turn, used, ci, co, ccr, ccw, last_user_epoch, now.
    // SESSION (ctx% · model · turn) and ECONOMY (idle + cost) both read from this.
    let mut sess = "🧠 ?" + FSEP + (if model_name.len() > 0 { model_name } else { "?" }) + FSEP + "t?"
    let mut econ = DASH
    let mut ctx_pct_str = "?"
    let mut turn_str = "?"
    let mut cost_str = "?"
    if transcript_path.len() > 0 && file_exists(transcript_path) {
        let tp_sh = transcript_path.replace("'", "'\\''")
        let rates = model_rates(model_name)
        let window = ctx_window(model_name)
        let jq_prog = "[.[] | select(.type==\"assistant\") | .message.usage // {}] as $A " +
            "| ($A | length) as $turn " +
            "| ($A | last // {}) as $lu " +
            "| (($lu.input_tokens // 0) + ($lu.cache_read_input_tokens // 0) + ($lu.cache_creation_input_tokens // 0)) as $used " +
            "| ($A | map(.input_tokens // 0) | add // 0) as $ci " +
            "| ($A | map(.output_tokens // 0) | add // 0) as $co " +
            "| ($A | map(.cache_read_input_tokens // 0) | add // 0) as $ccr " +
            "| ($A | map(.cache_creation_input_tokens // 0) | add // 0) as $ccw " +
            "| ([.[] | select(.type==\"user\") | (.timestamp // \"\" | sub(\"\\\\.[0-9]+Z$\"; \"Z\") | fromdateiso8601? // empty)] | last // 0) as $lu_epoch " +
            "| [$turn, $used, $ci, $co, $ccr, $ccw, $lu_epoch] | @tsv"
        let cmd = "jq -rs '" + jq_prog + "' '" + tp_sh + "' 2>/dev/null | " +
            "awk -v w=" + window + " -v r='" + rates + "' -v now=$(date +%s) '" +
            "BEGIN { split(r, R, \" \") }" +
            "{" +
            "  turn=$1; used=$2; ci=$3; co=$4; ccr=$5; ccw=$6; lu=$7;" +
            "  pct = (used>0 && w>0) ? int(used*100/w) : \"\";" +
            "  cost = (ci*R[1] + co*R[2] + ccr*R[3] + ccw*R[4]) / 1000000;" +
            "  if (lu>0) { s = now - lu; if (s<60) age = s\"s\"; else if (s<3600) age = int(s/60)\"m\"; else if (s<86400) age = int(s/3600)\"h\"; else age = int(s/86400)\"d\" } else { age = \"?\" };" +
            "  printf \"%s\\t%d\\t%s\\t%.2f\", (pct==\"\" ? \"?\" : pct\"%\"), turn, age, cost" +
            "}'"
        let bundle = to_string(exec(cmd)).trim()  // @allow-bare-exec
        if bundle.len() > 0 {
            let b = bundle.split("\t")
            if b.len() >= 4 {
                ctx_pct_str = b[0]
                turn_str = b[1]
                cost_str = b[3]
                let mfull = if model_name.len() > 0 { model_name } else { "?" }
                let mshort = model_short(mfull)
                if tier == "full" {
                    sess = "🧠 " + b[0] + FSEP + mfull + FSEP + "t" + b[1]
                    econ = "⏱ " + b[2] + FSEP + "💸 $" + b[3]
                } else if tier == "compact" {
                    sess = "🧠 " + b[0] + FSEP + mshort + FSEP + "t" + b[1]
                    econ = "⏱ " + b[2] + " 💸 $" + b[3]
                } else {
                    // narrow: keep only ctx% in SESSION, drop idle in ECONOMY.
                    sess = "🧠 " + b[0]
                    econ = "💸 $" + b[3]
                }
            }
        }
    }

    // Join non-empty panels with SEP.
    let mut parts: [str] = []
    if ctx.len() > 0 { parts.push(ctx) }
    if sess.len() > 0 { parts.push(sess) }
    parts.push(emrg)
    parts.push(econ)

    let mut line = ""
    let mut i = 0
    while i < parts.len() {
        if i > 0 { line = line + SEP }
        line = line + parts[i]
        i = i + 1
    }
    println(line)

    // Observability (spec §28) — one jsonl line per render. jq builds the
    // JSON with proper escaping; >> append is atomic for ≤ PIPE_BUF payloads.
    if HEXA_LANG.len() > 0 {
        let log_file = HEXA_LANG + "/.hook-statusline.jsonl"
        let sid_sh = session_id.replace("'", "'\\''")
        let emrg_sh = emrg.replace("'", "'\\''")
        // render_ms = now_ms - start_ms. "?" when gdate unavailable.
        let render_ms_expr = if start_ms.len() > 0 {
            "$(gdate +%s%3N 2>/dev/null | awk -v s=" + start_ms + " '{print $1-s}')"
        } else { "?" }
        let log_cmd = "jq -cn " +
            "--arg ts \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\" " +
            "--arg session '" + sid_sh + "' " +
            "--arg tier '" + tier + "' " +
            "--arg cols '" + cols_str + "' " +
            "--arg ctx_pct '" + ctx_pct_str + "' " +
            "--arg turn '" + turn_str + "' " +
            "--arg cost '" + cost_str + "' " +
            "--arg emerg '" + emrg_sh + "' " +
            "--arg render_ms \"" + render_ms_expr + "\" " +
            "'{ts:$ts, session:$session, tier:$tier, cols:$cols, ctx_pct:$ctx_pct, turn:$turn, cost:$cost, render_ms:$render_ms, emerg:$emerg}' " +
            ">> '" + log_file + "' 2>/dev/null"
        exec(log_cmd)  // @allow-bare-exec
    }
}

main()
