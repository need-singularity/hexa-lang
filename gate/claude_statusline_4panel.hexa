// gate/claude_statusline_4panel.hexa — 4-panel Claude Code statusLine.
// Panels: CONTEXT (맥락) · SESSION (세션) · EMERGENCE (창발) · ECONOMY (경제)
// Spec: airgenome/docs/statusline_4panel.md
// Step 1 prototype — CONTEXT + SESSION live, EMERGENCE/ECONOMY stubbed with `—`.
// Stdin: CC pipes JSON with {session_id, transcript_path, cwd, model.display_name, …}.
// Stdout: single line. Runs every turn, must stay under 300ms.
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox

let SEP = " ·· "     // panel separator
let DASH = "—"       // stubbed panel placeholder

fn jq_field(input_sh: str, expr: str) -> str {
    let cmd = "printf '%s' '" + input_sh + "' | jq -r '" + expr + " // empty' 2>/dev/null"
    return to_string(exec(cmd)).trim()  // @allow-bare-exec
}

// CONTEXT — git branch + dirty count. Cwd-scoped; silent outside a repo.
fn panel_context(cwd: str) -> str {
    if cwd.len() == 0 { return "" }
    let cwd_sh = cwd.replace("'", "'\\''")
    // Single git call: branch + ahead/behind + porcelain. parse in awk.
    let cmd = "cd '" + cwd_sh + "' 2>/dev/null && git status --porcelain=v2 --branch --ahead-behind 2>/dev/null"
    let raw = to_string(exec(cmd))  // @allow-bare-exec
    if raw.len() == 0 { return "" }

    let branch = to_string(exec("printf '%s' '" + raw.replace("'", "'\\''") + "' | awk '/^# branch.head/ {print $3; exit}'")).trim()  // @allow-bare-exec
    if branch.len() == 0 { return "" }
    if branch == "(detached)" { return "⎇ (detached)" }

    let dirty = to_string(exec("printf '%s' '" + raw.replace("'", "'\\''") + "' | awk '/^[12u?]/ {n++} END {print n+0}'")).trim()  // @allow-bare-exec
    let ab = to_string(exec("printf '%s' '" + raw.replace("'", "'\\''") + "' | awk '/^# branch.ab/ {print $3, $4; exit}'")).trim()  // @allow-bare-exec

    let mut out = "⎇ " + branch
    if dirty != "0" && dirty.len() > 0 { out = out + " ±" + dirty }
    if ab.len() > 0 {
        // ab = "+N -M" — ahead N, behind M
        let ahead = to_string(exec("echo '" + ab + "' | awk '{print $1}' | tr -d +")).trim()  // @allow-bare-exec
        let behind = to_string(exec("echo '" + ab + "' | awk '{print $2}' | tr -d -")).trim()  // @allow-bare-exec
        if ahead != "0" && ahead.len() > 0 { out = out + " ↑" + ahead }
        if behind != "0" && behind.len() > 0 { out = out + " ↓" + behind }
    }
    return out
}

// SESSION — ctx% · model · turn. ctx% is approximate (last assistant usage / window).
fn panel_session(input_sh: str, model_name: str, transcript_path: str) -> str {
    let model_short = if model_name.len() > 0 { model_name } else { "?" }

    let mut turn = "?"
    let mut ctx_pct = "?"
    if transcript_path.len() > 0 && file_exists(transcript_path) {
        let tp_sh = transcript_path.replace("'", "'\\''")
        // turn = assistant message count
        let t = to_string(exec("grep -c '\"role\":\"assistant\"' '" + tp_sh + "' 2>/dev/null")).trim()  // @allow-bare-exec
        if t.len() > 0 { turn = t }
        // ctx% from last assistant usage: input + cache_read + cache_creation
        // Context window: opus/sonnet/haiku default 200K (1m variant 1M).
        let window = if model_name.contains("1m") || model_name.contains("1M") { "1000000" } else { "200000" }
        let used = to_string(exec("tail -c 16384 '" + tp_sh + "' | grep -o '\"usage\":{[^}]*}' | tail -1 | jq -r '(.input_tokens // 0) + (.cache_read_input_tokens // 0) + (.cache_creation_input_tokens // 0)' 2>/dev/null")).trim()  // @allow-bare-exec
        if used.len() > 0 && used != "0" {
            let pct = to_string(exec("echo 'scale=0; " + used + " * 100 / " + window + "' | bc 2>/dev/null")).trim()  // @allow-bare-exec
            if pct.len() > 0 { ctx_pct = pct }
        }
    }

    return "🧠 " + ctx_pct + "% · " + model_short + " · t" + turn
}

fn main() {
    let input = read_stdin()
    if input.len() == 0 {
        println("📁 statusline · no-stdin")
        return
    }
    let input_sh = input.replace("'", "'\\''")

    let cwd = jq_field(input_sh, ".cwd")
    let transcript_path = jq_field(input_sh, ".transcript_path")
    let model_name = jq_field(input_sh, ".model.display_name")

    let ctx = panel_context(cwd)
    let sess = panel_session(input_sh, model_name, transcript_path)
    let emrg = DASH       // step 2: .raw tail + .meta2-cert + rig_trend
    let econ = DASH       // step 2: idle + cost_cum

    // Join non-empty panels with SEP.
    let mut parts: [str] = []
    if ctx.len() > 0 { parts.push(ctx) }
    if sess.len() > 0 { parts.push(sess) }
    parts.push(emrg)
    parts.push(econ)

    let mut line = ""
    let mut i = 0
    while i < parts.len() {
        if i > 0 { line = line + SEP }
        line = line + parts[i]
        i = i + 1
    }
    println(line)
}

main()
