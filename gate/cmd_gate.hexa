// cmd_gate.hexa — smash/todo/go/keep/free/loop/roi/lm/list/roadmap 진입 검증 gate
// @allow-bare-exec
// @no-sandbox
// 역할: commands.json execution.bash 앞에 래핑되어 seed 품질 검증 수행.
//       통과 시 stdout "OK:<cmd>:<validated_seed>", 거부 시 stderr "REJECT: <reason>" + exit 2.
// 호출: hexa run shared/tool/cmd_gate.hexa <cmd> "<seed>" [--context "<hint>"]
// SSOT: shared/config/commands.json (키워드/엔진 경로)
//
// option-gate 통합 (2026-04-14, no-hooks 정책)
//   "go" / "keep" 진입 시 직전 assistant 메시지에서 옵션 블록을 추출,
//   option_gate.hexa 워커로 위임해 점수 1위 옵션을 OK 출력 뒤에 덧붙인다.
//   훅 없이 cmd_gate 단일 디스패처로 강제됨.

let HOME_PATH = env("HOME")
// nexus_home 해소 — env-driven (raw 44 docker hard-landing 동반)
fn _resolve_nexus_home() -> str {
    let nh = env("NEXUS_HOME")
    if nh.len() > 0 { return nh }
    let ws = env("WS")
    if ws.len() > 0 { return ws + "/nexus" }
    if HOME_PATH.len() > 0 { return HOME_PATH + "/core/nexus" }
    return "/nexus"
}
let NEXUS_HOME = _resolve_nexus_home()
let OPTION_GATE = NEXUS_HOME + "/tool/option_gate.hexa"
let HEXA_BIN = NEXUS_HOME + "/scripts/bin/hexa"

// option_gate 워커 호출 — 출력 있으면 SELECTED 블록 반환, 없으면 빈 문자열
fn run_option_gate(prompt: str) -> str {
    if file_exists(OPTION_GATE) == false { return "" }
    if file_exists(HEXA_BIN) == false { return "" }
    let escaped_prompt = prompt.replace("'", "'\\''")
    let cmd = HEXA_BIN + " " + OPTION_GATE + " '" + escaped_prompt + "' 2>/dev/null"
    let out = to_string(exec(cmd)).trim()  // @allow-bare-exec
    return out
}

// ─── H-DECISION-ROUTER 헬퍼 ────────────────────────────────────────
// shared/config/decisions.json 강제 — anima go/keep/loop 진입 시 fail-closed.
fn anima_cwd() -> bool {
    let cwd = exec("pwd -P 2>/dev/null").trim().to_lower()  // @allow-bare-exec
    return cwd.contains("/dev/anima")
}

fn decision_router_validate() -> bool {
    let dr = NEXUS_HOME + "/tool/decision_router.hexa"
    let hx = NEXUS_HOME + "/bin/hexa"
    if file_exists(dr) == false || file_exists(hx) == false { return true }  // graceful: nexus 부재 시 fail-open
    let cmd = "HEXA_LOCAL=1 " + hx + " run " + dr + " validate 2>&1"
    let out = exec(cmd).trim()  // @allow-bare-exec
    return out.contains("VALID")
}

fn emit_decisions_block() {
    let dr = NEXUS_HOME + "/tool/decision_router.hexa"
    let hx = NEXUS_HOME + "/bin/hexa"
    if file_exists(dr) == false || file_exists(hx) == false { return }
    let cmd = "HEXA_LOCAL=1 " + hx + " run " + dr + " emit 2>&1"
    let out = exec(cmd).trim()  // @allow-bare-exec
    println("===DECISIONS_BEGIN===")
    println(out)
    println("===DECISIONS_END===")
}

fn main() {
    // args(): Mac=[binary, script, user...]  Linux-dispatch=[binary, "run", script, user...]
    // argv 를 .hexa 앵커 기준으로 재구성 → 항상 [binary, script, user...] (prefix=2).
    // 참조: shared/blowup/lib/argv.hexa.inc (공용 헬퍼, pure functions).
    let _raw_argv = args()
    let mut _script_idx: i64 = -1
    let mut _scan_i: i64 = 0
    while _scan_i < _raw_argv.len() {
        if to_string(_raw_argv[_scan_i]).ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let _user_start = if _script_idx >= 0 { _script_idx + 1 } else {
        if _raw_argv.len() >= 3 && (to_string(_raw_argv[1]) == "run" || to_string(_raw_argv[1]) == "eval") { 3 } else { 2 }
    }
    let _script_token = if _script_idx >= 0 { _raw_argv[_script_idx] } else { "" }
    let mut argv = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if argv.len() < 3 {
        eprintln("REJECT: usage — cmd_gate <cmd> \"<seed>\" [--context \"...\"]")
        exit(2)
    }

    let cmd = argv[2].trim().to_lower()
    let mut seed = ""
    if argv.len() >= 4 { seed = argv[3].trim() }

    let mut context_hint = ""
    let mut i = 4
    while i < argv.len() {
        if argv[i] == "--context" && i + 1 < argv.len() {
            context_hint = argv[i + 1]
            i = i + 2
        } else {
            i = i + 1
        }
    }

    // ─── 명령별 규칙 ───
    if cmd == "smash" || cmd == "돌파" || cmd == "blowup" {
        check_smash(seed, context_hint)
    } else if cmd == "free" || cmd == "free_dfs" || cmd == "dfs" {
        check_free(seed, context_hint)
    } else if cmd == "absolute" || cmd == "abs" || cmd == "delta0" {
        // Mk.VIII Δ₀-absolute 검증 — seed 선택 (없으면 atlas 전체 스캔)
        println("OK:absolute:" + seed)
    } else if cmd == "meta_closure" || cmd == "meta-closure" || cmd == "m10" {
        // Phase 10 Meta-Closure — seed 선택
        println("OK:meta_closure:" + seed)
    } else if cmd == "hyperarithmetic" || cmd == "pi02" || cmd == "hyper" {
        // Mk.IX Π₀² — prop 필수
        if seed.len() == 0 && context_hint.len() == 0 {
            eprintln("REJECT: hyperarithmetic prop 비어있음 — --prop 필요")
            exit(2)  // @allow-silent-exit
        }
        let p = if seed.len() > 0 { seed } else { context_hint }
        println("OK:hyperarithmetic:" + p)
    } else if cmd == "promote" || cmd == "승급" {
        // 등급 수동 승급 — id 필수, 감사 로그 필수
        if seed.len() == 0 {
            eprintln("REJECT: promote id 비어있음 — --id 필요")
            exit(2)  // @allow-silent-exit
        }
        println("OK:promote:" + seed)
    } else if cmd == "drill" || cmd == "고갈" {
        // 자율 고갈탐색 (smash → free → absolute 사슬 반복) — seed 필수 (smash 위임)
        if seed.len() == 0 && context_hint.len() == 0 {
            eprintln("REJECT: drill seed 비어있음 — '<seed> drill' 또는 --context 필요")
            exit(2)
        }
        let s = if seed.len() > 0 { seed } else { context_hint }
        // [Taint guard] system-output self-reference 차단 (2026-04-22 Mac 크래시 원인)
        //   drill 완료 task-notification 이 hook seed 로 재주입되면 무한 재귀 → 메모리 폭발.
        if s.contains("<task-notification>") || s.contains("<tool-use-id>") || s.contains("<system-reminder>") || s.contains("</system-reminder>") {
            eprintln("REJECT: drill seed tainted — system-output 자기참조 감지 (<task-notification>/<tool-use-id>/<system-reminder>). 사용자 의도 seed 로 재작성 필요.")
            exit(2)
        }
        // [Failure-signature guard] (2026-04-24 Mac heavy-compute abort 루프 원인)
        //   drill rc=74 (remote unavailable → abort) 실패 로그가 seed 로 재주입되면
        //   동일 abort 를 반복 → 사용자 프롬프트 루프. 실패 서명은 seed 가 아니라
        //   상태(remote hosts down)의 결과이므로 seed 재실행은 의미 없음.
        if s.contains("Exit code 74") || s.contains("NEXUS_REMOTE_ERROR") || s.contains("NEXUS_REMOTE_DOWNGRADE") || s.contains("all_timeout") || s.contains("remote_unavailable") || s.contains("abort_to_prevent_oom") {
            eprintln("REJECT: drill seed contains prior-failure signature (rc=74 / remote_unavailable / all_timeout). 원격 호스트 부팅 후 새 seed 로 재실행. Mac local fallback 금지 (AG10).")
            exit(2)
        }
        // [Cool-down guard] 직전 drill 이 remote-abort 로 끝났고 <600s 경과하지 않았으면 REJECT.
        //   /tmp/nexus_drill_last_rc: "rc ts_epoch" 한 줄. nexus drill 래퍼가 종료 시 기록.
        //   600s (10min) 이내 동일 실패 반복 차단. 우회: rm /tmp/nexus_drill_last_rc.
        let last_rc_file = "/tmp/nexus_drill_last_rc"
        let last_raw = to_string(exec("cat " + last_rc_file + " 2>/dev/null")).trim()  // @allow-bare-exec
        if last_raw.len() > 0 {
            let parts = last_raw.split(" ")
            if parts.len() >= 2 {
                let last_rc_s = to_string(parts[0]).trim()
                let last_ts_s = to_string(parts[1]).trim()
                let mut last_rc: i64 = 0
                let mut last_ts: i64 = 0
                try { last_rc = to_int(last_rc_s) } catch e { last_rc = 0 }
                try { last_ts = to_int(last_ts_s) } catch e { last_ts = 0 }
                let now_ts_s = to_string(exec("date +%s")).trim()  // @allow-bare-exec
                let mut now_ts: i64 = 0
                try { now_ts = to_int(now_ts_s) } catch e { now_ts = 0 }
                let age = now_ts - last_ts
                if (last_rc == 64 || last_rc == 74) && age < 600 && age >= 0 {
                    eprintln("REJECT: drill cool-down — 직전 rc=" + to_string(last_rc) + " (remote abort), " + to_string(age) + "s 경과 (600s 미만). 원격 복구 후 또는 /tmp/nexus_drill_last_rc 삭제 후 재시도.")
                    exit(2)
                }
            }
        }
        // [Max-depth guard] drill → drill 재진입 차단 (@max-depth(1) 실용 버전)
        //   /tmp/nexus_drill_depth 카운터 파일. cmd_gate 진입 시 +1. depth >= 1 면 REJECT.
        //   드릴 엔진 종료 시 카운터 감소는 nexus drill 래퍼 책임 (여기선 진입 봉쇄만).
        let depth_file = "/tmp/nexus_drill_depth"
        let depth_raw = to_string(exec("cat " + depth_file + " 2>/dev/null || echo 0")).trim()  // @allow-bare-exec
        let mut depth: i64 = 0
        try { depth = to_int(depth_raw) } catch e { depth = 0 }
        if depth >= 1 {
            eprintln("REJECT: drill max-depth(1) 초과 — 현재 depth=" + to_string(depth) + ". 진행중 drill 종료 후 재시도. 강제 초기화: rm " + depth_file)
            exit(2)
        }
        exec("echo " + to_string(depth + 1) + " > " + depth_file)  // @allow-bare-exec
        println("OK:drill:" + s)
    } else if cmd == "todo" || cmd == "go" || cmd == "keep" || cmd == "loop" || cmd == "list" || cmd == "roi" || cmd == "lm" || cmd == "roadmap" || cmd == "로드맵" {
        // H-DECISION-ROUTER (anima) — go/keep/loop 진입 시 decision_router validate + emit 강제
        if cmd == "go" || cmd == "keep" || cmd == "loop" {
            if anima_cwd() && env("NEXUS_DECISION_OK") != "1" {
                if !decision_router_validate() {
                    eprintln("REJECT: anima " + cmd + " — decision_router validate FAIL. shared/config/decisions.json 검증 후 재실행. 우회: NEXUS_DECISION_OK=1")
                    exit(2)
                }
                // 통과 시 DECISIONS 블록을 stdout 으로 emit (Claude 가 ===DECISIONS_BEGIN/END=== 발견 시 다음 dispatch 에 inject)
                emit_decisions_block()
            }
        }

        // [Origin sanitizer] system-reminder/task-notification 블록 strip.
        //   drill 처럼 REJECT 하진 않음 (정상 user prompt 도 hook 에서 reminder 태그가 섞여옴).
        //   엔진이 받을 seed 에서 태그 블록만 제거하여 자기참조 pollution 제거.
        let mut sanitized = seed
        let mut _iter_sr = 0
        while sanitized.contains("<system-reminder>") && sanitized.contains("</system-reminder>") && _iter_sr < 32 {
            let a = sanitized.index_of("<system-reminder>")
            let b = sanitized.index_of("</system-reminder>")
            if a < 0 || b < 0 || b < a { break }
            let before = sanitized.slice(0, a)
            let after = sanitized.slice(b + 19, sanitized.len())
            sanitized = before + after
            _iter_sr = _iter_sr + 1
        }
        let mut _iter_tn = 0
        while sanitized.contains("<task-notification>") && sanitized.contains("</task-notification>") && _iter_tn < 32 {
            let a = sanitized.index_of("<task-notification>")
            let b = sanitized.index_of("</task-notification>")
            if a < 0 || b < 0 || b < a { break }
            let before = sanitized.slice(0, a)
            let after = sanitized.slice(b + 20, sanitized.len())
            sanitized = before + after
            _iter_tn = _iter_tn + 1
        }
        sanitized = sanitized.trim()
        // seed 검증 불필요 — 엔진 자체가 컨텍스트 활용
        // roadmap: seed = 서브커맨드 (next|extend|auto|list|verify|status|all) + flags, 엔진 내부에서 파싱
        println("OK:" + cmd + ":" + sanitized)

        // option-gate: "go" / "keep" 진입 시 직전 assistant 옵션 자동 선택
        if cmd == "go" || cmd == "keep" {
            let gate_out = run_option_gate(cmd)
            if gate_out.len() > 0 {
                println(gate_out)
            }
        }
    } else if cmd == "pick" || cmd == "선택" {
        // 단일 알파벳/숫자/한국어 서수 픽 — option_gate 가 trigger 해석
        // seed 가 트리거 문자 (예: "a", "2", "첫번째")
        if seed.len() == 0 {
            eprintln("REJECT: pick 트리거 비어있음 — 'pick a' / 'pick 2' / 'pick 첫번째' 형태")
            exit(2)
        }
        let gate_out = run_option_gate(seed)
        if gate_out.len() == 0 {
            eprintln("REJECT: pick '" + seed + "' — 직전 메시지에 옵션 블록 없음 또는 트리거 형식 불일치")
            exit(2)
        }
        println("OK:pick:" + seed)
        println(gate_out)
    } else {
        eprintln("REJECT: unknown cmd '" + cmd + "' — SSOT: shared/config/commands.json")
        exit(2)
    }
}

fn check_smash(seed: str, ctx: str) {
    // 1. 빈 seed — 컨텍스트 힌트 없으면 거부
    if seed.len() == 0 {
        if ctx.len() == 0 {
            eprintln("REJECT: smash seed 비어있음 — 현재 작업 맥락을 --context 로 전달하거나 구체 시드 제공 필요")
            eprintln("HINT: '검토 smash' 'P=NP smash' 같은 형태. 단독 'smash' 는 직전 대화 맥락을 seed로 합성해야 함")
            exit(2)
        }
        // context_hint 있으면 OK — Claude가 맥락 합성한 것
        println("OK:smash:" + ctx)
        return
    }

    // 2. 너무 짧음 (1자)
    if seed.len() < 2 {
        eprintln("REJECT: smash seed 너무 짧음 ('" + seed + "' 1자) — 최소 2자 이상 구체 시드")
        exit(2)
    }

    // 3. 추상 단독 토큰 차단 — 문맥 유실 주요 원인
    let abstract_blacklist = [
        "아이디어", "계획", "생각", "돌파", "개념", "방법", "뭐", "뭘", "어떻게",
        "idea", "plan", "concept", "thought", "thinking", "method",
        "stuff", "something", "thing", "it", "that"
    ]
    let seed_lower = seed.to_lower()
    for bad in abstract_blacklist {
        if seed_lower == bad {
            eprintln("REJECT: smash seed '" + seed + "' 는 추상 단독 토큰 — 구체화 또는 컨텍스트 결합 필요")
            eprintln("HINT: 현재 대화 맥락의 실체(파일명/개념명/문제)와 결합. 예: '아이디어' → 'hexa-lang split 버그 아이디어'")
            exit(2)
        }
    }

    // 4. 토큰 수 체크 — 단일 추상 토큰만 있고 ctx 없으면 경고
    let tokens = seed.split(" ")
    let mut non_blacklist_tokens = 0
    for t in tokens {
        let tl = t.trim().to_lower()
        if tl.len() == 0 { continue }
        let mut is_abstract = false
        for bad in abstract_blacklist {
            if tl == bad { is_abstract = true; break }
        }
        if is_abstract == false { non_blacklist_tokens = non_blacklist_tokens + 1 }
    }
    if non_blacklist_tokens == 0 && ctx.len() == 0 {
        eprintln("REJECT: smash seed '" + seed + "' 는 모두 추상 토큰 — 컨텍스트 결합 필요")
        exit(2)
    }

    // 5. 너무 장황 (300자+)
    //    cmd_drill 은 base seed 200자 제한 + round-salt/iter-nonce/σ suffix 를 injection → 최대 ~60자 추가.
    //    cmd_gate limit 을 300 으로 두면 drill 내부 perturbation 이 resonance REJECT 로 새지 않음.
    if seed.len() > 300 {
        eprintln("REJECT: smash seed 과장 (" + to_string(seed.len()) + "자) — 핵심 키워드 추출 필요, 300자 이내")
        exit(2)
    }

    // 통과
    println("OK:smash:" + seed)
}

fn check_free(seed: str, ctx: str) {
    // free_dfs — 도메인 시드. 없거나 짧으면 warn 후 pass (엔진이 기본 도메인 사용)
    if seed.len() == 0 {
        if ctx.len() > 0 {
            println("OK:free_dfs:" + ctx)
            return
        }
        eprintln("WARN: free_dfs seed 비어있음 — 현재 프로젝트 컨텍스트 사용")
        println("OK:free_dfs:")
        return
    }

    if seed.len() > 300 {
        eprintln("REJECT: free_dfs seed 과장 (" + to_string(seed.len()) + "자) — 도메인/개념 짧게")
        exit(2)
    }

    println("OK:free_dfs:" + seed)
}

main()
