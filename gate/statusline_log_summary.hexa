// gate/statusline_log_summary.hexa — aggregate .hook-statusline.jsonl for
// dogfood analysis (spec §9 / §28 follow-up).
// Usage:   hexa run gate/statusline_log_summary.hexa
// Output:  JSON with total count, render_ms percentiles, tier/emerge distributions.
// Point at a different log via env SL_LOG.

fn main() {
    let log = env("SL_LOG")
    let path = if log.len() > 0 { log } else { env("HEXA_LANG") + "/.hook-statusline.jsonl" }
    if file_exists(path) == false {
        println("{\"error\":\"log file not found\",\"path\":\"" + path + "\"}")
        return
    }

    let jq_prog = "[inputs] as $A | " +
        "($A | length) as $n | " +
        "($A | map(.render_ms | tonumber? // empty) | sort) as $rms | " +
        "($rms | length) as $rn | " +
        "($rms[($rn * 0.50 | floor)] // null) as $p50 | " +
        "($rms[($rn * 0.95 | floor)] // null) as $p95 | " +
        "($rms[($rn * 0.99 | floor)] // null) as $p99 | " +
        "($A | group_by(.tier) | map({tier: .[0].tier, n: length})) as $tiers | " +
        "($A | map(.emerg // \"—\") | group_by(.) | map({label: .[0], n: length}) | sort_by(-.n) | .[0:5]) as $top | " +
        "($A | map(.session) | unique | length) as $sessions | " +
        "{total: $n, sessions: $sessions, render_ms: {p50: $p50, p95: $p95, p99: $p99}, tiers: $tiers, top_emerg: $top}"

    let cmd = "jq -n -s 'null | " + jq_prog + "' < /dev/null 2>/dev/null || " +
        "jq -n --slurpfile A '/dev/stdin' '.' 2>/dev/null < " + path
    // Simpler: just feed the log to jq -n with inputs.
    let real_cmd = "jq -n '" + jq_prog + "' < '" + path.replace("'", "'\\''") + "' 2>/dev/null"
    let out = to_string(exec(real_cmd)).trim()  // @allow-bare-exec
    if out.len() == 0 {
        println("{\"error\":\"jq aggregation failed\",\"path\":\"" + path + "\"}")
        return
    }
    println(out)
}
