// gate/hexa_url.hexa — hexa:// URL resolver (local scope, phase 1).
//
// Schema:
//   hexa://gate/drill?seed=<text>            → drill_bg_spawn.hexa <seed>
//   hexa://gate/entry?mode=<m>&text=<t>      → entry.hexa <mode> <text>
//   hexa://cmd/<name>?seed=<text>            → commands.json must_invoke (or cli_equivalent)
//   hexa://cmd/list[?fmt=text|json]          → enumerate available command names
//   hexa://active                            → read <git-root>/.hook-commands/active.json
//
// usage:
//   hexa run gate/hexa_url.hexa "hexa://gate/drill?seed=밀레니엄 문제 돌파 분석 30자"
//   hexa run gate/hexa_url.hexa "hexa://cmd/smash?seed=..."
//
// Platform: Mac/Linux neutral — shell calls only. Remote scope reserved for
// phase 2 (hexa://remote/<host>/...).

let HOME = env("HOME")
let WS = env("WS")
let GATE = WS + "/hexa-lang/gate"
let CMDS_JSON = GATE + "/commands.json"

// ─── ai-native error helper — structured diagnostic to stderr ────────
// Every failure path emits 3 lines: what happened, how to fix, SSOT pointer.
// This keeps Claude's response deterministic when gate refuses a request.
fn ai_err(code: str, what: str, fix: str, ssot: str) -> void {
    eprintln("[hexa-url/" + code + "] " + what)
    eprintln("  fix: " + fix)
    eprintln("  ssot: " + ssot)
}

// ─── URL decoding — pure hexa, no subprocess ─────────────────────────
// RFC 3986 percent-decode + '+' → ' ' (form-style). Byte-level; UTF-8
// sequences pass through unchanged because %XX just yields raw bytes.
fn _hex_to_int(c: str) -> i64 {
    let o = ord(c)
    if o >= 48 && o <= 57  { return o - 48 }
    if o >= 65 && o <= 70  { return o - 65 + 10 }
    if o >= 97 && o <= 102 { return o - 97 + 10 }
    return -1
}

fn url_decode(s: str) -> str {
    if s.contains("%") == false && s.contains("+") == false { return s }
    let mut out = ""
    let n = s.len()
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == "+" {
            out = out + " "
            i = i + 1
        } else if ch == "%" && i + 2 < n {
            let h1 = _hex_to_int(s.substring(i + 1, i + 2))
            let h2 = _hex_to_int(s.substring(i + 2, i + 3))
            if h1 >= 0 && h2 >= 0 {
                out = out + chr(h1 * 16 + h2)
                i = i + 3
            } else {
                // malformed %-escape — emit literal, continue.
                out = out + ch
                i = i + 1
            }
        } else {
            out = out + ch
            i = i + 1
        }
    }
    return out
}

// ─── URL parser — returns [scope, resource, query_raw] ───────────────
fn parse_url(u: str) -> [str] {
    let prefix = "hexa://"
    if u.starts_with(prefix) == false { return ["", "", ""] }
    let rest = u.substring(prefix.len(), u.len())
    let mut path = rest
    let mut query = ""
    let q_idx = rest.index_of("?")
    if q_idx >= 0 {
        path = rest.substring(0, q_idx)
        query = rest.substring(q_idx + 1, rest.len())
    }
    let slash = path.index_of("/")
    if slash < 0 { return [path, "", query] }
    let us_scope = path.substring(0, slash)
    let us_res = path.substring(slash + 1, path.len())
    return [us_scope, us_res, query]
}

// ─── freshness axis (closure.011) — orthogonal 5th axis ──────────────
// Values: gate (default — probe + inline sync if stale)
//         skip (no probe — opt-out for read-only fleet probes)
//         strict (probe + hard-block + non-zero exit if stale)
//         force (always sync regardless of probe)
// Applies to all target=ubu1|ubu2|fleet invocations across all scopes
// (not only sync/*). Precedence per closure.011:
//   target → freshness → timeout → async → fmt
//
// validate_freshness returns "" if value is in whitelist (or empty, which
// means default), else returns the offending value for the caller to
// surface through ai_err.
fn validate_freshness(v: str) -> str {
    if v.len() == 0 { return "" }
    if v == "gate" || v == "skip" || v == "strict" || v == "force" { return "" }
    return v
}

fn freshness_default(v: str) -> str {
    if v.len() == 0 { return "gate" }
    return v
}

// Map a target string to the canonical fleet host(s) the freshness axis
// must probe. Single host → [host]; "fleet" → reads `hive-resource list`.
// resource.015 — host list comes from `hive-resource list` only.
fn freshness_target_hosts(target: str) -> [str] {
    if target == "ubu1" || target == "ubu2" { return [target] }
    if target == "fleet" {
        // hive-resource list emits "<host>  <reachable>  <load>  <mem>  <nexus>"
        // Skip header lines (start with '#') and __HIVE_RESOURCE__ trailer.
        let raw = to_string(exec("/Users/ghost/.hx/bin/hive-resource list 2>/dev/null"))  // @allow-bare-exec
        let lines = raw.split("\n")
        let mut out = []
        for ln in lines {
            let t = ln.trim()
            if t.len() == 0 { continue }
            if t.starts_with("#") { continue }
            if t.starts_with("__HIVE_RESOURCE__") { continue }
            // First whitespace-delimited token is the host name.
            let mut h = ""
            let mut i = 0
            while i < t.len() {
                let ch = t.substring(i, i + 1)
                if ch == " " || ch == "\t" { break }
                h = h + ch
                i = i + 1
            }
            if h.len() > 0 { out = out + [h] }
        }
        return out
    }
    return []
}

// Run the drift probe for ONE host+repo via gate/remote_preflight.hexa.
// Returns triple [verdict, local_sha, remote_sha] where verdict ∈
// {fresh, stale, offline}. local_sha may be empty on offline path.
fn freshness_probe(host: str, repo: str) -> [str] {
    let hx = WS + "/hexa-lang/hexa"
    let pre = GATE + "/remote_preflight.hexa"
    // NO_REROUTE so the probe sees the real local filesystem (not the docker
    // sandbox where /Users/ghost/core paths don't resolve). raw 200 / raw 82.
    let cmd = "HEXA_RESOLVER_NO_REROUTE=1 HEXA_SHIM_NO_DARWIN_LANDING=1 " +
              hx + " run " + pre +
              " --drift-probe --host " + host.replace("'", "'\\''") +
              " --repo " + repo.replace("'", "'\\''") +
              " 2>/dev/null; echo __DRIFT_RC=$?"
    let out = to_string(exec(cmd))  // @allow-bare-exec
    // Parse "<verdict> local=<sha> remote=<sha>" line + __DRIFT_RC=N.
    let mut verdict = "offline"
    let mut local_sha = ""
    let mut remote_sha = ""
    let lines = out.split("\n")
    for ln in lines {
        let t = ln.trim()
        if t.starts_with("fresh ") || t.starts_with("stale ") || t.starts_with("offline ") {
            // Tokenize on space — first token is verdict.
            let sp1 = t.index_of(" ")
            verdict = t.substring(0, sp1)
            // local=<sha> remote=<sha>
            let l_idx = t.index_of("local=")
            let r_idx = t.index_of("remote=")
            if l_idx >= 0 {
                let l_end = if r_idx > l_idx { r_idx } else { t.len() }
                local_sha = t.substring(l_idx + 6, l_end).trim()
            }
            if r_idx >= 0 {
                remote_sha = t.substring(r_idx + 7, t.len()).trim()
            }
        }
    }
    return [verdict, local_sha, remote_sha]
}

// Apply the freshness gate before remote dispatch. Caller passes the
// resolved freshness value (post-default), the target, and the repo
// the dispatch operates against. Returns true if dispatch should proceed,
// false if the gate has blocked (already emitted sentinel + caller exits).
//
// Behavior per closure.011 + meta-enforcement.132:
//   skip   → no probe; proceed.
//   force  → no probe; trigger sync first; then proceed.
//   gate   → probe; if stale, emit __HEXA_SYNC_STALE__ + inline sync; proceed.
//   strict → probe; if stale, emit __HEXA_SYNC_STALE__ + return false (caller exits non-zero).
//
// The inline sync delegates to the bash sync handler (hexa://sync/pull)
// rather than re-implementing git here — keeps audit trail uniform per
// dispatch.001.
fn freshness_gate_apply(freshness: str, target: str, repo: str) -> bool {
    if freshness == "skip" { return true }
    // Default repo: when caller didn't set ?repo=, derive from $WS.
    // For the resolver routes this is the active repo at $WS (typically hive).
    let mut active_repo = repo
    if active_repo.len() == 0 {
        // Fall back to git rev-parse on the local cwd.
        let root = to_string(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()  // @allow-bare-exec
        if root.len() > 0 {
            // Last path component.
            let last = root.split("/")
            active_repo = last[last.len() - 1]
        }
    }
    if active_repo.len() == 0 { active_repo = "hive" }
    let hosts = freshness_target_hosts(target)
    if hosts.len() == 0 { return true }  // nothing to probe (e.g. mac)
    let mut any_stale = false
    let mut i = 0
    while i < hosts.len() {
        let h = hosts[i]
        if freshness == "force" {
            // Force sync regardless of probe — emit pre-sync sentinel.
            eprintln("__HEXA_SYNC_STALE__ before=force required=force repo=" +
                     active_repo + " target=" + h)
            // Trigger inline sync via bash dispatcher.
            let sync_cmd = HOME + "/.hx/bin/hexa-url-handler.sh 'hexa://sync/pull?repo=" +
                           active_repo + "&target=" + h + "&freshness=force' 2>&1"
            let _ = to_string(exec(sync_cmd))  // @allow-bare-exec
            i = i + 1
            continue
        }
        let res = freshness_probe(h, active_repo)
        let verdict = res[0]
        let local_sha = res[1]
        let remote_sha = res[2]
        if verdict == "fresh" { i = i + 1; continue }
        if verdict == "offline" {
            // Drift probe failed; meta-enforcement.132 forbids silent stale exec.
            eprintln("__HEXA_SYNC_OFFLINE__ repo=" + active_repo + " target=" + h)
            if freshness == "strict" {
                ai_err("DRIFT-OFFLINE-STRICT",
                       "drift probe offline (host=" + h + " repo=" + active_repo + ") and freshness=strict",
                       "retry when ssh to " + h + " is available, or use freshness=gate to proceed with last-known-good",
                       "gate/remote_preflight.hexa:drift_probe")
                return false
            }
            // gate (default) — proceed against possibly stale remote, audit logged.
            i = i + 1
            continue
        }
        // verdict == "stale"
        any_stale = true
        eprintln("__HEXA_SYNC_STALE__ before=" + remote_sha + " required=" + local_sha +
                 " repo=" + active_repo + " target=" + h)
        if freshness == "strict" {
            ai_err("DRIFT-STALE-STRICT",
                   "remote " + h + " stale for repo " + active_repo + " (remote=" + remote_sha +
                   " required=" + local_sha + ") under freshness=strict",
                   "run: hxq 'hexa://sync/pull?repo=" + active_repo + "&target=" + h + "'  # then retry",
                   "closure.011 + meta-enforcement.132")
            return false
        }
        // gate (default) — inline sync via bash dispatcher.
        let sync_cmd = HOME + "/.hx/bin/hexa-url-handler.sh 'hexa://sync/pull?repo=" +
                       active_repo + "&target=" + h + "&freshness=force' 2>&1"
        let _ = to_string(exec(sync_cmd))  // @allow-bare-exec
        i = i + 1
    }
    // Quiet success path — no sentinel needed (no drift detected).
    return true
}

// ─── Query → single param lookup (no multi-value, no escaping beyond urldecode) ──
fn get_param(query: str, key: str) -> str {
    if query.len() == 0 { return "" }
    let parts = query.split("&")
    for p in parts {
        let eq = p.index_of("=")
        if eq < 0 { continue }
        let k = p.substring(0, eq)
        if k == key {
            let v = p.substring(eq + 1, p.len())
            return url_decode(v)
        }
    }
    return ""
}

// Prefer execution.entry (clean CLI template with {seed}) over must_invoke
// (user-facing prose) or cli_equivalent (may include nexus-cli passthrough notes).
fn cmd_must_invoke(name: str) -> str {
    let q = "jq -r '.commands[\"" + name + "\"].execution.entry // .commands[\"" + name + "\"].execution.cli_equivalent // .commands[\"" + name + "\"].must_invoke // \"\"' '" + CMDS_JSON + "' 2>/dev/null"
    return to_string(exec(q)).trim()  // @allow-bare-exec
}

fn dispatch_drill(seed: str) -> void {
    let log = "/tmp/nexus_drill_active.log"
    let seed_sh = seed.replace("'", "'\\''")
    let hx = WS + "/hexa-lang/hexa"
    let bg_hexa = GATE + "/drill_bg_spawn.hexa"
    let log_sh = log.replace("'", "'\\''")
    let bg_cmd = hx + " run " + bg_hexa + " '" + seed_sh + "' '" + log_sh + "'"
    let pid = to_string(exec(bg_cmd)).trim()  // @allow-bare-exec
    println("[hexa-url] drill dispatched pid=" + pid + " log=" + log)
}

// Strip bracketed optional-flag notation from commands.json templates.
// commands.json uses "[--max-rounds 10]" etc. as documentation for optional
// flags; don't pass those literal brackets through to the shell.
fn strip_optional_flags(s: str) -> str {
    let mut out = ""
    let mut depth = 0
    let mut i = 0
    while i < s.len() {
        let ch = s.substring(i, i + 1)
        if ch == "[" { depth = depth + 1 }
        else if ch == "]" { if depth > 0 { depth = depth - 1 } }
        else if depth == 0 { out = out + ch }
        i = i + 1
    }
    // Collapse runs of whitespace left behind by removed brackets.
    return to_string(exec("printf '%s' '" + out.replace("'", "'\\''") + "' | tr -s ' '")).trim()  // @allow-bare-exec
}

// hexa://cmd/list[?fmt=text|json] — enumerate available command names from
// commands.json. Spec says "top-level keys" but in this repo commands live
// under .commands (the existing dispatch_cmd/cmd_must_invoke uses
// .commands["name"]); enumerating .commands keeps the discovery output in
// sync with what hexa://cmd/<name> can actually dispatch.
fn dispatch_cmd_list(query: str) -> void {
    let fmt_raw = get_param(query, "fmt")
    let mut fmt = fmt_raw
    if fmt.len() == 0 { fmt = "text" }
    if fmt != "text" && fmt != "json" {
        ai_err("CMD-LIST-BAD-FMT",
               "unsupported fmt='" + fmt_raw + "' (only text|json)",
               "drop ?fmt= for default text, or use ?fmt=text | ?fmt=json",
               "gate/hexa_url.hexa:dispatch_cmd_list")
        exit(4)
    }
    if !file_exists(CMDS_JSON) {
        ai_err("CMD-LIST-NO-FILE",
               "commands.json not found at '" + CMDS_JSON + "'",
               "ensure $WS/hexa-lang/gate/commands.json exists; check $WS env var",
               CMDS_JSON)
        exit(1)
    }
    let mut raw = ""
    try { raw = read_file(CMDS_JSON) } catch e {}
    let obj = json_parse(raw)
    if type_of(obj) != "map" {
        ai_err("CMD-LIST-PARSE-FAIL",
               "commands.json failed to parse as JSON object",
               "validate with: jq . '" + CMDS_JSON + "'",
               CMDS_JSON)
        exit(1)
    }
    // Spec text says "top-level keys", but the dispatch path resolves
    // .commands["<name>"]; enumerate that subtree so list mirrors the
    // dispatchable namespace. Fall back to top-level if .commands absent.
    let mut src = obj
    if has_key(obj, "commands") && type_of(obj["commands"]) == "map" {
        src = obj["commands"]
    }
    let mut names = keys(src)
    names = sort_array(names)
    if fmt == "text" {
        for n in names { println(n) }
        exit(0)
    }
    // fmt == "json" — build a JSON array of {name[, entry, description]}.
    // Use json_stringify on each scalar value to escape safely; assemble the
    // array with string concatenation (matches the local convention of
    // building shell strings inline rather than pulling in a builder helper).
    let mut out = "["
    let mut first = true
    for n in names {
        if !first { out = out + "," }
        first = false
        out = out + "{\"name\":" + json_stringify(n)
        let v = src[n]
        if type_of(v) == "map" {
            if has_key(v, "entry") {
                out = out + ",\"entry\":" + json_stringify(v["entry"])
            }
            if has_key(v, "description") {
                out = out + ",\"description\":" + json_stringify(v["description"])
            }
        }
        out = out + "}"
    }
    out = out + "]"
    println(out)
    exit(0)
}

fn dispatch_cmd(name: str, seed: str) -> void {
    let tmpl_raw = cmd_must_invoke(name)
    if tmpl_raw.len() == 0 {
        ai_err("CMD-NO-TEMPLATE",
               "command '" + name + "' has no execution.entry / cli_equivalent / must_invoke",
               "add one of those fields under .commands[\"" + name + "\"] in commands.json",
               CMDS_JSON)
        return
    }
    let tmpl = strip_optional_flags(tmpl_raw)
    let seed_sh = seed.replace("'", "'\\''")
    let mut cmd = tmpl
    if cmd.contains("{seed}") {
        cmd = cmd.replace("{seed}", seed_sh)
    } else {
        cmd = cmd + " --seed '" + seed_sh + "'"
    }
    // execution.entry often uses double quotes around "{seed}" — replace
    // those with single quotes so the shell handles the seed cleanly.
    cmd = cmd.replace("\"" + seed_sh + "\"", "'" + seed_sh + "'")
    println("[hexa-url] exec: " + cmd)
    let out = to_string(exec(cmd + " 2>&1"))  // @allow-bare-exec
    println(out)
}

fn dispatch_active() -> void {
    let root = to_string(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()  // @allow-bare-exec
    if root.len() == 0 {
        ai_err("GIT-NO-ROOT",
               "not in a git repo — no active.json to read",
               "cd into a repo with .hook-commands/active.json, or initialize one",
               "git rev-parse --show-toplevel")
        return
    }
    let p = root + "/.hook-commands/active.json"
    if !file_exists(p) {
        println("{\"stack\":[]}")
        return
    }
    let mut content = ""
    try { content = read_file(p) } catch e {}
    if content.len() == 0 { println("{\"stack\":[]}") } else { println(content.trim()) }
}

// hexa://remote/<host>/<inner-scope>/<inner-resource>?<query>
//   → ssh <host> hxq <reconstructed inner URL>.
// Requires <host> to have hxq + gate/ installed (see airgenome-init's
// planned ensure_remote_gate() / manual: scp hxq + rsync gate/).
// Seeds Mac-heavy-compute routing (AG6): callers on Mac can substitute
// hexa://gate/drill → hexa://remote/ubu/gate/drill without thrashing
// interp locally.
//
// Preflight (2026-04-22): before the ssh handshake (which paid ~5s per
// host on failure), run gate/remote_preflight.hexa with a 300 ms parallel
// TCP probe. If the host is unreachable we short-circuit with ai_err
// instead of burning the full ConnectTimeout. Cache TTL 30 s means
// back-to-back invocations on the same dead host cost ~0 s.
fn dispatch_remote(remote_path: str, query: str) -> void {
    let slash = remote_path.index_of("/")
    if slash < 0 {
        ai_err("REMOTE-BAD-HOST",
               "remote URL missing inner scope: got '" + remote_path + "'",
               "use hexa://remote/<host>/<inner-scope>/<resource>?<query>",
               "gate/hexa_url.hexa:dispatch_remote")
        return
    }
    let host = remote_path.substring(0, slash)
    let inner = remote_path.substring(slash + 1, remote_path.len())
    let mut inner_url = "hexa://" + inner
    if query.len() > 0 { inner_url = inner_url + "?" + query }
    let url_sh = inner_url.replace("'", "'\\''")
    // Freshness axis (closure.011) — apply BEFORE TCP probe + ssh handshake.
    // Default = gate (probe + inline sync if stale). Per the rule's
    // precedence: target → freshness → timeout → async → fmt.
    let fresh_raw = get_param(query, "freshness")
    let bad = validate_freshness(fresh_raw)
    if bad.len() > 0 {
        ai_err("FRESHNESS-BAD-VALUE",
               "unknown freshness='" + bad + "' (use: gate|skip|strict|force)",
               "drop ?freshness= for default 'gate', or pick from the whitelist",
               "closure.011")
        exit(3)
    }
    let freshness = freshness_default(fresh_raw)
    let repo_for_drift = get_param(query, "repo")
    if !freshness_gate_apply(freshness, host, repo_for_drift) {
        // Strict mode hit — sentinel already emitted, hard-block.
        exit(1)
    }
    // Fast preflight — abort early if the host is TCP-dead. Use exec_with_status
    // so we can key off the exit code (0 = reachable, 74 = all-unreachable on
    // Darwin heavy-compute path, 64 = generic unreachable).
    let hx = WS + "/hexa-lang/hexa"
    let pre = GATE + "/remote_preflight.hexa"
    let pre_cmd = hx + " run " + pre + " --hosts '" + host.replace("'", "'\\''") +
                  "' --json-only 2>/dev/null; echo __PRE_RC=$?"
    let pre_out = to_string(exec(pre_cmd))  // @allow-bare-exec
    let rc_idx = pre_out.index_of("__PRE_RC=")
    let mut pre_rc = "0"
    if rc_idx >= 0 {
        pre_rc = pre_out.substring(rc_idx + 9, pre_out.len()).trim()
    }
    if pre_rc != "0" {
        ai_err("REMOTE-UNREACHABLE",
               "preflight: host '" + host + "' failed TCP probe (300ms) — rc=" + pre_rc,
               "run: hexa run gate/remote_preflight.hexa --hosts " + host + "  # verbose diagnosis",
               "gate/remote_preflight.hexa")
        // Surface the resolver-compat NEXUS_REMOTE_ERROR line to stderr
        // (preflight already emitted NEXUS_REMOTE_PREFLIGHT verdict).
        return
    }
    // ssh BatchMode fails fast if host not reachable; use absolute path to
    // ~/.hx/bin/hxq since non-interactive shells may lack ~/.hx/bin in PATH.
    let ssh_cmd = "ssh -o BatchMode=yes -o ConnectTimeout=5 " + host +
                  " \"\\$HOME/.hx/bin/hxq '" + url_sh + "'\" 2>&1"
    println("[hexa-url] remote → " + host + " : " + inner_url)
    let out = to_string(exec(ssh_cmd))  // @allow-bare-exec
    println(out)
}

// NOTE: hexa://harness/<subcmd>?<query> is handled NATIVELY by the bash
// dispatcher at ~/.hx/bin/hexa-url-handler.sh — NOT here. Reason: this
// resolver runs inside hexa-runtime docker sandbox (route=docker
// mac_safe_landing) which cannot exec Mac-host binaries like
// ~/.hx/bin/browser-harness. The bash dispatcher is native and unaffected.
// hxq detects 'hexa://harness/' prefix and short-circuits to the bash
// handler before this resolver is ever invoked.

fn main() {
    let argv = args()
    let mut url = ""
    let mut i = 0
    while i < argv.len() {
        if argv[i].starts_with("hexa://") { url = argv[i]; break }
        i = i + 1
    }
    if url.len() == 0 {
        ai_err("USAGE-EMPTY",
               "no hexa:// URL argument given",
               "pass one of: gate/{drill,entry}  cmd/<name>  cmd/list[?fmt=text|json]  active  harness/<subcmd>  remote/<host>/...",
               "gate/hexa_url.hexa")
        return
    }

    let parsed = parse_url(url)
    let sc = parsed[0]
    let res = parsed[1]
    let query = parsed[2]

    if sc == "gate" && res == "drill" {
        dispatch_drill(get_param(query, "seed"))
    } else if sc == "gate" && res == "entry" {
        let md = get_param(query, "mode")
        let tx = get_param(query, "text")
        let ent = HOME + "/core/hexa-lang/gate/entry.hexa"
        let hx = WS + "/hexa-lang/hexa"
        let tx_sh = tx.replace("'", "'\\''")
        let cmd = hx + " run " + ent + " " + md + " '" + tx_sh + "' 2>&1"
        println(to_string(exec(cmd)))  // @allow-bare-exec
    } else if sc == "cmd" && res == "list" {
        dispatch_cmd_list(query)
    } else if sc == "cmd" {
        dispatch_cmd(res, get_param(query, "seed"))
    } else if sc == "active" {
        dispatch_active()
    } else if sc == "harness" {
        dispatch_harness(res, query)
    } else if sc == "remote" {
        dispatch_remote(res, query)
    } else {
        ai_err("SCOPE-UNKNOWN",
               "unknown scope/resource: '" + sc + "/" + res + "'",
               "use one of: gate/{drill,entry}  cmd/<name>  cmd/list[?fmt=text|json]  active  harness/<subcmd>  remote/<host>/...",
               "gate/hexa_url.hexa:main")
    }
}

main()
