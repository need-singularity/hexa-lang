// gate/hexa_url.hexa — hexa:// URL resolver (local scope, phase 1).
//
// Schema:
//   hexa://gate/drill?seed=<text>            → drill_bg_spawn.sh <seed>
//   hexa://gate/entry?mode=<m>&text=<t>      → entry.hexa <mode> <text>
//   hexa://cmd/<name>?seed=<text>            → commands.json must_invoke (or cli_equivalent)
//   hexa://active                            → cat <git-root>/.hook-commands/active.json
//   hexa://statusline                        → claude_statusline.hexa
//
// usage:
//   hexa run gate/hexa_url.hexa "hexa://gate/drill?seed=밀레니엄 문제 돌파 분석 30자"
//   hexa run gate/hexa_url.hexa "hexa://cmd/smash?seed=..."
//
// Platform: Mac/Linux neutral — shell calls only. Remote scope reserved for
// phase 2 (hexa://remote/<host>/...).

let HOME = env("HOME")
let GATE = HOME + "/Dev/hexa-lang/gate"
let CMDS_JSON = GATE + "/commands.json"

// ─── URL decoding (percent-encoded) ──────────────────────────────────
// Supports ASCII + UTF-8 multi-byte (jq does the work — avoids per-byte loop).
fn url_decode(s: str) -> str {
    if s.contains("%") == false && s.contains("+") == false { return s }
    // jq --arg s "<input>" -n '$s | gsub("\\+"; " ") | @uri' undoes + but not %; use python one-liner instead.
    let cmd = "printf '%s' '" + s.replace("'", "'\\''") + "' | python3 -c 'import sys,urllib.parse;sys.stdout.write(urllib.parse.unquote_plus(sys.stdin.read()))' 2>/dev/null"
    let out = to_string(exec(cmd))  // @allow-bare-exec
    if out.len() == 0 { return s }
    return out
}

// ─── URL parser — returns [scope, resource, query_raw] ───────────────
fn parse_url(u: str) -> [str] {
    let prefix = "hexa://"
    if u.starts_with(prefix) == false { return ["", "", ""] }
    let rest = u.substring(prefix.len(), u.len())
    let mut path = rest
    let mut query = ""
    let q_idx = rest.index_of("?")
    if q_idx >= 0 {
        path = rest.substring(0, q_idx)
        query = rest.substring(q_idx + 1, rest.len())
    }
    let slash = path.index_of("/")
    if slash < 0 { return [path, "", query] }
    let us_scope = path.substring(0, slash)
    let us_res = path.substring(slash + 1, path.len())
    return [us_scope, us_res, query]
}

// ─── Query → single param lookup (no multi-value, no escaping beyond urldecode) ──
fn get_param(query: str, key: str) -> str {
    if query.len() == 0 { return "" }
    let parts = query.split("&")
    for p in parts {
        let eq = p.index_of("=")
        if eq < 0 { continue }
        let k = p.substring(0, eq)
        if k == key {
            let v = p.substring(eq + 1, p.len())
            return url_decode(v)
        }
    }
    return ""
}

// Prefer execution.entry (clean CLI template with {seed}) over must_invoke
// (user-facing prose) or cli_equivalent (may include nexus-cli passthrough notes).
fn cmd_must_invoke(name: str) -> str {
    let q = "jq -r '.commands[\"" + name + "\"].execution.entry // .commands[\"" + name + "\"].execution.cli_equivalent // .commands[\"" + name + "\"].must_invoke // \"\"' '" + CMDS_JSON + "' 2>/dev/null"
    return to_string(exec(q)).trim()  // @allow-bare-exec
}

fn dispatch_drill(seed: str) -> void {
    let log = "/tmp/nexus_drill_active.log"
    let seed_sh = seed.replace("'", "'\\''")
    let bg_cmd = GATE + "/drill_bg_spawn.sh '" + seed_sh + "' '" + log + "'"
    let pid = to_string(exec(bg_cmd)).trim()  // @allow-bare-exec
    println("[hexa-url] drill dispatched pid=" + pid + " log=" + log)
}

// Strip bracketed optional-flag notation from commands.json templates.
// commands.json uses "[--max-rounds 10]" etc. as documentation for optional
// flags; don't pass those literal brackets through to the shell.
fn strip_optional_flags(s: str) -> str {
    let mut out = ""
    let mut depth = 0
    let mut i = 0
    while i < s.len() {
        let ch = s.substring(i, i + 1)
        if ch == "[" { depth = depth + 1 }
        else if ch == "]" { if depth > 0 { depth = depth - 1 } }
        else if depth == 0 { out = out + ch }
        i = i + 1
    }
    // Collapse runs of whitespace left behind by removed brackets.
    return to_string(exec("printf '%s' '" + out.replace("'", "'\\''") + "' | tr -s ' '")).trim()  // @allow-bare-exec
}

fn dispatch_cmd(name: str, seed: str) -> void {
    let tmpl_raw = cmd_must_invoke(name)
    if tmpl_raw.len() == 0 {
        eprintln("[hexa-url] no execution.entry / cli_equivalent / must_invoke for cmd '" + name + "' — check " + CMDS_JSON)
        return
    }
    let tmpl = strip_optional_flags(tmpl_raw)
    let seed_sh = seed.replace("'", "'\\''")
    let mut cmd = tmpl
    if cmd.contains("{seed}") {
        cmd = cmd.replace("{seed}", seed_sh)
    } else {
        cmd = cmd + " --seed '" + seed_sh + "'"
    }
    // execution.entry often uses double quotes around "{seed}" — replace
    // those with single quotes so the shell handles the seed cleanly.
    cmd = cmd.replace("\"" + seed_sh + "\"", "'" + seed_sh + "'")
    println("[hexa-url] exec: " + cmd)
    let out = to_string(exec(cmd + " 2>&1"))  // @allow-bare-exec
    println(out)
}

fn dispatch_active() -> void {
    let root = to_string(exec("git rev-parse --show-toplevel 2>/dev/null")).trim()  // @allow-bare-exec
    if root.len() == 0 {
        eprintln("[hexa-url] not in a git repo — no active.json")
        return
    }
    let p = root + "/.hook-commands/active.json"
    let out = to_string(exec("cat '" + p + "' 2>/dev/null"))  // @allow-bare-exec
    if out.len() == 0 { println("{\"stack\":[]}") } else { println(out.trim()) }
}

fn dispatch_statusline() -> void {
    let cmd = HOME + "/Dev/hexa-lang/hexa run " + GATE + "/claude_statusline.hexa"
    println(to_string(exec(cmd)).trim())  // @allow-bare-exec
}

fn main() {
    let argv = args()
    let mut url = ""
    let mut i = 0
    while i < argv.len() {
        if argv[i].starts_with("hexa://") { url = argv[i]; break }
        i = i + 1
    }
    if url.len() == 0 {
        eprintln("usage: hexa run gate/hexa_url.hexa \"hexa://<scope>/<resource>?<args>\"")
        eprintln("       scopes: gate/{drill,entry}  cmd/<name>  active  statusline")
        return
    }

    let parsed = parse_url(url)
    let sc = parsed[0]
    let res = parsed[1]
    let query = parsed[2]

    if sc == "gate" && res == "drill" {
        dispatch_drill(get_param(query, "seed"))
    } else if sc == "gate" && res == "entry" {
        let md = get_param(query, "mode")
        let tx = get_param(query, "text")
        let ent = HOME + "/Dev/hexa-lang/gate/entry.hexa"
        let hx = HOME + "/Dev/hexa-lang/hexa"
        let tx_sh = tx.replace("'", "'\\''")
        let cmd = hx + " run " + ent + " " + md + " '" + tx_sh + "' 2>&1"
        println(to_string(exec(cmd)))  // @allow-bare-exec
    } else if sc == "cmd" {
        dispatch_cmd(res, get_param(query, "seed"))
    } else if sc == "active" {
        dispatch_active()
    } else if sc == "statusline" {
        dispatch_statusline()
    } else {
        eprintln("[hexa-url] unknown scope/resource: " + sc + "/" + res)
    }
}

main()
