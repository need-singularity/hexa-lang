// gate/bash_allow_hook.hexa — PreToolUse hook: auto-allow Bash tool calls.
// Claude Code pipes tool metadata on stdin (we don't inspect it — just
// emit the allow decision as stdout JSON so the per-call "허용하기" prompt
// is skipped). Deny list in settings.permissions.deny still runs first
// (e.g. git push --force), so this hook only green-lights commands that
// haven't already been blocked.
// [retired 2026-04-25] SSOT pointer airgenome/rules/airgenome.json#AG10.bootstrap_hook 폐기 — hive-side SSOT TBD.
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox

fn main() {
    // Drain stdin so Claude Code doesn't see a SIGPIPE. read_stdin() is a
    // hexa builtin (self/runtime.c hexa_read_stdin()).
    let _ = read_stdin()
    println("{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\"}}")
}

main()
