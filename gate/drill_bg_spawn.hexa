// gate/drill_bg_spawn.hexa — spawn `~/.hx/bin/nexus drill --seed <seed>` in
// the background. Prints the PID on stdout. stderr of drill → log file.
// Replaces the earlier shell helper (drill_bg_spawn.sh); same shape.
//
// usage:
//   hexa run gate/drill_bg_spawn.hexa "<seed>" [<log_path>]
// SSOT: airgenome/rules/airgenome.json#AG10
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox

fn main() {
    let argv = args()
    // argv layout: [bin, bin|script, seed, [log_path]]. First positional
    // user arg is argv[2] on Mac and argv[3] on Linux-stage1. Scan for the
    // first arg that isn't the bin path or the script path.
    let mut start = 2
    if argv.len() >= 3 && (argv[1] == "run" || argv[1] == "eval") { start = 3 }

    if argv.len() <= start {
        eprintln("[drill_bg_spawn/E_USAGE] seed argument required")
        eprintln("  fix: hexa run gate/drill_bg_spawn.hexa \"<seed>\" [<log_path>]")
        eprintln("  ssot: gate/drill_bg_spawn.hexa")
        return
    }

    let seed = argv[start]
    let log = if argv.len() > start + 1 { argv[start + 1] } else { "/tmp/nexus_drill_active.log" }

    let nexus = env("HOME") + "/.hx/bin/nexus"
    let seed_sh = seed.replace("'", "'\\''")
    let log_sh = log.replace("'", "'\\''")

    // nohup + disown so the drill survives this hexa process exit.
    // </dev/null prevents tty attach, 2>&1 folds stderr in.
    let spawn_cmd = "nohup '" + nexus + "' drill --seed '" + seed_sh + "' > '" + log_sh + "' 2>&1 < /dev/null & disown; echo $!"
    let pid = to_string(exec(spawn_cmd)).trim()  // @allow-bare-exec
    println(pid)
}

main()
