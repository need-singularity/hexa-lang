// nexus/tool/claude_harness_pointer.hexa
// Emits the session-bootstrap text injected into Claude Code's system prompt
// via cl-launch's --append-system-prompt flag. Replaces deleted CLAUDE.md
// context (AG10 single-pointer pattern — no per-project CLAUDE.md / hooks /
// skills). One source; all `cl` sessions see identical harness guidance.
// SSOT: $AIRGENOME/rules/airgenome.json#AG10

fn main() {
    println("## hexa-only harness (AG10 — see $AIRGENOME/rules/airgenome.json)")
    println("")
    println("On EVERY user prompt, FIRST run:")
    println("  hexa run /Users/ghost/core/hexa-lang/gate/entry.hexa prompt \"<user_text>\"")
    println("This surfaces [CMD]/[AG10]/[H-*] gates and writes matched commands to")
    println("<project_root>/.hook-commands/active.json (drives the statusLine).")
    println("")
    println("When [CMD] <name> is emitted, dispatch per $HEXA_LANG/gate/commands.json.")
    println("  e.g. [CMD] drill → ~/.hx/bin/nexus drill --seed \"<inferred>\"")
    println("The command's `must_invoke` / `required_action_on_imperative` field")
    println("in commands.json is authoritative — do not reply with vocabulary")
    println("lists, markdown option menus, or 'I should drill' intent text.")
    println("")
    println("Session-start links (workspace first):")
    println("  .workspace   $WS/.workspace                            core-bundle SSOT (7 projects, resources, members)")
    println("  policy       /Users/ghost/core/airgenome/rules/airgenome.json  (AG*)")
    println("  enforce      /Users/ghost/core/hexa-lang/gate/enforcement_registry.json  (H-*)")
    println("  handlers     /Users/ghost/core/hexa-lang/gate/{prompt_scan,pre_tool_guard,lint}.hexa")
    println("  statusline   /Users/ghost/core/hexa-lang/gate/claude_statusline.hexa (+ .jq)")
    println("  active.json  <project_root>/.hook-commands/active.json")
    println("  commands     /Users/ghost/core/hexa-lang/gate/commands.json")
    println("")
    println("DO NOT create per-project CLAUDE.md / Claude Code hooks / .claude/skills/ (AG10).")
    println("Bypass: NEXUS_HOOK_OK=1 (explicit user approval only).")
}
