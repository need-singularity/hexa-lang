// gate/wrappers/install.hexa — builder/installer for mk1 compute-routing wrappers.
//
// Resurrects the mk1 wrapper set from airgenome v1: `cargo`, `rustc`, `python3`,
// `sh-run`, and `hexa` shims intercept invocations and route mac-heavy compute
// to a remote host (phase-1: local fallback only). Build artifacts land in
// $WS/hexa-lang/gate/wrappers/bin/ and should be prepended to $PATH via the
// user's shell rc.
//
// Usage:
//   hexa run $WS/hexa-lang/gate/wrappers/install.hexa
//
// Invariants:
//   - $WS must be set; hard error otherwise (E_WS_UNSET).
//   - Each source file that exists under src/ builds to a corresponding binary
//     in bin/. Missing sources are skipped with a note, not an error (the
//     phase-1 wrapper set is still being ported — _cache.hexa is shared-lib
//     only and never builds standalone).
//   - config.jsonl is dropped with defaults on first run; never overwritten.
//
// Hexa constraints: no spawn/scope/find; every exec bears `// @allow-bare-exec`.

let WS = env("WS")

// ─── ai-native error helper — 3-line stderr format (match gate/hexa_url.hexa) ──
fn ai_err(code: str, what: str, fix: str, ssot: str) -> void {
    eprintln("[wrapper_install/" + code + "] " + what)
    eprintln("  fix: " + fix)
    eprintln("  ssot: " + ssot)
}

// ─── build one wrapper binary; returns true on success ────────────────
fn build_one(src_name: str, out_name: str) -> bool {
    let src = WS + "/hexa-lang/gate/wrappers/src/" + src_name + ".hexa"
    let out = WS + "/hexa-lang/gate/wrappers/bin/" + out_name
    if !file_exists(src) {
        ai_err("E_SRC_MISSING",
               "source not found: " + src,
               "create src/" + src_name + ".hexa or remove '" + out_name + "' from the build list",
               "gate/wrappers/install.hexa:build_one")
        return false
    }
    let hx = WS + "/hexa-lang/hexa"
    let cmd = hx + " build " + src + " -o " + out
    let r = exec_with_status(cmd + " 2>&1")  // @allow-bare-exec
    if r[1] != 0 {
        ai_err("E_BUILD_FAIL",
               "build failed for " + src_name + ".hexa → bin/" + out_name,
               cmd,
               to_string(r[0]).trim())
        return false
    }
    println("  [ok] " + src_name + ".hexa → bin/" + out_name)
    return true
}

fn ensure_config() -> void {
    let cfg = WS + "/hexa-lang/gate/wrappers/config.jsonl"
    if file_exists(cfg) { return }
    let body = "{\"key\":\"remote_host\",\"value\":\"192.168.50.119\"}\n" +
               "{\"key\":\"remote_port\",\"value\":\"9900\"}\n" +
               "{\"key\":\"remote_user\",\"value\":\"aiden\"}\n" +
               "{\"key\":\"ssh_alias\",\"value\":\"ubu\"}\n" +
               "{\"key\":\"tailscale_host\",\"value\":\"\"}\n" +
               "{\"key\":\"hetzner_host\",\"value\":\"157.180.8.154\"}\n" +
               "{\"key\":\"max_budget\",\"value\":\"4\"}\n"
    try { write_file(cfg, body) } catch e {
        ai_err("E_CFG_WRITE",
               "could not drop default config.jsonl at " + cfg,
               "check write perms on gate/wrappers/ and rerun",
               "gate/wrappers/install.hexa:ensure_config")
        return
    }
    println("  [ok] wrote default config.jsonl")
}

fn main() {
    if WS.len() == 0 {
        ai_err("E_WS_UNSET",
               "$WS is not set — cannot locate hexa-lang workspace",
               "export WS=\"$HOME/core\" (or your workspace root) and rerun",
               "gate/wrappers/install.hexa:main")
        return
    }

    let bin_dir = WS + "/hexa-lang/gate/wrappers/bin"
    let mk = exec_with_status("mkdir -p '" + bin_dir + "' 2>&1")  // @allow-bare-exec
    if mk[1] != 0 {
        ai_err("E_MKDIR",
               "could not create " + bin_dir,
               "mkdir -p '" + bin_dir + "'",
               to_string(mk[0]).trim())
        return
    }

    // (src_name, out_name) pairs. _cache.hexa is a shared lib — never built
    // standalone. sh_run → sh-run (dash, not underscore, to match user shells).
    let targets = [
        ["cargo",      "cargo"],
        ["rustc",      "rustc"],
        ["python3",    "python3"],
        ["sh_run",     "sh-run"],
        ["hexa_wrap",  "hexa"],
    ]

    let total = targets.len()
    let mut ok = 0
    let mut failed = []
    let mut i = 0
    while i < targets.len() {
        let t = targets[i]
        if build_one(t[0], t[1]) { ok = ok + 1 } else { failed = failed + [t[1]] }
        i = i + 1
    }

    ensure_config()

    if ok == total {
        println("[wrapper_install] built " + to_string(ok) + " / " + to_string(total) + " binaries to " + bin_dir)
    } else {
        let mut flist = ""
        let mut j = 0
        while j < failed.len() {
            if j > 0 { flist = flist + "," }
            flist = flist + failed[j]
            j = j + 1
        }
        println("[wrapper_install] built " + to_string(ok) + " / " + to_string(total) + " binaries to " + bin_dir + " (failed: " + flist + ")")
    }
}

main()
