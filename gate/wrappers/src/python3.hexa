// gate/wrappers/src/python3.hexa — phase-1 port of archive/v1/gate/wrappers/python3
// @allow-bare-exec
//
// Mirrors v1 semantics with two narrowings:
//   1. REPL / `-c <code>` fast-path is preserved *exactly* (exec local,
//      no filter, no budget). This keeps interactive python3 latency
//      identical to un-wrapped python3.
//   2. Remote (ubu) dispatch is DEFERRED — v1's rsync + scp + nc pipeline
//      needs proper host-sync primitives that aren't in _cache.hexa yet.
//      When ag_filter_decide returns "ubu", we log a TODO row and fall
//      back to the local python3 so callers never block on remote gaps.
//
// Ref style: gate/hexa_url.hexa (ai_err, $WS guard, @allow-bare-exec).
// Reserved-word guard: no `spawn`/`scope`/`find` — local names use
// `bg_cmd`, `sc`, `index_of` instead (gate/HEXA_RESERVED.md §3).

use "_cache"

// ─── ai-native error helper — every failure: what/fix/ssot ────────────
fn ai_err(code: str, what: str, fix: str, ssot: str) -> void {
    eprintln("[python3/" + code + "] " + what)
    eprintln("  fix: " + fix)
    eprintln("  ssot: " + ssot)
}

// ─── Resolve the real python3 binary ──────────────────────────────────
// Probe order matches v1: brew → /usr/bin → PATH-next. "PATH-next" means
// we ask the shell for the next python3 in PATH *other* than this very
// wrapper — `command -v -a` returns all matches in order, skip the first
// if it's the wrapper itself.
fn _real_python3(self_path: str) -> str {
    let brew = "/opt/homebrew/bin/python3"
    if file_exists(brew) { return brew }
    let ubin = "/usr/bin/python3"
    if file_exists(ubin) { return ubin }
    // PATH-next fallback.
    let self_sh = self_path.replace("'", "'\\''")
    let q = "command -v -a python3 2>/dev/null | awk -v s='" + self_sh +
            "' '$0 != s {print; exit}'"
    let r = to_string(exec(q)).trim()  // @allow-bare-exec
    if r.len() > 0 { return r }
    // Last-ditch: return the brew path even though it doesn't exist, so
    // the ai_err at call-site points somewhere specific.
    return brew
}

// ─── Shell-quote each argv item, join with spaces ─────────────────────
fn _sh_quote(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _join_quoted(items: [str]) -> str {
    let mut out = ""
    let mut i = 0
    while i < items.len() {
        if i > 0 { out = out + " " }
        out = out + _sh_quote(to_string(items[i]))
        i = i + 1
    }
    return out
}

fn _join_raw(items: [str]) -> str {
    let mut out = ""
    let mut i = 0
    while i < items.len() {
        if i > 0 { out = out + " " }
        out = out + to_string(items[i])
        i = i + 1
    }
    return out
}

// ─── Epoch seconds as i64 (for elapsed calc) ──────────────────────────
fn _epoch_i() -> i64 {
    let s = to_string(exec("date +%s")).trim()  // @allow-bare-exec
    if s.len() == 0 { return 0 }
    let mut n: i64 = 0
    try { n = to_int(s) } catch e { return 0 }
    return n
}

fn main() {
    // ─── $WS guard ────────────────────────────────────────────────────
    let WS = env("WS")
    if WS.len() == 0 {
        ai_err("E_WS_UNSET",
               "$WS not set — python3 wrapper needs it to locate config/log paths",
               "export WS=<repo-root> in shell rc or ~/.claude/settings.json env",
               "airgenome/rules/airgenome.json#AG10")
        // Still try to exec the real python3 so the user isn't stranded.
        // @allow-bare-exec
        let r0 = exec_with_status("/opt/homebrew/bin/python3 2>&1")
        let o0 = to_string(r0[0])
        if o0.len() > 0 { print(o0) }
        let rc0 = to_int(to_string(r0[1]))
        exit(rc0)
    }

    // ─── argv normalization — strip `hexa run <script>` / `hexa <script>` prefix ──
    // Mirrors the pattern used in gate/post_edit.hexa + gate/pre_tool_guard.hexa.
    // Compiled-binary mode (hexa_set_args dup'd argv[0]) surfaces as
    // raw_argv[0] == raw_argv[1]; skip the duplicate so user args start right.
    let raw_argv = args()
    let mut script_idx = -1
    let mut sc = 0  // scan index — `scope` is reserved (§1a), using `sc`.
    while sc < raw_argv.len() {
        if to_string(raw_argv[sc]).ends_with(".hexa") { script_idx = sc; break }
        sc = sc + 1
    }
    let self_path = if script_idx >= 0 { to_string(raw_argv[script_idx]) } else { to_string(raw_argv[0]) }
    let first_user_idx = if script_idx >= 0 { script_idx + 1 } else {
        if raw_argv.len() >= 2 && to_string(raw_argv[0]) == to_string(raw_argv[1]) { 2 }
        else if raw_argv.len() >= 3 && (to_string(raw_argv[1]) == "run" || to_string(raw_argv[1]) == "eval") { 3 }
        else { 1 }
    }
    let mut uargs: [str] = []
    let mut ui = first_user_idx
    while ui < raw_argv.len() {
        uargs = uargs + [to_string(raw_argv[ui])]
        ui = ui + 1
    }

    // ─── Emergency bypass: CLAUDX_NO_WRAPPER=1 ────────────────────────
    if env("CLAUDX_NO_WRAPPER") == "1" {
        let real = _real_python3(self_path)
        // Drop the `exec ` prefix — popen/exec_with_status is a child shell,
        // `exec` would replace the shell but our capture still works; either
        // way we MUST relay stdout to our own caller or output is swallowed.
        let ex = _sh_quote(real) + " " + _join_quoted(uargs) + " 2>&1"
        // @allow-bare-exec
        let r = exec_with_status(ex)
        let out = to_string(r[0])
        if out.len() > 0 { print(out) }
        let rc = to_int(to_string(r[1]))
        exit(rc)
    }

    let real_py = _real_python3(self_path)

    // ─── Fast-path: REPL (no args) or `-c <code>` ─────────────────────
    // v1 preserves this unconditionally: no filter, no budget, no record.
    // Interactive python3 must feel native — any ~100ms of gate overhead
    // here would be noticeable in a REPL session.
    if uargs.len() == 0 || (uargs.len() >= 1 && to_string(uargs[0]) == "-c") {
        ag_gate_msg("local", "python3 " + _join_raw(uargs))
        let ex = _sh_quote(real_py) + " " + _join_quoted(uargs) + " 2>&1"
        // @allow-bare-exec
        let r = exec_with_status(ex)
        let out = to_string(r[0])
        if out.len() > 0 { print(out) }
        let rc = to_int(to_string(r[1]))
        exit(rc)
    }

    // ─── Budget + filter decide ───────────────────────────────────────
    ag_budget_enter()
    let t0 = _epoch_i()

    let joined = _join_raw(uargs)
    let dec = ag_filter_decide("python3", joined)
    let mut target = to_string(dec[0])
    let reason = to_string(dec[1])

    // Budget check overrides target → local when over cap (v1 parity:
    // only applies when FILTER_BUDGET_BYPASS != 1).
    if env("FILTER_BUDGET_BYPASS") != "1" {
        if ag_budget_check() == false {
            // Over budget → force local to shed load.
            target = "local"
        }
    }

    // Resolve host; if target=ubu but no reachable GH, degrade to local.
    let gh = ag_resolve_host()
    if target == "ubu" && gh.len() == 0 {
        target = "local"
    }

    // ─── target = local ───────────────────────────────────────────────
    if target == "local" {
        ag_gate_msg("local", "python3 " + joined + " [filter:" + reason + "]")
        let ex = _sh_quote(real_py) + " " + _join_quoted(uargs) + " 2>&1"
        // @allow-bare-exec
        let r = exec_with_status(ex)
        let out = to_string(r[0])
        let rc = to_int(to_string(r[1]))
        if out.len() > 0 { print(out) }
        let t1 = _epoch_i()
        ag_filter_record("python3", "local", rc, t1 - t0)
        ag_budget_leave()
        exit(rc)
    }

    // ─── target = ubu (DEFERRED) ─────────────────────────────────────
    // v1 rsyncs $NEXUS/shared, scps arg-files, pipes `cd <dir> && python3 ...`
    // through `nc <GH>:<port>` and strips the ---END--- sentinel. That whole
    // pipeline depends on primitives _cache.hexa doesn't expose yet
    // (remote_exec, file_sync, nc_pipe). Rather than silently produce a
    // half-working ubu path, we:
    //   1. log a TODO row via ag_filter_record (target="ubu-deferred") so
    //      the deferral is visible in /tmp/ag_gate_filter.log.
    //   2. fall back to local python3 so the user's command still runs.
    //   3. emit a one-line TODO on stderr (only when AG_GATE_DEBUG=1 to
    //      avoid polluting normal output).
    ag_gate_msg("local", "python3 " + joined + " [filter:" + reason + " ubu-deferred→local]")
    if env("AG_GATE_DEBUG") == "1" {
        eprintln("[python3/TODO-REMOTE] ubu dispatch deferred (rsync/scp/nc not yet in _cache.hexa) — running local")
    }
    let ex2 = _sh_quote(real_py) + " " + _join_quoted(uargs) + " 2>&1"
    // @allow-bare-exec
    let r2 = exec_with_status(ex2)
    let out2 = to_string(r2[0])
    let rc2 = to_int(to_string(r2[1]))
    if out2.len() > 0 { print(out2) }
    let t2 = _epoch_i()
    ag_filter_record("python3", "ubu-deferred", rc2, t2 - t0)
    ag_budget_leave()
    exit(rc2)
}

main()
