// gate/wrappers/src/python3.hexa — phase-1 port of archive/v1/gate/wrappers/python3
// @allow-bare-exec
//
// Mirrors v1 semantics with one narrowing:
//   1. REPL / `-c <code>` fast-path is preserved *exactly* (exec local,
//      no filter, no budget). This keeps interactive python3 latency
//      identical to un-wrapped python3.
//   2. Remote (ubu) dispatch is ACTIVE: scp each .py arg to the host under
//      /tmp/ag_gate/files/, rewrite argv, and run `python3` remotely via
//      `ssh`. On any stage failure we degrade to local so the user's
//      command still runs.
//
// Ref style: gate/hexa_url.hexa (ai_err, $WS guard, @allow-bare-exec).
// Reserved-word guard: no `spawn`/`scope`/`find` — local names use
// `bg_cmd`, `sc`, `index_of` instead (gate/HEXA_RESERVED.md §3).
//
// TODO (sibling-import / venv limitations):
//   * Remote cwd is /tmp/ag_gate/files — sibling module imports only work
//     if those siblings were also passed on argv (or pre-staged). No auto
//     package graph walk yet.
//   * `-m <module>` is NOT supported: we would have to rsync site-packages
//     or resolve the importable path to a file. Fall back local today.
//   * No virtualenv / pyenv resolution on the remote side — the host's
//     plain `python3` is invoked.

use "_cache"

// ─── Remote primitives ────────────────────────────────────────────────
// ag_remote_exec / ag_rsync / ag_scp_files are pub in _cache.hexa;
// see _cache.hexa:382+ for contracts. No inline stubs here.

// ─── ai-native error helper — every failure: what/fix/ssot ────────────
fn ai_err(code: str, what: str, fix: str, ssot: str) -> void {
    eprintln("[python3/" + code + "] " + what)
    eprintln("  fix: " + fix)
    eprintln("  ssot: " + ssot)
}

// ─── Resolve the real python3 binary ──────────────────────────────────
// Probe order matches v1: brew → /usr/bin → PATH-next. "PATH-next" means
// we ask the shell for the next python3 in PATH *other* than this very
// wrapper — `command -v -a` returns all matches in order, skip the first
// if it's the wrapper itself.
fn _real_python3(self_path: str) -> str {
    let brew = "/opt/homebrew/bin/python3"
    if file_exists(brew) { return brew }
    let ubin = "/usr/bin/python3"
    if file_exists(ubin) { return ubin }
    // PATH-next fallback.
    let self_sh = self_path.replace("'", "'\\''")
    let q = "command -v -a python3 2>/dev/null | awk -v s='" + self_sh +
            "' '$0 != s {print; exit}'"
    let r = to_string(exec(q)).trim()  // @allow-bare-exec
    if r.len() > 0 { return r }
    // Last-ditch: return the brew path even though it doesn't exist, so
    // the ai_err at call-site points somewhere specific.
    return brew
}

// ─── Shell-quote each argv item, join with spaces ─────────────────────
fn _sh_quote(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _join_quoted(items: [str]) -> str {
    let mut out = ""
    let mut i = 0
    while i < items.len() {
        if i > 0 { out = out + " " }
        out = out + _sh_quote(to_string(items[i]))
        i = i + 1
    }
    return out
}

fn _join_raw(items: [str]) -> str {
    let mut out = ""
    let mut i = 0
    while i < items.len() {
        if i > 0 { out = out + " " }
        out = out + to_string(items[i])
        i = i + 1
    }
    return out
}

// ─── .py arg detection + basename ─────────────────────────────────────
// Heuristic: any argv item that ends with ".py" AND does not start with "-"
// is treated as a script path to ship. Simple by design — `-m foo.py` is
// rare enough to punt to local (see TODO block at top of file).
fn _is_py_arg(s: str) -> bool {
    if s.len() == 0 { return false }
    if s.starts_with("-") { return false }
    return s.ends_with(".py")
}

fn _basename(path: str) -> str {
    let parts = path.split("/")
    let mut last = ""
    let mut i = 0
    while i < parts.len() {
        let p = to_string(parts[i])
        if p.len() > 0 { last = p }
        i = i + 1
    }
    return last
}

// ─── Epoch seconds as i64 (for elapsed calc) ──────────────────────────
fn _epoch_i() -> i64 {
    let s = to_string(exec("date +%s")).trim()  // @allow-bare-exec
    if s.len() == 0 { return 0 }
    let mut n: i64 = 0
    try { n = to_int(s) } catch e { return 0 }
    return n
}

fn main() {
    // ─── $WS guard ────────────────────────────────────────────────────
    let WS = env("WS")
    if WS.len() == 0 {
        ai_err("E_WS_UNSET",
               "$WS not set — python3 wrapper needs it to locate config/log paths",
               "export WS=<repo-root> in shell rc or ~/.claude/settings.json env",
               "airgenome/rules/airgenome.json#AG10")
        // Still try to exec the real python3 so the user isn't stranded.
        // @allow-bare-exec
        let r0 = exec_with_status("/opt/homebrew/bin/python3 2>&1")
        let o0 = to_string(r0[0])
        if o0.len() > 0 { print(o0) }
        let rc0 = to_int(to_string(r0[1]))
        exit(rc0)
    }

    // ─── argv normalization — strip `hexa run <script>` / `hexa <script>` prefix ──
    // Mirrors the pattern used in gate/post_edit.hexa + gate/pre_tool_guard.hexa.
    // Compiled-binary mode (hexa_set_args dup'd argv[0]) surfaces as
    // raw_argv[0] == raw_argv[1]; skip the duplicate so user args start right.
    let raw_argv = args()
    let mut script_idx = -1
    let mut sc = 0  // scan index — `scope` is reserved (§1a), using `sc`.
    while sc < raw_argv.len() {
        if to_string(raw_argv[sc]).ends_with(".hexa") { script_idx = sc; break }
        sc = sc + 1
    }
    let self_path = if script_idx >= 0 { to_string(raw_argv[script_idx]) } else { to_string(raw_argv[0]) }
    let first_user_idx = if script_idx >= 0 { script_idx + 1 } else {
        if raw_argv.len() >= 2 && to_string(raw_argv[0]) == to_string(raw_argv[1]) { 2 }
        else if raw_argv.len() >= 3 && (to_string(raw_argv[1]) == "run" || to_string(raw_argv[1]) == "eval") { 3 }
        else { 1 }
    }
    let mut uargs: [str] = []
    let mut ui = first_user_idx
    while ui < raw_argv.len() {
        uargs = uargs + [to_string(raw_argv[ui])]
        ui = ui + 1
    }

    // ─── Emergency bypass: CLAUDX_NO_WRAPPER=1 ────────────────────────
    if env("CLAUDX_NO_WRAPPER") == "1" {
        let real = _real_python3(self_path)
        // Drop the `exec ` prefix — popen/exec_with_status is a child shell,
        // `exec` would replace the shell but our capture still works; either
        // way we MUST relay stdout to our own caller or output is swallowed.
        let ex = _sh_quote(real) + " " + _join_quoted(uargs) + " 2>&1"
        // @allow-bare-exec
        let r = exec_with_status(ex)
        let out = to_string(r[0])
        if out.len() > 0 { print(out) }
        let rc = to_int(to_string(r[1]))
        exit(rc)
    }

    let real_py = _real_python3(self_path)

    // ─── Fast-path: REPL (no args) or `-c <code>` ─────────────────────
    // v1 preserves this unconditionally: no filter, no budget, no record.
    // Interactive python3 must feel native — any ~100ms of gate overhead
    // here would be noticeable in a REPL session.
    if uargs.len() == 0 || (uargs.len() >= 1 && to_string(uargs[0]) == "-c") {
        ag_gate_msg("local", "python3 " + _join_raw(uargs))
        let ex = _sh_quote(real_py) + " " + _join_quoted(uargs) + " 2>&1"
        // @allow-bare-exec
        let r = exec_with_status(ex)
        let out = to_string(r[0])
        if out.len() > 0 { print(out) }
        let rc = to_int(to_string(r[1]))
        exit(rc)
    }

    // ─── Budget + filter decide ───────────────────────────────────────
    ag_budget_enter()
    let t0 = _epoch_i()

    let joined = _join_raw(uargs)
    let dec = ag_filter_decide("python3", joined)
    let mut target = to_string(dec[0])
    let reason = to_string(dec[1])

    // Budget check overrides target → local when over cap (v1 parity:
    // only applies when FILTER_BUDGET_BYPASS != 1).
    if env("FILTER_BUDGET_BYPASS") != "1" {
        if ag_budget_check() == false {
            // Over budget → force local to shed load.
            target = "local"
        }
    }

    // Resolve host; if target=ubu but no reachable GH, degrade to local.
    let gh = ag_resolve_host()
    if target == "ubu" && gh.len() == 0 {
        target = "local"
    }

    // ─── target = local ───────────────────────────────────────────────
    if target == "local" {
        ag_gate_msg("local", "python3 " + joined + " [filter:" + reason + "]")
        let ex = _sh_quote(real_py) + " " + _join_quoted(uargs) + " 2>&1"
        // @allow-bare-exec
        let r = exec_with_status(ex)
        let out = to_string(r[0])
        let rc = to_int(to_string(r[1]))
        if out.len() > 0 { print(out) }
        let t1 = _epoch_i()
        ag_filter_record("python3", "local", rc, t1 - t0)
        ag_budget_leave()
        exit(rc)
    }

    // ─── target = ubu (ACTIVE remote dispatch) ───────────────────────
    // Flow:
    //   1. Collect .py args (argv items ending .py, not starting with `-`).
    //   2. `-m <module>` → fall back local (TODO: site-packages sync).
    //   3. scp each .py to host:/tmp/ag_gate/files/ ; on any scp failure
    //      degrade to local.
    //   4. Rewrite argv — each .py path becomes /tmp/ag_gate/files/<base>.
    //   5. ssh `cd /tmp/ag_gate/files && python3 <rewritten>` and relay.
    //
    // Limitation (documented): remote cwd is /tmp/ag_gate/files, so sibling
    // imports only resolve if those siblings were also on argv. Pre-staging
    // whole packages is not handled yet (TODO: ag_rsync dir sync).

    // Detect `-m` early — no support yet, fall back local.
    let mut has_dash_m = false
    let mut mi = 0
    while mi < uargs.len() {
        if to_string(uargs[mi]) == "-m" { has_dash_m = true; break }
        mi = mi + 1
    }

    // Collect .py files from argv.
    let mut py_files: [str] = []
    let mut pi = 0
    while pi < uargs.len() {
        let arg = to_string(uargs[pi])
        if _is_py_arg(arg) { py_files = py_files + [arg] }
        pi = pi + 1
    }

    // TODO: venv / pyenv resolution on host — we invoke plain `python3`.
    if has_dash_m {
        ag_gate_msg("local", "python3 " + joined + " [filter:" + reason + " -m→local (TODO:site-packages)]")
        if env("AG_GATE_DEBUG") == "1" {
            eprintln("[python3/TODO-REMOTE] -m module dispatch unsupported remotely — running local")
        }
        let ex_m = _sh_quote(real_py) + " " + _join_quoted(uargs) + " 2>&1"
        // @allow-bare-exec
        let r_m = exec_with_status(ex_m)
        let out_m = to_string(r_m[0])
        let rc_m = to_int(to_string(r_m[1]))
        if out_m.len() > 0 { print(out_m) }
        let t_m = _epoch_i()
        ag_filter_record("python3", "local", rc_m, t_m - t0)
        ag_budget_leave()
        exit(rc_m)
    }

    // Stage files on host.
    let scp_rc = ag_scp_files(gh, py_files)
    if scp_rc != 0 {
        ag_gate_msg("local", "python3 " + joined + " [filter:" + reason + " scp-fail→local]")
        if env("AG_GATE_DEBUG") == "1" {
            eprintln("[python3/E_SCP] scp rc=" + to_string(scp_rc) + " → local fallback")
        }
        let ex_f = _sh_quote(real_py) + " " + _join_quoted(uargs) + " 2>&1"
        // @allow-bare-exec
        let r_f = exec_with_status(ex_f)
        let out_f = to_string(r_f[0])
        let rc_f = to_int(to_string(r_f[1]))
        if out_f.len() > 0 { print(out_f) }
        let t_f = _epoch_i()
        ag_filter_record("python3", "local", rc_f, t_f - t0)
        ag_budget_leave()
        exit(rc_f)
    }

    // Rewrite argv: each .py path → /tmp/ag_gate/files/<basename>. Other
    // args (flags, `-`, non-.py positionals) pass through verbatim.
    let mut rargs: [str] = []
    let mut ri = 0
    while ri < uargs.len() {
        let a = to_string(uargs[ri])
        if _is_py_arg(a) {
            rargs = rargs + ["/tmp/ag_gate/files/" + _basename(a)]
        } else {
            rargs = rargs + [a]
        }
        ri = ri + 1
    }

    let remote_cmd = "cd /tmp/ag_gate/files && python3 " + _join_quoted(rargs)
    ag_gate_msg("ubu", "python3 " + joined + " [filter:" + reason + " host=" + gh + "]")
    let result = ag_remote_exec(gh, remote_cmd)
    let out_r = to_string(result[0])
    let rc_r = to_int(to_string(result[1]))
    if out_r.len() > 0 { print(out_r) }
    let t_r = _epoch_i()
    ag_filter_record("python3", "ubu", rc_r, t_r - t0)
    ag_budget_leave()
    exit(rc_r)
}

main()
