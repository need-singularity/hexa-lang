// gate/wrappers/src/rustc.hexa — phase-1 port of archive/v1/gate/wrappers/rustc.
// @allow-bare-exec
//
// Scope: local-exec fast-path + budget enter/leave + filter decide/record +
// ACTIVE remote (ubu) dispatch. The CARGO-env fast-path is preserved exactly:
// when AG_ENTANGLE_KEY is unset AND CARGO is set, the wrapper runs rustc
// locally without going through the decide path, because a cargo parent's
// entanglement already chose routing for the whole build.
//
// Remote flow mirrors python3.hexa:
//   1. ag_resolve_host() → pick reachable host (empty = local fallback + warn).
//   2. Collect argv items ending in ".rs" (v1 parity: bare .rs + `--crate-name
//      foo src/foo.rs` — any positional path ending .rs is staged).
//   3. scp each .rs to host:/tmp/ag_gate/files/; scp fail → local fallback.
//   4. Rewrite argv — each .rs path becomes /tmp/ag_gate/files/<basename>.
//   5. ssh `rustc <rewritten>` and relay stdout + rc.
//
// Phase-1 limitation (documented): output binaries (.a, .rlib, .so, exe) are
// left on the remote at /tmp/ag_gate/files/ — we DO NOT fetch build artifacts
// back. TODO: E_REMOTE_ARTIFACT_UNFETCHED. Workflows that expect local output
// files must run under CLAUDX_NO_WRAPPER=1 or AG_GATE_FORCE_LOCAL=1.
//
// Ref: gate/hexa_url.hexa for ai_err / $WS / @allow-bare-exec conventions.
// Reserved-word guard (gate/HEXA_RESERVED.md): no spawn / scope / find.

use "_cache"

// ─── Remote primitives ────────────────────────────────────────────────
// ag_remote_exec / ag_rsync / ag_scp_files are pub in _cache.hexa;
// see _cache.hexa:382+ for contracts. No inline stubs here.

let HOME = env("HOME")
let WS = env("WS")

// ─── ai-native error helper ───────────────────────────────────────────
fn ai_err(code: str, what: str, fix: str, ssot: str) -> void {
    eprintln("[rustc/" + code + "] " + what)
    eprintln("  fix: " + fix)
    eprintln("  ssot: " + ssot)
}

// ─── join argv → single raw_args string for ag_filter_decide ─────────
fn _join_args(a: [str]) -> str {
    let mut out = ""
    let mut i: i64 = 0
    // Skip duplicated argv[0] emitted by hexa_set_args in compiled binaries.
    if a.len() >= 2 && a[0] == a[1] { i = 2 }
    while i < a.len() {
        if out.len() > 0 { out = out + " " }
        out = out + a[i]
        i = i + 1
    }
    return out
}

// ─── shell-escape one argv element for the `exec` single-quoted form ─
fn _sh_quote(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _join_shell(a: [str]) -> str {
    let mut out = ""
    let mut i: i64 = 0
    // Skip duplicated argv[0] emitted by hexa_set_args in compiled binaries.
    if a.len() >= 2 && a[0] == a[1] { i = 2 }
    while i < a.len() {
        if out.len() > 0 { out = out + " " }
        out = out + _sh_quote(a[i])
        i = i + 1
    }
    return out
}

// Shell-join a pre-normalized argv (no argv[0] dedup, every item quoted).
fn _join_quoted(items: [str]) -> str {
    let mut out = ""
    let mut i: i64 = 0
    while i < items.len() {
        if i > 0 { out = out + " " }
        out = out + _sh_quote(to_string(items[i]))
        i = i + 1
    }
    return out
}

// ─── Resolve real rustc: cargo bin → homebrew → PATH-next ────────────
// PATH-next: drop the wrapper's own dir from PATH so `which rustc` finds
// the next entry. In phase-1 we only consult the two well-known paths
// and then fall back to a bare `rustc` (assumes PATH is already sane at
// the point this wrapper is invoked — typical for Claude Code harness).
fn _resolve_rustc() -> str {
    let cargo_bin = HOME + "/.cargo/bin/rustc"
    if file_exists(cargo_bin) { return cargo_bin }
    let brew_bin = "/opt/homebrew/bin/rustc"
    if file_exists(brew_bin) { return brew_bin }
    // PATH-next probe — drop wrapper dir from PATH, ask `command -v`.
    let path = env("PATH")
    let self_dir = WS + "/hexa-lang/gate/wrappers"
    let stripped = path.replace(self_dir + ":", "").replace(":" + self_dir, "")
    let q = "PATH=" + _sh_quote(stripped) + " command -v rustc 2>/dev/null"
    let r = to_string(exec(q)).trim()  // @allow-bare-exec
    if r.len() > 0 { return r }
    return "rustc"
}

// ─── run real rustc locally, return rc ────────────────────────────────
// We forward stdin/stdout/stderr inheritedly via the shell, then capture
// the exit code through $?. `exec` here is the hexa builtin; stdout is
// emitted directly by the child thanks to the absence of a redirect.
fn _exec_local(bin: str, argv: [str]) -> i64 {
    let cmd = _sh_quote(bin) + " " + _join_shell(argv) + "; printf '\\n__RC__%s__' \"$?\""
    let raw = to_string(exec(cmd))  // @allow-bare-exec
    // Tail marker __RC__N__ lets us read the child's rc without losing
    // stdout content. Find it from the right so a payload line that
    // happens to contain "__RC__" substring doesn't confuse us.
    let marker = "__RC__"
    let idx = raw.index_of(marker)
    if idx < 0 {
        // Fall back: emit whatever we got, assume rc=0 (best-effort).
        print(raw)
        return 0
    }
    // Split: payload before marker, rc_str between markers.
    let payload = raw.substring(0, idx)
    let tail = raw.substring(idx + marker.len(), raw.len())
    let end = tail.index_of("__")
    let rc_str = if end > 0 { tail.substring(0, end) } else { tail }
    print(payload)
    let mut rc: i64 = 0
    try { rc = to_int(rc_str.trim()) } catch e { rc = 0 }
    return rc
}

// ─── .rs arg detection + basename ────────────────────────────────────
// Heuristic: any argv item ending in ".rs" AND not starting with "-" is a
// source path to stage. This matches v1's `[[ -f "$a" && "$a" == *.rs ]]`
// for both bare positionals (`rustc foo.rs`) and path-valued flags where
// the path follows as the next argv item (`--crate-name foo src/foo.rs`).
// Flags like `--edition=2021` have `=` so they don't end in `.rs`.
fn _is_rs_arg(s: str) -> bool {
    if s.len() == 0 { return false }
    if s.starts_with("-") { return false }
    return s.ends_with(".rs")
}

fn _basename(path: str) -> str {
    let parts = path.split("/")
    let mut last = ""
    let mut i = 0
    while i < parts.len() {
        let p = to_string(parts[i])
        if p.len() > 0 { last = p }
        i = i + 1
    }
    return last
}

// ─── epoch seconds helper (duplicated from _cache to avoid cross-fn) ─
fn _now_s() -> i64 {
    let s = to_string(exec("date +%s")).trim()  // @allow-bare-exec
    let mut n: i64 = 0
    try { n = to_int(s) } catch e { n = 0 }
    return n
}

// ─── Normalize argv (skip compiled-binary argv[0] dup) ───────────────
// Returns the user-facing argv without the `self == self` duplicate that
// hexa_set_args emits in compiled-binary mode. Used for the remote path
// where we need a clean list to scan + rewrite.
fn _norm_argv(a: [str]) -> [str] {
    let mut i: i64 = 0
    if a.len() >= 2 && a[0] == a[1] { i = 2 }
    let mut out: [str] = []
    while i < a.len() {
        out = out + [to_string(a[i])]
        i = i + 1
    }
    return out
}

fn main() {
    if WS.len() == 0 {
        ai_err("E_WS_UNSET",
               "$WS not set — cannot resolve wrapper paths",
               "export WS=<repo-root> in shell rc or ~/.claude/settings.json env",
               "airgenome/rules/airgenome.json#AG10")
        exit(2)
    }

    let argv = args()
    let joined = _join_args(argv)
    let real_rustc = _resolve_rustc()
    let t0 = _now_s()

    // ─── Emergency bypass: skip all gating, exec real rustc now. ─────
    if env("CLAUDX_NO_WRAPPER") == "1" {
        let rc = _exec_local(real_rustc, argv)
        // No budget/filter book-keeping in bypass mode — by design.
        exit(rc)
    }

    // ─── CARGO-env fast-path (v1 rustc:18–24) ─────────────────────────
    // When invoked as cargo's rustc child (CARGO set by cargo itself)
    // AND no entanglement key inherited from a parent cargo call, run
    // locally with NO filter/decide call — the parent cargo already
    // chose routing for the whole build graph. This prevents per-crate
    // wrapper storms during a `cargo build`.
    let cargo_env = env("CARGO")
    let entangle_key = env("AG_ENTANGLE_KEY")
    if entangle_key.len() == 0 && cargo_env.len() > 0 {
        ag_gate_msg("local", "rustc " + joined + " [no-entangle]")
        ag_budget_enter()
        let mut rc: i64 = 0
        try { rc = _exec_local(real_rustc, argv) } catch e { rc = 1 }
        ag_budget_leave()
        ag_filter_record("rustc", "local", rc, _now_s() - t0)
        exit(rc)
    }

    // ─── Normal path: decide → budget → exec ──────────────────────────
    ag_budget_enter()
    let decision = ag_filter_decide("rustc", joined)
    let target = decision[0]
    let reason = decision[1]

    if target == "local" {
        ag_gate_msg("local", "rustc " + joined + " [" + reason + "]")
        let mut rc: i64 = 0
        try { rc = _exec_local(real_rustc, argv) } catch e { rc = 1 }
        ag_budget_leave()
        ag_filter_record("rustc", "local", rc, _now_s() - t0)
        exit(rc)
    }

    if target == "ubu" {
        // ─── ACTIVE remote dispatch ──────────────────────────────────
        // Resolve reachable host; empty = no host reachable → local.
        let host = ag_resolve_host()
        if host.len() == 0 {
            ag_gate_msg("local", "rustc " + joined + " [ubu:no-host→local]")
            if env("AG_GATE_DEBUG") == "1" {
                eprintln("[rustc/W_NO_HOST] ag_resolve_host() returned empty — local fallback")
            }
            let mut rc: i64 = 0
            try { rc = _exec_local(real_rustc, argv) } catch e { rc = 1 }
            ag_budget_leave()
            ag_filter_record("rustc", "local", rc, _now_s() - t0)
            exit(rc)
        }

        // Collect .rs files from a normalized (no argv[0] dup) argv.
        let uargv = _norm_argv(argv)
        let mut rs_files: [str] = []
        let mut pi = 0
        while pi < uargv.len() {
            let a = to_string(uargv[pi])
            if _is_rs_arg(a) { rs_files = rs_files + [a] }
            pi = pi + 1
        }

        // Stage sources. If scp fails at any step → local fallback.
        let scp_rc = ag_scp_files(host, rs_files)
        if scp_rc != 0 {
            ag_gate_msg("local", "rustc " + joined + " [ubu:scp-fail→local rc=" + to_string(scp_rc) + "]")
            if env("AG_GATE_DEBUG") == "1" {
                eprintln("[rustc/E_SCP] scp rc=" + to_string(scp_rc) + " → local fallback")
            }
            let mut rc: i64 = 0
            try { rc = _exec_local(real_rustc, argv) } catch e { rc = 1 }
            ag_budget_leave()
            ag_filter_record("rustc", "local", rc, _now_s() - t0)
            exit(rc)
        }

        // Rewrite argv: every .rs path → /tmp/ag_gate/files/<basename>.
        // Flags, crate names, and non-.rs positionals pass through verbatim.
        // This covers both `rustc foo.rs` and `rustc --crate-name foo src/foo.rs`
        // — `--crate-name` sits in its own argv slot, followed by `foo` (no dot),
        // then `src/foo.rs` (matched + rewritten). `--edition=2021` does not end
        // in .rs so it passes through.
        let mut rargs: [str] = []
        let mut ri = 0
        while ri < uargv.len() {
            let a = to_string(uargv[ri])
            if _is_rs_arg(a) {
                rargs = rargs + ["/tmp/ag_gate/files/" + _basename(a)]
            } else {
                rargs = rargs + [a]
            }
            ri = ri + 1
        }

        let remote_cmd = "rustc " + _join_quoted(rargs)
        ag_gate_msg("ubu", "rustc " + joined + " [filter:" + reason + " host=" + host + "]")
        let result = ag_remote_exec(host, remote_cmd)
        let out_r = to_string(result[0])
        let rc_r = to_int(to_string(result[1]))
        if out_r.len() > 0 { print(out_r) }

        // TODO E_REMOTE_ARTIFACT_UNFETCHED: output binaries (.a, .rlib, .so,
        // exe) remain on remote at /tmp/ag_gate/files/. Fetching them back is
        // phase-2 work — needs crate_type detection, basename inference, and
        // scp round-trip. For now, log the limitation when debug is on.
        if env("AG_GATE_DEBUG") == "1" && rs_files.len() > 0 {
            eprintln("[rustc/TODO E_REMOTE_ARTIFACT_UNFETCHED] build outputs left on " +
                     host + ":/tmp/ag_gate/files/ — phase-1 limitation")
        }
        ag_gate_msg("ubu", "rustc artifacts at " + host + ":/tmp/ag_gate/files/ (TODO E_REMOTE_ARTIFACT_UNFETCHED)")

        ag_budget_leave()
        ag_filter_record("rustc", "ubu", rc_r, _now_s() - t0)
        exit(rc_r)
    }

    // ─── Fallthrough: unknown target, run local, mark unreachable ────
    ag_gate_msg("unreachable", "rustc " + joined + " target=" + target)
    let mut rc: i64 = 0
    try { rc = _exec_local(real_rustc, argv) } catch e { rc = 1 }
    ag_budget_leave()
    ag_filter_record("rustc", "local", rc, _now_s() - t0)
    exit(rc)
}

main()
