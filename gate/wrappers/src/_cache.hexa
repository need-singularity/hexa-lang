// gate/wrappers/src/_cache.hexa — phase-1 port of archive/v1/gate/wrappers/_cache.sh
// @allow-bare-exec
//
// Scope: minimum-viable reach cache + budget counter + filter decide/record.
// Full 11-layer filter pipeline, pathogen escalation, entanglement emit, and
// config-mtime caching are deliberately OUT of scope (see v1 source for
// reference). This file exposes pub fn's other wrappers will call.
//
// Ref: gate/hexa_url.hexa for ai_err / $WS / @allow-bare-exec conventions.
// Reserved-word guard (gate/HEXA_RESERVED.md): do NOT use spawn/scope/find.

// ─── env + paths ─────────────────────────────────────────────────────
let WS = env("WS")
let HOME_DIR = env("HOME")
let REACH_CACHE = "/tmp/ag_gate_reachable.state"
let REACH_TTL   = 60
let BUDGET_FILE = "/tmp/ag_gate_budget.count"
let FILTER_LOG  = "/tmp/ag_gate_filter.log"
let SESSION_NOW = HOME_DIR + "/.airgenome/session_now.json"

// Config lives relative to $WS. Guard inside functions since hexa top-level
// doesn't do early return — callers get a structured error if $WS unset.
fn _config_path() -> str {
    if WS.len() == 0 { return "" }
    return WS + "/hexa-lang/gate/wrappers/config.jsonl"
}

// ─── ai-native error helper ───────────────────────────────────────────
fn ai_err(code: str, what: str, fix: str, ssot: str) -> void {
    eprintln("[wrapper_cache/" + code + "] " + what)
    eprintln("  fix: " + fix)
    eprintln("  ssot: " + ssot)
}

// ─── internal: quick file-exists probe via builtin ────────────────────
fn _exists(p: str) -> bool {
    if p.len() == 0 { return false }
    return file_exists(p)
}

// ─── internal: epoch seconds ──────────────────────────────────────────
fn _epoch() -> str {
    return to_string(exec("date +%s")).trim()  // @allow-bare-exec
}

// ─── internal: file mtime (epoch seconds) or "0" ─────────────────────
fn _mtime(p: str) -> str {
    if _exists(p) == false { return "0" }
    let raw = to_string(exec("stat -f %m '" + p.replace("'", "'\\''") + "' 2>/dev/null")).trim()  // @allow-bare-exec
    if raw.len() == 0 { return "0" }
    return raw
}

// ─── internal: str → i64 with fallback ────────────────────────────────
fn _to_i64(s: str, fallback: i64) -> i64 {
    if s.len() == 0 { return fallback }
    let mut n: i64 = 0
    try { n = to_int(s) } catch e { return fallback }
    return n
}

// ═════════════════════════════════════════════════════════════════════
//  pub fn ag_load_config(key, fallback) -> str
//  JSONL shape: each line { "key": "...", "value": "..." }. Creates file
//  with "{}\n" default stub if absent. Uses jq for line scan.
// ═════════════════════════════════════════════════════════════════════
pub fn ag_load_config(key: str, fallback: str) -> str {
    let cfg = _config_path()
    if cfg.len() == 0 {
        ai_err("E_WS_UNSET",
               "$WS not set — cannot resolve wrappers/config.jsonl",
               "export WS=<repo-root> in shell rc or ~/.claude/settings.json env",
               "airgenome/rules/airgenome.json#AG10")
        return fallback
    }
    if _exists(cfg) == false {
        // Seed with a one-line default object — keeps future jq reads happy.
        try { write_file(cfg, "{}\n") } catch e {}
        return fallback
    }
    let key_sh = key.replace("'", "'\\''")
    let cfg_sh = cfg.replace("'", "'\\''")
    // Match lines where .key == key, print .value. Empty string means miss.
    let q = "jq -r --arg k '" + key_sh +
            "' 'select(.key==$k) | .value // empty' '" + cfg_sh +
            "' 2>/dev/null | head -1"
    let v = to_string(exec(q)).trim()  // @allow-bare-exec
    if v.len() == 0 { return fallback }
    return v
}

// ═════════════════════════════════════════════════════════════════════
//  pub fn ag_resolve_host() -> str
//  60s TTL cache at /tmp/ag_gate_reachable.state (HOST|PORT or NONE|PORT).
//  Probe order: remote_host:remote_port, tailscale_host:remote_port,
//  hetzner_host:remote_port.
// ═════════════════════════════════════════════════════════════════════
fn _nc_ok(host: str, port: str, wait_s: i64) -> bool {
    if host.len() == 0 || port.len() == 0 { return false }
    let h = host.replace("'", "'\\''")
    let p = port.replace("'", "'\\''")
    let cmd = "nc -z -w " + to_string(wait_s) + " '" + h + "' '" + p +
              "' >/dev/null 2>&1 && echo y || echo n"
    let r = to_string(exec(cmd)).trim()  // @allow-bare-exec
    return r == "y"
}

pub fn ag_resolve_host() -> str {
    let port = ag_load_config("remote_port", "22")

    // ── Cache hit path (TTL + port match) ────────────────────────────
    if _exists(REACH_CACHE) {
        let mt = _to_i64(_mtime(REACH_CACHE), 0)
        let nw = _to_i64(_epoch(), 0)
        let age = nw - mt
        if age >= 0 && age < REACH_TTL {
            let mut cached = ""
            try { cached = read_file(REACH_CACHE).trim() } catch e { cached = "" }
            if cached.len() > 0 {
                let bar = cached.index_of("|")
                if bar > 0 {
                    let ch = cached.substring(0, bar)
                    let cp = cached.substring(bar + 1, cached.len())
                    if cp == port {
                        if ch == "NONE" { return "" }
                        if ch.len() > 0 { return ch }
                    }
                }
            }
        }
    }

    // ── Live probe: ubu → tailscale → hetzner ────────────────────────
    let ubu = ag_load_config("remote_host", "")
    let ts  = ag_load_config("tailscale_host", "")
    let htz = ag_load_config("hetzner_host", "")

    let mut picked = ""
    if ubu.len() > 0 && _nc_ok(ubu, port, 1)      { picked = ubu }
    else if ts.len()  > 0 && _nc_ok(ts,  port, 2) { picked = ts }
    else if htz.len() > 0 && _nc_ok(htz, port, 2) { picked = htz }

    let payload = if picked.len() > 0 { picked + "|" + port } else { "NONE|" + port }
    try { write_file(REACH_CACHE, payload) } catch e {}
    return picked
}

// ═════════════════════════════════════════════════════════════════════
//  Budget counter — one line per live wrapper instance. v1 used $$ via
//  bash; in hexa we reconstruct our own pid via `exec("echo $$")` so the
//  semantic of "this process's row" survives the port.
// ═════════════════════════════════════════════════════════════════════
fn _my_pid() -> str {
    // echo $$ inside exec's subshell yields that subshell's pid (NOT the
    // interpreter's). Fall back to PPID env for a stable per-wrapper key
    // if echo $$ somehow returns empty.
    let sh_pid = to_string(exec("echo $$")).trim()  // @allow-bare-exec
    if sh_pid.len() > 0 { return sh_pid }
    let pp = env("PPID")
    if pp.len() > 0 { return pp }
    return "0"
}

pub fn ag_budget_enter() -> void {
    let pid = _my_pid()
    let mut cur = ""
    if _exists(BUDGET_FILE) {
        try { cur = read_file(BUDGET_FILE) } catch e { cur = "" }
    }
    let sep = if cur.len() == 0 || cur.ends_with("\n") { "" } else { "\n" }
    let nxt = cur + sep + pid + "\n"
    try { write_file(BUDGET_FILE, nxt) } catch e {
        ai_err("BUDGET-WRITE",
               "failed to append pid " + pid + " to " + BUDGET_FILE,
               "check /tmp permissions",
               "gate/wrappers/src/_cache.hexa:ag_budget_enter")
    }
}

pub fn ag_budget_leave() -> void {
    if _exists(BUDGET_FILE) == false { return }
    let pid = _my_pid()
    let mut body = ""
    try { body = read_file(BUDGET_FILE) } catch e { return }
    let lines = body.split("\n")
    let mut kept = ""
    let mut i = 0
    while i < lines.len() {
        let ln = to_string(lines[i]).trim()
        if ln.len() > 0 && ln != pid {
            kept = kept + ln + "\n"
        }
        i = i + 1
    }
    try { write_file(BUDGET_FILE, kept) } catch e {}
}

pub fn ag_budget_count() -> i64 {
    if _exists(BUDGET_FILE) == false { return 0 }
    let mut body = ""
    try { body = read_file(BUDGET_FILE) } catch e { return 0 }
    if body.len() == 0 { return 0 }
    let lines = body.split("\n")
    let mut n: i64 = 0
    let mut i = 0
    while i < lines.len() {
        if to_string(lines[i]).trim().len() > 0 { n = n + 1 }
        i = i + 1
    }
    return n
}

pub fn ag_budget_check() -> bool {
    let cap_s = ag_load_config("max_budget", "4")
    let cap = _to_i64(cap_s, 4)
    return ag_budget_count() < cap
}

// ═════════════════════════════════════════════════════════════════════
//  ag_filter_decide — phase-1 minimum viable (6 rules, no 11-layer).
//  Returns [target, reason]. target ∈ {local, ubu}. Reason is a short
//  tag matching v1's `_ag_reason_push` style for grep-ability.
// ═════════════════════════════════════════════════════════════════════

// Read a top-level string number field from session_now.json without a
// full json_parse pass — the file may be absent or partial during normal
// operation and we don't want that to poison the decide path.
fn _read_mac_load() -> str {
    if _exists(SESSION_NOW) == false { return "0" }
    let p_sh = SESSION_NOW.replace("'", "'\\''")
    // Try jq first; fall back to "0" on any error.
    let v = to_string(exec("jq -r '.load_avg // \"0\"' '" + p_sh + "' 2>/dev/null")).trim()  // @allow-bare-exec
    if v.len() == 0 || v == "null" { return "0" }
    return v
}

// Convert a float-ish string like "5.23" → integer hundredths (523).
// Avoids float ops (not all hexa builds route them the same) and lets
// us stay in integer space for the 5.0 threshold check.
fn _load_hundredths(s: str) -> i64 {
    let t = s.trim()
    if t.len() == 0 { return 0 }
    let dot = t.index_of(".")
    if dot < 0 {
        return _to_i64(t, 0) * 100
    }
    let whole = t.substring(0, dot)
    let mut frac = t.substring(dot + 1, t.len())
    // Pad / truncate to exactly 2 digits.
    if frac.len() > 2 { frac = frac.substring(0, 2) }
    while frac.len() < 2 { frac = frac + "0" }
    let w = _to_i64(whole, 0)
    let f = _to_i64(frac, 0)
    return w * 100 + f
}

pub fn ag_filter_decide(cmd: str, raw_args: str) -> [str] {
    // (cmd / raw_args are accepted for v1 parity + future 11-layer use;
    // phase-1 only keys on env + mac load.)
    let _c = cmd
    let _a = raw_args

    if env("CLAUDX_NO_SANDBOX") == "1" {
        return ["local", "sandbox-bypass"]
    }
    if env("AG_GATE_FORCE_LOCAL") == "1" {
        return ["local", "forced"]
    }
    if env("AG_GATE_FORCE_REMOTE") == "1" {
        return ["ubu", "forced"]
    }

    let ml_str = _read_mac_load()
    let ml100  = _load_hundredths(ml_str)
    if ml100 >= 500 {
        return ["ubu", "mac-hot"]
    }

    return ["local", "default"]
}

// ═════════════════════════════════════════════════════════════════════
//  ag_filter_record — append one JSONL row per dispatch for later replay.
// ═════════════════════════════════════════════════════════════════════
fn _jesc(s: str) -> str {
    // Minimal JSON string escaper — mirrors what post_bash.hexa does.
    let a = s.replace("\\", "\\\\")
    let b = a.replace("\"", "\\\"")
    let c = b.replace("\n", " ")
    let d = c.replace("\r", " ")
    return d.replace("\t", " ")
}

pub fn ag_filter_record(cmd: str, target: str, rc: i64, elapsed_s: i64) -> void {
    let ts = _epoch()
    let row = "{\"ts\":" + ts +
              ",\"cmd\":\""     + _jesc(cmd)    + "\"" +
              ",\"target\":\""  + _jesc(target) + "\"" +
              ",\"rc\":"        + to_string(rc) +
              ",\"elapsed\":"   + to_string(elapsed_s) + "}\n"
    let mut prev = ""
    if _exists(FILTER_LOG) {
        try { prev = read_file(FILTER_LOG) } catch e { prev = "" }
    }
    try { write_file(FILTER_LOG, prev + row) } catch e {
        ai_err("FILTER-WRITE",
               "failed to append row to " + FILTER_LOG,
               "check /tmp permissions or disk space",
               "gate/wrappers/src/_cache.hexa:ag_filter_record")
    }
}

// ═════════════════════════════════════════════════════════════════════
//  ag_gate_msg — debug banner, routed to stderr when AG_GATE_DEBUG=1.
// ═════════════════════════════════════════════════════════════════════
pub fn ag_gate_msg(target: str, text: str) -> void {
    if env("AG_GATE_DEBUG") == "1" {
        eprintln("[gate] " + target + " " + text)
    }
}

// ═════════════════════════════════════════════════════════════════════
//  Phase 2 — remote dispatch primitives (ssh / rsync / scp)
//
//  Hostname resolution fallback chain (v1 parity):
//     ssh_alias (default "ubu")  →  hetzner_host  →  ""
//  Caller decides what to do on empty return. v1 used "ubu" as the
//  canonical alias in ~/.ssh/config; hetzner is the WAN backup.
//
//  Shared ssh flags (v1 gate/wrappers/hexa L64, L86, L100):
//     -o BatchMode=yes          fail fast on auth prompt
//     -o ConnectTimeout=5       bounded wait
//     -o ServerAliveInterval=30 hold long rsync/scp open
//
//  Stamp files (v1 L26-28): /tmp/ag_gate_rsync.stamp  +
//     /tmp/ag_gate_scp_dedup/<basename>.mtime — reused so Phase 1 cache
//     state doesn't get invalidated by the port.
// ═════════════════════════════════════════════════════════════════════

let RSYNC_STAMP   = "/tmp/ag_gate_rsync.stamp"
let SCP_DEDUP_DIR = "/tmp/ag_gate_scp_dedup"

// Resolve the effective remote host. If `host` arg is non-empty, caller
// pinned the target → return as-is. Else walk the fallback chain.
fn _resolve_remote(host: str) -> str {
    if host.len() > 0 { return host }
    let alias = ag_load_config("ssh_alias", "ubu")
    if alias.len() > 0 { return alias }
    let htz = ag_load_config("hetzner_host", "")
    return htz
}

// Standard ssh flags used by all three fns — keeps v1 semantics.
fn _ssh_flags() -> str {
    return "-o BatchMode=yes -o ConnectTimeout=5 -o ServerAliveInterval=30"
}

// basename — last path segment. Avoids shelling out to `basename(1)`.
fn _basename(p: str) -> str {
    if p.len() == 0 { return "" }
    let mut last = 0
    let mut i = 0
    while i < p.len() {
        if p.substring(i, i + 1) == "/" { last = i + 1 }
        i = i + 1
    }
    return p.substring(last, p.len())
}

// Directory signature = `find <dir> -type f -exec stat -f %m {} +` piped
// through `cksum`. Cheap, stable, and captures any mtime change without
// needing a full manifest. Returns "" on failure (treat as "changed").
fn _dir_mtime_hash(d: str) -> str {
    if d.len() == 0 { return "" }
    let d_sh = d.replace("'", "'\\''")
    let cmd = "find '" + d_sh + "' -type f -exec stat -f %m {} + 2>/dev/null" +
              " | sort | cksum | awk '{print $1}'"
    let h = to_string(exec(cmd)).trim()  // @allow-bare-exec
    return h
}

// ═════════════════════════════════════════════════════════════════════
//  pub fn ag_remote_exec(host, cmd) -> [stdout_plus_stderr, rc_str]
//
//  v1 parity: ssh -o BatchMode=yes -o ConnectTimeout=5
//             -o ServerAliveInterval=30 <host> "<cmd>" 2>&1
//  Uses exec_with_status so we capture rc alongside the combined stream.
//  Caller prints — we return so chain callers (dispatcher) can parse.
//  Failure modes:
//     - unresolvable host (empty after fallback) → E_SSH_FAIL, rc "255"
//     - rc != 0 from remote                      → E_SSH_FAIL, rc passthrough
//     - ssh timeout / auth fail                  → rc 255 with hint
// ═════════════════════════════════════════════════════════════════════
pub fn ag_remote_exec(host: str, cmd: str) -> [str] {
    let h = _resolve_remote(host)
    if h.len() == 0 {
        ai_err("E_SSH_FAIL",
               "no reachable remote host (ssh_alias + hetzner_host both empty/down)",
               "fix: add ssh_alias to wrappers/config.jsonl, or `ssh ubu true` to verify",
               "gate/wrappers/src/_cache.hexa:ag_remote_exec")
        return ["", "255"]
    }
    let h_sh = h.replace("'", "'\\''")
    let cmd_sh = cmd.replace("'", "'\\''")
    let ssh_cmd = "ssh " + _ssh_flags() + " '" + h_sh + "' '" + cmd_sh + "' 2>&1"
    let r = exec_with_status(ssh_cmd)  // @allow-bare-exec
    let out = to_string(r[0])
    let rc: i64 = to_int(to_string(r[1]))
    if rc != 0 {
        ai_err("E_SSH_FAIL",
               "ssh to '" + h + "' exited rc=" + to_string(rc),
               "fix: " + ssh_cmd,
               "gate/wrappers/src/_cache.hexa:ag_remote_exec")
    }
    return [out, to_string(rc)]
}

// ═════════════════════════════════════════════════════════════════════
//  pub fn ag_rsync(host, local_src) -> rc
//
//  rsync -az --delete [--exclude-from=<src>/.gitignore] <src>/
//      <host>:/tmp/ag_gate/<basename>/
//  Skip-fast: compute dir mtime hash; if it equals the cached stamp,
//  return 0 (no-op). Otherwise rsync + update stamp on success.
//  Failure modes:
//     - src missing              → E_RSYNC_FAIL, rc 2
//     - unresolvable host        → E_RSYNC_FAIL, rc 255
//     - rsync rc != 0            → E_RSYNC_FAIL, rc passthrough
// ═════════════════════════════════════════════════════════════════════
pub fn ag_rsync(host: str, local_src: str) -> i64 {
    if _exists(local_src) == false {
        ai_err("E_RSYNC_FAIL",
               "local_src does not exist: " + local_src,
               "fix: verify path before call — `ls -ld '" + local_src + "'`",
               "gate/wrappers/src/_cache.hexa:ag_rsync")
        return 2
    }
    let h = _resolve_remote(host)
    if h.len() == 0 {
        ai_err("E_RSYNC_FAIL",
               "no reachable remote host for rsync",
               "fix: add ssh_alias to wrappers/config.jsonl, or `ssh ubu true` to verify",
               "gate/wrappers/src/_cache.hexa:ag_rsync")
        return 255
    }

    let bn = _basename(local_src)
    let sig_key = local_src + "|" + bn
    let cur_hash = _dir_mtime_hash(local_src)

    // Stamp payload format: "<sig_key>\t<hash>\n". Skip only on exact match.
    if _exists(RSYNC_STAMP) && cur_hash.len() > 0 {
        let mut prev = ""
        try { prev = read_file(RSYNC_STAMP) } catch e { prev = "" }
        let want = sig_key + "\t" + cur_hash
        let lines = prev.split("\n")
        let mut i = 0
        while i < lines.len() {
            if to_string(lines[i]).trim() == want { return 0 }
            i = i + 1
        }
    }

    // Build rsync cmd. --exclude-from is only added when .gitignore exists.
    let gi = local_src + "/.gitignore"
    let mut excl = ""
    if _exists(gi) {
        excl = " --exclude-from='" + gi.replace("'", "'\\''") + "'"
    }
    let src_sh  = local_src.replace("'", "'\\''")
    let h_sh    = h.replace("'", "'\\''")
    let bn_sh   = bn.replace("'", "'\\''")
    let dest    = "/tmp/ag_gate/" + bn_sh + "/"
    // Ensure remote parent exists (rsync -a creates the trailing dir).
    let mk_cmd  = "ssh " + _ssh_flags() + " '" + h_sh + "' 'mkdir -p " + dest + "' 2>&1"
    let _mk = exec_with_status(mk_cmd)  // @allow-bare-exec

    let rsync_cmd = "rsync -az --delete" + excl +
                    " -e 'ssh " + _ssh_flags() + "'" +
                    " '" + src_sh + "/' '" + h_sh + ":" + dest + "' 2>&1"
    let r = exec_with_status(rsync_cmd)  // @allow-bare-exec
    let rc: i64 = to_int(to_string(r[1]))
    if rc != 0 {
        ai_err("E_RSYNC_FAIL",
               "rsync to '" + h + ":" + dest + "' rc=" + to_string(rc),
               "fix: " + rsync_cmd,
               "gate/wrappers/src/_cache.hexa:ag_rsync")
        return rc
    }

    // Update stamp (append-or-replace policy: simple rewrite keeps latest
    // hash per sig_key, trims stale entries by keeping only non-matching
    // prior rows unchanged).
    let mut prev = ""
    if _exists(RSYNC_STAMP) {
        try { prev = read_file(RSYNC_STAMP) } catch e { prev = "" }
    }
    let mut kept = ""
    let prior = prev.split("\n")
    let mut j = 0
    while j < prior.len() {
        let ln = to_string(prior[j])
        if ln.len() > 0 && ln.starts_with(sig_key + "\t") == false {
            kept = kept + ln + "\n"
        }
        j = j + 1
    }
    kept = kept + sig_key + "\t" + cur_hash + "\n"
    try { write_file(RSYNC_STAMP, kept) } catch e {}
    return 0
}

// ═════════════════════════════════════════════════════════════════════
//  pub fn ag_scp_files(host, files) -> rc
//
//  For each file: compare local mtime to cached stamp at
//  /tmp/ag_gate_scp_dedup/<basename>.mtime. If equal → skip. Else scp
//  into <host>:/tmp/ag_gate/files/ and refresh stamp.
//  Returns 0 if every file either skipped or copied OK; otherwise the
//  first non-zero rc encountered.
//  Failure modes:
//     - unresolvable host        → E_SCP_FAIL, rc 255
//     - missing local file       → E_SCP_FAIL, rc 2 (continues list)
//     - scp rc != 0              → E_SCP_FAIL, rc passthrough
// ═════════════════════════════════════════════════════════════════════
pub fn ag_scp_files(host: str, files: [str]) -> i64 {
    if files.len() == 0 { return 0 }
    let h = _resolve_remote(host)
    if h.len() == 0 {
        ai_err("E_SCP_FAIL",
               "no reachable remote host for scp",
               "fix: add ssh_alias to wrappers/config.jsonl, or `ssh ubu true` to verify",
               "gate/wrappers/src/_cache.hexa:ag_scp_files")
        return 255
    }

    // Make sure dedup dir + remote dest exist up front — once per call.
    let _mkl = exec_with_status("mkdir -p '" + SCP_DEDUP_DIR + "' 2>/dev/null")  // @allow-bare-exec
    let h_sh = h.replace("'", "'\\''")
    let dest = "/tmp/ag_gate/files/"
    let mk_remote = "ssh " + _ssh_flags() + " '" + h_sh + "' 'mkdir -p " + dest + "' 2>&1"
    let _mkr = exec_with_status(mk_remote)  // @allow-bare-exec

    let mut first_err: i64 = 0
    let mut i = 0
    while i < files.len() {
        let f = to_string(files[i])
        i = i + 1
        if _exists(f) == false {
            ai_err("E_SCP_FAIL",
                   "local file missing: " + f,
                   "fix: verify path before call — `ls -l '" + f + "'`",
                   "gate/wrappers/src/_cache.hexa:ag_scp_files")
            if first_err == 0 { first_err = 2 }
            continue
        }

        let bn = _basename(f)
        let mt = _mtime(f)
        let stamp = SCP_DEDUP_DIR + "/" + bn + ".mtime"
        let mut cached = "0"
        if _exists(stamp) {
            try { cached = read_file(stamp).trim() } catch e { cached = "0" }
        }
        if mt == cached && mt != "0" {
            // skip — remote already has same mtime.
            continue
        }

        let f_sh  = f.replace("'", "'\\''")
        let scp_cmd = "scp -q -o BatchMode=yes -o ConnectTimeout=5" +
                      " -o ServerAliveInterval=30" +
                      " '" + f_sh + "' '" + h_sh + ":" + dest + "' 2>&1"
        let r = exec_with_status(scp_cmd)  // @allow-bare-exec
        let rc: i64 = to_int(to_string(r[1]))
        if rc != 0 {
            ai_err("E_SCP_FAIL",
                   "scp '" + bn + "' to '" + h + ":" + dest + "' rc=" + to_string(rc),
                   "fix: " + scp_cmd,
                   "gate/wrappers/src/_cache.hexa:ag_scp_files")
            if first_err == 0 { first_err = rc }
            continue
        }
        try { write_file(stamp, mt) } catch e {}
    }
    return first_err
}
