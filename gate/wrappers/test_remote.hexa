#!hexa lax
// gate/wrappers/test_remote.hexa — Phase-2 remote-dispatch smoke harness.
// @allow-bare-exec
//
// Checks:
//   1. $WS is exported + ag_resolve_host() returns a non-empty target.
//      (If either is missing, skip the whole suite with rc 0.)
//   2. AG_GATE_FORCE_REMOTE=1 + wrapper bin invocations for each of the
//      five wrappers; we match expected substrings in the combined
//      stdout/stderr capture.
//
// Failure rows use ai_err style: `[test_remote/FAIL-<case>] ...` on stderr.
// Exit code: 0 if all five pass (or suite skipped), 1 otherwise.
//
// Ref: README.md#Status + src/_cache.hexa for ag_resolve_host.

use "src/_cache"

let WS = env("WS")
let BIN = WS + "/hexa-lang/gate/wrappers/bin"

fn ai_err(case_: str, msg: str) {
    eprintln("[test_remote/FAIL-" + case_ + "] " + msg)
}

// Run `cmd` with AG_GATE_FORCE_REMOTE=1, return [out, rc_str].
fn run_wrap(cmd: str) {
    let full = "AG_GATE_FORCE_REMOTE=1 " + cmd + " 2>&1"
    let r = exec_with_status(full)
    return [to_string(r[0]), to_string(r[1])]
}

// One test: invoke `cmd`, check `needle` appears in the output.
// Returns 1 on pass, 0 on fail (matches the "PASS counter" idiom).
fn check(case_: str, cmd: str, needle: str) {
    let r = run_wrap(cmd)
    let out = r[0]
    let rc  = r[1]
    if out.index_of(needle) >= 0 {
        println("[PASS] " + case_ + " — matched '" + needle + "'")
        return 1
    }
    ai_err(case_, "cmd=[" + cmd + "] rc=" + rc + " missing '" + needle +
                  "' in output (first 200 chars): " + out.substring(0, 200))
    return 0
}

fn main() {
    // ── Guard: $WS + reachable host ─────────────────────────────────
    if WS.len() == 0 {
        println("[test_remote] SKIP — $WS not set (run `export WS=$HOME/core`)")
        return 0
    }
    let host = ag_resolve_host()
    if host.len() == 0 {
        println("[test_remote] SKIP — ag_resolve_host() returned '' (no remote reachable)")
        return 0
    }
    println("[test_remote] host=" + host + " bin=" + BIN)

    // ── Prepare python3 fixture (avoid -c fast-path) ────────────────
    let py_tmp = "/tmp/ag_test_99.py"
    try { write_file(py_tmp, "print(99)\n") } catch e {
        ai_err("setup", "could not write " + py_tmp)
        return 1
    }

    // ── Run 5 cases ─────────────────────────────────────────────────
    let mut passed = 0

    // 1. cargo --version — expect "cargo 1."
    passed = passed + check("cargo",
                            "'" + BIN + "/cargo' --version",
                            "cargo 1.")

    // 2. rustc --version — expect "rustc 1."
    passed = passed + check("rustc",
                            "'" + BIN + "/rustc' --version",
                            "rustc 1.")

    // 3. python3 <tmpscript.py> — NOT the -c fast-path, triggers scp.
    passed = passed + check("python3",
                            "'" + BIN + "/python3' '" + py_tmp + "'",
                            "99")

    // 4. sh-run -c 'echo 99' — direct ag_remote_exec, no file copy.
    passed = passed + check("sh-run",
                            "'" + BIN + "/sh-run' -c 'echo 99'",
                            "99")

    // 5. hexa --version — short-circuit flag; expect "hexa " prefix.
    passed = passed + check("hexa",
                            "'" + BIN + "/hexa' --version",
                            "hexa ")

    // ── Summary ─────────────────────────────────────────────────────
    println("wrappers smoke: " + to_string(passed) + "/5 PASS")
    if passed == 5 { return 0 }
    return 1
}

main()
