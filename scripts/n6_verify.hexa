// n6_verify.hexa — ported from scripts/n6_verify.sh
// NEXUS-6 based n=6 constant auto-verification
// Usage: hexa scripts/n6_verify.hexa [--strict]
// Can be called from pre-commit hook

let project_root = exec("cd \"$(dirname \"$0\")/..\" && pwd").trim()
let n6 = env("HOME") + "/Dev/n6-architecture/tools/nexus/target/release/nexus"
let strict = args(1) ?? ""
let mut errors = 0
let mut warnings = 0

// Colors
let red = "\x1b[0;31m"
let green = "\x1b[0;32m"
let yellow = "\x1b[1;33m"
let cyan = "\x1b[0;36m"
let nc = "\x1b[0m"

print(cyan + "╔══════════════════════════════════════════════╗" + nc)
print(cyan + "║  NEXUS-6 x HEXA-LANG n=6 constant verify    ║" + nc)
print(cyan + "╚══════════════════════════════════════════════╝" + nc)
print("")

// === Count extraction functions ===

fn count_keywords() {
    return exec("grep -cE '^\\s+\"[a-z]+\" => Some\\(Token::' " + project_root + "/src/token.rs").trim()
}

fn count_keyword_groups() {
    return exec("grep -A200 'pub fn keyword_from_str' " + project_root + "/src/token.rs | grep -cE '// Group [0-9]+:'").trim()
}

fn count_binop() {
    return exec("grep -A50 'pub enum BinOp' " + project_root + "/src/ast.rs | sed '/^}$/q' | grep -oE '\\b[A-Z][a-z]\\w*' | wc -l | tr -d ' '").trim()
}

fn count_unaryop() {
    return exec("grep 'pub enum UnaryOp' " + project_root + "/src/ast.rs | grep -oE '\\b[A-Z][a-z]\\w*' | grep -v UnaryOp | wc -l | tr -d ' '").trim()
}

fn count_expr() {
    return exec("grep -A200 'pub enum Expr' " + project_root + "/src/ast.rs | sed '/^}$/q' | grep -cE '^\\s+\\w+' || echo 0").trim()
}

fn count_stmt() {
    return exec("grep -A200 'pub enum Stmt' " + project_root + "/src/ast.rs | sed '/^}$/q' | grep -cE '^\\s+\\w+' || echo 0").trim()
}

fn count_primitives() {
    return exec("grep -A20 'pub enum PrimitiveType' " + project_root + "/src/types.rs | sed '/^}/q' | grep -cE '^\\s+\\w+,' || echo 0").trim()
}

fn count_type_layers() {
    return exec("grep -cE '// Layer [0-9]+:' " + project_root + "/src/types.rs").trim()
}

fn count_visibility() {
    return exec("grep -A10 'pub enum Visibility' " + project_root + "/src/ast.rs | sed '/^}/q' | grep -cE '^\\s+\\w+,' || echo 0").trim()
}

fn count_ast_enums() {
    return exec("grep -c '^pub enum' " + project_root + "/src/ast.rs").trim()
}

fn count_source_files() {
    return exec("ls " + project_root + "/src/*.rs | wc -l | tr -d ' '").trim()
}

fn count_examples() {
    return exec("ls " + project_root + "/examples/*.hexa | wc -l | tr -d ' '").trim()
}

fn count_modules() {
    return exec("grep -c '^mod ' " + project_root + "/src/main.rs").trim()
}

fn count_opt_passes() {
    let mut count = 0
    let passes = ["dce.rs", "loop_unroll.rs", "escape_analysis.rs", "inline_cache.rs", "simd_hint.rs", "pgo.rs"]
    for f in passes {
        if file_exists(project_root + "/src/" + f) {
            count = count + 1
        }
    }
    return str(count)
}

fn count_stdlib() {
    return exec("ls " + project_root + "/src/std_*.rs 2>/dev/null | wc -l | tr -d ' '").trim()
}

// === Verify function ===

fn verify(name, actual_str, expected, formula) {
    let actual = int(actual_str)
    if actual == expected {
        print("  " + green + "OK" + nc + " " + name + ": " + str(actual) + " = " + formula + " = " + str(expected))
    } else {
        let diff = actual - expected
        if strict == "--strict" {
            print("  " + red + "FAIL" + nc + " " + name + ": " + str(actual) + " != " + formula + " = " + str(expected) + " (drift: " + str(diff) + ")")
            errors = errors + 1
        } else {
            print("  " + yellow + "WARN" + nc + " " + name + ": " + str(actual) + " != " + formula + " = " + str(expected) + " (drift: " + str(diff) + ")")
            warnings = warnings + 1
        }
    }
}

// === Execution ===

print(cyan + "[1/4] Design constants (EXACT required)" + nc)
let kw_groups = count_keyword_groups()
let primitives = count_primitives()
let type_layers = count_type_layers()
let visibility = count_visibility()
let opt_passes = count_opt_passes()
let ast_enums = count_ast_enums()

verify("Keyword groups",  kw_groups,  12, "sigma(6)")
verify("Primitive types", primitives, 8,  "sigma-tau")
verify("Type layers",     type_layers, 4, "tau(6)")
verify("Visibility",      visibility, 4,  "tau(6)")
verify("Opt passes",      opt_passes, 6,  "n")
verify("AST enums",       ast_enums,  12, "sigma(6)")

print("")
print(cyan + "[2/4] Operators (design)" + nc)
let binop = count_binop()
let unaryop = count_unaryop()
let total_ops = int(binop) + int(unaryop)
verify("Total operators", str(total_ops), 26, "BinOp(22->23)+Unary(3)")

print("")
print(cyan + "[3/4] Emergent constants (monitoring)" + nc)
let keywords = count_keywords()
let expr = count_expr()
let stmt = count_stmt()
let expr_stmt_diff = int(stmt) - int(expr)
let src_files = count_source_files()
let examples = count_examples()
let modules = count_modules()
let stdlib = count_stdlib()

verify("|Stmt-Expr|",    str(expr_stmt_diff), 8,  "sigma-tau")
verify("Stdlib modules", stdlib,              12, "sigma(6)")

print("")
print(cyan + "[4/4] NEXUS-6 remote verification" + nc)
if file_exists(n6) {
    for val in [12, 8, 4, 6, 24] {
        let result = exec(n6 + " verify " + str(val) + " 2>&1 | grep 'Match:' | awk '{print $NF}'").trim()
        if result == "(EXACT)" {
            print("  " + green + "OK" + nc + " nexus verify " + str(val) + ": EXACT")
        } else {
            print("  " + yellow + "WARN" + nc + " nexus verify " + str(val) + ": " + result)
        }
    }
} else {
    print("  " + yellow + "WARN" + nc + " NEXUS-6 binary not found: " + n6)
}

// === Summary ===
print("")
print(cyan + "==============================================" + nc)

let total_checks = errors + warnings
let exact_count = 6 + 2 - errors

if errors == 0 {
    print(green + "  OK n=6 consistency verification passed" + nc)
    print("  EXACT: " + str(exact_count) + " | WARNINGS: " + str(warnings) + " | ERRORS: 0")
    print("  Keywords: " + keywords + " | Expr: " + expr + " | Stmt: " + stmt)
    print("  Modules: " + modules + " | Examples: " + examples + " | Stdlib: " + stdlib)
    exit(0)
} else {
    print(red + "  FAIL n=6 consistency violation: " + str(errors) + " errors" + nc)
    print("  --strict mode blocks commit")
    exit(1)
}
