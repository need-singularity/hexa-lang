// install_stage0_shim.hexa — (re)install the build/hexa_stage0 bash shim
//
// WHY (2026-04-18): rebuild_stage0.hexa (and the underlying clang in
// build_stage0.hexa) overwrites build/hexa_stage0 with a fresh Mach-O
// native binary. That removes the layered-defense shim introduced in
// commit ca46279 (flock + RSS cap + jetsam — the defense against the
// 2026-04-18 13:22 Mac panic / 16:23 load=376 / compressor 12.72 GB).
//
// This module is called by rebuild_stage0.hexa and build_stage0.hexa
// immediately after a successful build (post sanity-check). It:
//
//   1. Confirms build/hexa_stage0 is currently a Mach-O (fresh build)
//      — if it is already the bash shim, we have nothing to do.
//   2. Moves that Mach-O to build/hexa_stage0.real (overwrites any
//      stale .real; the pre-rebuild binary is backed up separately by
//      rebuild_stage0's pid-scoped backup file).
//   3. Restores the tracked bash shim from `git show HEAD:build/hexa_stage0`
//      into build/hexa_stage0 and marks it executable. Using the git
//      index as the SSOT keeps the shim in lockstep with whatever is
//      committed, rather than duplicating its text here. If the git path
//      is unavailable (detached checkout / submodule / worktree edge
//      cases), falls back to a minimal fallback shim written below.
//   4. On Darwin, codesigns the new .real — the stage0 binary needs
//      ad-hoc signing (AppleSystemPolicy SIGKILL) and moving it already
//      revoked any prior signature.
//
// Usage — called as a library from other .hexa scripts:
//   use "install_stage0_shim"   (or hexa stdlib-style include)
//   install_stage0_shim(hexa_dir, uname)
//
// Usage — direct CLI (debug/repair):
//   ./hexa scripts/install_stage0_shim.hexa
//     → resolves hexa_dir from argv[1]'s parent and runs install.
//
// Idempotent: safe to call repeatedly. If build/hexa_stage0 is already
// the shim (bash script), no-op. If build/hexa_stage0 is missing, logs
// and exits 0 (nothing to shim).
//
// Opt-out — HEXA_SKIP_SHIM=1 env skips reinstall (emergency raw binary).

fn iss_is_shim(path) {
    // Shim is a bash script; Mach-O starts with 0xCF,0xFA,0xED,0xFE (arm64)
    // or 0xFE,0xED,0xFA,0xCE (ppc) etc. ELF is 0x7F 0x45 0x4C 0x46.
    // Cheapest check: `file` output contains "script" or "text".
    let out = exec("file -b " + path + " 2>/dev/null").trim()
    if out.contains("script") { return true }
    if out.contains("text") { return true }
    return false
}

fn iss_fallback_shim_content() {
    // Minimal fallback when git SSOT is unreachable. Implements layer 1
    // (mkdir lock) + layer 2 (safe_hexa_launchd re-entry) equivalent to
    // build/hexa_stage0 in commit ca46279. Kept short for readability; the
    // canonical copy is in git.
    "#!/bin/bash\n" +
    "# hexa_stage0 shim (fallback) — serialize + RSS cap\n" +
    "set -u\n" +
    "DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n" +
    "# 2026-04-18: REAL resolution — SSOT absolute path preferred over $DIR-relative.\n" +
    "# Override via HEXA_STAGE0_REAL env. Falls back to $DIR/hexa_stage0.real for\n" +
    "# Dev checkout where SSOT layout (.hx/packages) is absent.\n" +
    "if [ -n \"${HEXA_STAGE0_REAL:-}\" ] && [ -x \"$HEXA_STAGE0_REAL\" ]; then\n" +
    "    REAL=\"$HEXA_STAGE0_REAL\"\n" +
    "elif [ -x \"/Users/ghost/.hx/packages/hexa/build/hexa_stage0.real\" ]; then\n" +
    "    REAL=\"/Users/ghost/.hx/packages/hexa/build/hexa_stage0.real\"\n" +
    "else\n" +
    "    REAL=\"$DIR/hexa_stage0.real\"\n" +
    "fi\n" +
    "WRAPPER=\"$HOME/Dev/nexus/shared/harness/safe_hexa_launchd.sh\"\n" +
    "LOCKDIR=\"/tmp/hexa_stage0.lock.d\"\n" +
    "LOCK_WAIT_SECS=\"${HEXA_STAGE0_LOCK_WAIT:-300}\"\n" +
    "if [ \"${HEXA_LOCAL_NO_CAP:-}\" = \"1\" ] || [ \"${HEXA_LOCAL:-}\" = \"1\" ] || [ \"${HEXA_STAGE0_NO_CAP:-}\" = \"1\" ]; then exec \"$REAL\" \"$@\"; fi\n" +
    "if [ \"${HEXA_NO_LAUNCHD:-}\" = \"1\" ]; then exec \"$REAL\" \"$@\"; fi\n" +
    "acquire_lock() {\n" +
    "    local deadline=$(( $(date +%s) + LOCK_WAIT_SECS ))\n" +
    "    while true; do\n" +
    "        if mkdir \"$LOCKDIR\" 2>/dev/null; then echo \"$$\" > \"$LOCKDIR/pid\" 2>/dev/null || true; return 0; fi\n" +
    "        if [ -r \"$LOCKDIR/pid\" ]; then\n" +
    "            local holder; holder=$(cat \"$LOCKDIR/pid\" 2>/dev/null)\n" +
    "            if [ -n \"$holder\" ] && ! kill -0 \"$holder\" 2>/dev/null; then rm -rf \"$LOCKDIR\" 2>/dev/null; continue; fi\n" +
    "        fi\n" +
    "        if [ \"$(date +%s)\" -ge \"$deadline\" ]; then echo \"hexa_stage0 shim: lock timeout\" >&2; return 1; fi\n" +
    "        sleep 0.5\n" +
    "    done\n" +
    "}\n" +
    "release_lock() { if [ -r \"$LOCKDIR/pid\" ] && [ \"$(cat \"$LOCKDIR/pid\" 2>/dev/null)\" = \"$$\" ]; then rm -rf \"$LOCKDIR\" 2>/dev/null; fi; }\n" +
    "trap release_lock EXIT INT TERM\n" +
    "if ! acquire_lock; then exit 75; fi\n" +
    "if [ ! -x \"$WRAPPER\" ]; then exec \"$REAL\" \"$@\"; fi\n" +
    "HEXA_BIN=\"$REAL\" \"$WRAPPER\" \"$@\"\n" +
    "exit $?\n"
}

// Core entry. hexa_dir = root of hexa-lang checkout. uname = "Darwin"/"Linux"/etc.
fn install_stage0_shim(hexa_dir, uname) {
    if env("HEXA_SKIP_SHIM") != "" {
        println("[install_stage0_shim] HEXA_SKIP_SHIM=1 -> skip")
        return
    }
    let out = hexa_dir + "/build/hexa_stage0"
    let real = hexa_dir + "/build/hexa_stage0.real"

    let out_check = exec_with_status("test -e " + out)
    if out_check[1] != 0 {
        println("[install_stage0_shim] build/hexa_stage0 absent — nothing to do")
        return
    }

    if iss_is_shim(out) {
        println("[install_stage0_shim] already shim — no-op")
        return
    }

    // Move fresh Mach-O / ELF to .real
    let mv_result = exec_with_status("mv -f " + out + " " + real)
    if mv_result[1] != 0 {
        eprintln("[install_stage0_shim] mv " + out + " -> " + real + " FAILED")
        exit(1)
    }

    // Darwin: codesign .real before shim starts invoking it.
    if uname == "Darwin" {
        let cs = exec_with_status("command -v codesign >/dev/null 2>&1")
        if cs[1] == 0 {
            exec_with_status("codesign --force --sign - " + real + " 2>/dev/null")
        }
    }

    // Restore shim from git SSOT. Must run from inside the repo.
    let git_check = exec_with_status("cd " + hexa_dir + " && git rev-parse --show-toplevel >/dev/null 2>&1")
    let mut restored = false
    if git_check[1] == 0 {
        let restore = exec_with_status("cd " + hexa_dir + " && git show HEAD:build/hexa_stage0 > " + out + " 2>/dev/null")
        if restore[1] == 0 {
            let sz = to_int(exec("wc -c < " + out + " | tr -d ' '").trim())
            // Shim is small (<20KB) but non-empty (>500B).
            if sz > 500 && sz < 20000 {
                restored = true
            } else {
                eprintln("[install_stage0_shim] git shim restore size suspicious (" + str(sz) + ") — falling back")
            }
        } else {
            eprintln("[install_stage0_shim] git show HEAD:build/hexa_stage0 failed — falling back")
        }
    } else {
        eprintln("[install_stage0_shim] not a git checkout — using fallback shim content")
    }

    if !restored {
        write_file(out, iss_fallback_shim_content())
    }

    exec("chmod +x " + out)
    let final_check = exec_with_status("test -x " + out + " && test -x " + real)
    if final_check[1] != 0 {
        eprintln("[install_stage0_shim] post-install check FAILED (out/real missing or not executable)")
        exit(1)
    }
    let real_size = exec("wc -c < " + real + " | tr -d ' '").trim()
    let shim_size = exec("wc -c < " + out + " | tr -d ' '").trim()
    println("[install_stage0_shim] OK — shim=" + shim_size + "B wrapping real=" + real_size + "B")
}

// ── CLI entry ─────────────────────────────────────────────────
// Always runs when this file is executed as a script (the only intended
// usage — rebuild_stage0.hexa and build_stage0.hexa invoke it via a
// `./hexa scripts/install_stage0_shim.hexa` subprocess so their own
// flatten pipeline stays untouched).

let _av = argv()
let script_path = _av[1]
let hexa_dir = exec("cd \"$(dirname '" + script_path + "')/../\" && pwd").trim()
let uname = exec("uname 2>/dev/null | tr -d ' \\n\\t'").trim()
install_stage0_shim(hexa_dir, uname)
