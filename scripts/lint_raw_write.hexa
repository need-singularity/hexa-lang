// scripts/lint_raw_write.hexa — report-only scanner for direct write_file()
// calls across the repo.  Complements Layer 1 (self/stdlib/law_io.hexa):
// every raw `write_file(` outside law_io.hexa itself is a candidate for
// migration to `safe_write_file`.
//
// Exit code: always 0 (report-only — future Layer 2 may promote to block).
//
// Usage:
//   hexa scripts/lint_raw_write.hexa
//
// Design note: we delegate the walk+match to a single `grep -rn` call so
// the interpreter never has to load thousands of .hexa files into VM
// memory — feedback_interp_push_quadratic ate 10GB on an in-process walk.
// The grep output is a small filtered subset (typically <1KB per repo),
// so parsing it is O(hits), not O(files).

fn collect() -> string {
    // Single-line shell pipeline — hexa parser dislikes multi-line string concat
    // on some stage0 builds, so we keep `cmd` on one physical line.
    let cmd = "grep -rnE 'write_file\\(' --include='*.hexa' --exclude-dir=build --exclude-dir=.git self scripts tests bench 2>/dev/null | grep -v safe_write_file | grep -v hexa_write_file | grep -v 'self/stdlib/law_io.hexa' | grep -vE '^[^:]+:[0-9]+:[[:space:]]*//'"
    try { return exec(cmd) } catch e { return "" }
}

fn main() {
    let out = collect()
    if out.trim() == "" {
        println("lint_raw_write: CLEAN — 0 direct write_file() call sites")
        return
    }
    let lines = out.split("\n")
    let mut count = 0
    let mut i = 0
    while i < len(lines) {
        if lines[i].trim() != "" { count = count + 1 }
        i = i + 1
    }
    println("lint_raw_write: " + to_string(count) + " direct write_file() call sites (report-only)")
    println("  → migrate to self/stdlib/law_io.safe_write_file when Layer 2 lands")
    println("")
    println(out)
}
