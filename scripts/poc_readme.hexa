// scripts/poc_readme.hexa
//
// Auto-generates self/poc/README.md from the filesystem layout.
//   self/poc/expr/<snake>.hexa     @kinds X[, Y]  → poc_ex_<snake>
//   self/poc/stmt/<snake>.hexa     @kinds X[, Y]  → poc_st_<snake>
//   self/poc/builtin/<snake>.hexa  @name X[, Y] | @method X → poc_bi_<snake>
//
// Usage:  hexa scripts/poc_readme.hexa
// Output: self/poc/README.md  (overwritten in place)

let CATS = [["expr", "ex"], ["stmt", "st"], ["builtin", "bi"]]

fn strip(s) {
    let mut i = 0
    while i < len(s) && (s[i] == " " || s[i] == "\t") { i = i + 1 }
    let mut j = len(s) - 1
    while j >= i && (s[j] == " " || s[j] == "\t" || s[j] == "\r" || s[j] == "\n") { j = j - 1 }
    let mut out = ""
    let mut k = i
    while k <= j { out = out + s[k]; k = k + 1 }
    return out
}

fn list_dir_hexa(dir) {
    let raw = exec("ls " + dir + "/*.hexa 2>/dev/null")
    if raw == "" { return [] }
    let lines = raw.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let s = strip(lines[i])
        if s != "" { out = out.push(s) }
        i = i + 1
    }
    return out
}

fn basename_noext(path) {
    let mut last = -1
    let mut i = 0
    while i < len(path) { if path[i] == "/" { last = i } ; i = i + 1 }
    let start = last + 1
    let mut out = ""
    let mut k = start
    while k < len(path) { out = out + path[k]; k = k + 1 }
    if len(out) > 5 {
        let n = len(out)
        let dot = out[n - 5]
        if dot == "." {
            let mut m = ""
            let mut q = 0
            while q < n - 5 { m = m + out[q]; q = q + 1 }
            return m
        }
    }
    return out
}

fn basename(path) {
    let mut last = -1
    let mut i = 0
    while i < len(path) { if path[i] == "/" { last = i } ; i = i + 1 }
    let start = last + 1
    let mut out = ""
    let mut k = start
    while k < len(path) { out = out + path[k]; k = k + 1 }
    return out
}

fn annot_val(line, tag) {
    let prefix = "// @" + tag
    if !line.starts_with(prefix) { return "" }
    let mut i = len(prefix)
    while i < len(line) && (line[i] == " " || line[i] == "\t") { i = i + 1 }
    let mut out = ""
    while i < len(line) { out = out + line[i]; i = i + 1 }
    return strip(out)
}

fn split_by_comma(s) {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        if s[i] == "," { out = out.push(strip(cur)); cur = "" } else { cur = cur + s[i] }
        i = i + 1
    }
    let last = strip(cur)
    if last != "" { out = out.push(last) }
    return out
}

// Read line-2 annotation; returns [tag, value] where tag ∈ {"kinds","name","method",""}.
fn read_annot(path, cat) {
    let src = read_file(path)
    if src == "" { return ["", ""] }
    let lines = src.split("\n")
    let mut i = 1
    while i < len(lines) && i < 5 {
        let s = strip(lines[i])
        if s != "" {
            if cat == "builtin" {
                let n = annot_val(s, "name")
                if n != "" { return ["name", n] }
                let m = annot_val(s, "method")
                if m != "" { return ["method", m] }
            } else {
                let v = annot_val(s, "kinds")
                if v != "" { return ["kinds", v] }
            }
        }
        i = i + 1
    }
    return ["", ""]
}

// Skip helper files: _*.hexa (dispatcher, common) and *_test.hexa.
fn is_handler_file(path) {
    let name = basename(path)
    if len(name) == 0 { return false }
    if name[0] == "_" { return false }
    // *_test.hexa
    let n = len(name)
    if n > 10 {
        // last 10 chars should equal "_test.hexa"
        let suf = "_test.hexa"
        let mut k = 0
        let mut ok = true
        while k < 10 {
            if name[n - 10 + k] != suf[k] { ok = false; break }
            k = k + 1
        }
        if ok { return false }
    }
    return true
}

fn main() {
    let mut out = "# self/poc/ — modular native POC\n\n"
    out = out + "AUTO-GENERATED by `scripts/poc_readme.hexa`. Do not hand-edit.\n\n"
    out = out + "## Convention\n"
    out = out + "- `self/poc/<cat>/<snake>.hexa` → `fn poc_<cat2>_<snake>(...)`\n"
    out = out + "  - `expr` → `ex`, `stmt` → `st`, `builtin` → `bi`\n"
    out = out + "- Line 2 annotation: `@kinds X[, Y]` (expr/stmt) or `@name X` / `@method X` (builtin)\n"
    out = out + "- Add a handler = new file, run `hexa scripts/poc_gen_dispatch.hexa`.\n"
    out = out + "- Verify convention: `hexa scripts/poc_lint.hexa`.\n\n"
    out = out + "## Handlers\n\n"

    let mut c = 0
    while c < len(CATS) {
        let cat = CATS[c][0]
        let prefix = CATS[c][1]
        let dir = "self/poc/" + cat
        let all_files = list_dir_hexa(dir)

        // Filter handler files.
        let mut files = []
        let mut fi = 0
        while fi < len(all_files) {
            if is_handler_file(all_files[fi]) { files = files.push(all_files[fi]) }
            fi = fi + 1
        }

        // Collect rows: [filename, annotation_display, fn_name, is_method_bool_as_int]
        let mut rows = []
        let mut total_kinds = 0
        let mut total_names = 0
        let mut total_methods = 0
        let mut gi = 0
        while gi < len(files) {
            let path = files[gi]
            let base = basename_noext(path)
            let fname = basename(path)
            let fn_name = "poc_" + prefix + "_" + base
            let r = read_annot(path, cat)
            let tag = r[0]
            let val = r[1]
            let mut display = val
            let mut is_method = 0
            if tag == "method" {
                display = "(method " + val + ")"
                is_method = 1
                total_methods = total_methods + 1
            } else if tag == "name" {
                let keys = split_by_comma(val)
                total_names = total_names + len(keys)
            } else if tag == "kinds" {
                let keys = split_by_comma(val)
                total_kinds = total_kinds + len(keys)
            }
            if tag == "" { display = "(no annotation)" }
            rows = rows.push([fname, display, fn_name, str(is_method)])
            gi = gi + 1
        }

        // Section header.
        let n_files = str(len(files))
        if cat == "expr" {
            out = out + "### expr (" + n_files + " files, " + str(total_kinds) + " kinds)\n"
            out = out + "| file | kinds | fn |\n"
            out = out + "|---|---|---|\n"
        } else if cat == "stmt" {
            out = out + "### stmt (" + n_files + " files, " + str(total_kinds) + " kinds)\n"
            out = out + "| file | kinds | fn |\n"
            out = out + "|---|---|---|\n"
        } else {
            out = out + "### builtin (" + n_files + " files, " + str(total_names) + " names, " + str(total_methods) + " methods)\n"
            out = out + "| file | name/method | fn |\n"
            out = out + "|---|---|---|\n"
        }
        let mut ri = 0
        while ri < len(rows) {
            out = out + "| " + rows[ri][0] + " | " + rows[ri][1] + " | " + rows[ri][2] + " |\n"
            ri = ri + 1
        }
        out = out + "\n"
        c = c + 1
    }

    out = out + "## Generated\n"
    out = out + "- `_dispatch.hexa` — dispatcher for poc_lower_expr, poc_lower_stmt, poc_ex_call\n"

    write_file("self/poc/README.md", out)
    println("[poc-readme] wrote self/poc/README.md")
}
