// scripts/hexa_link.hexa — M1 link step for Separate Compilation
//
// Thin clang wrapper. Takes N .c files (transpiled by `hexa build --c-only`
// or equivalent) and produces a native executable. Paired .hxi sidecars
// are optional at link time -- clang handles C-level symbol resolution
// natively. .hxi validation (signature consistency across units) is a
// post-M1 concern.
//
// Usage:
//     ./hexa run scripts/hexa_link.hexa -o <out> <a.c> [b.c ...] [-- clang-extra-flags...]
//
// Defaults:
//     CFLAGS="-O2 -I $HEXA_LANG/self"
//     OS-specific flags auto-appended (macOS codesign).
//
// HX4 self-host: bash 의존 제거, 순수 hexa 로 링킹.

fn show_usage() {
    println("usage: hexa_link.hexa -o <out> <a.c> [b.c ...] [-- clang-flags...]")
}

// ── Parse CLI args ──
let raw_args = argv()
// argv() = [program, script, ...user_args]
let mut out = ""
let mut c_files = []
let mut extra_flags = []
let mut past_double_dash = false

let mut i = 2
while i < len(raw_args) {
    let arg = raw_args[i]
    if past_double_dash {
        extra_flags.push(arg)
        i = i + 1
    } else if arg == "-o" {
        if i + 1 < len(raw_args) {
            out = raw_args[i + 1]
            i = i + 2
        } else {
            eprintln("error: -o requires an argument")
            exit(1)
        }
    } else if arg == "--" {
        past_double_dash = true
        i = i + 1
    } else if arg == "-h" || arg == "--help" {
        show_usage()
        exit(0)
    } else {
        c_files.push(arg)
        i = i + 1
    }
}

if out == "" || len(c_files) == 0 {
    show_usage()
    exit(1)
}

// ── Resolve paths ──
let hexa_dir = if env("HEXA_LANG") != "" {
    env("HEXA_LANG")
} else {
    exec("cd \"$(dirname '" + argv()[1] + "')/../\" && pwd").trim()
}

let clang = if env("CLANG") != "" { env("CLANG") } else { "clang" }
let uname = exec("uname 2>/dev/null").trim()

// ── OS-specific flags ──
let mut cflags = ""
let mut ldflags = ""

if uname == "Linux" {
    cflags = "-O2 -std=gnu11 -D_GNU_SOURCE -I " + hexa_dir + "/self"
    ldflags = "-lm -ldl"
} else {
    // Darwin or unknown
    cflags = "-O2 -std=c11 -I " + hexa_dir + "/self"
    ldflags = ""
}

// ── Build file list string ──
let files_str = c_files.join(" ")
let extra_str = extra_flags.join(" ")

println("[hexa_link] uname=" + uname + " files=" + to_string(len(c_files)) + " out=" + out)

// ── Invoke clang ──
let mut cmd = clang + " " + cflags + " -Wno-trigraphs " + files_str + " -o " + out
if ldflags != "" {
    cmd = cmd + " " + ldflags
}
if extra_str != "" {
    cmd = cmd + " " + extra_str
}

let result = exec_with_status(cmd)
if result[1] != 0 {
    eprintln("[hexa_link] clang failed (exit=" + to_string(result[1]) + ")")
    if result[0] != "" {
        eprintln(result[0])
    }
    exit(result[1])
}

// ── macOS codesign ──
if uname == "Darwin" {
    let cs = exec_with_status("command -v codesign >/dev/null 2>&1")
    if cs[1] == 0 {
        exec_with_status("codesign --force --sign - " + out + " 2>/dev/null")
    }
}

println("[hexa_link] OK -> " + out)
