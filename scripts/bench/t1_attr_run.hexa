// t1_attr_run.hexa — ported from scripts/bench/t1_attr_run.sh
// AI-native attr acceleration comparison bench
//
// 1. Run hexa self/ml/t1_bench_attr.hexa on htz remote
// 2. Capture all JSON lines starting with '{' from stdout
// 3. Inject ts(local), host="htz" into each line
//    Append to nexus/shared/bench/zeta_compare.jsonl

let remote_host = "hetzner"
// 2026-04-11: 원격 hexa는 self-host precompiled (구 cargo 경로 폐기)
let remote_hexa = "$HEXA_LANG/hexa"
let remote_bench = "$HEXA_LANG/self/ml/t1_bench_attr.hexa"
let _nexus = if len(env_var("NEXUS")) > 0 { env_var("NEXUS") } else { env_var("HOME") + "/Dev/nexus" }
let out_jsonl = _nexus + "/shared/bench/zeta_compare.jsonl"
let host_tag = "htz"

print("[t1_attr_run] launching attr-compare bench on " + remote_host + "...")

let raw = exec("ssh " + remote_host + " \"" + remote_hexa + " " + remote_bench + "\" 2>&1")
let ssh_ok = exec("ssh " + remote_host + " \"" + remote_hexa + " " + remote_bench + "\" 2>&1 && echo SSH_OK || echo SSH_FAIL")
if ssh_ok.contains("SSH_FAIL") {
    print("[t1_attr_run] ERROR: SSH or remote execution failed")
    print("----- remote output -----")
    print(raw)
    exit(2)
}

// Collect all lines starting with '{'
let mut json_lines = []
for line in raw.split("\n") {
    if line.starts_with("{") {
        json_lines.push(line)
    }
}

if json_lines.len() == 0 {
    print("[t1_attr_run] ERROR: no JSON line found in remote output")
    print("----- remote output -----")
    print(raw)
    exit(3)
}

shell("mkdir -p " + exec("dirname " + out_jsonl).trim())

let now_ts = exec("date +%s").trim()
let mut count = 0

for line in json_lines {
    if line.trim() == "" {
        continue
    }
    // remove trailing '}' and re-append with injected host/ts
    let stripped = line.trim_end("}")
    let enriched = stripped + ",\"host\":\"" + host_tag + "\",\"local_ts\":" + now_ts + "}"
    print(enriched)
    file_append(out_jsonl, enriched + "\n")
    count = count + 1
}

print("[t1_attr_run] appended " + str(count) + " lines to " + out_jsonl)
