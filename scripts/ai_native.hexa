// ai_native — unified dashboard CLI (orchestrates all ai-native tools)
//
// Runs the relevant subset of ai-native tooling on one or more .hexa files
// and emits a compact grade per file plus a repo summary.
//
// Invokes (via exec):
//   scripts/ai_native_lint.hexa      L1-L4 syntactic rules
//   scripts/ai_native_hotpath.hexa   static hot-path candidates
//   self/opt/algorithm_swap.hexa     bubble/insertion detection
//
// Grading (per file):
//   A+  no findings                           — exceptional
//   A   warnings only (non-strict)            — acceptable
//   B   >=1 block violation OR 3+ warnings    — fix before ship
//   C   >=3 blocks OR hotpath+algo_swap hit   — refactor needed
//   F   complex violations (>=10 findings)    — rewrite
//
// Usage:
//   hexa scripts/ai_native.hexa <file.hexa> [file2 ...]
//   hexa scripts/ai_native.hexa --all self/stdlib    # glob-like dir scan

fn is_alpha(c) { let k = char_code(c, 0); return (k >= 97 && k <= 122) || (k >= 65 && k <= 90) || k == 95 }
fn is_alnum(c) { let k = char_code(c, 0); return (k >= 48 && k <= 57) || (k >= 97 && k <= 122) || (k >= 65 && k <= 90) || k == 95 }

fn count_lines_with(text, substr) {
    let lines = text.split("\n")
    let mut n = 0
    let mut i = 0
    while i < len(lines) {
        if lines[i].contains(substr) { n = n + 1 }
        i = i + 1
    }
    return n
}

fn run_capture(cmd) {
    try {
        return exec(cmd + " 2>/dev/null").trim()
    } catch e { return "" }
}

fn grade_from_counts(blocks, warns, hot, swap) {
    if blocks >= 10 || warns >= 20 { return "F" }
    if blocks >= 3 || (hot >= 3 && swap >= 1) { return "C" }
    if blocks >= 1 || warns >= 3 { return "B" }
    if warns >= 1 || hot >= 1 { return "A" }
    return "A+"
}

fn analyze_file(path) {
    let bin = env_var("HEXA_LANG") + "/build/hexa_stage0"
    let root = env_var("HEXA_LANG")

    // Lint — L1-L4
    let lint_out = run_capture("'" + bin + "' '" + root + "/scripts/ai_native_lint.hexa' '" + path + "' | grep -v 'security warning' | grep -v 'PERF:'")
    let blocks = count_lines_with(lint_out, "[BLOCK")
    let warns = count_lines_with(lint_out, "[warn ")

    // Hotpath
    let hot_out = run_capture("'" + bin + "' '" + root + "/scripts/ai_native_hotpath.hexa' '" + path + "' | grep -v 'security warning' | grep -v 'PERF:'")
    let hot = count_lines_with(hot_out, "@hot candidate")
    let inline = count_lines_with(hot_out, "@inline candidate")
    let memo = count_lines_with(hot_out, "@memoize candidate")

    // Algorithm swap
    let swap_out = run_capture("'" + bin + "' '" + root + "/self/opt/algorithm_swap.hexa' '" + path + "' | grep -v 'security warning' | grep -v 'PERF:'")
    let swap = count_lines_with(swap_out, "[SUGGEST swap]")

    let grade = grade_from_counts(blocks, warns, hot, swap)
    return [grade, blocks, warns, hot, inline, memo, swap]
}

fn pad(s, w) {
    let mut r = s
    while len(r) < w { r = r + " " }
    return r
}

fn list_dir_hexa(dir) {
    let raw = run_capture("ls " + dir + "/*.hexa 2>/dev/null")
    if raw == "" { return [] }
    return raw.split("\n")
}

fn main() {
    let argv = args()
    let mut files = []
    let mut i = 2
    while i < len(argv) {
        let a = argv[i]
        if a == "--all" && i + 1 < len(argv) {
            let dir_files = list_dir_hexa(argv[i + 1])
            let mut k = 0
            while k < len(dir_files) { files = files.push(dir_files[k]); k = k + 1 }
            i = i + 2
            continue
        }
        files = files.push(a)
        i = i + 1
    }
    if len(files) == 0 {
        println("usage: ai_native.hexa <file.hexa> [file2 ...]")
        println("       ai_native.hexa --all <dir>")
        return
    }

    println("╔═══════════════════════════════════════════════════════════════════════════════╗")
    println("║  ai-native dashboard — unified grade across L1-L4 + hotpath + algorithm_swap  ║")
    println("╚═══════════════════════════════════════════════════════════════════════════════╝")
    println("")
    println(pad("grade ", 7) + pad("block", 6) + pad("warn", 6) + pad("@hot", 6) + pad("@inl", 6) + pad("@mem", 6) + pad("swap", 6) + "file")
    println("───────┴─────┴─────┴─────┴─────┴─────┴─────┴─────────────────────────────────────────")

    let mut grades = []
    let mut i2 = 0
    while i2 < len(files) {
        let f = files[i2]
        try {
            let r = analyze_file(f)
            let grade = r[0]
            grades = grades.push(grade)
            println(pad(grade, 7) + pad(to_string(r[1]), 6) + pad(to_string(r[2]), 6) + pad(to_string(r[3]), 6) + pad(to_string(r[4]), 6) + pad(to_string(r[5]), 6) + pad(to_string(r[6]), 6) + f)
        } catch e { println("  error on " + f + ": " + e) }
        i2 = i2 + 1
    }

    // Tally grade distribution
    let mut cA_plus = 0
    let mut cA = 0
    let mut cB = 0
    let mut cC = 0
    let mut cF = 0
    let mut gi = 0
    while gi < len(grades) {
        let g = grades[gi]
        if g == "A+" { cA_plus = cA_plus + 1 }
        else if g == "A" { cA = cA + 1 }
        else if g == "B" { cB = cB + 1 }
        else if g == "C" { cC = cC + 1 }
        else if g == "F" { cF = cF + 1 }
        gi = gi + 1
    }
    println("")
    println("═══ summary ═══")
    println("  A+ : " + to_string(cA_plus))
    println("  A  : " + to_string(cA))
    println("  B  : " + to_string(cB))
    println("  C  : " + to_string(cC))
    println("  F  : " + to_string(cF))
    println("  total files analyzed: " + to_string(len(files)))
}

main()
