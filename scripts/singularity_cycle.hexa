// singularity_cycle.hexa — ported from singularity_cycle.py
// Blowup -> Contraction -> Emergence -> Singularity -> Absorption cycle engine
//
// Usage:
//     let engine = cycle_engine_new()
//     cycle_engine_feed(engine, "opcodes", 24.0)
//     cycle_engine_feed(engine, "types", 12.0)
//     let result = cycle_engine_run(engine)
//     print(str(result))

let N = 6
let SIGMA = 12
let TAU = 4
let PHI = 2
let SOPFR = 5
let J2 = 24

struct N6Constant {
    name: str
    value: float
}

let N6_CONSTANTS = [
    N6Constant { name: "n",      value: 6.0 },
    N6Constant { name: "sigma",  value: 12.0 },
    N6Constant { name: "tau",    value: 4.0 },
    N6Constant { name: "phi",    value: 2.0 },
    N6Constant { name: "sopfr",  value: 5.0 },
    N6Constant { name: "J2",     value: 24.0 },
    N6Constant { name: "sigma-tau", value: 8.0 },
    N6Constant { name: "sigma*phi", value: 24.0 },
    N6Constant { name: "tau^2/sigma", value: 1.333333 },
    N6Constant { name: "n+1",    value: 7.0 },
    N6Constant { name: "unity",  value: 1.0 },
    N6Constant { name: "sigma*tau", value: 48.0 },
    N6Constant { name: "sigma*tau+s", value: 53.0 },
    N6Constant { name: "phi/tau", value: 0.5 },
    N6Constant { name: "1/n",    value: 0.166667 },
    N6Constant { name: "1/sigma", value: 0.083333 }
]

struct N6Match {
    value: float
    constant: str
    quality: float
}

struct CycleResult {
    cycle: int
    blowup: int
    exact: int
    close: int
    patterns: int
    rules: int
    exact_ratio: float
    singularity: bool
}

struct PatternEntry {
    constant: str
    count: int
}

struct CycleEngine {
    metrics_keys: [str]
    metrics_vals: [float]
    patterns: [PatternEntry]
    rules: [PatternEntry]
    cycle_count: int
    exact_ratio: float
    threshold: float
    history: [CycleResult]
}

fn n6_check(value: float) -> (bool, N6Match) {
    if value == 0.0 || is_nan(value) || is_inf(value) {
        return (false, N6Match { value: 0.0, constant: "", quality: 0.0 })
    }
    let mut best_found = false
    let mut best = N6Match { value: 0.0, constant: "", quality: 0.0 }

    for nc in N6_CONSTANTS {
        if nc.value == 0.0 {
            // skip
        } else {
            let ratio = value / nc.value
            if ratio > 0.0 {
                let log_ratio = abs(ln(ratio))
                let q = 1.0 - min(log_ratio, 1.0)
                if q >= 0.8 {
                    if !best_found || q > best.quality {
                        best = N6Match { value: value, constant: nc.name, quality: q }
                        best_found = true
                    }
                }
            }
        }
    }
    return (best_found, best)
}

fn cycle_engine_new() -> CycleEngine {
    return CycleEngine {
        metrics_keys: [],
        metrics_vals: [],
        patterns: [],
        rules: [],
        cycle_count: 0,
        exact_ratio: 0.0,
        threshold: to_float(PHI) / to_float(TAU),
        history: []
    }
}

fn cycle_engine_feed(engine: CycleEngine, name: str, value: float) -> CycleEngine {
    let mut e = engine
    // Check if key already exists
    let mut found = false
    for i in range(0, len(e.metrics_keys)) {
        if e.metrics_keys[i] == name {
            e.metrics_vals[i] = value
            found = true
        }
    }
    if !found {
        e.metrics_keys = append(e.metrics_keys, name)
        e.metrics_vals = append(e.metrics_vals, value)
    }
    return e
}

fn cycle_engine_feed_dict(engine: CycleEngine, keys: [str], vals: [float]) -> CycleEngine {
    let mut e = engine
    for i in range(0, len(keys)) {
        e = cycle_engine_feed(e, keys[i], vals[i])
    }
    return e
}

fn cycle_engine_run(engine: CycleEngine) -> (CycleEngine, CycleResult) {
    let mut e = engine
    e.cycle_count = e.cycle_count + 1
    let mut r = CycleResult {
        cycle: e.cycle_count,
        blowup: 0, exact: 0, close: 0,
        patterns: 0, rules: 0,
        exact_ratio: 0.0, singularity: false
    }

    // Blowup: check individual values and pairwise ratios/products
    let mut matches = []
    let vals = e.metrics_vals

    for v in vals {
        let (found, m) = n6_check(v)
        if found {
            matches = append(matches, m)
        }
    }
    for i in range(0, len(vals)) {
        for j in range(i + 1, len(vals)) {
            if vals[j] != 0.0 {
                let (found_r, mr) = n6_check(vals[i] / vals[j])
                if found_r {
                    matches = append(matches, mr)
                }
            }
            let (found_p, mp) = n6_check(vals[i] * vals[j])
            if found_p {
                matches = append(matches, mp)
            }
        }
    }
    r.blowup = len(matches)

    // Contraction: separate exact vs close matches
    let mut exact_matches = []
    let mut close_matches = []
    for m in matches {
        if m.quality >= 0.95 {
            exact_matches = append(exact_matches, m)
        } else {
            if m.quality >= 0.8 {
                close_matches = append(close_matches, m)
            }
        }
    }
    r.exact = len(exact_matches)
    r.close = len(close_matches)

    // Emergence: count by constant name
    let mut all_matches = []
    for m in exact_matches {
        all_matches = append(all_matches, m)
    }
    for m in close_matches {
        all_matches = append(all_matches, m)
    }

    let mut const_names = []
    let mut const_counts = []
    for m in all_matches {
        let mut idx = -1
        for k in range(0, len(const_names)) {
            if const_names[k] == m.constant {
                idx = k
            }
        }
        if idx >= 0 {
            const_counts[idx] = const_counts[idx] + 1
        } else {
            const_names = append(const_names, m.constant)
            const_counts = append(const_counts, 1)
        }
    }

    let mut new_patterns = 0
    for i in range(0, len(const_names)) {
        if const_counts[i] >= 3 {
            new_patterns = new_patterns + 1
            e.patterns = append(e.patterns, PatternEntry {
                constant: const_names[i],
                count: const_counts[i]
            })
        }
    }
    r.patterns = new_patterns

    // Singularity
    let total = max(len(e.metrics_keys), 1)
    e.exact_ratio = to_float(len(exact_matches)) / to_float(total)
    r.exact_ratio = e.exact_ratio
    r.singularity = e.exact_ratio >= e.threshold

    // Absorption: exact matches appearing >= 2 times
    let mut new_rules = 0
    for i in range(0, len(const_names)) {
        if const_counts[i] >= 2 {
            // Check if this constant appears in exact matches
            let mut in_exact = false
            for m in exact_matches {
                if m.constant == const_names[i] {
                    in_exact = true
                }
            }
            if in_exact {
                new_rules = new_rules + 1
                e.rules = append(e.rules, PatternEntry {
                    constant: const_names[i],
                    count: const_counts[i]
                })
            }
        }
    }
    r.rules = new_rules

    e.history = append(e.history, r)
    return (e, r)
}

fn cycle_engine_run_until_singularity(engine: CycleEngine, max_cycles: int) -> (CycleEngine, [CycleResult]) {
    let mut e = engine
    let mut results = []
    for _ in range(0, max_cycles) {
        let (new_e, r) = cycle_engine_run(e)
        e = new_e
        results = append(results, r)
        if r.singularity {
            return (e, results)
        }
    }
    return (e, results)
}

fn cycle_engine_report(engine: CycleEngine) -> str {
    let mut lines = []
    lines = append(lines, "=== Singularity Cycle Engine ===")
    lines = append(lines, "Cycle: " + str(engine.cycle_count) + " | Metrics: " +
                   str(len(engine.metrics_keys)))
    lines = append(lines, "EXACT ratio: " + format_float(engine.exact_ratio * 100.0, 1) +
                   "% (threshold: " + format_float(engine.threshold * 100.0, 1) + "%)")
    lines = append(lines, "Patterns: " + str(len(engine.patterns)) + " | Rules: " +
                   str(len(engine.rules)))

    if engine.exact_ratio >= engine.threshold {
        lines = append(lines, "Singularity: * REACHED *")
    } else {
        lines = append(lines, "Singularity: approaching...")
    }

    if len(engine.history) > 0 {
        lines = append(lines, "")
        lines = append(lines, "History:")
        for h in engine.history {
            lines = append(lines, "  C" + str(h.cycle) + ": exact=" +
                           format_float(h.exact_ratio * 100.0, 1) + "% pat=" +
                           str(h.patterns) + " rules=" + str(h.rules))
        }
    }
    return join(lines, "\n")
}

fn cycle_engine_to_json(engine: CycleEngine) -> str {
    return json_encode(engine)
}

fn main() {
    let mut engine = cycle_engine_new()

    let args = argv()
    if list_contains(args, "--metrics") {
        let idx = list_index(args, "--metrics") + 1
        if idx < len(args) {
            let d = json_parse(args[idx])
            let keys = json_keys(d)
            for k in keys {
                let v = to_float(json_get(d, k, "0"))
                engine = cycle_engine_feed(engine, k, v)
            }
        }
    } else {
        // Default: HEXA-IR metrics
        let default_keys = [
            "opcodes", "types", "primitives", "compounds",
            "opt_passes", "waves", "per_wave", "targets",
            "zones", "bench_ir", "bench_ceil",
            "convergence", "tests", "ar_rules"
        ]
        let default_vals = [
            24.0, 12.0, 8.0, 4.0,
            12.0, 3.0, 4.0, 2.0,
            3.0, 0.07, 0.008,
            0.92, 798.0, 7.0
        ]
        engine = cycle_engine_feed_dict(engine, default_keys, default_vals)
    }

    let (final_engine, results) = cycle_engine_run_until_singularity(engine, 6)
    print(cycle_engine_report(final_engine))
    print("")
    for r in results {
        print("  -> C" + str(r.cycle) + " blowup=" + str(r.blowup) + " exact=" +
              str(r.exact) + " close=" + str(r.close) + " pat=" + str(r.patterns) +
              " rules=" + str(r.rules) + " ratio=" + format_float(r.exact_ratio * 100.0, 1) +
              "% singularity=" + str(r.singularity))
    }
}
