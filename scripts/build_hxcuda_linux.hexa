// build_hxcuda_linux.hexa -- build libhxcuda.so on Linux (H100, sm_90)
//
// C4 roadmap -- "CUDA fused mega-kernels + bf16 Tensor Core"
// Companion to build_hxblas_linux.hexa, build_hxflash_linux.hexa.
// Same layout and operator contract.
//
// Prerequisites (Linux, CUDA 12.x):
//   - nvcc in PATH (CUDA toolkit)
//   - GPU with sm_90 (H100) for bf16 WMMA -- degrades gracefully
//     on sm_80 (A100) if --arch is overridden.
//
// Usage:
//   hexa scripts/build_hxcuda_linux.hexa                // normal build (sm_90)
//   hexa scripts/build_hxcuda_linux.hexa --debug        // -O0 -G for CUDA debug
//   hexa scripts/build_hxcuda_linux.hexa --arch=sm_80   // override arch (A100)
//   hexa scripts/build_hxcuda_linux.hexa --syntax-check // compile-only, no link
//   DEPLOY=/usr/local/lib hexa scripts/build_hxcuda_linux.hexa  // install
//
// Outputs:
//   self/native/build/libhxcuda.so

fn run(cmd) {
    let result = exec_with_status(cmd)
    if result[1] != 0 {
        eprintln("FAILED: " + cmd)
        exit(1)
    }
    result[0]
}

fn main() {
    let args = argv()
    let hexa_dir = exec("cd \"$(dirname '" + args[1] + "')/../\" && pwd").trim()
    let src_dir = hexa_dir + "/self/native"
    let out_dir = hexa_dir + "/self/native/build"
    let src = src_dir + "/hxcuda_fused.cu"
    let src_stft = src_dir + "/hxcuda_stft.cu"
    let src_conv1d = src_dir + "/hxcuda_conv1d.cu"

    exec("mkdir -p " + out_dir)

    // ── Parse args ────────────────────────────────────────────────────
    let mut arch = "sm_90"
    let mut opt = "-O2"
    let mut mode = "build"

    let mut i = 2
    while i < len(args) {
        let arg = args[i]
        if arg == "--debug" {
            opt = "-O0 -G"
        } else if arg.starts_with("--arch=") {
            arch = arg.replace("--arch=", "")
        } else if arg == "--syntax-check" {
            mode = "syntax"
        } else {
            eprintln("unknown arg: " + arg)
            exit(1)
        }
        i = i + 1
    }

    // ── Verify nvcc ───────────────────────────────────────────────────
    let nvcc_check = exec_with_status("command -v nvcc >/dev/null 2>&1")
    if nvcc_check[1] != 0 {
        eprintln("[build_hxcuda] ERROR: nvcc not found in PATH")
        eprintln("  Install CUDA toolkit or add /usr/local/cuda/bin to PATH")
        exit(2)
    }

    let nvcc_ver = exec("nvcc --version 2>&1 | grep -oP 'release \\K[0-9.]+' || echo unknown").trim()

    // Auto-detect GPU arch if not overridden via --arch
    if arch == "sm_90" {
        let gpu_name = exec("nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1 || true").trim()
        if gpu_name.contains("H100") {
            arch = "sm_90"
        } else if gpu_name.contains("A100") {
            arch = "sm_80"
        } else if gpu_name.contains("4090") || gpu_name.contains("4080") {
            arch = "sm_89"
        } else if gpu_name.contains("3090") || gpu_name.contains("3080") {
            arch = "sm_86"
        }
        println("[build_hxcuda] nvcc version: " + nvcc_ver + ", target arch: " + arch + ", gpu: " + gpu_name)
    } else {
        println("[build_hxcuda] nvcc version: " + nvcc_ver + ", target arch: " + arch + ", gpu: unknown")
    }

    // ── Syntax-check only ────────────────────────────────────────────
    if mode == "syntax" {
        println("[build_hxcuda] syntax check: " + src + " + " + src_stft + " + " + src_conv1d)
        run("nvcc -arch=" + arch + " " + opt + " --ptx " + src + " -o /dev/null 2>&1")
        run("nvcc -arch=" + arch + " " + opt + " --ptx " + src_stft + " -o /dev/null 2>&1")
        run("nvcc -arch=" + arch + " " + opt + " --ptx " + src_conv1d + " -o /dev/null 2>&1")
        println("[build_hxcuda] syntax check PASSED")
        exit(0)
    }

    // ── Build libhxcuda.so ───────────────────────────────────────────
    println("[build_hxcuda] compiling " + src + " + " + src_stft + " + " + src_conv1d + " -> libhxcuda.so (arch=" + arch + ")")

    run("nvcc -arch=" + arch + " " + opt + " --shared -Xcompiler -fPIC " + src + " " + src_stft + " " + src_conv1d + " -lcufft -o " + out_dir + "/libhxcuda.so")

    println("[build_hxcuda] built:")
    println(exec("ls -la " + out_dir + "/libhxcuda.so").trim())

    // ── Symbol verification ──────────────────────────────────────────
    println("[build_hxcuda] symbol check:")

    let expected_syms = ["hxcuda_version", "hxcuda_matmul_bf16", "hxcuda_matmul_bf16_pos", "hxcuda_fused_lmhead_fwd", "hxcuda_matmul_bf16_bwd", "hxcuda_softmax_bwd", "hxcuda_ce_loss_bwd", "hxcuda_fused_lmhead_bwd", "hxcuda_device_info", "hxcuda_sync", "hxcuda_stft_bf16", "hxcuda_istft_bf16", "hxcuda_stft_version", "hxcuda_conv1d_bf16", "hxcuda_conv1d_version", "hxcuda_conv1d_selftest"]
    let mut all_ok = true
    for sym in expected_syms {
        let result = exec_with_status("nm -D " + out_dir + "/libhxcuda.so 2>/dev/null | grep -q ' T " + sym + "\\|_" + sym + "'")
        if result[1] == 0 {
            println("  " + sym + " PRESENT")
        } else {
            eprintln("  " + sym + " MISSING")
            all_ok = false
        }
    }

    if !all_ok {
        eprintln("[build_hxcuda] WARNING: some symbols missing (may still work via dlsym)")
    }

    // ── Optional: deploy to system lib path ──────────────────────────
    let deploy = env("DEPLOY")
    if deploy != "" {
        println("[build_hxcuda] deploying to " + deploy)
        run("cp " + out_dir + "/libhxcuda.so " + deploy + "/")
        exec_with_status("command -v ldconfig >/dev/null && ldconfig")
    }

    println("[build_hxcuda] done -- set LD_LIBRARY_PATH=" + out_dir)
}

main()
