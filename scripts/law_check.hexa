// scripts/law_check.hexa — compile-time law gate (Phase 2)
//
// 목적:
//   git-hook 보다 앞선 compile-time 레벨에서 raw 위반 차단.
//   `hexa` 명령 실행 전 사용자가 수동/alias 로 호출 → law 통과시에만 진행.
//
// 사용:
//   hexa scripts/law_check.hexa                 — 전체 위반 리포트 (exit 1 if violation)
//   hexa scripts/law_check.hexa <file.hexa>     — 특정 파일 + .hexa 만
//   hexa scripts/law_check.hexa --warn-only     — 경고만, exit 0
//
// alias 설치 (선택):
//   alias hexa-safe='hexa scripts/law_check.hexa && hexa'
//   또는 shell function:
//     hexa() { /path/to/hexa scripts/law_check.hexa "$@" && /path/to/hexa.real "$@"; }
//
// 재진입 방지:
//   LAW_CHECK_DONE=1 환경변수 있으면 skip (raw_cli 자체 실행 시 무한루프 방지)
//
// 현재 검사:
//   · raw #3 @attr 네이밍 (hexa self/attrs/_registry.hexa 결과 grep)
//   · raw #5 트리구조 (F5/F6 from ai_native_scan)
//   · raw #6 파일명 (F1/F2/F3 from ai_native_scan)
//
//   raw #4 (폴더명) 은 파일 create 시점 감지 어려움 (pre-commit 에서만)
//   raw #1 (ai-native 24 @attr) 은 warn-only (Tier 2/3 semantic 분석 미완)
//   raw #2 (알고리즘) 은 deferred

let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args = cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

// 재진입 방지
if env("LAW_CHECK_DONE") == "1" { exit(0) }

let mut warn_only = false
let mut target = ""
for a in cli_args {
    if a == "--warn-only" { warn_only = true }
    else { target = a }
}

fn _pwd() -> string {
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p
}

fn _has_file(path: string) -> bool {
    let r = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    return r == "y"
}

fn _run_and_capture(cmd: string) -> string {
    // LAW_CHECK_DONE=1 로 재진입 차단
    return to_string(exec("LAW_CHECK_DONE=1 " + cmd + " 2>&1"))
}

let root = _pwd()
let mut violations = []
let mut warnings = []

println("── law check (compile-time gate) ──")
println("root   : " + root)
if target != "" { println("target : " + target) }
println("")

// ─── raw #3 @attr 네이밍 ────────────────────────
if _has_file(root + "/self/attrs/_registry.hexa") {
    println("[raw #3] @attr 네이밍 — check_naming_all")
    let out = _run_and_capture("cd '" + root + "' && hexa self/attrs/_registry.hexa 2>&1 | grep -Ei 'violation|naming.*fail|reason'")
    if out.trim() != "" {
        println("  ✗ 위반:")
        println("  " + out.trim())
        violations = violations.push("raw#3 @attr 네이밍")
    } else {
        println("  ✓ pass")
    }
}

// ─── raw #5/#6 ai_native_scan (F1~F6) ──────────
if _has_file(root + "/scripts/ai_native_scan.hexa") {
    println("")
    println("[raw #5/#6] 트리/파일명 — ai_native_scan")
    let out = _run_and_capture("cd '" + root + "' && hexa scripts/ai_native_scan.hexa 2>&1 | grep -E '^\\s*F[1-6]'")
    if out.trim() != "" {
        println("  ✗ 위반:")
        println("  " + out.trim())
        violations = violations.push("raw#5/#6 트리/파일명")
    } else {
        println("  ✓ pass")
    }
} else {
    warnings = warnings.push("scripts/ai_native_scan.hexa 없음 — raw #5/#6 검사 스킵")
}

// ─── raw #1 ai-native 24 @attr (warn-only) ────
println("")
println("[raw #1] ai-native 24 @attr — warn-only (Tier 2/3 pending)")
warnings = warnings.push("raw #1 ai-native @attr usage scan 미구현 (defer 참조)")

// ─── 종합 ───────────────────────────────────────
println("")
println("── 결과 ────────────────────────────────────")
println("위반 : " + to_string(len(violations)))
println("경고 : " + to_string(len(warnings)))

if len(violations) > 0 {
    println("")
    println("🚫 law violations:")
    for v in violations { println("   · " + v) }
}

if len(warnings) > 0 {
    println("")
    println("⚠ warnings:")
    for w in warnings { println("   · " + w) }
}

if len(violations) > 0 && !warn_only {
    println("")
    println("compile 차단 — 위반 수정 후 재실행")
    exit(1)
}

if len(violations) == 0 {
    println("")
    println("✅ law gate 통과")
}

exit(0)
