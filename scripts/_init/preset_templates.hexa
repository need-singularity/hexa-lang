// scripts/_init/preset_templates.hexa — project.hexa scaffold presets (옵션 β)
//
// HX11 (갱신안): project.hexa is the single SSOT for a hexa project.
// 문법은 **옵션 β** (self_format_architecture.md §5-3-3 구현 주석):
//   @<attr>_rules[(selector)]
//   let _<attr>_<suffix> = #{...hexa map literal...}
//
// 이렇게 선언하면 project.hexa 전체가 valid hexa 파일이 되어 `hexa parse` 통과하고,
// self/attrs/_lib/project_parser.hexa 가 텍스트 스캔으로 블록 목록을 추출한다.
//
// Presets:
//   minimum — @project only (legacy/backward-compat, no @<attr>_rules)
//   basic   — @project + @readme_rules(scope=root) + README.md + .gitignore
//   paper   — doc-heavy (paper 21 + brief 7 + academic 7 sections)
//   lang    — hexa-lang style (spec/adr/breakthrough doc, root+attr-doc readme)
//   hub     — nexus-style hub (root readme + sealed focus, no domains)
//
// 기존 API (backward compat): preset_minimal/paper/lang/hub(name, hexa_lang) -> string
// 신규 API: render_scaffold(preset, name, hx, first_domain, first_axis, license, author, year) -> [string]
//
// PERF 101 guard: every preset builds via parts + join("").

use "_init/license_templates"

// ─────────────────────────────────────────────────────────────
// header helpers
// ─────────────────────────────────────────────────────────────

pub fn header_comment(name: string, tag: string) -> string {
    let mut parts = []
    parts.push("// project.hexa — ")
    parts.push(name)
    parts.push(" (preset: ")
    parts.push(tag)
    parts.push(")\n")
    parts.push("//\n")
    parts.push("// Single SSOT for this hexa project (HX11, updated 2026-04-18).\n")
    parts.push("// Design reference: $HEXA_LANG/docs/self_format_architecture.md §4-§5.\n")
    parts.push("// Syntax: @<attr>_rules[(selector)] + `let _<attr>_<suffix> = #{...}`.\n")
    parts.push("// No external JSON/YAML/TOML — hexa defines hexa.\n")
    parts.push("//\n")
    parts.push("// Generated by `hexa init`. Edit freely.\n")
    parts.push("\n")
    return parts.join("")
}

pub fn project_block(name: string, hexa_lang: string) -> string {
    let mut parts = []
    parts.push("@project(\n")
    parts.push("    name      = \"")
    parts.push(name)
    parts.push("\",\n")
    parts.push("    version   = \"0.1\",\n")
    parts.push("    hexa_lang = \"")
    parts.push(hexa_lang)
    parts.push("\"\n")
    parts.push(")\n")
    parts.push("let _project_meta = #{\n")
    parts.push("    \"name\": \"")
    parts.push(name)
    parts.push("\",\n")
    parts.push("    \"version\": \"0.1\",\n")
    parts.push("    \"hexa_lang\": \"")
    parts.push(hexa_lang)
    parts.push("\"\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("@rules_meta\n")
    parts.push("let _rules_meta = #{\n")
    parts.push("    \"inherit\": false,\n")
    parts.push("    \"version\": 1,\n")
    parts.push("    \"updated\": \"2026-04-18\"\n")
    parts.push("}\n")
    parts.push("\n")
    return parts.join("")
}

// Q2: license 필드 포함 @project 블록 (project_block 과 동일 구조 + license 필드)
pub fn project_block_with_license(name: string, hexa_lang: string, license_spdx: string) -> string {
    if license_spdx == "" { return project_block(name, hexa_lang) }
    let mut parts = []
    parts.push("@project(\n")
    parts.push("    name      = \"")
    parts.push(name)
    parts.push("\",\n")
    parts.push("    version   = \"0.1\",\n")
    parts.push("    hexa_lang = \"")
    parts.push(hexa_lang)
    parts.push("\",\n")
    parts.push("    license   = \"")
    parts.push(license_spdx)
    parts.push("\"\n")
    parts.push(")\n")
    parts.push("let _project_meta = #{\n")
    parts.push("    \"name\": \"")
    parts.push(name)
    parts.push("\",\n")
    parts.push("    \"version\": \"0.1\",\n")
    parts.push("    \"hexa_lang\": \"")
    parts.push(hexa_lang)
    parts.push("\",\n")
    parts.push("    \"license\": \"")
    parts.push(license_spdx)
    parts.push("\"\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("@rules_meta\n")
    parts.push("let _rules_meta = #{\n")
    parts.push("    \"inherit\": false,\n")
    parts.push("    \"version\": 1,\n")
    parts.push("    \"updated\": \"2026-04-18\"\n")
    parts.push("}\n")
    parts.push("\n")
    return parts.join("")
}

pub fn legacy_project_meta_block(name: string, hexa_lang: string) -> string {
    let mut parts = []
    parts.push("// ─── backward-compat ProjectMeta (pre-@project era) ─────────\n")
    parts.push("\n")
    parts.push("struct ProjectMeta {\n")
    parts.push("    name: string,\n")
    parts.push("    hexa_lang: string,\n")
    parts.push("    ssot_attrs: [string],\n")
    parts.push("    local_overrides: [string]\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("fn project_meta() -> ProjectMeta {\n")
    parts.push("    return ProjectMeta {\n")
    parts.push("        name: \"")
    parts.push(name)
    parts.push("\",\n")
    parts.push("        hexa_lang: \"")
    parts.push(hexa_lang)
    parts.push("\",\n")
    parts.push("        ssot_attrs: [\n")
    parts.push("            \"dispatch\",\n")
    parts.push("            \"naming\",\n")
    parts.push("            \"self_host\",\n")
    parts.push("            \"ai_native\"\n")
    parts.push("        ],\n")
    parts.push("        local_overrides: []\n")
    parts.push("    }\n")
    parts.push("}\n")
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// Q3 — @doc_rules 3 type 렌더러 (paper / brief / academic) — β 옵션 형식
// ─────────────────────────────────────────────────────────────

pub fn render_doc_rules_paper() -> string {
    let mut parts = []
    parts.push("@doc_rules(type=\"paper\")\n")
    parts.push("let _doc_rules_paper = #{\n")
    parts.push("    \"sections\": [\"WHY\", \"COMPARE\", \"REQUIRES\", \"STRUCT\", \"FLOW\", \"EVOLVE\", \"VERIFY\",\n")
    parts.push("                 \"EXEC SUMMARY\", \"SYSTEM REQUIREMENTS\", \"ARCHITECTURE\",\n")
    parts.push("                 \"CIRCUIT DESIGN\", \"PCB DESIGN\", \"FIRMWARE\", \"MECHANICAL\",\n")
    parts.push("                 \"MANUFACTURING\", \"TEST\", \"BOM\", \"VENDOR\", \"ACCEPTANCE\",\n")
    parts.push("                 \"APPENDIX\", \"IMPACT\"],\n")
    parts.push("    \"require_ascii_check\": true,\n")
    parts.push("    \"require_verify\": true,\n")
    parts.push("    \"require_mk_history\": true,\n")
    parts.push("    \"mk_history_min_lines\": 3\n")
    parts.push("}\n")
    parts.push("\n")
    return parts.join("")
}

pub fn render_doc_rules_brief() -> string {
    let mut parts = []
    parts.push("@doc_rules(type=\"brief\")\n")
    parts.push("let _doc_rules_brief = #{\n")
    parts.push("    \"sections\": [\"WHY\", \"COMPARE\", \"REQUIRES\", \"STRUCT\", \"FLOW\", \"EVOLVE\", \"VERIFY\"],\n")
    parts.push("    \"require_ascii_check\": true,\n")
    parts.push("    \"require_verify\": true,\n")
    parts.push("    \"require_mk_history\": false\n")
    parts.push("}\n")
    parts.push("\n")
    return parts.join("")
}

pub fn render_doc_rules_academic() -> string {
    let mut parts = []
    parts.push("@doc_rules(type=\"academic\")\n")
    parts.push("let _doc_rules_academic = #{\n")
    parts.push("    \"sections\": [\"Abstract\", \"Introduction\", \"Related Work\", \"Method\",\n")
    parts.push("                 \"Results\", \"Discussion\", \"Conclusion\"],\n")
    parts.push("    \"require_ascii_check\": false,\n")
    parts.push("    \"require_verify\": false,\n")
    parts.push("    \"require_mk_history\": false\n")
    parts.push("}\n")
    parts.push("\n")
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// preset: minimal — @project only, legacy ProjectMeta retained
// ─────────────────────────────────────────────────────────────

pub fn preset_minimal(name: string, hexa_lang: string) -> string {
    // minimal 은 @<attr>_rules 블록이 없어 parser 도 0 블록을 반환한다.
    // 프로젝트는 전역 _defaults.hexa + legacy JSON + builtin fallback 으로 동작.
    let mut parts = []
    parts.push(header_comment(name, "minimal"))
    parts.push("@project(\n")
    parts.push("    name      = \"")
    parts.push(name)
    parts.push("\",\n")
    parts.push("    version   = \"0.1\",\n")
    parts.push("    hexa_lang = \"")
    parts.push(hexa_lang)
    parts.push("\"\n")
    parts.push(")\n")
    parts.push("let _project_meta = #{\n")
    parts.push("    \"name\": \"")
    parts.push(name)
    parts.push("\",\n")
    parts.push("    \"version\": \"0.1\",\n")
    parts.push("    \"hexa_lang\": \"")
    parts.push(hexa_lang)
    parts.push("\"\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("// No @<attr>_rules blocks — this project inherits built-in defaults.\n")
    parts.push("// Run `hexa init . --preset paper|lang|hub|basic` to scaffold rule blocks.\n")
    parts.push("\n")
    parts.push(legacy_project_meta_block(name, hexa_lang))
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// preset: basic — @project + @readme_rules(scope=root)
// ─────────────────────────────────────────────────────────────

pub fn preset_basic(name: string, hexa_lang: string) -> string {
    let mut parts = []
    parts.push(header_comment(name, "basic"))
    parts.push(project_block(name, hexa_lang))
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @readme_rules — root scope (README.md 기본 섹션)\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@readme_rules(scope=\"root\")\n")
    parts.push("let _readme_rules_root = #{\n")
    parts.push("    \"sections\": [\"Overview\", \"Quick Start\", \"Architecture\", \"Contributing\", \"License\"],\n")
    parts.push("    \"require_codeblock\": false,\n")
    parts.push("    \"require_mdlink\": false,\n")
    parts.push("    \"require_sealed\": false\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push(legacy_project_meta_block(name, hexa_lang))
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// preset: paper — Q3: paper + brief + academic 3 type 전부 포함
// ─────────────────────────────────────────────────────────────

pub fn preset_paper(name: string, hexa_lang: string) -> string {
    let mut parts = []
    parts.push(header_comment(name, "paper"))
    parts.push(project_block(name, hexa_lang))

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @doc_rules — paper §1-§21 + brief §1-§7 + academic 7 sections\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push(render_doc_rules_paper())
    parts.push(render_doc_rules_brief())
    parts.push(render_doc_rules_academic())

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @readme_rules — root + project + domain scope\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@readme_rules(scope=\"root\")\n")
    parts.push("let _readme_rules_root = #{\n")
    parts.push("    \"sections\": [\"Overview\", \"Quick Start\", \"Architecture\", \"Domains\",\n")
    parts.push("                 \"Contributing\", \"License\"],\n")
    parts.push("    \"require_codeblock\": false,\n")
    parts.push("    \"require_mdlink\": false,\n")
    parts.push("    \"require_sealed\": true\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("@readme_rules(scope=\"project\")\n")
    parts.push("let _readme_rules_project = #{\n")
    parts.push("    \"sections\": [\"Purpose\", \"Usage\", \"Structure\", \"Dependencies\", \"Test\", \"License\"],\n")
    parts.push("    \"require_codeblock\": true,\n")
    parts.push("    \"require_sealed\": false\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("@readme_rules(scope=\"domain\")\n")
    parts.push("let _readme_rules_domain = #{\n")
    parts.push("    \"sections\": [],\n")
    parts.push("    \"require_mdlink\": true,\n")
    parts.push("    \"_domain_hints\": true\n")
    parts.push("}\n")
    parts.push("\n")

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @domain_rules — 10 axes, mk1~mk5\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@domain_rules\n")
    parts.push("let _domain_rules = #{\n")
    parts.push("    \"axes\": [\"compute\", \"life\", \"energy\", \"material\", \"space\",\n")
    parts.push("             \"number\", \"signal\", \"bio\", \"chem\", \"sf-ufo\"],\n")
    parts.push("    \"required_fields\": [\"id\", \"axis\"],\n")
    parts.push("    \"id_max_length\": 40,\n")
    parts.push("    \"id_pattern\": \"lowercase-kebab\",\n")
    parts.push("    \"intent_values\": [\"create\", \"update\", \"auto\"],\n")
    parts.push("    \"intent_default\": \"create\",\n")
    parts.push("    \"mk_target_default\": \"mk1\",\n")
    parts.push("    \"alien_now_default\": 7,\n")
    parts.push("    \"alien_target_default\": 10,\n")
    parts.push("    \"scaffold_files\": [\"<id>.md\", \"CLAUDE.md\"],\n")
    parts.push("    \"require_prev_tag_when_not_mk1\": true\n")
    parts.push("}\n")
    parts.push("\n")

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @sealed_rules — sdbm+len, info on first seal\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@sealed_rules\n")
    parts.push("let _sealed_rules = #{\n")
    parts.push("    \"hash_algorithm\": \"sdbm+len\",\n")
    parts.push("    \"sidecar_suffix\": \".sealed.hash\",\n")
    parts.push("    \"first_seal_severity\": \"info\",\n")
    parts.push("    \"mismatch_severity\": \"error\",\n")
    parts.push("    \"max_lines_for_file_decl\": 50\n")
    parts.push("}\n")
    parts.push("\n")

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @publish_rules — main branch only, Korean commit body\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@publish_rules\n")
    parts.push("let _publish_rules = #{\n")
    parts.push("    \"allowed_branches\": [\"main\"],\n")
    parts.push("    \"remote\": \"origin\",\n")
    parts.push("    \"default_auto\": false,\n")
    parts.push("    \"default_push\": false,\n")
    parts.push("    \"require_doc_zero_violations\": true,\n")
    parts.push("    \"dirty_check_allow_only_target\": true,\n")
    parts.push("    \"create_template\": \"feat({axis}): {name_ko} 도메인 신규 등록 (@publish)\",\n")
    parts.push("    \"update_template\": \"chore({axis}): {entry_id} {mk_target} 업데이트 (@publish)\",\n")
    parts.push("    \"encoding\": \"utf-8\",\n")
    parts.push("    \"language\": \"ko\"\n")
    parts.push("}\n")
    parts.push("\n")

    parts.push(legacy_project_meta_block(name, hexa_lang))
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// preset: lang — hexa-lang style (doc minimal, readme root + attr-doc)
// ─────────────────────────────────────────────────────────────

pub fn preset_lang(name: string, hexa_lang: string) -> string {
    let mut parts = []
    parts.push(header_comment(name, "lang"))
    parts.push(project_block(name, hexa_lang))

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @doc_rules — spec / adr / breakthrough (no heavy paper)\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@doc_rules(type=\"spec\")\n")
    parts.push("let _doc_rules_spec = #{\n")
    parts.push("    \"sections\": [\"Overview\", \"Syntax\", \"Semantics\", \"Examples\", \"Errors\"],\n")
    parts.push("    \"require_ascii_check\": false,\n")
    parts.push("    \"require_verify\": false\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("@doc_rules(type=\"adr\")\n")
    parts.push("let _doc_rules_adr = #{\n")
    parts.push("    \"sections\": [\"Context\", \"Decision\", \"Consequences\"]\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("@doc_rules(type=\"breakthrough\")\n")
    parts.push("let _doc_rules_breakthrough = #{\n")
    parts.push("    \"sections\": [\"WHY\", \"BEFORE\", \"AFTER\", \"BENCH\", \"IMPACT\"],\n")
    parts.push("    \"require_ascii_check\": true,\n")
    parts.push("    \"require_verify\": true,\n")
    parts.push("    \"require_mk_history\": false\n")
    parts.push("}\n")
    parts.push("\n")

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @readme_rules — repo root + attr-doc subpages\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@readme_rules(scope=\"root\")\n")
    parts.push("let _readme_rules_root = #{\n")
    parts.push("    \"sections\": [\"Overview\", \"Install\", \"Quick Start\", \"Language Tour\",\n")
    parts.push("                 \"Breakthroughs\", \"Contributing\", \"License\"],\n")
    parts.push("    \"require_codeblock\": true,\n")
    parts.push("    \"require_sealed\": false\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("@readme_rules(scope=\"attr-doc\")\n")
    parts.push("let _readme_rules_attr_doc = #{\n")
    parts.push("    \"sections\": [\"Purpose\", \"Example\", \"Cost\", \"Requires\"]\n")
    parts.push("}\n")
    parts.push("\n")

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @sealed_rules — protect self/attrs/*.hexa\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@sealed_rules\n")
    parts.push("let _sealed_rules = #{\n")
    parts.push("    \"hash_algorithm\": \"sdbm+len\",\n")
    parts.push("    \"sidecar_suffix\": \".sealed.hash\",\n")
    parts.push("    \"first_seal_severity\": \"info\",\n")
    parts.push("    \"mismatch_severity\": \"error\"\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("// @domain_rules / @publish_rules intentionally omitted for tool projects.\n")
    parts.push("\n")

    parts.push(legacy_project_meta_block(name, hexa_lang))
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// preset: hub — nexus hub style (root readme + sealed, no domains)
// ─────────────────────────────────────────────────────────────

pub fn preset_hub(name: string, hexa_lang: string) -> string {
    let mut parts = []
    parts.push(header_comment(name, "hub"))
    parts.push(project_block(name, hexa_lang))

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @doc_rules — hub docs are short references (adr + rfc only)\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@doc_rules(type=\"adr\")\n")
    parts.push("let _doc_rules_adr = #{\n")
    parts.push("    \"sections\": [\"Context\", \"Decision\", \"Consequences\"]\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("@doc_rules(type=\"rfc\")\n")
    parts.push("let _doc_rules_rfc = #{\n")
    parts.push("    \"sections\": [\"Status\", \"Abstract\", \"Introduction\", \"Requirements\",\n")
    parts.push("                 \"Security Considerations\"]\n")
    parts.push("}\n")
    parts.push("\n")

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @readme_rules — root only (hub has no subproject READMEs)\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@readme_rules(scope=\"root\")\n")
    parts.push("let _readme_rules_root = #{\n")
    parts.push("    \"sections\": [\"Overview\", \"Layout\", \"Consumers\", \"Contributing\", \"License\"],\n")
    parts.push("    \"require_codeblock\": false,\n")
    parts.push("    \"require_mdlink\": true,\n")
    parts.push("    \"require_sealed\": true\n")
    parts.push("}\n")
    parts.push("\n")
    parts.push("@readme_rules(scope=\"module\")\n")
    parts.push("let _readme_rules_module = #{\n")
    parts.push("    \"sections\": [\"Purpose\", \"Dependencies\", \"API\", \"Usage\", \"Safety\"],\n")
    parts.push("    \"require_codeblock\": true\n")
    parts.push("}\n")
    parts.push("\n")

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @sealed_rules — hub is read-heavy, strict seal for shared configs\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@sealed_rules\n")
    parts.push("let _sealed_rules = #{\n")
    parts.push("    \"hash_algorithm\": \"sdbm+len\",\n")
    parts.push("    \"sidecar_suffix\": \".sealed.hash\",\n")
    parts.push("    \"first_seal_severity\": \"warn\",\n")
    parts.push("    \"mismatch_severity\": \"error\",\n")
    parts.push("    \"max_lines_for_file_decl\": 50\n")
    parts.push("}\n")
    parts.push("\n")

    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("// @publish_rules — hub publishes to develop, never auto-pushes\n")
    parts.push("// ─────────────────────────────────────────────────────────────\n")
    parts.push("\n")
    parts.push("@publish_rules\n")
    parts.push("let _publish_rules = #{\n")
    parts.push("    \"allowed_branches\": [\"develop\"],\n")
    parts.push("    \"remote\": \"origin\",\n")
    parts.push("    \"default_auto\": false,\n")
    parts.push("    \"default_push\": false,\n")
    parts.push("    \"encoding\": \"utf-8\",\n")
    parts.push("    \"language\": \"ko\"\n")
    parts.push("}\n")
    parts.push("\n")

    parts.push("// @domain_rules intentionally omitted — hubs do not own domains.\n")
    parts.push("\n")

    parts.push(legacy_project_meta_block(name, hexa_lang))
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// README.md / CLAUDE.md / .gitignore / main.hexa / 도메인 seed 렌더
// ─────────────────────────────────────────────────────────────

pub fn render_readme_basic(name: string) -> string {
    let mut parts = []
    parts.push("<!-- @readme(scope=root) -->\n\n")
    parts.push("# ")
    parts.push(name)
    parts.push("\n\n")
    parts.push("한 줄 요약 — 이 프로젝트가 무엇을 하는지 한 문장으로.\n\n")
    parts.push("## Overview\n\n")
    parts.push("이 프로젝트는 hexa-lang 으로 작성된 프로젝트다. 핵심 목표를 1-2 문장으로.\n\n")
    parts.push("- 핵심 기능 1\n")
    parts.push("- 핵심 기능 2\n")
    parts.push("- 핵심 기능 3\n\n")
    parts.push("## Quick Start\n\n")
    parts.push("```bash\n")
    parts.push("# 규칙 검증\n")
    parts.push("hexa policy\n\n")
    parts.push("# 실행 (main.hexa 가 있다면)\n")
    parts.push("hexa run main.hexa\n")
    parts.push("```\n\n")
    parts.push("## Architecture\n\n")
    parts.push("- `project.hexa` — 프로젝트 루트 마커 + @readme_rules 블록\n")
    parts.push("- `README.md` — 이 파일 (프로젝트 소개)\n")
    parts.push("- `.gitignore` — git 무시 목록\n\n")
    parts.push("## Contributing\n\n")
    parts.push("PR 환영. 수정 전 `hexa policy` 로 규칙 위반 0 확인 필수.\n\n")
    parts.push("## License\n\n")
    parts.push("프로젝트별 설정 (LICENSE 파일 참조).\n")
    return parts.join("")
}

pub fn render_readme_paper(name: string) -> string {
    let mut parts = []
    parts.push("<!-- @readme(scope=root) -->\n\n")
    parts.push("# ")
    parts.push(name)
    parts.push("\n\n")
    parts.push("논문 + 도메인 중심 hexa 프로젝트 (paper preset).\n\n")
    parts.push("## Overview\n\n")
    parts.push("이 프로젝트는 `@doc(type=paper)` 21 섹션 / `@doc(type=brief)` 7 섹션 / `@doc(type=academic)` 7 섹션 템플릿으로 논문을 작성하고, `domains/<axis>/<id>/` 구조로 도메인을 관리한다.\n\n")
    parts.push("- 논문: `papers/` 하위 `.md` 파일, `@doc(type=paper|brief|academic)` attr.\n")
    parts.push("- 도메인: `domains/<axis>/<id>/<id>.md`, `@domain(id=..., axis=...)` attr.\n")
    parts.push("- 리포트: `reports/` 하위 시점별 리포트.\n\n")
    parts.push("## Quick Start\n\n")
    parts.push("```bash\n")
    parts.push("hexa policy\n")
    parts.push("hexa init . --preset domain_only --axis life --id dog-robot\n")
    parts.push("```\n\n")
    parts.push("## Architecture\n\n")
    parts.push("- `project.hexa` — 프로젝트 SSOT (@doc_rules x3, @domain_rules, @sealed_rules, @publish_rules)\n")
    parts.push("- `papers/` — 논문 `.md` 파일 집합\n")
    parts.push("- `reports/` — 시점 리포트\n")
    parts.push("- `domains/<axis>/<id>/` — 도메인 seed\n\n")
    parts.push("## Domains\n\n")
    parts.push("10 축: compute, life, energy, material, space, number, signal, bio, chem, sf-ufo.\n\n")
    parts.push("## Contributing\n\n")
    parts.push("PR 전 `hexa policy` + `hexa doc lint` 위반 0 확인 필수.\n\n")
    parts.push("## License\n\n")
    parts.push("LICENSE 파일 참조.\n")
    return parts.join("")
}

