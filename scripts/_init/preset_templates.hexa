    parts.push("**외계인 지수**: 7 → 10 (목표)\n\n")
    parts.push("## 요약\n\n")
    parts.push("이 도메인의 한 문단 요약.\n\n")
    parts.push("## 선행 도메인\n\n")
    parts.push("- (필요시 참조)\n\n")
    parts.push("## 빠른 참조\n\n")
    parts.push("- seed: 본 파일\n")
    parts.push("- 규칙: 상위 `project.hexa` 의 `@domain_rules` 참조\n")
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// project_hexa_with_license — license 플래그 반영 @project 블록 치환
// ─────────────────────────────────────────────────────────────

pub fn project_hexa_with_license(preset: string, name: string, hexa_lang: string, license_spdx: string) -> string {
    let mut body = ""
    if preset == "minimum"      { body = preset_minimal(name, hexa_lang) }
    else if preset == "minimal" { body = preset_minimal(name, hexa_lang) }
    else if preset == "basic"   { body = preset_basic(name, hexa_lang) }
    else if preset == "paper"   { body = preset_paper(name, hexa_lang) }
    else if preset == "lang"    { body = preset_lang(name, hexa_lang) }
    else if preset == "hub"     { body = preset_hub(name, hexa_lang) }
    else                        { body = preset_minimal(name, hexa_lang) }
    if license_spdx == "" { return body }

    // 기존 @project(...) 블록을 license-aware 버전으로 텍스트 치환.
    // 본문은 `@project(\n    name      = "<name>",\n    version   = "0.1",\n    hexa_lang = "<hx>"\n)\n` 패턴.
    let old_block_end = "\"\n)\n"
    let tail_pos = body.index_of(old_block_end)
    if tail_pos < 0 { return body }
    let new_project_tail = "\",\n    license   = \"" + license_spdx + "\"\n)\n"
    let before = body.substring(0, tail_pos)
    let after = body.substring(tail_pos + len(old_block_end), len(body))
    return before + new_project_tail + after
}

// ─────────────────────────────────────────────────────────────
// render_scaffold — 풀 scaffold 파일 맵 반환 (flat [path, content, ...] pairs)
//   `.gitkeep` 빈 파일은 content "" 로 표기.
// ─────────────────────────────────────────────────────────────

pub fn render_scaffold(preset: string, name: string, hexa_lang: string, first_domain: string, first_axis: string, license_spdx: string, license_author: string, license_year: string) -> [string] {
    let mut files = []

    // 1) project.hexa
    let proj_body = project_hexa_with_license(preset, name, hexa_lang, license_spdx)
    files.push("project.hexa")
    files.push(proj_body)

    // minimum 은 project.hexa 하나로 끝
    if preset == "minimum" || preset == "minimal" {
        return files
    }

    // 2) README + .gitignore (basic 이상 공통)
    let mut readme_body = ""
    if preset == "paper"      { readme_body = render_readme_paper(name) }
    else if preset == "lang"  { readme_body = render_readme_lang(name) }
    else if preset == "hub"   { readme_body = render_readme_hub(name) }
    else                      { readme_body = render_readme_basic(name) }
    files.push("README.md")
    files.push(readme_body)

    files.push(".gitignore")
    files.push(render_gitignore(preset))

    // basic 은 CLAUDE.md 없음
    if preset == "basic" {
        if license_spdx != "" {
            let lic = render_license(license_spdx, license_author, license_year)
            if lic != "" {
                files.push("LICENSE")
                files.push(lic)
            }
        }
        return files
    }

    // 3) paper / lang / hub: CLAUDE.md
    files.push("CLAUDE.md")
    files.push(render_claude_md(name, preset))

    if preset == "paper" {
        files.push("domains/.gitkeep")
        files.push("")
        files.push("papers/.gitkeep")
        files.push("")
        files.push("reports/.gitkeep")
        files.push("")
        if first_domain != "" && first_axis != "" {
            let mut dp = []
            dp.push("domains/")
            dp.push(first_axis)
            dp.push("/")
            dp.push(first_domain)
            dp.push("/")
            dp.push(first_domain)
            dp.push(".md")
            files.push(dp.join(""))
            files.push(render_domain_seed_md(first_domain, first_axis))
        }
    }

    if preset == "lang" {
        files.push("main.hexa")
        files.push(render_main_hexa_lang())
        files.push("self/.gitkeep")
        files.push("")
        files.push("self/attrs/.gitkeep")
        files.push("")
        files.push("scripts/.gitkeep")
        files.push("")
        files.push("tests/.gitkeep")
        files.push("")
        files.push("docs/.gitkeep")
        files.push("")
    }

    if preset == "hub" {
        files.push("shared/config/.gitkeep")
        files.push("")
        files.push("shared/rules/.gitkeep")
        files.push("")
        files.push("shared/harness/.gitkeep")
        files.push("")
        files.push("docs/.gitkeep")
        files.push("")
    }

    // 4) Q2: LICENSE (preset 무관, --license 지정 시만)
    if license_spdx != "" {
        let lic = render_license(license_spdx, license_author, license_year)
        if lic != "" {
            files.push("LICENSE")
            files.push(lic)
        }
    }

    return files
}

// ─────────────────────────────────────────────────────────────
// migrate helpers — .{attr}-rules.json → @<attr>_rules(...) + let _<attr>_... = #{...}
// ─────────────────────────────────────────────────────────────

pub fn migrate_stub_block(attr: string, raw_json: string) -> string {
    // Minimal best-effort translation: keep JSON as hexa comment block plus a
    // placeholder @<attr>_rules + let _<attr>_stub = #{} so the user can hand-migrate values.
    let mut parts = []
    parts.push("// migrated from .")
    parts.push(attr)
    parts.push("-rules.json (hand-review required):\n")
    let lines = split(raw_json, "\n")
    let mut i = 0
    while i < len(lines) {
        parts.push("//   ")
        parts.push(lines[i])
        parts.push("\n")
        i = i + 1
    }
    parts.push("@")
    parts.push(attr)
    parts.push("_rules\n")
    parts.push("let _")
    parts.push(attr)
    parts.push("_rules_stub = #{\n")
    parts.push("    // TODO: copy values from JSON above\n")
    parts.push("}\n")
    parts.push("\n")
    return parts.join("")
}
