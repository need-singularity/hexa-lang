pub fn render_claude_md(name: string, preset: string) -> string {
    let mut parts = []
    parts.push("# ")
    parts.push(name)
    parts.push(" — AI 에이전트 가이드\n\n")
    parts.push("이 파일은 Claude Code / Cursor / Aider 가 이 프로젝트에서 작업할 때 참조.\n\n")
    parts.push("## 첫 30 초 체크\n\n")
    parts.push("1. `Read project.hexa` — 규칙 SSOT 확인\n")
    parts.push("2. `Read README.md` — 프로젝트 의도 확인\n")
    if preset == "paper" {
        parts.push("3. `Glob papers/*.md`, `Glob domains/**/*.md` — 문서 구조 인지\n\n")
    } else if preset == "lang" {
        parts.push("3. `Read main.hexa` — 실행 진입점\n")
        parts.push("4. `Glob self/attrs/*.hexa` — 프로젝트 고유 attr 목록\n\n")
    } else if preset == "hub" {
        parts.push("3. `Glob shared/config/*.json`, `Glob shared/rules/*.json` — 공유 자원 구조\n\n")
    } else {
        parts.push("3. `Glob **/*.hexa` — 파일 구조 인지\n\n")
    }
    parts.push("## 핵심 규칙 (HX11 준수)\n\n")
    parts.push("- 모든 문서 첫 줄에 `<!-- @doc(type=...) -->` 또는 `<!-- @readme(scope=...) -->` 마커.\n")
    parts.push("- 코드는 전부 `.hexa` (HX4). Rust/Python/JS 금지.\n")
    parts.push("- 규칙은 `project.hexa` 의 `@<attr>_rules` 블록으로.\n\n")
    if preset == "paper" {
        parts.push("## paper preset 특이점\n\n")
        parts.push("- `@doc_rules(type=\"paper\")` §1-21 섹션 강제.\n")
        parts.push("- `@doc_rules(type=\"brief\")` 7 섹션 약식.\n")
        parts.push("- `@doc_rules(type=\"academic\")` Abstract/Intro/Related/Method/Results/Discussion/Conclusion.\n")
        parts.push("- 도메인 추가: `hexa init . --preset domain_only --axis <axis> --id <id>`.\n\n")
    } else if preset == "lang" {
        parts.push("## lang preset 특이점\n\n")
        parts.push("- `self/attrs/` 디렉토리 관례 (hexa-lang 고유).\n")
        parts.push("- `main.hexa` = 실행 진입점.\n")
        parts.push("- `@doc_rules(type=\"spec\"|\"adr\"|\"breakthrough\")` 3 종.\n\n")
    } else if preset == "hub" {
        parts.push("## hub preset 특이점\n\n")
        parts.push("- `shared/` 하위 파일은 `.sealed.hash` 봉인.\n")
        parts.push("- `main` 브랜치 직접 push 금지, develop 만.\n\n")
    }
    parts.push("## 참조\n\n")
    parts.push("- hexa-lang SSOT: `$HEXA_LANG/CLAUDE.md` (HX3/HX4/HX7/HX11)\n")
    parts.push("- 글로벌 규칙: `$NEXUS/shared/rules/common.json` (R0~R27)\n")
    return parts.join("")
}

pub fn render_gitignore(preset: string) -> string {
    let mut parts = []
    parts.push("# hexa build artifacts\n")
    parts.push("build/\n")
    parts.push("target/\n")
    parts.push("dist/\n")
    if preset == "lang" {
        parts.push("*.o\n")
        parts.push("*.a\n\n")
        parts.push("# hexa native artifacts (self-host 빌드 산출물)\n")
        parts.push("self/native/*.c\n")
        parts.push("self/native/hexa_v2\n")
        parts.push("self/native/hexa_stage0\n")
        parts.push("!self/native/*.hexanoport\n")
    }
    parts.push("\n")
    parts.push("# hexa sealed sidecars (@sealed 가 자동 생성)\n")
    if preset == "hub" {
        parts.push("# 허브는 .sealed.hash 를 git 에 포함 — 봉인 이력 공유\n")
        parts.push("# *.sealed.hash\n")
    } else {
        parts.push("*.sealed.hash\n")
    }
    parts.push("\n")
    if preset == "lang" {
        parts.push("# test artifacts\n")
        parts.push("tests/*.tmp\n")
        parts.push("tests/*.out\n\n")
    }
    if preset == "paper" {
        parts.push("# 리포트 임시 파일\n")
        parts.push("reports/*.tmp\n")
        parts.push("reports/*.bak\n\n")
    }
    if preset == "hub" {
        parts.push("# 허브 로컬 캐시\n")
        parts.push("shared/cache/\n")
        parts.push("shared/runtime/\n\n")
    }
    parts.push("# OS\n")
    parts.push(".DS_Store\n")
    parts.push("Thumbs.db\n")
    parts.push("._*\n\n")
    parts.push("# editor / IDE\n")
    parts.push(".vscode/\n")
    parts.push(".idea/\n")
    parts.push("*.swp\n")
    parts.push("*.swo\n")
    parts.push("*~\n\n")
    parts.push("# local env / secrets\n")
    parts.push(".env\n")
    parts.push(".env.local\n")
    return parts.join("")
}

pub fn render_main_hexa_lang() -> string {
    let mut parts = []
    parts.push("// main.hexa — lang preset 실행 진입점 샘플\n")
    parts.push("//\n")
    parts.push("// `hexa run main.hexa` 로 실행.\n")
    parts.push("\n")
    parts.push("fn main() {\n")
    parts.push("    println(\"hello hexa\")\n")
    parts.push("    println(\"preset=lang, project scaffolded by `hexa init --preset lang`\")\n")
    parts.push("}\n")
    return parts.join("")
}

