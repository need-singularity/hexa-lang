// ai_native_lint — text-based linter for 3 ai-native rules (no parser required)
//
// Rules:
//   L1 scope          — #!hexa strict header activates the other 2 rules file-wide
//                        (without header: warn only; with header: block)
//   L2 literal_ban    — NumberLit on either side of comparison ops
//                        (>, <, >=, <=, ==, !=) is forbidden.
//                        Exceptions: -1, 0, 1, 2 (power-of-2 common)
//                                    left operand `len(x)` / `.length` / `i` loop var
//                                    RHS after `== null` / `== true` / `== false`
//                                    inside // or /* comment
//   L3 brace_lock     — within a single file, the first `{` placement wins.
//                        Styles: `same_line` (K&R:  `fn f() {`)
//                                `next_line` (Allman: `fn f()\n{`)
//                        Mixing the two triggers a violation.
//
// Usage:
//   hexa scripts/ai_native_lint.hexa <file.hexa>              # single file
//   hexa scripts/ai_native_lint.hexa --staged                  # all git-staged .hexa
//
// Exit:
//   0 — no blocking violations (or only warnings without strict header)
//   1 — one or more blocking violations

fn is_digit(c) {
    let k = char_code(c, 0)
    return k >= 48 && k <= 57
}

fn is_alpha(c) {
    let k = char_code(c, 0)
    return (k >= 97 && k <= 122) || (k >= 65 && k <= 90) || k == 95
}

fn is_alnum(c) {
    return is_digit(c) || is_alpha(c)
}

// Strip inline /* ... */ comments and // ... EOL.
// Preserves positions by overwriting with spaces (so column numbers still make sense).
fn strip_comments(src) {
    let n = len(src)
    let mut i = 0
    let mut out = ""
    while i < n {
        let c = src[i]
        if c == "/" && i + 1 < n && src[i + 1] == "/" {
            while i < n && src[i] != "\n" { out = out + " "; i = i + 1 }
        } else if c == "/" && i + 1 < n && src[i + 1] == "*" {
            out = out + "  "; i = i + 2
            while i + 1 < n && !(src[i] == "*" && src[i + 1] == "/") {
                if src[i] == "\n" { out = out + "\n" } else { out = out + " " }
                i = i + 1
            }
            if i + 1 < n { out = out + "  "; i = i + 2 }
        } else if c == "\"" {
            out = out + c; i = i + 1
            while i < n && src[i] != "\"" {
                if src[i] == "\\" && i + 1 < n { out = out + src[i]; i = i + 1 }
                out = out + src[i]; i = i + 1
            }
            if i < n { out = out + src[i]; i = i + 1 }
        } else {
            out = out + c; i = i + 1
        }
    }
    return out
}

// Return list of [line_no, col_no, op_str, lit_str] violations
fn find_literal_compare(clean_src) {
    let mut out = []
    let n = len(clean_src)
    let mut i = 0
    let mut line = 1
    let mut line_start = 0
    while i < n {
        if clean_src[i] == "\n" { line = line + 1; line_start = i + 1; i = i + 1; continue }
        // Try to detect comparison ops: == != <= >= < >
        let mut op = ""
        let mut op_len = 0
        if i + 1 < n {
            let two = clean_src[i] + clean_src[i + 1]
            if two == "==" || two == "!=" || two == "<=" || two == ">=" {
                op = two; op_len = 2
            }
        }
        if op == "" {
            let c = clean_src[i]
            if c == "<" || c == ">" {
                // Avoid generics / channel ops / shift: skip `<<`, `>>`, `<-`, `->`, `<T>` boundaries
                let nextc = if i + 1 < n { clean_src[i + 1] } else { "" }
                if nextc == "<" || nextc == ">" || nextc == "-" { i = i + 1; continue }
                // skip `<T>` generic (alnum on both sides OR next is upper letter)
                if nextc != "" { let nk = char_code(nextc, 0); if nk >= 65 && nk <= 90 { i = i + 1; continue } }
                op = c; op_len = 1
            }
        }
        if op == "" { i = i + 1; continue }
        // Check RHS: skip whitespace, see if it starts with a digit literal
        let mut j = i + op_len
        while j < n && (clean_src[j] == " " || clean_src[j] == "\t") { j = j + 1 }
        // Skip unary minus
        let mut neg = false
        if j < n && clean_src[j] == "-" { neg = true; j = j + 1; while j < n && (clean_src[j] == " " || clean_src[j] == "\t") { j = j + 1 } }
        if j < n && is_digit(clean_src[j]) {
            // collect literal
            let mut lit = ""
            if neg { lit = "-" }
            while j < n {
                let cj = clean_src[j]
                let kj = char_code(cj, 0)
                let is_hex = (kj >= 97 && kj <= 102) || (kj >= 65 && kj <= 70)
                if is_digit(cj) || cj == "." || cj == "_" || cj == "x" || cj == "b" || is_hex {
                    lit = lit + cj; j = j + 1
                } else {
                    j = n + 1
                }
            }
            // Allow the small-integer exceptions
            let ok = lit == "0" || lit == "1" || lit == "-1" || lit == "2"
            if !ok {
                out = out.push([line, i - line_start + 1, op, lit])
            }
        }
        i = i + op_len
    }
    return out
}

// Detect brace style per-file.
// Returns [first_style, violations]
//   first_style ∈ {"same_line", "next_line", "none"}
//   violations  = [[line, style_seen]]
fn find_brace_style_violations(clean_src) {
    let n = len(clean_src)
    let mut first = "none"
    let mut out = []
    let mut i = 0
    let mut line = 1
    while i < n {
        if clean_src[i] == "\n" { line = line + 1; i = i + 1; continue }
        if clean_src[i] == "{" {
            // Scan backwards: first skip spaces/tabs on current line to detect same_line
            let mut j = i - 1
            let mut crossed_nl = false
            while j >= 0 && (clean_src[j] == " " || clean_src[j] == "\t") { j = j - 1 }
            // If we hit a newline here, this brace is on its own line (next_line style).
            // Continue past \n and more whitespace to find the token of the previous non-empty line.
            while j >= 0 && (clean_src[j] == "\n" || clean_src[j] == " " || clean_src[j] == "\t") {
                if clean_src[j] == "\n" { crossed_nl = true }
                j = j - 1
            }
            let mut is_block = false
            if j >= 0 {
                let pc = clean_src[j]
                if pc == ")" || is_alpha(pc) { is_block = true }
            }
            if is_block {
                let style = if crossed_nl { "next_line" } else { "same_line" }
                if first == "none" { first = style }
                else if style != first {
                    out = out.push([line, style])
                }
            }
        }
        i = i + 1
    }
    return [first, out]
}

// L4 — O(n^2) concat detection.
// Looks for `name = name + X` inside for/while body where X is array literal [..]
// or a single char/token. Patterns like `out = out + c` or `arr = arr + [x]`.
// Returns [[line, col, expr_preview]] violations.
fn find_on2_concat(clean_src) {
    let n = len(clean_src)
    let mut out = []
    let mut i = 0
    let mut line = 1
    let mut line_start = 0
    let mut loop_depth = 0
    // Simple brace-level tracking for loop body scope. We detect `for ` or `while `
    // followed by an opening `{` within the next 200 chars, then increment depth.
    // depth decrements at matching `}`. This is an approximation (ignores nested
    // non-loop `{`), good enough for a lint heuristic.
    let mut loop_brace_depths = []
    let mut cur_brace_depth = 0
    while i < n {
        let c = clean_src[i]
        if c == "\n" { line = line + 1; line_start = i + 1; i = i + 1; continue }
        // Detect `for ` / `while ` keyword at word boundary
        let kw_for = i + 4 <= n && clean_src.substring(i, i + 4) == "for " && (i == 0 || !is_alnum(clean_src[i - 1]))
        let kw_while = i + 6 <= n && clean_src.substring(i, i + 6) == "while " && (i == 0 || !is_alnum(clean_src[i - 1]))
        if kw_for || kw_while {
            // Scan forward for matching `{` within 300 chars
            let mut k = i
            let limit = if n < i + 300 { n } else { i + 300 }
            while k < limit && clean_src[k] != "{" && clean_src[k] != ";" { k = k + 1 }
            if k < limit && clean_src[k] == "{" {
                loop_brace_depths = loop_brace_depths.push(cur_brace_depth + 1)
                loop_depth = loop_depth + 1
            }
        }
        if c == "{" { cur_brace_depth = cur_brace_depth + 1 }
        if c == "}" {
            if loop_depth > 0 && len(loop_brace_depths) > 0 && loop_brace_depths[len(loop_brace_depths) - 1] == cur_brace_depth {
                let mut nd = []
                let mut _li = 0
                while _li < len(loop_brace_depths) - 1 {
                    nd = nd.push(loop_brace_depths[_li])
                    _li = _li + 1
                }
                loop_brace_depths = nd
                loop_depth = loop_depth - 1
            }
            cur_brace_depth = cur_brace_depth - 1
        }
        // Inside a loop? check for `ident = ident + ...` pattern at statement start
        if loop_depth > 0 && is_alpha(c) && (i == 0 || !is_alnum(clean_src[i - 1])) {
            // collect identifier
            let mut k = i
            while k < n && is_alnum(clean_src[k]) { k = k + 1 }
            let name = clean_src.substring(i, k)
            // skip spaces
            while k < n && clean_src[k] == " " { k = k + 1 }
            // expect `=` (single, not `==`)
            if k < n && clean_src[k] == "=" && (k + 1 >= n || clean_src[k + 1] != "=") {
                let mut m = k + 1
                while m < n && clean_src[m] == " " { m = m + 1 }
                // expect same `name` again
                if m + len(name) <= n && clean_src.substring(m, m + len(name)) == name {
                    let after = m + len(name)
                    // skip spaces
                    let mut p = after
                    while p < n && clean_src[p] == " " { p = p + 1 }
                    // expect `+`
                    if p < n && clean_src[p] == "+" && (p + 1 >= n || clean_src[p + 1] != "+") {
                        // skip whitespace after `+` to see what we're adding
                        let mut q = p + 1
                        while q < n && clean_src[q] == " " { q = q + 1 }
                        // Exclude pure arithmetic: RHS starts with digit (counter increment)
                        // True concat RHS starts with `[` (array), `"` (string), or identifier/call.
                        let is_arith = q < n && (is_digit(clean_src[q]) || (clean_src[q] == "-" && q + 1 < n && is_digit(clean_src[q + 1])))
                        if !is_arith {
                            // match — this is O(n^2) concat inside a loop
                            let mut preview_end = n
                            let mut _pi = i
                            while _pi < n && clean_src[_pi] != "\n" && _pi < i + 60 { _pi = _pi + 1 }
                            preview_end = _pi
                            let raw_preview = clean_src.substring(i, preview_end)
                            // trim trailing whitespace
                            let mut te = len(raw_preview)
                            while te > 0 && (raw_preview[te - 1] == " " || raw_preview[te - 1] == "\t") { te = te - 1 }
                            let preview = raw_preview.substring(0, te)
                            out = out.push([line, i - line_start + 1, preview])
                            i = preview_end
                            continue
                        }
                    }
                }
            }
            i = k
            continue
        }
        i = i + 1
    }
    return out
}

fn has_strict_header(src) {
    // Lines 1 or 2 should contain `#!hexa strict`
    let n = len(src)
    let mut i = 0
    let mut line = 1
    while i < n && line <= 2 {
        if src[i] == "\n" { line = line + 1; i = i + 1; continue }
        if i + 12 < n {
            let head = src.substring(i, i + 13)
            if head == "#!hexa strict" { return true }
        }
        // advance to EOL
        while i < n && src[i] != "\n" { i = i + 1 }
    }
    return false
}

fn lint_file(path) {
    let src = read_file(path)
    let clean = strip_comments(src)
    let strict = has_strict_header(src)
    let mut violations = 0
    let mut warnings = 0

    let lit_v = find_literal_compare(clean)
    let mut i = 0
    while i < len(lit_v) {
        let v = lit_v[i]
        let tag = if strict { "BLOCK" } else { "warn " }
        println(path + ":" + to_string(v[0]) + ":" + to_string(v[1]) + ": [" + tag + " L2 literal-ban] magic literal " + v[3] + " in '" + v[2] + "' comparison")
        if strict { violations = violations + 1 } else { warnings = warnings + 1 }
        i = i + 1
    }

    let brace = find_brace_style_violations(clean)
    let first_style = brace[0]
    let brace_v = brace[1]
    let mut j = 0
    while j < len(brace_v) {
        let v = brace_v[j]
        let tag = if strict { "BLOCK" } else { "warn " }
        println(path + ":" + to_string(v[0]) + ":1: [" + tag + " L3 brace-lock] file started with '" + first_style + "' but saw '" + v[1] + "' here")
        if strict { violations = violations + 1 } else { warnings = warnings + 1 }
        j = j + 1
    }

    let on2 = find_on2_concat(clean)
    let mut k = 0
    while k < len(on2) {
        let v = on2[k]
        let tag = if strict { "BLOCK" } else { "warn " }
        println(path + ":" + to_string(v[0]) + ":" + to_string(v[1]) + ": [" + tag + " L4 O(n^2)-concat] `" + v[2] + "` inside loop — use .push() + .join() instead")
        if strict { violations = violations + 1 } else { warnings = warnings + 1 }
        k = k + 1
    }

    return [violations, warnings]
}

fn staged_files() {
    try {
        let raw = exec("git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep '\\.hexa$'").trim()
        if raw == "" { return [] }
        return raw.split("\n")
    } catch e { return [] }
}

fn main() {
    let argv = args()
    let mut files = []
    let mut i = 2
    while i < len(argv) {
        if argv[i] == "--staged" {
            files = staged_files()
        } else {
            files = files.push(argv[i])
        }
        i = i + 1
    }
    if len(files) == 0 {
        println("usage: ai_native_lint.hexa [--staged | <file.hexa> ...]")
        return
    }
    let mut total_viol = 0
    let mut total_warn = 0
    let mut k = 0
    while k < len(files) {
        let f = files[k]
        if len(f) >= 5 && f.substring(len(f) - 5, len(f)) == ".hexa" {
            try {
                let r = lint_file(f)
                total_viol = total_viol + r[0]
                total_warn = total_warn + r[1]
            } catch e {
                println(f + ": [lint error] " + e)
            }
        }
        k = k + 1
    }
    if total_viol > 0 {
        println("")
        println("ai-native-lint: " + to_string(total_viol) + " blocking violations, " + to_string(total_warn) + " warnings")
        exit(1)
    } else if total_warn > 0 {
        println("ai-native-lint: CLEAN (blocking) — " + to_string(total_warn) + " warnings (files lack #!hexa strict header)")
    } else {
        println("ai-native-lint: CLEAN")
    }
}

