// scripts/poc_gen_dispatch.hexa
//
// Generates self/poc/_dispatch.hexa from the filesystem layout:
//   self/poc/expr/<snake>.hexa     @kinds X[, Y]  → poc_ex_<snake>
//   self/poc/stmt/<snake>.hexa     @kinds X[, Y]  → poc_st_<snake>
//   self/poc/builtin/<snake>.hexa  @name X[, Y]   → poc_bi_<snake>
//                                  @method push   → method dispatch
//
// Emits 3 thin dispatcher fns:
//   fn poc_lower_expr(e) -> int         — routes by e.kind
//   fn poc_lower_stmt(stmt) -> int      — routes by stmt.kind
//   fn poc_ex_call(e) -> int            — routes by e.left.name (builtin)
//                                          + method dispatch + user fn fallback
//
// Usage:  hexa scripts/poc_gen_dispatch.hexa
// Output: self/poc/_dispatch.hexa  (overwritten in place)

let CATS = [["expr", "ex"], ["stmt", "st"], ["builtin", "bi"]]

fn strip(s) {
    let mut i = 0
    while i < len(s) && (s[i] == " " || s[i] == "\t") { i = i + 1 }
    let mut j = len(s) - 1
    while j >= i && (s[j] == " " || s[j] == "\t" || s[j] == "\r" || s[j] == "\n") { j = j - 1 }
    let mut out = ""
    let mut k = i
    while k <= j { out = out + s[k]; k = k + 1 }
    return out
}

fn list_dir_hexa(dir) {
    let raw = exec("ls " + dir + "/*.hexa 2>/dev/null")
    if raw == "" { return [] }
    let lines = raw.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let s = strip(lines[i])
        if s != "" { out = out.push(s) }
        i = i + 1
    }
    return out
}

fn basename_noext(path) {
    let mut last = -1
    let mut i = 0
    while i < len(path) { if path[i] == "/" { last = i } ; i = i + 1 }
    let start = last + 1
    let mut out = ""
    let mut k = start
    while k < len(path) { out = out + path[k]; k = k + 1 }
    if len(out) > 5 {
        let n = len(out)
        let dot = out[n - 5]
        if dot == "." {
            let mut m = ""
            let mut q = 0
            while q < n - 5 { m = m + out[q]; q = q + 1 }
            return m
        }
    }
    return out
}

fn annot_val(line, tag) {
    let prefix = "// @" + tag
    if !line.starts_with(prefix) { return "" }
    let mut i = len(prefix)
    while i < len(line) && (line[i] == " " || line[i] == "\t") { i = i + 1 }
    let mut out = ""
    while i < len(line) { out = out + line[i]; i = i + 1 }
    return strip(out)
}

fn split_by_comma(s) {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        if s[i] == "," { out = out.push(strip(cur)); cur = "" } else { cur = cur + s[i] }
        i = i + 1
    }
    let last = strip(cur)
    if last != "" { out = out.push(last) }
    return out
}

// Read file, extract (keys: string, is_method: bool, arity: string) from
// annotations near the top (scan first ~5 lines). arity is "" if not
// declared (current dispatcher behavior — no check), "*" for wildcard
// (variadic, e.g. syscall), or a decimal digit string like "1"/"2" for a
// fixed-arity guard. Only builtin files carry @arity.
// Returns ["", false, ""] if no @name/@method/@kinds annotation found.
fn read_annot(path, cat) {
    let src = read_file(path)
    if src == "" { return ["", false, ""] }
    let lines = src.split("\n")
    // First pass: scan for @arity anywhere in the top window (builtin only).
    let mut arity = ""
    if cat == "builtin" {
        let mut ai = 1
        while ai < len(lines) && ai < 5 {
            let sa = strip(lines[ai])
            if sa != "" {
                let av = annot_val(sa, "arity")
                if av != "" { arity = av; ai = 5 }
            }
            ai = ai + 1
        }
    }
    // Second pass: resolve the primary annotation (@name/@method/@kinds).
    let mut i = 1
    while i < len(lines) && i < 5 {
        let s = strip(lines[i])
        if s != "" {
            if cat == "builtin" {
                let n = annot_val(s, "name")
                if n != "" { return [n, false, arity] }
                let m = annot_val(s, "method")
                if m != "" { return [m, true, arity] }
            } else {
                let v = annot_val(s, "kinds")
                if v != "" { return [v, false, ""] }
            }
        }
        i = i + 1
    }
    return ["", false, ""]
}

// Pad a string to width `w` with trailing spaces, for column alignment.
fn pad(s, w) {
    let mut out = s
    while len(out) < w { out = out + " " }
    return out
}

fn main() {
    let mut out = "// self/poc/_dispatch.hexa\n"
    out = out + "//\n"
    out = out + "// AUTO-GENERATED by scripts/poc_gen_dispatch.hexa — do not edit.\n"
    out = out + "// Regenerate: hexa scripts/poc_gen_dispatch.hexa\n"
    out = out + "//\n"
    out = out + "// Dispatchers read from self/poc/<cat>/<snake>.hexa handlers via the\n"
    out = out + "// filename=dispatch-key convention. Adding a new kind = new file;\n"
    out = out + "// regenerating this file picks it up automatically.\n"
    out = out + "\n"

    // Collect per-cat: (kinds/names, fn_name) pairs.
    let mut expr_rows = []    // each: [kind, fn_name]
    let mut stmt_rows = []
    let mut bi_rows = []      // @name builtins
    let mut method_rows = []  // @method entries
    let mut c = 0
    while c < len(CATS) {
        let cat = CATS[c][0]
        let prefix = CATS[c][1]
        let dir = "self/poc/" + cat
        let files = list_dir_hexa(dir)
        let mut fi = 0
        while fi < len(files) {
            let path = files[fi]
            let base = basename_noext(path)
            let fn_name = "poc_" + prefix + "_" + base
            let r = read_annot(path, cat)
            let ann = r[0]
            let is_method = r[1]
            let arity = r[2]
            if ann == "" { fi = fi + 1; continue }
            let keys = split_by_comma(ann)
            let mut ki = 0
            while ki < len(keys) {
                let k = keys[ki]
                if k != "" {
                    if cat == "expr" { expr_rows = expr_rows.push([k, fn_name]) }
                    else if cat == "stmt" { stmt_rows = stmt_rows.push([k, fn_name]) }
                    else if is_method { method_rows = method_rows.push([k, fn_name]) }
                    else { bi_rows = bi_rows.push([k, fn_name, arity]) }
                }
                ki = ki + 1
            }
            fi = fi + 1
        }
        c = c + 1
    }

    // Emit fn poc_lower_expr.
    out = out + "fn poc_lower_expr(e) -> int {\n"
    let mut i = 0
    while i < len(expr_rows) {
        let k = expr_rows[i][0]
        let f = expr_rows[i][1]
        // Group Array + ArrayLit into a single OR row automatically? For now
        // the generator emits one line per kind — downstream short-circuit
        // evaluation means semantics are equivalent.
        out = out + "    if e.kind == " + "\"" + k + "\"" + pad("", 13 - len(k)) + " { return " + f + "(e) }\n"
        i = i + 1
    }
    out = out + "    println(\"[poc] unsupported expr kind: \" + e.kind)\n"
    out = out + "    return -1\n"
    out = out + "}\n\n"

    // Emit fn poc_lower_stmt.
    out = out + "fn poc_lower_stmt(stmt) -> int {\n"
    let mut si = 0
    while si < len(stmt_rows) {
        let k = stmt_rows[si][0]
        let f = stmt_rows[si][1]
        out = out + "    if stmt.kind == " + "\"" + k + "\"" + pad("", 17 - len(k)) + " { return " + f + "(stmt) }\n"
        si = si + 1
    }
    out = out + "    println(\"[poc] unsupported stmt kind: \" + stmt.kind)\n"
    out = out + "    return -1\n"
    out = out + "}\n\n"

    // Emit fn poc_ex_call — includes method dispatch + builtin dispatch + user fn fallback.
    out = out + "// Dispatcher for Call expressions: routes method calls, then named\n"
    out = out + "// builtins (from self/poc/builtin/), then user-defined fns.\n"
    out = out + "fn poc_ex_call(e) -> int {\n"
    // Method dispatch (for now only .push since that's the only @method).
    let mut mi = 0
    while mi < len(method_rows) {
        let k = method_rows[mi][0]       // e.g. ".push"
        let f = method_rows[mi][1]
        // Strip leading '.' if present.
        let name = if len(k) > 0 && k[0] == "." {
            let mut n = ""
            let mut q = 1
            while q < len(k) { n = n + k[q]; q = q + 1 }
            n
        } else { k }
        out = out + "    if e.left.kind == \"Field\" && e.left.name == \"" + name + "\" && len(e.args) == 1 { return " + f + "(e) }\n"
        mi = mi + 1
    }
    out = out + "    if e.left.kind != \"Ident\" {\n"
    out = out + "        println(\"[poc] call target must be Ident (PoC)\")\n"
    out = out + "        return -1\n"
    out = out + "    }\n"
    out = out + "    let name = e.left.name\n"
    let mut bi = 0
    // Group builtins with same fn (for min_max which has 2 names).
    // Emit fixed-arity guard when @arity <N> declared; skip guard for
    // wildcard ("*", e.g. syscall) or missing annotation (back-compat).
    while bi < len(bi_rows) {
        let k = bi_rows[bi][0]
        let f = bi_rows[bi][1]
        let a = bi_rows[bi][2]
        let has_arity = a != "" && a != "*"
        if has_arity {
            out = out + "    if name == \"" + k + "\"" + pad("", 14 - len(k)) + "&& len(e.args) == " + a + " { return " + f + "(e) }\n"
        } else {
            out = out + "    if name == \"" + k + "\"" + pad("", 14 - len(k)) + "{ return " + f + "(e) }\n"
        }
        bi = bi + 1
    }
    // User fn fallback.
    out = out + "    let target_fn_id = poc_fn_id_for(name)\n"
    out = out + "    if target_fn_id < 0 {\n"
    out = out + "        println(\"[poc] unbound fn: \" + name)\n"
    out = out + "        return -1\n"
    out = out + "    }\n"
    out = out + "    let mut arg_vids = []\n"
    out = out + "    let mut ai = 0\n"
    out = out + "    while ai < len(e.args) {\n"
    out = out + "        let av = poc_lower_expr(e.args[ai])\n"
    out = out + "        if av < 0 { return -1 }\n"
    out = out + "        arg_vids = arg_vids.push(av)\n"
    out = out + "        ai = ai + 1\n"
    out = out + "    }\n"
    out = out + "    let mut mi = 0\n"
    out = out + "    while mi < len(arg_vids) {\n"
    out = out + "        if arg_vids[mi] != mi { poc_emit(mn_mov(mi, arg_vids[mi])) }\n"
    out = out + "        mi = mi + 1\n"
    out = out + "    }\n"
    out = out + "    poc_emit(mn_call(target_fn_id))\n"
    out = out + "    let result_vid = poc_fresh_vid()\n"
    out = out + "    if result_vid != 0 { poc_emit(mn_mov(result_vid, 0)) }\n"
    out = out + "    return result_vid\n"
    out = out + "}\n"

    let n_expr = str(len(expr_rows))
    let n_stmt = str(len(stmt_rows))
    let n_bi = str(len(bi_rows))
    let n_m = str(len(method_rows))
    write_file("self/poc/_dispatch.hexa", out)
    println("[poc-gen] wrote self/poc/_dispatch.hexa — " + n_expr + " expr kinds, " + n_stmt + " stmt kinds, " + n_bi + " builtins, " + n_m + " methods")
}
