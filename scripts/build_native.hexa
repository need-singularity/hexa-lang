// build_native.hexa — hexa -> C -> native binary pipeline
//
// Uses hexa_v2 (self-hosted compiler) to transpile a .hexa source file
// to C, then compiles with clang to a native binary. This is the same
// pipeline that produced the 1,922x vocoder result.
//
// The generated C emits `#include "runtime.c"` which transitively
// includes native/tensor_kernels.c and native/net.c, so we stage
// runtime.c + native/ into the build dir before clang.
//
// Usage:
//   ./hexa scripts/build_native.hexa input.hexa              # -> build/input_native
//   ./hexa scripts/build_native.hexa input.hexa my_binary     # -> my_binary
//   ./hexa scripts/build_native.hexa --clean                  # remove build artifacts
//
// Environment overrides:
//   CC=gcc          ./hexa scripts/build_native.hexa foo.hexa   # swap compiler
//   CFLAGS="-O2 -g" ./hexa scripts/build_native.hexa foo.hexa  # custom flags
//   HEXA_V2=/path   ./hexa scripts/build_native.hexa foo.hexa  # custom compiler

fn die(msg) {
    eprintln("[build_native] ERROR: " + msg)
    exit(1)
}

fn info(msg) {
    println("[build_native] " + msg)
}

fn human_size(bytes) {
    if bytes >= 1048576 {
        let mb = bytes / 1048576
        let frac = (bytes % 1048576) * 10 / 1048576
        str(mb) + "." + str(frac) + " MB"
    } else if bytes >= 1024 {
        str(bytes / 1024) + " KB"
    } else {
        str(bytes) + " bytes"
    }
}

let script_path = argv()[1]
let hexa_dir = exec("cd \"$(dirname '" + script_path + "')/../\" && pwd").trim()
let build_dir = hexa_dir + "/build/native_tmp"
let mut hexa_v2_path = if env("HEXA_V2") != "" { env("HEXA_V2") } else { hexa_dir + "/self/native/hexa_v2" }
let cc = if env("CC") != "" { env("CC") } else { "clang" }
let uname = exec("uname -s").trim()

// ── --clean ────────────────────────────────────────────────────
let av = argv()
let mut input_arg = ""
let mut output_arg = ""

// Parse arguments: argv() = [program, script, arg0, arg1, ...]
if len(av) >= 3 {
    input_arg = av[2]
} else {
    eprintln("Usage: ./hexa scripts/build_native.hexa INPUT.hexa [OUTPUT]")
    eprintln("       ./hexa scripts/build_native.hexa --clean")
    exit(1)
}

if len(av) >= 4 {
    output_arg = av[3]
}

if input_arg == "--clean" {
    info("cleaning " + build_dir)
    exec("rm -rf " + build_dir)
    info("done")
    exit(0)
}

// resolve to absolute path
let mut input = input_arg
if !input.starts_with("/") {
    let cwd = exec("pwd").trim()
    input = cwd + "/" + input
}

if !file_exists(input) {
    die("input file not found: " + input)
}

// derive output name
let mut output = ""
if output_arg != "" {
    output = output_arg
    if !output.starts_with("/") {
        let cwd = exec("pwd").trim()
        output = cwd + "/" + output
    }
} else {
    let basename = exec("basename " + input + " .hexa").trim()
    output = hexa_dir + "/build/" + basename + "_native"
}

// ── preflight checks ─────────────────────────────────────────
let v2_check = exec_with_status("test -x " + hexa_v2_path)
if v2_check[1] != 0 {
    die("hexa_v2 compiler not found at " + hexa_v2_path)
}

let cc_check = exec_with_status("command -v " + cc + " >/dev/null 2>&1")
if cc_check[1] != 0 {
    die(cc + " not found in PATH")
}

let runtime_c = hexa_dir + "/self/runtime.c"
let native_dir = hexa_dir + "/self/native"
if !file_exists(runtime_c) {
    die("runtime.c not found at " + runtime_c)
}
if !file_exists(native_dir + "/tensor_kernels.c") {
    die("native/tensor_kernels.c not found")
}
if !file_exists(native_dir + "/net.c") {
    die("native/net.c not found")
}

// ── prepare build dir ─────────────────────────────────────────
exec("mkdir -p " + build_dir + "/native")
exec("mkdir -p \"$(dirname '" + output + "')\"")

// Stage runtime files from working tree.
exec("cp -f " + runtime_c + " " + build_dir + "/runtime.c")
exec("cp -f " + native_dir + "/tensor_kernels.c " + build_dir + "/native/tensor_kernels.c")
if file_exists(native_dir + "/net.c") {
    exec("cp -f " + native_dir + "/net.c " + build_dir + "/native/net.c")
} else {
    let git_check = exec_with_status("git -C " + hexa_dir + " rev-parse HEAD >/dev/null 2>&1")
    if git_check[1] == 0 {
        exec("git -C " + hexa_dir + " show HEAD:self/native/net.c > " + build_dir + "/native/net.c")
    }
}

// ── step 1: hexa_v2 transpile ────────────────────────────────
let gen_c = build_dir + "/gen.c"
let input_basename = exec("basename " + input).trim()
info("transpile: " + hexa_v2_path + " " + input_basename + " -> gen.c")
let transpile_result = exec_with_status(hexa_v2_path + " " + input + " " + gen_c)
if transpile_result[1] != 0 {
    die("hexa_v2 transpile failed")
}
if !file_exists(gen_c) {
    die("hexa_v2 produced no output")
}

let gen_size = to_int(exec("wc -c < " + gen_c + " | tr -d ' '").trim())
info("generated C: " + human_size(gen_size))

// ── step 1b: NaN-boxing FFI pointer fix ──────────────────────
// Until hexa_v2 is rebuilt with the HX_INT_U codegen change,
// post-process generated C to use unsigned pointer extraction
// in FFI dispatch lines. Fixes ARM64 cstring() corruption.
let hx_int_u_check = exec_with_status("grep -q 'HX_INT_U' " + build_dir + "/runtime.c 2>/dev/null")
if hx_int_u_check[1] == 0 {
    exec("awk '{if (/__ffi_ftyp/) { gsub(/HX_INT\\(/, \"HX_INT_U(\"); gsub(/HX_IS_INT_U/, \"HX_IS_INT\") } print}' " + gen_c + " > " + gen_c + ".tmp && mv " + gen_c + ".tmp " + gen_c)
    info("applied HX_INT_U FFI pointer fix")
}

// ── step 2: clang compile ────────────────────────────────────
let default_cflags = "-O3"
let mut default_ldflags = "-lm -ldl"
if uname != "Linux" && uname != "Darwin" {
    default_ldflags = "-lm"
}

let cflags = if env("CFLAGS") != "" { env("CFLAGS") } else { default_cflags }
let ldflags = if env("LDFLAGS") != "" { env("LDFLAGS") } else { default_ldflags }

// Optionally link hxvocoder.c for native FFI shims
let mut extra_src = ""
let hxvocoder_c = native_dir + "/hxvocoder.c"
if file_exists(hxvocoder_c) {
    extra_src = hxvocoder_c
    info("linking hxvocoder.c (static FFI shims)")
}

let output_basename = exec("basename " + output).trim()
info("compile: " + cc + " " + cflags + " -I" + build_dir + " -o " + output_basename + " gen.c " + ldflags)
let compile_result = exec_with_status(cc + " " + cflags + " -I" + build_dir + " -o " + output + " " + gen_c + " " + extra_src + " " + ldflags)
if compile_result[1] != 0 {
    die("clang compilation failed")
}

let exec_check = exec_with_status("test -x " + output)
if exec_check[1] != 0 {
    die("compilation produced no executable")
}

// ── report ────────────────────────────────────────────────────
let bin_size = to_int(exec("wc -c < " + output + " | tr -d ' '").trim())
info("OK: " + output + " (" + human_size(bin_size) + ")")
