// ═══════════════════════════════════════════════════════════════
//  deploy_h100.hexa — H100 서버에 hexa 배포
//
//  사용법:
//    hexa scripts/deploy_h100.hexa <user@host> [remote_dir]
//    hexa scripts/deploy_h100.hexa root@h100.example.com /opt/hexa
//
//  수행:
//    1. Linux x86_64 릴리스 빌드 (--no-default-features)
//    2. hexa 바이너리 + ML 파일 scp
//    3. 원격에서 gpu_smoke_test 실행
//
//  요구: 로컬에 x86_64-unknown-linux-gnu 타겟
//        원격에 CUDA toolkit (/usr/local/cuda)
// ═══════════════════════════════════════════════════════════════

let args = argv()
if len(args) < 2 {
    println("Usage: hexa scripts/deploy_h100.hexa <user@host> [remote_dir]")
    println("  e.g. hexa scripts/deploy_h100.hexa root@gpu-server /opt/hexa")
    exit(1)
}

let HOST = args[1]
let REMOTE_DIR = if len(args) >= 3 { args[2] } else { "/opt/hexa" }

println("═══ hexa H100 Deploy ═══")
println("Target: " + HOST + ":" + REMOTE_DIR)

// ── 1. Cross-compile (self-host) ───────────────────────────
// 2026-04-11: src/ deleted, cargo removed. Cross-compilation via
// self-host codegen is not yet implemented for x86_64-linux-gnu.
// For H100 deploy, either:
//   (a) use a precompiled Linux hexa binary (bin/hexa-linux-x86_64)
//   (b) run build_hexa.hexa on the target Linux machine natively
//   (c) bootstrap via stage1 (hexa→C) + remote clang
println("[1/4] Locating Linux hexa binary...")
let binary = "bin/hexa-linux-x86_64"
if !file_exists(binary) {
    println("[ERROR] Linux binary not found: " + binary)
    println("  TODO: self-host cross-compile to x86_64-linux-gnu")
    println("  Workaround: ssh to H100 and run build_hexa.hexa there")
    exit(1)
}
println("[OK] Binary built: " + binary)

// ── 2. Create remote directory ──────────────────────────────
println("[2/4] Creating remote directory...")
let _ = exec("ssh " + HOST + " 'mkdir -p " + REMOTE_DIR + "/self/ml " + REMOTE_DIR + "/self/serve'")

// ── 3. Upload files ─────────────────────────────────────────
println("[3/4] Uploading files...")

// Binary
let _ = exec("scp " + binary + " " + HOST + ":" + REMOTE_DIR + "/hexa")
let _ = exec("ssh " + HOST + " 'chmod +x " + REMOTE_DIR + "/hexa'")

// GPU ML files
let gpu_files = [
    "cuda_ffi", "gpu_tensor", "gpu_grad_engine", "gpu_optimizer",
    "gpu_inference", "gpu_generate", "gpu_sampler", "gpu_kv_cache",
    "model_100m_gpu", "train_gpu", "t2_gpu_bench", "gpu_smoke_test"
]
let cpu_support = [
    "sampler", "kv_cache", "transformer", "generate", "device",
    "offload", "checkpoint", "quantize", "distributed",
    "distributed_train", "model_parallel", "zero_shard",
    "monitor", "profiler", "optimizer", "grad_engine",
    "model_100m", "train_full", "eval", "eval_runner",
    "embedding", "vector_store", "rag", "dataloader",
    "data_pipeline", "tokenizer", "finetune", "dpo",
    "rlhf", "batch_inference", "streaming", "pipeline",
    "gguf_loader", "gguf_writer", "onnx_writer", "visualize",
    "reward_model"
]

let all_files = gpu_files + cpu_support
let mut i = 0
while i < len(all_files) {
    let f = all_files[i]
    let src = "self/ml/" + f + ".hexa"
    if file_exists(src) {
        let _ = exec("scp " + src + " " + HOST + ":" + REMOTE_DIR + "/self/ml/")
    }
    i = i + 1
}

println("[OK] " + str(len(all_files)) + " files uploaded")

// ── 4. Run smoke test ───────────────────────────────────────
println("[4/4] Running GPU smoke test...")
let smoke_cmd = "ssh " + HOST + " 'cd " + REMOTE_DIR + " && LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH:-} ./hexa self/ml/gpu_smoke_test.hexa'"
let smoke_rc = exec(smoke_cmd)

println("")
println("═══ Deploy Complete ═══")
println("")
println("사용법 (원격):")
println("  ssh " + HOST)
println("  cd " + REMOTE_DIR)
println("  export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH")
println("")
println("  ./hexa self/ml/gpu_smoke_test.hexa    # 스모크 테스트")
println("  ./hexa self/ml/t2_gpu_bench.hexa      # TFLOPS 벤치")
println("  ./hexa self/ml/train_gpu.hexa          # GPU 학습 103M")
println("  ./hexa self/ml/gpu_generate.hexa       # GPU 추론")

if smoke_rc == 0 {
    println("")
    println("STATUS: READY — H100 ML 워크로드 실행 가능")
}
