// infinite_growth.hexa — ported from scripts/infinite_growth.sh
// Growth daemon for hexa-lang project

let growth_name = "hexa-lang"
let project_root = exec("cd \"$(dirname \"$0\")/..\" && pwd").trim()
let domain = "programming_language"
let max_cycles = int(env("MAX_CYCLES") ?? args(1) ?? "999")
let interval = int(env("INTERVAL") ?? args(2) ?? "1800")
let dry_run = args(3) ?? "false"

let common = env("HOME") + "/Dev/nexus/scripts/lib/growth_common.sh"
// Note: In Hexa we cannot source a bash lib directly.
// The growth_common functions (log_info, write_growth_bus, run_growth_loop)
// would need native Hexa equivalents. Below we define minimal stubs.

fn log_info(msg) {
    print("[" + growth_name + "] " + msg)
}

fn write_growth_bus(key, status, detail) {
    // Stub: in full port, this writes to the growth bus
    log_info("  bus: " + key + " = " + status + " (" + detail + ")")
}

let cargo = env("HOME") + "/.cargo/bin/cargo"

fn domain_phases(cycle, load) {
    // Phase 1: Keyword implementation status
    log_info("Phase 1: Keyword implementation")
    let token_file = project_root + "/src/token.rs"
    if file_exists(token_file) {
        let kw_count = exec("grep -c '\"[a-z]*\" => Some(Token::' " + token_file + " 2>/dev/null || echo 0").trim()
        log_info("  Keywords in token.rs: " + kw_count)
        let parser_file = project_root + "/src/parser.rs"
        if file_exists(parser_file) {
            let parser_refs = exec("grep -c 'Token::' " + parser_file + " 2>/dev/null || echo 0").trim()
            log_info("  Parser token refs: " + parser_refs)
        }
        write_growth_bus("keywords", "ok", "count=" + kw_count)
    } else {
        log_info("  token.rs not found")
        write_growth_bus("keywords", "skip", "no_token_rs")
    }

    // Phase 2: Operator coverage
    log_info("Phase 2: Operator coverage")
    let test_dir = project_root + "/examples"
    if dir_exists(test_dir) {
        let test_count = exec("ls " + test_dir + "/test_*.hexa 2>/dev/null | wc -l | tr -d ' '").trim()
        log_info("  Test files: " + test_count)
        let symbols = ["+", "-", "*", "/", "%", "==", "!=", "<=", ">=", "&&", "||"]
        let mut op_hits = 0
        for sym in symbols {
            let escaped = exec("printf '%s' '" + sym + "' | sed 's/[.*+?^${}()|[\\]\\\\]/\\\\&/g'").trim()
            let found = exec("grep -q '" + escaped + "' " + test_dir + "/*.hexa 2>/dev/null && echo yes || echo no").trim()
            if found == "yes" {
                op_hits = op_hits + 1
            }
        }
        log_info("  Operators tested: " + str(op_hits) + "/11")
        write_growth_bus("operators", "ok", "tests=" + test_count + ",ops=" + str(op_hits))
    } else {
        log_info("  examples/ not found")
        write_growth_bus("operators", "skip", "no_examples")
    }

    if load == "LIGHT" {
        return
    }

    // Phase 3: Parser health (cargo test)
    log_info("Phase 3: Parser health")
    if file_exists(project_root + "/Cargo.toml") && file_exists(cargo) {
        let test_output = exec(cargo + " test --manifest-path " + project_root + "/Cargo.toml -- --quiet 2>&1 || true")
        let passed = exec("echo '" + test_output + "' | grep -o '[0-9]* passed' | head -1 | grep -o '[0-9]*' || echo 0").trim()
        let failed = exec("echo '" + test_output + "' | grep -o '[0-9]* failed' | head -1 | grep -o '[0-9]*' || echo 0").trim()
        log_info("  Tests: " + passed + " passed, " + failed + " failed")
        write_growth_bus("parser_health", "ok", "passed=" + passed + ",failed=" + failed)
    } else {
        log_info("  No Cargo.toml or cargo")
        write_growth_bus("parser_health", "skip", "no_cargo")
    }

    // Phase 4: Codegen completeness
    log_info("Phase 4: Codegen completeness")
    let backends = ["wasm", "codegen_wgsl", "codegen_esp32", "codegen_verilog", "jit", "vm"]
    let mut found_backends = 0
    let total_backends = backends.len()
    for backend in backends {
        let f = project_root + "/src/" + backend + ".rs"
        if file_exists(f) {
            found_backends = found_backends + 1
            let lines = exec("wc -l < " + f + " | tr -d ' '").trim()
            let todos = exec("grep -ci 'todo\\|unimplemented' " + f + " 2>/dev/null || echo 0").trim()
            log_info("  " + backend + ": " + lines + " lines, " + todos + " TODOs")
        } else {
            log_info("  " + backend + ": MISSING")
        }
    }
    write_growth_bus("codegen", "ok", "found=" + str(found_backends) + "/" + str(total_backends))

    // Phase 5: REPL features
    log_info("Phase 5: REPL features")
    let main_file = project_root + "/src/main.rs"
    if file_exists(main_file) {
        let features = ["completion", "history", "multiline", "highlight", "type_info", "help", "benchmark"]
        let mut feat_found = 0
        let feat_total = features.len()
        for feat in features {
            let found = exec("grep -qi '" + feat + "' " + main_file + " " + project_root + "/src/interpreter.rs " + project_root + "/src/lsp.rs 2>/dev/null && echo yes || echo no").trim()
            if found == "yes" {
                feat_found = feat_found + 1
            }
        }
        log_info("  REPL features: " + str(feat_found) + "/" + str(feat_total))
        write_growth_bus("repl", "ok", "features=" + str(feat_found) + "/" + str(feat_total))
    } else {
        log_info("  main.rs not found")
        write_growth_bus("repl", "skip", "no_main")
    }

    // Phase 6: Growth scan
    log_info("Phase 6: Growth scan")
    let scan_py = project_root + "/.growth/scan.py"
    if file_exists(scan_py) {
        let scan_output = exec("python3 " + scan_py + " 2>&1 | tail -10")
        for line in scan_output.split("\n") {
            log_info("  " + line)
        }
        write_growth_bus("growth_scan", "ok", "scanned")
    } else {
        log_info("  scan.py not found")
        write_growth_bus("growth_scan", "skip", "no_scanner")
    }
}

// Main growth loop
for cycle in 1..=max_cycles {
    let load = if cycle % 3 == 0 { "FULL" } else { "LIGHT" }
    log_info("=== Cycle " + str(cycle) + "/" + str(max_cycles) + " (load=" + load + ") ===")
    domain_phases(cycle, load)
    if cycle < max_cycles {
        log_info("Sleeping " + str(interval) + "s...")
        sleep(interval)
    }
}
log_info("Growth loop complete.")
