// ai_native_testgen — generate property tests from @attr catalog (S-4 skeleton)
//
// Reads shared/hexa-lang/attrs.json to learn what each @attr promises.
// Scans a target .hexa file for @attr annotations on fn definitions.
// Emits property-style tests that verify the promise.
//
// Supported generators (minimal initial set):
//   @pure     → determinism check: call fn(args) twice, expect ==
//   @memoize  → equivalence check: disabled-memo vs enabled-memo produce ==
//   @limit    → re-entrancy check: second call while first active throws
//
// Usage:
//   hexa scripts/ai_native_testgen.hexa <source.hexa>
//     → emits tests_auto/<basename>_prop_tests.hexa
//
// Status: skeleton — detects annotations + emits test scaffolds. Full
// correctness verification (random-input generation per signature)
// requires parser-level type inference (deferred to S-4b).

fn is_alpha(c) { let k = char_code(c, 0); return (k >= 97 && k <= 122) || (k >= 65 && k <= 90) || k == 95 }
fn is_alnum(c) { let k = char_code(c, 0); return (k >= 48 && k <= 57) || (k >= 97 && k <= 122) || (k >= 65 && k <= 90) || k == 95 }

// find all `@attr` `fn name(params)` sequences. Returns [[attr, fn_name, params_str, line]]
fn find_annotated_fns(src) {
    let n = len(src)
    let mut i = 0
    let mut line = 1
    let mut out = []
    while i < n {
        let c = src[i]
        if c == "\n" { line = line + 1; i = i + 1; continue }
        if c == "@" && i + 1 < n && is_alpha(src[i + 1]) {
            // collect @attr
            let mut k = i + 1
            while k < n && is_alnum(src[k]) { k = k + 1 }
            let attr = src.substring(i + 1, k)
            // skip whitespace + optional `pub`
            while k < n && (src[k] == " " || src[k] == "\n" || src[k] == "\t") {
                if src[k] == "\n" { line = line + 1 }
                k = k + 1
            }
            // optional `pub`
            if k + 4 <= n && src.substring(k, k + 4) == "pub " {
                k = k + 4
            }
            while k < n && (src[k] == " " || src[k] == "\t") { k = k + 1 }
            // expect `fn `
            if k + 3 <= n && src.substring(k, k + 3) == "fn " {
                k = k + 3
                while k < n && src[k] == " " { k = k + 1 }
                let name_start = k
                while k < n && is_alnum(src[k]) { k = k + 1 }
                let fn_name = src.substring(name_start, k)
                // collect params up to matching `)`
                while k < n && src[k] == " " { k = k + 1 }
                if k < n && src[k] == "(" {
                    let pstart = k + 1
                    let mut depth = 1
                    let mut p = k + 1
                    while p < n && depth > 0 {
                        if src[p] == "(" { depth = depth + 1 }
                        if src[p] == ")" { depth = depth - 1 }
                        if depth > 0 { p = p + 1 }
                    }
                    let params = src.substring(pstart, p)
                    out = out.push([attr, fn_name, params, line])
                    i = p + 1
                    continue
                }
            }
            i = k
            continue
        }
        i = i + 1
    }
    return out
}

// Minimal param parser: split by `,`, take first word as name. Returns [names...]
fn parse_param_names(params) {
    if params.trim() == "" { return [] }
    let parts = params.split(",")
    let mut out = []
    let mut i = 0
    while i < len(parts) {
        let p = parts[i].trim()
        let mut k = 0
        while k < len(p) && is_alnum(p[k]) { k = k + 1 }
        let name = p.substring(0, k)
        if name != "" { out = out.push(name) }
        i = i + 1
    }
    return out
}

// Emit a single test block for one (attr, fn_name, params) combo.
// Returns a string of hexa code.
fn emit_test(attr, fn_name, params) {
    let param_names = parse_param_names(params)
    // Generate dummy arguments: int 7 for each param
    let mut args = ""
    let mut i = 0
    while i < len(param_names) {
        if args != "" { args = args + ", " }
        args = args + "7"
        i = i + 1
    }

    if attr == "pure" {
        return "fn test_pure_" + fn_name + "() {\n" +
               "    let a = " + fn_name + "(" + args + ")\n" +
               "    let b = " + fn_name + "(" + args + ")\n" +
               "    if a != b { println(\"FAIL: @pure " + fn_name + " non-deterministic\"); return }\n" +
               "    println(\"PASS: @pure " + fn_name + "\")\n" +
               "}\n"
    }
    if attr == "memoize" || attr == "cache" || attr == "memo" {
        return "fn test_memoize_" + fn_name + "() {\n" +
               "    let a = " + fn_name + "(" + args + ")\n" +
               "    let b = " + fn_name + "(" + args + ")    // second call hits cache\n" +
               "    if a != b { println(\"FAIL: @memoize " + fn_name + " returned different value from cache\"); return }\n" +
               "    println(\"PASS: @memoize " + fn_name + "\")\n" +
               "}\n"
    }
    if attr == "limit" {
        return "fn test_limit_" + fn_name + "() {\n" +
               "    // @limit singleton check: sequential calls OK\n" +
               "    let a = " + fn_name + "(" + args + ")\n" +
               "    let b = " + fn_name + "(" + args + ")\n" +
               "    println(\"PASS: @limit " + fn_name + " sequential\")\n" +
               "}\n"
    }
    return "// TODO testgen: no generator for @" + attr + " on " + fn_name + "\n"
}

fn basename(path) {
    let parts = path.split("/")
    return parts[len(parts) - 1]
}

fn main() {
    let argv = args()
    if len(argv) < 3 {
        println("usage: ai_native_testgen.hexa <source.hexa>")
        return
    }
    let src_path = argv[2]
    let src = read_file(src_path)
    let annotated = find_annotated_fns(src)
    if len(annotated) == 0 {
        println("ai-native-testgen: 0 annotated fns in " + src_path)
        return
    }
    // Output path
    let base = basename(src_path)
    let stem = base.substring(0, len(base) - 5)  // strip .hexa
    let out_dir = env_var("HEXA_LANG") + "/tests_auto"
    try { exec("mkdir -p '" + out_dir + "'") } catch e { }
    let out_path = out_dir + "/" + stem + "_prop_tests.hexa"

    let mut body = "// AUTO-GENERATED from " + src_path + "\n"
    body = body + "// ai_native_testgen — do not edit; regenerate instead.\n\n"
    // Inline the source (minus any top-level main() call) so we don't depend
    // on hexa's `use` module resolution (relative paths don't resolve here).
    // Strip a trailing `main()` invocation if present.
    let mut src_inline = src
    let mlen = len(src_inline)
    if mlen >= 7 && src_inline.substring(mlen - 7, mlen) == "main()\n" {
        src_inline = src_inline.substring(0, mlen - 7)
    }
    body = body + src_inline + "\n"

    let mut i = 0
    let mut generated = 0
    while i < len(annotated) {
        let a = annotated[i]
        let test_code = emit_test(a[0], a[1], a[2])
        body = body + test_code + "\n"
        generated = generated + 1
        i = i + 1
    }

    // Runner
    body = body + "fn main() {\n"
    let mut j = 0
    while j < len(annotated) {
        let a = annotated[j]
        let fn_name = a[1]
        let attr = a[0]
        if attr == "pure" || attr == "memoize" || attr == "cache" || attr == "memo" || attr == "limit" {
            body = body + "    test_" + attr + "_" + fn_name + "()\n"
        }
        j = j + 1
    }
    body = body + "}\n\nmain()\n"

    write_file(out_path, body)
    println("ai-native-testgen: " + to_string(generated) + " tests → " + out_path)
}

