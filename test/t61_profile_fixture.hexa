// t61 — fixture for ai_native_profile.hexa
// fib_rec is called many times (recursive), hot() once, cold() never.
// Expected: profile shows fib_rec >> hot > cold=0.

fn fib_rec(n) {
    if n < 2 { return n }
    return fib_rec(n - 1) + fib_rec(n - 2)
}

fn hot() {
    let x = fib_rec(6)
    return x
}

fn cold() {
    return 0
}

fn main() {
    println(hot())
}

main()
