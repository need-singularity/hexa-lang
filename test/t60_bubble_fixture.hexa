// t60_bubble_fixture — fixture for self/opt/algorithm_swap detection.
// Contains:
//   - bubble_sort     (SHOULD detect: nested loops + swap pattern)
//   - insertion_sort  (SHOULD detect: backward shift pattern)
//   - sum_array       (SHOULD NOT flag: single loop, no swap/shift)

fn bubble_sort(a) {
    let n = len(a)
    let mut i = 0
    while i < n - 1 {
        let mut j = 0
        while j < n - i - 1 {
            if a[j] > a[j + 1] {
                let tmp = a[j]
                a[j] = a[j + 1]
                a[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    return a
}

fn insertion_sort(a) {
    let n = len(a)
    let mut i = 1
    while i < n {
        let key = a[i]
        let mut j = i
        while j > 0 && a[j - 1] > key {
            a[j] = a[j - 1]
            j = j - 1
        }
        a[j] = key
        i = i + 1
    }
    return a
}

fn sum_array(a) {
    let n = len(a)
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + a[i]
        i = i + 1
    }
    return s
}

fn main() {
    let arr = [3, 1, 4, 1, 5, 9, 2, 6]
    bubble_sort(arr)
    insertion_sort(arr)
    let total = sum_array(arr)
    println("total=" + to_string(total))
}

main()
