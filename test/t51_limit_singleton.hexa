// t51 — @limit singleton enforcement
// - normal sequential calls pass (count returns to 0 after each)
// - recursive self-call trips singleton (count > 0 on re-entry)

@limit fn singleton_ok() {
    return 1
}

@limit fn singleton_recurse(n) {
    if n > 0 {
        return singleton_recurse(n - 1)
    }
    return 0
}

fn main() {
    let a = singleton_ok()
    let b = singleton_ok()
    println("sequential=" + to_string(a + b))

    try {
        let r = singleton_recurse(1)
        println("recurse_unexpected=" + to_string(r))
    } catch e {
        if e.contains("@limit") && e.contains("singleton") {
            println("recurse_caught=OK")
        } else {
            println("recurse_caught=WRONG_MSG:" + e)
        }
    }

    println("PASS t51_limit_singleton")
}

main()
