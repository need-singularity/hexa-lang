#!hexa lax
// test/test_drill_classify.hexa — unit tests for tool/drill_classify.hexa
//
// Runs all 3 fixtures and checks verdict:
//   drill_saturated.jsonl -> "saturated"
//   drill_absorbed.jsonl  -> "absorbed"
//   drill_ongoing.jsonl   -> "ongoing"
//
// Exit 0 on all pass, 1 on any fail.

fn _project_root() {
    let av = argv()
    if len(av) >= 2 {
        let script = av[1]
        let r = exec("cd \"$(dirname '" + script + "')/../\" 2>/dev/null && pwd").trim()
        if r != "" { return r }
    }
    return exec("pwd").trim()
}

let ROOT = _project_root()
let HEXA = ROOT + "/hexa"
let TOOL = ROOT + "/tool/drill_classify.hexa"
let CRIT = ROOT + "/tool/drill_breakthrough_criteria.json"
let FIX  = ROOT + "/test/fixtures"

fn run_case(name, fixture, expected) {
    let cmd = "HEXA_VAL_ARENA=0 " + HEXA + " " + TOOL + " --criteria " + CRIT + " " + FIX + "/" + fixture + " 2>&1"
    let r = exec_with_status(cmd)
    let got = r[0].trim()
    // strip any trailing non-verdict lines — expect single-line output
    let lines = got.split("\n")
    let verdict = lines[len(lines) - 1].trim()
    if r[1] != 0 {
        println("[FAIL] " + name + " — exit=" + str(r[1]) + " out=[" + got + "]")
        return 1
    }
    if verdict == expected {
        println("[PASS] " + name + " — verdict=" + verdict)
        return 0
    }
    println("[FAIL] " + name + " — expected=" + expected + " got=" + verdict)
    return 1
}

fn main() {
    println("[test_drill_classify] root = " + ROOT)
    if !file_exists(HEXA) {
        eprintln("[test_drill_classify] missing hexa binary at " + HEXA)
        return 2
    }
    if !file_exists(TOOL) {
        eprintln("[test_drill_classify] missing classifier at " + TOOL)
        return 2
    }
    let mut fails = 0
    fails = fails + run_case("saturated", "drill_saturated.jsonl", "saturated")
    fails = fails + run_case("absorbed",  "drill_absorbed.jsonl",  "absorbed")
    fails = fails + run_case("ongoing",   "drill_ongoing.jsonl",   "ongoing")
    if fails == 0 {
        println("[test_drill_classify] ALL 3 PASS")
        return 0
    }
    println("[test_drill_classify] FAILED " + str(fails) + "/3")
    return 1
}

exit(main())
