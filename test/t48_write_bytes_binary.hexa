// t48_write_bytes_binary — write_bytes/read_file_bytes binary roundtrip + null safety
// EXPECTED: ALL PASS
//
// Locks down the binary I/O path underpinning native binary emission
// (codegen_native.hexa). Covers the three regression classes that
// broke prior revisions:
//   - NULL byte truncation (fputs → fwrite fix, commit 404f3ad)
//   - ASCII digit emission instead of raw bytes (commit b7cc2e9)
//   - length mismatch / zero-length empty-array handling
//
// Related commits: 785454c, dc8bf2e, b7cc2e9, 404f3ad.

let mut total_pass = 0
let mut total_fail = 0

// --- Test 1: edge-case bytes including NULL at index 0, 0x80, 0xff ---
let path1 = "/tmp/t48_edgebytes.bin"
let b1 = [0x00, 0x01, 0x80, 0xff]
write_bytes(path1, b1)
let r1 = read_file_bytes(path1)
let mut ok1 = true
if len(r1) != 4 { ok1 = false }
if ok1 {
    let mut i = 0
    while i < 4 {
        if r1[i] != b1[i] { ok1 = false }
        i = i + 1
    }
}
if ok1 {
    println("PASS test1 edge-case bytes [0x00, 0x01, 0x80, 0xff]")
    total_pass = total_pass + 1
} else {
    println("FAIL test1 edge-case bytes — len=" + to_string(len(r1)) + " expected=4")
    total_fail = total_fail + 1
}

// --- Test 2: ELF magic + 100 bytes, check length + first/last ---
let path2 = "/tmp/t48_elfmagic.bin"
let mut b2 = [0x7f, 0x45, 0x4c, 0x46]
let mut n = 0
while n < 100 {
    // Mix of low/high/null-adjacent to catch all classes of bug.
    // Cycle through 0x00..0xff via (n * 37 + 13) mod 256.
    let byte = (n * 37 + 13) % 256
    b2.push(byte)
    n = n + 1
}
write_bytes(path2, b2)
let r2 = read_file_bytes(path2)
let mut ok2 = true
if len(r2) != 104 { ok2 = false }
if ok2 && r2[0] != 0x7f { ok2 = false }
if ok2 && r2[1] != 0x45 { ok2 = false }
if ok2 && r2[2] != 0x4c { ok2 = false }
if ok2 && r2[3] != 0x46 { ok2 = false }
if ok2 && r2[103] != b2[103] { ok2 = false }
if ok2 {
    println("PASS test2 ELF magic + 100 bytes — length + first/last match")
    total_pass = total_pass + 1
} else {
    println("FAIL test2 ELF magic — len=" + to_string(len(r2)) + " expected=104")
    total_fail = total_fail + 1
}

// --- Test 3: empty array roundtrip ---
let path3 = "/tmp/t48_empty.bin"
let b3 = []
write_bytes(path3, b3)
let r3 = read_file_bytes(path3)
if len(r3) == 0 {
    println("PASS test3 empty array — len=0")
    total_pass = total_pass + 1
} else {
    println("FAIL test3 empty array — len=" + to_string(len(r3)) + " expected=0")
    total_fail = total_fail + 1
}

// --- Test 4: 8192 bytes cycling 0..255 ---
let path4 = "/tmp/t48_8192.bin"
let mut b4 = []
let mut k = 0
while k < 8192 {
    b4.push(k % 256)
    k = k + 1
}
write_bytes(path4, b4)
let r4 = read_file_bytes(path4)
let mut ok4 = true
if len(r4) != 8192 { ok4 = false }
if ok4 {
    let mut j = 0
    while j < 8192 {
        if r4[j] != (j % 256) { ok4 = false; j = 8192 }
        j = j + 1
    }
}
if ok4 {
    println("PASS test4 8192-byte cycle 0..255")
    total_pass = total_pass + 1
} else {
    println("FAIL test4 8192-byte cycle — len=" + to_string(len(r4)) + " expected=8192")
    total_fail = total_fail + 1
}

println("----")
println("summary: " + to_string(total_pass) + " pass / " + to_string(total_fail) + " fail")
if total_fail == 0 {
    println("ALL PASS")
}
