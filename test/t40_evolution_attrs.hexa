@stable fn frozen_func() {
    return 42
}

@track fn tracked_func() {
    return 100
}

@deprecated fn old_func() {
    return "legacy"
}

fn main() {
    println("frozen=" + to_string(frozen_func()))
    println("tracked=" + to_string(tracked_func()))
    println("old=" + old_func())
    // Call deprecated again — should NOT warn twice
    let x = old_func()
    println("PASS t40_evolution_attrs")
}

main()
