// tests/t_batch22_print_fmt_pure.hexa — Batch 22 runnable asserts.
//
// Exercises the five builtins from self/runtime/print_fmt_pure.hexa:
//   table_render_pure, tree_render_pure, box_render_pure,
//   align_cols_pure, truncate_ellipsis_pure
//
// Codegen cannot resolve imports for test files — inlined per the
// standard convention used by self/test_*_pure.hexa.

// ═══════════════════════════════════════════════════════════════════
//  ── INLINED: self/runtime/print_fmt_pure.hexa ──
// ═══════════════════════════════════════════════════════════════════

@pure
fn _pf_repeat(s, n) {
    if n <= 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        parts.push(s)
        i = i + 1
    }
    return parts.join("")
}

@pure
fn _pf_pad_right(s, width) {
    let slen = len(s)
    if slen >= width { return s }
    return s + _pf_repeat(" ", width - slen)
}

@pure
fn _pf_col_width(rows, col) {
    let n = len(rows)
    let mut w = 0
    let mut i = 0
    while i < n {
        let row = rows[i]
        if col < len(row) {
            let cl = len(row[col])
            if cl > w { w = cl }
        }
        i = i + 1
    }
    return w
}

@pure
fn _pf_max_cols(rows) {
    let n = len(rows)
    let mut mc = 0
    let mut i = 0
    while i < n {
        let rl = len(rows[i])
        if rl > mc { mc = rl }
        i = i + 1
    }
    return mc
}

@pure
pub fn align_cols_pure(rows) {
    let n = len(rows)
    if n == 0 { return [] }
    let ncols = _pf_max_cols(rows)
    let mut widths = []
    let mut c = 0
    while c < ncols {
        widths.push(_pf_col_width(rows, c))
        c = c + 1
    }
    let mut out = []
    let mut i = 0
    while i < n {
        let row = rows[i]
        let rl = len(row)
        let mut new_row = []
        let mut j = 0
        while j < ncols {
            let cell = if j < rl { row[j] } else { "" }
            new_row.push(_pf_pad_right(cell, widths[j]))
            j = j + 1
        }
        out.push(new_row)
        i = i + 1
    }
    return out
}

@pure
pub fn truncate_ellipsis_pure(s, max) {
    if max <= 0 { return "" }
    let slen = len(s)
    if slen <= max { return s }
    if max <= 3 { return s.substring(0, max) }
    return s.substring(0, max - 3) + "..."
}

@pure
fn _pf_render_row(cells, widths) {
    let n = len(widths)
    let mut parts = ["|"]
    let mut j = 0
    while j < n {
        let cell = if j < len(cells) { cells[j] } else { "" }
        parts.push(" ")
        parts.push(_pf_pad_right(cell, widths[j]))
        parts.push(" |")
        j = j + 1
    }
    return parts.join("")
}

@pure
fn _pf_render_sep(widths) {
    let n = len(widths)
    let mut parts = ["|"]
    let mut j = 0
    while j < n {
        parts.push(_pf_repeat("-", widths[j] + 2))
        parts.push("|")
        j = j + 1
    }
    return parts.join("")
}

@pure
pub fn table_render_pure(rows, headers) {
    let nh = len(headers)
    let nr = len(rows)
    let data_cols = _pf_max_cols(rows)
    let ncols = if nh > data_cols { nh } else { data_cols }
    let mut widths = []
    let mut c = 0
    while c < ncols {
        let hw = if c < nh { len(headers[c]) } else { 0 }
        let dw = _pf_col_width(rows, c)
        let w = if hw > dw { hw } else { dw }
        widths.push(w)
        c = c + 1
    }
    let mut lines = []
    lines.push(_pf_render_row(headers, widths))
    lines.push(_pf_render_sep(widths))
    let mut i = 0
    while i < nr {
        lines.push(_pf_render_row(rows[i], widths))
        i = i + 1
    }
    return lines.join("\n")
}

@pure
pub fn box_render_pure(lines) {
    let n = len(lines)
    let mut max_w = 0
    let mut i = 0
    while i < n {
        let lw = len(lines[i])
        if lw > max_w { max_w = lw }
        i = i + 1
    }
    let tl = "┌"
    let tr = "┐"
    let bl = "└"
    let br = "┘"
    let horiz = "─"
    let vert = "│"
    let top = tl + _pf_repeat(horiz, max_w) + tr
    let bottom = bl + _pf_repeat(horiz, max_w) + br
    let mut parts = [top]
    let mut k = 0
    while k < n {
        let padded = _pf_pad_right(lines[k], max_w)
        parts.push(vert + padded + vert)
        k = k + 1
    }
    parts.push(bottom)
    return parts.join("\n")
}

@pure
fn _pf_children(edges, node) {
    let n = len(edges)
    let mut out = []
    let mut i = 0
    while i < n {
        let e = edges[i]
        if len(e) >= 2 {
            if e[0] == node {
                out.push(e[1])
            }
        }
        i = i + 1
    }
    return out
}

@pure
fn _pf_tree_build(edges, node, prefix, branch, acc) {
    let mut lines = acc
    lines.push(prefix + branch + to_string(node))
    let kids = _pf_children(edges, node)
    let nk = len(kids)
    if nk == 0 { return lines }
    let mut next_prefix = prefix
    if branch == "├── " {
        next_prefix = prefix + "│   "
    } else {
        if branch == "└── " {
            next_prefix = prefix + "    "
        }
    }
    let mut i = 0
    while i < nk {
        let is_last = (i == nk - 1)
        let cb = if is_last { "└── " } else { "├── " }
        lines = _pf_tree_build(edges, kids[i], next_prefix, cb, lines)
        i = i + 1
    }
    return lines
}

@pure
pub fn tree_render_pure(edges, root) {
    let mut lines = _pf_tree_build(edges, root, "", "", [])
    return lines.join("\n")
}

// ═══════════════════════════════════════════════════════════════════
//  ── Test harness ──
// ═══════════════════════════════════════════════════════════════════
let mut pass = 0
let mut fail = 0

fn eq_str(name, got, want) {
    if got == want {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
        println("  got : " + got)
        println("  want: " + want)
    }
}

fn eq_int(name, got, want) {
    if got == want {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(got) + " want " + to_string(want))
    }
}

fn eq_arr(name, got, want) {
    let ng = len(got)
    let nw = len(want)
    if ng != nw {
        fail = fail + 1
        println("[FAIL] " + name + " len " + to_string(ng) + " vs " + to_string(nw))
        return
    }
    let mut i = 0
    while i < ng {
        if got[i] != want[i] {
            fail = fail + 1
            println("[FAIL] " + name + " at " + to_string(i) + ": " + to_string(got[i]) + " vs " + to_string(want[i]))
            return
        }
        i = i + 1
    }
    pass = pass + 1
}

println("=== t_batch22_print_fmt_pure test suite ===")

// ──────────────────────────────────────────────────────────────────
// 1. truncate_ellipsis_pure
// ──────────────────────────────────────────────────────────────────
eq_str("trunc basic",       truncate_ellipsis_pure("hello world", 7),  "hell...")
eq_str("trunc short ok",    truncate_ellipsis_pure("hi", 10),          "hi")
eq_str("trunc exact",       truncate_ellipsis_pure("abcdef", 6),       "abcdef")
eq_str("trunc max=3",       truncate_ellipsis_pure("abcdef", 3),       "abc")
eq_str("trunc max=4",       truncate_ellipsis_pure("abcdef", 4),       "a...")
eq_str("trunc max=0",       truncate_ellipsis_pure("abcdef", 0),       "")
eq_str("trunc max=-1",      truncate_ellipsis_pure("abcdef", -1),      "")
eq_str("trunc empty",       truncate_ellipsis_pure("", 5),             "")

// ──────────────────────────────────────────────────────────────────
// 2. align_cols_pure
// ──────────────────────────────────────────────────────────────────
let a1 = align_cols_pure([["a", "bb"], ["cc", "d"]])
eq_int("align row count",  len(a1),     2)
eq_int("align col count",  len(a1[0]),  2)
eq_str("align [0][0]",     a1[0][0],    "a ")
eq_str("align [0][1]",     a1[0][1],    "bb")
eq_str("align [1][0]",     a1[1][0],    "cc")
eq_str("align [1][1]",     a1[1][1],    "d ")

// Missing cells fill with empty → padded to column width.
let a2 = align_cols_pure([["foo"], ["a", "bb"]])
eq_int("align ragged cols", len(a2[0]), 2)
eq_str("align ragged [0][0]", a2[0][0], "foo")
eq_str("align ragged [0][1]", a2[0][1], "  ")
eq_str("align ragged [1][0]", a2[1][0], "a  ")
eq_str("align ragged [1][1]", a2[1][1], "bb")

// Empty input → empty output.
let a3 = align_cols_pure([])
eq_int("align empty", len(a3), 0)

// ──────────────────────────────────────────────────────────────────
// 3. table_render_pure
// ──────────────────────────────────────────────────────────────────
let t1 = table_render_pure([["1", "a"], ["22", "bb"]], ["n", "x"])
let t1_expected = "| n  | x  |" + "\n" +
                  "|----|----|" + "\n" +
                  "| 1  | a  |" + "\n" +
                  "| 22 | bb |"
eq_str("table basic 2x2", t1, t1_expected)

// Header wider than data → header drives column width.
let t2 = table_render_pure([["1", "a"]], ["name", "val"])
let t2_expected = "| name | val |" + "\n" +
                  "|------|-----|" + "\n" +
                  "| 1    | a   |"
eq_str("table wide header", t2, t2_expected)

// No rows → still emits header + separator.
let t3 = table_render_pure([], ["a", "b"])
let t3_expected = "| a | b |" + "\n" +
                  "|---|---|"
eq_str("table empty rows", t3, t3_expected)

// ──────────────────────────────────────────────────────────────────
// 4. box_render_pure
// ──────────────────────────────────────────────────────────────────
let b1 = box_render_pure(["hello", "hi"])
let b1_expected = "┌─────┐" + "\n" +
                  "│hello│" + "\n" +
                  "│hi   │" + "\n" +
                  "└─────┘"
eq_str("box two lines", b1, b1_expected)

let b2 = box_render_pure(["x"])
let b2_expected = "┌─┐" + "\n" +
                  "│x│" + "\n" +
                  "└─┘"
eq_str("box one char", b2, b2_expected)

let b3 = box_render_pure([])
let b3_expected = "┌┐" + "\n" + "└┘"
eq_str("box empty", b3, b3_expected)

// ──────────────────────────────────────────────────────────────────
// 5. tree_render_pure
// ──────────────────────────────────────────────────────────────────
// Tree:
//   1
//   ├── 2
//   │   └── 4
//   └── 3
let t_edges = [[1, 2], [1, 3], [2, 4]]
let tr1 = tree_render_pure(t_edges, 1)
let tr1_expected = "1" + "\n" +
                   "├── 2" + "\n" +
                   "│   └── 4" + "\n" +
                   "└── 3"
eq_str("tree depth-2 branching", tr1, tr1_expected)

// Single node (no edges).
let tr2 = tree_render_pure([], 7)
eq_str("tree single node", tr2, "7")

// Chain 10 → 20 → 30.
let chain = [[10, 20], [20, 30]]
let tr3 = tree_render_pure(chain, 10)
let tr3_expected = "10" + "\n" +
                   "└── 20" + "\n" +
                   "    └── 30"
eq_str("tree chain 3", tr3, tr3_expected)

// Three siblings, each leaf.
let sibs = [[0, 1], [0, 2], [0, 3]]
let tr4 = tree_render_pure(sibs, 0)
let tr4_expected = "0" + "\n" +
                   "├── 1" + "\n" +
                   "├── 2" + "\n" +
                   "└── 3"
eq_str("tree three siblings", tr4, tr4_expected)

// Deep nested chain under middle child:
//   1
//   ├── 2
//   │   ├── 5
//   │   └── 6
//   │       └── 9
//   └── 3
let deep = [[1, 2], [1, 3], [2, 5], [2, 6], [6, 9]]
let tr5 = tree_render_pure(deep, 1)
let tr5_expected = "1" + "\n" +
                   "├── 2" + "\n" +
                   "│   ├── 5" + "\n" +
                   "│   └── 6" + "\n" +
                   "│       └── 9" + "\n" +
                   "└── 3"
eq_str("tree deep nested", tr5, tr5_expected)

// ──────────────────────────────────────────────────────────────────
println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAIL") }
