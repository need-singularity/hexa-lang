// S-5 FFI marshalling skeleton — structural tests only.
//
// Plan: docs/plans/s5_ffi_plan.md
// Module under test: self/opt/ffi_marshal.hexa
//
// These tests prove the SURFACE exists — function names, string
// constants, sentinel return — not any marshalling correctness.
// Real ABI tests land in S-5 step (b) + (c).

use "../self/opt/ffi_marshal"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn main() {
    // Assert 1 — the functions exist and return the TODO sentinel.
    check("marshal_in returns sentinel",
          marshal_in(0, FFI_REPR_I64),
          FFI_MARSHAL_TODO_SENTINEL)
    check("marshal_out returns sentinel",
          marshal_out("", FFI_REPR_I64),
          FFI_MARSHAL_TODO_SENTINEL)

    // Assert 2 — target_repr constants are strings (type check via
    // concat — only strings concatenate cleanly to string literals).
    check("FFI_REPR_I64 is string", "<" + FFI_REPR_I64 + ">", "<c_i64>")
    check("FFI_REPR_CSTR is string", "<" + FFI_REPR_CSTR + ">", "<c_cstr>")
    check("FFI_REPR_VOID is string", "<" + FFI_REPR_VOID + ">", "<c_void>")

    // Assert 3 — repr validation helper behaves as documented.
    check("ffi_repr_is_known(c_i64) = true",  ffi_repr_is_known(FFI_REPR_I64),  true)
    check("ffi_repr_is_known(c_bogus) = false", ffi_repr_is_known("c_bogus"),   false)
    check("ffi_repr_list len = 6",             len(ffi_repr_list()),            6)
    check("ffi_marshal_self_check = true",     ffi_marshal_self_check(),        true)

    println("---")
    println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("RESULT: PASS")
    } else {
        println("RESULT: FAIL")
    }
}

main()
