@retry fn might_fail() {
    println("attempt")
    return 42
}

@fallback fn safe_func() {
    return "ok"
}

@guard fn monitored() {
    let mut s = 0
    let mut i = 0
    while i < 100 { s = s + i; i = i + 1 }
    return s
}

fn main() {
    println("retry=" + to_string(might_fail()))
    println("fallback=" + safe_func())
    println("guard=" + to_string(monitored()))
    println("PASS t41_recovery_attrs")
}

main()
