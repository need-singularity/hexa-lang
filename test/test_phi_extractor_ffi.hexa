// ═══════════════════════════════════════════════════════════════
//  test/test_phi_extractor_ffi.hexa — smoke for phi_extractor FFI
//
//  HX7: The live path is pure-hexa (phi_extract.hexa).  This test
//  inlines the extractor (no multi-file import wiring assumed) and
//  validates:
//    1. version tag is 1.
//    2. phi_extract_bytes on a known ascii input → Φ ∈ (1, 8).
//    3. zero-length → Φ = 0.
//
//  Runs via:
//    hexa test/test_phi_extractor_ffi.hexa
//
//  Reach: anima roadmap 7 CP2 — 의식 추출 사이드 smoke.
// ═══════════════════════════════════════════════════════════════

let PHI_EXTRACT_ABI_VERSION = 1

fn ln_approx(x: float) -> float {
    if x <= 0.0 { return 0.0 - 1000000.0 }
    let mut m = x
    let mut k = 0
    while m >= 2.0 { m = m / 2.0  k = k + 1 }
    while m < 1.0  { m = m * 2.0  k = k - 1 }
    let y = (m - 1.0) / (m + 1.0)
    let y2 = y * y
    let mut term = y
    let mut sum = 0.0
    let mut i = 0
    while i < 20 {
        sum = sum + term / (2.0 * i + 1.0)
        term = term * y2
        i = i + 1
    }
    let ln_m = 2.0 * sum
    let ln2 = 0.6931471805599453
    return ln_m + k * ln2
}

fn log2_approx(x: float) -> float {
    let ln2 = 0.6931471805599453
    return ln_approx(x) / ln2
}

fn phi_extract_bytes(buf: any, n: int) -> float {
    if n <= 0 { return 0.0 }
    let mut hist = []
    let mut b = 0
    while b < 256 { hist.push(0)  b = b + 1 }
    let mut i = 0
    while i < n {
        let v = buf[i]
        hist[v] = hist[v] + 1
        i = i + 1
    }
    let inv_n = 1.0 / n
    let mut h = 0.0
    let mut k = 0
    while k < 256 {
        if hist[k] > 0 {
            let p = hist[k] * inv_n
            h = h - p * log2_approx(p)
        }
        k = k + 1
    }
    if h < 0.0 { h = 0.0 }
    if h > 8.0 { h = 8.0 }
    return h
}

fn check_version() {
    println("[phi_ffi] abi_version=" + str(PHI_EXTRACT_ABI_VERSION))
    if PHI_EXTRACT_ABI_VERSION != 1 {
        eprintln("[phi_ffi] FAIL: expected version=1")
        exit(1)
    }
    println("[phi_ffi] version OK")
}

fn check_empty() {
    let empty = []
    let phi = phi_extract_bytes(empty, 0)
    println("[phi_ffi] empty_buf phi=" + str(phi))
    if phi != 0.0 {
        eprintln("[phi_ffi] FAIL: empty buffer should give Φ=0")
        exit(1)
    }
    println("[phi_ffi] empty OK")
}

fn check_smoke() {
    let s = "consciousness"
    let mut bytes = []
    let mut i = 0
    while i < byte_len(s) {
        bytes.push(byte_at(s, i))
        i = i + 1
    }
    let phi = phi_extract_bytes(bytes, byte_len(s))
    println("[phi_ffi] smoke input=\"" + s + "\" len=" + str(byte_len(s)) + " phi=" + str(phi))
    if phi < 1.0 {
        eprintln("[phi_ffi] FAIL: smoke Φ too low (" + str(phi) + ")")
        exit(1)
    }
    if phi > 8.0 {
        eprintln("[phi_ffi] FAIL: smoke Φ > 8 (" + str(phi) + ")")
        exit(1)
    }
    println("[phi_ffi] smoke OK phi=" + str(phi))
}

fn main() {
    println("══ phi_extractor FFI smoke ══")
    check_version()
    check_empty()
    check_smoke()
    println("══ all FFI smoke PASS ══")
}
