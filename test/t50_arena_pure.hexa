// t50_arena_pure — bump allocator core test
// EXPECTED: ALL PASS

let mut blocks = []
let mut block_used = []
let mut cur = -1

fn new_block(n) {
    let cap = n
    if cap < 64 { cap = 64 }
    let mut b = []
    let mut i = 0
    while i < cap { b.push(0); i = i + 1 }
    blocks.push(b)
    block_used.push(0)
    cur = len(blocks) - 1
}

fn alloc(n) {
    if cur < 0 { new_block(n) }
    let c = cur
    let u = block_used[c]
    if u + n <= len(blocks[c]) {
        block_used[c] = u + n
        return [c, u, n]
    }
    new_block(n)
    block_used[cur] = n
    return [cur, 0, n]
}

fn rd(a, i) {
    return blocks[a[0]][(a[1] + i)]
}

fn wr(a, i, v) {
    blocks[a[0]][(a[1] + i)] = v
}

// test
let a1 = alloc(10)
let a2 = alloc(5)
wr(a1, 0, 42)
wr(a1, 9, 99)
wr(a2, 0, 100)

let mut fail = 0
if a1[1] != 0 { fail = fail + 1; println("FAIL a1 off") }
if a2[1] != 10 { fail = fail + 1; println("FAIL a2 off=" + to_string(a2[1])) }
if rd(a1, 0) != 42 { fail = fail + 1; println("FAIL rd0") }
if rd(a1, 9) != 99 { fail = fail + 1; println("FAIL rd9") }
if rd(a2, 0) != 100 { fail = fail + 1; println("FAIL a2r0") }

// isolation after second alloc
wr(a1, 5, 555)
if rd(a1, 5) != 555 { fail = fail + 1; println("FAIL iso") }

if fail == 0 {
    println("ALL PASS")
}
