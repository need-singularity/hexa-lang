// t_statusline_4panel.hexa — smoke test for gate/claude_statusline_4panel.hexa
// Spec: airgenome/docs/statusline_4panel.md §27 (fixture × golden harness).
// This is the minimum-viable subset: run the panel with a synthetic CC stdin
// and assert exit-clean + non-empty stdout + at least one panel separator.
// Deterministic golden-file comparisons are deferred — the render depends on
// live state (git HEAD, .raw mtime, transcript contents) which the full
// harness would have to freeze via fixture dirs + mocked clock.

fn main() {
    let hexa_lang = env("HEXA_LANG")
    if hexa_lang.len() == 0 {
        println("[t_statusline_4panel] SKIP: HEXA_LANG not set")
        return
    }
    let script = hexa_lang + "/gate/claude_statusline_4panel.hexa"
    let hexa_bin = hexa_lang + "/hexa"

    // Synthetic stdin covering the fields panel_emergence / panel_session read.
    let stdin_json = "{\"session_id\":\"smoke-test\",\"cwd\":\"/tmp\"," +
        "\"transcript_path\":\"/tmp/nonexistent.jsonl\"," +
        "\"model\":{\"display_name\":\"Opus 4.7\"}}"

    let cmd = "printf '%s' '" + stdin_json + "' | '" + hexa_bin + "' run '" + script + "' 2>/dev/null"
    let out = to_string(exec(cmd))  // @allow-bare-exec

    let mut pass = true
    let mut fails: [str] = []

    if out.len() == 0 {
        pass = false
        fails.push("empty stdout")
    }

    // Panels joined with " ·· ". A healthy render with /tmp cwd (no git) will
    // drop CONTEXT and may drop EMERGENCE (no HEXA_LANG/.raw match for /tmp),
    // but SESSION / ECONOMY still render, so at least one "··" should appear.
    let parts = out.split(" ·· ")
    if parts.len() < 2 {
        pass = false
        fails.push("no panel separator (got " + str(parts.len() - 1) + " of ≥1)")
    }

    // ASCII fallback / emoji smoke — either the 🧠 SESSION prefix or the
    // ASCII no-stdin sentinel should appear. Anything else means parse fail.
    if out.contains("🧠") == false && out.contains("statusline") == false {
        pass = false
        fails.push("missing 🧠 or statusline marker — parse likely failed")
    }

    if pass {
        println("[t_statusline_4panel] PASS (" + str(out.len()) + " bytes, " + str(parts.len() - 1) + " separators)")
    } else {
        println("[t_statusline_4panel] FAIL")
        let mut i = 0
        while i < fails.len() {
            println("  - " + fails[i])
            i = i + 1
        }
        println("  output: " + out)
        exit(1)
    }
}
