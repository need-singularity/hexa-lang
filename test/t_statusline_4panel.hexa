// t_statusline_4panel.hexa — smoke test for gate/claude_statusline_4panel.hexa
// Spec: airgenome/docs/statusline_4panel.md §27 (fixture × golden harness).
// This is the minimum-viable subset: run the panel with a synthetic CC stdin
// and assert exit-clean + non-empty stdout + at least one panel separator.
// Deterministic golden-file comparisons are deferred — the render depends on
// live state (git HEAD, .raw mtime, transcript contents) which the full
// harness would have to freeze via fixture dirs + mocked clock.

// Run the statusline under a given COLUMNS, assert structural smoke properties.
// Returns true on pass.
fn run_case(hexa_bin: str, script: str, stdin_json: str, cols: str, label: str) -> bool {
    let cmd = "printf '%s' '" + stdin_json + "' | env COLUMNS=" + cols + " '" + hexa_bin + "' run '" + script + "' 2>/dev/null"
    let out = to_string(exec(cmd))  // @allow-bare-exec

    let mut fails: [str] = []
    if out.len() == 0 { fails.push("empty stdout") }
    let parts = out.split(" ·· ")
    if parts.len() < 2 { fails.push("no panel separator (got " + str(parts.len() - 1) + ")") }
    if out.contains("🧠") == false && out.contains("statusline") == false {
        fails.push("missing 🧠 / statusline marker")
    }

    if fails.len() == 0 {
        println("[t_statusline_4panel] " + label + " PASS (" + str(out.len()) + " bytes, " + str(parts.len() - 1) + " separators)")
        return true
    }
    println("[t_statusline_4panel] " + label + " FAIL")
    let mut i = 0
    while i < fails.len() { println("  - " + fails[i]); i = i + 1 }
    println("  output: " + out)
    return false
}

fn main() {
    let hexa_lang = env("HEXA_LANG")
    if hexa_lang.len() == 0 {
        println("[t_statusline_4panel] SKIP: HEXA_LANG not set")
        return
    }
    let script = hexa_lang + "/gate/claude_statusline_4panel.hexa"
    let hexa_bin = hexa_lang + "/hexa"

    let stdin_opus = "{\"session_id\":\"smoke-opus\",\"cwd\":\"/tmp\"," +
        "\"transcript_path\":\"/tmp/nonexistent.jsonl\"," +
        "\"model\":{\"display_name\":\"Opus 4.7\"}}"
    let stdin_sonnet = "{\"session_id\":\"smoke-sonnet\",\"cwd\":\"/tmp\"," +
        "\"transcript_path\":\"/tmp/nonexistent.jsonl\"," +
        "\"model\":{\"display_name\":\"Sonnet 4.6\"}}"

    // Matrix: {opus,sonnet} × {full,compact,narrow}.
    let mut ok = true
    if run_case(hexa_bin, script, stdin_opus, "140", "opus/full")      == false { ok = false }
    if run_case(hexa_bin, script, stdin_opus, "100", "opus/compact")   == false { ok = false }
    if run_case(hexa_bin, script, stdin_opus, "80",  "opus/narrow")    == false { ok = false }
    if run_case(hexa_bin, script, stdin_sonnet, "140", "sonnet/full")  == false { ok = false }

    if ok == false { exit(1) }
}
