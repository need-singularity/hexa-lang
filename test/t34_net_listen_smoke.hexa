// t34_net_listen_smoke.hexa — B1 POSIX net builtin smoke
// Verifies: hexa_net_listen + hexa_net_close wiring via codegen_c2
// direct-lowering (net_listen/net_close are in the Day-1 triad that
// self/native/hexa_cc.c already recognises).
// Expected on mac/linux: fd >= 0, close_rc = 0, exit 0.
// Port 0 asks the OS to pick an ephemeral port so the test never collides
// with whatever is already bound locally.
//
// B5 fix (runtime.c hexa_val_arena_scope_pop heapifies __VAL_INT_CACHE)
// cleared the val_int(0) arena dangle. HEXA_VAL_ARENA=0 no longer required.
//   ./hexa run tests/t34_net_listen_smoke.hexa

let fd = net_listen("127.0.0.1:0")
println("listen_fd=" + to_string(fd))
if fd < 0 {
    println("FAIL: listen returned errno")
} else {
    let rc = net_close(fd)
    println("close_rc=" + to_string(rc))
    if rc == 0 {
        println("OK")
    } else {
        println("FAIL: close returned errno")
    }
}
