// G39 regression test — @attr pub fn parsing
//
// Before fix: `@pure pub fn foo()` fails with "unexpected token Pub"
// After fix:  `@attr pub fn ...` parses correctly, attrs attached to FnDecl
//
// Stage0 rebuild applied — fix is active.
// Expected output:
//   pure_pub=42
//   hot_pub=hello
//   multi_attr_pub=100

@pure pub fn compute() {
    return 42
}

@hot pub fn greet() {
    return "hello"
}

@pure @hot pub fn combined() {
    return 100
}

fn main() {
    println("pure_pub=" + to_string(compute()))
    println("hot_pub=" + greet())
    println("multi_attr_pub=" + to_string(combined()))
}

main()
