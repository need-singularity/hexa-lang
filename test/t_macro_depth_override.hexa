// #7 DoS-class fix: @depth(N) override pushes bound to N=8
//
// Simulates `@depth(8) @macro fn deep_loop() { deep_loop!() }`. The
// 9th call (depth=9) must trigger the abort. Also validates the
// clamp: N<1 -> 1, N>64 -> 64.
//
// See t_macro_depth_default.hexa for the SEED-FREEZE inlining note.

let mut pass_count = 0
let mut fail_count = 0

fn check(name, ok) {
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// Inlined mirror of self/macro_expand.hexa depth logic.
struct MCtx {
    depth: int,
    max_depth: int,
    stack: [string],
    error: string
}

fn mctx_with_max(max_depth: int) -> MCtx {
    let mut m = max_depth
    if m < 1 { m = 1 }
    if m > 64 { m = 64 }
    return MCtx { depth: 0, max_depth: m, stack: [], error: "" }
}

fn check_bound(ctx: MCtx, mac_name: string) -> string {
    ctx.depth = ctx.depth + 1
    ctx.stack = ctx.stack.push(mac_name)
    if ctx.depth > ctx.max_depth {
        let chain = ctx.stack.join(" -> ")
        let msg = "ERROR:macro " + mac_name +
            " exceeded tau-bound (depth=" + to_string(ctx.depth) +
            " > " + to_string(ctx.max_depth) +
            ") at chain: " + chain
        ctx.error = msg
        return msg
    }
    return "OK"
}

fn main() {
    let ctx = mctx_with_max(8)

    let mut fired_at = -1
    let mut last = ""
    let mut i = 0
    while i < 40 {
        last = check_bound(ctx, "deep_loop")
        if ctx.error != "" && fired_at == -1 {
            fired_at = ctx.depth
            break
        }
        i = i + 1
    }
    check("override max_depth == 8", ctx.max_depth == 8)
    check("abort fires", ctx.error != "")
    check("abort fires at depth 9 (N+1)", fired_at == 9)
    check("error mentions '> 8'", ctx.error.contains("> 8"))
    check("error mentions deep_loop", ctx.error.contains("deep_loop"))

    // Clamp checks
    let low = mctx_with_max(0)
    check("clamp low: 0 -> 1", low.max_depth == 1)
    let high = mctx_with_max(999)
    check("clamp high: 999 -> 64", high.max_depth == 64)
    let exact_1 = mctx_with_max(1)
    check("exact 1 preserved", exact_1.max_depth == 1)
    let exact_64 = mctx_with_max(64)
    check("exact 64 preserved", exact_64.max_depth == 64)

    println("---")
    println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("RESULT: PASS")
    } else {
        println("RESULT: FAIL")
    }
}

main()
