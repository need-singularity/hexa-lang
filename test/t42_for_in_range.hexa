// t42_for_in_range — for..in loops with ranges and arrays
// EXPECTED: ALL PASS

// --- exclusive range 0..N ---
let mut sum1 = 0
for i in 0..5 {
    sum1 = sum1 + i
}
if sum1 == 10 {
    println("PASS range 0..5 sum=10")
} else {
    println("FAIL range 0..5 sum=" + to_string(sum1))
}

// --- inclusive range 0..=N ---
let mut sum2 = 0
for i in 0..=5 {
    sum2 = sum2 + i
}
if sum2 == 15 {
    println("PASS range 0..=5 sum=15")
} else {
    println("FAIL range 0..=5 sum=" + to_string(sum2))
}

// --- for..in over array ---
let fruits = ["apple", "banana", "cherry"]
let mut count = 0
let mut collected = ""
for f in fruits {
    count = count + 1
    if collected != "" {
        collected = collected + ","
    }
    collected = collected + f
}
if count == 3 && collected == "apple,banana,cherry" {
    println("PASS for..in array count=3")
} else {
    println("FAIL for..in array count=" + to_string(count) + " collected=" + collected)
}

// --- nested for..in ---
let mut pairs = 0
for i in 0..3 {
    for j in 0..3 {
        pairs = pairs + 1
    }
}
if pairs == 9 {
    println("PASS nested for 3x3=9")
} else {
    println("FAIL nested for pairs=" + to_string(pairs))
}

// --- for..in with break ---
let mut last = 0
for i in 0..100 {
    if i == 7 {
        break
    }
    last = i
}
if last == 6 {
    println("PASS for..in break at 7, last=6")
} else {
    println("FAIL for..in break last=" + to_string(last))
}

println("ALL PASS")
