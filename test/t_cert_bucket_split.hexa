// ═══════════════════════════════════════════════════════════
//  test/t_cert_bucket_split.hexa
//
//  Assert that bucket_assign() gives exactly 12 "issue" +
//  8 "propagate" + 4 "verify" across the 24 HEXA-IR opcodes
//  (Egyptian split 1/2 + 1/3 + 1/6 = 1 on J₂ = 24).
//
//  Run:
//      ./hexa run test/t_cert_bucket_split.hexa
// ═══════════════════════════════════════════════════════════

use "self/proof/certificate"

fn main_cert_bucket_split() {
    println("[t_cert_bucket_split] Egyptian 12/8/4 over J₂=24 opcodes")

    let ops = [
        "Add","Sub","Mul","Div","Mod","Neg",
        "Load","Store","Alloc","Free","Copy","Move",
        "Jump","Branch","Call","Return","Phi","Switch",
        "Assert","Assume","Invariant","LifetimeStart","LifetimeEnd","OwnershipTransfer"
    ]
    let mut n_issue  = 0
    let mut n_prop   = 0
    let mut n_verify = 0
    let mut n_other  = 0
    let mut i = 0
    while i < len(ops) {
        let b = bucket_assign(ops[i])
        if b == "issue"          { n_issue  = n_issue  + 1 }
        else if b == "propagate" { n_prop   = n_prop   + 1 }
        else if b == "verify"    { n_verify = n_verify + 1 }
        else                     { n_other  = n_other  + 1 }
        i = i + 1
    }

    println("  issue=" + to_string(n_issue) + " propagate=" + to_string(n_prop) + " verify=" + to_string(n_verify) + " other=" + to_string(n_other))

    let total = n_issue + n_prop + n_verify
    let ok = (n_issue == 12) && (n_prop == 8) && (n_verify == 4) && (n_other == 0) && (total == 24)

    if ok {
        println("PASS t_cert_bucket_split  (Egyptian 1/2 + 1/3 + 1/6 = 24)")
        return 0
    }
    println("FAIL t_cert_bucket_split")
    exit(1)
    return 1
}

main_cert_bucket_split()
