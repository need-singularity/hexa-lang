#!hexa strict
// test/regression/ai_err_self_test.hexa — ai_err module smoke + format assertion
//
// Emits 3 sample errors + 1 ok message on stderr, then asserts that each
// required substring appears in a captured replay. The test CAPTURES its
// own stderr by execing itself with a marker env var — the parent pass
// runs the emitter, the child verifies.
//
// Exit 0 = all format assertions pass.
// Exit 1 = any required substring missing.

use "self/stdlib/ai_err"

fn sample_emit() {
    // Sample 1 — single remedy
    ai_err("os-lock", "unknown-file", [
        ["slug", "raw:os-lock"],
        ["file", "some/random/path.hexa"],
        ["cause", "file not in raw:os-lock scope"],
        ["remedy", "add to _required_targets() in tool/os_level_lock.hexa"],
        ["ref", "raw:os-lock"]
    ])

    // Sample 2 — multi remedy (tests block form)
    ai_err("hx-edit", "sudo-aborted", [
        ["cause", "user ctrl-C during sudo prompt"],
        ["remedy", "./hx edit --retry"],
        ["remedy", "sudo -v   # refresh sudo cache"],
        ["ref", "raw:os-lock"]
    ])

    // Sample 3 — pam-tid not configured
    ai_err("pam-tid", "not-configured", [
        ["file", "/etc/pam.d/sudo"],
        ["cause", "pam_tid.so not listed as auth sufficient"],
        ["remedy", "edit /etc/pam.d/sudo: auth sufficient pam_tid.so (first auth line)"],
        ["ref", "doc/os_level_lock_setup.md"]
    ])

    // Sample OK — for ai_ok format check
    ai_ok("os-lock/status", [
        ["platform", "darwin"],
        [".raw", "L2-schg"],
        [".own", "L2-schg"]
    ])
}

fn assert_contains(hay: string, needle: string, tag: string) -> bool {
    if hay.contains(needle) { return true }
    println("FAIL " + tag + " — missing: " + needle)
    return false
}

fn verify_capture(captured: string) -> int {
    let mut failures = 0

    // Header format
    if !assert_contains(captured, "err os-lock/unknown-file", "hdr1") { failures = failures + 1 }
    if !assert_contains(captured, "err hx-edit/sudo-aborted", "hdr2") { failures = failures + 1 }
    if !assert_contains(captured, "err pam-tid/not-configured", "hdr3") { failures = failures + 1 }

    // Field indentation (2-space)
    if !assert_contains(captured, "  slug: raw:os-lock", "slug-indent") { failures = failures + 1 }
    if !assert_contains(captured, "  file: some/random/path.hexa", "file-indent") { failures = failures + 1 }
    if !assert_contains(captured, "  cause: file not in raw:os-lock scope", "cause") { failures = failures + 1 }
    if !assert_contains(captured, "  ref: raw:os-lock", "ref") { failures = failures + 1 }

    // Remedy block form (4-space items)
    if !assert_contains(captured, "  remedy:", "remedy-hdr") { failures = failures + 1 }
    if !assert_contains(captured, "    - ./hx edit --retry", "remedy-item1") { failures = failures + 1 }
    if !assert_contains(captured, "    - sudo -v", "remedy-item2") { failures = failures + 1 }

    // OK format
    if !assert_contains(captured, "ok os-lock/status", "ok-hdr") { failures = failures + 1 }
    if !assert_contains(captured, "  platform: darwin", "ok-field") { failures = failures + 1 }

    return failures
}

fn main() -> int {
    let marker = env("AI_ERR_CHILD")
    if marker == "1" {
        // Child mode — just emit and exit. Parent captures stderr.
        sample_emit()
        return 0
    }

    // Parent — re-exec self with marker + capture stderr.
    let av = argv()
    if len(av) < 2 {
        eprintln("ai_err_self_test: cannot determine own script path")
        return 2
    }
    let me = av[1]
    // Build command: AI_ERR_CHILD=1 <runner> <me> 2>/tmp/ai_err_capture
    // Runner is the same interpreter currently running us — prefer
    // ./build/hexa_interp (present in tree) else system `hexa`.
    let mut runner = "./build/hexa_interp"
    let r = exec_with_status("test -x " + runner)
    if r[1] != 0 { runner = "hexa" }

    let cap_path = "/tmp/ai_err_self_test_stderr"
    let cmd = "AI_ERR_CHILD=1 " + runner + " " + me + " 2>" + cap_path + " >/dev/null"
    exec(cmd)
    let captured = to_string(exec("cat " + cap_path + " 2>/dev/null"))
    exec("rm -f " + cap_path)

    println("── ai_err self test ──")
    println("captured " + to_string(len(captured)) + " bytes of stderr")
    println("")
    println("── replay ──")
    print(captured)
    println("── asserts ──")

    let fails = verify_capture(captured)
    if fails == 0 {
        println("PASS ai_err format (4 samples, 12 asserts)")
        return 0
    }
    println("FAIL ai_err format — " + to_string(fails) + " assertion(s) failed")
    return 1
}

let _av = argv()
fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = _av[1]
    if s.ends_with("/ai_err_self_test.hexa") { return true }
    if s == "ai_err_self_test.hexa" { return true }
    return false
}

if _is_main() { exit(main()) }
