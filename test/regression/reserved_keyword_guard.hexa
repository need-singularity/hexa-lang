// Reserved-keyword identifier guard (grammar.jsonl P51).
// Parser must emit a loud "P51: reserved keyword ..." error when
// `borrow` / `own` / `move` are used in identifier position
// (let/mut, fn param, field, etc.). Historically they silently bound
// to void, producing [void, void] miscompilations in bignum_sub_pure.
//
// How to exercise (once the parser patch is baked into a rebuilt interp):
//
//   ./hexa parse tests/regression/reserved_keyword_guard.hexa
//
// Expected: three diagnostics containing "P51: reserved keyword ...".
// Until interp rebuild, the old interp binary will print the legacy
// "expected identifier, got Borrow (...)" message — which is also
// non-silent, so the silent-void class is already mitigated; the new
// message just makes the remediation hint explicit.

fn sub_bad(a, b) {
    let mut borrow = 0        // P51: reserved — should say rename to 'br'
    return a - b - borrow
}

fn own_bad(p) {
    let mut own = p           // P51: reserved — should say rename to 'owner'
    return own
}

fn move_bad(x) {
    let mut move = x          // P51: reserved — should say rename to 'mv'
    return move
}

fn main() {
    println(to_string(sub_bad(5, 3)))
    println(to_string(own_bad(42)))
    println(to_string(move_bad(7)))
    return 0
}
