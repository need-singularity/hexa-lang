// FIX-6 (BG-HX2, 2026-05-04): reserved-keyword guard for parameter and
// let-binding name positions.
//
// Background: commit 08e2d9aa (worktree-agent-ace8e5f603275089b) discovered
// that `fn foo(fn) { ... }` — using a hard reserved keyword as a parameter
// name — silently turned the entire module into a no-op load (exit 0,
// empty stdout). p_expect_ident's lenient generic-error branch failed to
// consume the offending Fn token, so the surrounding p_expect("RParen")
// re-saw it and cascaded into max_errors silent recovery.
//
// Fix: parse_params and parse_let now consult p_check_strict_reserved()
// before delegating to p_expect_ident. The check rejects any of:
//
//   fn, let, if, else, while, for, return, pub, struct, enum, match,
//   use, as, trait, impl, loop, break, continue, const, static, mut,
//   async, await
//
// with a clear FIX-6 diagnostic and consumes the keyword token so
// downstream parse can collect further errors instead of silent-looping.
//
// Negative cases (must emit FIX-6 errors):
//
//   fn fn_param_bad(fn) { return fn + 1 }
//   fn while_param_bad(while) { return while }
//   fn main() { let return = 5; let match = 6; let if = 7 }
//
// Positive case (must continue parsing without FIX-6 errors):
//
//   fn add(x, y) { return x + y }
//   fn main() { let result = add(2, 3); println(to_string(result)) }
//
// How to exercise:
//
//   self/native/hexa_v2 test/regression/fix6_reserved_param_guard.hexa /tmp/out.c
//
// Expected stdout: a FIX-6 diagnostic per offending site, e.g.
//
//   Parse error at L:C: FIX-6: reserved keyword 'fn' cannot be used as
//                       parameter name — rename the binding
//   Parse error at L:C: FIX-6: reserved keyword 'return' cannot be used as
//                       let-binding name — rename the binding
//
// The positive `add()` case below MUST still parse cleanly (no FIX-6
// diagnostics).

fn fn_param_bad(fn) {              // FIX-6: 'fn' as param name
    return fn + 1
}

fn while_param_bad(while) {        // FIX-6: 'while' as param name
    return while
}

fn add(x, y) {                     // OK: positive case, no error
    return x + y
}

fn main() {
    let return_val = 5             // OK: 'return_val' is a normal ident
    let match_val = 6              // OK: 'match_val' is a normal ident
    let result = add(2, 3)         // OK
    println(to_string(result))
    return 0
}
