#!hexa strict
// test/regression/chain_linear.hexa — forward-chain linear happy path
//
// PURPOSE
//   `tool/chain_runner.hexa` 의 가장 단순한 시나리오: chain "test1" =
//   a → b → c 를 entry at a 로 실행하면 a/b/c 가 순차 완료되고
//   `.chain-state/test1/step_c_ok` marker 가 남아야 한다.
//
// CASES
//   1. linear chain full run — exit 0, step_a_ok / step_b_ok / step_c_ok
//      세 marker 모두 생성, 최종 stdout 에 "chain test1: OK" 포함.
//
// FIXTURE
//   /tmp/chain_test_1_<pid>/ 에 fake repo 루트를 만들고 stage0 +
//   chain_runner + law_io 를 심볼릭 링크. 해당 디렉토리에 dedicated
//   `.chain` 를 써넣은 뒤 그 루트에서 chain_runner 호출.
//
// MAC/LINUX NOTE
//   stage0 (Mach-O) 가 없는 Linux sandbox 에서는 자동 SKIP. macOS
//   회귀 runner 전용.
//
// CLEANUP
//   fixture 디렉토리 통째 삭제. chflags 는 fixture 내 marker 에는
//   걸리지 않음 (test 는 fresh run 전제).

use "self/core/law_io"

fn _stage0_runnable() -> bool {
    let r = exec_with_status("test -x ./build/hexa_stage0 && echo y || echo n")
    let out = to_string(r[0]).trim()
    return out == "y"
}

fn _repo_root() -> string {
    let r = exec_with_status("pwd")
    return to_string(r[0]).trim()
}

fn _pid() -> string {
    let r = exec_with_status("echo $$")
    return to_string(r[0]).trim()
}

fn _cleanup(dir: string) {
    exec("rm -rf '" + dir + "' 2>/dev/null")
}

fn run_case_1(repo: string) -> bool {
    println("[case_1] linear chain a→b→c, entry at a — expect all markers")

    let dir = "/tmp/chain_test_1_" + _pid()
    _cleanup(dir)

    let mk = exec_with_status("mkdir -p '" + dir + "/build' '" + dir + "/tool' '" + dir + "/self/core' '" + dir + "/.chain-state/test1'")
    if mk[1] != 0 {
        eprintln("[case_1] FAIL — unable to mkdir fixture tree")
        _cleanup(dir)
        return false
    }

    let ln_cmds = [
        "ln -sf '" + repo + "/build/hexa_stage0' '" + dir + "/build/hexa_stage0'",
        "ln -sf '" + repo + "/tool/chain_runner.hexa' '" + dir + "/tool/chain_runner.hexa'",
        "ln -sf '" + repo + "/self/raw_loader.hexa' '" + dir + "/self/raw_loader.hexa'",
        "ln -sf '" + repo + "/self/core/law_io.hexa' '" + dir + "/self/core/law_io.hexa'"
    ]
    for c in ln_cmds {
        let r = exec_with_status(c)
        if r[1] != 0 {
            eprintln("[case_1] FAIL — symlink failed: " + c)
            _cleanup(dir)
            return false
        }
    }

    // Minimal .chain fixture — three trivial steps, each touches its own marker.
    let chain = "# fixture — linear\n\n" +
                "chain test1 new \"linear happy path\"\n" +
                "  mode strict\n" +
                "  step.a.cmd true\n" +
                "  step.a.next b\n" +
                "  step.b.cmd true\n" +
                "  step.b.next c\n" +
                "  step.c.cmd true\n"
    write_file(dir + "/.chain", chain)

    let cmd = "cd '" + dir + "' && ./build/hexa_stage0 tool/chain_runner.hexa run test1 a 2>&1"
    let r = exec_with_status(cmd)
    let rc = r[1]
    let out = to_string(r[0])

    let a_ok = exec_with_status("test -f '" + dir + "/.chain-state/test1/step_a_ok' && echo y || echo n")
    let b_ok = exec_with_status("test -f '" + dir + "/.chain-state/test1/step_b_ok' && echo y || echo n")
    let c_ok = exec_with_status("test -f '" + dir + "/.chain-state/test1/step_c_ok' && echo y || echo n")

    _cleanup(dir)

    if rc != 0 {
        eprintln("[case_1] FAIL — chain_runner exit=" + to_string(rc))
        eprintln(out)
        return false
    }
    if to_string(a_ok[0]).trim() != "y" {
        eprintln("[case_1] FAIL — step_a_ok marker missing")
        return false
    }
    if to_string(b_ok[0]).trim() != "y" {
        eprintln("[case_1] FAIL — step_b_ok marker missing")
        return false
    }
    if to_string(c_ok[0]).trim() != "y" {
        eprintln("[case_1] FAIL — step_c_ok marker missing")
        return false
    }
    println("[case_1] PASS — all three markers present")
    return true
}

fn main() -> int {
    println("── chain_linear regression ──")
    if !_stage0_runnable() {
        println("SKIP — ./build/hexa_stage0 not executable on this host (expected under Linux sandbox)")
        return 0
    }
    let repo = _repo_root()
    if len(repo) == 0 {
        eprintln("FATAL — unable to resolve repo root via pwd")
        return 1
    }

    let mut fail = 0
    if !run_case_1(repo) { fail = fail + 1 }

    println("")
    if fail == 0 {
        println("chain_linear: ALL PASS")
        return 0
    }
    eprintln("chain_linear: " + to_string(fail) + " case(s) failed")
    return 1
}

exit(main())
