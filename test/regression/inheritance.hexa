#!hexa strict
// test/regression/inheritance.hexa — nested .own monotonic inheritance
//
// PURPOSE
//   `tool/own_inherit_lint.hexa` enforces that nested .own files (under
//   `.claude/worktrees/*/.own`) never WEAKEN a matching rule in the root
//   `/.own`. Given root `/.own` with a `live` rule, a nested worktree
//   `.own` that drops it to `new` (weaker) must be flagged.
//
// STRATEGY
//   To avoid clobbering the real root `/.own`, we build a fake repo
//   scaffold under /tmp/inheritance_fx/ that contains:
//     · build/hexa_stage0  (symlink → real binary)
//     · tool/own_inherit_lint.hexa  (symlink → real lint)
//     · self/raw_loader.hexa, self/core/law_io.hexa  (symlinks → real)
//     · /.own   (synthetic — root rule, status=live)
//     · .claude/worktrees/testwt/.own  (nested — same slug, status=new → weakens)
//   Then we cd into the fixture and run the lint. The lint uses
//   $PWD/.own and $PWD/.claude/worktrees as its roots, so it will
//   compare our synthetic pair and emit a violation.
//
// CASE
//   1. nested testwt/.own relaxes root /.own → expect exit != 0 +
//      "relaxes root" / "weaken" marker in output.
//
// EXIT CONVENTION
//   0 — test passed
//   1 — test failed
//   2 — test setup error (missing stage0, mkdir failed, etc.)
//
// RUN
//   ./hexa test/regression/inheritance.hexa

use "self/core/law_io"

fn _stage0_runnable() -> bool {
    let r = exec_with_status("test -x ./build/hexa_stage0 && echo y || echo n")
    let out = to_string(r[0]).trim()
    return out == "y"
}

fn _repo_root() -> string {
    let r = exec_with_status("pwd")
    return to_string(r[0]).trim()
}

fn _cleanup(dir: string) {
    exec("rm -rf '" + dir + "' 2>/dev/null")
}

fn _scaffold(dir: string, repo: string) -> bool {
    _cleanup(dir)
    let mk = exec_with_status(
        "mkdir -p '" + dir + "/build' '" + dir + "/tool' '" + dir + "/self/core' '"
        + dir + "/.claude/worktrees/testwt'")
    if mk[1] != 0 {
        eprintln("inheritance: mkdir fixture failed")
        return false
    }
    let ln_cmds = [
        "ln -sf '" + repo + "/build/hexa_stage0' '" + dir + "/build/hexa_stage0'",
        "ln -sf '" + repo + "/tool/own_inherit_lint.hexa' '" + dir + "/tool/own_inherit_lint.hexa'",
        "ln -sf '" + repo + "/self/raw_loader.hexa' '" + dir + "/self/raw_loader.hexa'",
        "ln -sf '" + repo + "/self/core/law_io.hexa' '" + dir + "/self/core/law_io.hexa'"
    ]
    for c in ln_cmds {
        let r = exec_with_status(c)
        if r[1] != 0 {
            eprintln("inheritance: symlink failed: " + c)
            return false
        }
    }
    return true
}

fn _run_lint(dir: string) -> array {
    let cmd = "cd '" + dir + "' && ./build/hexa_stage0 tool/own_inherit_lint.hexa 2>&1"
    return exec_with_status(cmd)
}

fn run_case_1(repo: string) -> bool {
    println("[case_1] nested testwt/.own relaxes root /.own (live → new) — expect FAIL")

    let dir = "/tmp/inheritance_fx"
    if !_scaffold(dir, repo) {
        return false
    }

    // Root /.own — strong rule (live). Slug `demo_rule` pins inheritance key.
    let root_own = "# fixture — root /.own\n\n"
                   + "own 1 live \"demo rule\"\n"
                   + "  slug demo_rule\n"
                   + "  enforce tool/noop.hexa\n"
    // Nested testwt/.own — same slug but status=new (weaker than live).
    // raw_loader.status_strength: live=4, new=0 → violation.
    let nested_own = "# fixture — nested testwt/.own (weakening)\n\n"
                     + "own 1 new \"demo rule weakened\"\n"
                     + "  slug demo_rule\n"
                     + "  enforce tool/noop.hexa\n"

    write_file(dir + "/.own", root_own)
    write_file(dir + "/.claude/worktrees/testwt/.own", nested_own)

    let r = _run_lint(dir)
    let rc = r[1]
    let out = to_string(r[0])

    _cleanup(dir)

    if rc == 0 {
        eprintln("[case_1] FAIL")
        eprintln("  expected: exit != 0 (weakening flagged)")
        eprintln("  actual:   exit 0 (lint accepted weakening)")
        eprintln(out)
        return false
    }
    // own_inherit_lint emits  "[FAIL] <path>#<slug> relaxes root <slug> (root=live > nested=new)"
    let flagged = out.contains("relaxes root") || out.contains("🚫 FAIL")
    if !flagged {
        eprintln("[case_1] FAIL")
        eprintln("  expected: 'relaxes root' or '🚫 FAIL' in lint output")
        eprintln("  actual:   output below")
        eprintln(out)
        return false
    }
    println("[case_1] PASS — lint flagged weakening (exit=" + to_string(rc) + ")")
    return true
}

fn main() -> int {
    println("── inheritance regression ──")
    if !_stage0_runnable() {
        println("SKIP — ./build/hexa_stage0 not executable on this host")
        println("PASS: inheritance (skipped: non-Darwin host)")
        return 0
    }
    let repo = _repo_root()
    if len(repo) == 0 {
        eprintln("FAIL: inheritance")
        eprintln("  expected: repo root resolved via pwd")
        eprintln("  actual:   empty pwd output")
        return 2
    }

    let mut fail = 0
    if !run_case_1(repo) { fail = fail + 1 }

    println("")
    if fail == 0 {
        println("PASS: inheritance  (nested .own weakening flagged)")
        return 0
    }
    eprintln("FAIL: inheritance  (" + to_string(fail) + " case(s) failed)")
    return 1
}

exit(main())
