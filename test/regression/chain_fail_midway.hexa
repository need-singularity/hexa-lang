#!hexa strict
// test/regression/chain_fail_midway.hexa — forward-chain mid-failure halts
//
// PURPOSE
//   chain "test3" = a → b → c → d 에서 step b 가 의도적으로 실패
//   (`false`) 한다. entry at a 로 실행하면:
//     · step_a_ok 는 생성됨 (a 는 성공)
//     · step_b_ok 는 **부재** (b 가 실패해 marker 를 touch 안 함)
//     · step_c_ok / step_d_ok 부재 (runner 가 중단)
//     · chain_runner exit != 0 (실패 전파)
//     · stdout 또는 stderr 에 "FAIL" / "failed" 류 메시지.
//
// CASES
//   1. b 실패 시 a 만 완주, 이후 전부 중단 + 비영 exit.
//
// FIXTURE
//   /tmp/chain_test_3_<pid>/ fake repo, interp + chain_runner + law_io
//   심볼릭 링크, 전용 `.chain` 생성 (b 의 cmd 는 `false`).
//
// MAC/LINUX NOTE
//   Linux sandbox 는 자동 SKIP.

use "self/core/law_io"
fn _stage0_runnable() -> bool {
    let r = exec_with_status("test -x ./build/hexa_interp && echo y || echo n")
    let out = to_string(r[0]).trim()
    return out == "y"
}

fn _repo_root() -> string {
    let r = exec_with_status("pwd")
    return to_string(r[0]).trim()
}

fn _pid() -> string {
    let r = exec_with_status("echo $$")
    return to_string(r[0]).trim()
}

fn _cleanup(dir: string) {
    exec("rm -rf '" + dir + "' 2>/dev/null")
}

fn _marker(dir: string, name: string) -> bool {
    let r = exec_with_status("test -f '" + dir + "/.chain-state/test3/" + name + "' && echo y || echo n")
    return to_string(r[0]).trim() == "y"
}

fn run_case_1(repo: string) -> bool {
    println("[case_1] b fails mid-chain — expect a ok, b/c/d absent, exit != 0")

    let dir = "/tmp/chain_test_3_" + _pid()
    _cleanup(dir)

    let mk = exec_with_status("mkdir -p '" + dir + "/build' '" + dir + "/tool' '" + dir + "/self/core' '" + dir + "/.chain-state/test3'")
    if mk[1] != 0 {
        eprintln("[case_1] FAIL — mkdir fixture tree")
        _cleanup(dir)
        return false
    }

    let ln_cmds = [
        "ln -sf '" + repo + "/build/hexa_interp' '" + dir + "/build/hexa_interp'",
        "ln -sf '" + repo + "/tool/chain_runner.hexa' '" + dir + "/tool/chain_runner.hexa'",
        "ln -sf '" + repo + "/self/raw_loader.hexa' '" + dir + "/self/raw_loader.hexa'",
        "ln -sf '" + repo + "/self/core/law_io.hexa' '" + dir + "/self/core/law_io.hexa'"
    ]
    for c in ln_cmds {
        let r = exec_with_status(c)
        if r[1] != 0 {
            eprintln("[case_1] FAIL — symlink: " + c)
            _cleanup(dir)
            return false
        }
    }

    // b 의 cmd 를 `false` 로 설정 — POSIX utility false(1) 는 항상 exit 1.
    let chain = "# fixture — mid failure\n\n" +
                "chain test3 new \"mid failure\"\n" +
                "  mode strict\n" +
                "  step.a.cmd true\n" +
                "  step.a.next b\n" +
                "  step.b.cmd false\n" +
                "  step.b.next c\n" +
                "  step.c.cmd true\n" +
                "  step.c.next d\n" +
                "  step.d.cmd true\n"
    write_file(dir + "/.chain", chain)

    let cmd = "cd '" + dir + "' && ./build/hexa_interp tool/chain_runner.hexa run test3 a 2>&1"
    let r = exec_with_status(cmd)
    let rc = r[1]
    let out = to_string(r[0])

    let a_ok = _marker(dir, "step_a_ok")
    let b_ok = _marker(dir, "step_b_ok")
    let c_ok = _marker(dir, "step_c_ok")
    let d_ok = _marker(dir, "step_d_ok")

    _cleanup(dir)

    if rc == 0 {
        eprintln("[case_1] FAIL — chain_runner returned 0 despite b failing")
        eprintln(out)
        return false
    }
    if !a_ok {
        eprintln("[case_1] FAIL — step_a_ok missing (a should have succeeded)")
        return false
    }
    if b_ok {
        eprintln("[case_1] FAIL — step_b_ok present (b should not mark success)")
        return false
    }
    if c_ok {
        eprintln("[case_1] FAIL — step_c_ok present (c should be unreached)")
        return false
    }
    if d_ok {
        eprintln("[case_1] FAIL — step_d_ok present (d should be unreached)")
        return false
    }
    // Evidence of failure reporting in stdout/stderr combined stream.
    let failed = out.contains("FAIL") || out.contains("failed") || out.contains("halt") || out.contains("abort")
    if !failed {
        eprintln("[case_1] WARN — failure evidence string not found in output (continuing)")
        eprintln(out)
    }
    println("[case_1] PASS — a completed, b halted chain (exit=" + to_string(rc) + ")")
    return true
}

fn main() -> int {
    println("── chain_fail_midway regression ──")
    if !_stage0_runnable() {
        println("SKIP — ./build/hexa_interp not executable on this host")
        return 0
    }
    let repo = _repo_root()
    if len(repo) == 0 {
        eprintln("FATAL — pwd resolution failed")
        return 1
    }

    let mut fail = 0
    if !run_case_1(repo) { fail = fail + 1 }

    println("")
    if fail == 0 {
        println("chain_fail_midway: ALL PASS")
        return 0
    }
    eprintln("chain_fail_midway: " + to_string(fail) + " case(s) failed")
    return 1
}

exit(main())
