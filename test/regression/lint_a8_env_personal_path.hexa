// HX-safety A8 (BG-HX1, 2026-05-02) — env() lazy default lint fixture.
//
// raw 15 (no-hardcode) classifies absolute personal paths committed to
// source as a leak of per-developer location. The most common vector is
// `env(KEY, "/Users/...")` 2-arg fallback OR top-of-file
// `env("HOME") + "/Dev/<personal>/..."` concatenation.
//
// How to exercise:
//
//   ./hexa self/linter.hexa test/regression/lint_a8_env_personal_path.hexa
//
// Expected: 3 "[A8]" warnings (one per case 1, 2, 3 below).

// Case 1: env_or 2-arg with personal absolute path — should fire
fn env_or(key, default_v) {
    let v = env(key)
    if v == "" { return default_v }
    return v
}

let LOG_DIR = env_or("LOG", "/Users/<user>/Dev/somerepo/logs")

// Case 2: top-of-file env() concat with personal substring — should fire
let HEXA_BIN = env("HOME") + "/Dev/hexa-lang/hexa"

// Case 3: env_or with /home/ default — should fire
let CACHE_DIR = env_or("CACHE", "/home/dev/.cache/hexa")

// Negative: env() alone, no default — should NOT fire
let HOME = env("HOME")

// Negative: env() concat with non-personal path — should NOT fire
let MAYBE = env("FOO") + "/etc/hexa.conf"

// Negative: env_or with relative or non-/home, /Users path — should NOT fire
let PORT = env_or("PORT", "8080")

fn main() {
    println(LOG_DIR)
    println(HEXA_BIN)
    println(CACHE_DIR)
    println(HOME)
    println(MAYBE)
    println(PORT)
    return 0
}
