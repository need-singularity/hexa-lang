#!hexa strict
// test/regression/unlock_gate.hexa — hx_unlock raw_all-refusal gate
//
// PURPOSE
//   `tool/hx_unlock.hexa` 는 raw_all 이 FAIL 일 때 OS-level unlock 을
//   거부해야 한다. 본 테스트는 의도적으로 깨진 `.raw` fixture 를 만들고
//   hx_unlock 이 exit != 0 로 종료하면서 "refused — raw_all exit=" 메시지를
//   남기는지 확인한다. chflags 는 **건드리지 않는다** — fixture 파일은
//   애초에 locked 상태가 아니다.
//
// CASES
//   1. raw_all FAIL 상황에서 hx_unlock → exit != 0, "refused" 문자열 포함.
//
// MAC/LINUX NOTE
//   hx_unlock 자체는 macOS(Darwin) 와 Linux 둘 다 지원하지만 실제
//   chflags/chattr 는 root 또는 sudo 없이는 영향 없고, 이 테스트는
//   raw_all gate 단계에서 차단되는 지점만 본다. Linux CI sandbox 에서
//   interp (Mach-O) 가 실행 불가능하므로 자동 SKIP.
//
// STRATEGY
//   · /tmp/unlock_gate_test/ 에 fake repo 루트 생성.
//   · real repo 의 build/hexa_interp 와 tool/ 디렉토리에 심볼릭 링크.
//   · 해당 fixture 내 `.raw` 는 일부러 형식 위반 (bogus status) — raw_all
//     이 exit 1 을 반환하도록 유도.
//   · 그 디렉토리에서 hx_unlock --reason "test" 실행.
//   · 기대: exit != 0, "refused" 혹은 "blocked" 문자열 stderr/stdout 포함.
//   · 정리: 심볼릭 링크 + fixture 삭제, .raw-audit 흔적은 fixture 디렉토리
//     내에만 만들어지고 함께 삭제됨.

use "self/core/law_io"

fn _stage0_runnable() -> bool {
    let r = exec_with_status("test -x ./build/hexa_interp && echo y || echo n")
    let out = to_string(r[0]).trim()
    return out == "y"
}

fn _repo_root() -> string {
    let r = exec_with_status("pwd")
    return to_string(r[0]).trim()
}

fn _cleanup(dir: string) {
    exec("rm -rf '" + dir + "' 2>/dev/null")
}

fn run_case_1(repo: string) -> bool {
    println("[case_1] hx_unlock refusal when raw_all FAILs — expect exit != 0")

    let dir = "/tmp/unlock_gate_test"
    _cleanup(dir)

    // Build fake repo scaffold.
    let mk = exec_with_status("mkdir -p '" + dir + "/build' '" + dir + "/tool' '" + dir + "/self/core' '" + dir + "/self'")
    if mk[1] != 0 {
        eprintln("[case_1] FAIL — unable to mkdir fixture tree")
        _cleanup(dir)
        return false
    }

    // Symlink real interp + tool/ + self/ into fixture so hx_unlock can run.
    let ln_cmds = [
        "ln -sf '" + repo + "/build/hexa_interp' '" + dir + "/build/hexa_interp'",
        "ln -sf '" + repo + "/tool/raw_all.hexa' '" + dir + "/tool/raw_all.hexa'",
        "ln -sf '" + repo + "/tool/hx_unlock.hexa' '" + dir + "/tool/hx_unlock.hexa'",
        "ln -sf '" + repo + "/tool/hx_lock.hexa' '" + dir + "/tool/hx_lock.hexa'",
        "ln -sf '" + repo + "/tool/raw_audit.hexa' '" + dir + "/tool/raw_audit.hexa'",
        "ln -sf '" + repo + "/tool/os_level_lock.hexa' '" + dir + "/tool/os_level_lock.hexa'",
        "ln -sf '" + repo + "/self/raw_loader.hexa' '" + dir + "/self/raw_loader.hexa'",
        "ln -sf '" + repo + "/self/core/law_io.hexa' '" + dir + "/self/core/law_io.hexa'"
    ]
    for c in ln_cmds {
        let r = exec_with_status(c)
        if r[1] != 0 {
            eprintln("[case_1] FAIL — symlink failed: " + c)
            _cleanup(dir)
            return false
        }
    }

    // Broken .raw — unknown status token forces raw_all self-format FAIL.
    let bad_raw = "# fixture — deliberately broken\n\n" +
                  "raw 0 bogus \"fake\"\n" +
                  "  enforce tool/nonexistent.hexa\n"
    write_file(dir + "/.raw", bad_raw)

    // Run hx_unlock from inside fixture.
    let cmd = "cd '" + dir + "' && ./build/hexa_interp tool/hx_unlock.hexa --reason \"test\" 2>&1"
    let r = exec_with_status(cmd)
    let rc = r[1]
    let out = to_string(r[0])

    _cleanup(dir)

    if rc == 0 {
        eprintln("[case_1] FAIL — hx_unlock returned 0 despite raw_all FAIL")
        eprintln(out)
        return false
    }
    // hx_unlock prints "refused — raw_all exit=" on gate refusal, and
    // raw_all itself prints "verdict: FAIL". Accept either as evidence.
    let refused = out.contains("refused") || out.contains("verdict: FAIL") || out.contains("blocked")
    if !refused {
        eprintln("[case_1] FAIL — expected gate refusal marker in output")
        eprintln(out)
        return false
    }
    println("[case_1] PASS — hx_unlock refused (exit=" + to_string(rc) + ")")
    return true
}

fn main() -> int {
    println("── unlock_gate regression ──")
    if !_stage0_runnable() {
        println("SKIP — ./build/hexa_interp not executable on this host (expected under Linux sandbox / non-Darwin CI)")
        return 0
    }
    let repo = _repo_root()
    if len(repo) == 0 {
        eprintln("FATAL — unable to resolve repo root via pwd")
        return 1
    }

    let mut fail = 0
    if !run_case_1(repo) { fail = fail + 1 }

    println("")
    if fail == 0 {
        println("unlock_gate: ALL PASS")
        return 0
    }
    eprintln("unlock_gate: " + to_string(fail) + " case(s) failed")
    return 1
}

exit(main())
