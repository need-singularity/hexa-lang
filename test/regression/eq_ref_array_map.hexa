// test/regression/eq_ref_array_map.hexa
// 2026-04-20 hexa_eq array/map/fn reference-eq fix — commit 0adac579 site (4).
//
// Bug history:
//   runtime.c:3120 hexa_eq fell to `default: false` for TAG_ARRAY / TAG_MAP /
//   TAG_FN / TAG_CHAR / TAG_CLOSURE — so even aliased containers compared
//   unequal:
//     let a = [1, 2]; let b = a; a == b  // → false (BUG)
//
// Fix (0adac579):
//   Switch cases for TAG_ARRAY / TAG_MAP / TAG_FN / TAG_CHAR / TAG_CLOSURE
//   compare the underlying pointer (reference / C fn_ptr) — mirrors the
//   TAG_VALSTRUCT convention. TAG_FN/TAG_CLOSURE compare the C fn_ptr (not
//   the HexaVal descriptor) so two descriptors for the same function equate.
//
// Path notes:
//   * AOT (runtime.c linked) — reference equality.
//   * Interpreter (frozen stage0) — may use structural eq or unequal default.
//     We assert only the universally-stable "aliased value == itself" case
//     which holds on both paths (structural implies ref-eq for identical
//     pointers; the fix just makes ref-eq EXPLICIT rather than false-default).

fn main() {
    // (1) Self identity — the regression lock: `a == a` for an array.
    let a = [1, 2, 3]
    if a == a {
        println("OK self-eq arr")
    } else {
        println("FAIL arr self-eq (a == a) is false — regression of 0adac579 site 4")
        exit(1)
    }

    // (2) Aliased variable — `b = a` then `a == b`.
    let b = a
    if a == b {
        println("OK alias-eq arr (let b = a)")
    } else {
        println("FAIL arr alias-eq (a == b where b = a) is false")
        exit(1)
    }

    // (3) Distinct literals with same content — behavior diverges by path:
    //     AOT (ref-eq): false. Interpreter (structural): true.
    //     We check it's a deterministic bool, not that it's a specific value.
    let c = [1, 2, 3]
    let ac_eq = (a == c)
    if ac_eq {
        println("DIAG distinct-content-arr eq=true (interp/structural)")
    } else {
        println("DIAG distinct-content-arr eq=false (AOT/ref-eq active)")
    }

    // (4) Integer primitive eq — must always be structural.
    let x = 42
    let y = 42
    if x == y {
        println("OK int structural eq")
    } else {
        println("FAIL int structural eq broken")
        exit(1)
    }

    // (5) String primitive eq — must always compare by content.
    let s1 = "hexa"
    let s2 = "hexa"
    if s1 == s2 {
        println("OK string structural eq")
    } else {
        println("FAIL string structural eq broken")
        exit(1)
    }

    // (6) Nil/void behavior stable.
    let n1 = []
    if n1 == n1 {
        println("OK empty-arr self-eq")
    } else {
        println("FAIL empty-arr self-eq")
        exit(1)
    }

    println("PASS eq_ref_array_map 6/6 (0adac579 site 4)")
}
