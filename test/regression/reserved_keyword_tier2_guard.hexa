// HX-safety A3 (BG-HX1, 2026-05-02) — tier-2 reserved keyword guard.
//
// Tier-2 covers verification & metaprogramming family keywords that
// previously produced a generic "expected identifier, got Proof"
// diagnostic without consuming the offending token, allowing silent
// re-visit cascades. With HEXA_RESERVED_TIER2=1 the parser:
//   1. Emits "P51-EXT: reserved keyword '...' cannot be used as identifier"
//   2. Suggests a sanitized rename (e.g. proof → prf, theorem → thm)
//   3. Consumes the bad token to halt the cascade.
//
// How to exercise (post parser-rebuild):
//
//   HEXA_RESERVED_TIER2=1 ./hexa parse tests/regression/reserved_keyword_tier2_guard.hexa
//
// Expected (tier-2 ON): three "P51-EXT: reserved keyword ..." diagnostics.
// Expected (tier-2 OFF, default): three legacy
//   "expected identifier, got <Kind>" diagnostics — non-silent, but
//   without the targeted hint and without consuming the offender.
//
// This file intentionally uses tier-2 reserved words as identifiers
// in struct field, fn param, and let positions to surface all 3 sites.

struct Bag {
    proof: int,        // P51-EXT — should suggest rename to 'prf'
    theorem: string,   // P51-EXT — should suggest rename to 'thm'
    invariant: bool    // P51-EXT — should suggest rename to 'inv'
}

fn use_proof(proof) {  // P51-EXT — should suggest rename to 'prf'
    return proof + 1
}

fn main() {
    let pure = 42      // P51-EXT — should suggest rename to 'pure_v'
    println(to_string(pure))
    return 0
}
