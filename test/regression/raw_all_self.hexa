#!hexa strict
// test/regression/raw_all_self.hexa — raw#0 end-to-end self check
//
// PURPOSE
//   OS-level SSOT orchestrator `tool/raw_all.hexa` 를 현 repo 자신에게
//   적용했을 때 17 raw + 3 own 규칙 전부 PASS (exit 0) 하는지 회귀 검증.
//   tiered lock + unlock 게이트가 항상 기대한 상태에서 출발하도록 보증한다.
//
// CASES
//   1. raw_all plain          — exit 0, stdout 에 "verdict: PASS"
//   2. raw_all --fast         — exit 0 (heavy proof skipped) + verdict PASS
//   3. raw_all --json         — exit 0, JSON body contains "\"verdict\":\"PASS\""
//
// PREREQ
//   · ./build/hexa_interp must exist and be executable (macOS host only).
//   · Invoked from repo root (where .raw/.own live).
//
// RUN
//   ./hexa test/regression/raw_all_self.hexa
//
// NOTE
//   Linux sandbox 에서는 Mach-O interp 가 동작하지 않으므로 case 들은
//   SKIP 로 이어진다 (raw_all 내부 s0_check 가 SKIP 처리). 이 테스트는
//   Mac 회귀 runner 전용.

use "self/core/law_io"

fn _stage0_runnable() -> bool {
    let r = exec_with_status("test -x ./build/hexa_interp && echo y || echo n")
    let out = to_string(r[0]).trim()
    return out == "y"
}

fn run_case_1() -> bool {
    println("[case_1] raw_all plain run — expect exit 0 + 'verdict: PASS'")
    let r = exec_with_status("./build/hexa_interp tool/raw_all.hexa 2>&1")
    let rc = r[1]
    let out = to_string(r[0])
    if rc != 0 {
        eprintln("[case_1] FAIL — exit=" + to_string(rc))
        eprintln(out)
        return false
    }
    if !out.contains("verdict: PASS") {
        eprintln("[case_1] FAIL — missing 'verdict: PASS' in stdout")
        eprintln(out)
        return false
    }
    println("[case_1] PASS")
    return true
}

fn run_case_2() -> bool {
    println("[case_2] raw_all --fast — expect exit 0 + 'verdict: PASS'")
    let r = exec_with_status("./build/hexa_interp tool/raw_all.hexa --fast 2>&1")
    let rc = r[1]
    let out = to_string(r[0])
    if rc != 0 {
        eprintln("[case_2] FAIL — exit=" + to_string(rc))
        eprintln(out)
        return false
    }
    if !out.contains("verdict: PASS") {
        eprintln("[case_2] FAIL — missing 'verdict: PASS' in stdout")
        eprintln(out)
        return false
    }
    println("[case_2] PASS")
    return true
}

fn run_case_3() -> bool {
    println("[case_3] raw_all --json — expect exit 0 + JSON verdict PASS")
    let r = exec_with_status("./build/hexa_interp tool/raw_all.hexa --json 2>&1")
    let rc = r[1]
    let out = to_string(r[0])
    if rc != 0 {
        eprintln("[case_3] FAIL — exit=" + to_string(rc))
        eprintln(out)
        return false
    }
    if !out.contains("\"verdict\":\"PASS\"") {
        eprintln("[case_3] FAIL — missing JSON verdict PASS")
        eprintln(out)
        return false
    }
    println("[case_3] PASS")
    return true
}

fn main() -> int {
    println("── raw_all_self regression ──")
    if !_stage0_runnable() {
        println("SKIP — ./build/hexa_interp not executable on this host (expected under Linux sandbox)")
        return 0
    }

    let mut fail = 0
    if !run_case_1() { fail = fail + 1 }
    if !run_case_2() { fail = fail + 1 }
    if !run_case_3() { fail = fail + 1 }

    println("")
    if fail == 0 {
        println("raw_all_self: ALL PASS")
        return 0
    }
    eprintln("raw_all_self: " + to_string(fail) + " case(s) failed")
    return 1
}

exit(main())
