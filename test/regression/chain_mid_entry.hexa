#!hexa strict
// test/regression/chain_mid_entry.hexa — forward-chain mid-entry (loose mode)
//
// PURPOSE
//   chain "test2" = a → b → c → d → e, loose mode, entry at c. 전방
//   연쇄만 적용되므로 c/d/e 는 실행되지만 a/b 는 실행되지 않는다.
//   marker: step_c_ok / step_d_ok / step_e_ok 존재, step_a_ok /
//   step_b_ok 부재.
//
// CASES
//   1. loose mode, entry at c — c/d/e 실행, a/b 는 skip.
//
// FIXTURE
//   /tmp/chain_test_2_<pid>/ fake repo. stage0 + chain_runner + law_io
//   심볼릭 링크, 전용 `.chain` 생성.
//
// MAC/LINUX NOTE
//   Linux sandbox 에서는 stage0 미실행 → 자동 SKIP.

use "self/core/law_io"
fn _stage0_runnable() -> bool {
    let r = exec_with_status("test -x ./build/hexa_stage0 && echo y || echo n")
    let out = to_string(r[0]).trim()
    return out == "y"
}

fn _repo_root() -> string {
    let r = exec_with_status("pwd")
    return to_string(r[0]).trim()
}

fn _pid() -> string {
    let r = exec_with_status("echo $$")
    return to_string(r[0]).trim()
}

fn _cleanup(dir: string) {
    exec("rm -rf '" + dir + "' 2>/dev/null")
}

fn _marker(dir: string, name: string) -> bool {
    let r = exec_with_status("test -f '" + dir + "/.chain-state/test2/" + name + "' && echo y || echo n")
    return to_string(r[0]).trim() == "y"
}

fn run_case_1(repo: string) -> bool {
    println("[case_1] loose mode, entry at c — expect c/d/e markers only")

    let dir = "/tmp/chain_test_2_" + _pid()
    _cleanup(dir)

    let mk = exec_with_status("mkdir -p '" + dir + "/build' '" + dir + "/tool' '" + dir + "/self/core' '" + dir + "/.chain-state/test2'")
    if mk[1] != 0 {
        eprintln("[case_1] FAIL — mkdir fixture tree")
        _cleanup(dir)
        return false
    }

    let ln_cmds = [
        "ln -sf '" + repo + "/build/hexa_stage0' '" + dir + "/build/hexa_stage0'",
        "ln -sf '" + repo + "/tool/chain_runner.hexa' '" + dir + "/tool/chain_runner.hexa'",
        "ln -sf '" + repo + "/self/raw_loader.hexa' '" + dir + "/self/raw_loader.hexa'",
        "ln -sf '" + repo + "/self/core/law_io.hexa' '" + dir + "/self/core/law_io.hexa'"
    ]
    for c in ln_cmds {
        let r = exec_with_status(c)
        if r[1] != 0 {
            eprintln("[case_1] FAIL — symlink: " + c)
            _cleanup(dir)
            return false
        }
    }

    let chain = "# fixture — mid entry loose\n\n" +
                "chain test2 new \"mid entry\"\n" +
                "  mode loose\n" +
                "  step.a.cmd true\n" +
                "  step.a.next b\n" +
                "  step.b.cmd true\n" +
                "  step.b.next c\n" +
                "  step.c.cmd true\n" +
                "  step.c.next d\n" +
                "  step.d.cmd true\n" +
                "  step.d.next e\n" +
                "  step.e.cmd true\n"
    write_file(dir + "/.chain", chain)

    let cmd = "cd '" + dir + "' && ./build/hexa_stage0 tool/chain_runner.hexa run test2 c 2>&1"
    let r = exec_with_status(cmd)
    let rc = r[1]
    let out = to_string(r[0])

    let a_present = _marker(dir, "step_a_ok")
    let b_present = _marker(dir, "step_b_ok")
    let c_present = _marker(dir, "step_c_ok")
    let d_present = _marker(dir, "step_d_ok")
    let e_present = _marker(dir, "step_e_ok")

    _cleanup(dir)

    if rc != 0 {
        eprintln("[case_1] FAIL — chain_runner exit=" + to_string(rc))
        eprintln(out)
        return false
    }
    if a_present {
        eprintln("[case_1] FAIL — step_a_ok present (loose mode should not run a)")
        return false
    }
    if b_present {
        eprintln("[case_1] FAIL — step_b_ok present (loose mode should not run b)")
        return false
    }
    if !c_present {
        eprintln("[case_1] FAIL — step_c_ok missing (entry point should run)")
        return false
    }
    if !d_present {
        eprintln("[case_1] FAIL — step_d_ok missing (forward chain should run)")
        return false
    }
    if !e_present {
        eprintln("[case_1] FAIL — step_e_ok missing (forward chain terminal)")
        return false
    }
    println("[case_1] PASS — c/d/e ran, a/b skipped as expected")
    return true
}

fn main() -> int {
    println("── chain_mid_entry regression ──")
    if !_stage0_runnable() {
        println("SKIP — ./build/hexa_stage0 not executable on this host")
        return 0
    }
    let repo = _repo_root()
    if len(repo) == 0 {
        eprintln("FATAL — pwd resolution failed")
        return 1
    }

    let mut fail = 0
    if !run_case_1(repo) { fail = fail + 1 }

    println("")
    if fail == 0 {
        println("chain_mid_entry: ALL PASS")
        return 0
    }
    eprintln("chain_mid_entry: " + to_string(fail) + " case(s) failed")
    return 1
}

exit(main())
