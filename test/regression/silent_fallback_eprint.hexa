// test/regression/silent_fallback_eprint.hexa
// 2026-04-20 silent-"<value>"-fallback bug class repro.
// Focus on TAG_ARRAY (TAG_MAP has syntactic friction at interp fn body).
//
// Prior bug surface (pre-fix runtime.c):
//  - hexa_eprint_val:   TAG_ARRAY / TAG_VOID / TAG_MAP silently emit NOTHING
//  - hexa_eprintln:     TAG_ARRAY default -> "<value>\n"
//  - hexa_println:      TAG_MAP default   -> "<value>"
//  - hexa_to_string:    (already fixed earlier this session)
//
// After fix: eprintln(arr) -> "[1, 2, 3]\n"

fn main() {
    let arr = [1, 2, 3]

    // stdout — already OK pre-fix for arrays.
    println(arr)

    // stderr — pre-fix: "<value>\n" (hexa_eprintln default) or "" if routed
    // through hexa_eprint_val. Post-fix: "[1, 2, 3]\n".
    eprintln(arr)

    // str(x) concat path — hexa_to_string. Pre-fix (before 2850-fix):
    //   "arr=<value>". Post-fix: "arr=[1, 2, 3]".
    println("arr=" + str(arr))
}
