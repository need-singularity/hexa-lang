// test/regression/map_has_method.hexa
// RFC-002 P1: map.has(key) -> bool method
//
// Closes anima-eeg gap (16× per-tick `_kv_lookup` string-blob parsing
// → single `map.has(key)` boolean check).
//
// Reference: proposals/rfc_002_map_methods.md
//
// Falsifier (raw#71):
//   m.has(k) returns boolean equal to membership for all (k,m) pairs.
//   Behavior identical in interpreter AND AOT modes.

fn main() {
    // Case 1: empty map — no key returns false.
    let m1 = #{}
    if m1.has("k") {
        println("FAIL case1 empty.has(\"k\") returned true")
        exit(1)
    }
    println("OK case1 empty.has(\"k\")=false")

    // Case 2: key present — returns true.
    let m2 = #{"a": 1}
    if !m2.has("a") {
        println("FAIL case2 {a:1}.has(\"a\") returned false")
        exit(1)
    }
    println("OK case2 {a:1}.has(\"a\")=true")

    // Case 3: key absent in non-empty map — returns false.
    let m3 = #{"a": 1}
    if m3.has("b") {
        println("FAIL case3 {a:1}.has(\"b\") returned true")
        exit(1)
    }
    println("OK case3 {a:1}.has(\"b\")=false")

    // Case 4: empty-string key — returns true (well-defined corner).
    let m4 = #{"": 1}
    if !m4.has("") {
        println("FAIL case4 {\"\":1}.has(\"\") returned false")
        exit(1)
    }
    println("OK case4 {\"\":1}.has(\"\")=true")

    // Case 5: parity with .contains_key() — same boolean for every probe.
    let m5 = #{"x": 1, "y": 2, "z": 3}
    let probes = ["x", "y", "z", "missing", ""]
    let mut i = 0
    while i < len(probes) {
        let k = probes[i]
        if m5.has(k) != m5.contains_key(k) {
            println("FAIL case5 has/contains_key parity break for key=" + k)
            exit(1)
        }
        i = i + 1
    }
    println("OK case5 has/contains_key parity 5/5")

    println("PASS map_has_method 5/5 (RFC-002 P1)")
}
