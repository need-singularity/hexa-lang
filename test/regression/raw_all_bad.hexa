#!hexa strict
// test/regression/raw_all_bad.hexa — raw#0 negative-path fixtures
//
// PURPOSE
//   Intentionally-broken `.raw` 파일들에 대해 `tool/raw_all.hexa` 가
//   raw#1 self-format 검증 단계에서 정확히 거부(exit != 0) 하는지 확인.
//   validate_strict() 의 에러 메시지 샘플 3종을 실제로 유도하여 회귀
//   문자열 regression guard 를 만든다.
//
// CASES
//   A. status 화이트리스트 외 — "bogus" 상태 → "malformed rule header"
//   B. key 라인에 tab 문자   → "tab forbidden"
//   C. column-0 에 잘못된 토큰 — "wrong" 가 header 토큰이 아님 → "unknown column-0 line"
//
// STRATEGY
//   · /tmp/raw_all_bad_XXX 하위에 fake repo 레이아웃 (.raw) 만 만든다.
//     build/hexa_stage0 는 원 repo 절대경로를 그대로 호출하고, tool/raw_all.hexa
//     역시 원 repo 절대경로로 지정 — raw_all 이 쓰는 파일은 "." 기준
//     (.raw, .own) 이므로 cd 후 실행하면 fixture 를 읽는다.
//
// PREREQ
//   macOS host 기준 (/tmp → /private/tmp symlink). Linux sandbox 는 동일 경로.
//
// RUN
//   ./hexa test/regression/raw_all_bad.hexa

use "self/core/law_io"

fn _stage0_runnable() -> bool {
    let r = exec_with_status("test -x ./build/hexa_stage0 && echo y || echo n")
    let out = to_string(r[0]).trim()
    return out == "y"
}

fn _repo_root() -> string {
    let r = exec_with_status("pwd")
    return to_string(r[0]).trim()
}

fn _cleanup(dir: string) {
    exec("rm -rf '" + dir + "' 2>/dev/null")
}

fn _write_fixture(dir: string, content: string) -> bool {
    exec("rm -rf '" + dir + "' 2>/dev/null")
    let mk = exec_with_status("mkdir -p '" + dir + "'")
    if mk[1] != 0 {
        eprintln("mkdir failed for " + dir)
        return false
    }
    write_file(dir + "/.raw", content)
    return true
}

fn _run_raw_all_in(dir: string, repo: string) -> array {
    // cd into fixture + invoke stage0 via absolute path on the real tool script.
    let cmd = "cd '" + dir + "' && '" + repo + "/build/hexa_stage0' '"
              + repo + "/tool/raw_all.hexa' 2>&1"
    return exec_with_status(cmd)
}

// ─── CASE A: bogus status ────────────────────────────────────────
fn run_case_A(repo: string) -> bool {
    println("[case_A] bogus status — expect FAIL (malformed header)")
    let dir = "/tmp/raw_all_bad_A"
    let fixture = "# test fixture — bad status\n\n" +
                  "raw 0 bogus \"fake rule\"\n" +
                  "  enforce tool/nonexistent.hexa\n"
    if !_write_fixture(dir, fixture) { return false }

    let r = _run_raw_all_in(dir, repo)
    let rc = r[1]
    let out = to_string(r[0])
    _cleanup(dir)

    if rc == 0 {
        eprintln("[case_A] FAIL — raw_all accepted bogus status (exit=0)")
        eprintln(out)
        return false
    }
    // validate_strict emits "malformed rule header" when status not in whitelist.
    if !out.contains("malformed rule header") && !out.contains("fails self-format") {
        eprintln("[case_A] FAIL — expected 'malformed rule header' in stderr")
        eprintln(out)
        return false
    }
    println("[case_A] PASS — exit=" + to_string(rc))
    return true
}

// ─── CASE B: tab in key line ─────────────────────────────────────
fn run_case_B(repo: string) -> bool {
    println("[case_B] tab in key line — expect FAIL (tab forbidden)")
    let dir = "/tmp/raw_all_bad_B"
    // Key line uses literal TAB between indent and key token.
    let tab = "\t"
    let fixture = "# test fixture — tab forbidden\n\n" +
                  "raw 1 live \"tabbed rule\"\n" +
                  "  enforce" + tab + "tool/nonexistent.hexa\n"
    if !_write_fixture(dir, fixture) { return false }

    let r = _run_raw_all_in(dir, repo)
    let rc = r[1]
    let out = to_string(r[0])
    _cleanup(dir)

    if rc == 0 {
        eprintln("[case_B] FAIL — raw_all accepted tab (exit=0)")
        eprintln(out)
        return false
    }
    if !out.contains("tab forbidden") {
        eprintln("[case_B] FAIL — expected 'tab forbidden' in stderr")
        eprintln(out)
        return false
    }
    println("[case_B] PASS — exit=" + to_string(rc))
    return true
}

// ─── CASE C: unknown column-0 token ──────────────────────────────
fn run_case_C(repo: string) -> bool {
    println("[case_C] unknown column-0 token — expect FAIL (unknown column-0 line)")
    let dir = "/tmp/raw_all_bad_C"
    // 'wrong' is not one of raw|own|ext|roadmap|loop — validate_strict
    // must flag this as unknown column-0 line.
    let fixture = "# test fixture — unknown header token\n\n" +
                  "wrong 2 live \"not a valid kind\"\n" +
                  "  enforce tool/nonexistent.hexa\n"
    if !_write_fixture(dir, fixture) { return false }

    let r = _run_raw_all_in(dir, repo)
    let rc = r[1]
    let out = to_string(r[0])
    _cleanup(dir)

    if rc == 0 {
        eprintln("[case_C] FAIL — raw_all accepted bad kind token (exit=0)")
        eprintln(out)
        return false
    }
    if !out.contains("unknown column-0 line") {
        eprintln("[case_C] FAIL — expected 'unknown column-0 line' in stderr")
        eprintln(out)
        return false
    }
    println("[case_C] PASS — exit=" + to_string(rc))
    return true
}

fn main() -> int {
    println("── raw_all_bad regression ──")
    if !_stage0_runnable() {
        println("SKIP — ./build/hexa_stage0 not executable on this host (expected under Linux sandbox)")
        return 0
    }
    let repo = _repo_root()
    if len(repo) == 0 {
        eprintln("FATAL — unable to resolve repo root via pwd")
        return 1
    }

    let mut fail = 0
    if !run_case_A(repo) { fail = fail + 1 }
    if !run_case_B(repo) { fail = fail + 1 }
    if !run_case_C(repo) { fail = fail + 1 }

    println("")
    if fail == 0 {
        println("raw_all_bad: ALL PASS")
        return 0
    }
    eprintln("raw_all_bad: " + to_string(fail) + " case(s) failed")
    return 1
}

exit(main())
