// Regression: FIX-A Patch #4 — `resume` empty-LHS parsing
//
// Before: `resume` at end of block (no following expr on same line) fell
// through to parse_expr() and then into empty-LHS ident error because the
// lookahead token was Newline/RBrace.
//
// After: parse_resume_stmt guards Newline/RBrace/Eof and leaves node.left
// as "" — equivalent to `resume void`.
//
// This file parses cleanly when stage0 picks up the P51 extension.

// Case 1 — bare resume on its own line (no expr).
fn handler_bare() {
    // Inside a hypothetical effect handler body:
    //   op(x) => { resume }
    // which should resume with void.
    resume
}

// Case 2 — resume with trailing expression (the original supported form).
fn handler_with_expr() {
    let v = 42
    resume v
}

// Case 3 — resume expression followed by RBrace on next line.
fn handler_block() {
    let x = 1
    let y = 2
    resume x + y
}

// Case 4 — multiple resume sites (bare + value) in same fn.
fn handler_mixed(flag: bool) {
    if flag {
        resume
    } else {
        resume 99
    }
}

fn main() {
    print("parser_resume_empty_lhs: parse ok")
}
