#!hexa strict
// test/regression/own_inherit_violation.hexa — .own monotonic inheritance
//
// PURPOSE
//   `tool/own_inherit_lint.hexa` 는 .own (L1) 규칙이 같은 id 의 .raw (L0)
//   규칙을 약화시키면 FAIL 해야 한다. 본 테스트는 의도적으로 weakening
//   entries 를 심은 fixture 에서 lint 가 exit 1 을 반환하고, 깨끗한 기준
//   fixture 에서는 exit 0 (PASS) 을 반환하는지 검증한다.
//
// CASES
//   1. status weakening         — .raw 7 live  → .own 7 warn (FAIL)
//   2. bans narrowing           — .raw 7 bans "a b c" → .own 7 bans "a"  (FAIL)
//   3. clean inheritance        — .own 이 .raw 강도 이상 유지             (PASS)
//
// STRATEGY
//   · /tmp/own_inherit_fx/ 에 fake repo 레이아웃 + .raw + .own 구성.
//   · self/raw_loader + law_io symlink + tool/own_inherit_lint symlink.
//   · cd 후 interp 로 own_inherit_lint 실행.
//   · rc / stdout 의 "status: FAIL" or "status: PASS" 검증.
//   · 정리: fixture 디렉토리 삭제.
//
// RUN
//   ./hexa test/regression/own_inherit_violation.hexa

use "self/core/law_io"

fn _stage0_runnable() -> bool {
    let r = exec_with_status("test -x ./build/hexa_interp && echo y || echo n")
    let out = to_string(r[0]).trim()
    return out == "y"
}

fn _repo_root() -> string {
    let r = exec_with_status("pwd")
    return to_string(r[0]).trim()
}

fn _cleanup(dir: string) {
    exec("rm -rf '" + dir + "' 2>/dev/null")
}

fn _scaffold(dir: string, repo: string) -> bool {
    _cleanup(dir)
    let mk = exec_with_status("mkdir -p '" + dir + "/build' '" + dir + "/tool' '" + dir + "/self/core'")
    if mk[1] != 0 {
        eprintln("mkdir fixture failed")
        return false
    }
    let ln_cmds = [
        "ln -sf '" + repo + "/build/hexa_interp' '" + dir + "/build/hexa_interp'",
        "ln -sf '" + repo + "/tool/own_inherit_lint.hexa' '" + dir + "/tool/own_inherit_lint.hexa'",
        "ln -sf '" + repo + "/self/raw_loader.hexa' '" + dir + "/self/raw_loader.hexa'",
        "ln -sf '" + repo + "/self/core/law_io.hexa' '" + dir + "/self/core/law_io.hexa'"
    ]
    for c in ln_cmds {
        let r = exec_with_status(c)
        if r[1] != 0 {
            eprintln("symlink failed: " + c)
            return false
        }
    }
    return true
}

fn _run_lint(dir: string) -> array {
    let cmd = "cd '" + dir + "' && ./build/hexa_interp tool/own_inherit_lint.hexa 2>&1"
    return exec_with_status(cmd)
}

// ─── CASE 1: status weakening ────────────────────────────────────
fn run_case_1(repo: string) -> bool {
    println("[case_1] status weakening (.raw live → .own warn) — expect FAIL")
    let dir = "/tmp/own_inherit_fx_1"
    if !_scaffold(dir, repo) { return false }

    let raw = "# fixture\n\n" +
              "raw 7 live \"no forbidden ext\"\n" +
              "  enforce tool/noop.hexa\n"
    let own = "# fixture\n\n" +
              "own 7 warn \"weakened\"\n" +
              "  enforce tool/noop.hexa\n"
    write_file(dir + "/.raw", raw)
    write_file(dir + "/.own", own)

    let r = _run_lint(dir)
    let rc = r[1]
    let out = to_string(r[0])
    _cleanup(dir)

    if rc == 0 {
        eprintln("[case_1] FAIL — lint accepted weakening (exit=0)")
        eprintln(out)
        return false
    }
    if !out.contains("status weakening") {
        eprintln("[case_1] FAIL — expected 'status weakening' in output")
        eprintln(out)
        return false
    }
    if !out.contains("status: FAIL") {
        eprintln("[case_1] FAIL — expected 'status: FAIL' footer")
        eprintln(out)
        return false
    }
    println("[case_1] PASS — rc=" + to_string(rc))
    return true
}

// ─── CASE 2: bans narrowing ──────────────────────────────────────
fn run_case_2(repo: string) -> bool {
    println("[case_2] bans narrowing (.raw has a b c, .own has a) — expect FAIL")
    let dir = "/tmp/own_inherit_fx_2"
    if !_scaffold(dir, repo) { return false }

    let raw = "# fixture\n\n" +
              "raw 7 live \"bans superset\"\n" +
              "  enforce tool/noop.hexa\n" +
              "  bans alpha beta gamma\n"
    let own = "# fixture\n\n" +
              "own 7 live \"bans subset\"\n" +
              "  enforce tool/noop.hexa\n" +
              "  bans alpha\n"
    write_file(dir + "/.raw", raw)
    write_file(dir + "/.own", own)

    let r = _run_lint(dir)
    let rc = r[1]
    let out = to_string(r[0])
    _cleanup(dir)

    if rc == 0 {
        eprintln("[case_2] FAIL — lint accepted bans narrowing (exit=0)")
        eprintln(out)
        return false
    }
    if !out.contains("bans narrowing") {
        eprintln("[case_2] FAIL — expected 'bans narrowing' in output")
        eprintln(out)
        return false
    }
    println("[case_2] PASS — rc=" + to_string(rc))
    return true
}

// ─── CASE 3: clean inheritance (PASS baseline) ───────────────────
fn run_case_3(repo: string) -> bool {
    println("[case_3] .own strengthens .raw — expect PASS (exit 0)")
    let dir = "/tmp/own_inherit_fx_3"
    if !_scaffold(dir, repo) { return false }

    // .own 7 promotes status (warn → live) and keeps bans ⊇ .raw bans.
    let raw = "# fixture\n\n" +
              "raw 7 warn \"soft\"\n" +
              "  enforce tool/noop.hexa\n" +
              "  bans alpha\n"
    let own = "# fixture\n\n" +
              "own 7 live \"strengthened\"\n" +
              "  enforce tool/noop.hexa\n" +
              "  bans alpha beta\n"
    write_file(dir + "/.raw", raw)
    write_file(dir + "/.own", own)

    let r = _run_lint(dir)
    let rc = r[1]
    let out = to_string(r[0])
    _cleanup(dir)

    if rc != 0 {
        eprintln("[case_3] FAIL — lint rejected clean inheritance (exit=" + to_string(rc) + ")")
        eprintln(out)
        return false
    }
    if !out.contains("status: PASS") {
        eprintln("[case_3] FAIL — expected 'status: PASS' footer")
        eprintln(out)
        return false
    }
    println("[case_3] PASS")
    return true
}

fn main() -> int {
    println("── own_inherit_violation regression ──")
    if !_stage0_runnable() {
        println("SKIP — ./build/hexa_interp not executable on this host (expected under Linux sandbox)")
        return 0
    }
    let repo = _repo_root()
    if len(repo) == 0 {
        eprintln("FATAL — unable to resolve repo root via pwd")
        return 1
    }

    let mut fail = 0
    if !run_case_1(repo) { fail = fail + 1 }
    if !run_case_2(repo) { fail = fail + 1 }
    if !run_case_3(repo) { fail = fail + 1 }

    println("")
    if fail == 0 {
        println("own_inherit_violation: ALL PASS")
        return 0
    }
    eprintln("own_inherit_violation: " + to_string(fail) + " case(s) failed")
    return 1
}

exit(main())
