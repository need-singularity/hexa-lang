// Regression test for P0 bug #6 (anima handoff 2026-04-18)
//
// reproduce: stage0 인터프리터 fn main() 내 if/while/match 블록에서
//   println("literal") 이 HexaVal struct 포인터(e.g. 105553175085872)
//   를 출력하고 "literal" 이 출력되지 않음.
//
// expected output after fix:
//   inside_if
//   inside_while
//   inside_match
//   after
//
// reference:
//   /Users/ghost/Dev/anima/shared/feedback/hexa_lang_handoff_20260418.md L77-86
//   bt#52/53/66/67/68/69 + aa3060c (2026-04-13 부분 복구)
//   project_hexa_v2_circular_rebuild_20260417 (seed-freeze state)
//
// 검증 방법 (main 세션 rebuild 후):
//   build/hexa_stage0 tests/regression/anima_bug6_if_block_println.hexa
//   → 기대 출력 4줄. 숫자(ex 105553175085872) 출력되면 FAIL.

fn main() {
    if true {
        println("inside_if")
    }

    let mut i = 0
    while i < 1 {
        println("inside_while")
        i = i + 1
    }

    let k = 1
    match k {
        1 -> println("inside_match")
        _ -> println("other_match")
    }

    println("after")
}
