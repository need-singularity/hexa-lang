#!hexa strict
// test/regression/chain_prev_guard.hexa — strict mode prev-marker guard
//
// PURPOSE
//   chain "test4" = a → b → c (strict mode) 에서 c 에 직접 entry 를
//   시도하면 chain_runner 는 prev marker (step_a_ok, step_b_ok) 가 없어
//   BLOCKED 로 거부해야 한다. exit != 0 + "BLOCKED" / "refused" /
//   "prev" 류 키워드 포함.
//
// CASES
//   1. strict mode, entry at c (마커 전무) → chain_runner 거부.
//
// FIXTURE
//   /tmp/chain_test_4_<pid>/ fake repo, stage0 + chain_runner + law_io
//   심볼릭 링크. `.chain-state/test4/` 는 비어 있어야 한다 (fresh).
//
// MAC/LINUX NOTE
//   Linux sandbox 자동 SKIP.

use "self/core/law_io"

fn _stage0_runnable() -> bool {
    let r = exec_with_status("test -x ./build/hexa_stage0 && echo y || echo n")
    let out = to_string(r[0]).trim()
    return out == "y"
}

fn _repo_root() -> string {
    let r = exec_with_status("pwd")
    return to_string(r[0]).trim()
}

fn _pid() -> string {
    let r = exec_with_status("echo $$")
    return to_string(r[0]).trim()
}

fn _cleanup(dir: string) {
    exec("rm -rf '" + dir + "' 2>/dev/null")
}

fn run_case_1(repo: string) -> bool {
    println("[case_1] strict mode, mid-entry without prev markers — expect BLOCKED")

    let dir = "/tmp/chain_test_4_" + _pid()
    _cleanup(dir)

    let mk = exec_with_status("mkdir -p '" + dir + "/build' '" + dir + "/tool' '" + dir + "/self/core' '" + dir + "/.chain-state/test4'")
    if mk[1] != 0 {
        eprintln("[case_1] FAIL — mkdir fixture tree")
        _cleanup(dir)
        return false
    }

    let ln_cmds = [
        "ln -sf '" + repo + "/build/hexa_stage0' '" + dir + "/build/hexa_stage0'",
        "ln -sf '" + repo + "/tool/chain_runner.hexa' '" + dir + "/tool/chain_runner.hexa'",
        "ln -sf '" + repo + "/self/raw_loader.hexa' '" + dir + "/self/raw_loader.hexa'",
        "ln -sf '" + repo + "/self/core/law_io.hexa' '" + dir + "/self/core/law_io.hexa'"
    ]
    for c in ln_cmds {
        let r = exec_with_status(c)
        if r[1] != 0 {
            eprintln("[case_1] FAIL — symlink: " + c)
            _cleanup(dir)
            return false
        }
    }

    let chain = "# fixture — strict prev guard\n\n" +
                "chain test4 new \"strict prev guard\"\n" +
                "  mode strict\n" +
                "  step.a.cmd true\n" +
                "  step.a.next b\n" +
                "  step.b.cmd true\n" +
                "  step.b.next c\n" +
                "  step.c.cmd true\n"
    write_file(dir + "/.chain", chain)

    let cmd = "cd '" + dir + "' && ./build/hexa_stage0 tool/chain_runner.hexa run test4 c 2>&1"
    let r = exec_with_status(cmd)
    let rc = r[1]
    let out = to_string(r[0])

    let c_marker = exec_with_status("test -f '" + dir + "/.chain-state/test4/step_c_ok' && echo y || echo n")
    let c_present = to_string(c_marker[0]).trim() == "y"

    _cleanup(dir)

    if rc == 0 {
        eprintln("[case_1] FAIL — chain_runner returned 0 despite missing prev markers")
        eprintln(out)
        return false
    }
    if c_present {
        eprintln("[case_1] FAIL — step_c_ok present (should have been blocked)")
        return false
    }
    let blocked = out.contains("BLOCKED") || out.contains("blocked") || out.contains("refused") || out.contains("prev") || out.contains("missing")
    if !blocked {
        eprintln("[case_1] WARN — block evidence string not found (continuing)")
        eprintln(out)
    }
    println("[case_1] PASS — strict guard rejected mid-entry (exit=" + to_string(rc) + ")")
    return true
}

fn main() -> int {
    println("── chain_prev_guard regression ──")
    if !_stage0_runnable() {
        println("SKIP — ./build/hexa_stage0 not executable on this host")
        return 0
    }
    let repo = _repo_root()
    if len(repo) == 0 {
        eprintln("FATAL — pwd resolution failed")
        return 1
    }

    let mut fail = 0
    if !run_case_1(repo) { fail = fail + 1 }

    println("")
    if fail == 0 {
        println("chain_prev_guard: ALL PASS")
        return 0
    }
    eprintln("chain_prev_guard: " + to_string(fail) + " case(s) failed")
    return 1
}

exit(main())
