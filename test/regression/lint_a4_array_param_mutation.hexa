// HX-safety A4 (BG-HX1, 2026-05-02) — array param mutation lint fixture.
//
// hexa array values are passed by reference; in-place mutation of a
// param leaks back to the caller. This is the canonical class of bug
// underlying "mutation leak between sub-tests" patterns (e.g. the
// hxc_v3 selftest fixture array carrying state across test cases).
//
// Lint rule A4 fires on:
//   1. `param.push(...)` / `.pop(` / `.insert(` / `.remove(` / `.clear(` / `.append(` / `.extend(`
//   2. `param[i] = ...`
//   3. `param = param + ...` (rebinding)
//
// How to exercise:
//
//   ./hexa self/linter.hexa test/regression/lint_a4_array_param_mutation.hexa
//
// Expected: at least 4 "[A4] param ... mutated in fn body" warnings
// (one per case below).

// Case 1: push mutation — should fire
fn append_one(xs) {
    xs.push(1)
    return xs
}

// Case 2: index assign mutation — should fire
fn zero_first(xs) {
    xs[0] = 0
    return xs
}

// Case 3: rebinding param — should fire
fn rebind_param(xs) {
    xs = xs + [99]
    return xs
}

// Case 4: pop — should fire
fn drop_last(xs) {
    xs.pop()
    return xs
}

// Negative: read-only access — should NOT fire
fn read_first(xs) {
    if len(xs) > 0 { return xs[0] }
    return -1
}

// Negative: clone first then mutate local — should NOT fire (mutation
// targets `local`, not `xs`)
fn clone_then_mutate(xs) {
    let mut local = xs + []
    local.push(7)
    return local
}

fn main() {
    let v = [1, 2, 3]
    println(to_string(append_one(v)))
    println(to_string(zero_first(v)))
    println(to_string(rebind_param(v)))
    println(to_string(drop_last(v)))
    println(to_string(read_first(v)))
    println(to_string(clone_then_mutate(v)))
    return 0
}
