// test/regression/type_of_fn.hexa
// 2026-04-20 hexa_type_of fn/char/closure classification fix — commit
// 0adac579 site (3).
//
// Bug history:
//   runtime.c:3049 hexa_type_of's switch landed TAG_FN / TAG_CHAR /
//   TAG_CLOSURE in the default arm, returning "unknown". User Hexa code
//   that dispatches on `type_of(x) != "string"` silently took the wrong
//   branch for function / closure values.
//
// Fix (0adac579):
//   Explicit cases added:
//     TAG_FN      -> "fn"
//     TAG_CHAR    -> "char"
//     TAG_CLOSURE -> "closure"
//
// Path notes:
//   * Interpreter (stage0, seed-freeze) currently classifies bare fn exprs
//     as "fn" for both top-level fn values and `fn(...) {...}` lambdas.
//   * AOT (runtime.c fix active) classifies lambdas as "closure".
//   * Both must at minimum NOT return "unknown" for these categories —
//     that's the regression we're locking.

fn main() {
    // Closure literal — `fn(x) { ... }` inside a function body.
    let c = fn(x) { return x * 2 }
    let tc = type_of(c)
    if tc == "unknown" {
        println("FAIL type_of(closure) == unknown — fix 0adac579 regressed")
        exit(1)
    }
    // Accept either "fn" (interpreter) or "closure" (AOT runtime.c) — the
    // regression bar is "non-unknown, stable class name".
    if tc != "fn" {
        if tc != "closure" {
            print("FAIL type_of(closure) unexpected class: ")
            println(tc)
            exit(1)
        }
    }
    print("OK type_of(closure) = ")
    println(tc)

    // Primitive controls — must all classify cleanly (no "unknown").
    let ts = type_of("hello")
    if ts != "string" {
        print("FAIL type_of(string) expected 'string' got ")
        println(ts)
        exit(1)
    }
    let ti = type_of(42)
    if ti != "int" {
        print("FAIL type_of(int) expected 'int' got ")
        println(ti)
        exit(1)
    }
    let tf = type_of(3.14)
    if tf != "float" {
        print("FAIL type_of(float) expected 'float' got ")
        println(tf)
        exit(1)
    }
    let tb = type_of(true)
    if tb != "bool" {
        print("FAIL type_of(bool) expected 'bool' got ")
        println(tb)
        exit(1)
    }
    let ta = type_of([1, 2, 3])
    if ta != "array" {
        print("FAIL type_of(array) expected 'array' got ")
        println(ta)
        exit(1)
    }

    println("PASS type_of fn/closure/char no longer returns 'unknown' (0adac579 site 3)")
}
