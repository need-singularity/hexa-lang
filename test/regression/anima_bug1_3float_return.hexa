// tests/regression/anima_bug1_3float_return.hexa
//
// P0 regression — struct with multi-field + consecutive Field access emits
// fragmented C in native `hexa build` path. anima handoff 2026-04-18 reported
// it as "3-float struct return corrupt/SIGSEGV" but isolation narrows it to:
//
//   Field access inside a fn body emits `hexa_map_get_ic(obj, "k", &__hexa_ic_N)`
//   via gen2_expr; when a fn calls >=2 consecutive Field accesses on the same
//   local struct, the generated C file contains the fn body N+1 times — with
//   the first N copies progressively front-truncated (IC slot string appears
//   to share an arena slot that the next Field call rewrites).
//
// Observed minimal reproducer with N=2 fields → fn body emitted 3 times.
// Interpreter path (`hexa run`) is unaffected — pure codegen bug.
//
// This file is meant to be compiled with `hexa build` and the generated
// build/artifacts/<file>.c inspected. It must produce a valid C file where
// each user fn body is emitted exactly once. When compiled it must print
// the 1.0/2.0/3.0 sequence.
//
// anima workaround comments referenced this as "struct w/ ≥3 floats":
//   training/alm_affect_head.hexa:50-51
//   training/mi_fast.hexa:56
//
// Expected (after fix):
//   - `hexa build tests/regression/anima_bug1_3float_return.hexa` produces
//     a binary with exactly one `HexaVal u_main(void)` definition.
//   - Binary output contains `[anima_bug1_3float_return] ALL 13/13 PASS`.
//   - `hexa run` also produces the same banner.
// Actual (pre-fix, 2026-04-18 hexa_v2):
//   - `hexa build` fails with clang errors on front-truncated u_main copies.
//   - `hexa run` prints 13/13 PASS (interpreter side unaffected).

struct Coords3 { x: float, y: float, z: float }

fn make3() -> Coords3 {
    return Coords3{x: 1.0, y: 2.0, z: 3.0}
}

struct Coords4 { x: float, y: float, z: float, w: float }

fn make4() -> Coords4 {
    return Coords4{x: 1.0, y: 2.0, z: 3.0, w: 4.0}
}

struct Coords5 { a: float, b: float, c: float, d: float, e: float }

fn make5() -> Coords5 {
    return Coords5{a: 1.0, b: 2.0, c: 3.0, d: 4.0, e: 5.0}
}

fn feq(a: float, b: float) -> bool {
    let d = a - b
    if d < 0.0 { return (0.0 - d) < 0.0001 }
    return d < 0.0001
}

fn main() {
    let mut pass = 0
    let mut fail = 0

    // T1: 3-float struct return, all 3 fields
    let c3 = make3()
    if feq(c3.x, 1.0) { pass = pass + 1 } else { println("FAIL T1 c3.x"); fail = fail + 1 }
    if feq(c3.y, 2.0) { pass = pass + 1 } else { println("FAIL T1 c3.y"); fail = fail + 1 }
    if feq(c3.z, 3.0) { pass = pass + 1 } else { println("FAIL T1 c3.z"); fail = fail + 1 }

    // T2: 4-float struct return
    let c4 = make4()
    if feq(c4.x, 1.0) { pass = pass + 1 } else { println("FAIL T2 c4.x"); fail = fail + 1 }
    if feq(c4.y, 2.0) { pass = pass + 1 } else { println("FAIL T2 c4.y"); fail = fail + 1 }
    if feq(c4.z, 3.0) { pass = pass + 1 } else { println("FAIL T2 c4.z"); fail = fail + 1 }
    if feq(c4.w, 4.0) { pass = pass + 1 } else { println("FAIL T2 c4.w"); fail = fail + 1 }

    // T3: 5-float struct return
    let c5 = make5()
    if feq(c5.a, 1.0) { pass = pass + 1 } else { println("FAIL T3 c5.a"); fail = fail + 1 }
    if feq(c5.b, 2.0) { pass = pass + 1 } else { println("FAIL T3 c5.b"); fail = fail + 1 }
    if feq(c5.c, 3.0) { pass = pass + 1 } else { println("FAIL T3 c5.c"); fail = fail + 1 }
    if feq(c5.d, 4.0) { pass = pass + 1 } else { println("FAIL T3 c5.d"); fail = fail + 1 }
    if feq(c5.e, 5.0) { pass = pass + 1 } else { println("FAIL T3 c5.e"); fail = fail + 1 }

    // T4: inline construction + field access
    let z_direct = make3().z
    if feq(z_direct, 3.0) { pass = pass + 1 } else { println("FAIL T4 direct .z"); fail = fail + 1 }

    let total = pass + fail
    if fail == 0 {
        println("[anima_bug1_3float_return] ALL " + to_string(pass) + "/" + to_string(total) + " PASS")
    } else {
        println("[anima_bug1_3float_return] " + to_string(pass) + "/" + to_string(total) + " PASS, " + to_string(fail) + " FAIL")
    }
}

main()
