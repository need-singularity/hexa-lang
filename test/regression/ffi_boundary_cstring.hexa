// test/regression/ffi_boundary_cstring.hexa
// 2026-04-20 hexa_to_cstring container-fallback fix — commit 0adac579 site (1).
//
// Bug history:
//   runtime.c:621 hexa_to_cstring default branch returned the literal
//   string "<value>" for TAG_ARRAY / TAG_MAP / TAG_FN / TAG_CHAR / TAG_CLOSURE.
//   FFI callsites hash / compare on the returned ptr — every array, every map,
//   every fn silently collided in map keys and log strings.
//
// Fix (0adac579):
//   Default branch now delegates to hexa_to_string and returns the interned
//   char*, so distinct containers surface distinct strings ("[1, 2]" vs
//   "[3, 4]") and "<value>" is reserved as a last-resort when to_string itself
//   can't produce a string.
//
// Proxy test: the user-facing surface for hexa_to_cstring is indirect — most
// call sites are internal FFI (net.c / map key hashing). str() rides the same
// hexa_to_string path, so distinctness on str() of two different arrays
// proves the fallback is structural rather than collapsed to "<value>".
//
// Also verify: a map's structural repr is distinct from an array repr and
// from the "<value>" legacy sentinel.

fn main() {
    // Two distinct arrays must produce distinct strings.
    let a1 = [1, 2, 3]
    let a2 = [4, 5, 6]
    let s1 = str(a1)
    let s2 = str(a2)

    if s1 == s2 {
        println("FAIL arr cstring fallback collapsed (s1==s2)")
        exit(1)
    }
    if s1 == "<value>" {
        println("FAIL s1 returned legacy <value> sentinel")
        exit(1)
    }
    if s2 == "<value>" {
        println("FAIL s2 returned legacy <value> sentinel")
        exit(1)
    }
    println("PASS arr cstring distinctness: " + s1 + " != " + s2)

    // Array repr must not collide with the legacy "<value>" sentinel
    // regardless of content shape — exercise single-element + nested.
    let nested = [[1], [2, 3]]
    let sn = str(nested)
    if sn == "<value>" {
        println("FAIL nested arr returned <value>")
        exit(1)
    }
    println("PASS nested arr cstring: " + sn)

    // Integer-valued elements must surface their values, not the sentinel —
    // this protects log/error paths that cstring an arr for message assembly.
    if s1 == "[<value>]" || s1 == "<value>" {
        println("FAIL element-level <value> sentinel leak")
        exit(1)
    }

    println("PASS ffi_boundary_cstring 3/3 (0adac579 site 1)")
}
