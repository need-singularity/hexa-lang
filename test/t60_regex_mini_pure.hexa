// t60_regex_mini_pure — verifies self/runtime/regex_mini_pure.hexa
// EXPECTED: ALL PASS
//
// Covers the 5 net-new regex mini builtins. Fns are inlined because
// interp's interpreter does not currently parse import-paths (see
// t49_runtime_string_pure header, t59_geometry2d_pure header).
//
// Supported meta: . * ? ^ $ [abc] \\x
// Unsupported (not tested): + {n,m} | () \1 [a-z]

fn rx_char_at(s, i) {
    if i < 0 { return "" }
    if i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

fn rx_is_meta(ch) {
    if ch == "." { return true }
    if ch == "*" { return true }
    if ch == "?" { return true }
    if ch == "^" { return true }
    if ch == "$" { return true }
    if ch == "[" { return true }
    if ch == "]" { return true }
    if ch == "\\" { return true }
    return false
}

fn rx_atom_len(pattern, pi) {
    let plen = len(pattern)
    if pi >= plen { return 0 }
    let c = rx_char_at(pattern, pi)
    if c == "\\" {
        if pi + 1 >= plen { return 0 - 1 }
        return 2
    }
    if c == "[" {
        let mut j = pi + 1
        while j < plen {
            let cj = rx_char_at(pattern, j)
            if cj == "]" {
                return (j - pi) + 1
            }
            j = j + 1
        }
        return 0 - 1
    }
    return 1
}

fn rx_atom_matches(pattern, pi, atom_len, text, ti) {
    let tc = rx_char_at(text, ti)
    if tc == "" { return false }
    let head = rx_char_at(pattern, pi)
    if head == "\\" {
        let esc = rx_char_at(pattern, pi + 1)
        return tc == esc
    }
    if head == "." { return true }
    if head == "[" {
        let mut j = pi + 1
        let last = pi + atom_len - 1
        while j < last {
            let cj = rx_char_at(pattern, j)
            if cj == "\\" {
                let ej = rx_char_at(pattern, j + 1)
                if tc == ej { return true }
                j = j + 2
            } else {
                if tc == cj { return true }
                j = j + 1
            }
        }
        return false
    }
    return tc == head
}

fn rx_matchhere(pattern, pi, text, ti) {
    let plen = len(pattern)
    let tlen = len(text)
    if pi >= plen { return ti }
    let head = rx_char_at(pattern, pi)
    if head == "$" {
        if pi + 1 == plen {
            if ti == tlen { return ti }
            return 0 - 1
        }
    }
    let a_len = rx_atom_len(pattern, pi)
    if a_len < 0 { return 0 - 1 }
    let next_pi = pi + a_len
    let suffix = rx_char_at(pattern, next_pi)
    if suffix == "*" {
        return rx_matchstar(pattern, pi, a_len, next_pi + 1, text, ti)
    }
    if suffix == "?" {
        return rx_matchques(pattern, pi, a_len, next_pi + 1, text, ti)
    }
    if ti < tlen {
        if rx_atom_matches(pattern, pi, a_len, text, ti) {
            return rx_matchhere(pattern, next_pi, text, ti + 1)
        }
    }
    return 0 - 1
}

fn rx_matchstar(pattern, atom_pi, atom_len, rest_pi, text, ti) {
    let tlen = len(text)
    let mut hi = ti
    let mut stop = false
    while hi < tlen {
        if stop { break }
        if rx_atom_matches(pattern, atom_pi, atom_len, text, hi) {
            hi = hi + 1
        } else {
            stop = true
        }
    }
    let mut cur = hi
    while cur >= ti {
        let r = rx_matchhere(pattern, rest_pi, text, cur)
        if r >= 0 { return r }
        cur = cur - 1
    }
    return 0 - 1
}

fn rx_matchques(pattern, atom_pi, atom_len, rest_pi, text, ti) {
    let tlen = len(text)
    if ti < tlen {
        if rx_atom_matches(pattern, atom_pi, atom_len, text, ti) {
            let r1 = rx_matchhere(pattern, rest_pi, text, ti + 1)
            if r1 >= 0 { return r1 }
        }
    }
    return rx_matchhere(pattern, rest_pi, text, ti)
}

fn rx_search_span(pattern, text) {
    let plen = len(pattern)
    let tlen = len(text)
    if plen == 0 { return [0, 0] }
    if rx_char_at(pattern, 0) == "^" {
        let r = rx_matchhere(pattern, 1, text, 0)
        if r >= 0 { return [0, r] }
        return nil
    }
    let mut i = 0
    while i <= tlen {
        let r = rx_matchhere(pattern, 0, text, i)
        if r >= 0 { return [i, r] }
        i = i + 1
    }
    return nil
}

fn regex_match_pure(pattern, text) {
    let plen = len(pattern)
    let tlen = len(text)
    let mut start = 0
    let mut end = plen
    if plen > 0 {
        if rx_char_at(pattern, 0) == "^" { start = 1 }
    }
    if end > start {
        if rx_char_at(pattern, end - 1) == "$" {
            if end - 2 >= start {
                let before = rx_char_at(pattern, end - 2)
                if before != "\\" { end = end - 1 }
            } else {
                end = end - 1
            }
        }
    }
    let core = pattern.substring(start, end)
    let r = rx_matchhere(core, 0, text, 0)
    if r == tlen { return true }
    return false
}

fn regex_search_pure(pattern, text) {
    let span = rx_search_span(pattern, text)
    if type_of(span) == "void" { return false }
    return true
}

fn regex_find_pure(pattern, text) {
    let span = rx_search_span(pattern, text)
    if type_of(span) == "void" { return 0 - 1 }
    return span[0]
}

fn regex_find_all_pure(pattern, text) {
    let tlen = len(text)
    let plen = len(pattern)
    let mut out = []
    if plen == 0 { return out }
    if rx_char_at(pattern, 0) == "^" {
        let r = rx_matchhere(pattern, 1, text, 0)
        if r >= 0 { out.push(0) }
        return out
    }
    let mut i = 0
    while i <= tlen {
        let r = rx_matchhere(pattern, 0, text, i)
        if r >= 0 {
            out.push(i)
            if r > i {
                i = r
            } else {
                i = i + 1
            }
        } else {
            i = i + 1
        }
    }
    return out
}

fn regex_replace_first_pure(pattern, text, replacement) {
    let span = rx_search_span(pattern, text)
    if type_of(span) == "void" { return text }
    let s = span[0]
    let e = span[1]
    let tlen = len(text)
    let head = text.substring(0, s)
    let tail = text.substring(e, tlen)
    return head + replacement + tail
}

let mut fail = 0

// ── regex_match_pure (8) ───────────────────────────────────────────
// 1: literal exact
if regex_match_pure("abc", "abc") != true { fail = fail + 1; println("FAIL m1 literal") }
// 2: literal mismatch
if regex_match_pure("abc", "abd") != false { fail = fail + 1; println("FAIL m2 mismatch") }
// 3: literal partial not full match
if regex_match_pure("abc", "abcd") != false { fail = fail + 1; println("FAIL m3 partial") }
// 4: dot matches any single
if regex_match_pure("a.c", "abc") != true { fail = fail + 1; println("FAIL m4 dot") }
// 5: dot matches another char
if regex_match_pure("a.c", "axc") != true { fail = fail + 1; println("FAIL m5 dot x") }
// 6: a*b matches "b" (zero a's)
if regex_match_pure("a*b", "b") != true { fail = fail + 1; println("FAIL m6 star zero") }
// 7: a*b matches "aab"
if regex_match_pure("a*b", "aab") != true { fail = fail + 1; println("FAIL m7 star two") }
// 8: a*b matches "aaab"
if regex_match_pure("a*b", "aaab") != true { fail = fail + 1; println("FAIL m8 star three") }

// ── regex_match_pure anchors + classes (7) ─────────────────────────
// 9: ^abc redundant anchor full match
if regex_match_pure("^abc", "abc") != true { fail = fail + 1; println("FAIL m9 anchor start") }
// 10: abc$ redundant anchor full match
if regex_match_pure("abc$", "abc") != true { fail = fail + 1; println("FAIL m10 anchor end") }
// 11: [abc] class match
if regex_match_pure("[abc]", "b") != true { fail = fail + 1; println("FAIL m11 class b") }
// 12: [abc] class miss
if regex_match_pure("[abc]", "d") != false { fail = fail + 1; println("FAIL m12 class d") }
// 13: ? makes char optional — present
if regex_match_pure("ab?c", "abc") != true { fail = fail + 1; println("FAIL m13 ques yes") }
// 14: ? makes char optional — absent
if regex_match_pure("ab?c", "ac") != true { fail = fail + 1; println("FAIL m14 ques no") }
// 15: ? fails when extra char present
if regex_match_pure("ab?c", "abbc") != false { fail = fail + 1; println("FAIL m15 ques extra") }

// ── regex_match_pure escapes (3) ───────────────────────────────────
// 16: \\. escapes to literal dot
if regex_match_pure("a\\.c", "a.c") != true { fail = fail + 1; println("FAIL m16 esc dot yes") }
// 17: \\. does not match arbitrary char
if regex_match_pure("a\\.c", "abc") != false { fail = fail + 1; println("FAIL m17 esc dot no") }
// 18: \\* escapes to literal star
if regex_match_pure("a\\*b", "a*b") != true { fail = fail + 1; println("FAIL m18 esc star") }

// ── regex_search_pure (5) ──────────────────────────────────────────
// 19: search finds substring anywhere
if regex_search_pure("abc", "xabcy") != true { fail = fail + 1; println("FAIL s1 middle") }
// 20: search fails when absent
if regex_search_pure("abc", "xyz") != false { fail = fail + 1; println("FAIL s2 absent") }
// 21: ^abc only at start — hit
if regex_search_pure("^abc", "abcd") != true { fail = fail + 1; println("FAIL s3 start hit") }
// 22: ^abc only at start — miss
if regex_search_pure("^abc", "xabc") != false { fail = fail + 1; println("FAIL s4 start miss") }
// 23: bb does not match "b" (should be false — KMP sanity)
if regex_search_pure("bb", "b") != false { fail = fail + 1; println("FAIL s5 bb short") }

// ── regex_find_pure (5) ────────────────────────────────────────────
// 24: first hit at 1
if regex_find_pure("abc", "xabcy") != 1 { fail = fail + 1; println("FAIL f1 pos 1") }
// 25: no hit → -1
if regex_find_pure("zzz", "hello world") != 0 - 1 { fail = fail + 1; println("FAIL f2 neg1") }
// 26: hit at 0
if regex_find_pure("hel", "hello") != 0 { fail = fail + 1; println("FAIL f3 pos 0") }
// 27: ^ anchored miss → -1
if regex_find_pure("^abc", "xabc") != 0 - 1 { fail = fail + 1; println("FAIL f4 anchor miss") }
// 28: dot-class finds first matching char
if regex_find_pure(".", "xyz") != 0 { fail = fail + 1; println("FAIL f5 dot") }

// ── regex_find_all_pure (4) ────────────────────────────────────────
// 29: all occurrences of single char
let hits1 = regex_find_all_pure("a", "banana")
if len(hits1) != 3 { fail = fail + 1; println("FAIL fa1 count") }
if hits1[0] != 1 { fail = fail + 1; println("FAIL fa1 pos0") }
// 30: all occurrences of "ab" in "ababab"
let hits2 = regex_find_all_pure("ab", "ababab")
if len(hits2) != 3 { fail = fail + 1; println("FAIL fa2 count") }
// 31: no hits → empty array
let hits3 = regex_find_all_pure("zz", "hello")
if len(hits3) != 0 { fail = fail + 1; println("FAIL fa3 empty") }
// 32: anchored only matches once
let hits4 = regex_find_all_pure("^a", "aaaa")
if len(hits4) != 1 { fail = fail + 1; println("FAIL fa4 anchored") }

// ── regex_replace_first_pure (4) ───────────────────────────────────
// 33: replace literal once
if regex_replace_first_pure("cat", "the cat sat", "dog") != "the dog sat" { fail = fail + 1; println("FAIL r1 literal") }
// 34: no match → original
if regex_replace_first_pure("zzz", "hello", "X") != "hello" { fail = fail + 1; println("FAIL r2 miss") }
// 35: replace with empty string = deletion of first match
if regex_replace_first_pure("a", "banana", "") != "bnana" { fail = fail + 1; println("FAIL r3 delete") }
// 36: dot pattern replaces first char
if regex_replace_first_pure(".", "hi", "Q") != "Qi" { fail = fail + 1; println("FAIL r4 dot") }

// ── extra sanity: "c" should not match "a*b" full-anchored ─────────
// 37: "c" fails anchored a*b
if regex_match_pure("a*b", "c") != false { fail = fail + 1; println("FAIL m_extra c") }
// 38: "bb" fails anchored a*b (trailing b leftover)
if regex_match_pure("a*b", "bb") != false { fail = fail + 1; println("FAIL m_extra bb") }

if fail == 0 {
    println("ALL PASS")
} else {
    println("FAIL count=" + fail)
}
