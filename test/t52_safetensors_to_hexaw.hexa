// tests/t52_safetensors_to_hexaw.hexa — smoke for safetensors→hexaw2
//
// End-to-end proof that self/tools/safetensors_to_hexaw compiles
// + converts + the HEXAW2 reader in self/ml/hexaw.hexa loads the
// result with tensor names, shapes and values intact.
//
// Why this test is an *orchestrator* (builds+runs a native binary
// rather than exercising the converter directly in the interp):
// the streaming builtins (read_bytes_at / write_bytes_append /
// file_size_native) are wired through self/codegen_c2.hexa for
// native codegen (runtime.c hexa_read_bytes_at + friends) but the
// current stage0 interpreter cannot yet dispatch them — a stage0
// rebuild regression pre-dates this task. `hexa build` uses the
// hexa_v2 native transpiler which *does* see them, so we run the
// converter as a native binary. Small-tensor HEXAW2 *read-back*
// goes through hexaw_load which reads the whole file in one
// read_file_bytes slurp (safe for KB-range smoke input) and
// parses in pure-interp hexa — no new builtins required.
//
// Run:   ./hexa run tests/t52_safetensors_to_hexaw.hexa

use "../self/ml/hexaw"

let mut ok = true
fn must(label, cond) {
    if cond { println("PASS " + label) } else { ok = false; println("FAIL " + label) }
}

// ── 1. Build a tiny 2-tensor safetensors file in memory ──
//
// Layout:
//   [0..8)   header_size (u64 LE)
//   [8..)    JSON  { "t0": {dtype:"F32", shape:[3], offsets:[0,12]},
//                   "t1": {dtype:"BF16", shape:[2,2], offsets:[12, 20]} }
//                   // offsets are RELATIVE to the data region
//   then:
//   [hdr..)  data:  F32 t0 = [1.0, -2.0, 0.5]
//                   BF16 t1 = [1.0, 2.0, 3.0, 4.0]

let json = "{\"t0\":{\"dtype\":\"F32\",\"shape\":[3],\"data_offsets\":[0,12]},\"t1\":{\"dtype\":\"BF16\",\"shape\":[2,2],\"data_offsets\":[12,20]}}"
let mut json_bytes = []
let mut ci = 0
while ci < len(json) {
    json_bytes = json_bytes + [char_code(json, ci)]
    ci = ci + 1
}
let hsz = len(json_bytes)

// Pack u64 LE header_size
let mut out_bytes = []
let mut tmp = hsz
let mut bi = 0
while bi < 8 {
    out_bytes = out_bytes + [tmp % 256]
    tmp = tmp / 256
    bi = bi + 1
}
// Append JSON
out_bytes = out_bytes + json_bytes

// F32 payload for t0 = [1.0, -2.0, 0.5] — use hexaw_f32_to_bytes
out_bytes = out_bytes + hexaw_f32_to_bytes(1.0)
out_bytes = out_bytes + hexaw_f32_to_bytes(-2.0)
out_bytes = out_bytes + hexaw_f32_to_bytes(0.5)

// BF16 payload for t1 = [1.0, 2.0, 3.0, 4.0]
// bf16 is the high 16 bits of the IEEE f32 representation.
// f32(1.0) = 0x3f800000 → bf16 = 0x3f80 → LE [0x80, 0x3f]
// f32(2.0) = 0x40000000 → bf16 = 0x4000 → LE [0x00, 0x40]
// f32(3.0) = 0x40400000 → bf16 = 0x4040 → LE [0x40, 0x40]
// f32(4.0) = 0x40800000 → bf16 = 0x4080 → LE [0x80, 0x40]
out_bytes = out_bytes + [0x80, 0x3f]
out_bytes = out_bytes + [0x00, 0x40]
out_bytes = out_bytes + [0x40, 0x40]
out_bytes = out_bytes + [0x80, 0x40]

let st_path = "/tmp/_t52_input.safetensors"
write_bytes(st_path, out_bytes)
must("wrote safetensors input", file_exists(st_path))

// ── 2. Ensure converter binary exists; build if missing ──
//
// The converter embeds the new streaming builtins, so it must be
// compiled — `./hexa run` on the converter source would fail to
// resolve read_bytes_at in stage0. We shell out once per test run
// and cache the binary under build/.
let bin = "build/safetensors_to_hexaw"
if !file_exists(bin) {
    println("[t52] building converter (one-time)...")
    let build_rc = exec_with_status("./hexa build self/tools/safetensors_to_hexaw.hexa -o " + bin + " 2>&1")
    if build_rc[1] != 0 {
        println("FAIL converter build")
        println(build_rc[0])
        ok = false
    }
}
must("converter binary exists", file_exists(bin))

// ── 3. Run converter ─────────────────────────────────────
let hxw_path = "/tmp/_t52_output.hexaw"
let run_rc = exec_with_status(bin + " --input " + st_path + " --output " + hxw_path + " 2>&1")
must("converter exit 0", run_rc[1] == 0)
must("hexaw output exists", file_exists(hxw_path))

// ── 4. Read back via hexaw_load (autodetects HEXAW2) ─────
let hxw = hexaw_load(hxw_path)
must("2 tensors", len(hxw.names) == 2)
must("name[0] == t0", hxw.names[0] == "t0")
must("name[1] == t1", hxw.names[1] == "t1")
must("shape[0] == [3]", len(hxw.shapes[0]) == 1 && hxw.shapes[0][0] == 3)
must("shape[1] == [2,2]", len(hxw.shapes[1]) == 2 && hxw.shapes[1][0] == 2 && hxw.shapes[1][1] == 2)

// ── 5. Values (f32 round-trip must be bit-exact) ────────
let t0 = hxw.datas[0]
must("t0 len 3", len(t0) == 3)
must("t0[0] == 1.0", t0[0] == 1.0)
must("t0[1] == -2.0", t0[1] == -2.0)
must("t0[2] == 0.5", t0[2] == 0.5)

// ── 6. BF16 round-trip — bit-exact for values representable
//       in bf16 mantissa (all whole floats below 256). ──
let t1 = hxw.datas[1]
must("t1 len 4", len(t1) == 4)
must("t1[0] == 1.0", t1[0] == 1.0)
must("t1[1] == 2.0", t1[1] == 2.0)
must("t1[2] == 3.0", t1[2] == 3.0)
must("t1[3] == 4.0", t1[3] == 4.0)

// ── 7. Magic byte sanity on file ────────────────────────
let magic_bytes = read_file_bytes(hxw_path)
must("magic HEXAW2",
     magic_bytes[0] == 72 && magic_bytes[1] == 69 && magic_bytes[2] == 88
  && magic_bytes[3] == 65 && magic_bytes[4] == 87 && magic_bytes[5] == 50
  && magic_bytes[6] == 10)

// ── 8. HEXAW1 legacy path still works ────────────────────
let legacy = "/tmp/_t52_legacy.hexaw"
hexaw_save(legacy, ["leg"], [[2]], [[7.25, -3.5]])
let lrec = hexaw_load(legacy)
must("legacy 1 tensor", len(lrec.names) == 1)
must("legacy name", lrec.names[0] == "leg")
must("legacy values", lrec.datas[0][0] == 7.25 && lrec.datas[0][1] == -3.5)

if ok { println("PASS t52_safetensors_to_hexaw") } else { println("FAIL t52_safetensors_to_hexaw") }
