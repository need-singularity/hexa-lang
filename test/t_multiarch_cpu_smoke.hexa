// ═══════════════════════════════════════════════════════════════
//  test/t_multiarch_cpu_smoke.hexa — F-MULTIARCH-1 CPU acceptance
//
//  The CPU row of the 4 arch × 2 shape matrix:
//    - arch_dispatch identifies the local backend (cpu on macOS-no-MPS,
//      mps on macOS-with-Metal-built, cuda on H100 pod, etc.)
//    - model_registry exposes shape metadata for the 4 known shapes
//    - cpu_forward_tiny runs an end-to-end forward on the "tiny" shape
//      and emits a deterministic checksum
//
//  This test is the only matrix row that runs on a developer Mac
//  without hardware. The CUDA / MPS / ROCm rows on full-size shapes
//  (qwen14b / llama-7b / mistral-7b) are scheduled on the matching
//  hardware via state/multiarch_matrix.md.
//
//  Run:
//    /Users/ghost/.hx/bin/hexa run test/t_multiarch_cpu_smoke.hexa
// ═══════════════════════════════════════════════════════════════

use "self/ml/arch_dispatch"
use "self/ml/model_registry"
use "self/ml/cpu_forward_tiny"

let mut PASS = 0
let mut FAIL = 0

fn check(label, cond) {
    if cond { PASS = PASS + 1; println("[PASS] " + label) }
    else    { FAIL = FAIL + 1; println("[FAIL] " + label) }
}

// ── T1: arch dispatch reports a sensible backend ────────────────
let probes = arch_probe_all()
println("[t_multiarch] probes: cpu=" + str(probes[0][1])
      + " cuda=" + str(probes[1][1])
      + " mps="  + str(probes[2][1])
      + " rocm=" + str(probes[3][1]))
check("arch_probe_all returns 4 entries", len(probes) == 4)
check("cpu always available", probes[0][1] == true)

let be_cpu = arch_select("cpu")
check("arch_select(cpu).kind == ARCH_CPU", be_cpu.kind == 0)
check("arch_select(cpu).name == 'cpu'", be_cpu.name == "cpu")

// auto must produce a non-rocm result on darwin (we have no rocm host)
let be_auto = arch_select("auto")
check("arch_select(auto) returns a backend", be_auto.kind >= 0)
println("[t_multiarch] auto-selected: " + arch_describe(be_auto))

// ── T2: shape registry round-trip ───────────────────────────────
let qwen = shape_lookup("qwen14b")
check("qwen14b.layers == 48", qwen.layers == 48)
check("qwen14b.d_model == 5120", qwen.d_model == 5120)
check("qwen14b.n_kv_heads == 8 (GQA)", qwen.n_kv_heads == 8)

let llama = shape_lookup("llama-7b")
check("llama-7b.layers == 32", llama.layers == 32)
check("llama-7b.rope_base == 10000", llama.rope_base == 10000.0)
check("llama-7b no-GQA (kv_heads == n_heads)", llama.n_kv_heads == llama.n_heads)

let mistral = shape_lookup("mistral-7b")
check("mistral-7b.d_ff == 14336", mistral.d_ff == 14336)
check("mistral-7b GQA 4:1", mistral.n_heads == mistral.n_kv_heads * 4)
check("mistral-7b.rope_base == 1e6", mistral.rope_base == 1000000.0)

let tiny = shape_lookup("tiny")
check("tiny.layers == 2", tiny.layers == 2)
check("tiny.d_model == 16", tiny.d_model == 16)

let unknown = shape_lookup("does-not-exist")
check("unknown id surfaces as 'unknown'", unknown.id == "unknown")

let ids = shape_known_ids()
check("4 registered shapes", len(ids) == 4)

println("[t_multiarch] qwen14b est params: " + str(shape_param_estimate(qwen)))
println("[t_multiarch] llama-7b est params: " + str(shape_param_estimate(llama)))
println("[t_multiarch] mistral-7b est params: " + str(shape_param_estimate(mistral)))

// ── T3: end-to-end CPU forward on tiny shape ────────────────────
// Flat-buffer (alloc_raw + write_f32) implementation — pure-hexa
// nested arrays were 30x heavier and OOM'd the 4 GiB hexa-runner.
let result = cpu_forward_tiny(2)
let sample = result[0]   // [logits[0,0], logits[0,1], logits[0,2], logits[0,3]]
let csum = result[1]
let id = result[2]
let L = result[3]
let D = result[4]
let V = result[5]

check("forward returned tiny shape id", id == "tiny")
check("forward used 2 layers", L == 2)
check("forward used d_model=16", D == 16)
check("forward used vocab=32", V == 32)
check("logits row sample has 4 elems", len(sample) == 4)
check("checksum is finite (>= 0)", csum >= 0.0)
check("checksum is non-trivial (> 0)", csum > 0.0)
println("[t_multiarch] logits[0, 0..4] = " + str(sample))

println("[t_multiarch] forward checksum: " + str(csum))

// ── Summary ─────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════════")
println("  F-MULTIARCH-1 CPU smoke: PASS=" + str(PASS) + " FAIL=" + str(FAIL))
println("═══════════════════════════════════════════════════════════")
if FAIL > 0 { println("FAILED") } else { println("OK") }
