// test/t_multiarch_cpu_smoke.hexa
//
// F-MULTIARCH-1 CPU x tiny matrix cell. The only cell the agent owns
// without hardware. Asserts:
//   1. arch_select("cpu") yields kind == ARCH_CPU on any host.
//   2. arch_probe_all() reports CPU as available (always-true row).
//   3. shape_lookup("tiny") yields the canonical synthetic shape.
//   4. cpu_forward_tiny() returns a non-zero float (forward pass ran).
//   5. The checksum is finite (no NaN / inf from the kernels).
//
// We do NOT assert exact-checksum equality here. The matrix doc
// records the first-run checksum on each row; if a later commit
// changes the kernel and the checksum drifts, the row goes back to
// PENDING-HARDWARE until re-validated. That policy is documented in
// state/multiarch_matrix.md.
//
// Run:
//   /Users/ghost/.hx/bin/hexa run test/t_multiarch_cpu_smoke.hexa
//
// or with a forced backend:
//   HEXA_ARCH=cpu /Users/ghost/.hx/bin/hexa run test/t_multiarch_cpu_smoke.hexa

use "self/ml/arch_dispatch"
use "self/ml/model_registry"
use "self/ml/cpu_forward_tiny"

let mut G_OK = true

fn must(label, cond) {
    if cond {
        println("PASS " + label)
    } else {
        G_OK = false
        println("FAIL " + label)
    }
}

fn main() {
    println("[t_multiarch_cpu_smoke] start")

    // ── 1. arch_select → CPU ────────────────────────────────────
    let backend = arch_select("cpu")
    must("arch_select(cpu) kind == ARCH_CPU", backend.kind == ARCH_CPU)
    must("arch_select(cpu) name == cpu", backend.name == "cpu")
    println("  describe=" + arch_describe(backend))

    // ── 2. arch_probe_all → CPU row always true ─────────────────
    let probes = arch_probe_all()
    must("probe_all len == 4", len(probes) == 4)
    let cpu_row = probes[0]
    must("probe_all CPU available", cpu_row[1])

    // ── 3. shape registry has all 4 ids ─────────────────────────
    let ids = shape_known_ids()
    must("shape registry has 4 ids", len(ids) == 4)
    let s = shape_lookup("tiny")
    must("tiny.id == tiny", s.id == "tiny")
    must("tiny.n_layers == 4", s.n_layers == 4)
    must("tiny.head_dim == 16", s.head_dim == 16)
    println("  shape=" + shape_describe(s))

    // Spot-check the larger shapes load (no crash on the big ints).
    let q = shape_lookup("qwen14b")
    must("qwen14b family", q.family == "qwen")
    must("qwen14b rope_base 1e6", q.rope_base > 999999.0)
    let l = shape_lookup("llama-7b")
    must("llama-7b non-GQA", l.n_heads == l.n_kv_heads)
    let m = shape_lookup("mistral-7b")
    must("mistral-7b GQA 4:1", m.n_heads == m.n_kv_heads * 4)

    // ── 4. CPU forward pass runs and returns finite non-zero ────
    let chk = cpu_forward_tiny()
    println("  cpu_forward_tiny checksum=" + to_string(chk))
    // chk == 0.0 would mean either every kernel collapsed or the
    // residual stream cancelled exactly — both indicate a bug.
    must("forward checksum != 0", chk != 0.0)
    // NaN check: NaN != NaN, so the equality with itself would fail.
    must("forward checksum finite (== self)", chk == chk)

    // ── 5. Unknown shape fallback ───────────────────────────────
    let bogus = shape_lookup("definitely-not-a-shape-id")
    must("unknown shape falls back to tiny", bogus.id == "tiny")

    if G_OK {
        println("PASS t_multiarch_cpu_smoke")
    } else {
        println("FAIL t_multiarch_cpu_smoke")
    }
}
