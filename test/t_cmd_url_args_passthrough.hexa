// t_cmd_url_args_passthrough.hexa — selftest for cmd_url args= multi-value
// passthrough (2026-05-01 fix). Uses test fixtures: invokes the dispatcher
// itself via exec(), feeds a hexa://run URL, asserts argv is forwarded.
//
// Bug history: cmd_url() previously called cmd_run(file, []), silently
// dropping ?args= query values. Fix added hexa_url_query_get_all + decode.

fn assert_contains(out, needle, label) {
    if out.contains(needle) {
        println("  PASS: " + label)
        return 0
    }
    println("  FAIL: " + label + " (missing: " + needle + ")")
    println("  ----")
    println(out)
    println("  ----")
    return 1
}

fn main() {
    let probe = "/tmp/_cmd_url_args_probe.hexa"
    let _w = exec("cat > '" + probe + "' <<'HEXA'\nfn main() {\n    let n = args.len()\n    println(\"ARG_COUNT=\" + to_string(n))\n    let mut i = 0\n    while i < n {\n        println(\"ARG[\" + to_string(i) + \"]=\" + args[i])\n        i = i + 1\n    }\n}\nHEXA\n")
    let bin = env_var("HEXA_BIN")
    let mut cli = bin
    if len(cli) == 0 { cli = "/tmp/hexa_real_test" }
    let env_pre = "HEXA_SHIM_NO_DARWIN_LANDING=1 "
    let mut fails = 0
    // Case 1: multi-value args=.
    let r1 = exec(env_pre + "'" + cli + "' url 'hexa://run?file=" + probe + "&args=hello&args=world' 2>&1")
    fails = fails + assert_contains(r1, "ARG_COUNT=3", "case1 ARG_COUNT=3")
    fails = fails + assert_contains(r1, "ARG[1]=hello", "case1 args[1]=hello")
    fails = fails + assert_contains(r1, "ARG[2]=world", "case1 args[2]=world")
    // Case 2: %20 decode.
    let r2 = exec(env_pre + "'" + cli + "' url 'hexa://run?file=" + probe + "&args=hello%20world' 2>&1")
    fails = fails + assert_contains(r2, "ARG[1]=hello world", "case2 %20 decode")
    // Case 3: + decode.
    let r3 = exec(env_pre + "'" + cli + "' url 'hexa://run?file=" + probe + "&args=foo+bar' 2>&1")
    fails = fails + assert_contains(r3, "ARG[1]=foo bar", "case3 + decode")
    let _rm = exec("rm -f '" + probe + "'")
    if fails == 0 {
        println("OK: cmd_url args= passthrough (3/3)")
    } else {
        println("FAIL: " + to_string(fails) + " assertion(s)")
        exit(1)
    }
}
