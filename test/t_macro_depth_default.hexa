// #7 DoS-class fix: default tau=4 macro expansion bound
//
// Simulates an infinite macro (`@macro fn loop() { loop!() }`) by
// calling expand_macro_with_ctx in a tight recursion loop. Without
// the depth cap, this would never terminate. With tau=4, the 5th
// call must return an ERROR string containing "tau-bound".
//
// NOTE: self/macro_expand.hexa uses `match { "kind" => {...} }` which
// stage0 cannot parse, so we cannot `use` the module directly under
// seed-frozen build. Instead we INLINE the exact context struct +
// depth-check logic from macro_expand.hexa to exercise the bound
// semantics. The production module already has the same code; this
// test validates the contract without requiring a parser rebuild.

let mut pass_count = 0
let mut fail_count = 0

fn check(name, ok) {
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ── Inlined copy of self/macro_expand.hexa depth-bound logic ──
// If either changes, update both sites. See spec.md "tau-bound for
// metaprogramming".

struct MCtx {
    depth: int,
    max_depth: int,
    stack: [string],
    error: string
}

fn mctx_new() -> MCtx {
    return MCtx { depth: 0, max_depth: 4, stack: [], error: "" }
}

fn check_bound(ctx: MCtx, mac_name: string) -> string {
    ctx.depth = ctx.depth + 1
    ctx.stack = ctx.stack.push(mac_name)
    if ctx.depth > ctx.max_depth {
        let chain = ctx.stack.join(" -> ")
        let msg = "ERROR:macro " + mac_name +
            " exceeded tau-bound (depth=" + to_string(ctx.depth) +
            " > " + to_string(ctx.max_depth) +
            ") at chain: " + chain
        ctx.error = msg
        return msg
    }
    return "OK"
}

fn main() {
    let ctx = mctx_new()
    // Outer loop bounded at 20 so a regression cannot hang the runner.
    let mut fired_at = -1
    let mut last = ""
    let mut i = 0
    while i < 20 {
        last = check_bound(ctx, "loop_forever")
        if ctx.error != "" && fired_at == -1 {
            fired_at = ctx.depth
            break
        }
        i = i + 1
    }
    check("default max_depth == 4", ctx.max_depth == 4)
    check("abort fires (ctx.error != empty)", ctx.error != "")
    check("abort fires at depth 5 (first > 4)", fired_at == 5)
    check("error message mentions tau-bound",
          ctx.error.contains("tau-bound"))
    check("error message mentions macro name",
          ctx.error.contains("loop_forever"))
    check("error message includes chain",
          ctx.error.contains("chain:"))
    check("iteration budget not exhausted (fast fire)", i < 10)

    println("---")
    println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("RESULT: PASS")
    } else {
        println("RESULT: FAIL")
    }
}

main()
