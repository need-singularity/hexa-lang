// t_select_dispatch_parse — S-2d unit coverage for self/opt/select_dispatch.
//
// Verifies the pure-hexa parser for the @select serialized form emitted by
// self/parser.hexa 7550ae7:
//   "select|FAMILY@@COND_RAW~>ALGO@@...@@else~>DEFAULT"
//
// Also exercises select_find_in_annotations() against a composite
// FnDecl.annotations field that concatenates multiple `kind|raw` records
// with ';' (matches self/parser.hexa parse_fn_decl / parse_async_fn).
//
// Codegen rendering (select_emit_c_prologue) is smoke-tested for shape —
// the exact C literal is checked against a single golden string to keep
// this harness self-contained (no golden-file IO).

use "../self/opt/select_dispatch"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        println("       expected=" + to_string(expected))
        println("       got=     " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn main() {
    // T1: canonical 3-arm with explicit else (sort family).
    let s1 = "select|sort@@n <= 16~>insertion@@n <= 10000~>quick@@else~>merge"
    let r1 = select_parse_one(s1)
    check("T1 ok",               r1.ok,                 true)
    check("T1 family",            r1.family,             "sort")
    check("T1 arm count",         len(r1.arms),          2)
    check("T1 arm0 cond",         r1.arms[0].cond_raw,   "n <= 16")
    check("T1 arm0 algo",         r1.arms[0].algo,       "insertion")
    check("T1 arm1 cond",         r1.arms[1].cond_raw,   "n <= 10000")
    check("T1 arm1 algo",         r1.arms[1].algo,       "quick")
    check("T1 default algo",      r1.default_algo,       "merge")

    // T2: two-arm form with only else default (search family).
    let s2 = "select|search@@sorted~>binary@@else~>linear"
    let r2 = select_parse_one(s2)
    check("T2 ok",                r2.ok,                 true)
    check("T2 family",            r2.family,             "search")
    check("T2 arm count",         len(r2.arms),          1)
    check("T2 arm0 cond",         r2.arms[0].cond_raw,   "sorted")
    check("T2 arm0 algo",         r2.arms[0].algo,       "binary")
    check("T2 default",           r2.default_algo,       "linear")

    // T3: no default (fallthrough to annotated fn body).
    let s3 = "select|reduce@@n <= 64~>seq_reduce"
    let r3 = select_parse_one(s3)
    check("T3 ok",                r3.ok,                 true)
    check("T3 arm count",         len(r3.arms),          1)
    check("T3 default empty",     r3.default_algo,       "")

    // T4: malformed (missing ~> separator) → ok=false, no throw.
    let s4 = "select|broken@@no-separator-here"
    let r4 = select_parse_one(s4)
    check("T4 ok=false",          r4.ok,                 false)

    // T5: non-select record yields failure (not a throw).
    let s5 = "memo|(n, 100)"
    let r5 = select_parse_one(s5)
    check("T5 non-select fail",   r5.ok,                 false)

    // T6: select_find_in_annotations — composite field with memo + select,
    //     mirroring the ';' join at self/parser.hexa:1224.
    let composite = "memo|(n, 100);select|sort@@n <= 16~>insertion@@else~>merge"
    let r6 = select_find_in_annotations(composite)
    check("T6 finds select",      r6.ok,                 true)
    check("T6 family",            r6.family,             "sort")
    check("T6 default",           r6.default_algo,       "merge")

    // T7: absent select yields ok=false, err="not found" — NOT an error.
    let r7 = select_find_in_annotations("memo|(n, 100)")
    check("T7 absent select",     r7.ok,                 false)
    check("T7 err=not found",     r7.err,                "not found")

    // T8: empty annotations field — same semantics as T7.
    let r8 = select_find_in_annotations("")
    check("T8 empty ok=false",    r8.ok,                 false)

    // T9: select_emit_c_prologue — shape-check against golden for sort r1.
    //     (Arg format is the mangled-identifier list the caller chose.)
    let params = ["u_n"]
    let emitted = select_emit_c_prologue(r1, "HexaVal", params)
    let expected = ""
        + "    /* @select('sort') dispatch prologue — S-2d */\n"
        + "    if ((n <= 16)) {\n"
        + "        return insertion(u_n);\n"
        + "    }\n"
        + "    if ((n <= 10000)) {\n"
        + "        return quick(u_n);\n"
        + "    }\n"
        + "    /* @select default — explicit `else -> merge` */\n"
        + "    return merge(u_n);\n"
    check("T9 emitted prologue",  emitted,               expected)

    // T10: prologue for a spec without default ends with no explicit return —
    //      falls through to the annotated fn's own body.
    let params10 = ["u_n"]
    let emitted10 = select_emit_c_prologue(r3, "HexaVal", params10)
    let expected10 = ""
        + "    /* @select('reduce') dispatch prologue — S-2d */\n"
        + "    if ((n <= 64)) {\n"
        + "        return seq_reduce(u_n);\n"
        + "    }\n"
    check("T10 no-default prologue", emitted10,          expected10)

    // T11: multi-param render — arg list is comma-joined.
    let params11 = ["u_m", "u_n"]
    let r11 = select_parse_one("select|matmul@@m * n <= 4096~>naive_mm@@else~>blis_mm")
    let emitted11 = select_emit_c_prologue(r11, "HexaVal", params11)
    let expected11 = ""
        + "    /* @select('matmul') dispatch prologue — S-2d */\n"
        + "    if ((m * n <= 4096)) {\n"
        + "        return naive_mm(u_m, u_n);\n"
        + "    }\n"
        + "    /* @select default — explicit `else -> blis_mm` */\n"
        + "    return blis_mm(u_m, u_n);\n"
    check("T11 multi-param prologue", emitted11,         expected11)

    println("---")
    println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("RESULT: PASS")
    } else {
        println("RESULT: FAIL")
    }
}

main()
