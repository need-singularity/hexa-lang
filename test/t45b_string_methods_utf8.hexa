// t45b_string_methods_utf8 — UTF-8 + new methods regression
// EXPECTED: ALL PASS
// 2026-04-20: fix(hexa): string API — byte index + missing methods
//
// Semantics standardized on BYTE indices (matches C stdlib, len(), index_of(),
// substring()). Char-aware access via .char_count() / .nth_char() /
// .char_substring() / .chars() which walk UTF-8 codepoints.

// ── byte-index semantics invariants ────────────────────────
let ascii = "hello"
if ascii.len() == 5 { println("PASS ascii.len=5") } else { println("FAIL ascii.len") }
if ascii.index_of("ll") == 2 { println("PASS ascii.index_of") } else { println("FAIL ascii.index_of") }
if ascii.substring(1, 4) == "ell" { println("PASS ascii.substring") } else { println("FAIL ascii.substring") }

let ko = "한글hi"  // 3+3+1+1 = 8 bytes, 4 chars
if ko.len() == 8 { println("PASS ko.len=8") } else { println("FAIL ko.len=" + to_string(ko.len())) }
if ko.index_of("hi") == 6 { println("PASS ko.index_of=6") } else { println("FAIL ko.index_of") }
// byte-index substring(0,3) = first Korean char
if ko.substring(0, 3) == "한" { println("PASS ko.substring(0,3)=한") } else { println("FAIL ko.substring") }

// ── new method: find (alias of index_of) ────────────────────
if "abcdef".find("cd") == 2 { println("PASS find") } else { println("FAIL find") }
if "abc".find("xyz") == -1 { println("PASS find=-1") } else { println("FAIL find=-1") }

// ── new method: last_index_of / rfind ──────────────────────
if "abcabc".last_index_of("abc") == 3 { println("PASS last_index_of=3") } else { println("FAIL last_index_of") }
if "hello".rfind("l") == 3 { println("PASS rfind=3") } else { println("FAIL rfind") }
if "abc".last_index_of("xyz") == -1 { println("PASS last_index_of=-1") } else { println("FAIL last_index_of=-1") }
// multibyte last_index_of: byte offset
if "한글한글".last_index_of("한글") == 6 { println("PASS ko.last_index_of=6") } else { println("FAIL ko.last_index_of=" + to_string("한글한글".last_index_of("한글"))) }

// ── new method: char_at (byte-level) ────────────────────────
if "abc".char_at(1) == "b" { println("PASS char_at") } else { println("FAIL char_at") }
if "abc".char_at(10) == "" { println("PASS char_at_oob") } else { println("FAIL char_at_oob") }

// ── new method: slice (alias of substring) ──────────────────
if "hello".slice(1, 4) == "ell" { println("PASS slice") } else { println("FAIL slice") }
if "hello".slice(2) == "llo" { println("PASS slice_nodefault") } else { println("FAIL slice_nodefault") }

// ── new method: byte_at ─────────────────────────────────────
if "abc".byte_at(0) == 97 { println("PASS byte_at=97") } else { println("FAIL byte_at=" + to_string("abc".byte_at(0))) }
if "abc".byte_at(99) == -1 { println("PASS byte_at_oob") } else { println("FAIL byte_at_oob") }

// ── new method: char_count (UTF-8 aware) ────────────────────
if "hello".char_count() == 5 { println("PASS char_count_ascii=5") } else { println("FAIL char_count_ascii=" + to_string("hello".char_count())) }
if "한글hi".char_count() == 4 { println("PASS char_count_ko=4") } else { println("FAIL char_count_ko=" + to_string("한글hi".char_count())) }
if "".char_count() == 0 { println("PASS char_count_empty") } else { println("FAIL char_count_empty") }

// ── new method: nth_char (UTF-8 aware codepoint extract) ────
if "abc".nth_char(1) == "b" { println("PASS nth_char_ascii") } else { println("FAIL nth_char_ascii") }
if "한글hi".nth_char(0) == "한" { println("PASS nth_char_ko0=한") } else { println("FAIL nth_char_ko0=[" + "한글hi".nth_char(0) + "]") }
if "한글hi".nth_char(1) == "글" { println("PASS nth_char_ko1=글") } else { println("FAIL nth_char_ko1=[" + "한글hi".nth_char(1) + "]") }
if "한글hi".nth_char(2) == "h" { println("PASS nth_char_ko2=h") } else { println("FAIL nth_char_ko2=[" + "한글hi".nth_char(2) + "]") }
if "한글hi".nth_char(3) == "i" { println("PASS nth_char_ko3=i") } else { println("FAIL nth_char_ko3=[" + "한글hi".nth_char(3) + "]") }
if "한글".nth_char(9) == "" { println("PASS nth_char_oob") } else { println("FAIL nth_char_oob") }

// ── new method: char_substring (UTF-8 aware) ────────────────
if "한글hi".char_substring(0, 2) == "한글" { println("PASS char_sub_ko0_2") } else { println("FAIL char_sub_ko0_2=[" + "한글hi".char_substring(0, 2) + "]") }
if "한글hi".char_substring(2, 4) == "hi" { println("PASS char_sub_ko2_4") } else { println("FAIL char_sub_ko2_4") }
if "abcdef".char_substring(1, 4) == "bcd" { println("PASS char_sub_ascii") } else { println("FAIL char_sub_ascii") }

// ── chars() returns codepoints, not bytes ──────────────────
let cs = "한글hi".chars()
if len(cs) == 4 { println("PASS chars_ko_len=4") } else { println("FAIL chars_ko_len=" + to_string(len(cs))) }
if cs[0] == "한" { println("PASS chars_ko[0]=한") } else { println("FAIL chars_ko[0]=[" + cs[0] + "]") }
if cs[2] == "h" { println("PASS chars_ko[2]=h") } else { println("FAIL chars_ko[2]=[" + cs[2] + "]") }

// ── to_lowercase / to_uppercase aliases ────────────────────
if "HELLO".to_lowercase() == "hello" { println("PASS to_lowercase") } else { println("FAIL to_lowercase") }
if "hello".to_uppercase() == "HELLO" { println("PASS to_uppercase") } else { println("FAIL to_uppercase") }

println("ALL PASS")
