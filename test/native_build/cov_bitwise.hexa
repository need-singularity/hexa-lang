// ═══════════════════════════════════════════════════════════
//  tests/native_build/cov_bitwise.hexa
//  P7-6 coverage gap #2 — bitwise / shift IR ops smoke test
//
//  Scope:
//    Verifies that ir_to_arm64 + ir_to_x86 emit the expected bytes
//    for the 5 new IR ops: band/bor/bxor/shl/shr. Each test builds
//    a single-block IR stream with two imm loads + 1 bitwise op,
//    lowers to bytes, and asserts a specific encoding pattern is
//    present.
//
//  Strategy:
//    Encoders are inlined (same pattern as self/test_ir_to_arm64.hexa)
//    so this test is standalone under hexa_interp with no concat-link
//    dependency. Golden instruction word compared via contains_instr.
//
//  Run:
//    hexa tests/native_build/cov_bitwise.hexa
//
//  Expected: "ALL PASS — 10/10" on success.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check_true(name: string, cond: bool) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_int_eq(name: string, got: int, expected: int) {
    if got == expected {
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected " + to_string(expected) + " got " + to_string(got))
        fail_count = fail_count + 1
    }
}

// ── IR shape (mirrors self/test_ir_to_arm64.hexa) ────────────
struct IRInstr {
    result: int,
    op: string,
    ty: string,
    a: int,
    b: int,
    c: int,
    imm: int,
    is_imm: bool,
    cmp: string
}

struct BB {
    id: int,
    instructions: array
}

fn mk_bb(id: int) -> BB { return BB { id: id, instructions: [] } }
fn bb_push(bb: BB, inst: IRInstr) -> BB {
    return BB { id: bb.id, instructions: bb.instructions.push(inst) }
}

fn ir_load_imm(result: int, imm: int) -> IRInstr {
    return IRInstr { result: result, op: "load", ty: "i64",
        a: 0, b: 0, c: 0, imm: imm, is_imm: true, cmp: "" }
}
fn ir_binop(op: string, result: int, a: int, b: int) -> IRInstr {
    return IRInstr { result: result, op: op, ty: "i64",
        a: a, b: b, c: 0, imm: 0, is_imm: false, cmp: "" }
}

// ═══════════════════════════════════════════════════════════
//  Inlined ARM64 encoders (match self/codegen/ir_to_arm64.hexa)
// ═══════════════════════════════════════════════════════════

fn a_emit32_le(code: [int], instr: int) -> [int] {
    let b0 = instr % 256
    let b1 = (instr / 256) % 256
    let b2 = (instr / 65536) % 256
    let b3 = (instr / 16777216) % 256
    return code.push(b0).push(b1).push(b2).push(b3)
}
fn a_enc_movz(rd: int, imm16: int) -> int {
    return 3531603968 + (imm16 * 32) + rd
}
fn a_enc_and(rd: int, rn: int, rm: int) -> int {
    return 2315255808 + (rm * 65536) + (rn * 32) + rd
}
fn a_enc_orr(rd: int, rn: int, rm: int) -> int {
    return 2852126720 + (rm * 65536) + (rn * 32) + rd
}
fn a_enc_eor(rd: int, rn: int, rm: int) -> int {
    return 3388997632 + (rm * 65536) + (rn * 32) + rd
}
fn a_enc_lslv(rd: int, rn: int, rm: int) -> int {
    return 2596159488 + (rm * 65536) + (rn * 32) + rd
}
fn a_enc_lsrv(rd: int, rn: int, rm: int) -> int {
    return 2596160512 + (rm * 65536) + (rn * 32) + rd
}

fn a_lower(blocks) -> [int] {
    let mut bytes = []
    let mut bi = 0
    while bi < len(blocks) {
        let bb = blocks[bi]
        let mut ii = 0
        while ii < len(bb.instructions) {
            let inst = bb.instructions[ii]
            if inst.op == "load" {
                let rd = inst.result
                bytes = a_emit32_le(bytes, a_enc_movz(rd, inst.imm % 65536))
            }
            if inst.op == "band" {
                bytes = a_emit32_le(bytes, a_enc_and(inst.result, inst.a, inst.b))
            }
            if inst.op == "bor" {
                bytes = a_emit32_le(bytes, a_enc_orr(inst.result, inst.a, inst.b))
            }
            if inst.op == "bxor" {
                bytes = a_emit32_le(bytes, a_enc_eor(inst.result, inst.a, inst.b))
            }
            if inst.op == "shl" {
                bytes = a_emit32_le(bytes, a_enc_lslv(inst.result, inst.a, inst.b))
            }
            if inst.op == "shr" {
                bytes = a_emit32_le(bytes, a_enc_lsrv(inst.result, inst.a, inst.b))
            }
            ii = ii + 1
        }
        bi = bi + 1
    }
    return bytes
}

// ═══════════════════════════════════════════════════════════
//  Inlined x86 encoders (match self/codegen/ir_to_x86.hexa)
// ═══════════════════════════════════════════════════════════

fn x_rex_w(reg_ext: int, rm_ext: int) -> int {
    let mut b = 0x48
    if reg_ext != 0 { b = b + 4 }
    if rm_ext != 0 { b = b + 1 }
    return b
}
fn x_emit_and_rr(code: [int], dst: int, src: int) -> [int] {
    let rex = x_rex_w(if src >= 8 { 1 } else { 0 }, if dst >= 8 { 1 } else { 0 })
    return code.push(rex).push(0x21).push(0xc0 + (src % 8) * 8 + (dst % 8))
}
fn x_emit_or_rr(code: [int], dst: int, src: int) -> [int] {
    let rex = x_rex_w(if src >= 8 { 1 } else { 0 }, if dst >= 8 { 1 } else { 0 })
    return code.push(rex).push(0x09).push(0xc0 + (src % 8) * 8 + (dst % 8))
}
fn x_emit_xor_rr(code: [int], dst: int, src: int) -> [int] {
    let rex = x_rex_w(if src >= 8 { 1 } else { 0 }, if dst >= 8 { 1 } else { 0 })
    return code.push(rex).push(0x31).push(0xc0 + (src % 8) * 8 + (dst % 8))
}
fn x_emit_shl_cl(code: [int], dst: int) -> [int] {
    let rex = x_rex_w(0, if dst >= 8 { 1 } else { 0 })
    return code.push(rex).push(0xd3).push(0xe0 + (dst % 8))
}
fn x_emit_shr_cl(code: [int], dst: int) -> [int] {
    let rex = x_rex_w(0, if dst >= 8 { 1 } else { 0 })
    return code.push(rex).push(0xd3).push(0xe8 + (dst % 8))
}

// ── byte-array scanners ─────────────────────────────────────
fn contains_instr(bytes: [int], instr: int) -> bool {
    let b0 = instr % 256
    let b1 = (instr / 256) % 256
    let b2 = (instr / 65536) % 256
    let b3 = (instr / 16777216) % 256
    let mut i = 0
    while (i + 4) <= len(bytes) {
        if bytes[i] == b0 {
            if bytes[i + 1] == b1 {
                if bytes[i + 2] == b2 {
                    if bytes[i + 3] == b3 { return true }
                }
            }
        }
        i = i + 4
    }
    return false
}

fn contains_x86_triple(bytes: [int], b0: int, b1: int, b2: int) -> bool {
    let mut i = 0
    while (i + 3) <= len(bytes) {
        if bytes[i] == b0 {
            if bytes[i + 1] == b1 {
                if bytes[i + 2] == b2 { return true }
            }
        }
        i = i + 1
    }
    return false
}

// ═══════════════════════════════════════════════════════════
//  Tests
// ═══════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════")
println("  cov_bitwise — P7-6 coverage gap #2")
println("═══════════════════════════════════════════════════════")

// ── T1 ARM64: band x2, x0, x1 ─────────────────────────────
let mut bb = mk_bb(0)
bb = bb_push(bb, ir_load_imm(0, 12))    // x0 ← 12  (0b1100)
bb = bb_push(bb, ir_load_imm(1, 10))    // x1 ← 10  (0b1010)
bb = bb_push(bb, ir_binop("band", 2, 0, 1))
let bytes_band = a_lower([bb])
// Expected AND: 0x8a000000 + (1<<16) + (0<<5) + 2 = 2315255808 + 65536 + 2 = 2315321346
check_true("ARM64 band emits AND x2,x0,x1",
    contains_instr(bytes_band, 2315255808 + 65536 + 2))

// ── T2 ARM64: bor x2, x0, x1 ──────────────────────────────
let mut bb2 = mk_bb(0)
bb2 = bb_push(bb2, ir_load_imm(0, 12))
bb2 = bb_push(bb2, ir_load_imm(1, 10))
bb2 = bb_push(bb2, ir_binop("bor", 2, 0, 1))
let bytes_bor = a_lower([bb2])
check_true("ARM64 bor emits ORR x2,x0,x1",
    contains_instr(bytes_bor, 2852126720 + 65536 + 2))

// ── T3 ARM64: bxor x2, x0, x1 ─────────────────────────────
let mut bb3 = mk_bb(0)
bb3 = bb_push(bb3, ir_load_imm(0, 12))
bb3 = bb_push(bb3, ir_load_imm(1, 10))
bb3 = bb_push(bb3, ir_binop("bxor", 2, 0, 1))
let bytes_bxor = a_lower([bb3])
check_true("ARM64 bxor emits EOR x2,x0,x1",
    contains_instr(bytes_bxor, 3388997632 + 65536 + 2))

// ── T4 ARM64: shl x2, x0, x1 ──────────────────────────────
let mut bb4 = mk_bb(0)
bb4 = bb_push(bb4, ir_load_imm(0, 5))
bb4 = bb_push(bb4, ir_load_imm(1, 3))
bb4 = bb_push(bb4, ir_binop("shl", 2, 0, 1))
let bytes_shl = a_lower([bb4])
check_true("ARM64 shl emits LSLV x2,x0,x1",
    contains_instr(bytes_shl, 2596159488 + 65536 + 2))

// ── T5 ARM64: shr x2, x0, x1 ──────────────────────────────
let mut bb5 = mk_bb(0)
bb5 = bb_push(bb5, ir_load_imm(0, 40))
bb5 = bb_push(bb5, ir_load_imm(1, 3))
bb5 = bb_push(bb5, ir_binop("shr", 2, 0, 1))
let bytes_shr = a_lower([bb5])
check_true("ARM64 shr emits LSRV x2,x0,x1",
    contains_instr(bytes_shr, 2596160512 + 65536 + 2))

// ── T6 x86: AND rax, rcx  (0x48 21 c8) ────────────────────
let by1 = x_emit_and_rr([], 0, 1)
check_true("x86 AND rax,rcx bytes (48 21 c8)",
    contains_x86_triple(by1, 0x48, 0x21, 0xc8))

// ── T7 x86: OR rax, rcx   (0x48 09 c8) ────────────────────
let by2 = x_emit_or_rr([], 0, 1)
check_true("x86 OR rax,rcx bytes (48 09 c8)",
    contains_x86_triple(by2, 0x48, 0x09, 0xc8))

// ── T8 x86: XOR rax, rcx  (0x48 31 c8) ────────────────────
let by3 = x_emit_xor_rr([], 0, 1)
check_true("x86 XOR rax,rcx bytes (48 31 c8)",
    contains_x86_triple(by3, 0x48, 0x31, 0xc8))

// ── T9 x86: SHL rax, cl  (0x48 d3 e0) ─────────────────────
let by4 = x_emit_shl_cl([], 0)
check_true("x86 SHL rax,cl bytes (48 d3 e0)",
    contains_x86_triple(by4, 0x48, 0xd3, 0xe0))

// ── T10 x86: SHR rax, cl  (0x48 d3 e8) ────────────────────
let by5 = x_emit_shr_cl([], 0)
check_true("x86 SHR rax,cl bytes (48 d3 e8)",
    contains_x86_triple(by5, 0x48, 0xd3, 0xe8))

println("═══════════════════════════════════════════════════════")
if fail_count == 0 {
    println("ALL PASS — " + to_string(pass_count) + "/" + to_string(pass_count))
} else {
    println("FAIL — " + to_string(pass_count) + " pass / " + to_string(fail_count) + " fail")
    exit(1)
}
