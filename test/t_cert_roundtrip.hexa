// ═══════════════════════════════════════════════════════════
//  test/t_cert_roundtrip.hexa
//
//  Build a trivial IR opcode list {Add, Mul, Const-equivalent},
//  call issue_certificate + cert_hash for each, then
//  verify_certificate. Assert all verify OK.
//
//  Run:
//      ./hexa run test/t_cert_roundtrip.hexa
//
//  Exit semantics:
//      * all asserts pass → prints "PASS t_cert_roundtrip"
//      * any assert fails → prints FAIL line, exit 1
// ═══════════════════════════════════════════════════════════

use "self/proof/certificate"

fn _assert(tag, ok) {
    if ok {
        println("  PASS " + tag)
        return 0
    }
    println("  FAIL " + tag)
    return 1
}

fn main_cert_roundtrip() {
    println("[t_cert_roundtrip] trivial IR {Add, Mul, Neg} → issue→hash→verify")

    // Trivial IR opcode list. "Const" is not one of the 24 IR opcodes
    // in this project's opcode table; substitute "Neg" (unary op, idx 5,
    // same issue bucket) so the roundtrip exercises the 12-row mapping.
    let ops = ["Add", "Mul", "Neg"]
    let preds = ["bounded", "nonneg", "sign_flip"]

    let mut fail = 0
    let mut i = 0
    while i < len(ops) {
        let op   = ops[i]
        let pred = preds[i]
        let tgt  = "v_" + to_string(i)

        let c = issue_certificate(pred, tgt, op)

        // 1) ISSUED status
        if c["status"] != "ISSUED" { fail = fail + _assert(op + ":status=ISSUED", false) }
        else                       { fail = fail + _assert(op + ":status=ISSUED", true)  }

        // 2) hash is non-zero (cert_hash ran and wrote the hash slot)
        let h = c["hash"]
        fail = fail + _assert(op + ":hash-nonzero", h != 0)

        // 3) hash is deterministic: recompute from the canonical string form
        //    and compare to the stored hash.
        let probe = #{
            "predicate": c["predicate"],
            "target":    c["target"],
            "bucket":    c["bucket"],
            "status":    c["status"],
            "hash":      0
        }
        let h2 = cert_hash(probe)
        fail = fail + _assert(op + ":hash-deterministic", h == h2)

        // 4) verify_certificate returns VERIFY_OK
        let v = verify_certificate(c)
        fail = fail + _assert(op + ":verify-ok", v == "VERIFY_OK")

        i = i + 1
    }

    if fail == 0 {
        println("PASS t_cert_roundtrip")
        return 0
    }
    println("FAIL t_cert_roundtrip: " + to_string(fail) + " assertion(s)")
    exit(1)
    return 1
}

main_cert_roundtrip()
