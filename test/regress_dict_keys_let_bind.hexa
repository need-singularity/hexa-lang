// test/regress_dict_keys_let_bind.hexa — hxa-20260423-005 repro fixture.
//
// Two distinct interpreter map gaps observed while writing the
// roadmap-68 builtin_mangling snapshot (94b4aa66):
//
// REPRO 1 — `let ks = dict_keys(d)` binding loses content even when
//           inline `len(dict_keys(d))` returns the right count.
//
// REPRO 2 — empty map literal `{}` parses under the default AOT-cache
//           path but errors at the first token under HEXA_CACHE=0
//           (stage0 interpreter direct path):
//             "Parse error at 1:9: unexpected token LBrace ('{')"
//
// This file is the minimum reproducer kept in-tree so a future session
// can attach a fixed runtime and run `./hexa run test/regress_dict_keys_let_bind.hexa`
// to confirm the gap is closed. Currently expected to FAIL on `dict_bound`.

let mut d = {}
d["k1"] = 1
d["k2"] = 2

println("d_len=" + to_string(len(d)))                              // expect 2
println("dict_inline=" + to_string(len(dict_keys(d))))             // expect 2  (PASS today)

let ks = dict_keys(d)
println("dict_bound=" + to_string(len(ks)))                        // expect 2  (FAIL today: prints 0)

// Negative side-channel — bound array from a non-builtin source binds fine.
let mut copy = []
copy.push("a")
copy.push("b")
let bound_copy = copy
println("bound_copy=" + to_string(len(bound_copy)))                // expect 2  (PASS today)
