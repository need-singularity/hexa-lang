// tests/t_batch23_datetime_pure.hexa — Batch 23 runnable asserts.
//
// Exercises the five builtins from self/runtime/datetime_mini_pure.hexa:
//   is_leap_year_pure, days_in_month_pure, day_of_year_pure,
//   days_between_pure, weekday_zeller_pure
//
// Codegen cannot resolve imports for test files — inlined per the
// standard convention used by self/test_*_pure.hexa.
//
// Weekday convention (Zeller original):
//   0=Saturday, 1=Sunday, 2=Monday, 3=Tuesday,
//   4=Wednesday, 5=Thursday, 6=Friday

// ═══════════════════════════════════════════════════════════════════
//  ── INLINED: self/runtime/datetime_mini_pure.hexa ──
// ═══════════════════════════════════════════════════════════════════

@pure
fn _dt_mini_is_leap(year) {
    if (year % 4) != 0 { return 0 }
    if (year % 100) != 0 { return 1 }
    if (year % 400) != 0 { return 0 }
    return 1
}

@pure
fn _dt_mini_dim(year, month) {
    if month == 1  { return 31 }
    if month == 3  { return 31 }
    if month == 5  { return 31 }
    if month == 7  { return 31 }
    if month == 8  { return 31 }
    if month == 10 { return 31 }
    if month == 12 { return 31 }
    if month == 4  { return 30 }
    if month == 6  { return 30 }
    if month == 9  { return 30 }
    if month == 11 { return 30 }
    if month == 2 {
        if _dt_mini_is_leap(year) == 1 { return 29 }
        return 28
    }
    return 0
}

@pure
pub fn is_leap_year_pure(y) {
    return _dt_mini_is_leap(y)
}

@pure
pub fn days_in_month_pure(y, m) {
    return _dt_mini_dim(y, m)
}

@pure
pub fn day_of_year_pure(y, m, d) {
    let mut total = 0
    let mut mm = 1
    while mm < m {
        total = total + _dt_mini_dim(y, mm)
        mm = mm + 1
    }
    return total + d
}

@pure
fn _dt_mini_days_from_civil(y, m, d) {
    let mut yy = y
    if m <= 2 { yy = yy - 1 }
    let mut era = 0
    if yy >= 0 {
        era = yy / 400
    } else {
        era = (yy - 399) / 400
    }
    let yoe = yy - era * 400
    let mp = (m + 9) % 12
    let doy = (153 * mp + 2) / 5 + d - 1
    let doe = yoe * 365 + yoe / 4 - yoe / 100 + doy
    return era * 146097 + doe - 719468
}

@pure
pub fn days_between_pure(y1, m1, d1, y2, m2, d2) {
    let a = _dt_mini_days_from_civil(y1, m1, d1)
    let b = _dt_mini_days_from_civil(y2, m2, d2)
    return b - a
}

@pure
pub fn weekday_zeller_pure(y, m, d) {
    let mut yy = y
    let mut mm = m
    if mm < 3 {
        mm = mm + 12
        yy = yy - 1
    }
    let k = yy % 100
    let j = yy / 100
    let h = (d + (13 * (mm + 1)) / 5 + k + k / 4 + j / 4 + 5 * j) % 7
    return h
}

// ═══════════════════════════════════════════════════════════════════
//  ── Test harness ──
// ═══════════════════════════════════════════════════════════════════
let mut pass = 0
let mut fail = 0

fn eq_int(name, got, want) {
    if got == want {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(got) + " want " + to_string(want))
    }
}

println("=== t_batch23_datetime_pure test suite ===")

// ──────────────────────────────────────────────────────────────────
// 1. is_leap_year_pure — 1 if leap else 0
// ──────────────────────────────────────────────────────────────────
eq_int("leap 2000 (400-div century)",  is_leap_year_pure(2000), 1)
eq_int("leap 1900 (100-div, not 400)", is_leap_year_pure(1900), 0)
eq_int("leap 2024 (std 4-div)",        is_leap_year_pure(2024), 1)
eq_int("leap 2023 (not 4-div)",        is_leap_year_pure(2023), 0)
eq_int("leap 2026 (not 4-div)",        is_leap_year_pure(2026), 0)
eq_int("leap 1600 (400-div)",          is_leap_year_pure(1600), 1)
eq_int("leap 2100 (100, not 400)",     is_leap_year_pure(2100), 0)
eq_int("leap 4 (small 4-div)",         is_leap_year_pure(4),    1)
eq_int("leap 1 (not leap)",            is_leap_year_pure(1),    0)

// ──────────────────────────────────────────────────────────────────
// 2. days_in_month_pure — 28/29/30/31
// ──────────────────────────────────────────────────────────────────
eq_int("dim Jan",          days_in_month_pure(2026, 1),  31)
eq_int("dim Feb non-leap", days_in_month_pure(2026, 2),  28)
eq_int("dim Feb 2024 leap",days_in_month_pure(2024, 2),  29)
eq_int("dim Feb 2000 leap",days_in_month_pure(2000, 2),  29)
eq_int("dim Feb 1900 !lp", days_in_month_pure(1900, 2),  28)
eq_int("dim Mar",          days_in_month_pure(2026, 3),  31)
eq_int("dim Apr",          days_in_month_pure(2026, 4),  30)
eq_int("dim May",          days_in_month_pure(2026, 5),  31)
eq_int("dim Jun",          days_in_month_pure(2026, 6),  30)
eq_int("dim Jul",          days_in_month_pure(2026, 7),  31)
eq_int("dim Aug",          days_in_month_pure(2026, 8),  31)
eq_int("dim Sep",          days_in_month_pure(2026, 9),  30)
eq_int("dim Oct",          days_in_month_pure(2026, 10), 31)
eq_int("dim Nov",          days_in_month_pure(2026, 11), 30)
eq_int("dim Dec",          days_in_month_pure(2026, 12), 31)

// ──────────────────────────────────────────────────────────────────
// 3. day_of_year_pure — 1..366
// ──────────────────────────────────────────────────────────────────
eq_int("doy Jan 1",            day_of_year_pure(2026, 1, 1),   1)
eq_int("doy Jan 31",           day_of_year_pure(2026, 1, 31),  31)
eq_int("doy Feb 1",            day_of_year_pure(2026, 2, 1),   32)
eq_int("doy Feb 28 non-leap",  day_of_year_pure(2026, 2, 28),  59)
eq_int("doy Mar 1 non-leap",   day_of_year_pure(2026, 3, 1),   60)
eq_int("doy Apr 17 (target)",  day_of_year_pure(2026, 4, 17),  107)  // 31+28+31+17
eq_int("doy Dec 31 non-leap",  day_of_year_pure(2026, 12, 31), 365)
// Leap-year checks
eq_int("doy Feb 29 leap",      day_of_year_pure(2024, 2, 29),  60)
eq_int("doy Mar 1 leap",       day_of_year_pure(2024, 3, 1),   61)
eq_int("doy Dec 31 leap",      day_of_year_pure(2024, 12, 31), 366)

// ──────────────────────────────────────────────────────────────────
// 4. days_between_pure — signed day count
// ──────────────────────────────────────────────────────────────────
// Golden case from spec
eq_int("days 2026-01-01 → 2026-04-17",
       days_between_pure(2026,1,1, 2026,4,17), 106)

// Identity
eq_int("days same day",
       days_between_pure(2026,4,17, 2026,4,17), 0)

// Anti-symmetry (reverse direction → negative)
eq_int("days reverse -106",
       days_between_pure(2026,4,17, 2026,1,1), -106)

// One full non-leap year
eq_int("days one year 2026",
       days_between_pure(2026,1,1, 2027,1,1), 365)

// One full leap year (2024)
eq_int("days 2024 leap year",
       days_between_pure(2024,1,1, 2025,1,1), 366)

// Across 400-year cycle: 1900→2000 = 36524 days (24 leaps, since 1900 itself not leap)
eq_int("days 1900-01-01 → 2000-01-01",
       days_between_pure(1900,1,1, 2000,1,1), 36524)

// Unix epoch sanity: 1970-01-01 → 2000-01-01 = 10957 days
eq_int("days 1970-01-01 → 2000-01-01",
       days_between_pure(1970,1,1, 2000,1,1), 10957)

// Single-day increment
eq_int("days Feb 28 → Mar 1 leap (2 days)",
       days_between_pure(2024,2,28, 2024,3,1), 2)   // Feb 28→29→Mar 1
eq_int("days Feb 28 → Mar 1 non-leap (1 day)",
       days_between_pure(2023,2,28, 2023,3,1), 1)

// ──────────────────────────────────────────────────────────────────
// 5. weekday_zeller_pure — Zeller 0=Sat..6=Fri
// ──────────────────────────────────────────────────────────────────
// Golden case from spec: 2026-04-17 is a Friday → 6
eq_int("weekday 2026-04-17 = Fri",  weekday_zeller_pure(2026, 4, 17), 6)

// Other known dates (Zeller 0=Sat):
// 2000-01-01 = Saturday → 0
eq_int("weekday 2000-01-01 = Sat",  weekday_zeller_pure(2000, 1, 1),  0)
// 1970-01-01 = Thursday → 5
eq_int("weekday 1970-01-01 = Thu",  weekday_zeller_pure(1970, 1, 1),  5)
// 2024-02-29 = Thursday → 5
eq_int("weekday 2024-02-29 = Thu",  weekday_zeller_pure(2024, 2, 29), 5)
// 2026-01-01 = Thursday → 5
eq_int("weekday 2026-01-01 = Thu",  weekday_zeller_pure(2026, 1, 1),  5)
// 1900-01-01 = Monday → 2
eq_int("weekday 1900-01-01 = Mon",  weekday_zeller_pure(1900, 1, 1),  2)
// 2025-12-25 = Thursday → 5
eq_int("weekday 2025-12-25 = Thu",  weekday_zeller_pure(2025, 12, 25), 5)
// 2026-12-31 = Thursday → 5
eq_int("weekday 2026-12-31 = Thu",  weekday_zeller_pure(2026, 12, 31), 5)

// ──────────────────────────────────────────────────────────────────
println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 {
    println("PASS " + to_string(pass) + "/" + to_string(pass))
} else {
    println("FAIL " + to_string(fail) + "/" + to_string(pass + fail))
}
