// tests/runtime/arrays_test.hexa — P7-7b chunk 2 validation
//
// 검증 대상: self/runtime/arrays.hexa 의 10 함수 — C runtime.c 의
// hexa_array_* 헬퍼와 byte-for-byte 동일성 검증. 각 @test fn 은 empty /
// single / multi / 경계 경로를 커버한다.
//
// 실행
//   build/hexa_stage0 test tests/runtime/arrays_test.hexa
//
// 왜 본 파일에 함수가 그대로 들어가 있나?
//   self/test_runner.hexa 의 _write_driver 는 테스트 소스를 그대로 이어붙여
//   `<fn_name>()` 를 호출한다. import 해석은 러너가 관여하지 않으므로
//   (strings_test.hexa 의 관행과 동일하게) 테스트 파일이 함수 정의를
//   직접 포함해야 한다.
//
// OOB / non-array 오류 경로 (panic 경로) 는 테스트에서 제외 — 러너가
// panic 시 전체 배치를 중단하기 때문. 그쪽은 별도 negative harness 로.


// ═══════ UNDER TEST — self/runtime/arrays.hexa 사본 ═══════

pub fn array_new() {
    []
}

pub fn array_len(arr) {
    if type_of(arr) != "array" { return 0 }
    len(arr)
}

pub fn array_get(arr, idx) {
    if type_of(arr) != "array" {
        panic("array[]: container is not an array")
    }
    let n = len(arr)
    let mut i = idx
    if i < 0 { i = i + n }
    if i < 0 || i >= n {
        panic("array_get: index out of bounds")
    }
    arr[i]
}

pub fn array_set(arr, idx, val) {
    if type_of(arr) != "array" {
        panic("array_set[]: container is not an array")
    }
    let n = len(arr)
    let mut i = idx
    if i < 0 { i = i + n }
    if i < 0 || i >= n {
        panic("array_set: index out of bounds")
    }
    arr[i] = val
    arr
}

pub fn array_push(arr, item) {
    if type_of(arr) != "array" { return arr }
    arr.push(item)
}

pub fn array_pop(arr) {
    if type_of(arr) != "array" { return void }
    let n = len(arr)
    if n == 0 { return void }
    arr[n - 1]
}

pub fn array_slice(arr, start, end) {
    if type_of(arr) != "array" { return [] }
    let n = len(arr)
    let mut a = start
    let mut b = end
    if a < 0 { a = 0 }
    if b > n { b = n }
    if a > b { a = b }
    let mut out = []
    let mut i = a
    while i < b {
        out.push(arr[i])
        i = i + 1
    }
    out
}

pub fn array_reverse(arr) {
    if type_of(arr) != "array" { return arr }
    let n = len(arr)
    let mut out = []
    let mut i = n - 1
    while i >= 0 {
        out.push(arr[i])
        i = i - 1
    }
    out
}

pub fn array_index_of(arr, item) {
    if type_of(arr) != "array" { return -1 }
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == item { return i }
        i = i + 1
    }
    -1
}

pub fn array_concat(a, b) {
    let aa = if type_of(a) == "array" { a } else { [] }
    let bb = if type_of(b) == "array" { b } else { [] }
    let na = len(aa)
    let nb = len(bb)
    if na == 0 { return bb }
    if nb == 0 { return aa }
    let mut out = []
    let mut i = 0
    while i < na {
        out.push(aa[i])
        i = i + 1
    }
    let mut j = 0
    while j < nb {
        out.push(bb[j])
        j = j + 1
    }
    out
}


// ═══════ TESTS ═══════

@test
fn test_array_new() {
    // empty 배열 하나 새로 만든다
    let a = array_new()
    assert(type_of(a) == "array")
    assert(len(a) == 0)
    // 독립성: 두 번 호출이 같은 인스턴스를 공유하지 않는다
    let b = array_new()
    let b2 = b.push(1)
    assert(len(array_new()) == 0)
}

@test
fn test_array_len() {
    // empty
    assert(array_len([]) == 0)
    // single
    assert(array_len([42]) == 1)
    // multi
    assert(array_len([1, 2, 3, 4, 5]) == 5)
    // non-array → 0 (C 동일)
    assert(array_len("hello") == 0)
    assert(array_len(42) == 0)
}

@test
fn test_array_get() {
    // single
    assert(array_get([7], 0) == 7)
    // multi
    assert(array_get([10, 20, 30], 0) == 10)
    assert(array_get([10, 20, 30], 1) == 20)
    assert(array_get([10, 20, 30], 2) == 30)
    // 음수 인덱스 — C 는 idx += len
    assert(array_get([10, 20, 30], -1) == 30)
    assert(array_get([10, 20, 30], -2) == 20)
    assert(array_get([10, 20, 30], -3) == 10)
    // heterogeneous
    assert(array_get(["a", "b", "c"], 1) == "b")
}

@test
fn test_array_set() {
    // single
    let mut a = [0]
    a = array_set(a, 0, 99)
    assert(a[0] == 99)
    // multi
    let mut b = [1, 2, 3]
    b = array_set(b, 1, 20)
    assert(b[0] == 1)
    assert(b[1] == 20)
    assert(b[2] == 3)
    // 음수 인덱스
    let mut c = [1, 2, 3]
    c = array_set(c, -1, 99)
    assert(c[2] == 99)
    // 문자열 원소
    let mut d = ["x", "y"]
    d = array_set(d, 0, "Z")
    assert(d[0] == "Z")
}

@test
fn test_array_push() {
    // empty → single
    let mut a = []
    a = array_push(a, 1)
    assert(len(a) == 1)
    assert(a[0] == 1)
    // single → multi
    a = array_push(a, 2)
    a = array_push(a, 3)
    assert(len(a) == 3)
    assert(a[0] == 1)
    assert(a[2] == 3)
    // non-array → 변경 없음
    let b = array_push(42, 1)
    assert(b == 42)
    // 문자열 원소
    let mut s = []
    s = array_push(s, "hello")
    assert(s[0] == "hello")
}

@test
fn test_array_pop() {
    // empty → void
    assert(type_of(array_pop([])) == "void")
    // non-array → void
    assert(type_of(array_pop(42)) == "void")
    assert(type_of(array_pop("abc")) == "void")
    // single
    assert(array_pop([7]) == 7)
    // multi — 마지막 원소
    assert(array_pop([1, 2, 3]) == 3)
    assert(array_pop(["a", "b", "c"]) == "c")
    // C hexa_array_pop semantics: arr 은 변경되지 않음 (len unchanged)
    let orig = [1, 2, 3]
    let p = array_pop(orig)
    assert(p == 3)
    assert(len(orig) == 3)
}

@test
fn test_array_slice() {
    // empty
    assert(len(array_slice([], 0, 0)) == 0)
    assert(len(array_slice([], 0, 5)) == 0)
    // single
    let s1 = array_slice([7], 0, 1)
    assert(len(s1) == 1)
    assert(s1[0] == 7)
    // multi + 중간
    let s2 = array_slice([1, 2, 3, 4, 5], 1, 4)
    assert(len(s2) == 3)
    assert(s2[0] == 2)
    assert(s2[2] == 4)
    // 전체
    let s3 = array_slice([1, 2, 3], 0, 3)
    assert(len(s3) == 3)
    // a == b → empty
    let s4 = array_slice([1, 2, 3], 2, 2)
    assert(len(s4) == 0)
    // clamp: a < 0 → 0, b > n → n
    let s5 = array_slice([1, 2, 3], -5, 100)
    assert(len(s5) == 3)
    assert(s5[0] == 1)
    // a > b → a = b (빈 슬라이스)
    let s6 = array_slice([1, 2, 3], 2, 1)
    assert(len(s6) == 0)
    // non-array → []
    assert(len(array_slice(42, 0, 3)) == 0)
}

@test
fn test_array_reverse() {
    // empty
    assert(len(array_reverse([])) == 0)
    // single
    let r1 = array_reverse([7])
    assert(len(r1) == 1)
    assert(r1[0] == 7)
    // multi
    let r2 = array_reverse([1, 2, 3])
    assert(r2[0] == 3)
    assert(r2[1] == 2)
    assert(r2[2] == 1)
    // 짝수 길이
    let r3 = array_reverse([1, 2, 3, 4])
    assert(r3[0] == 4)
    assert(r3[3] == 1)
    // 문자열 원소
    let r4 = array_reverse(["a", "b", "c"])
    assert(r4[0] == "c")
    // non-array → 인자 그대로 (C 동일)
    assert(array_reverse(42) == 42)
}

@test
fn test_array_index_of() {
    // empty → -1
    assert(array_index_of([], 1) == -1)
    // 존재 안 함
    assert(array_index_of([1, 2, 3], 99) == -1)
    // 첫 원소
    assert(array_index_of([10, 20, 30], 10) == 0)
    // 중간
    assert(array_index_of([10, 20, 30], 20) == 1)
    // 끝
    assert(array_index_of([10, 20, 30], 30) == 2)
    // 중복 시 첫 발견 인덱스
    assert(array_index_of([1, 2, 1, 2], 2) == 1)
    // 문자열
    assert(array_index_of(["x", "y", "z"], "y") == 1)
    // non-array → -1
    assert(array_index_of(42, 1) == -1)
}

@test
fn test_array_concat() {
    // empty + empty
    assert(len(array_concat([], [])) == 0)
    // empty + single
    let c1 = array_concat([], [1])
    assert(len(c1) == 1)
    assert(c1[0] == 1)
    // single + empty
    let c2 = array_concat([1], [])
    assert(len(c2) == 1)
    // multi + multi
    let c3 = array_concat([1, 2], [3, 4])
    assert(len(c3) == 4)
    assert(c3[0] == 1)
    assert(c3[2] == 3)
    assert(c3[3] == 4)
    // 순서 보존
    let c4 = array_concat([1, 2, 3], [4, 5])
    assert(c4[0] == 1)
    assert(c4[4] == 5)
    // 문자열 원소
    let c5 = array_concat(["a"], ["b", "c"])
    assert(len(c5) == 3)
    assert(c5[2] == "c")
    // non-array → [] 로 치환
    let c6 = array_concat(42, [1])
    assert(len(c6) == 1)
    let c7 = array_concat([1], "str")
    assert(len(c7) == 1)
}
