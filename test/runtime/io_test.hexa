// tests/runtime/io_test.hexa — P7-7b chunk 4 validation
//
// 검증 대상: self/runtime/io.hexa 의 10 함수 —
//   file_read / file_write / io_file_exists / file_size
//   file_delete / file_append
//   dir_create / dir_exists
//   path_join / path_dirname / path_basename
//
// 실행
//   ./hexa run self/test_runner.hexa tests/runtime/io_test.hexa
//
// 왜 함수 본문이 파일에 들어가 있나?
//   self/test_runner.hexa 의 driver 합성은 테스트 소스를 그대로 이어붙여
//   `<fn_name>()` 를 호출한다. import 해석은 러너가 관여하지 않으므로
//   테스트 파일이 함수 정의를 직접 포함해야 한다.
//
// IO scope
//   /tmp/hexa_io_test_* 만 생성/삭제. 각 @test 내에서 셋업→검증→teardown.
//   독립 프로세스이므로 테스트 간 race 는 없다.


// ═══════ UNDER TEST — self/runtime/io.hexa 사본 ═══════

pub fn file_read(path) {
    if type_of(path) != "string" { return "" }
    read_file(path)
}

pub fn file_write(path, content) {
    if type_of(path) != "string" { return false }
    if type_of(content) != "string" { return false }
    write_file(path, content)
    true
}

pub fn io_file_exists(path) {
    if type_of(path) != "string" { return false }
    if len(path) == 0 { return false }
    let r = exec("test -e '" + path + "' && printf 1 || printf 0")
    r == "1"
}

pub fn file_size(path) {
    if type_of(path) != "string" { return 0 }
    if io_file_exists(path) == false { return 0 }
    let content = read_file(path)
    len(content)
}

pub fn file_delete(path) {
    if type_of(path) != "string" { return false }
    delete_file(path)
    true
}

pub fn file_append(path, content) {
    if type_of(path) != "string" { return false }
    if type_of(content) != "string" { return false }
    append_file(path, content)
    true
}

pub fn dir_create(path) {
    if type_of(path) != "string" { return false }
    if len(path) == 0 { return false }
    exec("mkdir -p '" + path + "'")
    true
}

pub fn dir_exists(path) {
    if type_of(path) != "string" { return false }
    if len(path) == 0 { return false }
    let r = exec("test -d '" + path + "' && printf 1 || printf 0")
    r == "1"
}

fn _io_last_slash(s) {
    let n = len(s)
    let mut i = n - 1
    while i >= 0 {
        if s.substring(i, i + 1) == "/" { return i }
        i = i - 1
    }
    -1
}

pub fn path_join(a, b) {
    if type_of(a) != "string" { return b }
    if type_of(b) != "string" { return a }
    if len(a) == 0 { return b }
    if len(b) == 0 { return a }
    let mut alen = len(a)
    while alen > 0 && a.substring(alen - 1, alen) == "/" {
        alen = alen - 1
    }
    let mut bstart = 0
    while bstart < len(b) && b.substring(bstart, bstart + 1) == "/" {
        bstart = bstart + 1
    }
    if alen == 0 {
        return "/" + b.substring(bstart, len(b))
    }
    let mut parts = []
    parts.push(a.substring(0, alen))
    parts.push("/")
    parts.push(b.substring(bstart, len(b)))
    parts.join("")
}

pub fn path_dirname(path) {
    if type_of(path) != "string" { return "" }
    if len(path) == 0 { return "" }
    let idx = _io_last_slash(path)
    if idx < 0 { return "" }
    if idx == 0 { return "/" }
    path.substring(0, idx)
}

pub fn path_basename(path) {
    if type_of(path) != "string" { return "" }
    let mut n = len(path)
    while n > 0 && path.substring(n - 1, n) == "/" {
        n = n - 1
    }
    let trimmed = path.substring(0, n)
    let idx = _io_last_slash(trimmed)
    if idx < 0 { return trimmed }
    trimmed.substring(idx + 1, len(trimmed))
}


// ═══════ TESTS ═══════

@test
fn test_file_write_and_read() {
    let p = "/tmp/hexa_io_test_write_read.txt"
    // cleanup any leftover
    file_delete(p)
    // write → read round-trip
    assert(file_write(p, "hello\n") == true)
    assert(file_read(p) == "hello\n")
    // overwrite
    assert(file_write(p, "world") == true)
    assert(file_read(p) == "world")
    file_delete(p)
    // non-string guard
    assert(file_write(42, "x") == false)
    assert(file_read(7) == "")
}

@test
fn test_io_file_exists() {
    let p = "/tmp/hexa_io_test_exists.txt"
    file_delete(p)
    // non-existent
    assert(io_file_exists(p) == false)
    // create → exists
    file_write(p, "x")
    assert(io_file_exists(p) == true)
    // delete → gone
    file_delete(p)
    assert(io_file_exists(p) == false)
    // guards
    assert(io_file_exists("") == false)
    assert(io_file_exists(123) == false)
}

@test
fn test_file_size() {
    let p = "/tmp/hexa_io_test_size.txt"
    file_delete(p)
    // missing → 0
    assert(file_size(p) == 0)
    // empty file → 0
    file_write(p, "")
    assert(file_size(p) == 0)
    // small
    file_write(p, "abc")
    assert(file_size(p) == 3)
    // larger
    file_write(p, "0123456789")
    assert(file_size(p) == 10)
    file_delete(p)
    // guards
    assert(file_size(0) == 0)
}

@test
fn test_file_delete() {
    let p = "/tmp/hexa_io_test_delete.txt"
    file_write(p, "bye")
    assert(io_file_exists(p) == true)
    assert(file_delete(p) == true)
    assert(io_file_exists(p) == false)
    // deleting missing is silent
    assert(file_delete(p) == true)
    // guard
    assert(file_delete(99) == false)
}

@test
fn test_file_append() {
    let p = "/tmp/hexa_io_test_append.txt"
    file_delete(p)
    // append to non-existent → creates
    assert(file_append(p, "aa") == true)
    assert(file_read(p) == "aa")
    // append extends
    assert(file_append(p, "bb") == true)
    assert(file_read(p) == "aabb")
    assert(file_append(p, "cc") == true)
    assert(file_read(p) == "aabbcc")
    file_delete(p)
    // guards
    assert(file_append(1, "x") == false)
    assert(file_append("/tmp/x", 2) == false)
}

@test
fn test_dir_create_and_exists() {
    let d = "/tmp/hexa_io_test_dir/sub/deep"
    let root = "/tmp/hexa_io_test_dir"
    exec("rm -rf '" + root + "'")
    assert(dir_exists(d) == false)
    assert(dir_create(d) == true)
    assert(dir_exists(d) == true)
    // idempotent
    assert(dir_create(d) == true)
    assert(dir_exists(d) == true)
    // file ≠ directory
    let f = "/tmp/hexa_io_test_dir/f.txt"
    file_write(f, "x")
    assert(dir_exists(f) == false)
    // cleanup
    exec("rm -rf '" + root + "'")
    assert(dir_exists(d) == false)
    // guards
    assert(dir_create("") == false)
    assert(dir_exists("") == false)
    assert(dir_exists(7) == false)
}

@test
fn test_path_join() {
    // basic
    assert(path_join("a", "b") == "a/b")
    // trailing slash on a
    assert(path_join("a/", "b") == "a/b")
    assert(path_join("a//", "b") == "a/b")
    // leading slash on b
    assert(path_join("a", "/b") == "a/b")
    assert(path_join("a", "//b") == "a/b")
    // both
    assert(path_join("a/", "/b") == "a/b")
    // empty sides
    assert(path_join("", "b") == "b")
    assert(path_join("a", "") == "a")
    assert(path_join("", "") == "")
    // absolute preservation
    assert(path_join("/", "b") == "/b")
    assert(path_join("/a", "b") == "/a/b")
    // multi-segment
    assert(path_join("/tmp", "x.txt") == "/tmp/x.txt")
    assert(path_join("foo/bar", "baz") == "foo/bar/baz")
}

@test
fn test_path_dirname() {
    // absolute
    assert(path_dirname("/a/b/c") == "/a/b")
    assert(path_dirname("/a") == "/")
    // root parent
    assert(path_dirname("/") == "/")
    // no slash
    assert(path_dirname("foo") == "")
    assert(path_dirname("") == "")
    // relative multi
    assert(path_dirname("a/b/c") == "a/b")
    assert(path_dirname("a/b") == "a")
    // trailing slash — kept as-is (C posix dirname would say "/a", but we
    // follow "last slash split" convention — see basename for trim path)
    assert(path_dirname("/a/b/c.txt") == "/a/b")
}

@test
fn test_path_basename() {
    // absolute
    assert(path_basename("/a/b/c") == "c")
    // trailing slash is stripped
    assert(path_basename("/a/b/c/") == "c")
    assert(path_basename("/a/b/c///") == "c")
    // no slash
    assert(path_basename("foo.hexa") == "foo.hexa")
    // root
    assert(path_basename("/") == "")
    assert(path_basename("///") == "")
    // empty
    assert(path_basename("") == "")
    // typical
    assert(path_basename("/tmp/hexa_io_test_x.txt") == "hexa_io_test_x.txt")
}

@test
fn test_round_trip_composed() {
    // Compose path_join + file_write + file_read + path_dirname + path_basename
    let dir = "/tmp/hexa_io_test_rt"
    exec("rm -rf '" + dir + "'")
    dir_create(dir)
    let p = path_join(dir, "data.txt")
    assert(p == "/tmp/hexa_io_test_rt/data.txt")
    assert(path_dirname(p) == dir)
    assert(path_basename(p) == "data.txt")
    file_write(p, "roundtrip")
    assert(file_size(p) == 9)
    assert(file_read(p) == "roundtrip")
    assert(io_file_exists(p) == true)
    file_delete(p)
    assert(io_file_exists(p) == false)
    exec("rm -rf '" + dir + "'")
    assert(dir_exists(dir) == false)
}
