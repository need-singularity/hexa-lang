// tests/runtime/strings_test.hexa — P7-7b chunk 1 validation
//
// 검증 대상: self/runtime/strings.hexa 의 8 함수 — C runtime.c 의 hexa_str_*
// 와 byte-for-byte 동일성. 각 @test fn 은 empty / single / multi / UTF-8
// 경로를 커버한다.
//
// 실행
//   hexa test tests/runtime/strings_test.hexa
//
// 왜 본 파일에 함수가 그대로 들어가 있나?
//   self/test_runner.hexa 의 _write_driver 는 테스트 소스를 그대로 이어붙여
//   `<fn_name>()` 를 호출한다. import 해석은 러너가 관여하지 않으므로
//   (self/test_string_pure.hexa 의 `-- inlined from ... --` 관행과 같이)
//   테스트 파일이 함수 정의를 직접 포함해야 한다.


// ═══════ UNDER TEST — self/runtime/strings.hexa 사본 ═══════

pub fn str_concat(a, b) {
    let sa = if type_of(a) == "string" { a } else { "" }
    let sb = if type_of(b) == "string" { b } else { "" }
    if len(sa) == 0 { return sb }
    if len(sb) == 0 { return sa }
    sa + sb
}

pub fn str_substring(s, a, b) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    let mut lo = a
    let mut hi = b
    if lo < 0 { lo = 0 }
    if hi > n { hi = n }
    if lo >= hi { return "" }
    s.substring(lo, hi)
}

pub fn str_index_of(s, sub) {
    if type_of(s) != "string" { return -1 }
    if type_of(sub) != "string" { return -1 }
    let sn = len(s)
    let mn = len(sub)
    if mn == 0 { return 0 }
    if mn > sn { return -1 }
    let limit = sn - mn + 1
    let mut i = 0
    while i < limit {
        if s.substring(i, i + mn) == sub {
            return i
        }
        i = i + 1
    }
    -1
}

pub fn str_starts_with(s, prefix) {
    if type_of(s) != "string" { return false }
    if type_of(prefix) != "string" { return false }
    let sn = len(s)
    let pn = len(prefix)
    if pn > sn { return false }
    if pn == 0 { return true }
    s.substring(0, pn) == prefix
}

pub fn str_ends_with(s, suffix) {
    if type_of(s) != "string" { return false }
    if type_of(suffix) != "string" { return false }
    let sn = len(s)
    let sfn = len(suffix)
    if sfn > sn { return false }
    if sfn == 0 { return true }
    s.substring(sn - sfn, sn) == suffix
}

pub fn str_to_upper(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    let mut parts = []
    let lowers = "abcdefghijklmnopqrstuvwxyz"
    let uppers = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        let mut j = 0
        let mut found = false
        while j < 26 && found == false {
            if lowers.substring(j, j + 1) == ch {
                parts = parts.push(uppers.substring(j, j + 1))
                found = true
            }
            j = j + 1
        }
        if found == false { parts = parts.push(ch) }
        i = i + 1
    }
    parts.join("")
}

pub fn str_to_lower(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    let mut parts = []
    let lowers = "abcdefghijklmnopqrstuvwxyz"
    let uppers = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        let mut j = 0
        let mut found = false
        while j < 26 && found == false {
            if uppers.substring(j, j + 1) == ch {
                parts = parts.push(lowers.substring(j, j + 1))
                found = true
            }
            j = j + 1
        }
        if found == false { parts = parts.push(ch) }
        i = i + 1
    }
    parts.join("")
}

pub fn str_trim(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    if n == 0 { return s }
    let mut lo = 0
    let mut done_lo = false
    while lo < n && done_lo == false {
        let ch = s.substring(lo, lo + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            lo = lo + 1
        } else {
            done_lo = true
        }
    }
    if done_lo == false { return "" }
    let mut hi = n - 1
    let mut done_hi = false
    while hi >= lo && done_hi == false {
        let ch = s.substring(hi, hi + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            hi = hi - 1
        } else {
            done_hi = true
        }
    }
    if hi < lo { return "" }
    s.substring(lo, hi + 1)
}


// ═══════ TESTS ═══════

@test
fn test_str_concat() {
    // empty
    assert(str_concat("", "") == "")
    assert(str_concat("", "a") == "a")
    assert(str_concat("a", "") == "a")
    // single
    assert(str_concat("a", "b") == "ab")
    // multi
    assert(str_concat("hello, ", "world") == "hello, world")
    // UTF-8 byte-level: café + "!" — byte 연결만 검증
    // (stage0 는 \x escape 미지원 — literal UTF-8 을 소스에 박음)
    assert(str_concat("café", "!") == "café!")
}

@test
fn test_str_substring() {
    // empty
    assert(str_substring("", 0, 0) == "")
    assert(str_substring("", 0, 5) == "")
    // single
    assert(str_substring("x", 0, 1) == "x")
    // multi + 경계
    assert(str_substring("hello", 0, 5) == "hello")
    assert(str_substring("hello", 1, 4) == "ell")
    assert(str_substring("hello", 3, 3) == "")
    // 음수 a → 0 으로 clamp, b > len → len 으로 clamp
    assert(str_substring("abc", -5, 100) == "abc")
    assert(str_substring("abc", 10, 20) == "")
    // UTF-8 byte 인덱스: "café" = c(1) a(1) f(1) é(2byte) → 총 5 byte
    // [0, 3) = "caf"
    assert(str_substring("café", 0, 3) == "caf")
}

@test
fn test_str_index_of() {
    // empty — C strstr(s, "") == s → 결과 0
    assert(str_index_of("abc", "") == 0)
    assert(str_index_of("", "") == 0)
    // 존재 안 함
    assert(str_index_of("abc", "x") == -1)
    assert(str_index_of("", "x") == -1)
    // 단일 글자
    assert(str_index_of("abc", "a") == 0)
    assert(str_index_of("abc", "c") == 2)
    // 여러 글자 / 첫 발견
    assert(str_index_of("banana", "na") == 2)
    assert(str_index_of("banana", "ana") == 1)
    // UTF-8: "café" 에서 "é" (0xc3 0xa9) 는 byte 3 에서 시작
    assert(str_index_of("café", "é") == 3)
}

@test
fn test_str_starts_with() {
    // empty prefix 는 C strncmp(p, "", 0) == 0 → true
    assert(str_starts_with("", "") == true)
    assert(str_starts_with("abc", "") == true)
    // single + multi
    assert(str_starts_with("abc", "a") == true)
    assert(str_starts_with("abc", "ab") == true)
    assert(str_starts_with("abc", "abc") == true)
    // 실패
    assert(str_starts_with("abc", "b") == false)
    assert(str_starts_with("abc", "abcd") == false)
    assert(str_starts_with("", "a") == false)
    // UTF-8 — "é" 로 시작하는 문자열
    assert(str_starts_with("éxx", "é") == true)
}

@test
fn test_str_ends_with() {
    // empty suffix → true (C strcmp("", "") == 0)
    assert(str_ends_with("", "") == true)
    assert(str_ends_with("abc", "") == true)
    // single + multi
    assert(str_ends_with("abc", "c") == true)
    assert(str_ends_with("abc", "bc") == true)
    assert(str_ends_with("abc", "abc") == true)
    // 실패
    assert(str_ends_with("abc", "a") == false)
    assert(str_ends_with("abc", "abcd") == false)
    assert(str_ends_with("", "a") == false)
    // UTF-8 — "é" 로 끝나는 문자열
    assert(str_ends_with("xxé", "é") == true)
}

@test
fn test_str_to_upper() {
    // empty + single
    assert(str_to_upper("") == "")
    assert(str_to_upper("a") == "A")
    assert(str_to_upper("A") == "A")
    // multi + 혼합
    assert(str_to_upper("hello") == "HELLO")
    assert(str_to_upper("Hello, World!") == "HELLO, WORLD!")
    // 숫자/기호 보존
    assert(str_to_upper("abc 123 !@#") == "ABC 123 !@#")
    // UTF-8 byte 보존 — "café" 의 0xc3 0xa9 는 lowers[a..z] 범위 밖 → 그대로
    assert(str_to_upper("café") == "CAFé")
}

@test
fn test_str_to_lower() {
    // empty + single
    assert(str_to_lower("") == "")
    assert(str_to_lower("A") == "a")
    assert(str_to_lower("a") == "a")
    // multi + 혼합
    assert(str_to_lower("HELLO") == "hello")
    assert(str_to_lower("Hello, World!") == "hello, world!")
    // 숫자/기호 보존
    assert(str_to_lower("ABC 123 !@#") == "abc 123 !@#")
    // UTF-8 보존
    assert(str_to_lower("CAFé") == "café")
}

@test
fn test_str_trim() {
    // empty
    assert(str_trim("") == "")
    // 전부 공백 → ""
    assert(str_trim("   ") == "")
    assert(str_trim("\t\n\r ") == "")
    // single
    assert(str_trim("x") == "x")
    assert(str_trim(" x ") == "x")
    // multi
    assert(str_trim("  hello  ") == "hello")
    assert(str_trim("\thello\n") == "hello")
    // 안쪽 공백 보존
    assert(str_trim("  a b c  ") == "a b c")
    // UTF-8: UTF-8 continuation byte 는 공백이 아니므로 보존
    assert(str_trim("  café  ") == "café")
}
