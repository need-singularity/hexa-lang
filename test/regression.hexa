// ============================================================
// tests/regression.hexa
// 2026-04-13 stage1 (./hexa) 버그 T23~T43 회귀 방지 스위트
// 14 cases — 각 케이스별 fixture 작성 -> 실행 -> 출력 비교
// 실행: $HEXA_LANG/hexa run tests/regression.hexa
// ============================================================

use "self/core/law_io"

let HEXA = "$HEXA_LANG/hexa"
let TMP = "/tmp/hexa_regress_stage1"

// 집계 (top-level mut)
let mut total = 0
let mut passed = 0
let mut failed = 0
let mut skipped = 0

fn record(id: string, label: string, ok: bool, note: string) {
    total = total + 1
    if ok {
        passed = passed + 1
        println("PASS  " + id + "  " + label)
    } else {
        failed = failed + 1
        println("FAIL  " + id + "  " + label + "  :: " + note)
    }
}
fn skip_case(id: string, label: string, reason: string) {
    total = total + 1
    skipped = skipped + 1
    println("SKIP  " + id + "  " + label + "  :: " + reason)
}

// 디렉토리 준비
exec("rm -rf " + TMP + " && mkdir -p " + TMP)

// ------------------------------------------------------------
// T23 — float codegen (compile/build path)
// 10.0*1000.0 == 10000, 90.0>75.0 == true — 네이티브 바이너리 경로
// ------------------------------------------------------------
let t23_f = TMP + "/t23.hexa"
let t23_bin = TMP + "/t23_bin"
safe_write_file(t23_f, "let a = 10.0 * 1000.0\nlet b = 90.0 > 75.0\nprintln(a)\nprintln(b)\n")
// T23/T28: Mac kernel-panic safety gate (2026-04-20) refuses `hexa build`
// output under /tmp. Tests are explicitly CI dry-runs, so enable the
// documented bypass instead of moving the fixture outside /tmp.
let t23_build = exec("HEXA_MAC_BUILD_OK=1 " + HEXA + " build " + t23_f + " -o " + t23_bin + " 2>&1 ; echo __EXIT__=$?")
let t23_built = t23_build.contains("__EXIT__=0")
if !t23_built {
    record("T23", "float codegen (build path)", false, "build failed")
} else {
    let t23_run = exec(t23_bin + " 2>&1")
    let t23_ok = t23_run.contains("10000") && t23_run.contains("true")
    record("T23", "float codegen (build path)", t23_ok, "got=" + t23_run.trim())
}

// ------------------------------------------------------------
// T24 — try/catch silent on to_int invalid
// ------------------------------------------------------------
let t24_f = TMP + "/t24.hexa"
safe_write_file(t24_f, "let mut x = -1\ntry {\n  x = to_int(\"abc\")\n} catch e {\n  x = 99\n}\nprintln(x)\n")
let t24_run = exec(HEXA + " run " + t24_f + " 2>&1")
record("T24", "try/catch to_int(abc)", t24_run.trim() == "99", "got=" + t24_run.trim())

// ------------------------------------------------------------
// T25 — enum runtime void
// ------------------------------------------------------------
let t25_f = TMP + "/t25.hexa"
safe_write_file(t25_f, "enum Color { Red, Green, Blue }\nlet c = Color::Red\nprintln(c)\n")
let t25_run = exec(HEXA + " run " + t25_f + " 2>&1")
let t25_s = t25_run.trim()
let t25_ok = !t25_s.contains("void") && (t25_s.contains("Red") || t25_s == "0")
record("T25", "enum Color::Red output", t25_ok, "got=" + t25_s)

// ------------------------------------------------------------
// T26 — comptime { expr } parser
// ------------------------------------------------------------
let t26_f = TMP + "/t26.hexa"
safe_write_file(t26_f, "let x = comptime { 1 + 2 }\nprintln(x)\n")
let t26_run = exec(HEXA + " run " + t26_f + " 2>&1")
record("T26", "comptime { 1+2 } parser", t26_run.trim() == "3", "got=" + t26_run.trim())

// ------------------------------------------------------------
// T27 — hexa parse <file> subcommand
// ------------------------------------------------------------
let t27_good = TMP + "/t27_good.hexa"
let t27_bad = TMP + "/t27_bad.hexa"
safe_write_file(t27_good, "println(\"ok\")\n")
safe_write_file(t27_bad, "let x = 1 +\n")
let t27_g = exec(HEXA + " parse " + t27_good + " 2>&1 ; echo __EXIT__=$?")
let t27_b = exec(HEXA + " parse " + t27_bad + " 2>&1 ; echo __EXIT__=$?")
let t27_gok = t27_g.contains("__EXIT__=0")
let t27_bok = t27_b.contains("Parse error") && t27_b.contains("__EXIT__=1")
record("T27", "hexa parse exit 0/1", t27_gok && t27_bok, "good=" + to_string(t27_gok) + " bad=" + to_string(t27_bok))

// ------------------------------------------------------------
// T28 — hexa build cwd 독립성
// ------------------------------------------------------------
let t28_f = TMP + "/t28.hexa"
let t28_bin = TMP + "/t28_bin"
safe_write_file(t28_f, "println(\"hello from build\")\n")
let t28_out = exec("cd /tmp && HEXA_MAC_BUILD_OK=1 " + HEXA + " build " + t28_f + " -o " + t28_bin + " 2>&1 ; echo __EXIT__=$?")
let t28_built = t28_out.contains("__EXIT__=0")
let t28_exists = file_exists(t28_bin)
let t28_run_ok = if t28_built && t28_exists {
    exec(t28_bin + " 2>&1").contains("hello from build")
} else {
    false
}
record("T28", "hexa build cwd=/tmp", t28_built && t28_exists && t28_run_ok, "built=" + to_string(t28_built) + " exists=" + to_string(t28_exists) + " run=" + to_string(t28_run_ok))

// ------------------------------------------------------------
// T29 — stderr 'map key elements not found' — investigated_no_repro
// ------------------------------------------------------------
skip_case("T29", "map key missing noise", "investigated_no_repro (shared/todo/hexa-lang.json)")

// ------------------------------------------------------------
// T30 — use 문 stmt-dispatch SEGV 회귀
// ------------------------------------------------------------
let t30_f = TMP + "/t30.hexa"
safe_write_file(t30_f, "use std::io\nuse std::fmt\nprintln(\"use ok\")\n")
let t30_run = exec(HEXA + " run " + t30_f + " 2>&1 ; echo __EXIT__=$?")
record("T30", "use directive no-SEGV", t30_run.contains("use ok") && t30_run.contains("__EXIT__=0"), "got=" + t30_run.trim())

// ------------------------------------------------------------
// T31 — Val arena default OFF
// ------------------------------------------------------------
let t31_f = TMP + "/t31.hexa"
safe_write_file(t31_f, "use std::io\nuse std::fmt\nuse std::collections\nprintln(\"arena off ok\")\n")
let t31_run = exec("HEXA_VAL_ARENA=0 " + HEXA + " run " + t31_f + " 2>&1 ; echo __EXIT__=$?")
record("T31", "Val arena default OFF safe", t31_run.contains("arena off ok") && t31_run.contains("__EXIT__=0"), "got=" + t31_run.trim())

// ------------------------------------------------------------
// T32 — 인터프리터 float 산술 (TAG_VALSTRUCT 언래핑)
// ------------------------------------------------------------
let t32_f = TMP + "/t32.hexa"
safe_write_file(t32_f, "let a = 10.0 * 1000.0\nlet b = 90.0 > 75.0\nlet c = 3.5 + 2.5\nlet d = 10.0 / 4.0\nprintln(a)\nprintln(b)\nprintln(c)\nprintln(d)\n")
let t32_run = exec(HEXA + " run " + t32_f + " 2>&1")
record("T32", "interpreter float arith", t32_run.contains("10000") && t32_run.contains("true") && t32_run.contains("6") && t32_run.contains("2.5"), "got=" + t32_run.trim())

// ------------------------------------------------------------
// T33 — Val arena=1 smoke (heapify audit in progress)
// ------------------------------------------------------------
let t33_f = TMP + "/t33.hexa"
safe_write_file(t33_f, "let mut s = \"\"\nfor i in 0..50 {\n  s = s + \"x\"\n}\nprintln(len(s))\n")
let t33_run = exec("HEXA_VAL_ARENA=1 " + HEXA + " run " + t33_f + " 2>&1 ; echo __EXIT__=$?")
record("T33", "Val arena=1 smoke", t33_run.contains("50") && t33_run.contains("__EXIT__=0"), "got=" + t33_run.trim())

// ------------------------------------------------------------
// T33b — Val arena array-passthrough corruption repro (2026-04-14 audit)
// Minimum trigger: fn returning array + fn returning same array + read idx 0.
// ARENA=0 must PASS (array_store refcount intact). ARENA=1 is a known fail
// until stage0 rebuild regression unblocks the heapify fix — recorded as
// canary so we notice when the corruption disappears.
// ------------------------------------------------------------
let t33b_f = TMP + "/t33b.hexa"
safe_write_file(t33b_f, "fn wrap() { return [\"a\", \"b\", \"c\"] }\nfn touch(x) { return x }\nfn inner() {\n  let lines = wrap()\n  let z = touch(lines)\n  println(type_of(lines[0]))\n}\ninner()\n")
let t33b_off = exec("HEXA_VAL_ARENA=0 " + HEXA + " run " + t33b_f + " 2>&1 ; echo __EXIT__=$?")
record("T33b-off", "array passthrough (ARENA=0)", t33b_off.contains("str") && t33b_off.contains("__EXIT__=0"), "got=" + t33b_off.trim())
let t33b_on = exec("HEXA_VAL_ARENA=1 " + HEXA + " run " + t33b_f + " 2>&1 ; echo __EXIT__=$?")
// Canary: we expect "str" to be printed. When ARENA=1 fix lands, this flips
// from FAIL to PASS and the failure notice in the log disappears.
record("T33b-on", "array passthrough (ARENA=1, canary)", t33b_on.contains("str"), "got=" + t33b_on.trim())

// ------------------------------------------------------------
// T34 — uncaught throw 진단 출력
// ------------------------------------------------------------
let t34_f = TMP + "/t34.hexa"
safe_write_file(t34_f, "let x = to_int(\"1.01\")\nprintln(x)\n")
let t34_run = exec(HEXA + " run " + t34_f + " 2>&1")
record("T34", "uncaught throw diag", t34_run.contains("error:") && t34_run.contains("1.01"), "got=" + t34_run.trim())

// ------------------------------------------------------------
// T35 — 멀티라인 라인시작 `+` 파서
// ------------------------------------------------------------
let t35_f = TMP + "/t35.hexa"
safe_write_file(t35_f, "let s = \"a\"\n  + \"b\"\n  + \"c\"\nprintln(s)\n")
let t35_run = exec(HEXA + " run " + t35_f + " 2>&1")
record("T35", "multiline leading +", t35_run.trim() == "abc", "got=" + t35_run.trim())

// ------------------------------------------------------------
// T36 — module_loader.hexa OOM 회귀 (< 1s, < 100MB)
// ------------------------------------------------------------
// file_exists() 는 shell 확장 안 됨 — env_var 로 절대경로 구성
let t36_root = env_var("HEXA_LANG")
let t36_ml = t36_root + "/self/module_loader.hexa"
if !file_exists(t36_ml) {
    skip_case("T36", "module_loader OOM", "module_loader.hexa not found at " + t36_ml)
} else {
    let t36_raw = exec("( /usr/bin/time -p " + HEXA + " run " + t36_ml + " ) 2>&1 ; echo __EXIT__=$?")
    let t36_exit = t36_raw.contains("__EXIT__=0")
    // Warm run ~0.3s; cold AOT build can spike to 2–3s on contended hosts.
    // Threshold loosened from <2s → <4s to absorb 1ba02018-era cache misses.
    let t36_fast = t36_raw.contains("real 0") || t36_raw.contains("real 1.") || t36_raw.contains("real 2.") || t36_raw.contains("real 3.")
    let t36_st = t36_raw.contains("self-test PASS")
    record("T36", "module_loader <4s no-OOM", t36_exit && t36_fast && t36_st, "exit=" + to_string(t36_exit) + " fast=" + to_string(t36_fast) + " selftest=" + to_string(t36_st))
}

// ------------------------------------------------------------
// T37 — .index_of(needle, start) 는 start offset 을 존중해야 함
//        (hxa-20260423-012: 2-arg 형태가 start 를 무시하던 버그)
// ------------------------------------------------------------
let t37_s = "abc-abc-abc"
let t37_a = t37_s.index_of("abc", 0)      // 0
let t37_b = t37_s.index_of("abc", 1)      // 4 (NOT 0)
let t37_c = t37_s.index_of("abc", 5)      // 8
let t37_d = t37_s.index_of("abc", 9)      // -1 (past last match start)
record("T37", "str.index_of start-offset",
    t37_a == 0 && t37_b == 4 && t37_c == 8 && t37_d == -1,
    "a=" + to_string(t37_a) + " b=" + to_string(t37_b) + " c=" + to_string(t37_c) + " d=" + to_string(t37_d))

// ------------------------------------------------------------
// T39 — AOT compound assign (+=, -=, *=, /=) 가 실제 lhs 를 갱신해야 함.
//        codegen_c2 가 op="+" 를 "+=" 로 비교했던 pre-existing bug 회귀 방지.
// ------------------------------------------------------------
let mut t39_a = 10
t39_a += 5
let mut t39_b = 10
t39_b -= 3
let mut t39_c = 4
t39_c *= 5
let mut t39_d = 20
t39_d /= 4
record("T39", "compound assign (+=, -=, *=, /=)",
    t39_a == 15 && t39_b == 7 && t39_c == 20 && t39_d == 5,
    "a=" + to_string(t39_a) + " b=" + to_string(t39_b) + " c=" + to_string(t39_c) + " d=" + to_string(t39_d))

// ------------------------------------------------------------
// T40 — Logical-compound assign (??=, ||=, &&=) pre-existing bug
//        lexer 가 `??=` 를 `??` + `=` 로 토큰화 + codegen 에 LogicalAssign
//        handler 없었던 2-layer silent failure 회귀 방지.
// ------------------------------------------------------------
let mut t40_a = ""
t40_a ??= "dflt"              // empty → dflt
let mut t40_b = "keep"
t40_b ??= "other"             // truthy → keep
let mut t40_c = "x"
t40_c ||= "y"                 // truthy → x
let mut t40_d = ""
t40_d ||= "fallback"          // falsy → fallback
let mut t40_e = "ok"
t40_e &&= "override"          // truthy → override
record("T40", "logical assign (??=, ||=, &&=)",
    t40_a == "dflt" && t40_b == "keep" && t40_c == "x" && t40_d == "fallback" && t40_e == "override",
    "a=[" + t40_a + "] b=[" + t40_b + "] c=[" + t40_c + "] d=[" + t40_d + "] e=[" + t40_e + "]")

// ------------------------------------------------------------
// T41 — `.method()` 다음-줄 체인 continuation (Rust/JS-style).
//        이전: "unexpected token Dot" interp / silent drop AOT.
// ------------------------------------------------------------
let t41_a = "abc"
    .substring(1, 3)
let t41_b = "  hi  "
    .trim()
let t41_c = "hello"
    .substring(0, 4)
    .substring(1, 4)
record("T41", "dot-chain multiline",
    t41_a == "bc" && t41_b == "hi" && t41_c == "ell",
    "a=[" + t41_a + "] b=[" + t41_b + "] c=[" + t41_c + "]")

// ------------------------------------------------------------
// T42 — `.reverse()` polymorphic (str + array). 이전까지 AOT 에서
//        문자열 reverse 는 no-op 이었음 — hexa_array_reverse 가 non-array
//        guard 로 원본 반환. runtime.c 에 string branch 추가 후 정상화.
// ------------------------------------------------------------
let t42_s = "abc".reverse()
let t42_a = [1, 2, 3].reverse()
record("T42", "reverse polymorphic (str + arr)",
    t42_s == "cba" && len(t42_a) == 3 && t42_a[0] == 3 && t42_a[2] == 1,
    "s=[" + t42_s + "] a.len=" + to_string(len(t42_a)) + " a[0]=" + to_string(t42_a[0]))

// ------------------------------------------------------------
// T43 — `.sort()` array element preservation + in-place aliasing 회귀 방지.
//        이전: hexa_array_sort 가 HX_SET_ARR_ITEMS 를 먼저 호출해서 src/dst
//        가 같은 buffer 가리키게 됨 → memcpy 무의미 → qsort 가 garbage 정렬
//        → [0,0,0] 반환 + 원본도 zeroed.
// ------------------------------------------------------------
let t43_in = [3, 1, 2]
let t43_sorted = t43_in.sort()
record("T43", "array sort preserves elements",
    len(t43_sorted) == 3 && t43_sorted[0] == 1 && t43_sorted[1] == 2 && t43_sorted[2] == 3
        && t43_in[0] == 3 && t43_in[1] == 1 && t43_in[2] == 2,
    "sorted=[" + to_string(t43_sorted[0]) + "," + to_string(t43_sorted[1]) + "," + to_string(t43_sorted[2])
     + "] in=[" + to_string(t43_in[0]) + "," + to_string(t43_in[1]) + "," + to_string(t43_in[2]) + "]")

// ------------------------------------------------------------
// T38 — self/runtime_hi.hexa probe (hxa-003 M1-lite scaffold)
//        5 hi-layer fn implementation selftest 이 회귀 방지선.
// ------------------------------------------------------------
let t38_rt_root = env_var("HEXA_LANG")
let t38_rthi = t38_rt_root + "/self/runtime_hi.hexa"
if !file_exists(t38_rthi) {
    skip_case("T38", "runtime_hi probe", "self/runtime_hi.hexa not found at " + t38_rthi)
} else {
    let t38_out = exec("timeout 30 " + HEXA + " run " + t38_rthi + " 2>&1 ; echo __EXIT__=$?")
    let t38_ok = t38_out.contains("selftest OK") && t38_out.contains("__EXIT__=0")
    record("T38", "runtime_hi selftest", t38_ok, "ok=" + to_string(t38_ok))
}

// ------------------------------------------------------------
// 요약
// ------------------------------------------------------------
println("")
println("==================================================")
println("  regression: total=" + to_string(total) + " pass=" + to_string(passed) + " fail=" + to_string(failed) + " skip=" + to_string(skipped))
println("==================================================")
if failed > 0 {
    exit(1)
}
