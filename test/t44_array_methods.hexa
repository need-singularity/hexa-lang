// t44_array_methods — comprehensive array method coverage
// EXPECTED: ALL PASS

// --- push / pop / len ---
let mut arr = [1, 2, 3]
arr.push(4)
if len(arr) == 4 {
    println("PASS push len=4")
} else {
    println("FAIL push len=" + to_string(len(arr)))
}
let popped = arr.pop()
if len(arr) == 3 {
    println("PASS pop len=3")
} else {
    println("FAIL pop len=" + to_string(len(arr)))
}

// --- contains ---
let nums = [10, 20, 30]
if nums.contains(20) && !nums.contains(99) {
    println("PASS contains")
} else {
    println("FAIL contains")
}

// --- map ---
let doubled = [1, 2, 3].map(|x| x * 2)
if doubled.join(",") == "2,4,6" {
    println("PASS map")
} else {
    println("FAIL map=" + doubled.join(","))
}

// --- filter ---
let evens = [1, 2, 3, 4, 5, 6].filter(|x| x % 2 == 0)
if evens.join(",") == "2,4,6" {
    println("PASS filter")
} else {
    println("FAIL filter=" + evens.join(","))
}

// --- fold ---
let total = [1, 2, 3, 4, 5].fold(0, |acc, x| acc + x)
if total == 15 {
    println("PASS fold sum=15")
} else {
    println("FAIL fold=" + to_string(total))
}

// --- sort ---
let sorted = [3, 1, 4, 1, 5].sort()
if sorted.join(",") == "1,1,3,4,5" {
    println("PASS sort")
} else {
    println("FAIL sort=" + sorted.join(","))
}

// --- reverse ---
let rev = [1, 2, 3].reverse()
if rev.join(",") == "3,2,1" {
    println("PASS reverse")
} else {
    println("FAIL reverse=" + rev.join(","))
}

// --- any / all ---
let data = [2, 4, 6, 8, 9]
if data.any(|x| x % 2 != 0) && !data.all(|x| x % 2 == 0) {
    println("PASS any/all")
} else {
    println("FAIL any/all")
}

// --- find ---
let found = [10, 20, 30, 40].find(|x| x > 25)
if found == 30 {
    println("PASS find=30")
} else {
    println("FAIL find=" + to_string(found))
}

// --- sum ---
let s = [1, 2, 3, 4, 5].sum()
if s == 15 {
    println("PASS sum=15")
} else {
    println("FAIL sum=" + to_string(s))
}

// --- join ---
let joined = ["a", "b", "c"].join("-")
if joined == "a-b-c" {
    println("PASS join")
} else {
    println("FAIL join=" + joined)
}

// --- enumerate ---
let en = ["x", "y", "z"].enumerate()
let mut ok = true
if en[0][0] != 0 || en[0][1] != "x" { ok = false }
if en[1][0] != 1 || en[1][1] != "y" { ok = false }
if en[2][0] != 2 || en[2][1] != "z" { ok = false }
if ok {
    println("PASS enumerate")
} else {
    println("FAIL enumerate")
}

// --- flatten ---
let nested = [[1, 2], [3, 4], [5]]
let flat = nested.flatten()
if flat.join(",") == "1,2,3,4,5" {
    println("PASS flatten")
} else {
    println("FAIL flatten=" + flat.join(","))
}

// --- slice ---
let sliced = [10, 20, 30, 40, 50].slice(1, 4)
if sliced.join(",") == "20,30,40" {
    println("PASS slice")
} else {
    println("FAIL slice=" + sliced.join(","))
}

// --- swap ---
let swapped = [1, 2, 3].swap(0, 2)
if swapped.join(",") == "3,2,1" {
    println("PASS swap")
} else {
    println("FAIL swap=" + swapped.join(","))
}

// --- fill ---
let filled = [0, 0, 0].fill(7)
if filled.join(",") == "7,7,7" {
    println("PASS fill")
} else {
    println("FAIL fill=" + filled.join(","))
}

println("ALL PASS")
