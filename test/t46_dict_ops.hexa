// t46_dict_ops — dict literal, access, mutation, builtins
// EXPECTED: ALL PASS

// --- literal creation and access ---
let d = #{"name": "hexa", "version": "6"}
if d["name"] == "hexa" && d["version"] == "6" {
    println("PASS dict literal access")
} else {
    println("FAIL dict literal access")
}

// --- mutation: add key ---
d["lang"] = "ai-native"
if d["lang"] == "ai-native" {
    println("PASS dict add key")
} else {
    println("FAIL dict add key=" + d["lang"])
}

// --- mutation: update key ---
d["version"] = "7"
if d["version"] == "7" {
    println("PASS dict update key")
} else {
    println("FAIL dict update key=" + d["version"])
}

// --- has_key ---
if has_key(d, "name") && !has_key(d, "missing") {
    println("PASS has_key")
} else {
    println("FAIL has_key")
}

// --- keys ---
let k = keys(d)
if len(k) == 3 {
    println("PASS keys len=3")
} else {
    println("FAIL keys len=" + to_string(len(k)))
}

// --- numeric values ---
let scores = #{"math": 95, "eng": 88, "sci": 92}
let mut total = 0
let ks = keys(scores)
for key in ks {
    total = total + scores[key]
}
if total == 275 {
    println("PASS dict numeric iteration sum=275")
} else {
    println("FAIL dict numeric iteration sum=" + to_string(total))
}

// --- empty dict ---
let empty = #{}
if len(keys(empty)) == 0 {
    println("PASS empty dict")
} else {
    println("FAIL empty dict")
}

// --- nested dict ---
let nested = #{"inner": #{"x": 42}}
if nested["inner"]["x"] == 42 {
    println("PASS nested dict access")
} else {
    println("FAIL nested dict access")
}

println("ALL PASS")
