// Regression — stage0 exec/env primitives + reproducible time primitives
//
// Added with feat/stage0-exec-env-reproducible. Exercises:
//   - setenv(name, value)       — POSIX setenv wrapper
//   - exec_capture(cmd)         — stdout/stderr/exit split via pipe/fork
//   - SOURCE_DATE_EPOCH pin     — now/timestamp/time_ms/utc_*_now
//   - HEXA_REPRODUCIBLE=1 pin   — same, epoch 0

// ── setenv roundtrip ──
let sv = setenv("HX_EXEC_ENV_TEST", "alpha")
assert sv == "alpha"
assert env("HX_EXEC_ENV_TEST") == "alpha"
assert setenv("HX_EXEC_ENV_TEST", "beta") == "beta"
assert env("HX_EXEC_ENV_TEST") == "beta"

// ── exec_capture: stdout+stderr+exit split ──
let r = exec_capture("echo out; echo err 1>&2; exit 3")
assert r[0].trim() == "out"
assert r[1].trim() == "err"
assert r[2] == 3

// ── exec_capture: empty stderr, exit 0 ──
let r2 = exec_capture("echo only_stdout")
assert r2[0].trim() == "only_stdout"
assert r2[1] == ""
assert r2[2] == 0

// ── SOURCE_DATE_EPOCH pin — timestamps freeze to fixed value ──
setenv("SOURCE_DATE_EPOCH", "1700000000")
assert now() == 1700000000
assert timestamp() == 1700000000
assert time_ms() == 1700000000000
assert utc_iso_now() == "2023-11-14T22:13:20Z"
assert utc_compact_now() == "20231114221320"

// ── SOURCE_DATE_EPOCH cleared → re-enable HEXA_REPRODUCIBLE path ──
setenv("SOURCE_DATE_EPOCH", "")
setenv("HEXA_REPRODUCIBLE", "1")
assert now() == 0
assert utc_iso_now() == "1970-01-01T00:00:00Z"

println("OK: exec_env_reproducible")
