// bubble_n8_swaphelper.rewritten — expected dry-run output of
// algorithm_swap rewrite_bubble_to_insertion on
// tests/fixtures/bubble_n8_swaphelper.hexa.
// Both canonical bubble shapes (tmp-swap + swap-helper) normalize onto
// the SAME insertion-sort body — swap() becomes dead code (caller may
// keep or DCE separately).

fn swap(a, i, j) {
    let tmp = a[i]
    a[i] = a[j]
    a[j] = tmp
}

fn bubble_sort(a) {
    // @rewritten_by: algorithm_swap (bubble → insertion, S-3b dry-run)
    let n = len(a)
    let mut i = 1
    while i < n {
        let key = a[i]
        let mut j = i
        while j > 0 && a[j - 1] > key {
            a[j] = a[j - 1]
            j = j - 1
        }
        a[j] = key
        i = i + 1
    }
    return a
}

fn main() {
    let arr = [5, 2, 7, 1, 8, 3, 6, 4]
    bubble_sort(arr)
    let mut s = ""
    let mut k = 0
    while k < len(arr) { s = s + to_string(arr[k]) + " "; k = k + 1 }
    println(s.trim())
}

main()
