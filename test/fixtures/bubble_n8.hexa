// bubble_n8 — canonical bubble-sort fixture for S-3b algorithm_swap rewrite.
// SHAPE: nested-while, swap via let-tmp.  Matches algorithm_swap rewrite_bubble_to_insertion.
// DO NOT EDIT formatting/spacing — the rewriter's canonical-shape matcher is strict.

fn bubble_sort(a) {
    let n = len(a)
    let mut i = 0
    while i < n - 1 {
        let mut j = 0
        while j < n - i - 1 {
            if a[j] > a[j + 1] {
                let tmp = a[j]
                a[j] = a[j + 1]
                a[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    return a
}

fn main() {
    let arr = [5, 2, 7, 1, 8, 3, 6, 4]
    bubble_sort(arr)
    let mut s = ""
    let mut k = 0
    while k < len(arr) { s = s + to_string(arr[k]) + " "; k = k + 1 }
    println(s.trim())
}

main()
