// tests/fixtures/run_bubble_rewrite_test — S-3b self-test harness.
//
// Runs:
//   hexa_stage0 self/opt/algorithm_swap.hexa --apply tests/fixtures/bubble_n8.hexa
// Captures stdout, asserts the [REWRITE dry-run] block matches the golden.
//
// Exit: prints "PASS"/"FAIL" plus a short diff on failure. Non-zero exit
// via a print-only signal (this harness stays in pure .hexa; the outer
// runner decides on exit code).
//
// Usage:
//   ./build/hexa_stage0 tests/fixtures/run_bubble_rewrite_test.hexa

fn extract_dry_run_block(text) {
    // Keep lines from the first "[REWRITE dry-run]" onward, up to the
    // "algorithm_swap[apply-dry-run]:" summary (exclusive). Drop the
    // "--- fn ..." and "+++ fn ..." headers (informational only — the
    // golden keeps just the tag line + diff lines).
    let lines = text.split("\n")
    let mut out = []
    let mut started = false
    let mut i = 0
    while i < len(lines) {
        let ln = lines[i]
        if !started {
            if ln.contains("[REWRITE dry-run]") {
                started = true
                // take everything after the path prefix up to EOL
                let idx = ln.index_of("[REWRITE dry-run]")
                out.push(ln.substring(idx, len(ln)))
            }
            i = i + 1
            continue
        }
        if ln.contains("algorithm_swap[apply-dry-run]:") { break }
        if ln.starts_with("--- ") || ln.starts_with("+++ ") { i = i + 1; continue }
        out.push(ln)
        i = i + 1
    }
    return out.join("\n")
}

fn main() {
    let root = env_var("HEXA_LANG")
    let bin = root + "/build/hexa_stage0"
    let pass = root + "/self/opt/algorithm_swap.hexa"
    let fixture = root + "/tests/fixtures/bubble_n8.hexa"
    let golden_path = root + "/tests/fixtures/bubble_n8.rewrite.golden.txt"

    let cmd = "'" + bin + "' '" + pass + "' --apply '" + fixture + "' 2>/dev/null"
    let mut raw = ""
    try { raw = exec(cmd) } catch e { println("FAIL: exec error: " + to_string(e)); return }
    let got = extract_dry_run_block(raw).trim()
    let want = read_file(golden_path).trim()

    if got == want {
        println("PASS: S-3b bubble→insertion rewrite dry-run matches golden")
        return
    }
    println("FAIL: S-3b rewrite mismatch")
    println("─── GOT ───")
    println(got)
    println("─── WANT ───")
    println(want)
}

main()
