// bubble_n8_swaphelper — S-3b+ canonical bubble-sort shape #2.
// SHAPE: nested-while, swap via `swap(a, j, j+1)` helper call (not inline tmp).
// Matches canonical_bubble_swaphelper_template in self/opt/algorithm_swap.hexa.
// DO NOT EDIT formatting/spacing — the rewriter's canonical-shape matcher is strict.

fn swap(a, i, j) {
    let tmp = a[i]
    a[i] = a[j]
    a[j] = tmp
}

fn bubble_sort(a) {
    let n = len(a)
    let mut i = 0
    while i < n - 1 {
        let mut j = 0
        while j < n - i - 1 {
            if a[j] > a[j + 1] {
                swap(a, j, j + 1)
            }
            j = j + 1
        }
        i = i + 1
    }
    return a
}

fn main() {
    let arr = [5, 2, 7, 1, 8, 3, 6, 4]
    bubble_sort(arr)
    let mut s = ""
    let mut k = 0
    while k < len(arr) { s = s + to_string(arr[k]) + " "; k = k + 1 }
    println(s.trim())
}

main()
