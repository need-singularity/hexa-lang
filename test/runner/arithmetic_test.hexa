// tests/runner/arithmetic_test.hexa — P7-6 BinOp arithmetic 커버리지
//
// 실행: `hexa test tests/runner/arithmetic_test.hexa`
// 기대: 5 PASS / 0 FAIL / 1 SKIP
//
// 대상 연산자: + - * / %
// 각 @test 는 독립 프로세스로 실행 (self/test_runner.hexa 설계).

@test
fn test_add_basic() {
    // 양수 / 음수 / 0 혼합 add
    assert(1 + 2 == 3)
    assert(-5 + 5 == 0)
    assert(0 + 0 == 0)
    assert(100 + 23 == 123)
    assert(-7 + -3 == -10)
}

@test
fn test_sub_basic() {
    // sub 는 음수 결과, 큰값-작은값, 자기자신 포함
    assert(10 - 3 == 7)
    assert(3 - 10 == -7)
    assert(0 - 42 == -42)
    assert(42 - 42 == 0)
    assert(-5 - -3 == -2)
}

@test
fn test_mul_basic() {
    // mul 부호 규칙 + 1 / 0 경계 + 큰 값
    assert(3 * 4 == 12)
    assert(-3 * 4 == -12)
    assert(-3 * -4 == 12)
    assert(0 * 99999 == 0)
    assert(1 * 7 == 7)
    assert(12345 * 10 == 123450)
}

@test
fn test_div_basic() {
    // div: 정수 나눗셈, 부호 규칙 (stage0 = truncate toward zero 가정).
    // NOTE: div-by-zero 는 런타임 abort → @test 당 SKIP 으로 남김 (아래 t_div_by_zero).
    assert(12 / 4 == 3)
    assert(12 / 3 == 4)
    assert(0 / 9 == 0)
    assert(-20 / 4 == -5)
    assert(100 / 7 == 14)  // 7*14 = 98
}

@test
fn test_mod_basic() {
    // mod: 양수/음수 양쪽, 자기배수, 0 피제수
    assert(10 % 3 == 1)
    assert(9 % 3 == 0)
    assert(0 % 5 == 0)
    assert(13 % 4 == 1)
    assert(100 % 10 == 0)
}

// div-by-zero 는 stage0 인터프리터에서 abort → 실행하면 FAIL.
// 의도적으로 @skip 으로 보존해 "이 케이스가 존재함" 문서화.
@test @skip
fn t_div_by_zero() {
    let x = 1 / 0   // runtime abort 예상 — 러너가 실행하면 안 됨
    assert(x == 0)  // unreachable
}
