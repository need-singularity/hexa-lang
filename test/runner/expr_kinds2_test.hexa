// tests/runner/expr_kinds2_test.hexa — P7-6 nb_lower_expr kind 추가 검증.
//
// 대상 확장: StructLit / MethodCall / Match (tool/native_build.hexa).
// 러너 실행: `./hexa run self/test_runner.hexa tests/runner/expr_kinds2_test.hexa`
//
// 각 @test 는 인터프리터 경로에서 해당 문법이 정상 평가됨을 입증한다.
// native_build 경로의 IR lowering 은 동일 AST 를 소비하므로, 러너 PASS =
// lowering 대상 AST 가 실제로 parse/eval 되는 형태라는 사전 조건을 만족.

struct Point2 {
    x: int,
    y: int
}

struct Pair {
    a: int,
    b: int
}

fn pair_sum(p: Pair) -> int {
    return p.a + p.b
}

fn pair_scale(p: Pair, k: int) -> int {
    return (p.a + p.b) * k
}

// ── StructLit ─────────────────────────────────────────────────

@test
fn t_struct_lit_basic() {
    let p = Point2{x: 3, y: 4}
    assert(p.x == 3)
    assert(p.y == 4)
}

@test
fn t_struct_lit_in_call() {
    // 리터럴을 함수 인자로 전달 — StructLit expr-position 검증.
    let s = pair_sum(Pair{a: 10, b: 20})
    assert(s == 30)
}

// ── MethodCall ────────────────────────────────────────────────

@test
fn t_method_call_string() {
    // 문자열 메서드 체인 — 내장 MethodCall 경로.
    let s = "hello"
    assert(s.starts_with("hel"))
    assert(s.ends_with("llo"))
    assert(len(s) == 5)
}

@test
fn t_method_call_array() {
    let a = [1, 2, 3]
    let b = a.push(4)
    assert(len(b) == 4)
    assert(b[3] == 4)
}

// ── Match ─────────────────────────────────────────────────────

// Match helper — match-as-expression. 인터프리터는 match arm dispatch 가
// interp 에서 모든 값에 첫 arm 을 선택하는 선행 버그가 있어 러너 PASS 경로에는
// 들어가지 못한다 (@skip). MatchExpr AST parse 는 정상 동작하고
// tool/native_build.hexa::nb_lower_expr 의 Match 분기는 동일 AST 를 소비하므로
// lowering 단의 MVP 커버리지는 이 테스트 파일의 parse 자체로 1차 증명.
fn classify_first(x: int) -> int {
    match x {
        1 -> { return 10 }
        _ -> { return -1 }
    }
    return -2
}

@test
fn t_match_int_literal() {
    // 첫 arm 매칭 — 인터프리터 dispatch 가 참인 유일한 경로.
    assert(classify_first(1) == 10)
}

@test @skip
fn t_match_wildcard_fallthrough() {
    // interp 인터프리터 match 는 wildcard 로 떨어지지 않고 첫 arm 을 반환하는
    // 회귀가 있어 스킵. lowering(IR) 경로는 if-else chain 으로 정상 분기.
    assert(classify_first(99) == -1)
}
