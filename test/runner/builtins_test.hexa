// tests/runner/builtins_test.hexa — 11 runtime builtin smoke 스위트
//
// 실행: `hexa test tests/runner/builtins_test.hexa`
// 기대: 9 PASS / 0 FAIL / 2 SKIP
//
// 배경 (P7-6):
//   tool/native_build.hexa 의 nb_lower_expr Call 디스패처에 11개 빌트인
//   라우팅 추가 — print/println/eprintln/len/argv/exit/exec/exec_with_status/
//   read_file/write_file/file_exists/env. 본 스위트는 hexa 표면 언어에서
//   각 빌트인이 정상 호출되는지 인터프리터 경로로 검증한다. 네이티브 코덖젠
//   회귀는 seed-freeze 해제 후 native_build 를 통해 별도 검증될 예정.
//
// 주의:
//   - exit(N) 은 러너 드라이버를 즉시 종료시키므로 @skip 처리.
//   - exec("echo ...") / exec_with_status("true") 는 부작용이 안전한 셀
//     명령만 사용.
//   - file_exists / read_file / write_file 은 /tmp 경로 사용.

// ─── print family ────────────────────────────────────────────────

@test
fn test_print_println_single_arg() {
    // 스모크: 예외 없이 통과하면 OK. stdout 내용은 sentinel 뒤에
    // 붙으므로 러너가 PASS 판정. eprintln 은 stderr 로 분리.
    println("builtins_test: println ok")
    print("builtins_test: print (no newline) ")
    println("— closing")
    eprintln("builtins_test: eprintln → stderr")
    assert(true)
}

// ─── len — arrays + strings ──────────────────────────────────────

@test
fn test_len_array() {
    let a = [1, 2, 3]
    assert(len(a) == 3)
    let empty = []
    assert(len(empty) == 0)
    let mixed = ["a", "b", "c", "d"]
    assert(len(mixed) == 4)
}

@test
fn test_len_string() {
    assert(len("abc") == 3)
    assert(len("") == 0)
    assert(len("hello world") == 11)
}

// ─── argv / args — 프로세스 인자 배열 ────────────────────────────

@test
fn t_argv_nonempty() {
    // interp 인터프리터는 argv[0] = exec path 를 항상 삽입하므로
    // 최소 1개 원소. args() 는 argv() 와 동일 런타임 심볼 (hexa_args).
    let av = argv()
    assert(len(av) >= 1)
    assert(len(av[0]) > 0)
    let av2 = args()
    assert(len(av2) >= 1)
}

// ─── exit — 별도 프로세스 요구, 러너 드라이버 보호 위해 @skip ────

@test @skip
fn t_exit_skipped_by_design() {
    // exit(N) 은 드라이버를 즉시 종료 → sentinel 누락 → FAIL 오판.
    // 네이티브 경로 검증은 별도 integration 테스트로 커버.
    exit(0)
}

// ─── exec / exec_with_status — 안전 셸 명령 ──────────────────────

@test
fn test_exec_basic() {
    // exec(cmd) 은 stdout 문자열 반환 (interp runtime.c:2471).
    let out = exec("echo builtins_exec_ok").trim()
    assert(out == "builtins_exec_ok")
}

@test
fn test_exec_with_status() {
    // exec_with_status → [stdout, rc]. `true` 는 항상 rc=0.
    let r = exec_with_status("true")
    assert(r[1] == 0)
    // `false` 는 rc=1. stdout 은 빈 문자열.
    let r2 = exec_with_status("false")
    assert(r2[1] != 0)
}

// ─── read_file / write_file — 라운드트립 ─────────────────────────

@test
fn test_read_write_file_roundtrip() {
    let path = "/tmp/hx_builtin_test.txt"
    let content = "hexa builtins roundtrip\nline2\n"
    write_file(path, content)
    let back = read_file(path)
    assert(back == content)
    // 정리 — 다음 실행 간섭 방지
    exec("rm -f " + path)
}

// ─── file_exists — true / false 양쪽 ─────────────────────────────

@test
fn test_file_exists_true_and_false() {
    let path = "/tmp/hx_builtin_exists.txt"
    // 먼저 삭제해 false 보장
    exec("rm -f " + path)
    assert(file_exists(path) == false)
    write_file(path, "probe")
    assert(file_exists(path) == true)
    exec("rm -f " + path)
    assert(file_exists(path) == false)
}

// ─── env / env_var — HOME 은 POSIX 에서 거의 항상 존재 ───────────

@test
fn test_env_home_nonempty() {
    let home = env("HOME")
    assert(len(home) > 0)
    // env_var 별칭
    let home2 = env_var("HOME")
    assert(len(home2) > 0)
    assert(home == home2)
}

@test @skip
fn t_env_missing_var() {
    // env("HX_DEFINITELY_UNSET_VAR_XYZ") 의 반환값은 런타임별로 다름 —
    // 현 interp 는 NULL 방어로 "" 리턴 (runtime.c:4625). 네이티브 경로
    // 합의 후 활성화.
    let missing = env("HX_DEFINITELY_UNSET_VAR_XYZ")
    assert(len(missing) == 0)
}
