// tests/runner/logical_test.hexa — P7-6 BinOp logical && || 커버리지
//
// 실행: `hexa test tests/runner/logical_test.hexa`
// 기대: 5 PASS / 0 FAIL
//
// && / || truth table + short-circuit 증명.
// stage0 surface parser 는 `({ stmt; val })` 블록-식을 지원하지 않으므로
// short-circuit 검증은 module-level mut 카운터 + 헬퍼 fn 으로 관찰한다.
// 각 @test 는 self/test_runner.hexa 가 독립 프로세스로 실행하므로
// 카운터 교차 오염 없음.

let mut __hits = 0

fn bump_true() {
    __hits = __hits + 1
    return true
}

fn bump_false() {
    __hits = __hits + 1
    return false
}

@test
fn test_and_truth_table() {
    // 4 cases
    assert((true && true) == true)
    assert((true && false) == false)
    assert((false && true) == false)
    assert((false && false) == false)
    // identity with true
    assert((true && true))
    // anything && false → false
    assert(!(true && false))
}

@test
fn test_or_truth_table() {
    // 4 cases
    assert((true || true) == true)
    assert((true || false) == true)
    assert((false || true) == true)
    assert((false || false) == false)
    // anything || true → true
    assert((false || true))
    // false || false → false
    assert(!(false || false))
}

@test
fn test_and_short_circuit() {
    // `false && RHS` 에서 RHS 가 평가되지 않음을 증명.
    // bump_true() 가 호출되면 __hits 가 1 증가 — 호출 안 돼야 함.
    __hits = 0
    let result = bump_false() && bump_true()
    assert(result == false)
    assert(__hits == 1)   // LHS 1회만; RHS 실행됐다면 2
}

@test
fn test_or_short_circuit() {
    // `true || RHS` 에서 RHS 가 평가되지 않음을 증명.
    __hits = 0
    let result = bump_true() || bump_false()
    assert(result == true)
    assert(__hits == 1)   // LHS 1회만; RHS 실행됐다면 2
}

@test
fn test_mixed_and_or() {
    // 혼합 표현식 — 우선순위: && 가 || 보다 tight.
    //   true || false && false   →  true || (false && false) = true
    assert(true || false && false)
    //   false && true || true     →  (false && true) || true = true
    assert(false && true || true)
    //   (false || true) && true   = true
    assert((false || true) && true)
    //   (true && false) || false  = false
    assert(!((true && false) || false))
    //   !false && true            = true
    assert(!false && true)
}
