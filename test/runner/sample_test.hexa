// tests/runner/sample_test.hexa — `hexa test` 러너 샘플
//
// 실행: `hexa test tests/runner/sample_test.hexa`
// 기대 리포트: 3 PASS / 1 FAIL / 1 SKIP  (총 5)

@test
fn test_add() {
    assert(1 + 1 == 2)
}

@test
fn t_string_prefix() {
    assert("hello".starts_with("hel"))
}

@test
fn test_array_push() {
    let mut a = []
    a = a.push(10)
    a = a.push(20)
    assert(len(a) == 2)
    assert(a[0] == 10)
    assert(a[1] == 20)
}

// 실패 샘플 — 러너가 rc!=0 으로 집계하는지 검증.
// 필요에 따라 주석 처리하면 4 PASS / 0 FAIL / 1 SKIP 로 깨끗해진다.
@test
fn test_intentional_fail() {
    assert(2 + 2 == 5)
}

// @skip 조합 — 러너가 skip 카운트에 반영, 실행 안 함.
@test @skip
fn t_pending_feature() {
    assert(false)
}
