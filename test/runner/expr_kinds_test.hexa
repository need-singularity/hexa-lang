// tests/runner/expr_kinds_test.hexa — P7-6 nb_lower_expr kind 커버리지
//
// 실행: `hexa test tests/runner/expr_kinds_test.hexa`
// 기대: 4 PASS / 0 FAIL
//
// 커버 대상 (tool/native_build.hexa:nb_lower_expr):
//   StringLit   — `"hello"` 리터럴 → bld_const_string
//   ArrayLit    — `[1, 2, 3]` 리터럴 → bld_alloc + N bld_array_store
//   Index       — `arr[i]` → bld_array_index
//   FieldAccess — `obj.field` (Field AST kind) → bld_struct_field
//
// 러너는 interp 인터프리터로 실행되므로 AST 레벨 의미 검증.
// native_build 의 IR lowering 도 동일 parser AST 를 읽으므로
// 여기 PASS = nb_lower_expr dispatch 정확성의 간접 증거.

@test
fn test_string_lit() {
    // StringLit — literal 값, 길이, 연결 (+), 비교
    let s = "hello"
    assert(len(s) == 5)
    assert(s == "hello")
    assert(s + " world" == "hello world")
    // 빈 문자열 엣지
    let empty = ""
    assert(len(empty) == 0)
}

@test
fn test_array_lit() {
    // ArrayLit — `[...]` 리터럴, 길이, 원소 접근
    let xs = [10, 20, 30]
    assert(len(xs) == 3)
    assert(xs[0] == 10)
    assert(xs[1] == 20)
    assert(xs[2] == 30)
    // 빈 배열
    let empty = []
    assert(len(empty) == 0)
    // 단일 원소
    let one = [42]
    assert(len(one) == 1)
    assert(one[0] == 42)
}

@test
fn test_index_access() {
    // Index — arr[i] 경로, 변수 인덱스 포함
    let xs = [100, 200, 300, 400]
    let i = 2
    assert(xs[i] == 300)
    // 계산된 인덱스
    assert(xs[i + 1] == 400)
    assert(xs[i - 2] == 100)
    // 경계
    assert(xs[0] == 100)
    assert(xs[len(xs) - 1] == 400)
}

@test
fn test_field_access() {
    // FieldAccess — struct field `.` 접근 (parser kind = "Field")
    let p = #{ "x": 3, "y": 4, "name": "origin" }
    assert(p["x"] == 3)
    assert(p["y"] == 4)
    assert(p["name"] == "origin")
    // 중첩
    let nested = #{ "inner": #{ "n": 42 } }
    assert(nested["inner"]["n"] == 42)
}
