// tests/runner/bitwise_test.hexa — P7-6 BinOp bitwise/shift 커버리지
//
// 실행: `hexa test tests/runner/bitwise_test.hexa`
// 기대: 5 PASS / 0 FAIL
//
// ── stage0 surface parser pitfall (2026-04-17 feedback_hexa_bitop_surface.md) ──
//   `<<` / `>>` — parser 가 silent reject (expression 자리에서 `Shl` 토큰 에러).
//   `|`         — `|a|` closure 와 충돌하여 int literal 위치에서 parse-error.
//   `&`, `^`    — OK.
//
// 따라서 shift 는 `* pow2(n)` / `/ pow2(n)` 로 우회 (self/runtime/bit_pure.hexa 관행).
// `|` 는 identity  a|b == (a+b) - (a&b)  (서로 다른 비트일 때 carry 없음) 로 우회.

fn pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

// a | b — bit_or emulation (both operands non-negative, small ints).
fn bor(a, b) {
    return (a + b) - (a & b)
}

@test
fn test_bit_and() {
    // 12 = 1100, 10 = 1010 → AND = 1000 = 8
    assert((12 & 10) == 8)
    // 0 & anything == 0
    assert((0 & 0xFF) == 0)
    // same operand identity
    assert((0xAA & 0xAA) == 0xAA)
    // disjoint bits
    assert((0x0F & 0xF0) == 0)
    // low-nibble mask
    assert((0xAB & 0x0F) == 0x0B)
}

@test
fn test_bit_xor() {
    // 12 ^ 10 = 0110 = 6
    assert((12 ^ 10) == 6)
    // self-xor zeros out
    assert((0xDEAD ^ 0xDEAD) == 0)
    // xor with 0 is identity
    assert((0x42 ^ 0) == 0x42)
    // toggle all bits in a nibble
    assert((0x0F ^ 0xFF) == 0xF0)
    // commutativity
    assert((7 ^ 3) == (3 ^ 7))
}

@test
fn test_bit_or_via_emul() {
    // `|` 는 surface parser 가 closure 로 오인 → bor() emul 사용.
    // 12 | 10 = 1110 = 14
    assert(bor(12, 10) == 14)
    // disjoint bits → add
    assert(bor(0x0F, 0xF0) == 0xFF)
    // or with 0 is identity
    assert(bor(0x42, 0) == 0x42)
    // same operand identity
    assert(bor(0xAA, 0xAA) == 0xAA)
    // full-mask
    assert(bor(0xABCD, 0xFFFF) == 0xFFFF)
}

@test
fn test_shl_via_pow2() {
    // `<<` 는 surface parser silent-reject → `* pow2(n)` 로 우회.
    //   1 << 4 == 16
    assert(1 * pow2(4) == 16)
    //   3 << 2 == 12  (0011 → 1100)
    assert(3 * pow2(2) == 12)
    //   0 << N == 0
    assert(0 * pow2(8) == 0)
    //   a << 0 == a
    assert(7 * pow2(0) == 7)
    //   1 << 10 == 1024
    assert(1 * pow2(10) == 1024)
}

@test
fn test_shr_via_pow2() {
    // `>>` 는 surface parser silent-reject → `/ pow2(n)` 로 우회 (양수 전제).
    //   16 >> 2 == 4
    assert(16 / pow2(2) == 4)
    //   1024 >> 10 == 1
    assert(1024 / pow2(10) == 1)
    //   0 >> N == 0
    assert(0 / pow2(8) == 0)
    //   a >> 0 == a
    assert(7 / pow2(0) == 7)
    //   truncation: 13 >> 2 == 3 (1101 → 0011)
    assert(13 / pow2(2) == 3)
}
