// tests/runner/bitop_surface_test.hexa — bit-op surface parser lift test
//
// Per memory feedback_hexa_bitop_surface.md + project_g39_hexa_full_drift.md:
//   - parser.hexa 이미 Shl/Shr/BitOr 를 parse_bit_ops() 에 포함 (2138 line).
//   - hexa_cc.c 이미 동일 패치 반영 (3189 line).
//   - hexa_full.hexa 가 drift — BitOr/Shl/Shr 누락 → 이번 브랜치에서 동기화.
//
// 현재 (seed-frozen) 상태:
//   - .hexa 인터프리터 경로: seed interp 이 pre-fix 상태이므로 <<, >>, | 전부 FAIL.
//   - 이 10 개 @test 는 freeze 해제 + FORCE=1 rebuild_interp 이후 PASS 로 뒤집힌다.
//
// 실행: `hexa test tests/runner/bitop_surface_test.hexa`
// 기대 (seed freeze 해제 후): 10 PASS / 0 FAIL.
// 기대 (seed freeze 동안)   : 전수 FAIL — parse error 또는 0 리턴 (의도된 감시 실패).

// ── 1) Left shift (<<) ──────────────────────────────────────────

@test
fn test_shl_basic() {
    // 1 << 4 == 16
    assert((1 << 4) == 16)
    // 3 << 2 == 12 (0011 → 1100)
    assert((3 << 2) == 12)
}

@test
fn test_shl_zero_operand() {
    // 0 << N == 0
    assert((0 << 8) == 0)
    // a << 0 == a
    assert((7 << 0) == 7)
}

@test
fn test_shl_large() {
    // 1 << 10 == 1024
    assert((1 << 10) == 1024)
    // 1 << 16 == 65536
    assert((1 << 16) == 65536)
}

// ── 2) Right shift (>>) ─────────────────────────────────────────

@test
fn test_shr_basic() {
    // 16 >> 2 == 4
    assert((16 >> 2) == 4)
    // 1024 >> 10 == 1
    assert((1024 >> 10) == 1)
}

@test
fn test_shr_zero_and_truncation() {
    // 0 >> N == 0
    assert((0 >> 8) == 0)
    // a >> 0 == a
    assert((7 >> 0) == 7)
    // truncation: 13 >> 2 == 3 (1101 → 0011)
    assert((13 >> 2) == 3)
}

// ── 3) Bitwise OR (|) — surface-parser ambiguity with `|x|` closure ────

@test
fn test_bit_or_basic() {
    // 12 | 10 == 1110 == 14
    assert((12 | 10) == 14)
    // disjoint bits → add
    assert((0x0F | 0xF0) == 0xFF)
}

@test
fn test_bit_or_identity() {
    // a | 0 == a
    assert((0x42 | 0) == 0x42)
    // a | a == a
    assert((0xAA | 0xAA) == 0xAA)
}

@test
fn test_bit_or_full_mask() {
    // any | 0xFFFF == 0xFFFF (within 16-bit range)
    assert((0xABCD | 0xFFFF) == 0xFFFF)
    // commutativity
    assert((7 | 3) == (3 | 7))
}

// ── 4) Mixed / regression guards ────────────────────────────────

@test
fn test_mixed_shift_and_or() {
    // build 0xAB from nibbles via shift + or
    //   (0xA << 4) | 0xB == 0xAB == 171
    assert(((0xA << 4) | 0xB) == 0xAB)
    // (1 << 3) | (1 << 1) == 10
    assert(((1 << 3) | (1 << 1)) == 10)
}

@test
fn test_and_still_ok() {
    // regression guard: & and ^ must stay green alongside the new ops.
    assert((12 & 10) == 8)
    assert((12 ^ 10) == 6)
    // combined with the newly-added operators
    assert(((0xF0 >> 4) & 0x0F) == 0x0F)
    assert(((1 << 2) ^ (1 << 1)) == 6)
}
