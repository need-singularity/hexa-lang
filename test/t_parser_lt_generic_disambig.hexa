// G-AMBIG / parser regression — `Foo<Bar` ambiguity
//
// Before fix: `while L < n_layers { ... }` was misread as the start of a
//   generic struct literal `L<n_layers>` (because `L` is uppercase and
//   `<` followed an uppercase ident). The trailing `{` then triggered:
//
//     Parse error at L:C: expected Gt, got LBrace ('{')
//
//   C8 (commit c6a62ecb on worktree-agent-a6bb89d9e434dc1c2) had to
//   rename the loop variable to `layer_idx` / `n_layers_local` to work
//   around this. Reported in that worktree's report under
//   "hexa parser has a `Foo<Bar` ambiguity".
//
// After fix: parser does a forward token-scan from `<` to disambiguate.
//   It only commits to generic-args when the matching `>` is followed
//   by `{` (struct literal — the only consumer of expression-position
//   type-args) or `(` (turbofish-style call). Otherwise `<` is a
//   comparison operator. See p_lookahead_generic_args() in
//   self/parser.hexa and self/hexa_full.hexa, plus the C mirror
//   p_lookahead_generic_args_c() in self/native/hexa_cc.c.
//
// Expected output:
//   L=3
//   M=4
//   box=42

struct Box<T> { val: T }

fn main() {
    // Case 1: comparison with capital ident (the bug).
    let mut L = 0
    let n_layers = 3
    while L < n_layers {
        L = L + 1
    }
    println("L=" + to_string(L))

    // Case 2: chained comparisons + capital idents (regression coverage).
    let mut M = 0
    while M <= n_layers && M >= 0 {
        M = M + 1
        if M > 100 { break }
    }
    println("M=" + to_string(M))

    // Case 3: legitimate generic struct literal must still parse.
    let b = Box<Int> { val: 42 }
    println("box=" + to_string(b.val))
}
