// t49_runtime_string_pure.hexa — verifies self/runtime/string_pure.hexa
// behavior matches the C runtime equivalents (hexa_is_error, hexa_bin,
// hexa_hex, hexa_str_trim, hexa_str_to_upper, hexa_str_to_lower,
// utf8_cpcount, hexa_str_repeat). Library contents are inlined here
// because stage0's interpreter does not currently parse
// `import "path"` (observed 2026-04-16).
//
// Ties to docs/runtime_port_plan.md §P2.1: this is the starter-pack
// port. When the codegen interpose pass lands and the C versions can
// drop, the library will be imported directly and this test will shrink
// to an import + check block.

fn is_error_pure(v) {
    if type_of(v) != "string" { return false }
    if len(v) < 4 { return false }
    if char_at(v, 0) != "E" { return false }
    if char_at(v, 1) != "R" { return false }
    if char_at(v, 2) != "R" { return false }
    if char_at(v, 3) != ":" { return false }
    true
}

fn int_to_hex_pure(n) {
    if n == 0 { return "0" }
    if n < 0 { return hex(n) }
    let mut v = n
    let mut out = ""
    let digits = "0123456789abcdef"
    while v > 0 {
        let d = v % 16
        out = char_at(digits, d) + out
        v = v / 16
    }
    out
}

fn int_to_bin_pure(n) {
    if n == 0 { return "0" }
    if n < 0 { return bin(n) }
    let mut v = n
    let mut out = ""
    while v > 0 {
        let bit = v % 2
        if bit == 0 { out = "0" + out } else { out = "1" + out }
        v = v / 2
    }
    out
}

fn str_to_upper_ascii(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    let mut out = ""
    let mut i = 0
    let lowers = "abcdefghijklmnopqrstuvwxyz"
    let uppers = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    while i < n {
        let ch = char_at(s, i)
        let mut j = 0
        let mut found = false
        while j < 26 && found == false {
            if char_at(lowers, j) == ch {
                out = out + char_at(uppers, j)
                found = true
            }
            j = j + 1
        }
        if found == false { out = out + ch }
        i = i + 1
    }
    out
}

fn str_to_lower_ascii(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    let mut out = ""
    let mut i = 0
    let lowers = "abcdefghijklmnopqrstuvwxyz"
    let uppers = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    while i < n {
        let ch = char_at(s, i)
        let mut j = 0
        let mut found = false
        while j < 26 && found == false {
            if char_at(uppers, j) == ch {
                out = out + char_at(lowers, j)
                found = true
            }
            j = j + 1
        }
        if found == false { out = out + ch }
        i = i + 1
    }
    out
}

fn utf8_cpcount_pure(s) {
    if type_of(s) != "string" { return 0 }
    let mut count = 0
    let mut i = 0
    let n = len(s)
    while i < n {
        let ch = char_at(s, i)
        let cc = char_code(ch, 0)
        if cc < 128 || cc >= 192 { count = count + 1 }
        i = i + 1
    }
    count
}

fn str_repeat_pure(s, n) {
    if type_of(s) != "string" { return "" }
    if n <= 0 { return "" }
    let mut out = ""
    let mut i = 0
    while i < n {
        out = out + s
        i = i + 1
    }
    out
}

fn str_trim_pure(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    if n == 0 { return s }
    let mut start = 0
    let mut done_start = false
    while start < n && done_start == false {
        let ch = char_at(s, start)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            start = start + 1
        } else {
            done_start = true
        }
    }
    if done_start == false { return "" }
    let mut end = n - 1
    let mut done_end = false
    while end >= start && done_end == false {
        let ch = char_at(s, end)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            end = end - 1
        } else {
            done_end = true
        }
    }
    if end < start { return "" }
    s.substring(start, end + 1)
}

// Additional pure helpers (latest string_pure.hexa extension — 2026-04-16).
// Also inlined here to match the latest library snapshot.

fn str_index_of_pure(s, sub) {
    if type_of(s) != "string" { return -1 }
    if type_of(sub) != "string" { return -1 }
    let sn = len(s)
    let mn = len(sub)
    if mn == 0 { return 0 }
    if mn > sn { return -1 }
    let limit = sn - mn + 1
    let mut i = 0
    while i < limit {
        if s.substring(i, i + mn) == sub {
            return i
        }
        i = i + 1
    }
    -1
}

fn str_contains_pure(s, sub) {
    if type_of(s) != "string" { return false }
    if type_of(sub) != "string" { return false }
    str_index_of_pure(s, sub) >= 0
}

fn str_starts_with_pure(s, prefix) {
    if type_of(s) != "string" { return false }
    if type_of(prefix) != "string" { return false }
    let sn = len(s)
    let pn = len(prefix)
    if pn > sn { return false }
    s.substring(0, pn) == prefix
}

fn str_ends_with_pure(s, suffix) {
    if type_of(s) != "string" { return false }
    if type_of(suffix) != "string" { return false }
    let sn = len(s)
    let sfn = len(suffix)
    if sfn > sn { return false }
    s.substring(sn - sfn, sn) == suffix
}

fn str_trim_start_pure(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    if n == 0 { return s }
    let mut start = 0
    let mut done_s = false
    while start < n && done_s == false {
        let ch = char_at(s, start)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            start = start + 1
        } else {
            done_s = true
        }
    }
    if done_s == false { return "" }
    s.substring(start, n)
}

fn str_trim_end_pure(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    if n == 0 { return s }
    let mut end_pos = n - 1
    let mut done_e = false
    while end_pos >= 0 && done_e == false {
        let ch = char_at(s, end_pos)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            end_pos = end_pos - 1
        } else {
            done_e = true
        }
    }
    if end_pos < 0 { return "" }
    s.substring(0, end_pos + 1)
}

// ═══════════════════════════════════════════════════════════════════
// Test harness — pass/fail lines match the t44 / t45 / t47 style so the
// existing smoke pipeline (looks for "ALL PASS" / "FAIL") keeps working.
// P26 workaround: init `let mut` counters to non-zero, then reassign.
// ═══════════════════════════════════════════════════════════════════

let mut fail = 1
fail = 0
let mut pass = 1
pass = 0

fn check(name, got, want) {
    let g = to_string(got)
    let w = to_string(want)
    if g == w {
        println("PASS " + name)
        pass = pass + 1
    } else {
        println("FAIL " + name + " got=[" + g + "] want=[" + w + "]")
        fail = fail + 1
    }
}

check("is_error 'ERR:boom'", is_error_pure("ERR:boom"), true)
check("is_error 'ok'",        is_error_pure("ok"),        false)
check("is_error 'ERR'",       is_error_pure("ERR"),       false)
check("is_error ''",           is_error_pure(""),           false)

check("int_to_hex(0)",      int_to_hex_pure(0),      "0")
check("int_to_hex(255)",    int_to_hex_pure(255),    "ff")
check("int_to_hex(4096)",   int_to_hex_pure(4096),   "1000")
check("int_to_hex(16)",     int_to_hex_pure(16),     "10")

check("int_to_bin(0)",      int_to_bin_pure(0),      "0")
check("int_to_bin(5)",      int_to_bin_pure(5),      "101")
check("int_to_bin(1)",      int_to_bin_pure(1),      "1")
check("int_to_bin(255)",    int_to_bin_pure(255),    "11111111")

check("upper 'Hello'",      str_to_upper_ascii("Hello"),     "HELLO")
check("upper 'abc123'",     str_to_upper_ascii("abc123"),    "ABC123")
check("upper ''",            str_to_upper_ascii(""),           "")
check("upper 'Mixed'",      str_to_upper_ascii("Mixed"),     "MIXED")
check("lower 'HELLO'",      str_to_lower_ascii("HELLO"),     "hello")
check("lower 'ABC123'",     str_to_lower_ascii("ABC123"),    "abc123")
check("lower 'Mixed'",      str_to_lower_ascii("Mixed"),     "mixed")

check("cpcount 'hello'",    utf8_cpcount_pure("hello"),    5)
check("cpcount ''",          utf8_cpcount_pure(""),          0)
check("cpcount 'abc'",      utf8_cpcount_pure("abc"),      3)

check("repeat 'ab' 3",     str_repeat_pure("ab", 3),      "ababab")
check("repeat 'x' 0",       str_repeat_pure("x", 0),       "")
check("repeat 'x' -1",      str_repeat_pure("x", -1),      "")

check("trim '  hi  '",     str_trim_pure("  hi  "),      "hi")
check("trim 'hi'",           str_trim_pure("hi"),            "hi")
check("trim ''",              str_trim_pure(""),              "")
check("trim '   '",            str_trim_pure("   "),            "")
check("trim 'hi\\n'",         str_trim_pure("hi\n"),         "hi")
check("trim '\\thi\\n'",       str_trim_pure("\thi\n"),       "hi")

// ── str_index_of_pure ──────────────────────────
check("index_of 'hello' 'll'",     str_index_of_pure("hello", "ll"),     2)
check("index_of 'hello' 'xx'",     str_index_of_pure("hello", "xx"),     -1)
check("index_of 'hello' ''",        str_index_of_pure("hello", ""),        0)
check("index_of '' 'x'",             str_index_of_pure("", "x"),             -1)

// ── str_contains_pure ──────────────────────────
check("contains 'hello' 'ell'",   str_contains_pure("hello", "ell"),   true)
check("contains 'hello' 'zz'",    str_contains_pure("hello", "zz"),    false)
check("contains 'a' 'ab'",         str_contains_pure("a", "ab"),         false)

// ── str_starts_with_pure / str_ends_with_pure ──
check("starts 'hello' 'he'",     str_starts_with_pure("hello", "he"),   true)
check("starts 'hello' 'lo'",      str_starts_with_pure("hello", "lo"),    false)
check("starts 'hi' 'hello'",     str_starts_with_pure("hi", "hello"),  false)
check("ends 'hello' 'lo'",        str_ends_with_pure("hello", "lo"),      true)
check("ends 'hello' 'he'",        str_ends_with_pure("hello", "he"),      false)

// ── str_trim_start / str_trim_end ─────────────
check("trim_start '  hi  '",    str_trim_start_pure("  hi  "),     "hi  ")
check("trim_end '  hi  '",       str_trim_end_pure("  hi  "),        "  hi")
check("trim_start 'hi'",          str_trim_start_pure("hi"),            "hi")
check("trim_end 'hi'",             str_trim_end_pure("hi"),               "hi")

// Cross-check against C builtin — must agree bit-for-bit.
check("hex(255) agrees",     hex(255),    int_to_hex_pure(255))
check("bin(5) agrees",       bin(5),      int_to_bin_pure(5))
check("bin(255) agrees",     bin(255),    int_to_bin_pure(255))

println("")
println("summary: pass=" + to_string(pass) + " fail=" + to_string(fail))
if fail > 0 {
    println("SOME FAIL")
    exit(1)
}
println("ALL PASS")
