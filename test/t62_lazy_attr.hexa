// t62 — @lazy attr end-to-end
//
// Case 1  runtime  — @lazy cached_config called exactly once across 10
//                    invocations; body has a side-effect counter to prove it.
// Case 2  static   — @lazy + @ossify contradiction (must be flagged by
//                    self/attrs/lazy.hexa:check_lazy). Recorded as a
//                    comment-only scenario since this test file is run
//                    under the interpreter, not the attr-lint driver.
// Case 3  static   — @lazy fn with params — Phase-1 restriction flagged
//                    by check_lazy. Also comment-only here.
//
// Runtime verification uses a mut global counter; read it after the loop.

let mut _t62_calls = 0

@lazy fn cached_config() {
    _t62_calls = _t62_calls + 1
    return 42
}

fn main() {
    // Case 1: call 10 times, observe body ran exactly once.
    let mut i = 0
    let mut sum = 0
    while i < 10 {
        sum = sum + cached_config()
        i = i + 1
    }
    let ok_sum   = sum == 420
    let ok_calls = _t62_calls == 1

    if ok_sum && ok_calls {
        println("case1=PASS sum=" + to_string(sum) + " calls=" + to_string(_t62_calls))
    } else {
        println("case1=FAIL sum=" + to_string(sum) + " calls=" + to_string(_t62_calls))
    }

    // Case 2/3 scenarios — static-analysis contract captured as comments.
    // Running these would hard-fail before reaching this test block, so
    // they live in test/t62_lazy_attr_bad_*.hexa fixtures (parallel).
    //
    //   @lazy @ossify fn bad_sealed() { return 1 }
    //   @lazy fn bad_arg(x) { return x + 1 }

    if ok_sum && ok_calls {
        println("PASS t62_lazy_attr")
    } else {
        println("FAIL t62_lazy_attr")
    }
}

main()
