// #7 DoS-class fix: bounded macros (chain a -> b -> c -> const 42)
// must succeed without tripping the tau-bound.
//
// Depth reaches 3; default max=4, so no abort.
// Also covers the comptime parallel path.
// See t_macro_depth_default.hexa for the SEED-FREEZE inlining note.

let mut pass_count = 0
let mut fail_count = 0

fn check(name, ok) {
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// Inlined mirrors of macro_expand.hexa + comptime.hexa.
struct MCtx {
    depth: int,
    max_depth: int,
    stack: [string],
    error: string
}

fn mctx_new() -> MCtx {
    return MCtx { depth: 0, max_depth: 4, stack: [], error: "" }
}

fn check_bound(ctx: MCtx, fn_name: string, kind: string) -> string {
    ctx.depth = ctx.depth + 1
    ctx.stack = ctx.stack.push(fn_name)
    if ctx.depth > ctx.max_depth {
        let chain = ctx.stack.join(" -> ")
        let msg = "ERROR:" + kind + " " + fn_name +
            " exceeded tau-bound (depth=" + to_string(ctx.depth) +
            " > " + to_string(ctx.max_depth) +
            ") at chain: " + chain
        ctx.error = msg
        return msg
    }
    return "OK"
}

fn main() {
    // Macro 3-deep chain: a -> b -> c -> 42
    let ctx = mctx_new()
    let r1 = check_bound(ctx, "a", "macro")
    let r2 = check_bound(ctx, "b", "macro")
    let r3 = check_bound(ctx, "c", "macro")
    check("macro depth reached 3 (< tau=4)", ctx.depth == 3)
    check("macro no error set", ctx.error == "")
    check("macro chain recorded 3 entries", len(ctx.stack) == 3)
    check("macro r1 OK", r1 == "OK")
    check("macro r3 OK", r3 == "OK")

    // Fourth call still OK (exactly at boundary)
    let r4 = check_bound(ctx, "d", "macro")
    check("macro 4th call still OK (depth=4 == max=4)", ctx.error == "")
    check("macro r4 OK", r4 == "OK")

    // Fifth call trips
    let r5 = check_bound(ctx, "e", "macro")
    check("macro 5th call aborts", ctx.error != "")
    check("macro 5th call returned error string", r5.contains("tau-bound"))

    // Comptime mirror: chain of 3 succeeds.
    let cctx = mctx_new()
    check_bound(cctx, "const_a", "comptime")
    check_bound(cctx, "const_b", "comptime")
    check_bound(cctx, "const_c", "comptime")
    check("comptime depth reached 3", cctx.depth == 3)
    check("comptime no error", cctx.error == "")

    println("---")
    println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("RESULT: PASS")
    } else {
        println("RESULT: FAIL")
    }
}

main()
