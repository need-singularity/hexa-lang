// tests/t38_nanbox_smoke.hexa — NaN-boxing typedef flip smoke test
// Verifies all HexaVal types survive round-trip through NaN-boxed encoding.
// Run: build/hexa_stage0 tests/t38_nanbox_smoke.hexa

let mut pass = 0
let mut fail = 0

fn check(label, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("FAIL: " + label)
    }
}

// ── int round-trip ──
check("int 0", 0 == 0)
check("int 42", 42 == 42)
check("int -1", -1 == -1)
check("int large", 1000000000000 == 1000000000000)
check("int neg large", -1000000000000 == -1000000000000)
check("int add", 3 + 4 == 7)
check("int mul", 6 * 7 == 42)
check("int mod", 10 % 3 == 1)

// ── float round-trip ──
check("float 0.0", 0.0 == 0.0)
check("float 3.14", 3.14 > 3.13)
check("float neg", -2.5 < 0.0)
check("float add", 1.5 + 2.5 == 4.0)

// ── bool ──
check("bool true", true)
check("bool false", !false)
check("bool eq", true == true)

// ── string ──
check("str empty", "" == "")
check("str hello", "hello" == "hello")
check("str concat", "a" + "b" == "ab")
check("str len", len("abc") == 3)

// ── void ──
fn returns_void() {}
let v = returns_void()
check("void is void", type_of(v) == "void")

// ── array ──
let arr = [1, 2, 3]
check("arr len", len(arr) == 3)
check("arr get", arr[0] == 1)
check("arr get 2", arr[2] == 3)
let arr2 = arr.push(4)
check("arr push len", len(arr2) == 4)
check("arr push val", arr2[3] == 4)

// ── map ──
let mut m = #{}
m["key"] = "val"
check("map set/get", m["key"] == "val")
m["num"] = 42
check("map int val", m["num"] == 42)

// ── nested ──
let nested = [[1,2],[3,4]]
check("nested arr", nested[0][0] == 1)
check("nested arr 2", nested[1][1] == 4)

// ── try/catch (ARM64 cleanup fix) ──
fn try_return() {
    try {
        return 42
    } catch e {
        return -1
    }
}
check("try return", try_return() == 42)

fn try_throw() {
    try {
        throw "boom"
    } catch e {
        return e
    }
}
check("try throw catch", try_throw() == "boom")

// ── fn / closure ──
fn add(a, b) { return a + b }
check("fn call", add(3, 4) == 7)

let captured = 10
let clo = fn(x) { return x + captured }
check("closure", clo(5) == 15)

// ── summary ──
println("NaN-box smoke: " + to_string(pass) + " pass / " + to_string(fail) + " fail")
if fail > 0 {
    println("FAILED")
} else {
    println("ALL PASS")
}
