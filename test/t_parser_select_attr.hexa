// S-2c parse-only smoke: @select(...) meta-DSL on fn declarations.
//
// This test does not invoke codegen for @select (S-2d territory). It only
// verifies that the parser accepts the @select(family, cond -> algo, ...,
// else -> algo) attribute form without breaking the host fn's semantics.
//
// Before the parser patch (self/parser.hexa S-2c), the generic-attribute
// branch would swallow the tokens via paren-balanced skip — the fn still
// parses but no structured rule is captured. After the patch + interp
// rebuild, parse_stmt emits a "select|FAMILY@@COND~>ALGO@@..." annotation
// on FnDecl.annotations.
//
// The runtime assertions here only prove that @select does not corrupt the
// attached fn. A deeper AST-shape roundtrip would require invoking the
// in-language parser harness; that belongs to tests/test_parser_full.hexa
// or a dedicated self/test_parser_select.hexa once S-2d lands a consumer.

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
        fail_count = fail_count + 1
    }
}

// Canonical form: string family + 2 cond arms + else default.
@select("sort", n <= 16 -> insertion, n <= 10000 -> quick, else -> merge)
fn sort_dispatch(n) {
    // Body intentionally trivial — the point is that parsing @select does
    // not disturb the fn_decl parse path. Actual dispatch will be emitted
    // by codegen in S-2d.
    return n
}

// Two-arm form with only else default.
@select("search", sorted -> binary, else -> linear)
fn search_dispatch(sorted) {
    return sorted
}

// Three-arm form, inclusive range threshold, algo names with underscores.
@select("matmul", m * n <= 4096 -> naive_mm, m * n <= 262144 -> blocked_mm, else -> blis_mm)
fn matmul_dispatch(m, n) {
    return m + n
}

// Mixed with other @attrs — @select should coexist with @pure/@hot on the
// same fn decl (attrs are collected in the same pending accumulator loop).
@pure @select("reduce", n <= 64 -> seq_reduce, else -> parallel_reduce)
fn reduce_dispatch(n) {
    return n * 2
}

fn main() {
    check("sort_dispatch body runs",   sort_dispatch(5),        5)
    check("sort_dispatch large n",     sort_dispatch(100000),   100000)
    check("search_dispatch sorted",    search_dispatch(true),   true)
    check("search_dispatch unsorted",  search_dispatch(false),  false)
    check("matmul_dispatch small",     matmul_dispatch(32, 32), 64)
    check("matmul_dispatch large",     matmul_dispatch(1024, 1024), 2048)
    check("reduce_dispatch @pure+@select", reduce_dispatch(10), 20)

    println("---")
    println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("RESULT: PASS")
    } else {
        println("RESULT: FAIL")
    }
}

main()
