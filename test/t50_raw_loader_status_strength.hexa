// t50_raw_loader_status_strength.hexa — regression test for
// self/raw_loader.hexa::status_strength consolidation (2026-04-20).
//
// Canonical ladder (weakest → strongest):
//   new(0) < deferred(1) < convention(2) < warn(3) < live(4);  unknown → -1
//
// Matches tool/own_lint.hexa (landed 59fa41f8) + tool/own_inherit_lint.hexa
// — unchanged semantics, the helper just moved into raw_loader.
//
// Expected output:
//   status_strength regression: PASS
// Exit code: 0 on PASS, 1 on FAIL.

use "self/raw_loader"

fn main() {
    let mut fails = 0

    if status_strength("live") != 4 {
        println("FAIL live=" + to_string(status_strength("live")))
        fails = fails + 1
    }
    if status_strength("warn") != 3 {
        println("FAIL warn=" + to_string(status_strength("warn")))
        fails = fails + 1
    }
    if status_strength("convention") != 2 {
        println("FAIL convention=" + to_string(status_strength("convention")))
        fails = fails + 1
    }
    if status_strength("deferred") != 1 {
        println("FAIL deferred=" + to_string(status_strength("deferred")))
        fails = fails + 1
    }
    if status_strength("new") != 0 {
        println("FAIL new=" + to_string(status_strength("new")))
        fails = fails + 1
    }

    // Ordering invariants — warn > convention is the spec-vs-live
    // ambiguity point from the P0c handoff; assert it explicitly.
    if status_strength("warn") <= status_strength("convention") {
        println("FAIL warn is not strictly above convention")
        fails = fails + 1
    }

    // Unknown → -1 so callers can detect typos.
    if status_strength("planned") != -1 {
        println("FAIL planned should be -1, got " + to_string(status_strength("planned")))
        fails = fails + 1
    }
    if status_strength("") != -1 {
        println("FAIL empty should be -1, got " + to_string(status_strength("")))
        fails = fails + 1
    }

    if fails == 0 {
        println("status_strength regression: PASS")
        return
    }
    println("status_strength regression: FAIL (" + to_string(fails) + " case(s))")
    exit(1)
}

main()
