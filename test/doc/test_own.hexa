// tests/doc/test_own.hexa — @own 하네스 6 fixture 검증
//
// 기대값은 error_catalog 의 ref (HX_OWN_...) 기준.

use "self/attrs/own"

fn _read_lines(path: string) {
    let raw = to_string(read_file(path))
    return raw.split("\n")
}

fn _collect_refs(msgs) {
    let mut out = []
    for m in msgs { out.push(m.ref) }
    return out
}

fn _refs_contain(msgs, target: string) -> bool {
    for m in msgs {
        if m.ref == target { return true }
    }
    return false
}

fn run_case(name: string, path: string, expected) {
    let lines = _read_lines(path)
    let msgs = check_own(path, lines)
    let got_refs = _collect_refs(msgs)
    if len(expected) == 0 {
        if len(msgs) == 0 { println("  PASS  " + name + "  (clean)"); return 0 }
        println("  FAIL  " + name + "  expected clean, got: " + join(got_refs, ", "))
        return 1
    }
    let mut miss = []
    for e in expected {
        if !_refs_contain(msgs, e) { miss.push(e) }
    }
    if len(miss) == 0 {
        println("  PASS  " + name + "  (got: " + join(got_refs, ", ") + ")")
        return 0
    }
    println("  FAIL  " + name + "  miss=[" + join(miss, ", ") + "]  (got: " + join(got_refs, ", ") + ")")
    return 1
}

fn main() {
    let root = "/home/aiden/mac_home/dev/hexa-lang/examples/paper/"
    println("@own harness self-test (6 fixtures)")
    println("------------------------------------")
    let mut fails = 0
    fails = fails + run_case("own_minimal       ", root + "own_minimal.md", [])
    fails = fails + run_case("own_missing       ", root + "own_missing.md", ["HX_OWN_SECTIONS_PRESENT"])
    fails = fails + run_case("own_strict_extra  ", root + "own_strict_extra.md", ["HX_OWN_STRICT_CLOSED"])
    fails = fails + run_case("own_order         ", root + "own_order.md", ["HX_OWN_ORDER_SEQUENTIAL"])
    fails = fails + run_case("own_malformed     ", root + "own_malformed.md", ["HX_OWN_DECL_WELLFORMED"])
    fails = fails + run_case("own_selfhost      ", root + "own_selfhost.md", [])
    println("------------------------------------")
    if fails == 0 { println("ALL 6 GREEN") } else { println("FAILED: " + to_string(fails)) }
}

main()
