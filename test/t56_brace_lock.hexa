#!hexa strict
// t53 — L3 brace_lock detection
// First brace is same-line (K&R). Second fn uses next-line style.
// Linter should flag the second.

fn first_fn() {
    return 1
}

fn second_fn()
{                     // L3 violation: brace should match file's first style (same_line)
    return 2
}

fn main() {
    println(first_fn())
    println(second_fn())
}
