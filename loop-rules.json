{
  "_doc": "hexa-lang 드리프트 규칙 — loop-guard.hexa L5 에서 참조",
  "rules": [
    {
      "type": "inline_number",
      "doc": "README.md",
      "pattern": "\\d+ keywords",
      "actual_cmd": "python3 -c \"import json; lines=open('grammar.jsonl').readlines(); total=0\nfor l in lines:\n    d=json.loads(l)\n    if 'tokens' in d: total+=len(d['tokens'])\n    elif 'ops' in d: total+=len(d['ops'])\nprint(total)\" 2>/dev/null || echo 0",
      "label": "키워드 수"
    },
    {
      "type": "inline_number",
      "doc": "README.md",
      "pattern": "\\d+ operators",
      "actual_cmd": "python3 -c \"import json; lines=open('grammar.jsonl').readlines(); total=sum(len(json.loads(l).get('ops',[])) for l in lines if 'ops' in l); print(total)\" 2>/dev/null || echo 0",
      "label": "연산자 수"
    },
    {
      "type": "loc",
      "doc": "README.md",
      "file": "self/lexer.hexa",
      "pattern": "lexer\\.hexa.*?\\d[\\d,]* LOC",
      "tolerance": 20,
      "label": "lexer.hexa LOC"
    },
    {
      "type": "loc",
      "doc": "README.md",
      "file": "self/parser.hexa",
      "pattern": "parser\\.hexa.*?\\d[\\d,]* LOC",
      "tolerance": 50,
      "label": "parser.hexa LOC"
    },
    {
      "type": "loc",
      "doc": "README.md",
      "file": "self/type_checker.hexa",
      "pattern": "type_checker\\.hexa.*?\\d[\\d,]* LOC",
      "tolerance": 20,
      "label": "type_checker.hexa LOC"
    },
    {
      "type": "loc",
      "doc": "README.md",
      "file": "self/interpreter.hexa",
      "pattern": "interpreter\\.hexa.*?\\d[\\d,]* LOC",
      "tolerance": 50,
      "label": "interpreter.hexa LOC"
    },
    {
      "type": "inline_number",
      "doc": "README.md",
      "pattern": "\\d+ stdlib",
      "actual_cmd": "find self -name 'std_*.hexa' -type f | wc -l",
      "label": "stdlib 모듈 수"
    },
    {
      "type": "inline_number",
      "doc": "README.md",
      "pattern": "src/.*\\d+ files",
      "actual_cmd": "find src -name '*.rs' -type f 2>/dev/null | wc -l",
      "label": "src/ .rs 파일수"
    }
  ]
}
