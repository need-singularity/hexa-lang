#!hexa strict
// hexa-lang/grammar_format/core/grammar_format_main.hexa — aggregator + selftest
//
// @tool(slug="grammar_format_main", desc="Grammar version core+module aggregator entry-point")
// @sentinel(__GRAMMAR_FORMAT_MAIN__ <PASS|FAIL> mode=selftest)
// @usage(hexa run hexa-lang/grammar_format/core/grammar_format_main.hexa)
//
// raw#9 hexa-only strict. Aggregates selftest evidence from:
//   hexa-lang/grammar_format/core/source.hexa
//   hexa-lang/grammar_format/core/registry.hexa
//   hexa-lang/grammar_format/core/router.hexa
//   hexa-lang/grammar_format/module/{grammar_v1, grammar_v2, grammar_v3, grammar_v4, grammar_v5}.hexa
//
// Output is byte-identical across runs (no timestamps, deterministic dispatch).
//
// Run:
//   hexa run hexa-lang/grammar_format/core/grammar_format_main.hexa
// Expect:
//   [grammar_format_main] interface contracts:    5/5 OK
//   [grammar_format_main] grammar versions:       v1 WRAPPED, v2-v4 STUB-FROM-SPEC, v5 STUB-FUTURE
//   [grammar_format_main] shebang dispatch:       6/6 mappings OK
//   [grammar_format_main] router fallback:        v2->v1 OK
//   [grammar_format_main] aggregate:              ALL PASS

// ── struct mirror (SSOT: hexa-lang/grammar_format/core/source.hexa) ────

struct GrammarSchema {
    name:             str,
    version:          int,
    phase:            str,
    status:           str,
    shebang_trigger:  str,
    breaking_changes: int,
    spec_source:      str,
    description:      str
}

struct AST {
    ok:      int,
    repr:    str,
    version: int,
    message: str
}

fn grammar_schema_make(
    name: str, version: int, phase: str, status: str,
    shebang_trigger: str, breaking_changes: int,
    spec_source: str, description: str
) -> GrammarSchema {
    return GrammarSchema {
        name:             name,
        version:          version,
        phase:            phase,
        status:           status,
        shebang_trigger:  shebang_trigger,
        breaking_changes: breaking_changes,
        spec_source:      spec_source,
        description:      description
    }
}

fn grammar_ast_stub(version: int, message: str) -> AST {
    return AST { ok: 0, repr: "STUB", version: version, message: message }
}

fn grammar_ast_ok(repr: str, version: int, message: str) -> AST {
    return AST { ok: 1, repr: repr, version: version, message: message }
}

// ── meta dispatch (mirror registry) ────────────────────────

fn _schema_for(name: str) -> GrammarSchema {
    if name == "grammar_v1" {
        return grammar_schema_make("grammar_v1", 1, "alpha", "WRAPPED", "#!hexa", 0, "", "current free-form (mk1) — wraps self/lexer.hexa + self/parser.hexa")
    }
    if name == "grammar_v2" {
        return grammar_schema_make("grammar_v2", 2, "beta", "STUB-FROM-SPEC", "#!hexa strict", 0, "hexa-lang/docs/phase_beta_parser_ext_spec.ai.md", "Phase beta: L1 @attr first-class AST + L2 strict mode + L10 attr typing")
    }
    if name == "grammar_v3" {
        return grammar_schema_make("grammar_v3", 3, "gamma", "STUB-FROM-SPEC", "#!hexa v3", 1, "hexa-lang/docs/phase_gamma_strict_semantic_spec.ai.md", "Phase gamma: L4 pub/public required + L8 canonical visibility + L9 fail-loud Result")
    }
    if name == "grammar_v4" {
        return grammar_schema_make("grammar_v4", 4, "delta", "STUB-FROM-SPEC", "#!hexa v4", 1, "hexa-lang/docs/phase_delta_language_v2_spec.ai.md", "Phase delta: L5 declarative @module block + L6 typed use + L12 attr composition")
    }
    if name == "grammar_v5" {
        return grammar_schema_make("grammar_v5", 5, "future", "STUB-FUTURE", "#!hexa v5", 1, "", "future placeholder — phase epsilon TBD")
    }
    return grammar_schema_make(name, -1, "unknown", "UNKNOWN", "", 0, "", "")
}

// ── shebang detect (mirror router) ──────────────────────────

fn _detect_shebang(source: str) -> str {
    if len(source) < 2 { return "" }
    let c0 = source.chars()[0]
    let c1 = source.chars()[1]
    if c0 != '#' { return "" }
    if c1 != '!' { return "" }
    let lines = source.split("\n")
    if len(lines) < 1 { return "" }
    let line1 = lines[0].trim()
    if line1 == "#!hexa" { return "grammar_v1" }
    if line1 == "#!hexa strict" { return "grammar_v2" }
    if line1 == "#!hexa v2" { return "grammar_v2" }
    if line1 == "#!hexa v3" { return "grammar_v3" }
    if line1 == "#!hexa v4" { return "grammar_v4" }
    if line1 == "#!hexa v5" { return "grammar_v5" }
    if line1.contains("hexa") { return "grammar_v1" }
    return ""
}

// ── per-version parse stub dispatch (mirror router) ─────────

fn _route_parse(name: str, source: str) -> AST {
    if name == "grammar_v1" {
        let n = len(source)
        return grammar_ast_ok("WRAPPED-V1(len=" + str(n) + ")", 1, "v1: ok")
    }
    if name == "grammar_v2" { return grammar_ast_stub(2, "v2 STUB-FROM-SPEC") }
    if name == "grammar_v3" { return grammar_ast_stub(3, "v3 STUB-FROM-SPEC") }
    if name == "grammar_v4" { return grammar_ast_stub(4, "v4 STUB-FROM-SPEC") }
    if name == "grammar_v5" { return grammar_ast_stub(5, "v5 STUB-FUTURE") }
    return grammar_ast_stub(-1, "unknown: " + name)
}

// ── Aggregated selftest ────────────────────────────────────

fn grammar_main_aggregate() -> int {
    let mut all_ok = 1

    // 1. Interface contracts: 5/5 versions have well-formed schema
    let names = ["grammar_v1", "grammar_v2", "grammar_v3", "grammar_v4", "grammar_v5"]
    let mut iface_ok = 0
    let mut i = 0
    while i < len(names) {
        let s = _schema_for(names[i])
        if s.name == names[i] {
            if s.version >= 1 {
                if len(s.status) > 0 {
                    if len(s.phase) > 0 {
                        iface_ok = iface_ok + 1
                    }
                }
            }
        }
        i = i + 1
    }
    let total = len(names)
    println("[grammar_format_main] interface contracts:    " + str(iface_ok) + "/" + str(total) + " OK")
    if iface_ok != total { all_ok = 0 }

    // 2. Grammar version status banner
    let v1 = _schema_for("grammar_v1")
    let v2 = _schema_for("grammar_v2")
    let v3 = _schema_for("grammar_v3")
    let v4 = _schema_for("grammar_v4")
    let v5 = _schema_for("grammar_v5")
    let banner = "v1 " + v1.status + ", v2 " + v2.status + ", v3 " + v3.status + ", v4 " + v4.status + ", v5 " + v5.status
    println("[grammar_format_main] grammar versions:       " + banner)

    // 3. Shebang dispatch: 6/6 mappings OK
    let mut sb_ok = 0
    if _detect_shebang("#!hexa\nx") == "grammar_v1" { sb_ok = sb_ok + 1 }
    if _detect_shebang("#!hexa strict\nx") == "grammar_v2" { sb_ok = sb_ok + 1 }
    if _detect_shebang("#!hexa v2\nx") == "grammar_v2" { sb_ok = sb_ok + 1 }
    if _detect_shebang("#!hexa v3\nx") == "grammar_v3" { sb_ok = sb_ok + 1 }
    if _detect_shebang("#!hexa v4\nx") == "grammar_v4" { sb_ok = sb_ok + 1 }
    if _detect_shebang("fn main() {}") == "" { sb_ok = sb_ok + 1 }
    println("[grammar_format_main] shebang dispatch:       " + str(sb_ok) + "/6 mappings OK")
    if sb_ok != 6 { all_ok = 0 }

    // 4. Router fallback: v2 STUB → v1 succeeds
    let r2 = _route_parse("grammar_v2", "fn main() {}")
    let r1 = _route_parse("grammar_v1", "fn main() {}")
    let mut fb_ok = 0
    if r2.ok == 0 { if r1.ok == 1 { fb_ok = 1 } }
    if fb_ok == 1 {
        println("[grammar_format_main] router fallback:        v2->v1 OK")
    } else {
        println("[grammar_format_main] router fallback:        FAIL")
        all_ok = 0
    }

    // 5. Phase coverage: alpha,beta,gamma,delta,future all represented
    let mut phase_count = 0
    let mut t = 0
    let phases = ["alpha", "beta", "gamma", "delta", "future"]
    while t < len(phases) {
        let mut found = 0
        let mut q = 0
        while q < len(names) {
            let s = _schema_for(names[q])
            if s.phase == phases[t] { found = 1 }
            q = q + 1
        }
        phase_count = phase_count + found
        t = t + 1
    }
    println("[grammar_format_main] phase coverage:         " + str(phase_count) + "/5 phases (alpha..future)")
    if phase_count != 5 { all_ok = 0 }

    // 6. Spec cross-link integrity (v2/v3/v4 must point to phase_*.ai.md)
    let mut spec_ok = 0
    if v2.spec_source.contains("phase_beta") { spec_ok = spec_ok + 1 }
    if v3.spec_source.contains("phase_gamma") { spec_ok = spec_ok + 1 }
    if v4.spec_source.contains("phase_delta") { spec_ok = spec_ok + 1 }
    println("[grammar_format_main] spec cross-link:        " + str(spec_ok) + "/3 OK")
    if spec_ok != 3 { all_ok = 0 }

    return all_ok
}

fn main() {
    println("[grammar_format_main] hexa-lang grammar abstraction — selftest aggregator")
    let ok = grammar_main_aggregate()
    if ok == 1 {
        println("[grammar_format_main] aggregate:              ALL PASS")
        println("[grammar_format_main] __GRAMMAR_FORMAT_MAIN__ PASS")
    } else {
        println("[grammar_format_main] aggregate:              SOME FAIL")
        println("[grammar_format_main] __GRAMMAR_FORMAT_MAIN__ FAIL")
    }
}
