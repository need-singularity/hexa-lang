// build_script.hexa — ported from build.sh

let path = env("HOME") + "/.cargo/bin:/opt/homebrew/bin:" + env("PATH")
shell("export PATH=" + path)

let mode = args(1) ?? "debug"

if mode == "test" {
    shell("cargo test")
} else if mode == "release" {
    shell("cargo build --release")
    shell("cp target/release/hexa .")
} else if mode == "bench" {
    shell("cargo build --release")
    shell("cp target/release/hexa .")
    shell("bash scripts/bench_hexa_ir.sh")
} else {
    shell("cargo build")
    shell("cp target/debug/hexa .")
}
