#!hexa strict
// hexa-lang/core/grammar_format/router.hexa — shebang-driven grammar version selection + fallback
//
// @tool(slug="grammar_format_router", desc="Shebang dispatch v4->v3->v2->v1 fallback chain")
// @sentinel(__GRAMMAR_FORMAT_ROUTER__ <PASS|FAIL> mode=selftest)
// @usage(hexa run hexa-lang/core/grammar_format/router.hexa)
//
// Reads the source file's shebang line (line 1) to dispatch the appropriate
// grammar version. Falls back through v4 -> v3 -> v2 -> v1 chain when a
// requested version is STUB or unimplemented.
//
// Shebang triggers:
//   #!hexa            → grammar_v1 (mk1, current free-form)
//   #!hexa strict     → grammar_v2 (Phase beta)
//   #!hexa v2         → grammar_v2 (alias)
//   #!hexa v3         → grammar_v3 (Phase gamma)
//   #!hexa v4         → grammar_v4 (Phase delta)
//   #!hexa v5         → grammar_v5 (future)
//   (no shebang)      → grammar_v1 (default)
//
// Env override:
//   HEXA_GRAMMAR_VERSION       — single version forced (no fallback)
//   HEXA_GRAMMAR_FALLBACK_CHAIN — comma-separated fallback chain
//
// raw#9 hexa-only strict. raw#10:
//   (1) Router uses the registry's switch dispatch. Adding a new grammar
//       version = update registry + add to default chain in
//       hexa-lang/config/grammar_format_sources.json.
//   (2) v2-v4 grammar versions are STUB-FROM-SPEC. Router will return STUB
//       AST for those and route falls back to v1 wherever the chain permits.
//   (3) Selftest emulates fallback cascade via STUB/STUB-FUTURE-only chain.

// ── struct mirror (SSOT: hexa-lang/core/grammar_format/source.hexa) ────

struct GrammarSchema {
    name:             str,
    version:          int,
    phase:            str,
    status:           str,
    shebang_trigger:  str,
    breaking_changes: int,
    spec_source:      str,
    description:      str
}

struct AST {
    ok:      int,
    repr:    str,
    version: int,
    message: str
}

fn grammar_schema_make(
    name: str, version: int, phase: str, status: str,
    shebang_trigger: str, breaking_changes: int,
    spec_source: str, description: str
) -> GrammarSchema {
    return GrammarSchema {
        name:             name,
        version:          version,
        phase:            phase,
        status:           status,
        shebang_trigger:  shebang_trigger,
        breaking_changes: breaking_changes,
        spec_source:      spec_source,
        description:      description
    }
}

fn grammar_ast_stub(version: int, message: str) -> AST {
    return AST { ok: 0, repr: "STUB", version: version, message: message }
}

fn grammar_ast_ok(repr: str, version: int, message: str) -> AST {
    return AST { ok: 1, repr: repr, version: version, message: message }
}

// ── per-version parse dispatch (inline registry mirrors) ────

fn _route_parse(name: str, source: str) -> AST {
    if name == "grammar_v1" {
        // v1 = WRAPPED. We wrap the canonical lexer/parser by emitting a
        // minimal sentinel "WRAPPED-V1" repr. The real parser is invoked by
        // the canonical hexa CLI; this router is for grammar metadata
        // dispatch + future v2-v4 routing, not a parser replacement.
        let n = len(source)
        return grammar_ast_ok("WRAPPED-V1(len=" + str(n) + ")", 1, "v1: ok (canonical lexer/parser, not invoked here)")
    }
    if name == "grammar_v2" {
        return grammar_ast_stub(2, "grammar_v2 (Phase beta) STUB-FROM-SPEC — see hexa-lang/docs/phase_beta_parser_ext_spec.ai.md")
    }
    if name == "grammar_v3" {
        return grammar_ast_stub(3, "grammar_v3 (Phase gamma) STUB-FROM-SPEC — see hexa-lang/docs/phase_gamma_strict_semantic_spec.ai.md")
    }
    if name == "grammar_v4" {
        return grammar_ast_stub(4, "grammar_v4 (Phase delta) STUB-FROM-SPEC — see hexa-lang/docs/phase_delta_language_v2_spec.ai.md")
    }
    if name == "grammar_v5" {
        return grammar_ast_stub(5, "grammar_v5 STUB-FUTURE — phase epsilon TBD")
    }
    return grammar_ast_stub(-1, "unknown grammar version: " + name)
}

// ── Default chain (overridable by env / config file) ────────

fn grammar_default_chain() -> [str] {
    let mut a = []
    a = a.push("grammar_v1")
    return a
}

// ── Resolve chain from env or default ───────────────────────

fn grammar_resolve_chain() -> [str] {
    // HEXA_GRAMMAR_VERSION wins → single-element chain (no fallback)
    let single = exec("printenv HEXA_GRAMMAR_VERSION 2>/dev/null || true").trim()
    if len(single) > 0 {
        let mut a = []
        a = a.push(single)
        return a
    }
    // HEXA_GRAMMAR_FALLBACK_CHAIN comma-list
    let chain = exec("printenv HEXA_GRAMMAR_FALLBACK_CHAIN 2>/dev/null || true").trim()
    if len(chain) > 0 {
        let parts = chain.split(",")
        let mut a = []
        let mut i = 0
        while i < len(parts) {
            let p = parts[i].trim()
            if len(p) > 0 { a = a.push(p) }
            i = i + 1
        }
        if len(a) > 0 { return a }
    }
    return grammar_default_chain()
}

// ── Detect shebang grammar version from source ──────────────
//
// Reads source line 1, returns mapped grammar version name or "" if no
// hexa-specific shebang present.

fn grammar_detect_shebang(source: str) -> str {
    if len(source) < 2 { return "" }
    let c0 = source.chars()[0]
    let c1 = source.chars()[1]
    if c0 != '#' { return "" }
    if c1 != '!' { return "" }
    // Extract line 1
    let lines = source.split("\n")
    if len(lines) < 1 { return "" }
    let line1 = lines[0].trim()
    // Map shebang → grammar version
    if line1 == "#!hexa" { return "grammar_v1" }
    if line1 == "#!hexa strict" { return "grammar_v2" }
    if line1 == "#!hexa v2" { return "grammar_v2" }
    if line1 == "#!hexa v3" { return "grammar_v3" }
    if line1 == "#!hexa v4" { return "grammar_v4" }
    if line1 == "#!hexa v5" { return "grammar_v5" }
    // POSIX shebang (#!/usr/bin/env hexa) → v1 default
    if line1.contains("hexa") { return "grammar_v1" }
    return ""
}

// ── Public parse: shebang detect → chain fallback ───────────

struct GrammarRouteResult {
    final_version:    str,    // name of grammar version that succeeded; "" if all failed
    detected_shebang: str,    // shebang-detected version (or "" if none)
    attempts:         [str],  // ordered list of version names tried
    reasons:          [str],  // parallel array: failure reason per attempt
    result:           AST
}

fn grammar_route_parse(source: str) -> GrammarRouteResult {
    let shebang = grammar_detect_shebang(source)
    let mut chain = []
    if len(shebang) > 0 {
        // Shebang detected: try that version first, then fall back through chain
        chain = chain.push(shebang)
        let env_chain = grammar_resolve_chain()
        let mut k = 0
        while k < len(env_chain) {
            if env_chain[k] != shebang { chain = chain.push(env_chain[k]) }
            k = k + 1
        }
    } else {
        // No shebang: use env-resolved chain (default = v1)
        chain = grammar_resolve_chain()
    }
    let mut attempts = []
    let mut reasons = []
    let mut i = 0
    while i < len(chain) {
        let name = chain[i]
        attempts = attempts.push(name)
        let r = _route_parse(name, source)
        if r.ok == 1 {
            reasons = reasons.push("ok")
            return GrammarRouteResult {
                final_version:    name,
                detected_shebang: shebang,
                attempts:         attempts,
                reasons:          reasons,
                result:           r
            }
        }
        reasons = reasons.push(r.message)
        i = i + 1
    }
    // All failed
    return GrammarRouteResult {
        final_version:    "",
        detected_shebang: shebang,
        attempts:         attempts,
        reasons:          reasons,
        result:           grammar_ast_stub(-1, "router: all grammar versions in chain failed (or all are STUB)")
    }
}

// ── Selftest ────────────────────────────────────────────────

fn _selftest_router() -> int {
    // 1. Default chain has 1 entry (v1)
    let dc = grammar_default_chain()
    if len(dc) != 1 { return 0 }
    if dc[0] != "grammar_v1" { return 0 }
    // 2. Resolve chain returns default when no env (best-effort assumption)
    let rc = grammar_resolve_chain()
    if len(rc) < 1 { return 0 }
    // 3. _route_parse direct: v1 always succeeds (wraps canonical)
    let r1 = _route_parse("grammar_v1", "fn main() {}")
    if r1.ok != 1 { return 0 }
    if r1.version != 1 { return 0 }
    // 4. _route_parse: v2 stub fails
    let r2 = _route_parse("grammar_v2", "fn main() {}")
    if r2.ok != 0 { return 0 }
    if r2.version != 2 { return 0 }
    // 5. _route_parse: v3 stub fails
    let r3 = _route_parse("grammar_v3", "fn main() {}")
    if r3.ok != 0 { return 0 }
    // 6. _route_parse: v4 stub fails
    let r4 = _route_parse("grammar_v4", "fn main() {}")
    if r4.ok != 0 { return 0 }
    // 7. _route_parse: v5 stub fails
    let r5 = _route_parse("grammar_v5", "fn main() {}")
    if r5.ok != 0 { return 0 }
    // 8. _route_parse: unknown fails
    let rx = _route_parse("not_a_version", "fn main() {}")
    if rx.ok != 0 { return 0 }
    // 9. Shebang detect: no shebang → ""
    let sh0 = grammar_detect_shebang("fn main() {}")
    if sh0 != "" { return 0 }
    // 10. Shebang detect: #!hexa → grammar_v1
    let sh1 = grammar_detect_shebang("#!hexa\nfn main() {}")
    if sh1 != "grammar_v1" { return 0 }
    // 11. Shebang detect: #!hexa strict → grammar_v2
    let sh2 = grammar_detect_shebang("#!hexa strict\nfn main() {}")
    if sh2 != "grammar_v2" { return 0 }
    // 12. Shebang detect: #!hexa v3 → grammar_v3
    let sh3 = grammar_detect_shebang("#!hexa v3\nfn main() {}")
    if sh3 != "grammar_v3" { return 0 }
    // 13. Shebang detect: #!hexa v4 → grammar_v4
    let sh4 = grammar_detect_shebang("#!hexa v4\nfn main() {}")
    if sh4 != "grammar_v4" { return 0 }
    // 14. Route: no shebang → v1 wins
    let rt0 = grammar_route_parse("fn main() {}")
    if rt0.final_version != "grammar_v1" { return 0 }
    if rt0.result.ok != 1 { return 0 }
    // 15. Route: #!hexa strict → v2 attempted, falls back to v1
    let rt2 = grammar_route_parse("#!hexa strict\nfn main() {}")
    if rt2.detected_shebang != "grammar_v2" { return 0 }
    if rt2.final_version != "grammar_v1" { return 0 }
    if len(rt2.attempts) < 2 { return 0 }
    if rt2.attempts[0] != "grammar_v2" { return 0 }
    return 1
}

fn main() {
    println("[grammar_format/router] shebang-driven grammar version selection + fallback chain")
    if _selftest_router() == 1 {
        println("[grammar_format/router] SELFTEST PASS")
        println("[grammar_format/router] __GRAMMAR_FORMAT_ROUTER__ PASS")
    } else {
        println("[grammar_format/router] SELFTEST FAIL")
        println("[grammar_format/router] __GRAMMAR_FORMAT_ROUTER__ FAIL")
    }
    // Demo: end-to-end route_parse (default chain, no shebang)
    let route = grammar_route_parse("fn main() { println(\"hi\") }")
    println("[grammar_format/router] route_parse demo:")
    println("[grammar_format/router]   detected_shebang=" + route.detected_shebang)
    println("[grammar_format/router]   attempts=" + str(len(route.attempts)) + " final_version=" + route.final_version)
    let mut i = 0
    while i < len(route.attempts) {
        println("[grammar_format/router]   try[" + str(i) + "] " + route.attempts[i] + " -> " + route.reasons[i])
        i = i + 1
    }
    println("[grammar_format/router]   ok=" + str(route.result.ok) + " version=" + str(route.result.version))
}
