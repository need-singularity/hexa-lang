#!hexa strict
// @tool(slug="attr_format_router", desc="hexa-lang attr-format config-driven version selection + composition lower chain (v4 → v3 → v2 → v1)")
// @sentinel(__ATTR_FORMAT_ROUTER__ <PASS|FAIL> mode=<selftest>)
// @usage(hexa hexa-lang/core/attr_format/router.hexa)
// @resolver-bypass(reason="local router selftest, no network/heavy compute")
//
// hexa-lang/core/attr_format/router.hexa — config-driven version + lower chain
//
// Reads hexa-lang/config/attr_format_sources.json (priority list) OR env overrides:
//   HEXA_ATTR_FORMAT          — single version forced (no fallback)
//   HEXA_ATTR_FORMAT_CHAIN    — comma-separated lower chain (e.g. v4,v3,v2,v1)
//
// Default priority: v1 only (current land state).
//   When a parse-source uses v4 composition, router auto-engages
//   v4 → v3 → v2 → v1 lowering chain. Until Phase β/δ impl lands, v2/v3/v4
//   parse return SPEC-PENDING and the chain falls through to v1.
//
// raw#9 hexa-only strict. raw#10:
//   (1) Lower chain logic is spec-only for v2/v3/v4. v1 default fully
//       functional via comment-form grep.
//   (2) Composition expand (v4 → v3) algorithm pinned by Phase δ §4.3
//       but not implemented — router returns SPEC-PENDING + falls through.
//   (3) Selftest emulates chain by forcing v4-first chain and asserting
//       SPEC-PENDING then v1 success.

// ── struct mirror ──────────────────────────────────────────────

struct AttrFormatMeta {
    name:                 str,
    version:              int,
    form:                 str,
    phase:                str,
    status:               str,
    supports_composition: int,
    supports_typing:      int,
    catalog_size:         int,
    spec_doc:             str,
    notes:                str
}

struct AttrDecl {
    name:         str,
    params:       [str],
    line:         int,
    col:          int,
    mode:         str,
    form_version: str
}

struct AttrParseResult {
    ok:       int,
    n_decls:  int,
    decls:    [AttrDecl],
    message:  str
}

fn attr_decl_make(name: str, params: [str], line: int, col: int, mode: str, form_version: str) -> AttrDecl {
    return AttrDecl { name: name, params: params, line: line, col: col, mode: mode, form_version: form_version }
}

fn attr_parse_fail(reason: str) -> AttrParseResult {
    return AttrParseResult { ok: 0, n_decls: 0, decls: [], message: reason }
}

fn attr_parse_ok(decls: [AttrDecl], message: str) -> AttrParseResult {
    return AttrParseResult { ok: 1, n_decls: len(decls), decls: decls, message: message }
}

// ── v1 extraction (mirror of registry, kept byte-identical) ────

fn _route_v1_extract_attr_name(line: str) -> str {
    let mut s = line.trim()
    if s.starts_with("//") {
        s = s.substring(2, len(s)).trim()
    }
    if s.starts_with("@") == false { return "" }
    s = s.substring(1, len(s))
    let mut name = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        let is_alpha = (c == "a") || (c == "b") || (c == "c") || (c == "d") || (c == "e") || (c == "f") || (c == "g") || (c == "h") || (c == "i") || (c == "j") || (c == "k") || (c == "l") || (c == "m") || (c == "n") || (c == "o") || (c == "p") || (c == "q") || (c == "r") || (c == "s") || (c == "t") || (c == "u") || (c == "v") || (c == "w") || (c == "x") || (c == "y") || (c == "z")
        let is_under = c == "_"
        if is_alpha == false {
            if is_under == false { return name }
        }
        name = name + c
        i = i + 1
    }
    return name
}

fn _route_parse_v1(src: str) -> AttrParseResult {
    if len(src) < 1 {
        return attr_parse_fail("empty source")
    }
    let lines = src.split("\n")
    let mut decls = []
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        let trimmed = line.trim()
        let is_comment_attr = trimmed.starts_with("//")
        let is_bare_attr = trimmed.starts_with("@")
        if is_comment_attr {
            let name = _route_v1_extract_attr_name(trimmed)
            if len(name) > 0 {
                let mode_v = if i < 8 { "file" } else { "decl" }
                let d = attr_decl_make(name, [], i + 1, 1, mode_v, "v1")
                decls = decls.push(d)
            }
        }
        if is_bare_attr {
            let name = _route_v1_extract_attr_name(trimmed)
            if len(name) > 0 {
                let mode_v = if i < 8 { "file" } else { "decl" }
                let d = attr_decl_make(name, [], i + 1, 1, mode_v, "v1")
                decls = decls.push(d)
            }
        }
        i = i + 1
    }
    return attr_parse_ok(decls, "v1: extracted " + str(len(decls)) + " attr decl(s) from " + str(len(lines)) + " line(s)")
}

// ── per-version parse dispatch (inline mirror of modules) ──────

fn _route_parse(name: str, src: str) -> AttrParseResult {
    if name == "v1" {
        return _route_parse_v1(src)
    }
    if name == "v2" {
        return attr_parse_fail("v2: SPEC-STUB — Phase β L1 parser ext not implemented")
    }
    if name == "v3" {
        return attr_parse_fail("v3: SPEC-STUB — Phase β L10 attr param typing not implemented")
    }
    if name == "v4" {
        return attr_parse_fail("v4: SPEC-STUB — Phase δ L12 composition expander not implemented")
    }
    if name == "v5" {
        return attr_parse_fail("v5: FUTURE-STUB — reserved")
    }
    return attr_parse_fail("unknown attr-format version: " + name)
}

// ── Default chain (overridable by env / config file) ───────────

fn attr_format_default_chain() -> [str] {
    let mut a = []
    a = a.push("v1")
    return a
}

// ── Resolve chain from env or default ──────────────────────────

fn attr_format_resolve_chain() -> [str] {
    let single = exec("printenv HEXA_ATTR_FORMAT 2>/dev/null || true").trim()
    if len(single) > 0 {
        let mut a = []
        a = a.push(single)
        return a
    }
    let chain = exec("printenv HEXA_ATTR_FORMAT_CHAIN 2>/dev/null || true").trim()
    if len(chain) > 0 {
        let parts = chain.split(",")
        let mut a = []
        let mut i = 0
        while i < len(parts) {
            let p = parts[i].trim()
            if len(p) > 0 { a = a.push(p) }
            i = i + 1
        }
        if len(a) > 0 { return a }
    }
    return attr_format_default_chain()
}

// ── Public route_parse: try chain in order ─────────────────────

struct AttrRouteResult {
    final_version: str,    // version that succeeded; "" if all failed
    attempts:      [str],  // ordered list of versions tried
    reasons:       [str],  // parallel array: failure reason per attempt
    result:        AttrParseResult
}

fn attr_format_route_parse(src: str) -> AttrRouteResult {
    let chain = attr_format_resolve_chain()
    let mut attempts = []
    let mut reasons = []
    let mut i = 0
    while i < len(chain) {
        let name = chain[i]
        attempts = attempts.push(name)
        let r = _route_parse(name, src)
        if r.ok == 1 {
            reasons = reasons.push("ok")
            return AttrRouteResult {
                final_version: name,
                attempts: attempts,
                reasons: reasons,
                result: r
            }
        }
        reasons = reasons.push(r.message)
        i = i + 1
    }
    return AttrRouteResult {
        final_version: "",
        attempts: attempts,
        reasons: reasons,
        result: attr_parse_fail("router: all versions in chain failed")
    }
}

// ── Lower chain (v4 → v3 → v2 → v1) — composition expander spec ─
//
// Phase δ §4.3 algorithm:
//   @module { tool: T, sentinel: S, usage: U, resolver-bypass: R }
//   → 4 individual attr nodes
//
// SPEC-STUB — algorithm pinned, impl deferred. Returns SPEC-PENDING.

fn attr_format_lower_to_v1(decls: [AttrDecl]) -> AttrParseResult {
    // For decls already at v1, pass through. For higher versions,
    // would expand here. SPEC-STUB returns input unchanged with note.
    let mut all_v1 = 1
    let mut i = 0
    while i < len(decls) {
        if decls[i].form_version != "v1" { all_v1 = 0 }
        i = i + 1
    }
    if all_v1 == 1 {
        return attr_parse_ok(decls, "lower_to_v1: all decls already v1, pass-through")
    }
    return attr_parse_fail("lower_to_v1: SPEC-STUB — v2/v3/v4 → v1 lowering not implemented (Phase δ §4.3)")
}

// ── Selftest ───────────────────────────────────────────────────

fn _selftest_router() -> int {
    // 1. Default chain has 1 entry: v1
    let dc = attr_format_default_chain()
    if len(dc) != 1 { return 0 }
    if dc[0] != "v1" { return 0 }
    // 2. Resolve chain returns default when no env (assume clean run)
    let rc = attr_format_resolve_chain()
    if len(rc) < 1 { return 0 }
    // 3. _route_parse direct: v1 always works on non-empty
    let synth = "// @tool(slug=\"x\", desc=\"y\")\nfn main() { return 0 }\n"
    let r1 = _route_parse("v1", synth)
    if r1.ok != 1 { return 0 }
    if r1.n_decls != 1 { return 0 }
    // 4. _route_parse: v2/v3/v4/v5 spec-stub fails
    let r2 = _route_parse("v2", synth)
    if r2.ok != 0 { return 0 }
    let r3 = _route_parse("v3", synth)
    if r3.ok != 0 { return 0 }
    let r4 = _route_parse("v4", synth)
    if r4.ok != 0 { return 0 }
    let r5 = _route_parse("v5", synth)
    if r5.ok != 0 { return 0 }
    // 5. _route_parse: unknown fails
    let rx = _route_parse("v9", synth)
    if rx.ok != 0 { return 0 }
    // 6. attr_format_route_parse with default chain → v1 succeeds
    let route = attr_format_route_parse(synth)
    if route.result.ok != 1 { return 0 }
    if route.final_version != "v1" { return 0 }
    // 7. lower_to_v1: pass-through for v1 decls
    let d_v1 = attr_decl_make("tool", [], 1, 1, "file", "v1")
    let lr1 = attr_format_lower_to_v1([d_v1])
    if lr1.ok != 1 { return 0 }
    // 8. lower_to_v1: SPEC-STUB fails for non-v1 decls
    let d_v4 = attr_decl_make("module", [], 1, 1, "file", "v4")
    let lr4 = attr_format_lower_to_v1([d_v4])
    if lr4.ok != 0 { return 0 }
    return 1
}

fn main() {
    println("[attr_format/router] config-driven version + lower chain")
    if _selftest_router() == 1 {
        println("[attr_format/router] SELFTEST PASS")
        println("__ATTR_FORMAT_ROUTER__ PASS mode=selftest")
    } else {
        println("[attr_format/router] SELFTEST FAIL")
        println("__ATTR_FORMAT_ROUTER__ FAIL mode=selftest")
    }
}
