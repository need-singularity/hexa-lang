#!hexa strict
// @tool(slug="attr_format_registry", desc="hexa-lang attr-format version registry — name → module dispatch (5 versions: v1 v2 v3 v4 v5)")
// @sentinel(__ATTR_FORMAT_REGISTRY__ <PASS|FAIL> mode=<selftest>)
// @usage(hexa hexa-lang/core/attr_format/registry.hexa)
// @resolver-bypass(reason="local registry dispatch selftest, no network/heavy compute")
//
// hexa-lang/core/attr_format/registry.hexa — version → module dispatch
//
// raw#9 hexa-only strict. Stage0 has no first-class fn pointers / dyn-call,
// so the registry uses a switch-style dispatch over canonical version names.
// Each branch inlines the meta from the sibling module + invokes a local
// shim for parse/validate/expand (kept byte-identical with module SSOT).
//
// REGISTERED VERSIONS (5):
//   v1   — comment-form `// @tool(...)`         (WRAPPED,    Phase current)
//   v2   — AST `@tool(...)`                     (SPEC-STUB,  Phase β L1)
//   v3   — typed params `@tool(slug:str req)`   (SPEC-STUB,  Phase β L10)
//   v4   — composition `@module {...}`          (SPEC-STUB,  Phase δ L12)
//   v5   — future placeholder                   (FUTURE-STUB)
//
// raw#10:
//   (1) Inlined dispatch is verbose but matches hexa stage0 capabilities.
//       When trait/dyn-call lands, this collapses to HashMap<&str, &dyn>.
//   (2) v1 catalog list is duplicated here (24 attrs) and in modules/attr_format/attr_v1.hexa.
//       SSOT is hexa-lang/self/attrs/attrs.json. Drift = lint failure.

// ── struct mirrors (SSOT: core/attr_format/source.hexa) ────────

struct AttrFormatMeta {
    name:                 str,
    version:              int,
    form:                 str,
    phase:                str,
    status:               str,
    supports_composition: int,
    supports_typing:      int,
    catalog_size:         int,
    spec_doc:             str,
    notes:                str
}

struct AttrDecl {
    name:         str,
    params:       [str],
    line:         int,
    col:          int,
    mode:         str,
    form_version: str
}

struct AttrParseResult {
    ok:       int,
    n_decls:  int,
    decls:    [AttrDecl],
    message:  str
}

struct AttrIssue {
    severity:  str,
    attr_name: str,
    line:      int,
    msg:       str
}

struct AttrValidateResult {
    ok:        int,
    n_issues:  int,
    issues:    [AttrIssue],
    message:   str
}

struct AttrExpandResult {
    ok:       int,
    n_decls:  int,
    decls:    [AttrDecl],
    message:  str
}

fn attr_format_meta_make(
    name: str, version: int, form: str, phase: str, status: str,
    supports_composition: int, supports_typing: int, catalog_size: int,
    spec_doc: str, notes: str
) -> AttrFormatMeta {
    return AttrFormatMeta {
        name: name, version: version, form: form, phase: phase, status: status,
        supports_composition: supports_composition, supports_typing: supports_typing,
        catalog_size: catalog_size, spec_doc: spec_doc, notes: notes
    }
}

fn attr_decl_make(name: str, params: [str], line: int, col: int, mode: str, form_version: str) -> AttrDecl {
    return AttrDecl { name: name, params: params, line: line, col: col, mode: mode, form_version: form_version }
}

fn attr_parse_fail(reason: str) -> AttrParseResult {
    return AttrParseResult { ok: 0, n_decls: 0, decls: [], message: reason }
}

fn attr_parse_ok(decls: [AttrDecl], message: str) -> AttrParseResult {
    return AttrParseResult { ok: 1, n_decls: len(decls), decls: decls, message: message }
}

fn attr_validate_ok(message: str) -> AttrValidateResult {
    return AttrValidateResult { ok: 1, n_issues: 0, issues: [], message: message }
}

fn attr_expand_fail(reason: str) -> AttrExpandResult {
    return AttrExpandResult { ok: 0, n_decls: 0, decls: [], message: reason }
}

fn attr_expand_ok(decls: [AttrDecl], message: str) -> AttrExpandResult {
    return AttrExpandResult { ok: 1, n_decls: len(decls), decls: decls, message: message }
}

// ── Registered version names (SSOT for list_available) ──────────

fn attr_format_registry_names() -> [str] {
    let mut a = []
    a = a.push("v1")
    a = a.push("v2")
    a = a.push("v3")
    a = a.push("v4")
    a = a.push("v5")
    return a
}

// ── Meta dispatch ──────────────────────────────────────────────

fn attr_format_registry_meta(name: str) -> AttrFormatMeta {
    if name == "v1" {
        return attr_format_meta_make(
            "v1", 1, "comment", "current", "WRAPPED",
            0, 0, 24,
            "hexa-lang/self/attrs/attrs.json",
            "comment-form // @attr(...) lint wrapper — current ai-native baseline"
        )
    }
    if name == "v2" {
        return attr_format_meta_make(
            "v2", 2, "ast", "beta", "SPEC-STUB",
            0, 0, 24,
            "hexa-lang/docs/phase_beta_parser_ext_spec.ai.md#L1",
            "AST-level @attr(...) first-class — Phase β L1 spec, parser impl deferred"
        )
    }
    if name == "v3" {
        return attr_format_meta_make(
            "v3", 3, "ast_typed", "beta", "SPEC-STUB",
            0, 1, 24,
            "hexa-lang/docs/phase_beta_parser_ext_spec.ai.md#L10",
            "attr param typing schema (key:str required/optional) — Phase β L10 spec, validation pass deferred"
        )
    }
    if name == "v4" {
        return attr_format_meta_make(
            "v4", 4, "composition", "delta", "SPEC-STUB",
            1, 1, 24,
            "hexa-lang/docs/phase_delta_language_v2_spec.ai.md#L12",
            "composition @module {tool: ..., sentinel: ...} group attr — Phase δ L12 spec, expander deferred"
        )
    }
    if name == "v5" {
        return attr_format_meta_make(
            "v5", 5, "future", "future", "FUTURE-STUB",
            0, 0, 0,
            "",
            "reserved — attr macro / attr inheritance / TBD"
        )
    }
    // Unknown version → version=-1 sentinel
    return attr_format_meta_make(name, -1, "", "", "UNKNOWN", 0, 0, 0, "", "")
}

// ── v1 catalog (24 known attrs — mirror of attr_usage_lint.hexa KNOWN_ATTRS) ─

fn _attr_format_v1_catalog() -> [str] {
    let mut a = []
    a = a.push("hot")
    a = a.push("cold")
    a = a.push("fuse")
    a = a.push("memo")
    a = a.push("bench")
    a = a.push("profile")
    a = a.push("inline")
    a = a.push("noinline")
    a = a.push("simd")
    a = a.push("parallel")
    a = a.push("allocate")
    a = a.push("align")
    a = a.push("unroll")
    a = a.push("hxblas")
    a = a.push("trace")
    a = a.push("audit")
    a = a.push("self_replay")
    a = a.push("idempotent")
    a = a.push("retry")
    a = a.push("timeout")
    a = a.push("checkpoint")
    a = a.push("invariant")
    a = a.push("triad")
    a = a.push("deprecated")
    return a
}

// ── Catalog dispatch (per-version list of known attr names) ────

fn attr_format_registry_catalog(name: str) -> [str] {
    if name == "v1" { return _attr_format_v1_catalog() }
    if name == "v2" { return _attr_format_v1_catalog() }
    if name == "v3" { return _attr_format_v1_catalog() }
    if name == "v4" { return _attr_format_v1_catalog() }
    return []
}

// ── v1 attr extraction (comment-form grep wrapper) ─────────────
//
// Mirrors hive/tool/attr_usage_lint.hexa regex:
//   '^\s*//\s*@[a-z_]+|^\s*@[a-z_]+'
// Returns AttrDecl[] with name extracted, params=[] (v1 does not parse args
// structurally — that is what v2 introduces).
//
// Argument: source string (multi-line .hexa file content).

fn _v1_extract_attr_name(line: str) -> str {
    // strip leading whitespace
    let mut s = line.trim()
    // strip leading "//"
    if s.starts_with("//") {
        s = s.substring(2, len(s)).trim()
    }
    // require leading "@"
    if s.starts_with("@") == false { return "" }
    s = s.substring(1, len(s))
    // attr name is [a-z_]+ until "(" or whitespace or end
    let mut name = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        // accept lowercase + underscore
        let is_alpha = (c == "a") || (c == "b") || (c == "c") || (c == "d") || (c == "e") || (c == "f") || (c == "g") || (c == "h") || (c == "i") || (c == "j") || (c == "k") || (c == "l") || (c == "m") || (c == "n") || (c == "o") || (c == "p") || (c == "q") || (c == "r") || (c == "s") || (c == "t") || (c == "u") || (c == "v") || (c == "w") || (c == "x") || (c == "y") || (c == "z")
        let is_under = c == "_"
        if is_alpha == false {
            if is_under == false { return name }
        }
        name = name + c
        i = i + 1
    }
    return name
}

fn attr_format_registry_parse_v1(src: str) -> AttrParseResult {
    if len(src) < 1 {
        return attr_parse_fail("empty source")
    }
    let lines = src.split("\n")
    let mut decls = []
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        let trimmed = line.trim()
        let is_comment_attr = trimmed.starts_with("//")
        let is_bare_attr = trimmed.starts_with("@")
        if is_comment_attr {
            let name = _v1_extract_attr_name(trimmed)
            if len(name) > 0 {
                let mode_v = if i < 8 { "file" } else { "decl" }
                let d = attr_decl_make(name, [], i + 1, 1, mode_v, "v1")
                decls = decls.push(d)
            }
        }
        if is_bare_attr {
            let name = _v1_extract_attr_name(trimmed)
            if len(name) > 0 {
                let mode_v = if i < 8 { "file" } else { "decl" }
                let d = attr_decl_make(name, [], i + 1, 1, mode_v, "v1")
                decls = decls.push(d)
            }
        }
        i = i + 1
    }
    return attr_parse_ok(decls, "v1: extracted " + str(len(decls)) + " attr decl(s) from " + str(len(lines)) + " line(s)")
}

// ── Selftest ───────────────────────────────────────────────────

fn _selftest_registry() -> int {
    // 1. names list = 5
    let names = attr_format_registry_names()
    if len(names) != 5 { return 0 }
    // 2. each name has well-formed meta
    let mut i = 0
    while i < len(names) {
        let m = attr_format_registry_meta(names[i])
        if m.name != names[i] { return 0 }
        if m.version < 0 { return 0 }
        if len(m.status) < 1 { return 0 }
        i = i + 1
    }
    // 3. unknown version → UNKNOWN sentinel
    let m_x = attr_format_registry_meta("not_a_version")
    if m_x.version != -1 { return 0 }
    if m_x.status != "UNKNOWN" { return 0 }
    // 4. v1 catalog = 24 entries
    let cat = attr_format_registry_catalog("v1")
    if len(cat) != 24 { return 0 }
    // 5. v5 catalog = 0
    let cat5 = attr_format_registry_catalog("v5")
    if len(cat5) != 0 { return 0 }
    // 6. v1 parse extracts comment-form attr names
    let synth = "// @tool(slug=\"x\", desc=\"y\")\n// @sentinel(__X__ <PASS|FAIL>)\nfn main() { return 0 }\n// @hot\n"
    let pr = attr_format_registry_parse_v1(synth)
    if pr.ok != 1 { return 0 }
    // expect 3 attrs: tool, sentinel, hot
    if pr.n_decls != 3 { return 0 }
    if pr.decls[0].name != "tool" { return 0 }
    if pr.decls[1].name != "sentinel" { return 0 }
    if pr.decls[2].name != "hot" { return 0 }
    // 7. v1 parse on empty → fail
    let pr_e = attr_format_registry_parse_v1("")
    if pr_e.ok != 0 { return 0 }
    // 8. v2/v3/v4/v5 meta has correct phase
    let m2 = attr_format_registry_meta("v2")
    if m2.phase != "beta" { return 0 }
    let m4 = attr_format_registry_meta("v4")
    if m4.phase != "delta" { return 0 }
    if m4.supports_composition != 1 { return 0 }
    let m5 = attr_format_registry_meta("v5")
    if m5.status != "FUTURE-STUB" { return 0 }
    return 1
}

fn main() {
    println("[attr_format/registry] 5-version dispatch table")
    if _selftest_registry() == 1 {
        println("[attr_format/registry] SELFTEST PASS")
        println("__ATTR_FORMAT_REGISTRY__ PASS mode=selftest")
    } else {
        println("[attr_format/registry] SELFTEST FAIL")
        println("__ATTR_FORMAT_REGISTRY__ FAIL mode=selftest")
    }
}
