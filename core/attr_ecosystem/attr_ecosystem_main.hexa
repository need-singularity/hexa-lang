#!hexa strict
// @tool(slug="attr_ecosystem_main", desc="hexa-lang attr-ecosystem aggregator + selftest harness — 5-module sentinel verification (B3/B4/B6/B7/B9)")
// @sentinel(__ATTR_ECOSYSTEM_MAIN__ <PASS|FAIL> mode=<selftest>)
// @usage(hexa hexa-lang/core/attr_ecosystem/attr_ecosystem_main.hexa)
// @resolver-bypass(reason="local aggregator selftest, no network/heavy compute")
//
// hexa-lang/core/attr_ecosystem/attr_ecosystem_main.hexa
//   Aggregator selftest for the 5-attr ecosystem (B3/B4/B6/B7/B9)
//
// raw#9 hexa-only strict. Aggregates selftest evidence from:
//   hexa-lang/core/attr_ecosystem/source.hexa
//   hexa-lang/core/attr_ecosystem/registry.hexa
//   hexa-lang/modules/attr_ecosystem/attr_falsifier.hexa
//   hexa-lang/modules/attr_ecosystem/attr_sister.hexa
//   hexa-lang/modules/attr_ecosystem/attr_user_verbatim_record_exempt.hexa
//   hexa-lang/modules/attr_ecosystem/attr_migration_quarantine.hexa
//   hexa-lang/modules/attr_ecosystem/attr_env_required.hexa
//
// Method
//   For each module path we shell out `hexa <path>` and check that the
//   appropriate `__ATTR_<NAME>__ PASS mode=selftest` sentinel appears
//   in stdout. Output is byte-identical across runs because
//   sentinels are deterministic + we suppress timing.
//
// Run
//   hexa hexa-lang/core/attr_ecosystem/attr_ecosystem_main.hexa
// Expect (deterministic stdout, all PASS):
//   [attr_ecosystem_main] modules:           7/7 OK
//   [attr_ecosystem_main] interface contract: PASS
//   [attr_ecosystem_main] registry dispatch:  PASS
//   [attr_ecosystem_main] aggregate:          ALL 7/7 PASS
//   __ATTR_ECOSYSTEM_MAIN__ PASS mode=selftest

// ── Per-target probe ─────────────────────────────────────────

struct ModuleProbe {
    rel_path: str,
    sentinel: str,
    code:     str
}

fn _probe(rel: str, sent: str, code: str) -> ModuleProbe {
    return ModuleProbe { rel_path: rel, sentinel: sent, code: code }
}

fn _all_probes() -> [ModuleProbe] {
    let mut a = []
    a = a.push(_probe(
        "core/attr_ecosystem/source.hexa",
        "__ATTR_ECOSYSTEM_SOURCE__ PASS mode=selftest",
        "IF"))
    a = a.push(_probe(
        "core/attr_ecosystem/registry.hexa",
        "__ATTR_ECOSYSTEM_REGISTRY__ PASS mode=selftest",
        "RG"))
    a = a.push(_probe(
        "modules/attr_ecosystem/attr_falsifier.hexa",
        "__ATTR_FALSIFIER__ PASS mode=selftest",
        "B3"))
    a = a.push(_probe(
        "modules/attr_ecosystem/attr_sister.hexa",
        "__ATTR_SISTER__ PASS mode=selftest",
        "B4"))
    a = a.push(_probe(
        "modules/attr_ecosystem/attr_user_verbatim_record_exempt.hexa",
        "__ATTR_USER_VERBATIM_RECORD_EXEMPT__ PASS mode=selftest",
        "B6"))
    a = a.push(_probe(
        "modules/attr_ecosystem/attr_migration_quarantine.hexa",
        "__ATTR_MIGRATION_QUARANTINE__ PASS mode=selftest",
        "B7"))
    a = a.push(_probe(
        "modules/attr_ecosystem/attr_env_required.hexa",
        "__ATTR_ENV_REQUIRED__ PASS mode=selftest",
        "B9"))
    return a
}

// Repo-root resolution: assume cwd is hexa-lang/ when invoked via
// `hexa core/attr_ecosystem/attr_ecosystem_main.hexa`. Fall back to
// the canonical absolute path used by the parent BG-HX3 driver.
fn _repo_root() -> str {
    let here = to_string(exec("pwd")).trim()
    let probe = to_string(exec("test -d 'core/attr_ecosystem' && printf 1 || printf 0")).trim()
    if probe == "1" { return here }
    return "/Users/<user>/core/hexa-lang"
}

fn _run_probe(repo: str, p: ModuleProbe) -> int {
    let cmd = "cd '" + repo + "' && /Users/<user>/.hx/bin/hexa '" + p.rel_path + "' 2>&1"
    let output = to_string(exec(cmd))
    if output.contains(p.sentinel) { return 1 }
    return 0
}

// ── Selftest aggregator ──────────────────────────────────────

fn _selftest() -> int {
    let repo = _repo_root()
    let probes = _all_probes()
    let total = len(probes)
    let mut ok_count = 0
    let mut fail_codes = []
    let mut i = 0
    while i < total {
        let p = probes[i]
        let r = _run_probe(repo, p)
        if r == 1 {
            ok_count = ok_count + 1
        } else {
            fail_codes = fail_codes.push(p.code)
        }
        i = i + 1
    }
    println("[attr_ecosystem_main] modules:           " + str(ok_count) + "/" + str(total) + " OK")
    if len(fail_codes) > 0 {
        println("[attr_ecosystem_main] failed codes:       " + fail_codes.join(", "))
    }
    if ok_count == total {
        println("[attr_ecosystem_main] interface contract: PASS")
        println("[attr_ecosystem_main] registry dispatch:  PASS")
        println("[attr_ecosystem_main] aggregate:          ALL " + str(total) + "/" + str(total) + " PASS")
        return 1
    }
    println("[attr_ecosystem_main] aggregate:          " + str(ok_count) + "/" + str(total) + " (FAIL)")
    return 0
}

fn main() {
    println("[attr_ecosystem_main] 5-module ecosystem aggregator (B3/B4/B6/B7/B9 + source + registry)")
    if _selftest() == 1 {
        println("__ATTR_ECOSYSTEM_MAIN__ PASS mode=selftest")
    } else {
        println("__ATTR_ECOSYSTEM_MAIN__ FAIL mode=selftest")
    }
}
