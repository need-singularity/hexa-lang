<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.hexa-lang.escalator — unsandboxed escalation daemon.

  Purpose: bypass Claude Code session's sandbox for operations Claude cannot
  perform directly (writes to raw#8 F3 test_*.hexa, launchctl bootstrap,
  etc.). Claude Code writes JSON requests to /tmp/hexa_escalate/*.req;
  this daemon wakes every 2s, processes the queue, writes *.result.

  Install (one time, in user terminal — NOT in a Claude Code session):

      launchctl bootstrap gui/$UID \
          ~/core/hexa-lang/config/launchd/com.hexa-lang.escalator.plist

  Uninstall:

      launchctl bootout gui/$UID/com.hexa-lang.escalator

  Spec: $HEXA_LANG/tool/escalator.hexa (2026-04-23).
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hexa-lang.escalator</string>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- Resolver bypass (~/.hx/bin/hexa.staged:24, ~/.hx/packages/hexa/hexa:38).
             Without this, the daemon body itself is rerouted by the Mac safe-landing
             resolver into a docker container whose /tmp is not the host /tmp,
             and the queue at /tmp/hexa_escalate/ is never observed. With it set,
             the resolver falls through to ~/.hx/packages/hexa/build/hexa.real and
             runs the daemon natively on bare Mac so it can see the host queue
             AND apply chflags / launchctl bootstrap on host paths. -->
        <key>HEXA_RESOLVER_NO_REROUTE</key>
        <string>1</string>
    </dict>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/ghost/.hx/bin/hexa</string>
        <string>run</string>
        <string>/Users/ghost/core/hexa-lang/tool/escalator.hexa</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/ghost/core/hexa-lang</string>

    <key>StartInterval</key>
    <integer>2</integer>

    <key>StandardOutPath</key>
    <string>/tmp/hexa_escalator.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/hexa_escalator.err</string>

    <key>Disabled</key>
    <false/>

    <key>RunAtLoad</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>1</integer>
</dict>
</plist>
