<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  com.hexa-lang.roadmap_continuous_scan — Phase 5 continuous runner.
  Spec: docs/roadmap_engine_continuous_meta_proposal_20260422.md §Phase 5.

  Runs Phase 1-3 scanners every 12 hours. Read-only: never mutates .roadmap.
  Install:
    cp config/launchd/com.hexa-lang.roadmap_continuous_scan.plist \
       ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) \
       ~/Library/LaunchAgents/com.hexa-lang.roadmap_continuous_scan.plist
  Uninstall:
    launchctl bootout gui/$(id -u)/com.hexa-lang.roadmap_continuous_scan

  STATUS: stub — enable after Phase 1-3 tools ship with real logic.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hexa-lang.roadmap_continuous_scan</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd "$HOME/core/hexa-lang" &amp;&amp; ./bin/roadmap_engine continuous-scan 2&gt;&amp;1 | tee -a state/roadmap_continuous_scan.log</string>
    </array>

    <key>StartInterval</key>
    <integer>43200</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/tmp/com.hexa-lang.roadmap_continuous_scan.out</string>
    <key>StandardErrorPath</key>
    <string>/tmp/com.hexa-lang.roadmap_continuous_scan.err</string>

    <key>Disabled</key>
    <true/>
</dict>
</plist>
