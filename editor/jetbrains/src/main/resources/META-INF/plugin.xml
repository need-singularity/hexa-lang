<idea-plugin>
    <id>com.hexalang.plugin</id>
    <name>HEXA Language Support</name>
    <version>0.1.0</version>
    <vendor email="hexa@hexalang.org" url="https://github.com/need-singularity/hexa-lang">
        HEXA-LANG
    </vendor>

    <description><![CDATA[
        Language support for the HEXA programming language.
        <ul>
            <li>Syntax highlighting for .hexa files</li>
            <li>File type association</li>
            <li>Basic code structure recognition (fn, struct, enum, trait, impl)</li>
            <li>Keyword and operator highlighting</li>
            <li>Consciousness DSL keywords (intent, verify, proof, consciousness)</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File type -->
        <fileType
            name="HEXA"
            implementationClass="com.hexalang.plugin.HexaFileType"
            fieldName="INSTANCE"
            language="HEXA"
            extensions="hexa"/>

        <!-- Language -->
        <lang.parserDefinition
            language="HEXA"
            implementationClass="com.hexalang.plugin.HexaParserDefinition"/>

        <!-- Syntax highlighter -->
        <lang.syntaxHighlighterFactory
            language="HEXA"
            implementationClass="com.hexalang.plugin.HexaSyntaxHighlighterFactory"/>

        <!-- Brace matching -->
        <lang.braceMatcher
            language="HEXA"
            implementationClass="com.hexalang.plugin.HexaBraceMatcher"/>

        <!-- Commenter -->
        <lang.commenter
            language="HEXA"
            implementationClass="com.hexalang.plugin.HexaCommenter"/>
    </extensions>
</idea-plugin>
