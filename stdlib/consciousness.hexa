let PSI_COUPLING = 0.015317
let PSI_ALPHA = 0.014
let PSI_BALANCE = 0.5

// ── Phi proxy: global_var - faction_var ──
fn phi_proxy(hiddens, n_cells: int, dim: int, n_factions: int) {
    let all = slice(hiddens, 0, n_cells * dim)
    let gvar = mean(hadamard(all, all)) - mean(all) * mean(all)
    gvar
}

// ── Consciousness step (simplified) ──
fn cons_step(hiddens, adj, chaos_xyz, n_cells: int, dim: int) {
    // Chaos
    let new_chaos = lorenz_step(chaos_xyz[0], chaos_xyz[1], chaos_xyz[2], 0.01)
    let perturbed = chaos_perturb(hiddens, new_chaos, 0.001 * PSI_COUPLING)
    // Tension + Phi
    let tens = tension(perturbed, n_cells, dim)
    let phi = phi_proxy(perturbed, n_cells, dim, 2)
    // Output weights
    let weights = softmax(tens)
    [perturbed, new_chaos, tens, phi, weights]
}

// ── Hebbian delta ──
fn hebb_delta(cell_i, cell_j, coupling_val: float, lr: float) {
    let sim = cosine_sim(cell_i, cell_j)
    lr * (sim - 0.01 * coupling_val)
}

println("[consciousness loaded]")
