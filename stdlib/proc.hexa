// stdlib/proc.hexa — supervised OS-process spawn + .resource registration
//
// @version 1.0.0
// @capabilities [process, shell, fs_write]
//
//
// @module(slug="proc", desc="spawn long-running OS processes with auto-register + lease-TTL supervision")
// @usage(import stdlib/proc; let pid = proc_spawn_supervised("long_cmd", 600, "why this process exists"))
//
// ── module governance metadata (hexa-lang module versioning spec 2026-05-03) ──
// @version 1.0.0
// @capabilities [proc_spawn_supervised, proc_lease_renew, proc_deregister, proc_kill, proc_alive, proc_reap, proc_run_with_stdin, proc_run_json_bridge]
// @stability stable
// @since 2026-04-25
// @maintainer anima-core
// @priority P0
// Versioning policy: docs/hexa_lang_module_versioning_spec_2026_05_03.md
// Breaking-change rule: bump @version major iff any name in @capabilities is
// removed, renamed, or changes its parameter arity / return-type contract.
//
// PROBLEM (2026-04-25 convergence event)
//   Hexa's builtin `exec()` is synchronous (popen). Long-running spawns
//   happen via `&` backgrounding in shell — when the hexa parent exits,
//   the child becomes an orphan parented to launchd. Three concrete
//   accidents this pattern produced:
//     · vitest worker pools (2 × 9 procs each) hung after the parent
//       claude session moved on — 18 orphaned workers.
//     · hexa_interp compiles stuck, parented to nothing.
//     · 11h hive coding-agent on /dev/ttys007 long after session close.
//
// STRATEGY (lease-based supervision, Phase 2 of Plan B 2026-04-25)
//   Every supervised spawn:
//     1. Runs through `setsid` so the child + its worker tree sit in a
//        fresh process-group (pgid == child pid).
//     2. Is registered in the project's `.resource` SSOT with a short
//        `lease-ttl` (default 300s). Owner renews via `proc_lease_renew`
//        while alive; dies silently if owner crashes.
//     3. The reaper (`tool/resource_reaper.hexa`) running on a cron or
//        launchd timer SIGTERMs any entry whose lease expired. Because
//        we recorded `pgid`, killpg wipes the whole worker tree in one
//        signal — vitest-style fanout can't leak.
//
// WHY NOT PDEATHSIG / kqueue NOTE_EXIT
//   Would be tighter (zero-lag parent-death detection) but requires a
//   new hexa builtin + runtime.c change. Phase 2 stays pure-hexa. A
//   future enhancement can swap the shell launcher for a C-level
//   spawn_supervised() builtin without changing this module's API.

// ── config / env ────────────────────────────────────────────────
// Path to the .resource file to register/renew against. Defaults to
// $PWD/.resource so hexa scripts inherit the project's SSOT. Override
// with $HEXA_PROC_RESOURCE for non-cwd scripts (CI runners, launchd).
fn _resource_path() -> string {
    let explicit = env("HEXA_PROC_RESOURCE")
    if len(explicit) > 0 { return explicit }
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p + "/.resource"
}

// Default lease — 5 minutes. Balances reaper latency vs renewal chatter.
// Long-running supervised workers renew every lease/3 (~100s) as a rule.
let PROC_DEFAULT_LEASE_TTL = 300

// ── id helpers ──────────────────────────────────────────────────
fn _now_epoch() -> int {
    return to_int(to_string(exec("date +%s")).trim())
}

// Scan the file for the next free `resource N ...` id. O(N) but .resource
// files are small (tens of entries); acceptable for register churn.
fn _next_resource_id(path: string) -> int {
    let exists = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    if exists != "y" { return 0 }
    let src = to_string(read_file(path))
    let lines = split(src, "\n")
    let mut max_id = -1
    for raw in lines {
        let line = raw.trim()
        if len(line) == 0 { continue }
        if line.substring(0, 1) == "#" { continue }
        if !line.starts_with("resource ") { continue }
        let rest = line.substring(9, len(line))
        let sp = rest.index_of(" ")
        if sp < 0 { continue }
        let id_str = rest.substring(0, sp)
        let id = to_int(id_str)
        if id > max_id { max_id = id }
    }
    return max_id + 1
}

// Serialize a process entry as a `.resource` block. Keep keys in the
// order the docs canon shows — reads better for humans skimming diffs.
fn _serialize_process_entry(
    id: int, slug: string, pid: int, pgid: int, cmd: string,
    started: int, lease_ttl: int, why: string, owner_scope: string
) -> string {
    let mut s = "\n"
    s = s + "resource " + to_string(id) + " live \"supervised process — " + slug + "\"\n"
    s = s + "  slug " + slug + "\n"
    s = s + "  kind process\n"
    s = s + "  pid " + to_string(pid) + "\n"
    if pgid > 0 {
        s = s + "  pgid " + to_string(pgid) + "\n"
    }
    s = s + "  cmd " + cmd + "\n"
    s = s + "  started " + to_string(started) + "\n"
    s = s + "  lease-ttl " + to_string(lease_ttl) + "\n"
    if len(owner_scope) > 0 {
        s = s + "  owner-scope " + owner_scope + "\n"
    }
    s = s + "  why " + why + "\n"
    return s
}

// ── spawn / register / renew / deregister ───────────────────────

// _has_setsid() — probe for GNU setsid binary.
//
// Linux distros ship it in util-linux; macOS does not (only the syscall,
// no CLI wrapper). Every spawn branches on this to decide whether the
// child can safely land in a fresh pgrp (= killpg-safe reaps) or must
// fall back to nohup (= kill-by-pid only, no worker-tree sweep).
fn _has_setsid() -> bool {
    let out = to_string(exec("command -v setsid >/dev/null 2>&1 && echo y || echo n")).trim()
    return out == "y"
}

// proc_spawn_supervised(cmd, lease_ttl, why) -> pid
//
// Spawns `cmd` detached from the hexa parent, registers it in .resource
// with the given lease-ttl (0 = indefinite, no auto-reap — use only for
// daemons with independent heartbeat), returns the child pid.
//
// Detachment strategy is platform-branched:
//   · setsid present (Linux) → child sits in a fresh pgrp; pgid = pid;
//     reaper uses killpg to sweep worker trees together (the vitest
//     9-proc fanout case).
//   · no setsid (macOS default) → child launched via `nohup` + `&`;
//     inherits parent's pgrp. We do NOT record pgid in this case —
//     reaper falls back to `kill pid`. Safe but won't cascade-kill
//     descendants. A future C-level `spawn_detached` runtime builtin
//     closes this gap without a module API change.
//
// Common to both: stdin/stdout/stderr redirect to /dev/null so the
// child can't block on a pipe the parent later closes.
fn proc_spawn_supervised(cmd: string, lease_ttl: int, why: string) -> int {
    let use_setsid = _has_setsid()
    let mut launch = ""
    if use_setsid {
        launch = "setsid sh -c '" + cmd + "' </dev/null >/dev/null 2>&1 & echo $!"
    } else {
        launch = "nohup sh -c '" + cmd + "' </dev/null >/dev/null 2>&1 & echo $!"
    }
    let pid_str = to_string(exec(launch)).trim()
    let pid = to_int(pid_str)
    if pid <= 0 {
        eprintln("proc.spawn_supervised: failed to launch — cmd=" + cmd)
        return 0
    }
    // Only record pgid when we know the child is a pgrp leader.
    let recorded_pgid = if use_setsid { pid } else { 0 }
    let started = _now_epoch()
    let path = _resource_path()
    let id = _next_resource_id(path)
    let slug = "supervised-" + to_string(pid)
    let entry = _serialize_process_entry(
        id, slug, pid, recorded_pgid, cmd, started, lease_ttl, why, ""
    )
    let _touch = exec("test -e '" + path + "' || touch '" + path + "'")
    append_file(path, entry)
    return pid
}

// proc_lease_renew(pid) -> bool
//
// Bumps the `heartbeat` field on the entry whose pid matches. Owners
// call this periodically (lease_ttl / 3 is a safe rule). Returns true
// on success, false if pid not found.
//
// Implementation: rewrite the file with an updated heartbeat line for
// the matching entry. Small-file-at-a-time is fine; we accept one
// rewrite per renew call because the alternative (sidecar index file)
// is a divergence-prone extra SSOT.
fn proc_lease_renew(pid: int) -> bool {
    let path = _resource_path()
    let exists = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    if exists != "y" { return false }
    let src = to_string(read_file(path))
    let lines = split(src, "\n")
    let now = _now_epoch()
    // Match on the trimmed line — raw lines carry the 2-space indent
    // but .trim() strips it, so target needs to follow suit.
    let target = "pid " + to_string(pid)

    let mut out = ""
    let mut in_target_block = false
    let mut wrote_heartbeat = false
    let mut saw_blank = false
    let mut changed = false

    for raw in lines {
        let line = raw
        if line.trim() == target {
            in_target_block = true
            saw_blank = false
        }
        // When we leave the block (blank line or new `resource`) and
        // still owe a heartbeat, emit it before the separator.
        let is_sep = line.trim() == "" || line.starts_with("resource ")
        if in_target_block && is_sep && !wrote_heartbeat {
            out = out + "  heartbeat " + to_string(now) + "\n"
            wrote_heartbeat = true
            in_target_block = false
            changed = true
        }
        // Replace existing heartbeat within the target block instead of
        // appending a duplicate.
        if in_target_block && line.trim().starts_with("heartbeat ") {
            out = out + "  heartbeat " + to_string(now) + "\n"
            wrote_heartbeat = true
            changed = true
            continue
        }
        out = out + line + "\n"
    }
    // Trailing block case (no blank line after target):
    if in_target_block && !wrote_heartbeat {
        out = out + "  heartbeat " + to_string(now) + "\n"
        changed = true
    }
    // read_file+split adds a trailing empty element if src ended in "\n";
    // strip the extra "\n" we appended for that sentinel.
    if len(out) > 0 && out.substring(len(out) - 1, len(out)) == "\n" {
        // one newline too many if original had none at EOF — rare, skip normalize
    }
    if changed {
        write_file(path, out)
    }
    return changed
}

// proc_deregister(pid) -> bool
//
// Removes the matching entry from .resource. Called via `defer` after
// the owner has killed or joined the child. Does NOT send any signal —
// caller is responsible for actual process cleanup.
fn proc_deregister(pid: int) -> bool {
    let path = _resource_path()
    let exists = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    if exists != "y" { return false }
    let src = to_string(read_file(path))
    let lines = split(src, "\n")
    // Match on the trimmed line — raw lines carry the 2-space indent
    // but .trim() strips it, so target needs to follow suit.
    let target = "pid " + to_string(pid)

    let mut blocks = []
    let mut cur_block = []
    for raw in lines {
        let line = raw
        if line.trim() == "" {
            if len(cur_block) > 0 {
                blocks.push(cur_block)
                cur_block = []
            }
            blocks.push([""])
            continue
        }
        if line.starts_with("resource ") && len(cur_block) > 0 {
            blocks.push(cur_block)
            cur_block = []
        }
        cur_block.push(line)
    }
    if len(cur_block) > 0 { blocks.push(cur_block) }

    let mut out = ""
    let mut dropped = false
    for block in blocks {
        let mut is_target = false
        for line in block {
            if line.trim() == target { is_target = true }
        }
        if is_target {
            dropped = true
            continue
        }
        for line in block {
            out = out + line + "\n"
        }
    }
    if dropped {
        write_file(path, out)
    }
    return dropped
}

// proc_kill(pid) -> bool
//
// Tries `kill -TERM -PID` (pgrp) first to cascade-kill worker trees
// spawned under the setsid path, then `kill -TERM PID` as the always-
// applicable fallback. Returns true once the exec shell completes.
//
// Idempotent: safe to call on a dead pid (both kills silently no-op).
fn proc_kill(pid: int) -> bool {
    let out = to_string(exec("kill -TERM -" + to_string(pid) + " 2>/dev/null; kill -TERM " + to_string(pid) + " 2>/dev/null; echo done")).trim()
    return out == "done"
}

// proc_alive(pid) -> bool — POSIX kill -0 probe.
fn proc_alive(pid: int) -> bool {
    let out = to_string(exec("kill -0 " + to_string(pid) + " 2>/dev/null && echo y || echo n")).trim()
    return out == "y"
}

// proc_reap(pid) -> bool
//
// Convenience: kill + deregister. Intended idiom is:
//   let pid = proc_spawn_supervised(cmd, 300, "...")
//   defer { proc_reap(pid) }
// Combined with hexa's existing `scope { }` / `defer`, scope exit
// guarantees the process is gone from both the OS and .resource.
fn proc_reap(pid: int) -> bool {
    let killed = proc_kill(pid)
    let unregistered = proc_deregister(pid)
    return killed && unregistered
}

// ── structured-concurrency pattern (interpreter today, codegen TODO) ──
//
// Hexa has `scope { }` and `defer { }` keywords parsed by the compiler.
// Their runtime semantics are implemented in the interp interpreter
// (HEXA_CACHE=0 or explicit interpreter mode) — `defer` is function-
// scoped, LIFO, and runs on function return; `scope { }` is a nested
// block that shares the enclosing function's defer stack.
//
// AOT codegen (default hexa run / hexa build path) does NOT yet emit
// cleanup code for DeferStmt / ScopeStmt — it errors with "unhandled
// stmt kind: DeferStmt". Tracked as Phase 3 codegen follow-up of the
// 2026-04-25 Plan B spawn-safety initiative.
//
// Recommended pattern (interpreter-mode today):
//
//   fn run_workload() {
//       let pid = proc_spawn_supervised("long_cmd", 300, "why this exists")
//       defer { proc_reap(pid) }
//       // ... do work while the spawned process runs ...
//   } // defer fires → pid SIGTERMed + .resource entry removed
//
// Codegen-mode fallback (until Phase 3 codegen lands):
//
//   let pid = proc_spawn_supervised("long_cmd", 300, "why")
//   do_work_using(pid)
//   proc_reap(pid)
//
// Even without defer, the Phase 1 reaper (`tool/resource_reaper.hexa`)
// running on a cron / launchd timer is the backstop — lease-TTL
// expiration SIGTERMs any entry whose owner forgot to reap.

// ── synchronous stdin-pipe + JSON bridge (P0 — qmirror substrate) ──
//
// Source: anima/docs/hexa_lang_attr_review_for_qmirror_2026_05_03.md §5.1, §5.2
//
// PROBLEM (qmirror engine_aer ↔ aer_runner.py)
//   Hexa's builtin `exec(cmd)` is synchronous popen but provides NO
//   stdin pipe. To send a QASM3 string (or any payload >256B) to a
//   python subprocess today the caller must hand-build a heredoc inside
//   the shell string — `exec("python3 ... <<'EOF'\n" + qasm + "\nEOF")`
//   — which (a) blows past macOS ARG_MAX (~256KB) on big circuits,
//   (b) requires escaping every single quote / dollar sign in payload,
//   (c) leaks the payload into `ps` output (security smell).
//
// FIX (additive, no runtime.c change)
//   1. proc_run_with_stdin(cmd, stdin_str) — spill stdin_str to a temp
//      file, exec `cmd < tmpfile`, unlink tmp. Capacity = filesystem.
//   2. proc_run_json_bridge(cmd, payload) — json_stringify payload,
//      pipe via #1, json_parse stdout. Returns hexa map. On parse
//      failure returns {"ok": 0, "error": "..."} — Result-style stays
//      compatible with nexus convention (`ok: int + message: str`).
//
// Breaking risk: 0. Both functions are new symbols; no existing call
// site is modified. `exec()` callers untouched.
//
// Caveats (raw#91):
//   · Temp-file write is not atomic against concurrent invokers; the
//     nonce uses now_epoch + len(stdin_str) which collides only if two
//     calls in the same wall-clock second happen with identical-length
//     payloads. For nexus single-threaded sampler/engine flow this is
//     adequate; a future C-level `popen3` builtin can supplant.
//   · stdout is captured via `2>&1` — caller cannot distinguish stderr
//     from stdout. Acceptable for JSON-bridge contract (python helpers
//     write JSON to stdout, log to stderr, but the bridge expects stdout
//     to BE the JSON; mixing is the helper's bug, not the wrapper's).
//   · Returns the entire output as a single string — no streaming.
//     Same trade-off as the existing `exec()` builtin.

// proc_run_with_stdin(cmd, stdin_str) -> string
//
// Run `cmd` synchronously with `stdin_str` piped on STDIN. Returns
// stdout (merged with stderr via `2>&1`).
//
// Implementation: spill stdin_str to /tmp/hexa_proc_stdin_<nonce>.txt,
// exec `cmd < tmpfile`, unlink tmp. Sidesteps ARG_MAX + shell escaping.
//
// On any internal failure the wrapper still returns whatever exec()
// produced — caller inspects exit status via the JSON contract or by
// re-invoking with explicit `; echo $?`.
pub fn proc_run_with_stdin(cmd: string, stdin_str: string) -> string {
    let nonce = to_string(_now_epoch()) + "_" + to_string(len(stdin_str))
    let tmp = "/tmp/hexa_proc_stdin_" + nonce + ".txt"
    write_file(tmp, stdin_str)
    let out = to_string(exec(cmd + " < '" + tmp + "' 2>&1"))
    let _drop = exec("rm -f '" + tmp + "'")
    return out
}

// proc_parse_json_bridge_stdout — extract the trailing JSON object from
// a captured stdout buffer. Pure string + json_parse, no exec(). Used
// internally by proc_run_json_bridge and exposed for golden-fixture
// testing of the parse-failure path without spawning a real process.
pub fn proc_parse_json_bridge_stdout(stdout: string) {
    let head_len = if len(stdout) < 200 { len(stdout) } else { 200 }
    let head = stdout.substring(0, head_len)
    let last_open = stdout.last_index_of("{")
    let last_close = stdout.last_index_of("}")
    if last_open < 0 || last_close < 0 || last_close < last_open {
        let err = json_parse("{}")
        err["ok"] = 0
        err["error"] = "bridge: stdout has no JSON object; got " + head
        return err
    }
    let candidate = stdout.substring(last_open, last_close + 1)
    let parsed = json_parse(candidate)
    if type_of(parsed) != "map" {
        let err = json_parse("{}")
        err["ok"] = 0
        err["error"] = "bridge: stdout was not JSON map; got " + head
        return err
    }
    return parsed
}

// proc_run_json_bridge(cmd, payload) -> map
//
// Serialize `payload` (any hexa value json_stringify accepts) to JSON,
// pipe to `cmd` via proc_run_with_stdin, parse stdout as JSON. Returns
// the parsed map.
//
// Error contract (parse failure or non-map result):
//   {"ok": 0, "error": "bridge: <reason>; got <head-of-stdout>"}
// Caller can gate on `result["ok"] == 0` without crashing on missing
// keys — has_key + index, the json_object_get_int idiom.
//
// On success the returned map is whatever the python helper emitted;
// the wrapper does NOT inject `ok: 1` (helpers commonly include their
// own ok / status field already).
pub fn proc_run_json_bridge(cmd: string, payload) {
    let stdin_str = json_stringify(payload)
    let stdout = proc_run_with_stdin(cmd, stdin_str)
    // Pre-flight: locate the LAST JSON object in stdout. Some hexa
    // wrappers prepend `[GATE]`-style log lines before the python
    // helper's actual JSON output, and the runtime json_parse panics
    // with "to_int: not an integer" on bare-text strings returned
    // from exec(). We slice to the last `{...}` substring before
    // parsing — common contract: helper writes JSON last, logs first.
    return proc_parse_json_bridge_stdout(stdout)
}
