// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/ckpt/test/pcc_roundtrip.hexa — write_pcc → verify_pcc happy path
//
//  Generates a deterministic synthetic payload, writes a .pcc, re-reads it,
//  and asserts that:
//      1. verify_pcc.ok is true
//      2. the recovered cert_json equals what we supplied verbatim
//      3. the recovered payload bytes are byte-identical to input
//      4. the declared chunk_count matches (multi-chunk path exercised)
//      5. the declared payload_len matches
//
//  CHUNK SIZE
//    We override chunk_size to 256 bytes and synthesize a 7 × 256 byte
//    payload → 7 chunks (odd → duplicate-last Merkle level exercised).
//    Default 4 MiB chunks are correct but too slow for the stage0 xxh64
//    inner loop inside the hexa interpreter; the module default remains
//    4 MiB. Compiled-mode (`hexa build`) of this test rips through a 10
//    MiB payload in ~4s — see commit log for benchmark numbers.
//
//  Run:
//      ./hexa run stdlib/ckpt/test/pcc_roundtrip.hexa
//  Exits 0 on success, 1 on any failure.
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/ckpt/writer"
use "stdlib/ckpt/verifier"
use "stdlib/ckpt/format"

fn _gen_payload(n) {
    // deterministic pseudo-random bytes from a simple LCG so every run
    // produces the same input (eases debugging). Uses .push() — `+ [b]`
    // would be O(n²) on big payloads in the interpreter.
    let mut out = []
    let mut s = 0x12345678
    let mut i = 0
    while i < n {
        s = (s * 1103515245 + 12345) & 0x7FFFFFFF
        out.push((s / 0x10000) & 0xFF)
        i = i + 1
    }
    return out
}

fn _bytes_equal(a, b) {
    if len(a) != len(b) { return false }
    let mut i = 0
    let n = len(a)
    while i < n {
        if (a[i] & 0xFF) != (b[i] & 0xFF) { return false }
        i = i + 1
    }
    return true
}

fn main() {
    let pid = exec("echo $$").trim()
    let path = "/tmp/hexa_pcc_roundtrip_" + pid + ".pcc"

    let chunk_sz = 256
    let n_chunks = 7
    let total_bytes = chunk_sz * n_chunks
    let payload = _gen_payload(total_bytes)
    let cert_json = "{\"schema_version\":\"2\",\"slug\":\"pcc_roundtrip_fixture\",\"verdict\":\"VERIFIED\"}\n"

    let opts = #{}
    opts["chunk_size"] = chunk_sz

    let w = write_pcc(path, payload, cert_json, opts)

    let mut pass = 0
    let mut fail = 0

    if w["ok"] {
        println("  PASS write_pcc.ok")
        pass = pass + 1
    } else {
        println("  FAIL write_pcc.ok — assembled_len=" + to_string(w["assembled_len"]))
        fail = fail + 1
    }

    if w["chunk_count"] == n_chunks {
        println("  PASS write_pcc.chunk_count==" + to_string(n_chunks))
        pass = pass + 1
    } else {
        println("  FAIL write_pcc.chunk_count=" + to_string(w["chunk_count"]) + " want " + to_string(n_chunks))
        fail = fail + 1
    }

    // Now verify.
    let v = verify_pcc(path)
    if v["ok"] {
        println("  PASS verify_pcc.ok — code=" + v["code"])
        pass = pass + 1
    } else {
        println("  FAIL verify_pcc — code=" + v["code"] + " reason=" + v["reason"])
        fail = fail + 1
    }

    if v["cert_json"] == cert_json {
        println("  PASS cert_json round-trip")
        pass = pass + 1
    } else {
        println("  FAIL cert_json mismatch")
        println("    want: " + cert_json)
        println("    got : " + v["cert_json"])
        fail = fail + 1
    }

    if _bytes_equal(v["payload"], payload) {
        println("  PASS payload byte-identical")
        pass = pass + 1
    } else {
        println("  FAIL payload differs (len want=" + to_string(len(payload)) +
                " got=" + to_string(len(v["payload"])) + ")")
        fail = fail + 1
    }

    if v["payload_len"] == total_bytes {
        println("  PASS payload_len==" + to_string(total_bytes))
        pass = pass + 1
    } else {
        println("  FAIL payload_len=" + to_string(v["payload_len"]))
        fail = fail + 1
    }

    // Clean up.
    exec("rm -f " + path)

    if fail == 0 {
        println("PASS: pcc roundtrip " + to_string(pass) + "/6")
        return 0
    }
    println("FAIL: pcc roundtrip " + to_string(pass) + "/6")
    exit(1)
}
