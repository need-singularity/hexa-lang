// HEXA Standard Library — ckpt/chunk_store tests

import "../chunk_store.hexa"
import "../../math/permille.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL: " + name)
    }
}

fn make_bytes(n: int, seed: int) -> array {
    let mut out = []
    let mut i = 0
    let mut x = seed
    while i < n {
        // Cheap LCG-like byte fill — deterministic from seed.
        x = (x * 1103515245 + 12345) % 2147483647
        out.push(x % 256)
        i = i + 1
    }
    return out
}

fn bytes_equal(a: array, b: array) -> bool {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

// ── T1 empty store ─────────────────────────────────────────────────────
let s1 = make_store()
check("T1a empty chunk_count=0", chunk_count(s1) == 0)
check("T1b empty total_input=0", total_input_bytes(s1) == 0)
check("T1c empty total_stored=0", total_stored_bytes(s1) == 0)
check("T1d empty dedup_ratio=0 pm", dedup_ratio(s1).pm == 0)

// ── T2 single put ──────────────────────────────────────────────────────
let s2 = make_store()
let blob_a = make_bytes(100, 1)
let h_a = put_chunk(s2, blob_a)
check("T2a hex is 8 chars", len(h_a) == 8)
check("T2b chunk_count=1", chunk_count(s2) == 1)
check("T2c total_input=100", total_input_bytes(s2) == 100)
check("T2d total_stored=100", total_stored_bytes(s2) == 100)
check("T2e has_chunk true", has_chunk(s2, h_a))
check("T2f has_chunk false for unknown", has_chunk(s2, "deadbeef") == false)

// ── T3 dedup — same bytes → same hash, no extra storage ────────────────
let h_a2 = put_chunk(s2, blob_a)
check("T3a dedup hash match", h_a2 == h_a)
check("T3b chunk_count still 1", chunk_count(s2) == 1)
check("T3c total_input grew to 200", total_input_bytes(s2) == 200)
check("T3d total_stored still 100", total_stored_bytes(s2) == 100)
check("T3e dedup_ratio=500 pm", dedup_ratio(s2).pm == 500)

// ── T4 distinct bytes → distinct hashes ────────────────────────────────
let blob_b = make_bytes(100, 2)
let h_b = put_chunk(s2, blob_b)
check("T4a new hash distinct", h_b != h_a)
check("T4b chunk_count=2", chunk_count(s2) == 2)
check("T4c total_stored=200", total_stored_bytes(s2) == 200)

// ── T5 round-trip get ──────────────────────────────────────────────────
let got_a = get_chunk(s2, h_a)
check("T5a get matches input", bytes_equal(got_a, blob_a))
check("T5b get unknown returns []", len(get_chunk(s2, "cafef00d")) == 0)

// ── T6 put_stream + reassemble ─────────────────────────────────────────
let s3 = make_store()
let stream = make_bytes(1000, 7)
let hashes = put_stream(s3, stream, 256)
// 1000 / 256 = 3 full + 232 tail → 4 chunks
check("T6a 4 chunks from 1000 bytes @256", len(hashes) == 4)
check("T6b chunk_count=4 (all distinct)", chunk_count(s3) == 4)
let rebuilt = reassemble(s3, hashes)
check("T6c reassemble bit-identical", bytes_equal(rebuilt, stream))

// ── T7 heavy dedup — 10× identical chunks ──────────────────────────────
let s4 = make_store()
let rep = make_bytes(50, 99)
let mut k = 0
let mut hh = ""
while k < 10 {
    hh = put_chunk(s4, rep)
    k = k + 1
}
check("T7a chunk_count=1 after 10 puts", chunk_count(s4) == 1)
check("T7b total_input=500", total_input_bytes(s4) == 500)
check("T7c total_stored=50", total_stored_bytes(s4) == 50)
// (500 - 50) / 500 = 900/1000
check("T7d dedup_ratio=900 pm", dedup_ratio(s4).pm == 900)

// ── T8 put_stream with duplicate chunks triggers dedup ─────────────────
let s5 = make_store()
let pat = make_bytes(100, 3)
// Build a 400-byte stream that's [pat, pat, pat, pat] → should store 1
let mut quad = []
let mut q = 0
while q < 4 {
    let mut j = 0
    while j < len(pat) { quad.push(pat[j]); j = j + 1 }
    q = q + 1
}
let hs = put_stream(s5, quad, 100)
check("T8a 4 hashes emitted", len(hs) == 4)
check("T8b all 4 hashes identical", hs[0] == hs[1] && hs[1] == hs[2] && hs[2] == hs[3])
check("T8c chunk_count=1 (dedup)", chunk_count(s5) == 1)
check("T8d total_stored=100", total_stored_bytes(s5) == 100)
check("T8e reassemble matches", bytes_equal(reassemble(s5, hs), quad))

// ── T9 reassemble with missing hash returns [] ─────────────────────────
let broken = ["deadbeef", "cafef00d"]
check("T9 reassemble with absent hash → []", len(reassemble(s5, broken)) == 0)

// ── Report ─────────────────────────────────────────────────────────────
if failed_name == "" {
    println("PASS: chunk_store " + to_string(pass_count) + "/" + to_string(total_count))
} else {
    println("FAIL: first failure = " + failed_name + " (" + to_string(pass_count) + "/" + to_string(total_count) + ")")
}
