// HEXA Standard Library — regex G3 tests (POSIX ERE bridge)

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn check_eq_int(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

fn check_eq_str(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + got + " want=" + want)
    }
}

fn main() {
    // ── basic match ────────────────────────────────────────────────────
    check("match literal", regex_match("hexa", "hello hexa world"))
    check("no-match literal", regex_match("zzz", "hello hexa world") == false)

    // ── anchored full pattern (witness schema name shape) ──────────────
    check("witness shape", regex_match("^raw_77_[a-z0-9_]+_v[0-9]+$",
                                       "raw_77_weave_compose_v1"))
    check("witness shape no-match",
        regex_match("^raw_77_[a-z0-9_]+_v[0-9]+$", "raw_999_invalid") == false)

    // ── alternation + anchor ───────────────────────────────────────────
    check("PASS alt", regex_match(" (PASS|FAIL)$", "test PASS"))
    check("FAIL alt", regex_match(" (PASS|FAIL)$", "test FAIL"))
    check("DEFER alt no-match",
        regex_match(" (PASS|FAIL)$", "test DEFER") == false)

    // ── inline (?i) case flag ──────────────────────────────────────────
    check("(?i) match", regex_match("(?i)hexa", "HEXA-LANG"))
    check("no-flag mismatch",
        regex_match("hexa", "HEXA-LANG") == false)

    // ── search range ───────────────────────────────────────────────────
    let r = regex_search("[0-9]+", "abc 123 def")
    check_eq_int("search start", r[0], 4)
    check_eq_int("search end",   r[1], 7)

    let r_none = regex_search("[0-9]+", "no digits here")
    check_eq_int("search no match → empty", len(r_none), 0)

    // ── findall ────────────────────────────────────────────────────────
    let all = regex_findall("[0-9]+", "12 ab 34 cd 56")
    check_eq_int("findall count", len(all), 3)
    check_eq_int("findall[0] start", all[0][0], 0)
    check_eq_int("findall[0] end",   all[0][1], 2)
    check_eq_int("findall[2] start", all[2][0], 12)

    // ── split ──────────────────────────────────────────────────────────
    let parts = regex_split(",[[:space:]]*", "a,  b ,c, d")
    check_eq_int("split count", len(parts), 4)
    check_eq_str("split[0]", parts[0], "a")
    check_eq_str("split[1]", parts[1], "b ")  // trailing space before next ',' kept
    check_eq_str("split[3]", parts[3], "d")

    // ── replace ────────────────────────────────────────────────────────
    check_eq_str("replace digits",
        regex_replace("[0-9]+", "a1 b22 c333", "X"),
        "aX bX cX")

    check_eq_str("replace empty repl",
        regex_replace("[0-9]+", "a1 b2 c3", ""),
        "a b c")

    // ── ribozyme nt-pattern (real hexa-bio _python_bridge usage) ──────
    // Original PCRE: r"~?\s*(\d{1,3})[\s-]*nt"
    // POSIX ERE:     ~?[[:space:]]*([0-9]{1,3})[[:space:]-]*nt
    check("nt-pattern match",
        regex_match("(?i)~?[[:space:]]*([0-9]{1,3})[[:space:]-]*nt",
                    "approximately ~12 nt catalytic core"))

    check("nt-pattern boundary - case",
        regex_match("(?i)~?[[:space:]]*([0-9]{1,3})[[:space:]-]*nt",
                    "12-NT scaffold"))

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
