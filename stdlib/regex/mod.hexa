// HEXA Standard Library — regex
//
// @version 0.1.0
// @capabilities [pure]
//
// POSIX ERE-based regex helpers — closes G3-REGEX (.roadmap.stdlib G3,
// 2026-05-06). Routes to runtime hexa_regex_* builtins which delegate
// to libc regcomp/regexec (`#include <regex.h>` in self/runtime.c).
//
// Surface:
//   pub fn regex_test(pat, s) -> bool         — match anywhere in s
//   pub fn regex_full_match(pat, s) -> bool   — match the whole s
//   pub fn regex_find(pat, s) -> [int]        — [start, end] of first match, [] if none
//   pub fn regex_find_all(pat, s) -> [[int]]  — list of [start, end] for all matches
//   pub fn regex_split_str(pat, s) -> [string]
//   pub fn regex_replace_all(pat, s, repl) -> string
//
// Flavor: POSIX Extended Regular Expressions.
//   Supported: . [] ^ $ * + ? {n,m} () |
//   Inline flag: (?i) at the start of a pattern → case-insensitive
//   POSIX char classes: [[:alpha:]] [[:digit:]] [[:space:]] [[:alnum:]] etc.
//
// PCRE shortcut translation (call regex_pcre_lite_translate(pat) to convert):
//   \d → [[:digit:]]   \D → [^[:digit:]]
//   \s → [[:space:]]   \S → [^[:space:]]
//   \w → [[:alnum:]_]  \W → [^[:alnum:]_]
// (Word-boundary `\b` has no portable POSIX ERE equivalent; rewrite as
//  (^|[^[:alnum:]_]) and ([^[:alnum:]_]|$) at use site.)

pub fn regex_test(pat, s) -> bool {
    return regex_match(pat, s)
}

pub fn regex_full_match(pat, s) -> bool {
    return regex_match_full(pat, s)
}

pub fn regex_find(pat, s) {
    return regex_search(pat, s)
}

pub fn regex_find_all(pat, s) {
    return regex_findall(pat, s)
}

pub fn regex_split_str(pat, s) {
    return regex_split(pat, s)
}

pub fn regex_replace_all(pat, s, repl) -> string {
    return regex_replace(pat, s, repl)
}

// Best-effort PCRE → POSIX ERE pattern translator.
// Use sparingly — POSIX char classes are more verbose but portable.
pub fn regex_pcre_lite_translate(pat) -> string {
    let mut out = pat
    out = string_replace(out, "\\d", "[[:digit:]]")
    out = string_replace(out, "\\D", "[^[:digit:]]")
    out = string_replace(out, "\\s", "[[:space:]]")
    out = string_replace(out, "\\S", "[^[:space:]]")
    out = string_replace(out, "\\w", "[[:alnum:]_]")
    out = string_replace(out, "\\W", "[^[:alnum:]_]")
    return out
}
