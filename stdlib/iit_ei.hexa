// HEXA Standard Library — iit_ei
//
// @version 0.1.0
// @capabilities [pure]
//
// IIT 4.0 conservative Φ lower-bound via Effective Information (EI).
// EI is the IIT-derived LOWER BOUND on Φ. Real IIT 4.0 Φ requires bipartition
// search across all subsystems; this module's output is conservative — true Φ ≥ EI.
//
// Why this exists:
//   Downstream consumers (hexa-bio anima Φ pattern, qmirror cond.6 docs) need
//   to compute a Φ-surrogate without pulling in ray/pyphi heavy deps. EI is
//   the standard conservative lower bound: the per-state KL divergence between
//   each row of the Transition Probability Matrix (TPM) and the column-mean
//   distribution (the maximum-entropy "no causal structure" reference).
//
//   ei_per_state(s) = Σ_t P(t|s) · log( P(t|s) / Q(t) ),
//   where Q(t) = (1/N) Σ_s P(t|s)  (column mean of TPM)
//
//   Singularity convention: if P(t|s) > 0 and Q(t) == 0 the KL term is +∞.
//   We push the sentinel string "+inf" into that array slot (matches
//   hexa-bio quantum_anima_phi.hexa output).
//
// Surface:
//   pub fn ei_per_state_nats(tpm: array) -> array
//       // one EI value per state, in NATURAL log units (nats).
//       // Mixed array: float for finite EI, string "+inf" for KL singularity.
//   pub fn ei_per_state_bits(tpm: array) -> array
//       // same as above, rescaled to log2 units (bits).
//   pub fn ei_average_nats(tpm: array) -> float
//       // unweighted mean across states, in nats.
//       // Skips "+inf" sentinel slots — if any present, returns the mean
//       // of the finite slots only (callers should check ei_per_state_nats
//       // for "+inf" if they care about singularity propagation).
//
// Reference impl (hexa-bio/_python_bridge/module/quantum_anima_phi.py
// compute_effective_information_stdlib) uses NATURAL log; bits variant is
// rescaled by 1/ln(2) = 1.4426950408889634 for IIT-textbook compatibility.

let LN2_INV = 1.4426950408889634   // 1 / ln(2) — nats → bits rescale factor

// ── column-mean distribution Q(t) over the TPM ─────────────────────────────

fn _ei_column_mean(tpm: array, n: int) -> array {
    let mut avg = []
    let mut t = 0
    while t < n {
        let mut acc = 0.0
        let mut s = 0
        while s < n {
            acc = acc + tpm[s][t]
            s = s + 1
        }
        avg.push(acc / to_float(n))
        t = t + 1
    }
    return avg
}

// ── per-state EI in nats ───────────────────────────────────────────────────

pub fn ei_per_state_nats(tpm: array) -> array {
    let n = len(tpm)
    let avg = _ei_column_mean(tpm, n)
    let mut out = []
    let mut s = 0
    while s < n {
        let mut ei = 0.0
        let mut singular = false
        let mut t = 0
        while t < n {
            let p = tpm[s][t]
            let q = avg[t]
            if p > 0.0 {
                if q > 0.0 {
                    ei = ei + p * log(p / q)
                } else {
                    // P(t|s) > 0 and Q(t) == 0 → KL term is +∞.
                    singular = true
                    t = n   // break inner while
                }
            }
            t = t + 1
        }
        if singular {
            out.push("+inf")
        } else {
            out.push(ei)
        }
        s = s + 1
    }
    return out
}

// ── per-state EI in bits (log2) ────────────────────────────────────────────

pub fn ei_per_state_bits(tpm: array) -> array {
    let nats = ei_per_state_nats(tpm)
    let n = len(nats)
    let mut out = []
    let mut i = 0
    while i < n {
        let v = nats[i]
        if v == "+inf" {
            out.push("+inf")
        } else {
            out.push(v * LN2_INV)
        }
        i = i + 1
    }
    return out
}

// ── unweighted average EI in nats (skips "+inf" slots) ─────────────────────

pub fn ei_average_nats(tpm: array) -> float {
    let per = ei_per_state_nats(tpm)
    let n = len(per)
    let mut acc = 0.0
    let mut cnt = 0
    let mut i = 0
    while i < n {
        let v = per[i]
        if v == "+inf" {
            // skip — singular state not included in finite average
        } else {
            acc = acc + v
            cnt = cnt + 1
        }
        i = i + 1
    }
    if cnt == 0 { return 0.0 }
    return acc / to_float(cnt)
}
