// HEXA Standard Library — linalg/dispatch
// Backend selector. Honors env `HEXA_LINALG_BACKEND`:
//   "ref"  → always pure-hexa reference kernels
//   "ffi"  → always runtime-builtin kernels (matmul / matvec)
//   "auto" → same as "ffi" when a builtin path applies; else "ref"
//   unset / empty / any other value → "auto"
//
// `auto` today is behaviourally identical to `ffi` because `ffi.hexa`
// already falls back to reference internally for ops without a builtin
// — the dispatch layer just routes the entry point.
//
// Callers must import `reference.hexa` and `ffi.hexa` alongside this
// file — stage0 does not chain transitive imports, so this module
// deliberately does not re-import them. See mod.hexa for the canonical
// triple-import idiom.

let BACKEND_REF = "ref"
let BACKEND_FFI = "ffi"
let BACKEND_AUTO = "auto"

fn select_backend() -> string {
    let raw = env_var("HEXA_LINALG_BACKEND")
    if raw == BACKEND_REF { return BACKEND_REF }
    if raw == BACKEND_FFI { return BACKEND_FFI }
    // "auto", "", or anything unrecognised → auto (defer to ffi wrapper,
    // which itself falls back to ref per-op when no builtin applies).
    return BACKEND_AUTO
}

pub fn sgemm(m: int, n: int, k: int,
             A: array, B: array, C: array,
             alpha: float, beta: float) -> array {
    let b = select_backend()
    if b == BACKEND_REF {
        return sgemm_ref(m, n, k, A, B, C, alpha, beta)
    }
    return sgemm_ffi(m, n, k, A, B, C, alpha, beta)
}

pub fn sgemv(m: int, n: int,
             A: array, x: array, y: array,
             alpha: float, beta: float) -> array {
    let b = select_backend()
    if b == BACKEND_REF {
        return sgemv_ref(m, n, A, x, y, alpha, beta)
    }
    return sgemv_ffi(m, n, A, x, y, alpha, beta)
}

pub fn sdot(n: int, x: array, y: array) -> float {
    let b = select_backend()
    if b == BACKEND_REF {
        return sdot_ref(n, x, y)
    }
    return sdot_ffi(n, x, y)
}

pub fn saxpy(n: int, alpha: float, x: array, y: array) -> array {
    let b = select_backend()
    if b == BACKEND_REF {
        return saxpy_ref(n, alpha, x, y)
    }
    return saxpy_ffi(n, alpha, x, y)
}

pub fn snrm2(n: int, x: array) -> float {
    let b = select_backend()
    if b == BACKEND_REF {
        return snrm2_ref(n, x)
    }
    return snrm2_ffi(n, x)
}

// Exposed for introspection / tests.
pub fn linalg_backend_name() -> string {
    return select_backend()
}
