// HEXA Standard Library — linalg/test/saxpy_test
// Validates saxpy (y := alpha*x + y) across backends (roadmap 57 / B16).

import "../reference.hexa"
import "../ffi.hexa"
import "../dispatch.hexa"
import "../../math/rng.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut fail_name = ""

fn abs_f(x) { if x < 0.0 { return 0.0 - x } else { return x } }

fn record(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if fail_name == "" { fail_name = name }
        println("  FAIL " + name)
    }
}

fn rel_close(a, b, tol) {
    let d = abs_f(a - b)
    let s = abs_f(a) + abs_f(b) + 0.000000001
    return (d / s) < tol
}

fn arrays_close(name, a, b, tol) {
    if len(a) != len(b) {
        record(name + " len", false)
        return
    }
    let mut i = 0
    let mut ok = true
    while i < len(a) {
        if rel_close(a[i], b[i], tol) == false { ok = false }
        i = i + 1
    }
    record(name, ok)
}

// ── Fixed oracle: alpha=2, x=[1,2,3,4], y=[10,20,30,40] → [12,24,36,48] ─
let rref = saxpy_ref(4, 2.0, [1.0, 2.0, 3.0, 4.0], [10.0, 20.0, 30.0, 40.0])
let rffi = saxpy_ffi(4, 2.0, [1.0, 2.0, 3.0, 4.0], [10.0, 20.0, 30.0, 40.0])
record("fixed ref [12,24,36,48]",
    rref[0] == 12.0 && rref[1] == 24.0 && rref[2] == 36.0 && rref[3] == 48.0)
record("fixed ffi [12,24,36,48]",
    rffi[0] == 12.0 && rffi[1] == 24.0 && rffi[2] == 36.0 && rffi[3] == 48.0)

// ── alpha=0 → returns y unchanged ─────────────────────────────
let y0 = [7.0, 8.0, 9.0]
let r0 = saxpy_ref(3, 0.0, [100.0, 200.0, 300.0], y0)
arrays_close("alpha=0 returns y", r0, y0, 0.00001)

// ── Random N=128 ──────────────────────────────────────────────
let N1 = 128
let x1 = randn_matrix(N1, 1, 57301)
let y1 = randn_matrix(N1, 1, 57302)
let ra = saxpy_ref(N1, 0.75, x1, y1)
let fa = saxpy_ffi(N1, 0.75, x1, y1)
arrays_close("N=128 alpha=0.75 ref==ffi", ra, fa, 0.00001)

// ── Negative alpha ────────────────────────────────────────────
let rn = saxpy_ref(N1, 0.0 - 2.25, x1, y1)
let fn_v = saxpy_ffi(N1, 0.0 - 2.25, x1, y1)
arrays_close("N=128 alpha=-2.25", rn, fn_v, 0.00001)

// ── Output length ─────────────────────────────────────────────
record("output length = n", len(ra) == N1)

// ── Dispatch ──────────────────────────────────────────────────
let da = saxpy(N1, 0.75, x1, y1)
arrays_close("dispatch matches ref", da, ra, 0.00001)

println("backend=" + linalg_backend_name())
if pass_count == total_count {
    println("PASS: saxpy " + to_string(pass_count) + "/" + to_string(total_count))
    exit(0)
} else {
    println("FAIL " + fail_name + " (" + to_string(pass_count) + "/" + to_string(total_count) + ")")
    exit(1)
}
