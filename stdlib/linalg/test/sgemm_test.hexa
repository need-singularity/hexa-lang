// HEXA Standard Library — linalg/test/sgemm_test
// Validates sgemm reference + ffi backends agree to 1e-5 relative on
// FP32 random inputs (roadmap 57 / B16 exit criterion).

import "../reference.hexa"
import "../ffi.hexa"
import "../dispatch.hexa"
import "../../math/rng.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut fail_name = ""

fn abs_f(x) { if x < 0.0 { return 0.0 - x } else { return x } }

fn record(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if fail_name == "" { fail_name = name }
        println("  FAIL " + name)
    }
}

// Relative-error comparison: |a - b| / (|a| + |b| + 1e-9) < tol.
fn rel_close(a, b, tol) {
    let d = abs_f(a - b)
    let s = abs_f(a) + abs_f(b) + 0.000000001
    return (d / s) < tol
}

fn arrays_close(name, a, b, tol) {
    if len(a) != len(b) {
        record(name + " len", false)
        return
    }
    let mut i = 0
    let mut ok = true
    while i < len(a) {
        if rel_close(a[i], b[i], tol) == false { ok = false }
        i = i + 1
    }
    record(name, ok)
}

// ── Fixed-case oracle: 2×2 · 2×2 ─────────────────────────────
let Afix = [1.0, 2.0, 3.0, 4.0]
let Bfix = [5.0, 6.0, 7.0, 8.0]
let Cfix_ref = sgemm_ref(2, 2, 2, Afix, Bfix, [], 1.0, 0.0)
let Cfix_ffi = sgemm_ffi(2, 2, 2, Afix, Bfix, [], 1.0, 0.0)
record("fixed ref [19,22,43,50]",
    Cfix_ref[0] == 19.0 && Cfix_ref[1] == 22.0 && Cfix_ref[2] == 43.0 && Cfix_ref[3] == 50.0)
record("fixed ffi [19,22,43,50]",
    Cfix_ffi[0] == 19.0 && Cfix_ffi[1] == 22.0 && Cfix_ffi[2] == 43.0 && Cfix_ffi[3] == 50.0)

// ── Random 8×8 · 8×8, alpha=1, beta=0 ────────────────────────
let M1 = 8
let N1 = 8
let K1 = 8
let A1 = randn_matrix(M1, K1, 57001)
let B1 = randn_matrix(K1, N1, 57002)
let R1 = sgemm_ref(M1, N1, K1, A1, B1, [], 1.0, 0.0)
let F1 = sgemm_ffi(M1, N1, K1, A1, B1, [], 1.0, 0.0)
arrays_close("random 8x8 ref==ffi alpha=1 beta=0", R1, F1, 0.00001)

// ── Non-square 5×3 · 3×7, alpha=2.5, beta=0 ──────────────────
let M2 = 5
let K2 = 3
let N2 = 7
let A2 = randn_matrix(M2, K2, 57003)
let B2 = randn_matrix(K2, N2, 57004)
let R2 = sgemm_ref(M2, N2, K2, A2, B2, [], 2.5, 0.0)
let F2 = sgemm_ffi(M2, N2, K2, A2, B2, [], 2.5, 0.0)
arrays_close("5x3 · 3x7 alpha=2.5", R2, F2, 0.00001)

// ── 6×6 with C accumulation, alpha=0.5, beta=-1.0 ────────────
let M3 = 6
let N3 = 6
let K3 = 6
let A3 = randn_matrix(M3, K3, 57005)
let B3 = randn_matrix(K3, N3, 57006)
let C3 = randn_matrix(M3, N3, 57007)
let R3 = sgemm_ref(M3, N3, K3, A3, B3, C3, 0.5, 0.0 - 1.0)
let F3 = sgemm_ffi(M3, N3, K3, A3, B3, C3, 0.5, 0.0 - 1.0)
arrays_close("6x6 alpha=0.5 beta=-1 accum", R3, F3, 0.00001)

// ── Dispatch entry point agrees with explicit backends ───────
let D3 = sgemm(M3, N3, K3, A3, B3, C3, 0.5, 0.0 - 1.0)
arrays_close("dispatch sgemm matches ref/ffi", D3, R3, 0.00001)

// ── Output shape ──────────────────────────────────────────────
record("output length = m*n", len(R3) == M3 * N3)

println("backend=" + linalg_backend_name())
if pass_count == total_count {
    println("PASS: sgemm " + to_string(pass_count) + "/" + to_string(total_count))
    exit(0)
} else {
    println("FAIL " + fail_name + " (" + to_string(pass_count) + "/" + to_string(total_count) + ")")
    exit(1)
}
