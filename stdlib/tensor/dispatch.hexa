// HEXA Standard Library — tensor/dispatch (F-STDLIB-T1)
// Backend selector for tensor ops. Mirrors stdlib/linalg/dispatch.hexa.
//
// Honors env HEXA_TENSOR_BACKEND:
//   "ref"    → always pure-hexa reference kernels (tensor/ops.hexa)
//   "native" → runtime builtin path (tensor/ffi.hexa, naive C kernel)
//   "blas"   → BLAS-via-stdlib/linalg path. Requires the caller to
//              also import the stdlib/linalg triple
//              (reference.hexa + ffi.hexa + dispatch.hexa). Falls back
//              to the native builtin path when not detected at runtime
//              (see tensor_backend_blas_available below).
//   "auto" / unset / unrecognised → "native" (the safe default — always
//                                  present, zero-marshal builtin).
//
// `linalg_backend_name()` is read for consistency: when the user has
// already opted into the linalg ffi path, tensor_dispatch picks "blas"
// behaviour automatically (the linalg layer is the seam where any real
// hxblas / Accelerate / cblas wiring lives — keeping the env story
// single-knob: "tensor follows linalg unless explicitly overridden").
//
// Caller import requirement — see tensor/mod.hexa for the canonical
// import idiom. This dispatch module reads `env_var` (runtime builtin)
// and forwards to the imported ref / ffi kernels in scope.

let TENSOR_BACKEND_REF    = "ref"
let TENSOR_BACKEND_NATIVE = "native"
let TENSOR_BACKEND_BLAS   = "blas"
let TENSOR_BACKEND_AUTO   = "auto"

// ── tensor_backend_blas_available ────────────────────────────────
// Surface the linalg-side detection through a stable name. Returns
// true when the linalg dispatch is in "ffi" mode (the seam where a
// real BLAS path attaches). Today linalg's ffi backend itself routes
// through the same runtime `matmul` builtin, so this is effectively
// "is the user signalling readiness for the BLAS-ish path?". When a
// future drop wires hxblas / cblas directly, this surface stays the
// same — only the linalg side changes.
pub fn tensor_backend_blas_available() -> bool {
    let lb = linalg_backend_name()
    return lb == "ffi"
}

// ── tensor_select_backend ───────────────────────────────────────────────
fn tensor_select_backend() -> string {
    let raw = env_var("HEXA_TENSOR_BACKEND")
    if raw == TENSOR_BACKEND_REF    { return TENSOR_BACKEND_REF }
    if raw == TENSOR_BACKEND_NATIVE { return TENSOR_BACKEND_NATIVE }
    if raw == TENSOR_BACKEND_BLAS {
        if tensor_backend_blas_available() {
            return TENSOR_BACKEND_BLAS
        }
        return TENSOR_BACKEND_NATIVE
    }
    // "auto", "", or anything unrecognised
    return TENSOR_BACKEND_NATIVE
}

// ── tensor_backend_name (introspection) ──────────────────────────
pub fn tensor_backend_name() -> string {
    return tensor_select_backend()
}

// ── Public dispatch entry points ─────────────────────────────────
// Each one routes to the backend selected at call-time. The "blas"
// branch goes through stdlib/linalg/sgemm — callers requesting that
// path must have those modules in their import scope.

pub fn tensor_matmul(A: Tensor, B: Tensor) -> Tensor {
    let b = tensor_select_backend()
    if b == TENSOR_BACKEND_REF {
        return tensor_matmul_ref(A, B)
    }
    if b == TENSOR_BACKEND_BLAS {
        // Delegate to stdlib/linalg sgemm dispatcher. CblasSgemm
        // ordering: (m, n, k); alpha=1, beta=0, no C accumulation.
        let M = A.shape[0]
        let K = A.shape[1]
        let N = B.shape[1]
        let raw = sgemm(M, N, K, A.data, B.data, [], 1.0, 0.0)
        return Tensor { shape: [M, N], dtype: A.dtype, data: raw }
    }
    return tensor_matmul_ffi(A, B)
}

pub fn tensor_add(A: Tensor, B: Tensor) -> Tensor {
    let b = tensor_select_backend()
    if b == TENSOR_BACKEND_REF {
        return tensor_add_ref(A, B)
    }
    return tensor_add_ffi(A, B)
}

pub fn tensor_relu(A: Tensor) -> Tensor {
    let b = tensor_select_backend()
    if b == TENSOR_BACKEND_REF {
        return tensor_relu_ref(A)
    }
    return tensor_relu_ffi(A)
}
