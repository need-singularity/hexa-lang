// HEXA Standard Library — tensor/shape (F-STDLIB-T1)
// Shape ops over Tensor: reshape, 2D transpose, broadcast.
//
// Public API:
//   pub fn tensor_reshape(t, new_shape)              -> Tensor
//       View-equivalent reshape. Element count must match. Returns a
//       fresh Tensor sharing the underlying data array reference (cheap;
//       row-major layout is unchanged).
//
//   pub fn tensor_transpose2d(t)                     -> Tensor
//       For a rank-2 tensor of shape [M, N] returns [N, M] with
//       data[j, i] = t.data[i, j]. Allocates a fresh buffer.
//
//   pub fn tensor_broadcast_shape(a_shape, b_shape)  -> [int]
//       Numpy-rule broadcast of two shapes. Right-aligned; each pair of
//       dims must be equal or one of them must be 1; the larger value
//       wins. Returns [] if shapes are incompatible (callers must check
//       len > 0 before use).
//
//   pub fn tensor_broadcast_to(t, target_shape)      -> Tensor
//       Materialise `t` to `target_shape` (allocates a fresh buffer).
//       Supported broadcast patterns (sufficient for matmul/add/relu
//       composition under F-STDLIB-T1):
//         * scalar → any shape           (rank 0 / shape [] / shape [1])
//         * row [N]    → [M, N]          (broadcast along axis 0)
//         * col [M, 1] → [M, N]          (broadcast along axis 1)
//         * [M, N]     → [M, N]          (identity)
//       Returns a Tensor whose shape == target_shape on success.
//       Returns the input unchanged when `target_shape` is empty.
//
// Import requirement — tensor/mod.hexa must be in the same import
// scope (interp does not chain transitive imports). Callers add both
// imports explicitly; see mod.hexa for the canonical idiom.

// ── tensor_reshape ────────────────────────────────────────────────
// Element count match is the only invariant; layout is preserved.
pub fn tensor_reshape(t: Tensor, new_shape: array) -> Tensor {
    return Tensor { shape: new_shape, dtype: t.dtype, data: t.data }
}

// ── tensor_transpose2d ────────────────────────────────────────────
// Rank-2 only. For higher ranks, use a future tensor_permute (out of
// scope for F-STDLIB-T1; matmul / add / relu only need 2D transpose).
pub fn tensor_transpose2d(t: Tensor) -> Tensor {
    let m = t.shape[0]
    let n = t.shape[1]
    let mut out = []
    let mut j = 0
    while j < n {
        let mut i = 0
        while i < m {
            out.push(t.data[i * n + j])
            i = i + 1
        }
        j = j + 1
    }
    return Tensor { shape: [n, m], dtype: t.dtype, data: out }
}

// ── tensor_broadcast_shape ────────────────────────────────────────
// Numpy broadcasting rule: align from the right; for each pair, dims
// must be equal or one must be 1; the larger value is taken.
pub fn tensor_broadcast_shape(a_shape: array, b_shape: array) -> array {
    let ra = len(a_shape)
    let rb = len(b_shape)
    let r_out = if ra > rb { ra } else { rb }
    let mut out = []
    let mut k = 0
    while k < r_out {
        // index from the right
        let ia = ra - 1 - k
        let ib = rb - 1 - k
        let av = if ia >= 0 { a_shape[ia] } else { 1 }
        let bv = if ib >= 0 { b_shape[ib] } else { 1 }
        if av != bv && av != 1 && bv != 1 {
            return []                    // incompatible
        }
        let dv = if av > bv { av } else { bv }
        out.push(dv)
        k = k + 1
    }
    // out is reversed (right-to-left); flip it.
    let mut flipped = []
    let mut p = r_out - 1
    while p >= 0 {
        flipped.push(out[p])
        p = p - 1
    }
    return flipped
}

// ── tensor_broadcast_to ───────────────────────────────────────────
// Materialise the supported patterns (see header). Falls through to
// identity for shape match. Unsupported patterns return `t` unchanged
// — callers should pre-check with tensor_broadcast_shape.
pub fn tensor_broadcast_to(t: Tensor, target_shape: array) -> Tensor {
    let r_t = len(t.shape)
    let r_tgt = len(target_shape)
    if r_tgt == 0 { return t }

    // Identity: shapes match exactly.
    if r_t == r_tgt {
        let mut same = true
        let mut k = 0
        while k < r_t {
            if t.shape[k] != target_shape[k] { same = false }
            k = k + 1
        }
        if same { return t }
    }

    // Scalar (rank 0 or [1] or [1,1...]) → any shape: replicate single value.
    let nt = tensor_size(t.shape)
    let n_out = tensor_size(target_shape)
    if nt == 1 {
        let v = t.data[0]
        let mut out = []
        let mut k = 0
        while k < n_out {
            out.push(v)
            k = k + 1
        }
        return Tensor { shape: target_shape, dtype: t.dtype, data: out }
    }

    // Rank-2 target [M, N]
    if r_tgt == 2 {
        let M = target_shape[0]
        let N = target_shape[1]

        // Row vector [N] → [M, N]
        if r_t == 1 && t.shape[0] == N {
            let mut out = []
            let mut i = 0
            while i < M {
                let mut j = 0
                while j < N {
                    out.push(t.data[j])
                    j = j + 1
                }
                i = i + 1
            }
            return Tensor { shape: target_shape, dtype: t.dtype, data: out }
        }

        // Column vector [M, 1] → [M, N]
        if r_t == 2 && t.shape[0] == M && t.shape[1] == 1 {
            let mut out = []
            let mut i = 0
            while i < M {
                let v = t.data[i]
                let mut j = 0
                while j < N {
                    out.push(v)
                    j = j + 1
                }
                i = i + 1
            }
            return Tensor { shape: target_shape, dtype: t.dtype, data: out }
        }

        // Row [1, N] → [M, N]
        if r_t == 2 && t.shape[0] == 1 && t.shape[1] == N {
            let mut out = []
            let mut i = 0
            while i < M {
                let mut j = 0
                while j < N {
                    out.push(t.data[j])
                    j = j + 1
                }
                i = i + 1
            }
            return Tensor { shape: target_shape, dtype: t.dtype, data: out }
        }
    }

    // Unsupported pattern in F-STDLIB-T1 — return unchanged (caller's
    // pre-check via tensor_broadcast_shape() should have caught this).
    return t
}
