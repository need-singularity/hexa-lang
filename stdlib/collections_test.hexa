// HEXA Standard Library — collections G5 tests
//
// counter + combinations + permutations vs Python reference outputs.
// Self-contained — inline the helpers (sidesteps cross-file import path).

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn check_eq_int(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

// ── inlined module surface ─────────────────────────────────────────────

fn counter_t(items) {
    let m = {}
    let i = 0
    while i < len(items) {
        let k = to_string(items[i])
        if has_key(m, k) {
            m[k] = m[k] + 1
        } else {
            m[k] = 1
        }
        i = i + 1
    }
    return m
}

fn combinations_t(items, k) {
    let n = len(items)
    if k <= 0 { return [[]] }
    if k > n { return [] }
    if k == n {
        let only = []
        let j = 0
        while j < n { only.push(items[j]); j = j + 1 }
        return [only]
    }
    let result = []
    let idx = []
    let s = 0
    while s < k { idx.push(s); s = s + 1 }
    while true {
        let row = []
        let r = 0
        while r < k { row.push(items[idx[r]]); r = r + 1 }
        result.push(row)
        let mut i = k - 1
        while i >= 0 && idx[i] == n - k + i {
            i = i - 1
        }
        if i < 0 { break }
        idx[i] = idx[i] + 1
        let mut j = i + 1
        while j < k {
            idx[j] = idx[j - 1] + 1
            j = j + 1
        }
    }
    return result
}

fn permutations_t(items) {
    let n = len(items)
    if n == 0 { return [[]] }
    if n == 1 {
        let row = [items[0]]
        return [row]
    }
    let result = []
    let i = 0
    while i < n {
        let rest = []
        let r = 0
        while r < n {
            if r != i { rest.push(items[r]) }
            r = r + 1
        }
        let sub_perms = permutations_t(rest)
        let p = 0
        while p < len(sub_perms) {
            let combined = [items[i]]
            let s = 0
            while s < len(sub_perms[p]) {
                combined.push(sub_perms[p][s])
                s = s + 1
            }
            result.push(combined)
            p = p + 1
        }
        i = i + 1
    }
    return result
}

fn main() {
    // ── counter ────────────────────────────────────────────────────────
    let c1 = counter_t([1, 1, 2, 3, 1, 2])
    check_eq_int("counter[1]", c1["1"], 3)
    check_eq_int("counter[2]", c1["2"], 2)
    check_eq_int("counter[3]", c1["3"], 1)
    check("counter empty key absent", has_key(c1, "4") == false)

    let c2 = counter_t([])
    check_eq_int("counter empty len", len(keys(c2)), 0)

    let c3 = counter_t(["aml", "scd", "aml", "pancov", "aml", "scd"])
    check_eq_int("counter str aml", c3["aml"], 3)
    check_eq_int("counter str scd", c3["scd"], 2)
    check_eq_int("counter str pancov", c3["pancov"], 1)

    // ── combinations(n, k) — output size matches C(n, k) ──────────────
    // C(4, 2) = 6
    let cb1 = combinations_t([1, 2, 3, 4], 2)
    check_eq_int("C(4,2) size", len(cb1), 6)
    // First combo is [1, 2]; last is [3, 4].
    check_eq_int("C(4,2)[0][0]", cb1[0][0], 1)
    check_eq_int("C(4,2)[0][1]", cb1[0][1], 2)
    check_eq_int("C(4,2)[5][0]", cb1[5][0], 3)
    check_eq_int("C(4,2)[5][1]", cb1[5][1], 4)

    // C(5, 3) = 10
    let cb2 = combinations_t([1, 2, 3, 4, 5], 3)
    check_eq_int("C(5,3) size", len(cb2), 10)

    // Edge cases.
    let cb3 = combinations_t([1, 2, 3], 0)
    check_eq_int("C(3,0) size", len(cb3), 1)
    check_eq_int("C(3,0)[0] len", len(cb3[0]), 0)

    let cb4 = combinations_t([1, 2], 5)
    check_eq_int("C(2,5) size", len(cb4), 0)

    let cb5 = combinations_t([1, 2, 3], 3)
    check_eq_int("C(3,3) size", len(cb5), 1)
    check_eq_int("C(3,3)[0]", cb5[0][2], 3)

    // ── permutations — output size matches n! ─────────────────────────
    let p3 = permutations_t([1, 2, 3])
    check_eq_int("3! size", len(p3), 6)
    // Lex first = [1,2,3]; lex last = [3,2,1].
    check_eq_int("perm[0][0]", p3[0][0], 1)
    check_eq_int("perm[0][1]", p3[0][1], 2)
    check_eq_int("perm[5][0]", p3[5][0], 3)
    check_eq_int("perm[5][2]", p3[5][2], 1)

    let p2 = permutations_t([1, 2])
    check_eq_int("2! size", len(p2), 2)

    let p0 = permutations_t([])
    check_eq_int("0! size", len(p0), 1)

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
