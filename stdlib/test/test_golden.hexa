// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_golden.hexa — F-FIXTURES-1 driver
//
//  Walks fixtures/<module>/golden_<case>.json, calls the public function
//  named in `g["fn"]` against the JSON `g["input"]`, and asserts the
//  return value structurally equals `g["expected"]`.
//
//  Run:
//      hexa run stdlib/test/test_golden.hexa
//
//  Output:
//      For every module that has at least one golden fixture, prints
//        ── <module> ──
//          PASS <module>/<fn>/<case>
//          ...
//      followed by a summary block:
//        per-module: bytes=2/2 json=1/1 ...
//        TOTAL: pass=<n>/<m>
//
//  Exit code: 0 iff all goldens pass and every native module has at
//  least one golden file. 1 otherwise.
//
//  Native module roster (as of 2026-05-04):
//      bytes, http, http2, json, parse, proc, qrng_anu,
//      registry_autodiscover, safetensors, sqlite, websocket, yaml
//  See `EXPECTED_MODULES` below — driver fails if any expected module
//  has zero golden fixtures (acceptance criterion F-FIXTURES-1).
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/test/golden"
use "stdlib/bytes"
use "stdlib/http"
use "stdlib/http2"
use "stdlib/json"
use "stdlib/parse"
use "stdlib/proc"
use "stdlib/qrng_anu"
use "stdlib/registry_autodiscover"
use "stdlib/safetensors"
use "stdlib/sqlite"
use "stdlib/websocket"
use "stdlib/yaml"

let FIXTURES_ROOT = "fixtures"
let EXPECTED_MODULES = [
    "bytes",
    "http",
    "http2",
    "json",
    "parse",
    "proc",
    "qrng_anu",
    "registry_autodiscover",
    "safetensors",
    "sqlite",
    "websocket",
    "yaml"
]

// ── per-fn dispatch ─────────────────────────────────────────────────────────
//
// The hexa interpreter (current revision) does not expose a generic
// `call_by_name` reflective dispatch on imported functions. We therefore
// keep a small explicit dispatch table here — adding a new fixture
// `golden_<x>.json` requires also adding an `if mod == "..." && fn == "..."`
// arm. This is intentional: it forces the test author to re-validate
// the input shape contract whenever a new public surface is added.
fn dispatch(mod_: string, fn_: string, input) {
    if mod_ == "bytes" {
        if fn_ == "bytes_to_uint64" {
            let b = input["bytes"]
            let off = to_int(input["offset"])
            return bytes_to_uint64(b, off)
        }
        if fn_ == "hex_encode_bytes" {
            return hex_encode_bytes(input["bytes"])
        }
    }
    if mod_ == "json" {
        if fn_ == "json_dump_pretty" {
            let v = input["value"]
            let i = to_int(input["indent"])
            return json_dump_pretty(v, i)
        }
    }
    if mod_ == "parse" {
        if fn_ == "to_int_safe" {
            let samples = input["samples"]
            let mut out = []
            let mut i = 0
            while i < len(samples) {
                out.push(to_int_safe(to_string(samples[i])))
                i = i + 1
            }
            return out
        }
    }
    if mod_ == "yaml" {
        if fn_ == "yaml_parse_flat" {
            return yaml_parse_flat(to_string(input["text"]))
        }
    }
    if mod_ == "safetensors" {
        if fn_ == "safetensors_dtype_size" {
            let dtypes = input["dtypes"]
            let mut out = []
            let mut i = 0
            while i < len(dtypes) {
                out.push(safetensors_dtype_size(to_string(dtypes[i])))
                i = i + 1
            }
            return out
        }
    }
    if mod_ == "qrng_anu" {
        if fn_ == "qrng_anu_uint8" {
            return qrng_anu_uint8(to_int(input["length"]))
        }
        if fn_ == "qrng_anu_parse_response" {
            return qrng_anu_parse_response(to_string(input["text"]))
        }
    }
    if mod_ == "sqlite" {
        if fn_ == "sqlite_bind_sql" {
            return sqlite_bind_sql(to_string(input["sql"]), input["params"])
        }
    }
    if mod_ == "http" {
        if fn_ == "http_build_header_flags" {
            return http_build_header_flags(input["headers"])
        }
    }
    if mod_ == "http2" {
        if fn_ == "http2_parse_curl_output" {
            return http2_parse_curl_output(to_string(input["raw"]))
        }
    }
    if mod_ == "websocket" {
        if fn_ == "ws_shell_escape_for_test" {
            return ws_shell_escape_for_test(to_string(input["s"]))
        }
    }
    if mod_ == "proc" {
        if fn_ == "proc_parse_json_bridge_stdout" {
            return proc_parse_json_bridge_stdout(to_string(input["stdout"]))
        }
    }
    if mod_ == "registry_autodiscover" {
        if fn_ == "registry_filter_excluded" {
            return registry_filter_excluded(input["names"], input["exclude"])
        }
    }
    return "__UNDISPATCHED__:" + mod_ + "/" + fn_
}

// ── driver ──────────────────────────────────────────────────────────────────

fn main() -> void {
    println("── F-FIXTURES-1 golden-value driver ──")
    println("  fixtures root: " + FIXTURES_ROOT)

    let mut total_pass = 0
    let mut total_fail = 0
    let mut module_summary = []
    let mut missing_modules = []

    let mut mi = 0
    while mi < len(EXPECTED_MODULES) {
        let mod_ = EXPECTED_MODULES[mi]
        mi = mi + 1
        let files = golden_files_for_module(FIXTURES_ROOT, mod_)
        if len(files) == 0 {
            missing_modules.push(mod_)
            module_summary.push(mod_ + "=0/0(MISSING)")
            continue
        }

        println("")
        println("── " + mod_ + " ──")
        let mut mod_pass = 0
        let mut mod_total = 0
        let mut fi = 0
        while fi < len(files) {
            let fname = files[fi]
            fi = fi + 1
            let path = FIXTURES_ROOT + "/" + mod_ + "/" + fname
            let g = golden_load(path)
            mod_total = mod_total + 1
            if !g["_loaded"] {
                println("  FAIL load " + path + " err=" + to_string(g["_error"]))
                total_fail = total_fail + 1
                continue
            }
            let actual = dispatch(to_string(g["module"]), to_string(g["fn"]), g["input"])
            let r = golden_assert_eq(g, actual)
            if r["ok"] {
                println("  PASS " + to_string(r["tag"]))
                total_pass = total_pass + 1
                mod_pass = mod_pass + 1
            } else {
                println("  FAIL " + to_string(r["tag"]))
                println("       " + to_string(r["diff"]))
                total_fail = total_fail + 1
            }
        }
        module_summary.push(mod_ + "=" + to_string(mod_pass) + "/" + to_string(mod_total))
    }

    println("")
    println("── per-module ──")
    let mut si = 0
    while si < len(module_summary) {
        println("  " + module_summary[si])
        si = si + 1
    }
    let total_n = total_pass + total_fail
    println("")
    println("  TOTAL: pass=" + to_string(total_pass) + "/" + to_string(total_n))

    if len(missing_modules) > 0 {
        println("")
        println("  MISSING goldens for module(s): " + to_string(len(missing_modules)))
        let mut k = 0
        while k < len(missing_modules) {
            println("    - " + missing_modules[k])
            k = k + 1
        }
        println("FAIL: F-FIXTURES-1 acceptance — every native module needs >=1 golden")
        exit(1)
    }

    if total_fail == 0 {
        println("PASS: F-FIXTURES-1 golden-value selftest " + to_string(total_pass) + "/" + to_string(total_n))
        return
    }
    println("FAIL: F-FIXTURES-1 golden-value selftest " + to_string(total_pass) + "/" + to_string(total_n))
    exit(1)
}
