// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_json.hexa
//
//  Selftest for stdlib/json — write-side helpers (P1 additions, qmirror
//  substrate review 2026-05-03 §5.3).
//
//  Run:
//      hexa run stdlib/test/test_json.hexa
//
//  Exit semantics:
//      * all asserts pass → prints "PASS: json stdlib selftest N/N"
//      * any assert fails → prints FAIL lines and exits 1
//
//  Coverage:
//      * json_stringify_value alias round-trip vs runtime builtin
//      * json_dump_pretty indent=0 falls back to compact builtin
//      * json_dump_pretty indent=2 produces multi-line output
//      * nested map + array pretty-printer correctness
//      * json_object_set returns same map, mutates in place, chainable
//      * json_array_push returns same array, mutates in place
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/json"

let mut pass_count = 0
let mut fail_count = 0

fn chk_eq_str(tag, got, want) {
    if got == want {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + got + " want=" + want)
        fail_count = fail_count + 1
    }
}

fn chk_eq_int(tag, got, want) {
    if got == want {
        println("  PASS " + tag + " == " + to_string(want))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + to_string(got) + " want=" + to_string(want))
        fail_count = fail_count + 1
    }
}

fn chk_eq_bool(tag, got, want) {
    if got == want {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        let g = if got { "true" } else { "false" }
        let w = if want { "true" } else { "false" }
        println("  FAIL " + tag + " got=" + g + " want=" + w)
        fail_count = fail_count + 1
    }
}

fn chk_contains(tag, haystack, needle) {
    let idx = haystack.index_of(needle)
    if idx >= 0 {
        println("  PASS " + tag + " contains \"" + needle + "\"")
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " missing \"" + needle + "\" in: " + haystack)
        fail_count = fail_count + 1
    }
}

fn main() -> void {
    println("── stdlib/json (P1 write-side) selftest ──")

    // ── 1. json_stringify_value alias ───────────────────────────────────
    // Must produce identical output to the runtime builtin.
    let m1 = json_parse("{\"a\":1,\"b\":\"hi\"}")
    let via_alias = json_stringify_value(m1)
    let via_builtin = json_stringify(m1)
    chk_eq_str("alias_matches_builtin", via_alias, via_builtin)

    // ── 2. json_dump_pretty indent=0 → compact ─────────────────────────
    let compact = json_dump_pretty(m1, 0)
    chk_eq_str("indent_zero_is_compact", compact, json_stringify(m1))

    // ── 3. json_dump_pretty indent=2 → multiline ───────────────────────
    let pretty = json_dump_pretty(m1, 2)
    chk_contains("pretty_has_newline", pretty, "\n")
    chk_contains("pretty_has_indent", pretty, "  \"a\"")

    // ── 4. round-trip: pretty output re-parses to same logical map ─────
    let reparsed = json_parse(pretty)
    chk_eq_int("roundtrip_a", reparsed["a"], 1)
    chk_eq_str("roundtrip_b", to_string(reparsed["b"]), "hi")

    // ── 5. nested map + array pretty-print ─────────────────────────────
    let nest = json_parse("{\"outer\":{\"inner\":[1,2,3]}}")
    let pn = json_dump_pretty(nest, 2)
    let renest = json_parse(pn)
    chk_eq_int("nested_inner_len", len(renest["outer"]["inner"]), 3)
    chk_eq_int("nested_inner_first", renest["outer"]["inner"][0], 1)
    chk_contains("nested_has_outer_indent", pn, "  \"outer\"")
    chk_contains("nested_has_inner_indent", pn, "    \"inner\"")

    // ── 6. empty cases ─────────────────────────────────────────────────
    let empty_map = json_parse("{}")
    let empty_arr = json_parse("[]")
    chk_eq_str("empty_map_pretty", json_dump_pretty(empty_map, 2), "{}")
    chk_eq_str("empty_arr_pretty", json_dump_pretty(empty_arr, 2), "[]")

    // ── 7. json_object_set returns same map + mutates ──────────────────
    let target = json_parse("{}")
    let returned = json_object_set(target, "k", 42)
    chk_eq_int("object_set_value", target["k"], 42)
    // Reference identity check via mutation visibility:
    json_object_set(returned, "k2", "v2")
    chk_eq_str("object_set_chained", to_string(target["k2"]), "v2")

    // ── 8. json_array_push returns same array + mutates ────────────────
    let arr = []
    let arr_returned = json_array_push(arr, 1)
    json_array_push(arr_returned, 2)
    json_array_push(arr_returned, 3)
    chk_eq_int("array_push_len", len(arr), 3)
    chk_eq_int("array_push_first", arr[0], 1)
    chk_eq_int("array_push_last", arr[2], 3)

    // ── 9. cache-shape build (qmirror calibration use case) ─────────────
    // Mimic: build a calibration cache map and pretty-print + reparse.
    let cache = json_parse("{}")
    json_object_set(cache, "calibration_version", "v2_2026_05_07")
    json_object_set(cache, "n_shots", 50000)
    let counts = json_parse("{}")
    json_object_set(counts, "00", 12500)
    json_object_set(counts, "01", 12500)
    json_object_set(counts, "10", 12500)
    json_object_set(counts, "11", 12500)
    json_object_set(cache, "counts", counts)
    let cache_str = json_dump_pretty(cache, 2)
    let cache_rt = json_parse(cache_str)
    chk_eq_str("cache_version", to_string(cache_rt["calibration_version"]), "v2_2026_05_07")
    chk_eq_int("cache_n_shots", cache_rt["n_shots"], 50000)
    chk_eq_int("cache_counts_00", cache_rt["counts"]["00"], 12500)
    chk_contains("cache_pretty_indented", cache_str, "  \"calibration_version\"")
    chk_contains("cache_pretty_nested_indent", cache_str, "    \"00\"")

    let total = pass_count + fail_count
    println("")
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: json stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
        return
    }
    println("FAIL: json stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
    exit(1)
}
