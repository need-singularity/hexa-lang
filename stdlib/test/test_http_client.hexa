// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_http_client.hexa
//
//  Selftest for stdlib/net/http_client — http_get + http_get_status.
//
//  Run:
//      /Users/<user>/core/hexa-lang/hexa run stdlib/test/test_http_client.hexa
//
//  Network: 기본은 NO network (negative + edge case 만). live network probe
//           는 ANIMA_HTTP_CLIENT_LIVE=1 일 때만 example.com 한 번 친다.
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/net/http_client"

let mut pass_count = 0
let mut fail_count = 0

fn chk_eq_int(tag, got, want) {
    if got == want {
        println("  PASS " + tag + " == " + to_string(want))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + to_string(got) + " want=" + to_string(want))
        fail_count = fail_count + 1
    }
}

fn chk_eq_bool(tag, got, want) {
    if got == want {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        let g = if got { "true" } else { "false" }
        let w = if want { "true" } else { "false" }
        println("  FAIL " + tag + " got=" + g + " want=" + w)
        fail_count = fail_count + 1
    }
}

fn chk_ge_int(tag, got, lo) {
    if got >= lo {
        println("  PASS " + tag + " " + to_string(got) + " >= " + to_string(lo))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " " + to_string(got) + " not >= " + to_string(lo))
        fail_count = fail_count + 1
    }
}

fn main() -> void {
    println("── stdlib/net/http_client selftest ──")

    // Negative: empty url → empty body.
    let body_empty = http_get("", 5)
    chk_eq_int("empty_url_body_len", len(body_empty), 0)

    // Negative: empty url status returns map with status=0 ok=false.
    let r_empty = http_get_status("", 5)
    chk_eq_int("empty_url_status", r_empty["status"], 0)
    chk_eq_bool("empty_url_not_ok", r_empty["ok"], false)

    // Edge: timeout_sec=0 → default 30 path; URL invalid → curl exits → empty body.
    let body_bad = http_get("http://127.0.0.1:1/no-such-port", 1)
    chk_eq_int("invalid_addr_body_len", len(body_bad), 0)

    // Edge: nonexistent host (DNS failure) under tight timeout.
    let r_dns = http_get_status("http://nonexistent.invalid.example/", 2)
    chk_eq_bool("dns_failure_not_ok", r_dns["ok"], false)

    // Live probe (opt-in).
    let live_env = env("ANIMA_HTTP_CLIENT_LIVE")
    if live_env == "1" {
        println("  -- live probe enabled (ANIMA_HTTP_CLIENT_LIVE=1) --")
        let body = http_get("https://example.com/", 10)
        chk_ge_int("live_body_len", len(body), 100)
        let r = http_get_status("https://example.com/", 10)
        chk_eq_int("live_status", r["status"], 200)
        chk_eq_bool("live_ok", r["ok"], true)
    } else {
        println("  -- live probe skipped (ANIMA_HTTP_CLIENT_LIVE!=1) --")
    }

    let total = pass_count + fail_count
    println("")
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: http_client stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
        return
    }
    println("FAIL: http_client stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
    exit(1)
}
