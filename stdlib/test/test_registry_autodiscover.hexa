// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_registry_autodiscover.hexa
//
//  Selftest for stdlib/registry_autodiscover — directory enumeration +
//  dispatch map + exclusion filter.
//
//  Run:
//      /Users/<user>/core/hexa-lang/hexa run stdlib/test/test_registry_autodiscover.hexa
//
//  Uses /tmp scratch dirs (deterministic prefix). Cleans up at exit.
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/registry_autodiscover"

let mut pass_count = 0
let mut fail_count = 0

fn chk_eq_int(tag, got, want) {
    if got == want {
        println("  PASS " + tag + " == " + to_string(want))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + to_string(got) + " want=" + to_string(want))
        fail_count = fail_count + 1
    }
}

fn chk_eq_str(tag, got, want) {
    if got == want {
        println("  PASS " + tag + " == \"" + want + "\"")
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=\"" + got + "\" want=\"" + want + "\"")
        fail_count = fail_count + 1
    }
}

fn chk_eq_bool(tag, got, want) {
    if got == want {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        let g = if got { "true" } else { "false" }
        let w = if want { "true" } else { "false" }
        println("  FAIL " + tag + " got=" + g + " want=" + w)
        fail_count = fail_count + 1
    }
}

// ── linear membership for asserting set semantics ──────────────────────────
fn arr_has(arr, needle: string) -> bool {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == needle { return true }
        i = i + 1
    }
    return false
}

fn main() -> void {
    println("── stdlib/registry_autodiscover selftest ──")

    let scratch_root = "/tmp/hexa_ra_selftest"
    // Clean / re-create scratch deterministic.
    let _r0 = exec("rm -rf " + scratch_root + " && mkdir -p " + scratch_root)

    // ── Case 1: empty dir → empty array, empty dispatch.
    let empty_dir = scratch_root + "/empty"
    let _r1 = exec("mkdir -p " + empty_dir)
    let names1 = registry_scan_dir(empty_dir, ".hexa")
    chk_eq_int("empty_dir_names", len(names1), 0)
    let disp1 = registry_build_dispatch(empty_dir, ".hexa")
    chk_eq_int("empty_dir_dispatch_keys", len(dict_keys(disp1)), 0)

    // ── Case 2: 3 .hexa files (anima rng-style modules).
    let three = scratch_root + "/three"
    let _r2 = exec("mkdir -p " + three + " && touch " + three + "/anu.hexa " + three + "/esp32.hexa " + three + "/urandom.hexa")
    let names2 = registry_scan_dir(three, ".hexa")
    chk_eq_int("three_count", len(names2), 3)
    chk_eq_bool("three_has_anu",     arr_has(names2, "anu"),     true)
    chk_eq_bool("three_has_esp32",   arr_has(names2, "esp32"),   true)
    chk_eq_bool("three_has_urandom", arr_has(names2, "urandom"), true)
    let disp2 = registry_build_dispatch(three, ".hexa")
    chk_eq_int("three_dispatch_keys", len(dict_keys(disp2)), 3)
    chk_eq_str("three_dispatch_anu_path", disp2["anu"], three + "/anu.hexa")

    // ── Case 3: suffix mismatch — only matching suffix returned.
    let mixed = scratch_root + "/mixed"
    let _r3 = exec("mkdir -p " + mixed + " && touch " + mixed + "/a.hexa " + mixed + "/b.py " + mixed + "/c.hexa " + mixed + "/d.md")
    let only_hexa = registry_scan_dir(mixed, ".hexa")
    chk_eq_int("mixed_hexa_count", len(only_hexa), 2)
    chk_eq_bool("mixed_has_a", arr_has(only_hexa, "a"), true)
    chk_eq_bool("mixed_has_c", arr_has(only_hexa, "c"), true)
    chk_eq_bool("mixed_no_b", arr_has(only_hexa, "b"), false)
    chk_eq_bool("mixed_no_d", arr_has(only_hexa, "d"), false)

    // ── Case 4: README + dotfile auto-skipped (dotfile via `.` prefix).
    // README without .hexa suffix is naturally filtered. Verify .hidden skipped.
    let readme_dir = scratch_root + "/readme"
    let _r4 = exec("mkdir -p " + readme_dir + " && touch " + readme_dir + "/README.ai.md " + readme_dir + "/main.hexa " + readme_dir + "/.hidden.hexa")
    let r_names = registry_scan_dir(readme_dir, ".hexa")
    // Note: ls -1 doesn't list dotfiles by default. Either way `.hidden`
    // dropped because of leading-dot filter.
    chk_eq_int("readme_dir_count", len(r_names), 1)
    chk_eq_bool("readme_has_main", arr_has(r_names, "main"), true)
    chk_eq_bool("readme_no_hidden", arr_has(r_names, "hidden"), false)
    // README.ai.md doesn't end in .hexa → not matched.
    chk_eq_bool("readme_no_README", arr_has(r_names, "README"), false)

    // ── Case 5: filter_excluded removes specified entries.
    let pre = ["urandom", "anu", "esp32", "ibm_q"]
    let exclude = ["esp32", "ibm_q"]
    let filtered = registry_filter_excluded(pre, exclude)
    chk_eq_int("filter_count", len(filtered), 2)
    chk_eq_bool("filter_has_urandom", arr_has(filtered, "urandom"), true)
    chk_eq_bool("filter_has_anu",     arr_has(filtered, "anu"),     true)
    chk_eq_bool("filter_no_esp32",    arr_has(filtered, "esp32"),   false)
    chk_eq_bool("filter_no_ibm_q",    arr_has(filtered, "ibm_q"),   false)

    // ── Case 6: nested subdir not enumerated (flat-only).
    let with_sub = scratch_root + "/withsub"
    let _r6 = exec("mkdir -p " + with_sub + "/sub && touch " + with_sub + "/top.hexa " + with_sub + "/sub/inner.hexa")
    let flat_names = registry_scan_dir(with_sub, ".hexa")
    chk_eq_int("flat_only_count", len(flat_names), 1)
    chk_eq_bool("flat_has_top", arr_has(flat_names, "top"), true)
    chk_eq_bool("flat_no_inner", arr_has(flat_names, "inner"), false)

    // ── Case 7: missing dir → silent empty (no panic).
    let missing = scratch_root + "/does_not_exist_" + to_string(pass_count)
    let m_names = registry_scan_dir(missing, ".hexa")
    chk_eq_int("missing_dir_silent", len(m_names), 0)

    // ── Case 8: trailing-slash dir handled (dispatch path no doubled `/`).
    let slash = scratch_root + "/slash/"
    let _r8 = exec("mkdir -p " + slash + " && touch " + slash + "x.hexa")
    let slash_disp = registry_build_dispatch(slash, ".hexa")
    chk_eq_str("slash_dispatch_path", slash_disp["x"], slash + "x.hexa")

    // Cleanup.
    let _rc = exec("rm -rf " + scratch_root)

    let total = pass_count + fail_count
    println("")
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: registry_autodiscover stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
        return
    }
    println("FAIL: registry_autodiscover stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
    exit(1)
}
