// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_http2.hexa
//
//  Selftest for stdlib/http2 (HTTP/2 over TLS via curl --http2).
//
//  Run:
//      hexa run stdlib/test/test_http2.hexa
//
//  Network: live probe enabled by default. Skipped gracefully when:
//      · SKIP_NET=1 in env, OR
//      · curl command not found.
//  Acceptance F-HTTP2: GET https://www.google.com/ returns 200..499 with
//  non-empty body.
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/http2"

let mut pass_count = 0
let mut fail_count = 0

fn chk_eq_int(tag, got, want) {
    if got == want {
        println("  PASS " + tag + " == " + to_string(want))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + to_string(got) + " want=" + to_string(want))
        fail_count = fail_count + 1
    }
}

fn chk_eq_bool(tag, got, want) {
    if got == want {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        let g = if got { "true" } else { "false" }
        let w = if want { "true" } else { "false" }
        println("  FAIL " + tag + " got=" + g + " want=" + w)
        fail_count = fail_count + 1
    }
}

fn chk_in_range_int(tag, got, lo, hi) {
    if got >= lo && got < hi {
        println("  PASS " + tag + " " + to_string(got) + " in [" + to_string(lo) + "," + to_string(hi) + ")")
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " " + to_string(got) + " not in [" + to_string(lo) + "," + to_string(hi) + ")")
        fail_count = fail_count + 1
    }
}

fn chk_ge_int(tag, got, lo) {
    if got >= lo {
        println("  PASS " + tag + " " + to_string(got) + " >= " + to_string(lo))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " " + to_string(got) + " not >= " + to_string(lo))
        fail_count = fail_count + 1
    }
}

fn main() -> void {
    println("── stdlib/http2 selftest ──")

    // ── 1. empty url → ok=false, status=0 ─────────────────────────────
    let r_empty = http2_get_status("", #{}, 5)
    chk_eq_int("empty_url_status", r_empty["status"], 0)
    chk_eq_bool("empty_url_not_ok", r_empty["ok"], false)

    // ── 2. invalid host (DNS fail) under tight timeout → not ok ───────
    let r_dns = http2_get_status("https://nonexistent.invalid.example/", #{}, 2)
    chk_eq_bool("dns_failure_not_ok", r_dns["ok"], false)
    chk_eq_int("dns_failure_status_zero", r_dns["status"], 0)

    // ── 3. shell-escape robustness: tricky header value ───────────────
    let r_tricky = http2_get_status(
        "https://127.0.0.1:1/x",
        #{"x-tricky": "value with 'single' quote"},
        1
    )
    chk_eq_bool("tricky_header_did_not_panic", r_tricky["status"] == 0, true)

    // ── 4. POST body via stdin pipe (offline shell-escape probe) ──────
    let r_post_offline = http2_post_status(
        "https://127.0.0.1:1/x",
        #{"content-type": "application/json"},
        "{\"hello\":\"world with 'quote'\"}",
        1
    )
    chk_eq_bool("post_offline_did_not_panic", r_post_offline["status"] == 0, true)

    // ── 5. F-HTTP2 acceptance: live GET https://www.google.com/ ───────
    let skip = env("SKIP_NET")
    let curl_present = to_string(exec("command -v curl >/dev/null 2>&1 && echo y || echo n")).trim()
    if skip == "1" {
        println("  -- live probe skipped (SKIP_NET=1) --")
    } else {
        if curl_present != "y" {
            println("  -- live probe skipped (curl not found) --")
        } else {
            println("  -- live probe: GET https://www.google.com/ --")
            let r = http2_get_status("https://www.google.com/", #{}, 15)
            // Acceptance: status >= 200 and < 500, body non-empty.
            chk_in_range_int("live_status_2xx_or_3xx_or_4xx", r["status"], 200, 500)
            chk_ge_int("live_body_nonempty", len(r["body"]), 1)
            // http_version is informational — google should always be HTTP/2,
            // but airgap curls without nghttp2 will downgrade to 1.1. Don't
            // hard-fail; just print.
            println("  -- live http_version=" + to_string(r["http_version"]) + " status=" + to_string(r["status"]) + " body_len=" + to_string(len(r["body"])) + " --")
        }
    }

    let total = pass_count + fail_count
    println("")
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: http2 stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
        return
    }
    println("FAIL: http2 stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
    exit(1)
}
