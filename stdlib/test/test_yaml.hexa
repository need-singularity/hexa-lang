// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_yaml.hexa
//
//  Selftest for stdlib/yaml — frontmatter extraction + flat key/value parser.
//
//  Run:
//      /Users/<user>/core/hexa-lang/hexa run stdlib/test/test_yaml.hexa
//
//  Exit semantics:
//      * all asserts pass → prints "PASS: yaml stdlib selftest N/N"
//      * any assert fails → prints FAIL lines and exits 1
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/yaml"

let mut pass_count = 0
let mut fail_count = 0

fn chk_eq_str(tag, got, want) {
    if got == want {
        println("  PASS " + tag + " == \"" + want + "\"")
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=\"" + got + "\" want=\"" + want + "\"")
        fail_count = fail_count + 1
    }
}

fn chk_eq_int(tag, got, want) {
    if got == want {
        println("  PASS " + tag + " == " + to_string(want))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + to_string(got) + " want=" + to_string(want))
        fail_count = fail_count + 1
    }
}

fn chk_eq_bool(tag, got, want) {
    if got == want {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        let g = if got { "true" } else { "false" }
        let w = if want { "true" } else { "false" }
        println("  FAIL " + tag + " got=" + g + " want=" + w)
        fail_count = fail_count + 1
    }
}

fn main() -> void {
    println("── stdlib/yaml selftest ──")

    // ── Case 1: empty input → empty frontmatter, empty parse map.
    let fm_empty = yaml_frontmatter_extract("")
    chk_eq_str("empty_frontmatter", fm_empty, "")
    let m_empty = yaml_parse_flat("")
    chk_eq_int("empty_parse_keys", len(dict_keys(m_empty)), 0)

    // ── Case 2: text without frontmatter → "" extract, body unchanged on strip.
    let no_fm = "# Heading\n\nbody text only.\n"
    chk_eq_str("no_frontmatter_extract", yaml_frontmatter_extract(no_fm), "")
    chk_eq_str("no_frontmatter_strip", yaml_strip_frontmatter(no_fm), no_fm)

    // ── Case 3: valid frontmatter (raw 271 ai-native shape).
    let valid = "---\nschema: anima/modules/rng/ai-native/1\nlast_updated: 2026-05-02\nstatus: landed\n---\n# Body\n\ncontent here\n"
    let fm_valid = yaml_frontmatter_extract(valid)
    let m_valid = yaml_parse_flat(fm_valid)
    chk_eq_str("valid_schema",       yaml_get(m_valid, "schema", ""),       "anima/modules/rng/ai-native/1")
    chk_eq_str("valid_last_updated", yaml_get(m_valid, "last_updated", ""), "2026-05-02")
    chk_eq_str("valid_status",       yaml_get(m_valid, "status", ""),       "landed")
    chk_eq_int("valid_key_count",    len(dict_keys(m_valid)),               3)
    let body = yaml_strip_frontmatter(valid)
    chk_eq_bool("valid_body_starts_with_heading", body.substring(0, 8) == "# Body\n\n", true)

    // ── Case 4: missing required key → returned in missing list.
    let m4 = yaml_parse_flat("schema: x\nstatus: landed\n")
    let req = ["schema", "last_updated", "status"]
    let miss = yaml_validate_keys(m4, req)
    chk_eq_int("missing_count", len(miss), 1)
    chk_eq_str("missing_key_name", miss[0], "last_updated")

    // ── Case 5: extra (unrequired) keys preserved, no error.
    let m5 = yaml_parse_flat("schema: y\nlast_updated: today\nstatus: live\nfoo: bar\nbaz: qux\n")
    let miss5 = yaml_validate_keys(m5, req)
    chk_eq_int("extra_keys_no_missing", len(miss5), 0)
    chk_eq_str("extra_key_foo", yaml_get(m5, "foo", ""), "bar")
    chk_eq_str("extra_key_baz", yaml_get(m5, "baz", ""), "qux")

    // ── Case 6: nested YAML rejected — child lines dropped, parent value "".
    let nested = "---\nssot:\n  interface: anima/core/rng/source.hexa\n  registry: anima/core/rng/registry.hexa\nschema: nested-test\n---\n"
    let fm6 = yaml_frontmatter_extract(nested)
    let m6 = yaml_parse_flat(fm6)
    // schema visible, ssot present (empty value), nested children dropped.
    chk_eq_str("nested_schema_visible",  yaml_get(m6, "schema", ""),  "nested-test")
    chk_eq_str("nested_ssot_empty",      yaml_get(m6, "ssot", "MISS"),  "")
    chk_eq_str("nested_child_dropped",   yaml_get(m6, "interface", "DROPPED"), "DROPPED")

    // ── Case 7: quoted values unquoted symmetrically.
    let q = "k1: \"double quoted\"\nk2: 'single quoted'\nk3: unquoted\nk4: \"unbalanced\nk5: \"\"\n"
    let mq = yaml_parse_flat(q)
    chk_eq_str("quote_double", yaml_get(mq, "k1", ""), "double quoted")
    chk_eq_str("quote_single", yaml_get(mq, "k2", ""), "single quoted")
    chk_eq_str("quote_none",   yaml_get(mq, "k3", ""), "unquoted")
    chk_eq_str("quote_unbal",  yaml_get(mq, "k4", ""), "\"unbalanced")
    chk_eq_str("quote_empty",  yaml_get(mq, "k5", ""), "")

    // ── Case 8: comments + list items dropped.
    let mixed = "# leading comment\nschema: ok\n# mid comment\nlist:\n- a\n- b\nstatus: live\n"
    let mm = yaml_parse_flat(mixed)
    chk_eq_str("mixed_schema", yaml_get(mm, "schema", ""), "ok")
    chk_eq_str("mixed_status", yaml_get(mm, "status", ""), "live")
    chk_eq_str("mixed_list_empty", yaml_get(mm, "list", "MISS"), "")

    // ── Case 9: yaml_get default on absent key.
    chk_eq_str("default_absent",  yaml_get(m_valid, "no_such_key", "DEFAULT"), "DEFAULT")
    // Empty default supported.
    chk_eq_str("default_empty",  yaml_get(m_valid, "no_such_key", ""), "")

    let total = pass_count + fail_count
    println("")
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: yaml stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
        return
    }
    println("FAIL: yaml stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
    exit(1)
}
