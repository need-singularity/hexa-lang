// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_parse.hexa
//
//  Selftest for stdlib/parse — to_int_safe + is_numeric_str.
//
//  Run:
//      /Users/ghost/core/hexa-lang/hexa run stdlib/test/test_parse.hexa
//
//  Exit semantics:
//      * all asserts pass → prints "PASS: parse stdlib selftest N/N"
//      * any assert fails → prints FAIL lines and exits 1
//
//  Source: RFC `to_int_safe` §5 (airgenome 2026-04-30) test fixtures.
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/parse"

let mut pass_count = 0
let mut fail_count = 0

fn chk_eq_int(tag, got, want) {
    if got == want {
        println("  PASS " + tag + " == " + to_string(want))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + to_string(got) + " want=" + to_string(want))
        fail_count = fail_count + 1
    }
}

fn chk_eq_bool(tag, got, want) {
    if got == want {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        let g = if got { "true" } else { "false" }
        let w = if want { "true" } else { "false" }
        println("  FAIL " + tag + " got=" + g + " want=" + w)
        fail_count = fail_count + 1
    }
}

fn main() -> void {
    println("── stdlib/parse selftest ──")

    // Basic
    chk_eq_int("zero",      to_int_safe("0"),     0)
    chk_eq_int("positive",  to_int_safe("5"),     5)
    chk_eq_int("negative",  to_int_safe("-3"),    -3)

    // Decimal truncation
    chk_eq_int("decimal_zero",  to_int_safe("0.0"),   0)
    chk_eq_int("decimal_pos",   to_int_safe("5.7"),   5)
    chk_eq_int("decimal_neg",   to_int_safe("-2.9"),  -2)

    // Whitespace trim
    chk_eq_int("trim_left",   to_int_safe(" 5"),    5)
    chk_eq_int("trim_right",  to_int_safe("5 "),    5)
    chk_eq_int("trim_both",   to_int_safe(" 5 "),   5)

    // Empty / non-digit
    chk_eq_int("empty",       to_int_safe(""),      0)
    chk_eq_int("non_digit",   to_int_safe("abc"),   0)
    chk_eq_int("partial",     to_int_safe("5abc"),  0)
    chk_eq_int("hex",         to_int_safe("0x10"),  0)
    chk_eq_int("scientific",  to_int_safe("1e3"),   0)

    // Real-world ps cpu sourced inputs
    chk_eq_int("ps_cpu_0",    to_int_safe("0.0"),   0)
    chk_eq_int("ps_cpu_100",  to_int_safe("100.0"), 100)
    chk_eq_int("ps_cpu_5_7",  to_int_safe("5.7"),   5)

    // is_numeric_str helper
    chk_eq_bool("is_numeric_str:5",     is_numeric_str("5"),     true)
    chk_eq_bool("is_numeric_str:-3",    is_numeric_str("-3"),    true)
    chk_eq_bool("is_numeric_str:5.7",   is_numeric_str("5.7"),   false)
    chk_eq_bool("is_numeric_str:abc",   is_numeric_str("abc"),   false)
    chk_eq_bool("is_numeric_str:empty", is_numeric_str(""),      false)
    chk_eq_bool("is_numeric_str:space", is_numeric_str(" 5 "),   true)
    chk_eq_bool("is_numeric_str:-",     is_numeric_str("-"),     false)

    let total = pass_count + fail_count
    println("")
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: parse stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
        return
    }
    println("FAIL: parse stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
    exit(1)
}
