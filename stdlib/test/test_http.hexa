// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_http.hexa
//
//  Selftest for stdlib/http — http_get_with_headers (P1 addition, qmirror
//  substrate review 2026-05-03 §5.4).
//
//  Run:
//      hexa run stdlib/test/test_http.hexa
//
//  Network: no live calls by default. Live probe only when
//           ANIMA_HTTP_HEADERS_LIVE=1 (hits httpbin.org/headers and
//           verifies the x-test-key header round-trips).
//
//  Coverage:
//      * empty url → empty body / status=0
//      * empty header map → matches no-header curl behaviour
//      * single header round-trip (live)
//      * x-api-key style header round-trip (live)
//      * multiple headers preserved (live)
//      * single-quote in header value escapes safely (offline shell-escape probe)
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/http"

let mut pass_count = 0
let mut fail_count = 0

fn chk_eq_int(tag, got, want) {
    if got == want {
        println("  PASS " + tag + " == " + to_string(want))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + to_string(got) + " want=" + to_string(want))
        fail_count = fail_count + 1
    }
}

fn chk_eq_bool(tag, got, want) {
    if got == want {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        let g = if got { "true" } else { "false" }
        let w = if want { "true" } else { "false" }
        println("  FAIL " + tag + " got=" + g + " want=" + w)
        fail_count = fail_count + 1
    }
}

fn chk_contains(tag, haystack, needle) {
    let idx = haystack.index_of(needle)
    if idx >= 0 {
        println("  PASS " + tag + " contains \"" + needle + "\"")
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " missing \"" + needle + "\" in: " + haystack)
        fail_count = fail_count + 1
    }
}

fn chk_ge_int(tag, got, lo) {
    if got >= lo {
        println("  PASS " + tag + " " + to_string(got) + " >= " + to_string(lo))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " " + to_string(got) + " not >= " + to_string(lo))
        fail_count = fail_count + 1
    }
}

fn main() -> void {
    println("── stdlib/http (P1 headers) selftest ──")

    // ── 1. empty url → "" ──────────────────────────────────────────────
    let body_empty = http_get_with_headers("", #{"x-api-key": "k"}, 5)
    chk_eq_int("empty_url_body_len", len(body_empty), 0)

    // ── 2. empty url status → status=0, ok=false ───────────────────────
    let r_empty = http_get_with_headers_status("", #{}, 5)
    chk_eq_int("empty_url_status", r_empty["status"], 0)
    chk_eq_bool("empty_url_not_ok", r_empty["ok"], false)

    // ── 3. invalid host (DNS fail) under tight timeout → not ok ────────
    let r_dns = http_get_with_headers_status(
        "http://nonexistent.invalid.example/", #{"x-api-key": "k"}, 2
    )
    chk_eq_bool("dns_failure_not_ok", r_dns["ok"], false)

    // ── 4. invalid port → empty body, --fail path ──────────────────────
    let body_bad = http_get_with_headers(
        "http://127.0.0.1:1/no-such-port", #{"x-api-key": "k"}, 1
    )
    chk_eq_int("invalid_port_body_len", len(body_bad), 0)

    // ── 5. shell-escape: single-quote in header value must not break ───
    // Offline probe: pass a tricky value to a non-routable URL with a
    // 1s timeout. The wrapper must not panic / not produce an unbalanced
    // shell command. Success criterion = call returns (status=0, ok=false)
    // not a runtime error.
    let r_tricky = http_get_with_headers_status(
        "http://127.0.0.1:1/x",
        #{"x-tricky": "value with 'single' quote"},
        1
    )
    chk_eq_bool("tricky_header_did_not_panic", r_tricky["status"] == 0, true)

    // ── 6. live probe (opt-in, ANIMA_HTTP_HEADERS_LIVE=1) ──────────────
    let live_env = env("ANIMA_HTTP_HEADERS_LIVE")
    if live_env == "1" {
        println("  -- live probe enabled (ANIMA_HTTP_HEADERS_LIVE=1) --")

        // httpbin.org/headers echoes request headers in a JSON body.
        let r = http_get_with_headers_status(
            "https://httpbin.org/headers",
            #{"x-api-key": "test-key-12345", "x-trace-id": "qmirror-selftest"},
            10
        )
        chk_eq_int("live_status", r["status"], 200)
        chk_eq_bool("live_ok", r["ok"], true)
        chk_ge_int("live_body_len", len(r["body"]), 50)
        chk_contains("live_x_api_key_echoed", r["body"], "X-Api-Key")
        chk_contains("live_x_api_key_value", r["body"], "test-key-12345")
        chk_contains("live_x_trace_id_echoed", r["body"], "X-Trace-Id")
    } else {
        println("  -- live probe skipped (ANIMA_HTTP_HEADERS_LIVE!=1) --")
    }

    let total = pass_count + fail_count
    println("")
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: http stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
        return
    }
    println("FAIL: http stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
    exit(1)
}
