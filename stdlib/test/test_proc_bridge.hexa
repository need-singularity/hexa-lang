// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_proc_bridge.hexa
//
//  Selftest for stdlib/proc — proc_run_with_stdin + proc_run_json_bridge
//  (P0 additions, qmirror substrate review 2026-05-03).
//
//  Run:
//      hexa run stdlib/test/test_proc_bridge.hexa
//
//  Exit semantics:
//      * all asserts pass → prints "PASS: proc_bridge stdlib selftest N/N"
//      * any assert fails → prints FAIL lines and exits 1
//
//  Coverage (P0 review §5.1, §5.2):
//      * tiny stdin round-trip (cat)
//      * large stdin (>4KB) — ARG_MAX-class payload via temp file
//      * unicode / quotes / special chars in stdin
//      * json bridge: hexa map → python -c json round-trip
//      * json bridge: parse-failure path (non-JSON stdout) returns ok=0
//
//  Dependencies (system tools): cat, python3. Both are mandatory on
//  macOS + Linux build hosts; if missing, smoke is skipped with a
//  diagnostic line (still prints PASS for whatever ran).
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/proc"

let mut pass_count = 0
let mut fail_count = 0

fn chk_eq_int(tag, got, want) {
    if got == want {
        println("  PASS " + tag + " == " + to_string(want))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + to_string(got) + " want=" + to_string(want))
        fail_count = fail_count + 1
    }
}

fn chk_eq_str(tag, got, want) {
    if got == want {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + got + " want=" + want)
        fail_count = fail_count + 1
    }
}

fn chk_eq_bool(tag, got, want) {
    if got == want {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        let g = if got { "true" } else { "false" }
        let w = if want { "true" } else { "false" }
        println("  FAIL " + tag + " got=" + g + " want=" + w)
        fail_count = fail_count + 1
    }
}

fn chk_contains(tag, haystack, needle) {
    let idx = haystack.index_of(needle)
    if idx >= 0 {
        println("  PASS " + tag + " contains \"" + needle + "\"")
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " missing \"" + needle + "\" in: " + haystack)
        fail_count = fail_count + 1
    }
}

fn _have_tool(t) -> bool {
    let probe = to_string(exec("command -v " + t + " >/dev/null 2>&1 && echo y || echo n")).trim()
    return probe == "y"
}

fn main() -> void {
    println("── stdlib/proc bridge selftest ──")

    let have_cat = _have_tool("cat")
    let have_py = _have_tool("python3")

    // ── 1. tiny round-trip via cat ──────────────────────────────────────
    if have_cat {
        let out = proc_run_with_stdin("cat", "hello")
        chk_eq_str("cat_tiny", out.trim(), "hello")
    } else {
        println("  SKIP cat_tiny (no cat in PATH)")
    }

    // ── 2. large payload (>4KB — pre-ARG_MAX comfort zone) ──────────────
    if have_cat {
        // Build ~5KB payload by repeating a 50-byte chunk 100x.
        let chunk = "0123456789abcdefghijklmnopqrstuvwxyz0123456789ABCD"
        let mut big = ""
        let mut i = 0
        while i < 100 {
            big = big + chunk
            i = i + 1
        }
        let out = proc_run_with_stdin("cat", big)
        chk_eq_int("cat_large_len", len(out.trim()), len(big))
        // Spot-check first + last 50 bytes preserved.
        chk_eq_str("cat_large_head", out.substring(0, 50), chunk)
        chk_eq_str("cat_large_tail", out.substring(len(big) - 50, len(big)), chunk)
    } else {
        println("  SKIP cat_large (no cat in PATH)")
    }

    // ── 3. payload with quotes / dollars / newlines ─────────────────────
    if have_cat {
        let tricky = "line1 with 'single' \"double\" $VAR and `backtick`\nline2\nline3"
        let out = proc_run_with_stdin("cat", tricky)
        chk_eq_str("cat_special_chars", out, tricky)
    } else {
        println("  SKIP cat_special (no cat in PATH)")
    }

    // ── 4. JSON bridge round-trip via python3 ───────────────────────────
    // python3 -c reads stdin, parses JSON, echoes back with one extra key.
    // This validates: hexa-map → JSON → python → JSON → hexa-map.
    if have_py {
        let payload = json_parse("{\"x\":1,\"y\":\"hello\"}")
        let cmd = "python3 -c \"import sys,json;d=json.load(sys.stdin);d['echo']=True;print(json.dumps(d))\""
        let result = proc_run_json_bridge(cmd, payload)
        chk_eq_bool("bridge_is_map", type_of(result) == "map", true)
        chk_eq_int("bridge_x", result["x"], 1)
        chk_eq_str("bridge_y", to_string(result["y"]), "hello")
        chk_eq_bool("bridge_echo", result["echo"], true)
    } else {
        println("  SKIP bridge_python_roundtrip (no python3 in PATH)")
    }

    // ── 5. JSON bridge — parse-failure path ─────────────────────────────
    // cat of a non-JSON payload → bridge must return ok=0 + error message,
    // NOT crash. (This is the contract qmirror engine_aer relies on for
    // python helper crashes — get a Result-like map back, never a panic.)
    if have_cat {
        // We send a JSON map but the cmd just echoes a non-JSON greeting.
        let payload = json_parse("{\"ignored\":1}")
        let result = proc_run_json_bridge("printf 'not-json-at-all'", payload)
        chk_eq_bool("bridge_failure_is_map", type_of(result) == "map", true)
        chk_eq_int("bridge_failure_ok_zero", result["ok"], 0)
        let err = to_string(result["error"])
        chk_contains("bridge_failure_error_msg", err, "bridge:")
        chk_contains("bridge_failure_error_head", err, "not-json-at-all")
    } else {
        println("  SKIP bridge_failure (no printf/cat surrogate)")
    }

    // ── 6. stdin temp file is cleaned up ────────────────────────────────
    // After a run, no /tmp/hexa_proc_stdin_*.txt should remain. Probe by
    // listing — count must be 0.
    if have_cat {
        let _drop = proc_run_with_stdin("cat", "cleanup-probe")
        let leftover = to_string(exec("ls /tmp/hexa_proc_stdin_*.txt 2>/dev/null | wc -l")).trim()
        chk_eq_str("tmp_cleanup", leftover, "0")
    } else {
        println("  SKIP tmp_cleanup (no cat in PATH)")
    }

    let total = pass_count + fail_count
    println("")
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: proc_bridge stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
        return
    }
    println("FAIL: proc_bridge stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
    exit(1)
}
