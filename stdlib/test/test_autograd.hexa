// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/test/test_autograd.hexa
//
//  Selftest for stdlib/autograd — tape-based reverse-mode autograd.
//
//  Run:
//      hexa run stdlib/test/test_autograd.hexa
//
//  Coverage (acceptance F-AUTOGRAD-T2):
//      * scalar y = x^2 + sin(x), x = 1.5  →  dy/dx within 1e-5 of FD.
//      * sanity: leaf grad accumulates over multiple uses (y = x*x).
//      * sanity: const tensor grad stays 0.
//      * sanity: tape isolation — ag_tape_reset between graphs is safe.
//      * sanity: chain rule  y = sin(x*x)  →  dy/dx = 2x cos(x^2).
//      * sanity: mul backward — y = a*b  →  da=b, db=a.
//      * sanity: ag_finite_difference helper itself is sane.
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/autograd"

let mut pass_count = 0
let mut fail_count = 0

// Floating-point absolute-tolerance check.
fn chk_close(tag, got: float, want: float, tol: float) {
    let d = got - want
    let ad = if d < 0.0 { -d } else { d }
    if ad <= tol {
        println("  PASS " + tag + " got=" + to_string(got) + " want=" + to_string(want) + " |d|=" + to_string(ad))
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag + " got=" + to_string(got) + " want=" + to_string(want) + " |d|=" + to_string(ad) + " tol=" + to_string(tol))
        fail_count = fail_count + 1
    }
}

fn chk_eq_float(tag, got: float, want: float) {
    chk_close(tag, got, want, 0.0)
}

// f(x) = x^2 + sin(x)   — unary lambda for finite-difference.
fn f_target(x: float) -> float {
    return x * x + sin(x)
}

fn main() -> void {
    println("── stdlib/autograd selftest ──")

    // ── Case 1 (acceptance F-AUTOGRAD-T2): y = x^2 + sin(x), x = 1.5 ──
    ag_tape_reset()
    let x = ag_var(1.5)
    let x2 = ag_pow(x, 2.0)
    let sx = ag_sin(x)
    let y = ag_add(x2, sx)
    chk_close("forward_y", ag_value(y), 1.5 * 1.5 + sin(1.5), 0.000000001)

    ag_backward(y)
    let dy_dx_auto = ag_grad(x)
    // analytic: dy/dx = 2x + cos(x) = 3.0 + cos(1.5)
    let dy_dx_analytic = 2.0 * 1.5 + cos(1.5)
    chk_close("autograd_vs_analytic", dy_dx_auto, dy_dx_analytic, 0.0000001)

    // numerical (central difference) — tightly bounded by FD truncation O(h^2).
    let dy_dx_fd = ag_finite_difference(f_target, 1.5, 0.0001)
    chk_close("autograd_vs_fd_F-AUTOGRAD-T2", dy_dx_auto, dy_dx_fd, 0.00001)

    // ── Case 2: leaf grad accumulates over multiple uses (y = x*x). ──
    ag_tape_reset()
    let x2var = ag_var(3.0)
    let y2 = ag_mul(x2var, x2var)   // x*x — leaf used twice
    ag_backward(y2)
    // dy/dx = 2x = 6.0
    chk_close("accum_two_uses", ag_grad(x2var), 6.0, 0.000000001)

    // ── Case 3: const has zero grad. ──
    ag_tape_reset()
    let xc = ag_var(2.0)
    let kc = ag_const(5.0)
    let yc = ag_mul(xc, kc)
    ag_backward(yc)
    chk_close("var_grad_eq_const", ag_grad(xc), 5.0, 0.000000001)
    chk_eq_float("const_grad_zero", ag_grad(kc), 0.0)

    // ── Case 4: tape isolation — reset between graphs. ──
    ag_tape_reset()
    chk_eq_float("tape_size_after_reset", to_float(ag_tape_size()), 0.0)
    let xa = ag_var(1.0)
    let _ = ag_add(xa, xa)
    let sz = ag_tape_size()
    if sz >= 2 {
        println("  PASS tape_size_grows_after_use size=" + to_string(sz))
        pass_count = pass_count + 1
    } else {
        println("  FAIL tape_size_grows_after_use size=" + to_string(sz))
        fail_count = fail_count + 1
    }

    // ── Case 5: chain rule  y = sin(x*x)  →  dy/dx = 2x cos(x^2).  ──
    ag_tape_reset()
    let x5 = ag_var(0.7)
    let sq = ag_mul(x5, x5)
    let y5 = ag_sin(sq)
    ag_backward(y5)
    let want5 = 2.0 * 0.7 * cos(0.7 * 0.7)
    chk_close("chain_sin_of_sq", ag_grad(x5), want5, 0.0000001)

    // ── Case 6: mul backward  y = a*b. ──
    ag_tape_reset()
    let a6 = ag_var(2.5)
    let b6 = ag_var(4.0)
    let y6 = ag_mul(a6, b6)
    ag_backward(y6)
    chk_close("mul_da_eq_b", ag_grad(a6), 4.0, 0.000000001)
    chk_close("mul_db_eq_a", ag_grad(b6), 2.5, 0.000000001)

    // ── Case 7: FD helper sanity — d/dx sin(x) at x=0 should be 1.
    //   Note: builtin functions (e.g. `sin`) cannot be passed directly as
    //   first-class function values in current hexa runtime; wrap in a
    //   user fn to get a proper hexa function reference.
    fn _sin_fn(x: float) -> float { return sin(x) }
    let dcos = ag_finite_difference(_sin_fn, 0.0, 0.0001)
    chk_close("fd_d_sin_at_0", dcos, 1.0, 0.00001)

    // ── Summary ───────────────────────────────────────────────────────
    let total = pass_count + fail_count
    if fail_count == 0 {
        println("PASS: autograd stdlib selftest " + to_string(pass_count) + "/" + to_string(total))
    } else {
        println("FAIL: autograd stdlib selftest " + to_string(pass_count) + "/" + to_string(total) + " (" + to_string(fail_count) + " failures)")
        exit(1)
    }
}

