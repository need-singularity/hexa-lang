// stdlib/bytes.hexa — byte/uint conversions (P1 — qmirror per-shot perf)
//
// @module(slug="stdlib-bytes", desc="byte-array <-> integer + hex helpers")
// @usage(import stdlib/bytes; let u = bytes_to_uint64(qrng_bytes, 0))
//
// Source: anima/docs/hexa_lang_attr_review_for_qmirror_2026_05_03.md §5.5
//
// PROBLEM (qmirror sampler.hexa per-shot path)
//   The hot loop pulls 8 bytes from the entropy source and folds them
//   into a uint64 to drive the [0, 1) float used for measurement-basis
//   selection. Today the conversion is `exec("printf '%d' 0x" + pair)`
//   per byte pair — fork-per-shot. At 50K shots × 8B/shot that is 400K
//   process forks, totally dominating the per-shot budget.
//
// FIX (additive, no runtime.c change)
//   1. bytes_to_uint64(b, offset) -> int
//        Big-endian fold of 8 bytes starting at b[offset]. Returns 0 if
//        the slice would run off the end (no panic). Pure arithmetic, no
//        exec — eliminates the per-shot fork cost.
//   2. bytes_to_uint64_le(b, offset) -> int
//        Little-endian variant for callers wrapping LE C structs.
//   3. bytes_to_uint32(b, offset) -> int
//        4-byte BE fold. Same family.
//   4. int_from_hex(s) -> int
//        "ff" / "0xFF" / "FF" → 255. Returns 0 on empty / bad input.
//   5. hex_encode_bytes(b) -> string
//        [0..255] array → "0a1bff…" lowercase. ASCII-safe.
//   6. uint64_to_unit_float(u) -> float
//        Convert a 64-bit uint into a [0, 1) double via division by 2^53
//        (the largest power-of-two that fits losslessly into IEEE-754
//        double). The top 11 bits of the uint are discarded — see caveat.
//
// Breaking risk: 0. New module, all new symbols. The runtime hex_encode
// builtin (which encodes a string to hex) is untouched; this module's
// hex_encode_bytes operates on an int-array of 0..255 byte values.
//
// Caveats (raw#91):
//   · `bytes` in hexa convention is `[int]` with each element in 0..255.
//     This module does NOT range-check input bytes — bytes outside
//     0..255 produce silent overflow (e.g. b[i]=256 → result shifted
//     wrong). qrng/anu byte arrays are guaranteed in-range; sister
//     callers should pre-validate or use an upstream sanitizer.
//   · uint64_to_unit_float discards 11 entropy bits to fit IEEE-754
//     mantissa. For Bell-state / measurement-basis selection (4 outcomes)
//     this is overkill precision; for cryptographic uses prefer raw
//     bytes_to_uint64 + manual masking.
//   · int_from_hex relies on the runtime hex_decode builtin per pair —
//     which is itself implemented in C and runs in O(N). Acceptable for
//     short cache-version strings; do NOT call in inner loops on KB-scale
//     inputs (use hex_encode_bytes + cache).
//   · No SIMD / runtime fast-path — these are pure arithmetic loops.
//     Fine for 8-byte folds (per-shot path); KB-scale conversions
//     should use a future C builtin if profiled hot.
//
// raw#9 hexa-only-strict: pure hexa, zero exec(), zero new C builtin.

// ── bytes_to_uint64 — big-endian 8-byte fold ─────────────────────
//
// Reads b[offset..offset+8] as big-endian (network order) and returns
// the 64-bit unsigned interpretation as a hexa int. Out-of-range
// (offset < 0 OR offset+8 > len(b)) returns 0 — caller must pre-check
// length if 0 is a valid result for them.
//
// Implementation: shift-by-multiply-256 to stay portable across hexa
// integer types (the runtime int is signed 64; explicit shift would
// require bit-ops on signed which behave platform-dependently).
pub fn bytes_to_uint64(b, offset: int) -> int {
    if offset < 0 { return 0 }
    if type_of(b) != "array" { return 0 }
    if offset + 8 > len(b) { return 0 }
    let mut u = 0
    let mut i = 0
    while i < 8 {
        u = u * 256 + b[offset + i]
        i = i + 1
    }
    return u
}

// bytes_to_uint64_le — little-endian variant.
//
// Same range checks; reads b[offset+7] as the most-significant byte.
pub fn bytes_to_uint64_le(b, offset: int) -> int {
    if offset < 0 { return 0 }
    if type_of(b) != "array" { return 0 }
    if offset + 8 > len(b) { return 0 }
    let mut u = 0
    let mut i = 7
    while i >= 0 {
        u = u * 256 + b[offset + i]
        i = i - 1
    }
    return u
}

// bytes_to_uint32 — big-endian 4-byte fold.
pub fn bytes_to_uint32(b, offset: int) -> int {
    if offset < 0 { return 0 }
    if type_of(b) != "array" { return 0 }
    if offset + 4 > len(b) { return 0 }
    let mut u = 0
    let mut i = 0
    while i < 4 {
        u = u * 256 + b[offset + i]
        i = i + 1
    }
    return u
}

// ── int_from_hex — accept "ff", "0xff", "FF" ─────────────────────
//
// Decimal-only input is NOT supported (would overlap the to_int builtin
// semantics ambiguously). Empty / non-hex input returns 0 silently —
// caller treats 0 as the "no parse" sentinel, validating in a caller
// scope that knows what 0 means in their problem domain.
pub fn int_from_hex(s: string) -> int {
    if len(s) == 0 { return 0 }
    let mut t = s.trim()
    if len(t) >= 2 && t.substring(0, 2) == "0x" {
        t = t.substring(2, len(t))
    }
    if len(t) >= 2 && t.substring(0, 2) == "0X" {
        t = t.substring(2, len(t))
    }
    if len(t) == 0 { return 0 }
    let mut acc = 0
    let mut i = 0
    while i < len(t) {
        let ch = t.substring(i, i + 1)
        let d = _hex_digit(ch)
        if d < 0 { return 0 }
        acc = acc * 16 + d
        i = i + 1
    }
    return acc
}

// _hex_digit — one hex char to 0..15, -1 on invalid.
fn _hex_digit(ch: string) -> int {
    if ch == "0" { return 0 }
    if ch == "1" { return 1 }
    if ch == "2" { return 2 }
    if ch == "3" { return 3 }
    if ch == "4" { return 4 }
    if ch == "5" { return 5 }
    if ch == "6" { return 6 }
    if ch == "7" { return 7 }
    if ch == "8" { return 8 }
    if ch == "9" { return 9 }
    if ch == "a" || ch == "A" { return 10 }
    if ch == "b" || ch == "B" { return 11 }
    if ch == "c" || ch == "C" { return 12 }
    if ch == "d" || ch == "D" { return 13 }
    if ch == "e" || ch == "E" { return 14 }
    if ch == "f" || ch == "F" { return 15 }
    return -1
}

// ── hex_encode_bytes — [0..255] array to lowercase hex string ────
//
// NOTE: the runtime `hex_encode` builtin operates on a STRING (encodes
// each char's byte value). This module's `hex_encode_bytes` operates on
// an INT-ARRAY (each element treated as a byte). Distinct functions for
// distinct inputs — sister callers using qrng [int]-byte arrays land
// here; callers with text strings stay on the runtime builtin.
pub fn hex_encode_bytes(b) -> string {
    if type_of(b) != "array" { return "" }
    let table = "0123456789abcdef"
    let mut s = ""
    let mut i = 0
    while i < len(b) {
        let v = b[i]
        let hi = (v / 16) % 16
        let lo = v % 16
        s = s + table.substring(hi, hi + 1) + table.substring(lo, lo + 1)
        i = i + 1
    }
    return s
}

// ── uint64_to_unit_float — uint to [0, 1) ────────────────────────
//
// Scales a 64-bit unsigned (passed as a hexa int) into the half-open
// [0, 1) interval by dividing by 2^53. The mantissa-aligned divisor
// guarantees the result has full IEEE-754 double precision and never
// reaches exactly 1.0.
//
// Only the low 53 bits of the input are used (top 11 bits discarded
// via integer division). Adequate for ≤2^53 distinct outcomes — far
// beyond the qmirror Bell-test 4-outcome alphabet.
pub fn uint64_to_unit_float(u: int) -> float {
    let denom = 9007199254740992.0  // 2^53
    let masked = u % 9007199254740992  // keep low 53 bits
    return to_float(masked) / denom
}

// ═══════════════════════════════════════════════════════════════════
//  Chunked I/O primitives — interp-memory escape hatch (P1)
//
//  WHY (see tool/docs/interp_memory.md for the full write-up)
//
//  Every "byte" in a hexa int-array is a boxed HexaVal (~24 B tagged
//  union + heap descriptor overhead). A 1 MiB byte payload therefore
//  costs ~25 MB of element storage on its own; the same payload fed
//  through `out = out + [b]` (concat-rebuild idiom) explodes to O(n²)
//  copies and trips the 2 GB RSS soft cap before reaching 64 KiB.
//
//  Prior-art:
//   · 947944ed (F-SAFETENSORS-1) — defaults to 8 K f32 (32 KiB) and
//     gates the full 1 MiB stress run behind HEXA_SAFETENSORS_FULL_MB.
//   · e7673823 (F-SQLITE)        — rewrote 1000-row single-shot fetch
//     as 100-row LIMIT/OFFSET chunked walks.
//   · stdlib/ckpt/format.hexa    — `bytes_append` uses .push (not +)
//     and the format itself is chunk-addressable at 4 MiB.
//
//  This block extends bytes.hexa with the same chunking idiom in the
//  general filesystem case, so callers can stream multi-MiB payloads
//  without inventing a new module each time.
//
//  All four helpers below use:
//    · `out.push(...)` — amortised O(1) growth, NEVER `out + [x]`.
//    · `read_bytes_at(path, offset, n)` / `write_bytes_append` /
//      `file_size` builtins (already in runtime.c — added 2026-04
//      for the safetensors→hexaw multi-GB pipeline).
//    · A default chunk size of 65536 (64 KiB) — well under the
//      ~1 MiB threshold, large enough to amortise per-chunk fopen.
// ═══════════════════════════════════════════════════════════════════

let BYTES_DEFAULT_CHUNK = 65536  // 64 KiB — see rationale above

pub fn bytes_default_chunk() -> int {
    return BYTES_DEFAULT_CHUNK
}

// ── bytes_iter_chunked — visit a file in [chunk_size] byte windows ──
//
// Reads `path` in successive `read_bytes_at` calls of `chunk_size`
// bytes each, invoking `fn(chunk, offset)` for every non-empty slice.
// The chunk is freed (drops out of scope) before the next read, so
// peak hexa-side RSS stays at O(chunk_size × 24 B) regardless of
// total file size. Use when:
//   · The file is multi-MiB and you only need streaming access.
//   · Your processing is per-byte / per-window (hash, scan, transform).
//
// `fn` semantics: receives (chunk: [int], offset: int). Return value
// ignored. To collect a result, mutate a captured outer variable.
//
// Returns total bytes visited (== file_size on success).
pub fn bytes_iter_chunked(path: string, chunk_size: int, cb) -> int {
    let mut size = file_size(path)
    if size <= 0 { return 0 }
    let mut step = chunk_size
    if step <= 0 { step = BYTES_DEFAULT_CHUNK }
    let mut offset = 0
    while offset < size {
        let want = if (size - offset) < step { size - offset } else { step }
        let chunk = read_bytes_at(path, offset, want)
        if len(chunk) == 0 { return offset }
        cb(chunk, offset)
        offset = offset + len(chunk)
    }
    return offset
}

// ── bytes_read_chunked — read a file as [int] without exceeding RSS ─
//
// Convenience wrapper around bytes_iter_chunked that materialises the
// full file into a single int-array — but uses .push (not concat) and
// frees each chunk between iterations. Caller still pays O(file_size
// × 24 B); this only avoids the O(file_size²) concat blow-up.
//
// SAFETY: do NOT call this on files that don't fit your RSS budget.
// Computing the safe limit: usable_RSS_MB × 1024 / 24 ≈ max bytes.
// On a 1.8 GB working budget that is roughly ~75 MiB of file payload.
// Above that, switch to bytes_iter_chunked + your own folding fn.
pub fn bytes_read_chunked(path: string, chunk_size: int) -> [int] {
    let mut out = []
    let mut step = chunk_size
    if step <= 0 { step = BYTES_DEFAULT_CHUNK }
    let mut size = file_size(path)
    if size <= 0 { return out }
    let mut offset = 0
    while offset < size {
        let want = if (size - offset) < step { size - offset } else { step }
        let chunk = read_bytes_at(path, offset, want)
        let n = len(chunk)
        if n == 0 { return out }
        let mut i = 0
        while i < n {
            out.push(chunk[i])
            i = i + 1
        }
        offset = offset + n
    }
    return out
}

// ── bytes_write_chunked — emit an int-array in chunk-sized appends ──
//
// Materialising the whole `data` array is the caller's problem; this
// helper just splits the write side so each fwrite stays under the
// runtime's per-call temp buffer (a malloc-then-fwrite-then-free
// triplet inside rt_write_bytes_append). Useful when:
//   · `data` came from bytes_read_chunked + transform and is large
//     enough that one rt_write_bytes call would temp-malloc it all.
//   · Caller is composing a result on the fly (loop where each
//     iteration produces ≤ chunk_size bytes, then flushes).
//
// First call truncates (rt_write_bytes), subsequent calls append
// (rt_write_bytes_append). Returns total bytes written.
pub fn bytes_write_chunked(path: string, data, chunk_size: int) -> int {
    let n = len(data)
    if n == 0 {
        write_bytes(path, [])
        return 0
    }
    let mut step = chunk_size
    if step <= 0 { step = BYTES_DEFAULT_CHUNK }
    let mut offset = 0
    let mut first = 1
    while offset < n {
        let end = if (offset + step) < n { offset + step } else { n }
        let mut buf = []
        let mut i = offset
        while i < end {
            buf.push(data[i])
            i = i + 1
        }
        if first == 1 {
            write_bytes(path, buf)
            first = 0
        } else {
            write_bytes_append(path, buf)
        }
        offset = end
    }
    return offset
}

// ── bytes_copy_chunked — file → file via fixed-size windows ──────────
//
// Reads src in chunk_size windows, writes each window straight to dst
// (truncating on first chunk, appending after). Peak hexa-side RSS
// stays at O(chunk_size × 24 B) regardless of file size — the safe
// idiom for multi-GB safetensors / checkpoint copies.
//
// Returns total bytes copied (== file_size(src) on success), or -1 on
// fopen / write failure (size mismatch sentinel; caller compares vs.
// file_size(src) themselves to detect partial copies).
pub fn bytes_copy_chunked(src: string, dst: string, chunk_size: int) -> int {
    let mut step = chunk_size
    if step <= 0 { step = BYTES_DEFAULT_CHUNK }
    let mut size = file_size(src)
    if size <= 0 {
        write_bytes(dst, [])
        return 0
    }
    let mut offset = 0
    let mut first = 1
    while offset < size {
        let want = if (size - offset) < step { size - offset } else { step }
        let chunk = read_bytes_at(src, offset, want)
        let n = len(chunk)
        if n == 0 { return offset }
        if first == 1 {
            write_bytes(dst, chunk)
            first = 0
        } else {
            write_bytes_append(dst, chunk)
        }
        offset = offset + n
    }
    return offset
}
