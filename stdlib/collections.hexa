// HEXA Standard Library — collections
//
// @version 0.1.0
// @capabilities [pure]
//
// 배열/맵 유틸리티

pub fn map_arr(arr, f) {
    let result = []
    let i = 0
    while i < len(arr) {
        result.push(f(arr[i]))
        i = i + 1
    }
    result
}

pub fn filter(arr, f) {
    let result = []
    let i = 0
    while i < len(arr) {
        if f(arr[i]) {
            result.push(arr[i])
        }
        i = i + 1
    }
    result
}

pub fn reduce(arr, init, f) {
    let acc = init
    let i = 0
    while i < len(arr) {
        acc = f(acc, arr[i])
        i = i + 1
    }
    acc
}

pub fn find(arr, f) {
    let i = 0
    while i < len(arr) {
        if f(arr[i]) { return arr[i] }
        i = i + 1
    }
    void
}

pub fn find_index(arr, f) {
    let i = 0
    while i < len(arr) {
        if f(arr[i]) { return i }
        i = i + 1
    }
    -1
}

pub fn contains_val(arr, val) {
    let i = 0
    while i < len(arr) {
        if arr[i] == val { return true }
        i = i + 1
    }
    false
}

pub fn flatten(arr) {
    let result = []
    let i = 0
    while i < len(arr) {
        let inner = arr[i]
        let j = 0
        while j < len(inner) {
            result.push(inner[j])
            j = j + 1
        }
        i = i + 1
    }
    result
}

pub fn zip(a, b) {
    let result = []
    let n = if len(a) < len(b) { len(a) } else { len(b) }
    let i = 0
    while i < n {
        result.push([a[i], b[i]])
        i = i + 1
    }
    result
}

pub fn range(start, end) {
    let result = []
    let i = start
    while i < end {
        result.push(i)
        i = i + 1
    }
    result
}

pub fn sort(arr) {
    let n = len(arr)
    if n <= 1 { return arr }
    let result = arr
    let i = 0
    while i < n {
        let j = i + 1
        while j < n {
            if result[j] < result[i] {
                let tmp = result[i]
                result[i] = result[j]
                result[j] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    result
}

pub fn reverse_arr(arr) {
    let result = []
    let i = len(arr) - 1
    while i >= 0 {
        result.push(arr[i])
        i = i - 1
    }
    result
}
