// HEXA Standard Library — collections
//
// @version 0.1.0
// @capabilities [pure]
//
// 배열/맵 유틸리티

pub fn map_arr(arr, f) {
    let result = []
    let i = 0
    while i < len(arr) {
        result.push(f(arr[i]))
        i = i + 1
    }
    result
}

pub fn filter(arr, f) {
    let result = []
    let i = 0
    while i < len(arr) {
        if f(arr[i]) {
            result.push(arr[i])
        }
        i = i + 1
    }
    result
}

pub fn reduce(arr, init, f) {
    let acc = init
    let i = 0
    while i < len(arr) {
        acc = f(acc, arr[i])
        i = i + 1
    }
    acc
}

pub fn find(arr, f) {
    let i = 0
    while i < len(arr) {
        if f(arr[i]) { return arr[i] }
        i = i + 1
    }
    void
}

pub fn find_index(arr, f) {
    let i = 0
    while i < len(arr) {
        if f(arr[i]) { return i }
        i = i + 1
    }
    -1
}

pub fn contains_val(arr, val) {
    let i = 0
    while i < len(arr) {
        if arr[i] == val { return true }
        i = i + 1
    }
    false
}

pub fn flatten(arr) {
    let result = []
    let i = 0
    while i < len(arr) {
        let inner = arr[i]
        let j = 0
        while j < len(inner) {
            result.push(inner[j])
            j = j + 1
        }
        i = i + 1
    }
    result
}

pub fn zip(a, b) {
    let result = []
    let n = if len(a) < len(b) { len(a) } else { len(b) }
    let i = 0
    while i < n {
        result.push([a[i], b[i]])
        i = i + 1
    }
    result
}

pub fn range(start, end) {
    let result = []
    let i = start
    while i < end {
        result.push(i)
        i = i + 1
    }
    result
}

pub fn sort(arr) {
    let n = len(arr)
    if n <= 1 { return arr }
    let result = arr
    let i = 0
    while i < n {
        let j = i + 1
        while j < n {
            if result[j] < result[i] {
                let tmp = result[i]
                result[i] = result[j]
                result[j] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    result
}

pub fn reverse_arr(arr) {
    let result = []
    let i = len(arr) - 1
    while i >= 0 {
        result.push(arr[i])
        i = i - 1
    }
    result
}

// G5-COLLECTIONS 2026-05-06 (.roadmap.stdlib.G5) ─────────────────────────────
// counter / combinations / permutations — Python `collections.Counter` and
// `itertools.{combinations,permutations}` analogues. Closes the
// Python-bridge usage in audit_registry_integrity.py (Counter on witness
// row category) and weave_pi_p2_verifier_v3_exhaustive.py (combinations
// for NP-solver exhaustive enumeration).

// counter(items): items array → map { item_str: int_count }
// Keys are coerced to string via to_string for map compatibility.
pub fn counter(items) {
    let m = {}
    let i = 0
    while i < len(items) {
        let k = to_string(items[i])
        if has_key(m, k) {
            m[k] = m[k] + 1
        } else {
            m[k] = 1
        }
        i = i + 1
    }
    return m
}

// combinations(items, k): array of k-element subsequences (preserves
// input order). k == 0 → [[]]; k > n → []. Output size = C(n, k).
pub fn combinations(items, k) {
    let n = len(items)
    if k <= 0 { return [[]] }
    if k > n { return [] }
    if k == n {
        let only = []
        let j = 0
        while j < n { only.push(items[j]); j = j + 1 }
        return [only]
    }
    let result = []
    let idx = []
    let s = 0
    while s < k { idx.push(s); s = s + 1 }
    while true {
        let row = []
        let r = 0
        while r < k { row.push(items[idx[r]]); r = r + 1 }
        result.push(row)
        let mut i = k - 1
        while i >= 0 && idx[i] == n - k + i {
            i = i - 1
        }
        if i < 0 { break }
        idx[i] = idx[i] + 1
        let mut j = i + 1
        while j < k {
            idx[j] = idx[j - 1] + 1
            j = j + 1
        }
    }
    return result
}

// permutations(items): array of all n! permutations of items, lex order.
pub fn permutations(items) {
    let n = len(items)
    if n == 0 { return [[]] }
    if n == 1 {
        let row = [items[0]]
        return [row]
    }
    let result = []
    let i = 0
    while i < n {
        let rest = []
        let r = 0
        while r < n {
            if r != i { rest.push(items[r]) }
            r = r + 1
        }
        let sub_perms = permutations(rest)
        let p = 0
        while p < len(sub_perms) {
            let combined = [items[i]]
            let s = 0
            while s < len(sub_perms[p]) {
                combined.push(sub_perms[p][s])
                s = s + 1
            }
            result.push(combined)
            p = p + 1
        }
        i = i + 1
    }
    return result
}
