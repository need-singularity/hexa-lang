// HEXA Standard Library — log
//
// @version 0.1.0
// @capabilities [io]
//
// Closes S-NEW-LOG (.roadmap.stdlib, 2026-05-07). Replaces the ad-hoc
// `println("[XYZ] ...")` pattern scattered through self/* and stdlib/*
// with a leveled logger that supports HEXA_LOG_LEVEL env override.
//
// Surface:
//   pub fn log_set_level(level: string)        // "debug"|"info"|"warn"|"error"
//   pub fn log_debug(msg: string)
//   pub fn log_info(msg: string)
//   pub fn log_warn(msg: string)
//   pub fn log_error(msg: string)
//   pub fn log_with(level: string, msg: string)
//
// Format:
//   <ISO8601-Z>  <LEVEL>  <msg>
//   2026-05-07T04:50:12Z  INFO  starting up
//
// Env override:
//   HEXA_LOG_LEVEL=debug      — show all
//   HEXA_LOG_LEVEL=info       — info and above (default)
//   HEXA_LOG_LEVEL=warn       — warn and above
//   HEXA_LOG_LEVEL=error      — error only
//
// Implementation note: the level is held in a global mutable. Hexa's
// interp+AOT both honor module-level `let mut`. The threshold is read
// once on module entry via env, then `log_set_level` overrides it
// programmatically. ISO8601 ts is sourced from G4 (stdlib/time/iso8601)
// at the point where I2-IMPORT-PATH lands; until then we inline a
// `date -u` shell-out (acceptable on the cold log path).

let mut _log_threshold = 1   // 0=debug 1=info 2=warn 3=error

fn _level_to_int(level: string) -> int {
    if level == "debug" { return 0 }
    if level == "info"  { return 1 }
    if level == "warn"  { return 2 }
    if level == "error" { return 3 }
    return 1
}

fn _now_iso() -> string {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

fn _read_env_threshold() {
    let v = exec("printenv HEXA_LOG_LEVEL 2>/dev/null").trim()
    if len(v) > 0 { _log_threshold = _level_to_int(v) }
}

pub fn log_set_level(level: string) {
    _log_threshold = _level_to_int(level)
}

pub fn log_with(level: string, msg: string) {
    let lvl = _level_to_int(level)
    if lvl < _log_threshold { return }
    let upper = level
    if level == "debug" { upper = "DEBUG" }
    if level == "info"  { upper = "INFO " }
    if level == "warn"  { upper = "WARN " }
    if level == "error" { upper = "ERROR" }
    let mut parts = []
    parts.push(_now_iso())
    parts.push("  ")
    parts.push(upper)
    parts.push("  ")
    parts.push(msg)
    println(parts.join(""))
}

pub fn log_debug(msg: string) { log_with("debug", msg) }
pub fn log_info (msg: string) { log_with("info" , msg) }
pub fn log_warn (msg: string) { log_with("warn" , msg) }
pub fn log_error(msg: string) { log_with("error", msg) }

// Module-level env read — invoked lazily on first log call to avoid
// paying the popen cost for libraries that import `log` but don't emit.
let mut _log_env_init_done = false
fn _maybe_init_env() {
    if _log_env_init_done { return }
    _read_env_threshold()
    _log_env_init_done = true
}
