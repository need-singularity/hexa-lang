// ── Linear Layer: forward(W, b, x, out_dim, in_dim) ──
fn linear(W, b, x, out_dim: int, in_dim: int) {
    mat_add(matvec(W, x, out_dim, in_dim), b)
}

// ── MLP 2-layer ──
fn mlp2(x, W1, b1, W2, b2, in_d: int, hid: int, out_d: int) {
    let h = gelu(linear(W1, b1, x, hid, in_d))
    linear(W2, b2, h, out_d, hid)
}

// ── Transformer Block ──
fn xformer_block(x, Wq, Wk, Wv, Wo, Wff, seq: int, dim: int, heads: int, drop_rate: float, train: bool) {
    let x_ln = layer_norm(x, dim)
    let q = batch_matvec(Wq, x_ln, dim, dim, seq)
    let k = batch_matvec(Wk, x_ln, dim, dim, seq)
    let v = batch_matvec(Wv, x_ln, dim, dim, seq)
    let attn = multi_head_attention(x_ln, Wq, Wk, Wv, Wo, seq, dim, heads, true)
    let x2 = mat_add(x, dropout(attn, drop_rate, train))
    let ff = batch_matvec(Wff, gelu(layer_norm(x2, dim)), dim, dim, seq)
    mat_add(x2, dropout(ff, drop_rate, train))
}

// ── Losses ──
fn ce_loss(logits, target: int) { cross_entropy(logits, target) }
fn hex_loss(logits, target: int, phi: float, alpha: float) { cross_entropy(logits, target) - phi * alpha }

println("[nn loaded]")
