// ══════════════════════════════════════════════════════════
//
// @version 0.1.0
// @capabilities [pure, ffi]
//
// Hexa Neural Network Standard Library
// Pure Hexa implementations of NN primitives + high-level layers
//
// Primitives work on float arrays (lists). Tensor builtins are
// immutable, so element-wise ops use mutable arrays internally.
// ══════════════════════════════════════════════════════════

// ── Activation: ReLU ─────────────────────────────────────
// relu(x) = max(0, x)  element-wise
pub fn relu(x) {
    let n = len(x)
    let mut out = []
    let mut i = 0
    while i < n {
        if x[i] > 0.0 {
            out.push(x[i])
        } else {
            out.push(0.0)
        }
        i = i + 1
    }
    return out
}

// ── Activation: Sigmoid ──────────────────────────────────
// sigmoid(x) = 1 / (1 + exp(-x))  element-wise
pub fn sigmoid(x) {
    let n = len(x)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(1.0 / (1.0 + exp(-x[i])))
        i = i + 1
    }
    return out
}

// ── Activation: Tanh ─────────────────────────────────────
// tanh(x) = (exp(2x) - 1) / (exp(2x) + 1)  element-wise
pub fn tanh_activation(x) {
    let n = len(x)
    let mut out = []
    let mut i = 0
    while i < n {
        let e2x = exp(2.0 * x[i])
        out.push((e2x - 1.0) / (e2x + 1.0))
        i = i + 1
    }
    return out
}

// ── Activation: Softmax ──────────────────────────────────
// softmax(x)_i = exp(x_i - max(x)) / sum(exp(x_j - max(x)))
// Numerically stable (max subtraction prevents overflow).
pub fn softmax(x) {
    let n = len(x)
    // find max for numerical stability
    let mut mx = x[0]
    let mut i = 1
    while i < n {
        if x[i] > mx { mx = x[i] }
        i = i + 1
    }
    // exp(x - max) and sum
    let mut exps = []
    let mut sm = 0.0
    i = 0
    while i < n {
        let e = exp(x[i] - mx)
        exps.push(e)
        sm = sm + e
        i = i + 1
    }
    // normalize
    let mut out = []
    i = 0
    while i < n {
        out.push(exps[i] / sm)
        i = i + 1
    }
    return out
}

// ── GELU (tanh approximation) ────────────────────────────
// gelu(x) = 0.5 * x * (1 + tanh(sqrt(2/pi) * (x + 0.044715 * x^3)))
@pure
pub fn gelu(x_val) {
    let c = 0.7978845608
    let x3 = x_val * x_val * x_val
    let z = c * (x_val + 0.044715 * x3)
    let e2z = exp(2.0 * z)
    let t = (e2z - 1.0) / (e2z + 1.0)
    return 0.5 * x_val * (1.0 + t)
}

// ── Layer Normalization ──────────────────────────────────
// layer_norm(x, gamma, beta) normalizes x to zero mean / unit
// variance then applies affine transform: gamma * x_hat + beta.
//
// x, gamma, beta: float arrays of equal length
pub fn layer_norm(x, gamma, beta) {
    let n = len(x)
    // mean
    let mut sm = 0.0
    let mut i = 0
    while i < n {
        sm = sm + x[i]
        i = i + 1
    }
    let mean = sm / to_float(n)
    // variance
    let mut var_sum = 0.0
    i = 0
    while i < n {
        let d = x[i] - mean
        var_sum = var_sum + d * d
        i = i + 1
    }
    let variance = var_sum / to_float(n)
    let eps = 0.00001
    let std = sqrt(variance + eps)
    // normalize + affine
    let mut out = []
    i = 0
    while i < n {
        let x_hat = (x[i] - mean) / std
        out.push(gamma[i] * x_hat + beta[i])
        i = i + 1
    }
    return out
}

// ── Linear Layer: forward(W, b, x, out_dim, in_dim) ──
fn linear(W, b, x, out_dim: int, in_dim: int) {
    mat_add(matvec(W, x, out_dim, in_dim), b)
}

// ── MLP 2-layer ──
fn mlp2(x, W1, b1, W2, b2, in_d: int, hid: int, out_d: int) {
    let h_val = gelu(linear(W1, b1, x, hid, in_d))
    linear(W2, b2, h_val, out_d, hid)
}

// ── Losses ──
fn ce_loss(logits, target: int) { cross_entropy(logits, target) }
fn hex_loss(logits, target: int, phi: float, alpha: float) { cross_entropy(logits, target) - phi * alpha }

