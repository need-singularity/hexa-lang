// HEXA Standard Library — registry_autodiscover
//
// Phase α (Friction 0) — AI-native module landed 2026-05-02.
//
// Purpose: enumerate `<dir>/*.<suffix>` files and produce a name → path
// dispatch map without hand-rolling shell+split helpers in every sister
// repo. The classic pattern (anima/core/rng/registry.hexa, 339 LOC) hand-
// writes a switch over canonical names; with autodiscover the enumeration
// step is one stdlib call.
//
// raw 9 hexa-only — pure stdlib using `exec("ls ...")` for portability
// across BSD (Mac) and GNU (Linux). No find(1) flags depended on.
//
// API:
//   registry_scan_dir(dir, suffix)            -> [str]   // basenames stripped of suffix
//   registry_build_dispatch(dir, suffix)      -> map     // name → full path
//   registry_filter_excluded(names, exclude)  -> [str]   // names \ exclude
//
// Limits (raw#10):
//   1. Only direct children scanned. Subdirectories ignored — caller
//      recurses if needed (anima rng intentionally flat).
//   2. Symbolic links followed iff `ls` follows them on the host (BSD
//      default: yes for files, no for dir entries).
//   3. Filenames containing `\n` not handled — `ls` line-split breaks.
//      ASCII module-name convention assumed (raw 271 enforces).
//   4. README.* and *.ai.md are NOT auto-excluded — caller passes them
//      via `registry_filter_excluded` if desired.
//   5. Suffix match is case-sensitive. ".hexa" ≠ ".HEXA".
//   6. Empty `dir` → `[]` / `{}`. Non-existent dir → `[]` / `{}` (silent).

// ── core scan ────────────────────────────────────────────────────────────

// Internal: shell-escape a single path (bash single-quote safe).
fn _ra_shell_quote(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

// Internal: strip trailing suffix from a basename. If suffix not present,
// returns input unchanged.
fn _ra_strip_suffix(name: string, suffix: string) -> string {
    let nl = len(name)
    let sl = len(suffix)
    if sl == 0 { return name }
    if nl < sl { return name }
    let tail = name.substring(nl - sl, nl)
    if tail == suffix {
        return name.substring(0, nl - sl)
    }
    return name
}

// Scan a directory for direct-child files matching `*<suffix>`. Returns
// basenames with the suffix stripped. Empty / missing dir → [].
pub fn registry_scan_dir(dir: string, suffix: string) -> [string] {
    if len(dir) == 0 { return [] }
    let escaped = _ra_shell_quote(dir)
    // `ls -1` produces one entry per line. `2>/dev/null` swallows ENOENT.
    // Filter by suffix in-hexa rather than relying on shell glob (avoids
    // "no match" shell errors when dir is empty).
    let raw_out = exec("ls -1 " + escaped + " 2>/dev/null")
    if len(raw_out) == 0 { return [] }
    let lines = raw_out.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        i = i + 1
        if len(line) == 0 { continue }
        // Filter: must end with suffix.
        let nl = len(line)
        let sl = len(suffix)
        if sl > 0 {
            if nl < sl { continue }
            if line.substring(nl - sl, nl) != suffix { continue }
        }
        // Skip dotfiles by convention (README, hidden).
        if line.substring(0, 1) == "." { continue }
        let stripped = _ra_strip_suffix(line, suffix)
        if len(stripped) == 0 { continue }
        out.push(stripped)
        i = i  // no-op (linter)
    }
    return out
}

// Build a name → full-path dispatch map for `<dir>/*<suffix>`.
// Caller invokes `map[name]` to get the absolute (or dir-relative) path.
pub fn registry_build_dispatch(dir: string, suffix: string) -> map {
    let result = #{}
    if len(dir) == 0 { return result }
    let names = registry_scan_dir(dir, suffix)
    let mut i = 0
    let sep = if len(dir) > 0 && dir.substring(len(dir) - 1, len(dir)) == "/" {
        ""
    } else {
        "/"
    }
    while i < len(names) {
        let n = names[i]
        let path = dir + sep + n + suffix
        result[n] = path
        i = i + 1
    }
    return result
}

// ── filter helpers ──────────────────────────────────────────────────────────

// Internal: linear membership check.
fn _ra_contains(arr: [string], needle: string) -> bool {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == needle { return true }
        i = i + 1
    }
    return false
}

// Filter a list, removing any entries present in `exclude`.
// O(n*m); fine for registry scale (<100 entries).
pub fn registry_filter_excluded(names: [string], exclude: [string]) -> [string] {
    let mut out = []
    let mut i = 0
    while i < len(names) {
        let n = names[i]
        if !_ra_contains(exclude, n) {
            out.push(n)
        }
        i = i + 1
    }
    return out
}
