// HEXA Standard Library — iit_ei tests
//
// Verifies the IIT 4.0 conservative Φ lower-bound (EI via per-row KL of TPM
// against the column-mean distribution). Three test cases:
//   T1) 4-state ribozyme TPM (parity check vs hexa-bio reference)
//   T2) Uniform TPM (no causal structure → EI = 0 for all states)
//   T3) Cyclic 4-state ladder (symmetry → all 4 EI values equal)

import "iit_ei.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn close_f(a: float, b: float, tol: float) -> bool {
    let d = a - b
    if d < 0.0 { return (0.0 - d) <= tol }
    return d <= tol
}

fn check_close(name, got: float, want: float, tol: float) {
    total_count = total_count + 1
    if close_f(got, want, tol) {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

fn main() {
    // ── T1: ribozyme TPM (parity vs hexa-bio quantum_anima_phi) ────────
    let tpm1 = []
    let r10 = []; r10.push(1.0); r10.push(0.0); r10.push(0.0); r10.push(0.0)
    let r11 = []; r11.push(0.5); r11.push(0.5); r11.push(0.0); r11.push(0.0)
    let r12 = []; r12.push(0.0); r12.push(0.0); r12.push(1.0); r12.push(0.0)
    let r13 = []; r13.push(0.0); r13.push(0.3); r13.push(0.0); r13.push(0.7)
    tpm1.push(r10); tpm1.push(r11); tpm1.push(r12); tpm1.push(r13)

    let ei1 = ei_per_state_nats(tpm1)
    println("T1 ribozyme nats: s0=" + to_string(ei1[0]) +
            " s1=" + to_string(ei1[1]) +
            " s2=" + to_string(ei1[2]) +
            " s3=" + to_string(ei1[3]))
    check_close("T1.s0", ei1[0], 0.9808292530, 1.0e-5)
    check_close("T1.s1", ei1[1], 0.6019864022, 1.0e-5)
    check_close("T1.s2", ei1[2], 1.3862943611, 1.0e-5)
    check_close("T1.s3", ei1[3], 1.0920455852, 1.0e-5)

    // bits variant: rescale by 1/ln(2) ≈ 1.4426950408889634
    let ei1b = ei_per_state_bits(tpm1)
    check_close("T1.s0_bits", ei1b[0], 0.9808292530 * 1.4426950408889634, 1.0e-5)
    check_close("T1.s2_bits", ei1b[2], 1.3862943611 * 1.4426950408889634, 1.0e-5)

    // average
    let avg1 = ei_average_nats(tpm1)
    let want_avg1 = (0.9808292530 + 0.6019864022 + 1.3862943611 + 1.0920455852) / 4.0
    check_close("T1.avg", avg1, want_avg1, 1.0e-5)

    // ── T2: uniform TPM — KL(uniform || uniform) = 0 ───────────────────
    let tpm2 = []
    let r20 = []; r20.push(0.25); r20.push(0.25); r20.push(0.25); r20.push(0.25)
    let r21 = []; r21.push(0.25); r21.push(0.25); r21.push(0.25); r21.push(0.25)
    let r22 = []; r22.push(0.25); r22.push(0.25); r22.push(0.25); r22.push(0.25)
    let r23 = []; r23.push(0.25); r23.push(0.25); r23.push(0.25); r23.push(0.25)
    tpm2.push(r20); tpm2.push(r21); tpm2.push(r22); tpm2.push(r23)

    let ei2 = ei_per_state_nats(tpm2)
    println("T2 uniform nats: s0=" + to_string(ei2[0]) +
            " s1=" + to_string(ei2[1]) +
            " s2=" + to_string(ei2[2]) +
            " s3=" + to_string(ei2[3]))
    check_close("T2.s0", ei2[0], 0.0, 1.0e-12)
    check_close("T2.s1", ei2[1], 0.0, 1.0e-12)
    check_close("T2.s2", ei2[2], 0.0, 1.0e-12)
    check_close("T2.s3", ei2[3], 0.0, 1.0e-12)
    check_close("T2.avg", ei_average_nats(tpm2), 0.0, 1.0e-12)

    // ── T3: cyclic 4-state ladder — symmetry → all states equal ────────
    // Expected EI per state (computed externally with NATURAL log):
    //   avg = [0.25, 0.25, 0.25, 0.25]
    //   each row contributes 0.7·ln(0.7/0.25) + 3·0.1·ln(0.1/0.25)
    //   = 0.4458463725...  nats per state
    let tpm3 = []
    let r30 = []; r30.push(0.1); r30.push(0.7); r30.push(0.1); r30.push(0.1)
    let r31 = []; r31.push(0.1); r31.push(0.1); r31.push(0.7); r31.push(0.1)
    let r32 = []; r32.push(0.1); r32.push(0.1); r32.push(0.1); r32.push(0.7)
    let r33 = []; r33.push(0.7); r33.push(0.1); r33.push(0.1); r33.push(0.1)
    tpm3.push(r30); tpm3.push(r31); tpm3.push(r32); tpm3.push(r33)

    let ei3 = ei_per_state_nats(tpm3)
    println("T3 cyclic nats: s0=" + to_string(ei3[0]) +
            " s1=" + to_string(ei3[1]) +
            " s2=" + to_string(ei3[2]) +
            " s3=" + to_string(ei3[3]))
    let want_cyc = 0.4458463725
    check_close("T3.s0", ei3[0], want_cyc, 1.0e-5)
    check_close("T3.s1", ei3[1], want_cyc, 1.0e-5)
    check_close("T3.s2", ei3[2], want_cyc, 1.0e-5)
    check_close("T3.s3", ei3[3], want_cyc, 1.0e-5)
    // symmetry: all four values within 1e-12 of each other
    check("T3.symmetry_01", close_f(ei3[0], ei3[1], 1.0e-12))
    check("T3.symmetry_12", close_f(ei3[1], ei3[2], 1.0e-12))
    check("T3.symmetry_23", close_f(ei3[2], ei3[3], 1.0e-12))

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        println("__IIT_EI_TEST__ FAIL")
        exit(1)
    }
    println("__IIT_EI_TEST__ PASS")
}
