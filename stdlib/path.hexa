// HEXA Standard Library — path
//
// @version 0.1.0
// @capabilities [pure]
//
// Closes S-NEW-PATH (.roadmap.stdlib, 2026-05-07). Provides path
// dirname/basename/join/normalize/ext helpers. Replaces the per-module
// re-implementation pattern (ml_dirname/ml_join_path in module_loader,
// ad-hoc copies in scripts/, tool/, stdlib/portable_fs).
//
// Surface (POSIX-style; backslash-on-Windows out of scope):
//   pub fn path_dirname(p: string) -> string
//   pub fn path_basename(p: string) -> string
//   pub fn path_ext(p: string) -> string         // ".hexa" or ""
//   pub fn path_stem(p: string) -> string        // basename without ext
//   pub fn path_join(a: string, b: string) -> string
//   pub fn path_is_abs(p: string) -> bool
//   pub fn path_normalize(p: string) -> string   // collapses "//" and "/./"
//
// Bootstrap caveat: self/module_loader.hexa cannot import this module
// (loader runs before resolution). It keeps its own ml_dirname /
// ml_join_path inline. All other callers (tool/, scripts/, stdlib/*)
// migrate via grep replacement once I2-IMPORT-PATH lands.

pub fn path_is_abs(p: string) -> bool {
    if len(p) == 0 { return false }
    if p[0] == '/' { return true }
    return false
}

pub fn path_dirname(p: string) -> string {
    let n = len(p)
    if n == 0 { return "." }
    let mut i = n - 1
    // strip trailing slashes
    while i > 0 {
        if p[i] != '/' { break }
        i = i - 1
    }
    while i >= 0 {
        if p[i] == '/' {
            if i == 0 { return "/" }
            return p.substring(0, i)
        }
        i = i - 1
    }
    return "."
}

pub fn path_basename(p: string) -> string {
    let n = len(p)
    if n == 0 { return "" }
    // strip trailing slashes
    let mut end = n
    while end > 0 {
        if p[end - 1] != '/' { break }
        end = end - 1
    }
    if end == 0 { return "/" }
    let mut i = end - 1
    while i >= 0 {
        if p[i] == '/' { return p.substring(i + 1, end) }
        i = i - 1
    }
    return p.substring(0, end)
}

pub fn path_ext(p: string) -> string {
    let base = path_basename(p)
    let n = len(base)
    let mut i = n - 1
    while i > 0 {
        if base[i] == '.' { return base.substring(i, n) }
        i = i - 1
    }
    return ""
}

pub fn path_stem(p: string) -> string {
    let base = path_basename(p)
    let ext = path_ext(p)
    let n = len(base)
    let m = len(ext)
    if m == 0 { return base }
    return base.substring(0, n - m)
}

pub fn path_join(a: string, b: string) -> string {
    if len(a) == 0 { return b }
    if len(b) == 0 { return a }
    if path_is_abs(b) { return b }
    let mut parts = []
    parts.push(a)
    if a[len(a) - 1] != '/' { parts.push("/") }
    parts.push(b)
    return parts.join("")
}

pub fn path_normalize(p: string) -> string {
    if len(p) == 0 { return "." }
    let abs = path_is_abs(p)
    let segs = p.split("/")
    let mut out = []
    let mut i = 0
    while i < len(segs) {
        let s = segs[i]
        if len(s) > 0 {
            if s == "." {
                // skip
            } else if s == ".." {
                if len(out) > 0 {
                    let last = out[len(out) - 1]
                    if last != ".." { out.pop() }
                    else { out.push(s) }
                } else {
                    if !abs { out.push(s) }
                }
            } else {
                out.push(s)
            }
        }
        i = i + 1
    }
    let body = out.join("/")
    if abs {
        let mut q = []
        q.push("/")
        q.push(body)
        return q.join("")
    }
    if len(body) == 0 { return "." }
    return body
}
