// HEXA Standard Library — time/iso8601
//
// @version 0.2.0
// @capabilities [pure]
//
// ISO-8601 / RFC 3339 UTC timestamp helpers — closes G4-ISO8601
// (.roadmap.stdlib G4, 2026-05-06). Replaces the
// `datetime.now(timezone.utc).isoformat()` pattern in 45 callsites
// across hexa-bio _python_bridge/module/*.py (witness row ts SSOT).
//
// Routes to runtime builtins (libc gmtime_r/strftime/timegm reference impl):
//   utc_iso_now()                — runtime.c:hexa_utc_iso_now
//   utc_iso_format(epoch)        — runtime.c:hexa_utc_iso_format (G4)
//   utc_iso_parse(s)             — runtime.c:hexa_utc_iso_parse  (G4)
//
// Surface:
//   pub fn iso8601_utc_now() -> string
//   pub fn iso8601_format(ts: int) -> string
//   pub fn iso8601_parse(s: string) -> int
//
// Invariants:
//   - Round-trip: iso8601_parse(iso8601_format(ts)) == ts (sec res)
//   - Output always ends with "Z" (UTC explicit)
//   - Output is RFC 3339 strict (no whitespace, no implicit local tz)

pub fn iso8601_utc_now() -> string {
    return utc_iso_now()
}

pub fn iso8601_format(ts: int) -> string {
    return utc_iso_format(ts)
}

pub fn iso8601_parse(s: string) -> int {
    return utc_iso_parse(s)
}
