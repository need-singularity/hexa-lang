// HEXA Standard Library — time/iso8601 tests (G4-ISO8601)
//
// Round-trip + tz tolerance, runtime-builtin path.

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn check_eq_int(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

fn check_eq_str(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + got + " want=" + want)
    }
}

fn main() {
    // ── format known epoch ─────────────────────────────────────────────
    // 2026-05-06T00:00:00Z = epoch 1778025600.
    check_eq_str("format epoch 1778025600",
        utc_iso_format(1778025600),
        "2026-05-06T00:00:00Z")

    // ── format unix-epoch zero ─────────────────────────────────────────
    check_eq_str("format epoch 0",
        utc_iso_format(0),
        "1970-01-01T00:00:00Z")

    // ── parse strict canonical form ────────────────────────────────────
    check_eq_int("parse strict",
        utc_iso_parse("2026-05-06T00:00:00Z"),
        1778025600)

    // ── round-trip identity ────────────────────────────────────────────
    let now = time_now()
    let s = utc_iso_format(now)
    let parsed = utc_iso_parse(s)
    check_eq_int("round-trip now", parsed, now)

    // ── parse with fractional seconds (truncated) ──────────────────────
    check_eq_int("parse fractional",
        utc_iso_parse("2026-05-06T00:00:00.123456Z"),
        1778025600)

    // ── parse with explicit +00:00 ─────────────────────────────────────
    check_eq_int("parse +00:00",
        utc_iso_parse("2026-05-06T00:00:00+00:00"),
        1778025600)

    // ── parse with offset -05:00 (US Eastern wintertime) ──────────────
    // 2026-05-06T00:00:00-05:00 = 2026-05-06T05:00:00Z = 1778025600 + 18000.
    check_eq_int("parse -05:00",
        utc_iso_parse("2026-05-06T00:00:00-05:00"),
        1778043600)

    // ── output always ends with Z ──────────────────────────────────────
    let nowstr = utc_iso_now()
    check("ends with Z", nowstr[len(nowstr) - 1] == "Z")
    check("length 20", len(nowstr) == 20)

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
