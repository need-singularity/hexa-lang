// HEXA Standard Library — math/eigen_test
// Validate symmetric eigendecomposition (cyclic Jacobi) against
// canonical small cases and a seeded 16×16 random symmetric matrix.
// Roadmap 58.

import "eigen.hexa"
import "rng.hexa"

let mut pass_count = 0
let mut fail_name = ""

fn record_pass(name) {
    pass_count = pass_count + 1
    println("  ok : " + name)
}

fn record_fail(name, msg) {
    if fail_name == "" { fail_name = name }
    println("  FAIL " + name + " — " + msg)
}

fn abs_f(x) { if x < 0.0 { return 0.0 - x } else { return x } }

fn close(a, b, tol) {
    return abs_f(a - b) < tol
}

// Flatten 2D array-of-rows into a flat list of floats with 6-digit
// scaled integer precision, newline-delimited, used for determinism
// hashing. Negative values keep their sign.
fn scale6(x) {
    let mut neg = false
    let mut v = x
    if v < 0.0 { neg = true; v = 0.0 - v }
    let scaled = v * 1000000.0 + 0.5
    let t = to_int(scaled)
    if neg { return "-" + to_string(t) } else { return to_string(t) }
}

fn encode_result(vals, vecs, n) {
    let mut s = ""
    let mut i = 0
    while i < n {
        s = s + scale6(vals[i]) + "\n"
        i = i + 1
    }
    i = 0
    while i < n {
        let mut j = 0
        while j < n {
            s = s + scale6(vecs[i][j]) + "\n"
            j = j + 1
        }
        i = i + 1
    }
    return s
}

fn sha256_of(s) {
    // Write via heredoc-free shell: use printf %s to avoid escape quirks.
    let cmd = "printf '%s' " + shell_quote(s) + " | shasum -a 256 | awk '{print $1}'"
    return exec(cmd).trim()
}

// Minimal single-quote shell-quoter.
fn shell_quote(s) {
    let mut out = "'"
    let mut i = 0
    while i < len(s) {
        let ch = s.substring(i, i + 1)
        if ch == "'" {
            out = out + "'" + "\\" + "'" + "'"
        } else {
            out = out + ch
        }
        i = i + 1
    }
    out = out + "'"
    return out
}

// ── Test 1 — 2x2 diagonal ────────────────────────────────────
let name1 = "2x2 diagonal"
let A1 = [3.0, 0.0, 0.0, 1.0]
let r1 = eigh(A1, 2)
let v1 = r1[0]
let u1 = r1[1]
println(name1 + " values=" + to_string(v1) + " vectors=" + to_string(u1))
if close(v1[0], 3.0, 1.0e-10) && close(v1[1], 1.0, 1.0e-10)
    && close(u1[0][0], 1.0, 1.0e-10) && close(u1[0][1], 0.0, 1.0e-10)
    && close(u1[1][0], 0.0, 1.0e-10) && close(u1[1][1], 1.0, 1.0e-10) {
    record_pass(name1)
} else {
    record_fail(name1, "unexpected spectrum / basis")
}

// ── Test 2 — 2x2 symmetric [[2,1],[1,2]] ─────────────────────
let name2 = "2x2 symmetric [[2,1],[1,2]]"
let A2 = [2.0, 1.0, 1.0, 2.0]
let r2 = eigh(A2, 2)
let v2 = r2[0]
let u2 = r2[1]
let s2 = 0.7071067811865476
println(name2 + " values=" + to_string(v2) + " vectors=" + to_string(u2))
if close(v2[0], 3.0, 1.0e-8) && close(v2[1], 1.0, 1.0e-8)
    && close(u2[0][0], s2, 1.0e-6) && close(u2[0][1], s2, 1.0e-6)
    && close(u2[1][0], s2, 1.0e-6) && close(u2[1][1], 0.0 - s2, 1.0e-6) {
    record_pass(name2)
} else {
    record_fail(name2, "eigenvalue or sign-canonical vector mismatch")
}

// ── Test 3 — 16x16 random symmetric ───────────────────────────
let name3 = "16x16 random symmetric"
let n3 = 16
// Generate a 16x16 Gaussian matrix via stdlib/math/rng and symmetrise.
let G = randn_matrix(n3, n3, 0x13579BDF)
let mut A3 = []
let mut i = 0
while i < n3 * n3 {
    A3 = A3 + [0.0]
    i = i + 1
}
i = 0
while i < n3 {
    let mut j = 0
    while j < n3 {
        let val = 0.5 * (G[i * n3 + j] + G[j * n3 + i])
        A3[i * n3 + j] = val
        j = j + 1
    }
    i = i + 1
}

let jr = eigh_jacobi(A3, n3, 100, 1.0e-12)
let vals3 = jr[0]
let vecs3 = jr[1]
let sweeps3 = jr[2]
println(name3 + " sweeps=" + to_string(sweeps3))
println(name3 + " values=" + to_string(vals3))

// (a) orthonormality — V V^T ≈ I where V rows are eigenvectors.
let mut max_off = 0.0
let mut max_diag_err = 0.0
i = 0
while i < n3 {
    let mut j = 0
    while j < n3 {
        let mut dot = 0.0
        let mut k = 0
        while k < n3 {
            dot = dot + vecs3[i][k] * vecs3[j][k]
            k = k + 1
        }
        if i == j {
            let e = abs_f(dot - 1.0)
            if e > max_diag_err { max_diag_err = e }
        } else {
            let a = abs_f(dot)
            if a > max_off { max_off = a }
        }
        j = j + 1
    }
    i = i + 1
}
println("  orthonormality: max off-diag=" + to_string(max_off) + " max diag err=" + to_string(max_diag_err))

// (b) residual ‖A v_k − λ_k v_k‖ small
let mut max_res = 0.0
let mut idx = 0
while idx < n3 {
    let mut r = 0
    let mut res_sq = 0.0
    while r < n3 {
        let mut s = 0.0
        let mut c = 0
        while c < n3 {
            s = s + A3[r * n3 + c] * vecs3[idx][c]
            c = c + 1
        }
        let diff = s - vals3[idx] * vecs3[idx][r]
        res_sq = res_sq + diff * diff
        r = r + 1
    }
    let res = sqrt(res_sq)
    if res > max_res { max_res = res }
    idx = idx + 1
}
println("  residual max=" + to_string(max_res))

// (c) values sorted descending
let mut sorted_ok = true
i = 1
while i < n3 {
    if vals3[i - 1] < vals3[i] { sorted_ok = false }
    i = i + 1
}

let tol_rel = 1.0e-4
if max_off < tol_rel && max_diag_err < tol_rel && max_res < tol_rel && sorted_ok {
    record_pass(name3)
} else {
    let mut why = ""
    if max_off >= tol_rel { why = why + " ortho" }
    if max_diag_err >= tol_rel { why = why + " norm" }
    if max_res >= tol_rel { why = why + " residual" }
    if sorted_ok == false { why = why + " sort" }
    record_fail(name3, "tolerance breach:" + why)
}

// ── Test 4 — determinism hash ─────────────────────────────────
let name4 = "determinism (3x hash)"
let run_a = eigh(A3, n3)
let run_b = eigh(A3, n3)
let run_c = eigh(A3, n3)

let enc_a = encode_result(run_a[0], run_a[1], n3)
let enc_b = encode_result(run_b[0], run_b[1], n3)
let enc_c = encode_result(run_c[0], run_c[1], n3)

let h_a = sha256_of(enc_a)
let h_b = sha256_of(enc_b)
let h_c = sha256_of(enc_c)
println("  hash A=" + h_a)
println("  hash B=" + h_b)
println("  hash C=" + h_c)
if h_a == h_b && h_b == h_c && len(h_a) == 64 {
    record_pass(name4)
} else {
    record_fail(name4, "hash mismatch")
}

if pass_count == 4 {
    println("PASS: eigen 4/4")
    exit(0)
} else {
    println("FAIL " + fail_name + " (" + to_string(pass_count) + "/4)")
    exit(1)
}
