// HEXA Standard Library — math/rng_ctx tests

import "rng_ctx.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn check_eq_int(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

// ── T1: rng_make reproducibility ───────────────────────────
let a1 = rng_make(42)
let a2 = rng_make(42)
check("T1.same_seed.state", a1.state == a2.state)
check("T1.same_seed.seed", a1.seed == a2.seed)
check_eq_int("T1.stream_id_default", a1.stream_id, 0)

// ── T2: rng_ctx_next_u32 advances state, value in [0, 2^32) ─
let r2 = rng_ctx_next_u32(a1)
let nc2 = r2[0]
let v2 = r2[1]
check("T2.advanced", nc2.state != a1.state)
check("T2.u32_lower", v2 >= 0)
check("T2.u32_upper", v2 <= 0xFFFFFFFF)
check("T2.seed_preserved", nc2.seed == a1.seed)

// ── T3: same seed → same first u32 ─────────────────────────
let b1 = rng_make(42)
let rb = rng_ctx_next_u32(b1)
check("T3.deterministic", rb[1] == v2)

// ── T4: different seed → different first u32 (overwhelming prob) ──
let c1 = rng_make(43)
let rc = rng_ctx_next_u32(c1)
check("T4.seed_changes_output", rc[1] != v2)

// ── T5: rng_fork determinism ───────────────────────────────
let parent = rng_make(100)
let f1 = rng_fork(parent, 7)
let f2 = rng_fork(parent, 7)
check("T5.fork_deterministic", f1.state == f2.state)
check_eq_int("T5.fork_stream_id", f1.stream_id, 7)

// ── T6: different sub_ids → different streams ──────────────
let g0 = rng_fork(parent, 0)
let g1 = rng_fork(parent, 1)
let g2 = rng_fork(parent, 2)
check("T6.fork_0_vs_1", g0.state != g1.state)
check("T6.fork_1_vs_2", g1.state != g2.state)
check("T6.fork_0_vs_2", g0.state != g2.state)

// First draws should differ across forks.
let d0 = rng_ctx_next_u32(g0)[1]
let d1 = rng_ctx_next_u32(g1)[1]
let d2 = rng_ctx_next_u32(g2)[1]
check("T6.draw_0_vs_1", d0 != d1)
check("T6.draw_1_vs_2", d1 != d2)

// ── T7: rng_ensemble shape + determinism ───────────────────
let ens_a = rng_ensemble(77, 4)
let ens_b = rng_ensemble(77, 4)
check_eq_int("T7.ensemble_len", len(ens_a), 4)
let mut i = 0
let mut all_eq = true
while i < 4 {
    if ens_a[i].state != ens_b[i].state { all_eq = false }
    if ens_a[i].stream_id != i { all_eq = false }
    i = i + 1
}
check("T7.ensemble_deterministic", all_eq)

// Pairwise distinct states (high probability with xxh64 mixing).
let mut all_distinct = true
i = 0
while i < 4 {
    let mut j = i + 1
    while j < 4 {
        if ens_a[i].state == ens_a[j].state { all_distinct = false }
        j = j + 1
    }
    i = i + 1
}
check("T7.ensemble_distinct", all_distinct)

// ── T8: float01 in [0, 1) ──────────────────────────────────
let fr = rng_ctx_next_float01(rng_make(1))
let fv = fr[1]
check("T8.float_lower", fv >= 0.0)
check("T8.float_upper", fv < 1.0)

// ── T9: gauss returns two samples ──────────────────────────
let gr = rng_ctx_next_gauss(rng_make(1))
check("T9.gauss_len", len(gr) == 3)
check("T9.gauss_state_advanced", gr[0].state != rng_make(1).state)

// ── Summary ─────────────────────────────────────────────────
if pass_count == total_count {
    println("PASS: rng_ctx " + to_string(pass_count) + "/" + to_string(total_count))
} else {
    println("FAIL: rng_ctx " + to_string(pass_count) + "/" + to_string(total_count) + " first_fail=" + failed_name)
}
