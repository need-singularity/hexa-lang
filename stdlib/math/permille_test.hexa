// HEXA Standard Library — math/permille tests

import "permille.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn check_eq_int(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

fn check_eq_str(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got='" + got + "' want='" + want + "'")
    }
}

// ── T1: constructors ──────────────────────────────────────
check_eq_int("T1.pm(1)",          pm(1).pm,                 1000)
check_eq_int("T1.pm(0)",          pm(0).pm,                 0)
check_eq_int("T1.pm(-3)",         pm(0 - 3).pm,             0 - 3000)
check_eq_int("T1.permille(123)",  pm_of_permille(123).pm,   123)
check_eq_int("T1.percent(50)",    pm_of_percent(50).pm,     500)
check_eq_int("T1.percent(-25)",   pm_of_percent(0 - 25).pm, 0 - 250)

// ── T2: ratio rounding (half-away-from-zero) ──────────────
check_eq_int("T2.ratio(1/3)",     pm_of_ratio(1, 3).pm,     333)   // 1000/3 = 333.33 → 333
check_eq_int("T2.ratio(2/3)",     pm_of_ratio(2, 3).pm,     667)   // 2000/3 = 666.66 → 667
check_eq_int("T2.ratio(-1/3)",    pm_of_ratio(0 - 1, 3).pm, 0 - 333)
check_eq_int("T2.ratio(1/2)",     pm_of_ratio(1, 2).pm,     500)
check_eq_int("T2.ratio(div_zero)", pm_of_ratio(5, 0).pm,    0)

// ── T3: float conversion round-trip ───────────────────────
check_eq_int("T3.of_float(0.5)",   pm_of_float(0.5).pm,    500)
check_eq_int("T3.of_float(-0.333)", pm_of_float(0.0 - 0.333).pm, 0 - 333)
check_eq_int("T3.of_float(3.14159)", pm_of_float(3.14159).pm,    3142)  // rounded

// ── T4: arithmetic ────────────────────────────────────────
let a = pm(2)                 // 2.000
let b = pm_of_percent(25)     // 0.250
check_eq_int("T4.add",        pm_add(a, b).pm,         2250)
check_eq_int("T4.sub",        pm_sub(a, b).pm,         1750)
check_eq_int("T4.mul_int",    pm_mul_int(a, 3).pm,     6000)   // 2 × 3 = 6.000
check_eq_int("T4.div_int_exact",  pm_div_int(pm(6), 2).pm, 3000)
check_eq_int("T4.div_int_round", pm_div_int(pm_of_permille(1000), 3).pm, 333)
check_eq_int("T4.div_int_zero",  pm_div_int(a, 0).pm,     0)

// ── T5: pm × pm (rescale by /1000) ────────────────────────
// 0.500 × 0.250 = 0.125  (500 × 250 = 125000, /1000 = 125)
check_eq_int("T5.mul_pm.025_0.5", pm_mul_pm(pm_of_permille(500), pm_of_permille(250)).pm, 125)
// 1/3 × 3.000 ≈ 1.000 (333 × 3000 = 999000, /1000 = 999)
check_eq_int("T5.mul_pm.1/3×3",   pm_mul_pm(pm_of_permille(333), pm(3)).pm, 999)
// banker-style half-away: 100 × 5 = 500000 pm² → /1000 = 500
check_eq_int("T5.mul_pm.0.1×0.005", pm_mul_pm(pm_of_permille(100), pm_of_permille(5)).pm, 1)  // 100*5=500 → /1000 round = 1? 500/1000=0.5 half away = 1

// ── T6: neg / clamp / cmp / eq ────────────────────────────
check_eq_int("T6.neg",    pm_neg(pm(5)).pm, 0 - 5000)
let lo = pm(0)
let hi = pm(1)
check_eq_int("T6.clamp_in",  pm_clamp(pm_of_permille(500), lo, hi).pm, 500)
check_eq_int("T6.clamp_lo",  pm_clamp(pm_of_permille(0 - 200), lo, hi).pm, 0)
check_eq_int("T6.clamp_hi",  pm_clamp(pm_of_permille(1500), lo, hi).pm, 1000)
check("T6.eq_true",   pm_eq(pm_of_permille(250), pm_of_permille(250)))
check("T6.eq_false",  !pm_eq(pm_of_permille(250), pm_of_permille(251)))
check_eq_int("T6.cmp_lt", pm_cmp(pm_of_permille(100), pm_of_permille(200)), -1)
check_eq_int("T6.cmp_gt", pm_cmp(pm_of_permille(300), pm_of_permille(200)),  1)
check_eq_int("T6.cmp_eq", pm_cmp(pm_of_permille(200), pm_of_permille(200)),  0)

// ── T7: conversions ───────────────────────────────────────
check_eq_int("T7.to_int_floor_pos",  pm_to_int_floor(pm_of_permille(1750)),     1)
check_eq_int("T7.to_int_floor_neg",  pm_to_int_floor(pm_of_permille(0 - 1750)), 0 - 2)
check_eq_int("T7.to_int_floor_exact", pm_to_int_floor(pm_of_permille(0 - 2000)), 0 - 2)

// to_float round-trip within rounding tolerance
let f_back = pm_to_float(pm_of_float(0.125))
let diff = if f_back >= 0.125 { f_back - 0.125 } else { 0.125 - f_back }
check("T7.to_float_roundtrip", diff < 0.001)

// ── T8: to_string formatting ──────────────────────────────
check_eq_str("T8.str_pos_whole",   pm_to_string(pm(3)),                 "3.000")
check_eq_str("T8.str_pos_frac",    pm_to_string(pm_of_permille(1234)),  "1.234")
check_eq_str("T8.str_pad",         pm_to_string(pm_of_permille(5)),     "0.005")
check_eq_str("T8.str_neg",         pm_to_string(pm_of_permille(0 - 1234)), "-1.234")
check_eq_str("T8.str_zero",        pm_to_string(pm(0)),                 "0.000")

// ── Summary ─────────────────────────────────────────────────
if pass_count == total_count {
    println("PASS: permille " + to_string(pass_count) + "/" + to_string(total_count))
} else {
    println("FAIL: permille " + to_string(pass_count) + "/" + to_string(total_count) + " first_fail=" + failed_name)
}
