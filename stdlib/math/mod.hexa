// stdlib/math/mod.hexa — package entry point.
// Re-exports float (transcendentals + classifiers), eigen, rng_ctx,
// permille. import "stdlib/math" as m → m.lgamma_f(0.5), m.eigen_*, etc.
//
// NB: math.hexa (top-level, integer-arithmetic surface) is the *flat*
// counterpart — that file is imported separately as `stdlib/math.hexa`
// without going through this directory.

import "stdlib/math/float.hexa"
import "stdlib/math/eigen.hexa"
import "stdlib/math/rng_ctx.hexa"
import "stdlib/math/rng.hexa"
import "stdlib/math/permille.hexa"
