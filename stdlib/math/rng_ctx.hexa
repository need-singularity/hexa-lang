// HEXA Standard Library — math/rng_ctx
//
// @version 0.1.0
// @capabilities [pure, randomness]
//
// Seed-propagating RNG context for deterministic multi-seed ensembles.
//
// Builds on stdlib/math/rng (LCG + Box-Muller) and stdlib/hash/xxhash
// (stream-split mixer). A RngCtx carries its own state; `rng_fork`
// produces a child whose sequence is statistically independent of the
// parent for each distinct `sub_id`, reproducible from the parent seed.
//
// Public API:
//   pub fn rng_make(seed) -> RngCtx
//   pub fn rng_fork(ctx, sub_id) -> RngCtx
//   pub fn rng_ensemble(seed, n) -> array<RngCtx>
//   pub fn rng_ctx_next_u32(ctx) -> [new_ctx, u32]
//   pub fn rng_ctx_next_float01(ctx) -> [new_ctx, float]
//   pub fn rng_ctx_next_gauss(ctx) -> [new_ctx, z0, z1]
//
// Determinism guarantees:
//   * Same (seed, sub_id) path → byte-identical RngCtx and output stream.
//   * Different sub_ids mix via xxh64 — sequences decorrelate without
//     relying on the parent's advanced state.
//   * No hidden globals.

import "rng.hexa"
import "../hash/xxhash.hexa"

pub struct RngCtx {
    seed: int,
    state: int,
    stream_id: int
}

pub fn rng_make(seed: int) -> RngCtx {
    let s = seed & 0xFFFFFFFF
    return RngCtx { seed: s, state: s, stream_id: 0 }
}

// Little-endian 8-byte encode of a 32-bit value (high 32 bits = 0).
fn _le8_bytes(out: array, v_in: int) -> array {
    let mut v = v_in & 0xFFFFFFFF
    let mut i = 0
    while i < 8 {
        out.push(v & 0xFF)
        v = v >> 8
        i = i + 1
    }
    return out
}

// xxh64(seed_le ++ stream_id_le), return low 32 bits as new LCG seed.
fn _mix_seed(seed: int, stream_id: int) -> int {
    let mut bytes = []
    bytes = _le8_bytes(bytes, seed)
    bytes = _le8_bytes(bytes, stream_id)
    let h = xxh64(bytes, 0)
    return h[1] & 0xFFFFFFFF
}

pub fn rng_fork(ctx: RngCtx, sub_id: int) -> RngCtx {
    let mixed = _mix_seed(ctx.seed, sub_id)
    return RngCtx { seed: mixed, state: mixed, stream_id: sub_id }
}

pub fn rng_ctx_next_u32(ctx: RngCtx) -> array {
    let r = lcg_u32(ctx.state)
    let nc = RngCtx { seed: ctx.seed, state: r[0], stream_id: ctx.stream_id }
    return [nc, r[1]]
}

pub fn rng_ctx_next_float01(ctx: RngCtx) -> array {
    let r = lcg_float01(ctx.state)
    let nc = RngCtx { seed: ctx.seed, state: r[0], stream_id: ctx.stream_id }
    return [nc, r[1]]
}

pub fn rng_ctx_next_gauss(ctx: RngCtx) -> array {
    let r = randn_box_muller(ctx.state)
    let nc = RngCtx { seed: ctx.seed, state: r[0], stream_id: ctx.stream_id }
    return [nc, r[1], r[2]]
}

pub fn rng_ensemble(seed: int, n: int) -> array {
    let parent = rng_make(seed)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(rng_fork(parent, i))
        i = i + 1
    }
    return out
}
