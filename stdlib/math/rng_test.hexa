// HEXA Standard Library — math/rng_test
// Deterministic tests for lcg_next and randn_matrix.

import "rng.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn check_eq_int(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

// ── Canonical LCG sequence (NR constants, m=2^32, seed=42) ──────
let s0 = 42
let s1 = lcg_next(s0)
let s2 = lcg_next(s1)
let s3 = lcg_next(s2)
println("lcg_next(42)        = " + to_string(s1))
println("lcg_next(lcg_next)  = " + to_string(s2))
println("lcg_next third step = " + to_string(s3))
check_eq_int("lcg step 1", s1, 1083814273)
check_eq_int("lcg step 2", s2, 378494188)
check_eq_int("lcg step 3", s3, 2479403867)

// ── lcg_float01 in [0,1) ──
let fp = lcg_float01(42)
check("lcg_float01 returns 2", len(fp) == 2)
check("lcg_float01 in [0,1)", fp[1] >= 0.0 && fp[1] < 1.0)

// ── randn_box_muller returns 3 values ──
let rp = randn_box_muller(42)
check("randn_box_muller len", len(rp) == 3)

// ── randn_matrix determinism: 3 runs identical ──
let seed = 20260421
let m1 = randn_matrix(16, 16, seed)
let m2 = randn_matrix(16, 16, seed)
let m3 = randn_matrix(16, 16, seed)

check("matrix size 16x16", len(m1) == 256)
check("matrix size m2", len(m2) == 256)
check("matrix size m3", len(m3) == 256)

println("randn_matrix first 4:")
println("  [0] = " + to_string(m1[0]))
println("  [1] = " + to_string(m1[1]))
println("  [2] = " + to_string(m1[2]))
println("  [3] = " + to_string(m1[3]))

// Determinism: all 256 elements identical across 3 runs.
let mut all_eq_12 = true
let mut all_eq_13 = true
let mut i = 0
while i < 256 {
    if m1[i] != m2[i] { all_eq_12 = false }
    if m1[i] != m3[i] { all_eq_13 = false }
    i = i + 1
}
check("randn_matrix determinism run1==run2", all_eq_12)
check("randn_matrix determinism run1==run3", all_eq_13)

if pass_count == total_count {
    println("PASS: rng " + to_string(pass_count) + "/" + to_string(total_count))
    exit(0)
} else {
    println("FAIL " + failed_name + " (" + to_string(pass_count) + "/" + to_string(total_count) + ")")
    exit(1)
}
