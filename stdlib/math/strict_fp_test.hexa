// HEXA Standard Library — math/strict_fp_test
//
// B20 / roadmap 55 Phase 1 — @strict_fp byte-identity smoke.
//
// Exercises:
//   1. A @strict_fp-annotated fn doing `a*b + c` (FMA gate must fire),
//      `1.0 / x` (reciprocal, no -fno-reciprocal-math rewrite), and a
//      transcendental (sin/cos — Phase 2 will vendor crlibm; same-
//      substrate same-process is the Phase 1 bar).
//   2. A non-@strict_fp control fn doing the same arithmetic. The
//      codegen-side FMA gate is conditional; control result need not
//      byte-match strict result (and in fact will not on hardware
//      with hw-FMA). The control exists to prove we didn't globally
//      disable fusion.
//   3. Calls each fn twice and asserts byte-identical to_string()
//      output run-to-run inside the same process.
//
// Phase 2 scope not exercised here:
//   - Cross-substrate (arm64 macOS vs x86_64 linux) transcendental
//     identity — requires crlibm vendoring.
//   - Multi-thread FP control-word inheritance — requires the
//     pthread_create trampoline.

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check_str_eq(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + got + " want=" + want)
    }
}

// ── @strict_fp path ────────────────────────────────────────────
// FMA fusion sites (CompoundAssign `acc += a*b` and BinOp `(a*b)+c`)
// are suppressed in codegen for this fn; strict IEEE two-roundings.
@strict_fp
fn strict_mix(x, y, z) {
    // (a*b) + c site — codegen_c2.hexa ~line 2502.
    let s1 = x * y + z
    // 1.0 / x — `-fno-reciprocal-math` prevents clang from rewriting
    // (a / b) * b → a etc. when both ops appear in the same TU.
    let s2 = 1.0 / (x + 0.5)
    // transcendental — libm sin/cos. Same-process same-substrate
    // byte-stable by construction (same libm call); Phase 2 crlibm
    // extends this to cross-substrate.
    let s3 = sin(x) + cos(y)
    // Compound-assign FMA site — codegen_c2.hexa ~line 1722.
    let mut acc = z
    acc += x * y
    acc += s1 * s2
    return s1 + s2 + s3 + acc
}

// ── Non-strict control ────────────────────────────────────────
// Same body shape; codegen should emit hexa_fma(…) at the two
// fusion sites. Result is allowed to differ from strict_mix.
fn relaxed_mix(x, y, z) {
    let s1 = x * y + z
    let s2 = 1.0 / (x + 0.5)
    let s3 = sin(x) + cos(y)
    let mut acc = z
    acc += x * y
    acc += s1 * s2
    return s1 + s2 + s3 + acc
}

// ── Drive the tests ───────────────────────────────────────────
let x = 1.2345
let y = 2.7182818284
let z = 0.1

let r1 = strict_mix(x, y, z)
let r2 = strict_mix(x, y, z)
let s1 = to_string(r1)
let s2 = to_string(r2)
println("strict_mix run1 = " + s1)
println("strict_mix run2 = " + s2)
check_str_eq("strict_mix byte-identical", s1, s2)

let c1 = relaxed_mix(x, y, z)
let c2 = relaxed_mix(x, y, z)
let cs1 = to_string(c1)
let cs2 = to_string(c2)
println("relaxed_mix run1 = " + cs1)
println("relaxed_mix run2 = " + cs2)
check_str_eq("relaxed_mix byte-identical", cs1, cs2)

// Report. Note: we do NOT require strict == relaxed. On hardware
// with hw-FMA (arm64, modern x86_64) they will differ by ≤1 ULP —
// that divergence is exactly the evidence the FMA gate is working.
println("strict vs relaxed delta = " + to_string(r1 - c1))

if pass_count == total_count {
    println("PASS: strict_fp " + to_string(pass_count) + "/" + to_string(total_count))
    exit(0)
} else {
    println("FAIL " + failed_name + " (" + to_string(pass_count) + "/" + to_string(total_count) + ")")
    exit(1)
}
