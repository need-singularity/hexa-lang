// HEXA Standard Library — math/float G1-FLOAT-PRIM smoke test.
//
// Self-contained — does NOT import float.hexa to keep the build single-
// file. Validates that runtime + codegen + interpreter dispatch lgamma /
// isnan / isinf / isfinite correctly. Module-level pi()/e()/tau() and the
// log_beta_binomial wrapper are tested separately under the import linker
// harness once cross-file `import` is wired into the AOT build path.

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn close_f(a: float, b: float, tol: float) -> bool {  // libc collision avoidance
    let d = a - b
    if d < 0.0 { return (0.0 - d) <= tol }
    return d <= tol
}

fn main() {
    // ── lgamma reference values (libm reference) ───────────────────────
    // lgamma(1) = 0, lgamma(2) = 0, lgamma(0.5) = log(√π) ≈ 0.5723649429
    // lgamma(10) = log(9!) = log(362880) ≈ 12.8018274801
    check("lgamma(1)", close_f(lgamma(1.0), 0.0, 1.0e-9))
    check("lgamma(2)", close_f(lgamma(2.0), 0.0, 1.0e-9))
    check("lgamma(0.5)", close_f(lgamma(0.5), 0.5723649429247, 1.0e-9))
    check("lgamma(10)", close_f(lgamma(10.0), 12.8018274801, 1.0e-7))

    // ── classifiers ────────────────────────────────────────────────────
    let inf_v = 1.0 / 0.0
    let nan_v = 0.0 / 0.0
    check("isnan(nan)", isnan(nan_v))
    check("isnan(1.0)", isnan(1.0) == false)
    check("isinf(inf)", isinf(inf_v))
    check("isinf(1.0)", isinf(1.0) == false)
    check("isfinite(1.0)", isfinite(1.0))
    check("isfinite(inf)", isfinite(inf_v) == false)
    check("isfinite(nan)", isfinite(nan_v) == false)

    // ── log_beta ratio sanity (Beta-Binomial conjugate, no C(n,s)) ─────
    // Beta(1,1) prior, n=10, s=5: log [B(6,6) / B(1,1)] = log(1/2772),
    // since Γ(6)·Γ(6)/Γ(12) = 14400/39916800 = 1/2772 and B(1,1)=1.
    // (Adding the binomial coefficient C(10,5)=252 recovers the
    //  uniform-marginal 1/11 identity — kept out of this primitive
    //  test because lgamma(int) is what we're stressing here.)
    let n_f = 10.0
    let s_f = 5.0
    let a = 1.0
    let b = 1.0
    let log_num = lgamma(a + s_f) + lgamma(b + n_f - s_f) - lgamma(a + b + n_f)
    let log_den = lgamma(a) + lgamma(b) - lgamma(a + b)
    let lbb = log_num - log_den
    let target = 0.0 - log(2772.0)
    check("log_beta_ratio(B(6,6)/B(1,1)) == -log(2772)", close_f(lbb, target, 1.0e-9))

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
