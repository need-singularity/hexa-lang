// ── Adam: returns [new_params, new_m, new_v] as flat array ──
fn adam(params, grads, m, v, lr: float, t: int) {
    adam_step(params, grads, m, v, lr, 0.9, 0.999, 0.00000001, t)
}

// ── LR with warmup + cosine ──
fn scheduled_lr(base: float, step: int, total: int, warmup: int) {
    warmup_lr(cosine_lr(base, step, total, base * 0.1), step, warmup)
}

// ── Safe gradient update ──
fn safe_update(params, grads, m, v, lr: float, t: int, max_norm: float) {
    let clipped = grad_clip_norm(grads, max_norm)
    adam(params, clipped, m, v, lr, t)
}

println("[optim loaded]")
