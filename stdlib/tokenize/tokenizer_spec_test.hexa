// HEXA Standard Library — tokenize/tokenizer_spec tests

import "tokenizer_spec.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL: " + name)
    }
}

// ── T1 happy-path parse (BPE with specials) ───────────────────────────
let bpe_json = "{\"version\":\"1.0\",\"model\":{\"type\":\"BPE\",\"vocab\":{\"<unk>\":0,\"hello\":1,\"world\":2,\"!\":3},\"merges\":[\"h e\",\"he l\",\"hel l\",\"hell o\"]},\"added_tokens\":[{\"id\":100,\"content\":\"<pad>\",\"special\":true},{\"id\":101,\"content\":\"<s>\",\"special\":true}]}"
let spec1 = parse_tokenizer(bpe_json)

check("T1a version=1.0", spec1.version == "1.0")
check("T1b model_type=BPE", spec1.model_type == "BPE")
check("T1c vocab_size=4", vocab_size(spec1) == 4)
check("T1d merges len=4", len(spec1.merges) == 4)
check("T1e added_tokens len=2", len(spec1.added_tokens) == 2)
check("T1f pad_token=<pad>", spec1.pad_token == "<pad>")
check("T1g bos_token=<s>", spec1.bos_token == "<s>")
check("T1h eos_token=empty (not declared)", spec1.eos_token == "")
check("T1i unk_token=empty (unk in vocab, not added_tokens)", spec1.unk_token == "")

// ── T2 encode_token ────────────────────────────────────────────────────
check("T2a encode(hello)=1", encode_token(spec1, "hello") == 1)
check("T2b encode(<pad>)=100", encode_token(spec1, "<pad>") == 100)
check("T2c encode(unknown)=-1", encode_token(spec1, "zzz_missing") == -1)
check("T2d encode(<unk>)=0 (from vocab)", encode_token(spec1, "<unk>") == 0)

// ── T3 decode_id (round-trip) ──────────────────────────────────────────
check("T3a decode(1)=hello", decode_id(spec1, 1) == "hello")
check("T3b decode(100)=<pad>", decode_id(spec1, 100) == "<pad>")
check("T3c decode(999)=empty", decode_id(spec1, 999) == "")

// ── T4 is_special ──────────────────────────────────────────────────────
check("T4a is_special(100)=true (<pad>)", is_special(spec1, 100) == true)
check("T4b is_special(1)=false (hello, not in added)", is_special(spec1, 1) == false)

// ── T5 validate happy path ─────────────────────────────────────────────
let errs1 = validate_tokenizer(spec1)
check("T5 valid BPE produces 0 errors", len(errs1) == 0)

// ── T6 validation errors ───────────────────────────────────────────────

// E1 unknown model_type
let bad_type = "{\"model\":{\"type\":\"Gibberish\",\"vocab\":{\"a\":0}},\"added_tokens\":[]}"
let errs2 = validate_tokenizer(parse_tokenizer(bad_type))
check("T6a E1 unknown model_type", len(errs2) >= 1 && errs2[0] == "E1")

// E2 empty vocab
let empty_vocab = "{\"model\":{\"type\":\"BPE\",\"vocab\":{},\"merges\":[\"a b\"]},\"added_tokens\":[]}"
let errs3 = validate_tokenizer(parse_tokenizer(empty_vocab))
let mut has_e2 = false
let mut k = 0
while k < len(errs3) { if errs3[k] == "E2" { has_e2 = true } k = k + 1 }
check("T6b E2 empty vocab", has_e2)

// E3 BPE with empty merges
let bpe_no_merges = "{\"model\":{\"type\":\"BPE\",\"vocab\":{\"a\":0,\"b\":1},\"merges\":[]},\"added_tokens\":[]}"
let errs4 = validate_tokenizer(parse_tokenizer(bpe_no_merges))
let mut has_e3 = false
let mut k2 = 0
while k2 < len(errs4) { if errs4[k2] == "E3" { has_e3 = true } k2 = k2 + 1 }
check("T6c E3 BPE missing merges", has_e3)

// E4 added_token id collides (id 0 is <unk> but added_token at 0 is different)
let collision_json = "{\"model\":{\"type\":\"WordLevel\",\"vocab\":{\"<unk>\":0,\"hello\":1}},\"added_tokens\":[{\"id\":0,\"content\":\"<sep>\",\"special\":true}]}"
let errs5 = validate_tokenizer(parse_tokenizer(collision_json))
let mut has_e4 = false
let mut k3 = 0
while k3 < len(errs5) { if errs5[k3] == "E4" { has_e4 = true } k3 = k3 + 1 }
check("T6d E4 added_token id collision", has_e4)

// ── T7 WordLevel (no merges required) ──────────────────────────────────
let wl_json = "{\"model\":{\"type\":\"WordLevel\",\"vocab\":{\"hi\":0,\"there\":1}},\"added_tokens\":[]}"
let spec_wl = parse_tokenizer(wl_json)
check("T7a WordLevel parse OK", spec_wl.model_type == "WordLevel")
check("T7b WordLevel no merges required", len(validate_tokenizer(spec_wl)) == 0)

// ── T8 vocab round-trip (encode . decode = identity) ───────────────────
let toks = ["hello", "world", "!"]
let mut all_rt = true
let mut t = 0
while t < len(toks) {
    let id = encode_token(spec1, toks[t])
    let back = decode_id(spec1, id)
    if back != toks[t] { all_rt = false }
    t = t + 1
}
check("T8 encode·decode round-trip", all_rt)

// ── Report ─────────────────────────────────────────────────────────────
if failed_name == "" {
    println("PASS: tokenizer_spec " + to_string(pass_count) + "/" + to_string(total_count))
} else {
    println("FAIL: first failure = " + failed_name + " (" + to_string(pass_count) + "/" + to_string(total_count) + ")")
}
