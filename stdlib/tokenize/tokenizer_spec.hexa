// HEXA Standard Library — tokenize/tokenizer_spec
//
// @version 0.1.0
// @capabilities [pure, fs_read]
//
// Loader for HuggingFace-style tokenizer.json (BPE / WordLevel / WordPiece / Unigram).
//
// Motivation: base model swap-in (ext-7) needs a reproducible way to read
// a tokenizer manifest without pulling in a python/rust dependency. This
// module provides struct + parser + O(1) lookup. Full BPE encoding (apply
// merges to arbitrary text) is deliberately out of scope — the loader is
// the swap-in primitive; encoding lives in a downstream module.
//
// Public API:
//   pub fn parse_tokenizer(json_text: string) -> TokenizerSpec
//   pub fn load_tokenizer(path: string)        -> TokenizerSpec
//   pub fn encode_token(spec, token: string)   -> int     (-1 if missing)
//   pub fn decode_id(spec, id: int)            -> string  ("" if missing)
//   pub fn vocab_size(spec)                    -> int
//   pub fn is_special(spec, id: int)           -> bool
//   pub fn validate_tokenizer(spec)            -> [string]
//
// Validation error codes:
//   E1  model_type unknown (must be BPE|WordPiece|Unigram|WordLevel)
//   E2  vocab empty
//   E3  BPE model with empty merges
//   E4  added_token id collides with vocab id
//   E5  vocab contains duplicate ids

pub struct AddedToken {
    id: int,
    content: string,
    special: bool
}

pub struct TokenizerSpec {
    version: string,
    model_type: string,
    vocab: map,             // token (string) -> id (int)
    inv_vocab: map,         // string(id) -> token (string)  (for O(1) decode)
    merges: [string],
    added_tokens: [AddedToken],
    unk_token: string,
    bos_token: string,
    eos_token: string,
    pad_token: string
}

fn _s(m, key: string) -> string {
    if has_key(m, key) { return to_string(m[key]) }
    return ""
}

fn _i(m, key: string) -> int {
    if !has_key(m, key) { return 0 }
    return to_int(m[key])
}

fn _b(m, key: string) -> bool {
    if !has_key(m, key) { return false }
    let v = m[key]
    if to_string(v) == "true" { return true }
    return false
}

fn _parse_added(am) -> AddedToken {
    return AddedToken {
        id:      _i(am, "id"),
        content: _s(am, "content"),
        special: _b(am, "special")
    }
}

fn _special_token_from(added: [AddedToken], needle: string) -> string {
    // Find first added_token whose content matches a conventional marker.
    // Fallback to empty if absent — caller uses "" to signal "not declared".
    let mut i = 0
    while i < len(added) {
        if added[i].content == needle { return added[i].content }
        i = i + 1
    }
    return ""
}

pub fn parse_tokenizer(json_text: string) -> TokenizerSpec {
    let obj = json_parse(json_text)

    let version = _s(obj, "version")

    let mut model_type = ""
    let mut vocab = json_parse("{}")
    let mut merges = []
    if has_key(obj, "model") {
        let mdl = obj["model"]
        model_type = _s(mdl, "type")
        if has_key(mdl, "vocab") { vocab = mdl["vocab"] }
        if has_key(mdl, "merges") {
            let arr = mdl["merges"]
            let mut i = 0
            while i < len(arr) {
                merges.push(to_string(arr[i]))
                i = i + 1
            }
        }
    }

    let mut added = []
    if has_key(obj, "added_tokens") {
        let arr = obj["added_tokens"]
        let mut i = 0
        while i < len(arr) {
            added.push(_parse_added(arr[i]))
            i = i + 1
        }
    }

    // Build inv_vocab for O(1) decode by id.
    let mut inv = json_parse("{}")
    let keys = map_keys(vocab)
    let mut i = 0
    while i < len(keys) {
        let tok = keys[i]
        let id = to_int(vocab[tok])
        inv[to_string(id)] = tok
        i = i + 1
    }

    return TokenizerSpec {
        version:      version,
        model_type:   model_type,
        vocab:        vocab,
        inv_vocab:    inv,
        merges:       merges,
        added_tokens: added,
        unk_token:    _special_token_from(added, "<unk>"),
        bos_token:    _special_token_from(added, "<s>"),
        eos_token:    _special_token_from(added, "</s>"),
        pad_token:    _special_token_from(added, "<pad>")
    }
}

pub fn load_tokenizer(path: string) -> TokenizerSpec {
    let text = read_file(path)
    return parse_tokenizer(text)
}

pub fn encode_token(spec: TokenizerSpec, token: string) -> int {
    if has_key(spec.vocab, token) { return to_int(spec.vocab[token]) }
    // Fall back to added_tokens table (specials).
    let mut i = 0
    while i < len(spec.added_tokens) {
        if spec.added_tokens[i].content == token { return spec.added_tokens[i].id }
        i = i + 1
    }
    return -1
}

pub fn decode_id(spec: TokenizerSpec, id: int) -> string {
    let key = to_string(id)
    if has_key(spec.inv_vocab, key) { return to_string(spec.inv_vocab[key]) }
    let mut i = 0
    while i < len(spec.added_tokens) {
        if spec.added_tokens[i].id == id { return spec.added_tokens[i].content }
        i = i + 1
    }
    return ""
}

pub fn vocab_size(spec: TokenizerSpec) -> int {
    return len(map_keys(spec.vocab))
}

pub fn is_special(spec: TokenizerSpec, id: int) -> bool {
    let mut i = 0
    while i < len(spec.added_tokens) {
        if spec.added_tokens[i].id == id { return spec.added_tokens[i].special }
        i = i + 1
    }
    return false
}

fn _known_model(t: string) -> bool {
    if t == "BPE" { return true }
    if t == "WordPiece" { return true }
    if t == "Unigram" { return true }
    if t == "WordLevel" { return true }
    return false
}

pub fn validate_tokenizer(spec: TokenizerSpec) -> [string] {
    let mut errs = []
    if !_known_model(spec.model_type) { errs.push("E1") }
    if vocab_size(spec) == 0 { errs.push("E2") }
    if spec.model_type == "BPE" {
        if len(spec.merges) == 0 { errs.push("E3") }
    }

    // E4: added_token id collides with a vocab id
    let vocab_keys = map_keys(spec.vocab)
    let mut used_ids = json_parse("{}")
    let mut i = 0
    while i < len(vocab_keys) {
        let id = to_int(spec.vocab[vocab_keys[i]])
        used_ids[to_string(id)] = "v"
        i = i + 1
    }
    let mut j = 0
    let mut collision = false
    while j < len(spec.added_tokens) {
        let aid = spec.added_tokens[j].id
        if has_key(used_ids, to_string(aid)) {
            // Only flag if the vocab entry at that id is a different token.
            let vtok = to_string(spec.inv_vocab[to_string(aid)])
            if vtok != spec.added_tokens[j].content { collision = true }
        }
        j = j + 1
    }
    if collision { errs.push("E4") }

    // E5: duplicate ids within vocab
    let mut seen_ids = json_parse("{}")
    let mut dup = false
    let mut k = 0
    while k < len(vocab_keys) {
        let id = to_int(spec.vocab[vocab_keys[k]])
        let key = to_string(id)
        if has_key(seen_ids, key) { dup = true }
        seen_ids[key] = "1"
        k = k + 1
    }
    if dup { errs.push("E5") }

    return errs
}
