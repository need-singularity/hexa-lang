// HEXA Standard Library — sys
//
// @version 0.1.0
// @capabilities [io]
//
// Closes S-NEW-SYS (.roadmap.stdlib, 2026-05-07). Mirrors Python `sys`
// for drop-in migration of self-host CLI tools that today reach for
// builtins ad-hoc.
//
// Surface:
//   pub fn sys_argv() -> [string]            // includes argv[0]
//   pub fn sys_exit(code: int)               // never returns
//   pub fn sys_stderr_println(msg: string)   // stderr + newline
//   pub fn sys_stdout_println(msg: string)   // stdout + newline (= println)
//   pub fn sys_stdin_read_line() -> string   // one line from stdin
//   pub fn sys_version() -> string           // hexa-lang version string
//   pub fn sys_platform() -> string          // "darwin" / "linux" / ...
//   pub fn sys_env(name: string) -> string   // "" if unset

pub fn sys_argv() -> [string] {
    return args()
}

pub fn sys_exit(code: int) {
    exit(code)
}

pub fn sys_stderr_println(msg: string) {
    // stdlib runtime may not expose eprintln directly; fall back via
    // exec on the host shell. The cost (one popen per call) matches
    // Python `print(..., file=sys.stderr)` order-of-magnitude and is
    // acceptable for CLI error paths (low frequency by definition).
    let _ = exec("printf '%s\\n' " + shell_quote(msg) + " 1>&2")
}

pub fn sys_stdout_println(msg: string) {
    println(msg)
}

pub fn sys_stdin_read_line() -> string {
    // Delegate to the runtime's stdin builtin if available; otherwise
    // shell `read` (limited to one line, no escapes — suitable for
    // CLI prompts only).
    return read_line()
}

pub fn sys_version() -> string {
    // Hexa version pin — synced from project.hexa @version. Falling
    // back to the install metadata keeps this stable across compiles.
    return "hexa-lang 0.1.0 (mk2)"
}

pub fn sys_platform() -> string {
    let raw = exec("uname -s 2>/dev/null").trim()
    if raw == "Darwin" { return "darwin" }
    if raw == "Linux"  { return "linux"  }
    return raw
}

pub fn sys_env(name: string) -> string {
    let v = exec("printenv " + shell_quote(name) + " 2>/dev/null")
    return v.trim()
}

// Local shell-arg quoter — single-quote wrap, embedded ' becomes '"'"'.
// Conservative; does not depend on stdlib/proc to avoid a circular
// import once I2-IMPORT-PATH lands.
fn shell_quote(s: string) -> string {
    let mut out = []
    out.push("'")
    let mut i = 0
    while i < len(s) {
        let c = s[i]
        if c == '\'' {
            out.push("'\"'\"'")
        } else {
            out.push(s.substring(i, i + 1))
        }
        i = i + 1
    }
    out.push("'")
    return out.join("")
}
