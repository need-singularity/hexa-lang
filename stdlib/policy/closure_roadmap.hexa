// HEXA Standard Library — policy/closure_roadmap
// Schema + loader + validator for closure_roadmap.json files.
//
// Purpose: declarative spec for multi-track policy (β / α / γ or any
// custom tag), so downstream tools can read a single file to know the
// active track, fork rules, exit criteria, and gate references without
// parsing ad-hoc YAML/shell formats per project.
//
// Schema v1 (id = "hexa-lang/closure_roadmap/1"):
//
//   {
//     "schema":       "hexa-lang/closure_roadmap/1",
//     "updated_ts":   "2026-04-23T...",
//     "active_track": "<name>",
//     "tracks": [
//       {
//         "name":           "β",
//         "phase":          "P1",
//         "parent":         "",
//         "fork_policy":    "permissive" | "strict" | "mirror",
//         "exit_criteria":  ["...", ...],
//         "gates":          ["gate_id_1", ...]
//       },
//       ...
//     ]
//   }
//
// Public API:
//   pub fn parse_closure_roadmap(json_text: string) -> ClosureRoadmap
//   pub fn load_closure_roadmap(path: string)      -> ClosureRoadmap
//   pub fn validate_closure_roadmap(rm)            -> array<string>
//   pub fn find_track(rm, name)                    -> array  [found_bool, TrackSpec]
//   pub fn active_track(rm)                        -> array  [found_bool, TrackSpec]
//
// Validation rules:
//   E1  schema id mismatch
//   E2  updated_ts missing or empty
//   E3  active_track empty or not present among tracks
//   E4  track with empty name
//   E5  duplicate track name
//   E6  fork_policy not in {permissive, strict, mirror}
//   E7  parent references a non-existent track
//   E8  parent cycle (A→B→A)

pub struct TrackSpec {
    name: string,
    phase: string,
    parent: string,
    fork_policy: string,
    exit_criteria: [string],
    gates: [string]
}

pub struct ClosureRoadmap {
    schema: string,
    updated_ts: string,
    active_track: string,
    tracks: [TrackSpec]
}

fn _s(m, key: string) -> string {
    if has_key(m, key) { return to_string(m[key]) }
    return ""
}

fn _a_of_str(m, key: string) -> array {
    if !has_key(m, key) { return [] }
    let v = m[key]
    let mut out = []
    let mut i = 0
    while i < len(v) {
        out.push(to_string(v[i]))
        i = i + 1
    }
    return out
}

fn _parse_track(tm) -> TrackSpec {
    return TrackSpec {
        name:          _s(tm, "name"),
        phase:         _s(tm, "phase"),
        parent:        _s(tm, "parent"),
        fork_policy:   _s(tm, "fork_policy"),
        exit_criteria: _a_of_str(tm, "exit_criteria"),
        gates:         _a_of_str(tm, "gates")
    }
}

pub fn parse_closure_roadmap(json_text: string) -> ClosureRoadmap {
    let obj = json_parse(json_text)
    let mut tracks = []
    if has_key(obj, "tracks") {
        let arr = obj["tracks"]
        let mut i = 0
        while i < len(arr) {
            tracks.push(_parse_track(arr[i]))
            i = i + 1
        }
    }
    return ClosureRoadmap {
        schema:       _s(obj, "schema"),
        updated_ts:   _s(obj, "updated_ts"),
        active_track: _s(obj, "active_track"),
        tracks:       tracks
    }
}

pub fn load_closure_roadmap(path: string) -> ClosureRoadmap {
    let text = read_file(path)
    return parse_closure_roadmap(text)
}

fn _known_fork_policy(p: string) -> bool {
    if p == "permissive" { return true }
    if p == "strict" { return true }
    if p == "mirror" { return true }
    return false
}

// Index of a track by name, or -1 if absent.
fn _track_index(rm: ClosureRoadmap, name: string) -> int {
    let mut i = 0
    while i < len(rm.tracks) {
        if rm.tracks[i].name == name { return i }
        i = i + 1
    }
    return -1
}

// Walk parent chain from `start`, returning true if a cycle is hit
// before reaching an empty parent. Bound by track count to handle
// malformed chains.
fn _has_parent_cycle(rm: ClosureRoadmap, start: int) -> bool {
    let mut seen = []
    let mut idx = start
    let budget = len(rm.tracks) + 1
    let mut steps = 0
    while idx >= 0 && steps < budget {
        let mut j = 0
        while j < len(seen) {
            if seen[j] == idx { return true }
            j = j + 1
        }
        seen.push(idx)
        let parent = rm.tracks[idx].parent
        if parent == "" { return false }
        idx = _track_index(rm, parent)
        steps = steps + 1
    }
    return false
}

pub fn validate_closure_roadmap(rm: ClosureRoadmap) -> array {
    let mut errs = []
    if rm.schema != "hexa-lang/closure_roadmap/1" {
        errs.push("E1 schema mismatch: '" + rm.schema + "'")
    }
    if rm.updated_ts == "" {
        errs.push("E2 updated_ts missing")
    }
    // E3: active_track required and must name an existing track
    if rm.active_track == "" {
        errs.push("E3 active_track empty")
    } else {
        if _track_index(rm, rm.active_track) < 0 {
            errs.push("E3 active_track '" + rm.active_track + "' not found")
        }
    }
    // E4/E5/E6/E7 per-track checks + name dedup
    let mut seen_names = []
    let mut i = 0
    while i < len(rm.tracks) {
        let t = rm.tracks[i]
        if t.name == "" {
            errs.push("E4 track at index " + to_string(i) + " has empty name")
        } else {
            let mut j = 0
            let mut dup = false
            while j < len(seen_names) {
                if seen_names[j] == t.name { dup = true }
                j = j + 1
            }
            if dup {
                errs.push("E5 duplicate track name '" + t.name + "'")
            } else {
                seen_names.push(t.name)
            }
        }
        if !_known_fork_policy(t.fork_policy) {
            errs.push("E6 track '" + t.name + "' has unknown fork_policy '" + t.fork_policy + "'")
        }
        if t.parent != "" {
            if _track_index(rm, t.parent) < 0 {
                errs.push("E7 track '" + t.name + "' parent '" + t.parent + "' not found")
            }
        }
        i = i + 1
    }
    // E8 cycle detection — only run when no E7 is flagged for this track,
    // because a missing parent name terminates the chain early.
    let mut k = 0
    while k < len(rm.tracks) {
        if _has_parent_cycle(rm, k) {
            errs.push("E8 parent cycle through '" + rm.tracks[k].name + "'")
        }
        k = k + 1
    }
    return errs
}

pub fn find_track(rm: ClosureRoadmap, name: string) -> array {
    let idx = _track_index(rm, name)
    if idx < 0 {
        return [false, TrackSpec {
            name: "", phase: "", parent: "", fork_policy: "",
            exit_criteria: [], gates: []
        }]
    }
    return [true, rm.tracks[idx]]
}

pub fn active_track(rm: ClosureRoadmap) -> array {
    return find_track(rm, rm.active_track)
}
