// HEXA Standard Library — policy/closure_roadmap tests

import "closure_roadmap.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn check_eq_int(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

fn check_eq_str(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got='" + got + "' want='" + want + "'")
    }
}

fn _errs_contain(errs, needle: string) -> bool {
    let mut i = 0
    while i < len(errs) {
        if errs[i].contains(needle) { return true }
        i = i + 1
    }
    return false
}

// ── fixtures ───────────────────────────────────────────────
let VALID = "{"
  + "\"schema\":\"hexa-lang/closure_roadmap/1\","
  + "\"updated_ts\":\"2026-04-23T00:00:00Z\","
  + "\"active_track\":\"beta\","
  + "\"tracks\":["
  + "  {\"name\":\"beta\",\"phase\":\"P1\",\"parent\":\"\",\"fork_policy\":\"permissive\",\"exit_criteria\":[\"e1\",\"e2\"],\"gates\":[\"g1\"]},"
  + "  {\"name\":\"alpha\",\"phase\":\"P0\",\"parent\":\"beta\",\"fork_policy\":\"strict\",\"exit_criteria\":[],\"gates\":[]}"
  + "]}"

// ── T1: valid roadmap parses + validates clean ─────────────
let rm = parse_closure_roadmap(VALID)
check_eq_str("T1.schema", rm.schema, "hexa-lang/closure_roadmap/1")
check_eq_str("T1.updated_ts", rm.updated_ts, "2026-04-23T00:00:00Z")
check_eq_str("T1.active_track", rm.active_track, "beta")
check_eq_int("T1.tracks_len", len(rm.tracks), 2)
check_eq_str("T1.tracks_0_name", rm.tracks[0].name, "beta")
check_eq_int("T1.tracks_0_exit_len", len(rm.tracks[0].exit_criteria), 2)
check_eq_str("T1.tracks_0_exit_0", rm.tracks[0].exit_criteria[0], "e1")
check_eq_str("T1.tracks_0_gates_0", rm.tracks[0].gates[0], "g1")
check_eq_str("T1.tracks_1_parent", rm.tracks[1].parent, "beta")

let errs = validate_closure_roadmap(rm)
check_eq_int("T1.no_errors", len(errs), 0)

// ── T2: find_track + active_track ──────────────────────────
let f = find_track(rm, "alpha")
check("T2.found_alpha", f[0])
check_eq_str("T2.alpha_phase", f[1].phase, "P0")

let missing = find_track(rm, "gamma")
check("T2.missing_gamma", !missing[0])

let act = active_track(rm)
check("T2.active_found", act[0])
check_eq_str("T2.active_name", act[1].name, "beta")

// ── T3: E1 schema mismatch ─────────────────────────────────
let bad_schema = "{\"schema\":\"other/1\",\"updated_ts\":\"x\",\"active_track\":\"a\",\"tracks\":[{\"name\":\"a\",\"phase\":\"P0\",\"parent\":\"\",\"fork_policy\":\"strict\",\"exit_criteria\":[],\"gates\":[]}]}"
let rm3 = parse_closure_roadmap(bad_schema)
let errs3 = validate_closure_roadmap(rm3)
check("T3.E1_detected", _errs_contain(errs3, "E1"))

// ── T4: E2 updated_ts missing ──────────────────────────────
let no_ts = "{\"schema\":\"hexa-lang/closure_roadmap/1\",\"updated_ts\":\"\",\"active_track\":\"a\",\"tracks\":[{\"name\":\"a\",\"phase\":\"P0\",\"parent\":\"\",\"fork_policy\":\"strict\",\"exit_criteria\":[],\"gates\":[]}]}"
let rm4 = parse_closure_roadmap(no_ts)
let errs4 = validate_closure_roadmap(rm4)
check("T4.E2_detected", _errs_contain(errs4, "E2"))

// ── T5: E3 active_track dangling ───────────────────────────
let bad_active = "{\"schema\":\"hexa-lang/closure_roadmap/1\",\"updated_ts\":\"x\",\"active_track\":\"gamma\",\"tracks\":[{\"name\":\"beta\",\"phase\":\"P1\",\"parent\":\"\",\"fork_policy\":\"strict\",\"exit_criteria\":[],\"gates\":[]}]}"
let rm5 = parse_closure_roadmap(bad_active)
let errs5 = validate_closure_roadmap(rm5)
check("T5.E3_detected", _errs_contain(errs5, "E3"))

// ── T6: E5 duplicate track name ────────────────────────────
let dup = "{\"schema\":\"hexa-lang/closure_roadmap/1\",\"updated_ts\":\"x\",\"active_track\":\"a\",\"tracks\":["
  + "{\"name\":\"a\",\"phase\":\"P0\",\"parent\":\"\",\"fork_policy\":\"strict\",\"exit_criteria\":[],\"gates\":[]},"
  + "{\"name\":\"a\",\"phase\":\"P1\",\"parent\":\"\",\"fork_policy\":\"strict\",\"exit_criteria\":[],\"gates\":[]}"
  + "]}"
let rm6 = parse_closure_roadmap(dup)
let errs6 = validate_closure_roadmap(rm6)
check("T6.E5_detected", _errs_contain(errs6, "E5"))

// ── T7: E6 unknown fork_policy ─────────────────────────────
let bad_policy = "{\"schema\":\"hexa-lang/closure_roadmap/1\",\"updated_ts\":\"x\",\"active_track\":\"a\",\"tracks\":[{\"name\":\"a\",\"phase\":\"P0\",\"parent\":\"\",\"fork_policy\":\"chaos\",\"exit_criteria\":[],\"gates\":[]}]}"
let rm7 = parse_closure_roadmap(bad_policy)
let errs7 = validate_closure_roadmap(rm7)
check("T7.E6_detected", _errs_contain(errs7, "E6"))

// ── T8: E7 dangling parent ─────────────────────────────────
let dangling = "{\"schema\":\"hexa-lang/closure_roadmap/1\",\"updated_ts\":\"x\",\"active_track\":\"a\",\"tracks\":[{\"name\":\"a\",\"phase\":\"P0\",\"parent\":\"ghost\",\"fork_policy\":\"strict\",\"exit_criteria\":[],\"gates\":[]}]}"
let rm8 = parse_closure_roadmap(dangling)
let errs8 = validate_closure_roadmap(rm8)
check("T8.E7_detected", _errs_contain(errs8, "E7"))

// ── T9: E8 parent cycle a→b→a ──────────────────────────────
let cycle = "{\"schema\":\"hexa-lang/closure_roadmap/1\",\"updated_ts\":\"x\",\"active_track\":\"a\",\"tracks\":["
  + "{\"name\":\"a\",\"phase\":\"P0\",\"parent\":\"b\",\"fork_policy\":\"strict\",\"exit_criteria\":[],\"gates\":[]},"
  + "{\"name\":\"b\",\"phase\":\"P0\",\"parent\":\"a\",\"fork_policy\":\"strict\",\"exit_criteria\":[],\"gates\":[]}"
  + "]}"
let rm9 = parse_closure_roadmap(cycle)
let errs9 = validate_closure_roadmap(rm9)
check("T9.E8_detected", _errs_contain(errs9, "E8"))

// ── Summary ─────────────────────────────────────────────────
if pass_count == total_count {
    println("PASS: closure_roadmap " + to_string(pass_count) + "/" + to_string(total_count))
} else {
    println("FAIL: closure_roadmap " + to_string(pass_count) + "/" + to_string(total_count) + " first_fail=" + failed_name)
}
