// HEXA Standard Library — policy/dual_track tests

import "dual_track.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn check_eq_int(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

fn check_eq_str(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got='" + got + "' want='" + want + "'")
    }
}

// ── T1: basic 50/50 split ─────────────────────────────────
let r1 = make_router([
    TrackWeight { name: "A", weight: 50 },
    TrackWeight { name: "B", weight: 50 }
], 0)

check_eq_int("T1.total_weight", r1.total_weight, 100)
check_eq_int("T1.track_count",  len(r1.tracks), 2)
check_eq_str("T1.tracks_0",     router_tracks(r1)[0], "A")

// ── T2: determinism — same key returns same track across calls ──
let k = "req-123"
let t_a = route(r1, k)
let t_b = route(r1, k)
let t_c = route(r1, k)
check("T2.deterministic_same_key", t_a == t_b)
check("T2.deterministic_triple",   t_b == t_c)
check("T2.valid_track", t_a == "A" || t_a == "B")

// ── T3: different keys should spread across tracks ────────
let mut a_count = 0
let mut b_count = 0
let mut i = 0
while i < 200 {
    let route_out = route(r1, "key-" + to_string(i))
    if route_out == "A" { a_count = a_count + 1 }
    if route_out == "B" { b_count = b_count + 1 }
    i = i + 1
}
check_eq_int("T3.total_routed", a_count + b_count, 200)
// 50/50 split should give roughly 100 each; allow ±30 slack (xxh32 is
// not a statistical PRNG, but over 200 keys this is very safe).
check("T3.A_in_range", a_count >= 70 && a_count <= 130)
check("T3.B_in_range", b_count >= 70 && b_count <= 130)

// ── T4: different salt → different assignments ────────────
let r1b = make_router([
    TrackWeight { name: "A", weight: 50 },
    TrackWeight { name: "B", weight: 50 }
], 99)

let mut differ = 0
let mut j = 0
while j < 50 {
    let k2 = "key-" + to_string(j)
    if route(r1, k2) != route(r1b, k2) { differ = differ + 1 }
    j = j + 1
}
// With independent salt, expect ~25/50 differences. Must be non-zero.
check("T4.salt_changes_assignment", differ > 5)

// ── T5: weighted split (70/30) lands closer to weight ratio ─
let r2 = make_router([
    TrackWeight { name: "big",   weight: 70 },
    TrackWeight { name: "small", weight: 30 }
], 7)

let mut big = 0
let mut small = 0
let mut k3 = 0
while k3 < 500 {
    let t = route(r2, "u-" + to_string(k3))
    if t == "big" { big = big + 1 }
    if t == "small" { small = small + 1 }
    k3 = k3 + 1
}
check_eq_int("T5.total",    big + small, 500)
// 70/30 over 500 → ~350/150. Allow ±60 slack.
check("T5.big_ratio",   big   >= 290 && big   <= 410)
check("T5.small_ratio", small >= 90  && small <= 210)

// ── T6: route_bucket uniform sanity ───────────────────────
let mut hits = [0, 0, 0, 0, 0]
let mut m = 0
while m < 100 {
    let b = route_bucket(r1, "x-" + to_string(m), 5)
    hits[b] = hits[b] + 1
    m = m + 1
}
// Each bucket should be hit at least once over 100 samples.
let mut all_hit = true
let mut n = 0
while n < 5 {
    if hits[n] == 0 { all_hit = false }
    n = n + 1
}
check("T6.all_buckets_hit", all_hit)

// ── T7: zero-weight track never picked ────────────────────
let r3 = make_router([
    TrackWeight { name: "alive", weight: 10 },
    TrackWeight { name: "ghost", weight: 0 }
], 0)
let mut ghost_seen = false
let mut p = 0
while p < 50 {
    if route(r3, "k-" + to_string(p)) == "ghost" { ghost_seen = true }
    p = p + 1
}
check("T7.zero_weight_never_picked", !ghost_seen)

// ── T8: bump_count / count_for ────────────────────────────
let r4 = make_router([
    TrackWeight { name: "A", weight: 50 },
    TrackWeight { name: "B", weight: 50 }
], 0)

check_eq_int("T8.initial_A", count_for(r4, "A"), 0)
let r4a = bump_count(r4, "A")
let r4b = bump_count(r4a, "A")
let r4c = bump_count(r4b, "B")
check_eq_int("T8.after_2A_1B.A", count_for(r4c, "A"), 2)
check_eq_int("T8.after_2A_1B.B", count_for(r4c, "B"), 1)

// bump unknown track — router unchanged
let r4d = bump_count(r4c, "nowhere")
check_eq_int("T8.bump_unknown_keeps_A", count_for(r4d, "A"), 2)
check_eq_int("T8.missing_name_returns_0", count_for(r4c, "nowhere"), 0)

// ── T9: empty tracks → empty route ────────────────────────
let r5 = make_router([], 0)
check_eq_str("T9.empty_route", route(r5, "anything"), "")

// ── Summary ─────────────────────────────────────────────────
if pass_count == total_count {
    println("PASS: dual_track " + to_string(pass_count) + "/" + to_string(total_count))
} else {
    println("FAIL: dual_track " + to_string(pass_count) + "/" + to_string(total_count) + " first_fail=" + failed_name)
}
