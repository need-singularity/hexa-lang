// HEXA Standard Library — hash/sha256 tests (G2-SHA256-WRAP)
//
// FIPS 180-4 test vectors — empty string + "abc" + 56-byte boundary.

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn check_eq(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
        println("  got  = " + got)
        println("  want = " + want)
    }
}

fn main() {
    // FIPS 180-4 Appendix B reference vectors.
    let h_empty = sha256("")
    check_eq("sha256(\"\")",
        h_empty,
        "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855")

    let h_abc = sha256("abc")
    check_eq("sha256(\"abc\")",
        h_abc,
        "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")

    // 56 bytes — last block boundary edge case.
    let h_56 = sha256("abcdbcdecdefdefgefghfghighijhijkijkljklmklmnlmnomnopnopq")
    check_eq("sha256(56-byte msg)",
        h_56,
        "248d6a61d20638b8e5c026930c3e6039a33ce45964ff2167f6ecedd419db06c1")

    // Round-trip: same input → same digest (determinism).
    check("determinism", sha256("hexa") == sha256("hexa"))

    // Different inputs → different digests.
    check("distinctness", sha256("hexa") != sha256("hexa "))

    // Output length always 64 hex chars.
    check("output length", len(sha256("any input")) == 64)

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
