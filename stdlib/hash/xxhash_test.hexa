// HEXA Standard Library — hash/xxhash_test
// Reference vectors for xxh32 and xxh64.

import "xxhash.hexa"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check_eq_int(name, got, want) {
    total_count = total_count + 1
    if got == want {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

fn check_eq_pair(name, got, want_hi, want_lo) {
    total_count = total_count + 1
    if got[0] == want_hi && got[1] == want_lo {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name + " got=[" + to_string(got[0]) + "," + to_string(got[1]) + "] want=[" + to_string(want_hi) + "," + to_string(want_lo) + "]")
    }
}

// helper: string → byte array (ASCII)
fn str_bytes(s) {
    let mut out = []
    let mut i = 0
    while i < len(s) {
        out.push(ord(s.substring(i, i + 1)))
        i = i + 1
    }
    return out
}

// ── xxh32 reference vectors ─────────────────────────────────────
// Canonical vectors from xxHash reference implementation.
let empty_bytes = []
check_eq_int("xxh32 empty seed=0", xxh32(empty_bytes, 0), 0x02CC5D05)
check_eq_int("xxh32 'a' seed=0", xxh32(str_bytes("a"), 0), 0x550D7456)

// ── xxh64 reference vectors ─────────────────────────────────────
// Empty string, seed=0 → 0xef46db3751d8e999
check_eq_pair("xxh64 empty seed=0", xxh64(empty_bytes, 0), 0xef46db37, 0x51d8e999)
// 'a', seed=0 → 0xd24ec4f1a98c6e5b
check_eq_pair("xxh64 'a' seed=0", xxh64(str_bytes("a"), 0), 0xd24ec4f1, 0xa98c6e5b)
// 'abc', seed=0 → 0x44bc2cf5ad770999
check_eq_pair("xxh64 'abc' seed=0", xxh64(str_bytes("abc"), 0), 0x44bc2cf5, 0xad770999)
// 'heyheyheyhey' (12 bytes), seed=0 → 0x974e04c60b58daa2
check_eq_pair("xxh64 'heyheyheyhey' seed=0", xxh64(str_bytes("heyheyheyhey"), 0), 0x974e04c6, 0x0b58daa2)

if pass_count == total_count {
    println("PASS: xxhash " + to_string(pass_count) + "/" + to_string(total_count))
    exit(0)
} else {
    println("FAIL " + failed_name + " (" + to_string(pass_count) + "/" + to_string(total_count) + ")")
    exit(1)
}
