// HEXA Standard Library — hash/xxhash
//
// @version 0.1.0
// @capabilities [pure, crypto]
//
// xxHash32 + xxHash64 non-cryptographic hash (Yann Collet).
//
// Public API:
//   pub fn xxh32(data: array, seed: int) -> int
//     - data: array of byte values (0..255)
//     - returns 32-bit hash as int in [0, 0xFFFFFFFF]
//   pub fn xxh64(data: array, seed: int) -> array
//     - returns [hi, lo] u32 halves of the 64-bit hash,
//       since interp int literals clamp at i63 (cannot hold u64).
//
// Stage0 notes:
//   P30 no unsigned int — all 32-bit ops mask with & 0xFFFFFFFF.
//   No 64-bit literals > 0x7FFFFFFF... — u64 values are
//   represented as [hi, lo] pairs of 32-bit ints.

// ── xxHash32 primes ──────────────────────────────────────────────
let XXH32_P1 = 0x9E3779B1
let XXH32_P2 = 0x85EBCA77
let XXH32_P3 = 0xC2B2AE3D
let XXH32_P4 = 0x27D4EB2F
let XXH32_P5 = 0x165667B1

let XXH_MASK32 = 0xFFFFFFFF

// ── xxHash64 primes split into (hi, lo) u32 halves ───────────────
// P1 = 0x9E3779B185EBCA87
let XXH64_P1_HI = 0x9E3779B1
let XXH64_P1_LO = 0x85EBCA87
// P2 = 0xC2B2AE3D27D4EB4F
let XXH64_P2_HI = 0xC2B2AE3D
let XXH64_P2_LO = 0x27D4EB4F
// P3 = 0x165667B19E3779F9
let XXH64_P3_HI = 0x165667B1
let XXH64_P3_LO = 0x9E3779F9
// P4 = 0x85EBCA77C2B2AE63
let XXH64_P4_HI = 0x85EBCA77
let XXH64_P4_LO = 0xC2B2AE63
// P5 = 0x27D4EB2F165667C5
let XXH64_P5_HI = 0x27D4EB2F
let XXH64_P5_LO = 0x165667C5

// ── bit helpers ──────────────────────────────────────────────────

fn xxh_pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n { r = r * 2; i = i + 1 }
    return r
}

fn xxh_or(a, b) {
    return (a + b) - (a & b)
}

fn xxh_rotl32(x, r) {
    let v = x & XXH_MASK32
    let sh = r % 32
    if sh == 0 { return v }
    let lo = (v * xxh_pow2(sh)) & XXH_MASK32
    let hi = v / xxh_pow2(32 - sh)
    return xxh_or(lo, hi) & XXH_MASK32
}

// 32-bit multiply via 16-bit split (avoids signed i64 overflow).
fn xxh_mul32(a, b) {
    let a32 = a & XXH_MASK32
    let b32 = b & XXH_MASK32
    let aL = a32 & 0xFFFF
    let aH = a32 / 0x10000
    let bL = b32 & 0xFFFF
    let bH = b32 / 0x10000
    let low = aL * bL
    let mid = (aL * bH + aH * bL) & 0xFFFF
    let result = low + mid * 0x10000
    return result & XXH_MASK32
}

fn xxh_add32(a, b) {
    return (a + b) & XXH_MASK32
}

// Read little-endian u32 from byte-array at offset.
fn xxh_read_u32(data, off) {
    let b0 = data[off] & 0xFF
    let b1 = data[off + 1] & 0xFF
    let b2 = data[off + 2] & 0xFF
    let b3 = data[off + 3] & 0xFF
    return xxh_or(xxh_or(b0, b1 * 0x100), xxh_or(b2 * 0x10000, b3 * 0x1000000))
}

// ── xxHash32 core ────────────────────────────────────────────────

fn xxh32_round(acc, input) {
    let v = xxh_add32(acc, xxh_mul32(input, XXH32_P2))
    let r = xxh_rotl32(v, 13)
    return xxh_mul32(r, XXH32_P1)
}

fn xxh32_avalanche(h_in) {
    let mut h = h_in
    h = h ^ (h / xxh_pow2(15))
    h = xxh_mul32(h, XXH32_P2)
    h = h ^ (h / xxh_pow2(13))
    h = xxh_mul32(h, XXH32_P3)
    h = h ^ (h / xxh_pow2(16))
    return h & XXH_MASK32
}

pub fn xxh32(data: array, seed: int) -> int {
    let length = len(data)
    let mut h = 0
    let mut idx = 0

    if length >= 16 {
        let mut v1 = xxh_add32(xxh_add32(seed, XXH32_P1), XXH32_P2)
        let mut v2 = xxh_add32(seed, XXH32_P2)
        let mut v3 = seed & XXH_MASK32
        let mut v4 = (seed - XXH32_P1) & XXH_MASK32

        let limit = length - 16
        while idx <= limit {
            v1 = xxh32_round(v1, xxh_read_u32(data, idx))
            v2 = xxh32_round(v2, xxh_read_u32(data, idx + 4))
            v3 = xxh32_round(v3, xxh_read_u32(data, idx + 8))
            v4 = xxh32_round(v4, xxh_read_u32(data, idx + 12))
            idx = idx + 16
        }

        let r1 = xxh_rotl32(v1, 1)
        let r2 = xxh_rotl32(v2, 7)
        let r3 = xxh_rotl32(v3, 12)
        let r4 = xxh_rotl32(v4, 18)
        h = xxh_add32(xxh_add32(xxh_add32(r1, r2), r3), r4)
    } else {
        h = xxh_add32(seed, XXH32_P5)
    }

    h = xxh_add32(h, length)

    let limit4 = length - 4
    while idx <= limit4 {
        let k = xxh_read_u32(data, idx)
        h = xxh_add32(h, xxh_mul32(k, XXH32_P3))
        h = xxh_mul32(xxh_rotl32(h, 17), XXH32_P4)
        idx = idx + 4
    }

    while idx < length {
        let b = data[idx] & 0xFF
        h = xxh_add32(h, xxh_mul32(b, XXH32_P5))
        h = xxh_mul32(xxh_rotl32(h, 11), XXH32_P1)
        idx = idx + 1
    }

    return xxh32_avalanche(h)
}

// ══════════════════════════════════════════════════════════════════
//  xxHash64 — 64-bit values as [hi, lo] u32 pairs
// ══════════════════════════════════════════════════════════════════

// 64-bit add: [a_hi, a_lo] + [b_hi, b_lo] → [new_hi, new_lo].
fn u64_add(a_hi, a_lo, b_hi, b_lo) {
    let lo_sum = a_lo + b_lo
    let lo = lo_sum & XXH_MASK32
    let carry = lo_sum / 0x100000000
    let hi = (a_hi + b_hi + carry) & XXH_MASK32
    return [hi, lo]
}

// 64-bit multiply via 16-bit limb decomposition.
// a = a3<<48 | a2<<32 | a1<<16 | a0
// result mod 2^64.
fn u64_mul(a_hi, a_lo, b_hi, b_lo) {
    let a0 = a_lo & 0xFFFF
    let a1 = (a_lo / 0x10000) & 0xFFFF
    let a2 = a_hi & 0xFFFF
    let a3 = (a_hi / 0x10000) & 0xFFFF
    let b0 = b_lo & 0xFFFF
    let b1 = (b_lo / 0x10000) & 0xFFFF
    let b2 = b_hi & 0xFFFF
    let b3 = (b_hi / 0x10000) & 0xFFFF

    // Column sums at 2^(16*k). Each partial product fits in 32 bits.
    let c0 = a0 * b0
    let c1 = a0 * b1 + a1 * b0
    let c2 = a0 * b2 + a1 * b1 + a2 * b0
    let c3 = a0 * b3 + a1 * b2 + a2 * b1 + a3 * b0

    // Low 32 bits: c0 + (c1 low 16) shifted.
    let low_acc = c0 + (c1 & 0xFFFF) * 0x10000
    let lo = low_acc & XXH_MASK32
    let carry = low_acc / 0x100000000

    // High 32 bits: carry + (c1 high 16) + c2 + (c3 low 16) shifted.
    let hi_acc = carry + (c1 / 0x10000) + c2 + (c3 & 0xFFFF) * 0x10000
    let hi = hi_acc & XXH_MASK32
    return [hi, lo]
}

// 64-bit xor.
fn u64_xor(a_hi, a_lo, b_hi, b_lo) {
    return [(a_hi ^ b_hi) & XXH_MASK32, (a_lo ^ b_lo) & XXH_MASK32]
}

// 64-bit left-rotate by r (0 < r < 64).
fn u64_rotl(hi, lo, r) {
    let rr = r % 64
    if rr == 0 { return [hi & XXH_MASK32, lo & XXH_MASK32] }
    if rr < 32 {
        let s = rr
        let inv = 32 - s
        let new_hi_l = (hi * xxh_pow2(s)) & XXH_MASK32
        let new_hi_r = lo / xxh_pow2(inv)
        let new_hi = xxh_or(new_hi_l, new_hi_r) & XXH_MASK32
        let new_lo_l = (lo * xxh_pow2(s)) & XXH_MASK32
        let new_lo_r = hi / xxh_pow2(inv)
        let new_lo = xxh_or(new_lo_l, new_lo_r) & XXH_MASK32
        return [new_hi, new_lo]
    }
    if rr == 32 { return [lo & XXH_MASK32, hi & XXH_MASK32] }
    // 32 < rr < 64
    let s = rr - 32
    let inv = 32 - s
    let new_hi_l = (lo * xxh_pow2(s)) & XXH_MASK32
    let new_hi_r = hi / xxh_pow2(inv)
    let new_hi = xxh_or(new_hi_l, new_hi_r) & XXH_MASK32
    let new_lo_l = (hi * xxh_pow2(s)) & XXH_MASK32
    let new_lo_r = lo / xxh_pow2(inv)
    let new_lo = xxh_or(new_lo_l, new_lo_r) & XXH_MASK32
    return [new_hi, new_lo]
}

// 64-bit logical right shift by n (0 < n < 64).
fn u64_shr(hi, lo, n) {
    if n == 0 { return [hi & XXH_MASK32, lo & XXH_MASK32] }
    if n < 32 {
        let new_hi = (hi / xxh_pow2(n)) & XXH_MASK32
        let low_from_hi = (hi & (xxh_pow2(n) - 1)) * xxh_pow2(32 - n)
        let new_lo = xxh_or((lo / xxh_pow2(n)) & XXH_MASK32, low_from_hi & XXH_MASK32) & XXH_MASK32
        return [new_hi, new_lo]
    }
    if n == 32 { return [0, hi & XXH_MASK32] }
    // 32 < n < 64
    let new_lo = (hi / xxh_pow2(n - 32)) & XXH_MASK32
    return [0, new_lo]
}

// Read little-endian u64 as [hi, lo] from byte array at offset.
fn xxh_read_u64(data, off) {
    let lo = xxh_read_u32(data, off)
    let hi = xxh_read_u32(data, off + 4)
    return [hi, lo]
}

// xxh64 round: acc = rotl64(acc + inp * P2, 31) * P1.
fn xxh64_round(acc_hi, acc_lo, inp_hi, inp_lo) {
    let mp = u64_mul(inp_hi, inp_lo, XXH64_P2_HI, XXH64_P2_LO)
    let ad = u64_add(acc_hi, acc_lo, mp[0], mp[1])
    let rt = u64_rotl(ad[0], ad[1], 31)
    let mu = u64_mul(rt[0], rt[1], XXH64_P1_HI, XXH64_P1_LO)
    return [mu[0], mu[1]]
}

// xxh64 merge round: acc = (acc xor round(0, val)) * P1 + P4.
fn xxh64_merge(acc_hi, acc_lo, val_hi, val_lo) {
    let v = xxh64_round(0, 0, val_hi, val_lo)
    let x = u64_xor(acc_hi, acc_lo, v[0], v[1])
    let m = u64_mul(x[0], x[1], XXH64_P1_HI, XXH64_P1_LO)
    let a = u64_add(m[0], m[1], XXH64_P4_HI, XXH64_P4_LO)
    return [a[0], a[1]]
}

// xxh64 avalanche final mix.
fn xxh64_avalanche(h_hi, h_lo) {
    let mut hi = h_hi & XXH_MASK32
    let mut lo = h_lo & XXH_MASK32
    // h ^= h >> 33
    let s1 = u64_shr(hi, lo, 33)
    let x1 = u64_xor(hi, lo, s1[0], s1[1])
    hi = x1[0]; lo = x1[1]
    // h *= P2
    let m1 = u64_mul(hi, lo, XXH64_P2_HI, XXH64_P2_LO)
    hi = m1[0]; lo = m1[1]
    // h ^= h >> 29
    let s2 = u64_shr(hi, lo, 29)
    let x2 = u64_xor(hi, lo, s2[0], s2[1])
    hi = x2[0]; lo = x2[1]
    // h *= P3
    let m2 = u64_mul(hi, lo, XXH64_P3_HI, XXH64_P3_LO)
    hi = m2[0]; lo = m2[1]
    // h ^= h >> 32
    let s3 = u64_shr(hi, lo, 32)
    let x3 = u64_xor(hi, lo, s3[0], s3[1])
    hi = x3[0]; lo = x3[1]
    return [hi, lo]
}

pub fn xxh64(data: array, seed: int) -> array {
    let length = len(data)
    let mut off = 0
    let mut hi = 0
    let mut lo = 0

    if length >= 32 {
        // v1 = seed + P1 + P2
        let t1a = u64_add(0, seed & XXH_MASK32, XXH64_P1_HI, XXH64_P1_LO)
        let t1b = u64_add(t1a[0], t1a[1], XXH64_P2_HI, XXH64_P2_LO)
        let mut v1_hi = t1b[0]
        let mut v1_lo = t1b[1]
        // v2 = seed + P2
        let t2 = u64_add(0, seed & XXH_MASK32, XXH64_P2_HI, XXH64_P2_LO)
        let mut v2_hi = t2[0]
        let mut v2_lo = t2[1]
        // v3 = seed
        let mut v3_hi = 0
        let mut v3_lo = seed & XXH_MASK32
        // v4 = seed - P1  (i.e. seed + (0 - P1) mod 2^64)
        let neg_p1 = u64_add(0, 0, (XXH64_P1_HI ^ XXH_MASK32) & XXH_MASK32, (XXH64_P1_LO ^ XXH_MASK32) & XXH_MASK32)
        // neg_p1 is ~P1; add 1 to get two's complement
        let neg_p1_plus1 = u64_add(neg_p1[0], neg_p1[1], 0, 1)
        let t4 = u64_add(0, seed & XXH_MASK32, neg_p1_plus1[0], neg_p1_plus1[1])
        let mut v4_hi = t4[0]
        let mut v4_lo = t4[1]

        while off + 32 <= length {
            let u0 = xxh_read_u64(data, off)
            let r0 = xxh64_round(v1_hi, v1_lo, u0[0], u0[1])
            v1_hi = r0[0]; v1_lo = r0[1]
            let u1 = xxh_read_u64(data, off + 8)
            let r1 = xxh64_round(v2_hi, v2_lo, u1[0], u1[1])
            v2_hi = r1[0]; v2_lo = r1[1]
            let u2 = xxh_read_u64(data, off + 16)
            let r2 = xxh64_round(v3_hi, v3_lo, u2[0], u2[1])
            v3_hi = r2[0]; v3_lo = r2[1]
            let u3 = xxh_read_u64(data, off + 24)
            let r3 = xxh64_round(v4_hi, v4_lo, u3[0], u3[1])
            v4_hi = r3[0]; v4_lo = r3[1]
            off = off + 32
        }

        // h = rotl(v1,1) + rotl(v2,7) + rotl(v3,12) + rotl(v4,18)
        let rv1 = u64_rotl(v1_hi, v1_lo, 1)
        let rv2 = u64_rotl(v2_hi, v2_lo, 7)
        let rv3 = u64_rotl(v3_hi, v3_lo, 12)
        let rv4 = u64_rotl(v4_hi, v4_lo, 18)
        let s12 = u64_add(rv1[0], rv1[1], rv2[0], rv2[1])
        let s123 = u64_add(s12[0], s12[1], rv3[0], rv3[1])
        let s1234 = u64_add(s123[0], s123[1], rv4[0], rv4[1])
        hi = s1234[0]; lo = s1234[1]

        // merge four accumulators
        let m1 = xxh64_merge(hi, lo, v1_hi, v1_lo)
        hi = m1[0]; lo = m1[1]
        let m2 = xxh64_merge(hi, lo, v2_hi, v2_lo)
        hi = m2[0]; lo = m2[1]
        let m3 = xxh64_merge(hi, lo, v3_hi, v3_lo)
        hi = m3[0]; lo = m3[1]
        let m4 = xxh64_merge(hi, lo, v4_hi, v4_lo)
        hi = m4[0]; lo = m4[1]
    } else {
        // h = seed + P5
        let t = u64_add(0, seed & XXH_MASK32, XXH64_P5_HI, XXH64_P5_LO)
        hi = t[0]; lo = t[1]
    }

    // h = h + length
    let hl = u64_add(hi, lo, 0, length & XXH_MASK32)
    hi = hl[0]; lo = hl[1]

    // 8-byte chunks
    while off + 8 <= length {
        let k = xxh_read_u64(data, off)
        let rv = xxh64_round(0, 0, k[0], k[1])
        let x = u64_xor(hi, lo, rv[0], rv[1])
        let rt = u64_rotl(x[0], x[1], 27)
        let mu = u64_mul(rt[0], rt[1], XXH64_P1_HI, XXH64_P1_LO)
        let ad = u64_add(mu[0], mu[1], XXH64_P4_HI, XXH64_P4_LO)
        hi = ad[0]; lo = ad[1]
        off = off + 8
    }

    // 4-byte chunk
    if off + 4 <= length {
        let k32 = xxh_read_u32(data, off)
        let mu = u64_mul(0, k32, XXH64_P1_HI, XXH64_P1_LO)
        let x = u64_xor(hi, lo, mu[0], mu[1])
        let rt = u64_rotl(x[0], x[1], 23)
        let mu2 = u64_mul(rt[0], rt[1], XXH64_P2_HI, XXH64_P2_LO)
        let ad = u64_add(mu2[0], mu2[1], XXH64_P3_HI, XXH64_P3_LO)
        hi = ad[0]; lo = ad[1]
        off = off + 4
    }

    // remaining bytes
    while off < length {
        let b = data[off] & 0xFF
        let mu = u64_mul(0, b, XXH64_P5_HI, XXH64_P5_LO)
        let x = u64_xor(hi, lo, mu[0], mu[1])
        let rt = u64_rotl(x[0], x[1], 11)
        let mu2 = u64_mul(rt[0], rt[1], XXH64_P1_HI, XXH64_P1_LO)
        hi = mu2[0]; lo = mu2[1]
        off = off + 1
    }

    let av = xxh64_avalanche(hi, lo)
    return [av[0], av[1]]
}
