// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/cert/verdict.hexa — verdict vocabulary → satisfaction score
//
//  Phase 1 of the cert stdlib extraction from anima/tool/cert_gate.hexa.
//  verdict_base_score values are taken VERBATIM from cert_gate.hexa so that
//  any downstream anima tool consuming this stdlib preserves bit-identical
//  reward_mult outputs (raw#10 proof-carrying determinism).
//
//  The three additional vocabulary terms listed in the Phase-1 spec
//  (synthetic_proof / natural_observed / conjecture) are appended below
//  the anima-derived table — they are new β additions, not overrides.
// ═══════════════════════════════════════════════════════════════════════════

// Map a verdict string → base satisfaction score ∈ [0.0, 1.0].
pub fn verdict_score(v) {
    // ── anima cert_gate.hexa verdict_base_score (verbatim) ──────────────────
    if v == "VERIFIED"                                    { return 1.0 }
    if v == "PASS"                                        { return 1.0 }
    if v == "CLOSED"                                      { return 1.0 }
    if v == "GO"                                          { return 1.0 }
    if v == "PHASE_JUMP"                                  { return 1.0 }
    if v == "STATIONARY_AT_FIXPOINT"                      { return 1.0 }
    if v == "H_STAR_STRONGLY_SUPPORTED"                   { return 1.0 }
    if v == "HEXAD_UNIVERSAL"                             { return 1.0 }
    if v == "USABLE"                                      { return 1.0 }
    if v == "CLAIM_CONFIRMED_CELL_BETTER_THAN_CLAIMED"    { return 1.0 }
    if v == "SELECTED"                                    { return 1.0 }
    if v == "BIT_IDENTICAL"                               { return 1.0 }
    if v == "PARTIAL"                                     { return 0.5 }
    if v == "HEXAD_CONDITIONAL"                           { return 0.5 }
    if v == "LEAKY"                                       { return 0.5 }
    if v == "ACTIVE"                                      { return 0.5 }
    if v == "HELD"                                        { return 0.3 }
    if v == "FAIL_EXPECTED"                               { return 0.5 }
    if v == "FAIL"                                        { return 0.0 }
    if v == "REJECT"                                      { return 0.0 }
    if v == "REJECTED"                                    { return 0.0 }
    if v == "INCOMPLETE"                                  { return 0.0 }

    // ── β Phase-1 additions (new vocabulary, not in anima) ─────────────────
    if v == "synthetic_proof"                             { return 0.9 }
    if v == "natural_observed"                            { return 1.0 }
    if v == "conjecture"                                  { return 0.5 }

    return 0.0
}

// True iff satisfaction is at the "fully satisfied" threshold used by
// anima cert_gate (sat >= 0.999 — tolerant of f64 round-off).
pub fn is_satisfied(sat) {
    return sat >= 0.999
}
