// ════════════════════════════════════════════════════════════════════════════
//  stdlib/cert/meta2_test.hexa — round-trip 3 anima certs
//
//  For each of 3 real anima/.meta2-cert/*.json certs:
//    c  = parse_cert(path)
//    s  = emit_cert(c)
//    c2 = parse_cert_from_string(s)
//    assert canonical_sha256(c) == canonical_sha256(c2)
//
//  On success prints "PASS: meta2 round-trip 3/3".
//  On any failure prints "FAIL <slug>" and exits non-zero.
//
//  CONSTRAINT: reads anima/.meta2-cert/*.json read-only; never modifies.
// ════════════════════════════════════════════════════════════════════════════

use "stdlib/cert/meta2_schema"
use "stdlib/cert/meta2_validator"

let ANIMA_CERT_DIR = env("HOME") + "/core/anima/.meta2-cert"

let TARGET_SLUGS = [
    "lora-phase-jump-k4",
    "cell-hexad-closure",
    "cell-mk8-stationary"
]

fn run_once(slug: string) -> bool {
    let path = ANIMA_CERT_DIR + "/" + slug + ".json"
    let c = parse_cert(path)
    if has_key(c, "_parse_error") {
        println("FAIL " + slug + " — parse: " + c["_parse_error"])
        return false
    }
    let errs = validate(c)
    if len(errs) > 0 {
        println("FAIL " + slug + " — validation errors:")
        let mut i = 0
        while i < len(errs) {
            println("  " + errs[i]["field"] + ": " + errs[i]["message"])
            i = i + 1
        }
        return false
    }
    let body = emit_cert(c)
    let c2 = parse_cert_from_string(body)
    if has_key(c2, "_parse_error") {
        println("FAIL " + slug + " — re-parse: " + c2["_parse_error"])
        return false
    }
    let h1 = canonical_sha256(c)
    let h2 = canonical_sha256(c2)
    if h1 != h2 {
        println("FAIL " + slug + " — sha mismatch: " + h1 + " vs " + h2)
        return false
    }
    return true
}

fn main_meta2_test() {
    let mut pass = 0
    let mut i = 0
    while i < len(TARGET_SLUGS) {
        let slug = TARGET_SLUGS[i]
        if run_once(slug) { pass = pass + 1 }
        i = i + 1
    }
    if pass == len(TARGET_SLUGS) {
        println("PASS: meta2 round-trip " + to_string(pass) + "/" +
                to_string(len(TARGET_SLUGS)))
        return
    }
    println("FAIL meta2 round-trip " + to_string(pass) + "/" +
            to_string(len(TARGET_SLUGS)))
    exit(1)
}

main_meta2_test()
