// ════════════════════════════════════════════════════════════════════════════
//  stdlib/cert/meta2_schema.hexa — Meta^2 breakthrough certificate schema
//
//  PURPOSE
//    Schema constants + record constructors for Meta^2 certificates
//    (anima/.meta2-cert/*.json). Stage0-compatible record strategy: dict
//    literals (#{}) instead of named-field structs so the polymorphic
//    evidence[] entries can round-trip losslessly.
//
//  WHY DICT-RECORDS (vs named-field struct):
//    Evidence entries carry heterogeneous shapes per `kind`:
//      {"type":"phase_jump","K":4,"verdict":"PHASE_JUMP"}
//      {"type":"kkt","target_value":0,"actual":0,"tolerance":1}
//      {"type":"artifact_count","count":3}
//      {"type":"jsd","target_value":1.0,"actual":1.0,"tolerance":0}
//    A flat struct with fixed fields would either drop extras or force a
//    sum-type (stage0 has none). Dicts preserve every key.
//
//  RECORD CONSTRUCTORS (pure factory funcs; readers just use dict access)
//    new_evidence()         → evidence record (kind, value, target_value,
//                             actual, tolerance, ratio, count, total, extras,
//                             _raw_numeric)
//    new_selftest_triple()  → triplet record
//    new_exit_criteria()    → exit criteria record
//    new_trigger()          → trigger record
//    new_cert()             → cert record (all v2 fields, populated defaults)
//    new_chain()            → chain record (index.json mirror)
//    new_chain_entry()      → chain entry record
//
//  ENUM WHITELISTS
//    verdict : VERIFIED | PASS | PARTIAL | HELD | CONDITIONAL | FAIL
//    status  : synthetic_proof | natural_observed | conjecture | HELD
//
//  NUMERIC-TOKEN PRESERVATION
//    Every numeric JSON token is parsed BOTH as a native value (for compute)
//    AND stored as a source-string token in the record's "_raw_numeric" map
//    under the JSON key path. The emitter writes the raw token verbatim
//    when present, preventing 1.60329e-16 → 1.60329e-16 drift or
//    0.0000001 → 1e-07 drift.
//
//  CONSTRAINTS
//    raw#9  hexa-only (no external deps)
//    raw#10 proof-carrying
//    raw#11 snake_case
//    raw#15 no-hardcode (schema version is the only constant)
// ════════════════════════════════════════════════════════════════════════════

// ── Schema version ──────────────────────────────────────────────────────────
pub fn schema_version() -> string { return "2" }

// Accepted historical schema versions on input ("" defaults to v1).
pub fn is_accepted_schema_version(v: string) -> bool {
    if v == "" { return true }
    if v == "1" { return true }
    if v == "2" { return true }
    return false
}

// ── Enum whitelists ─────────────────────────────────────────────────────────
pub fn verdict_whitelist() {
    return ["VERIFIED", "PASS", "PARTIAL", "HELD", "CONDITIONAL", "FAIL"]
}

pub fn status_whitelist() {
    return ["synthetic_proof", "natural_observed", "conjecture", "HELD"]
}

pub fn is_valid_verdict(v: string) -> bool {
    let wl = verdict_whitelist()
    let mut i = 0
    while i < len(wl) {
        if wl[i] == v { return true }
        i = i + 1
    }
    return false
}

pub fn is_valid_status(s: string) -> bool {
    let wl = status_whitelist()
    let mut i = 0
    while i < len(wl) {
        if wl[i] == s { return true }
        i = i + 1
    }
    return false
}

// ── Record constructors ─────────────────────────────────────────────────────
// All records are plain dicts. A sentinel "_record" key tags the shape so
// round-trip code can audit what it holds without type system support.

pub fn new_evidence() {
    let e = #{}
    e["_record"] = "Evidence"
    e["kind"] = ""
    e["value"] = ""
    e["target_value"] = ""
    e["actual"] = ""
    e["tolerance"] = ""
    e["ratio"] = 0.0
    e["count"] = 0
    e["total"] = 0
    e["extras"] = #{}
    // Source-string shadow for every numeric field in this evidence.
    // Keys in _raw_numeric map to the field name (e.g. "ratio",
    // "target_value", "actual", or any extras key).
    e["_raw_numeric"] = #{}
    // Key ordering (so emit can reproduce source order when possible).
    e["_key_order"] = []
    return e
}

pub fn new_selftest_triple() {
    let t = #{}
    t["_record"] = "SelfTestTriple"
    t["run1_sha"] = ""
    t["run2_sha"] = ""
    t["run3_sha"] = ""
    t["byte_identical"] = false
    t["_present"] = false
    return t
}

pub fn new_exit_criteria() {
    let ec = #{}
    ec["_record"] = "ExitCriteria"
    ec["keys"] = []
    ec["satisfied"] = #{}
    ec["_raw_numeric"] = #{}
    ec["_present"] = false
    return ec
}

pub fn new_trigger() {
    let t = #{}
    t["_record"] = "Trigger"
    t["name"] = ""
    t["slugs"] = []
    t["condition"] = ""
    t["satisfied"] = false
    t["satisfied_at"] = ""
    t["evidence_path"] = ""
    t["evidence_sha256"] = ""
    t["prev_hash"] = ""
    t["current_hash"] = ""
    t["_raw_numeric"] = #{}
    t["_extras"] = #{}
    t["_key_order"] = []
    return t
}

pub fn new_cert() {
    let c = #{}
    c["_record"] = "Cert"
    c["schema_version"] = ""
    c["slug"] = ""
    c["title"] = ""
    c["commit"] = ""
    c["created"] = ""
    c["status"] = ""
    c["verdict"] = ""
    c["notes"] = ""
    c["raw_compliance"] = []
    c["evidence"] = []
    c["cross_refs"] = []
    c["depends_on"] = []
    c["parallel_with"] = []
    c["roadmap_entry"] = ""
    c["exit_criteria"] = new_exit_criteria()
    c["prev_index_sha"] = ""
    c["deterministic_sha"] = ""
    c["selftest_3run"] = new_selftest_triple()
    c["payload_ext"] = #{}
    c["signature"] = ""
    // canonical-emit support:
    c["_raw_numeric"] = #{}     // top-level numeric token shadow
    c["_key_order"] = []        // original key order (best-effort)
    c["_source_path"] = ""      // file this cert was parsed from (for errs)
    return c
}

pub fn new_chain() {
    let ch = #{}
    ch["_record"] = "Chain"
    ch["schema_version"] = ""
    ch["location"] = ""
    ch["created"] = ""
    ch["description"] = ""
    ch["entries"] = []
    ch["triggers"] = []
    ch["_raw_numeric"] = #{}
    ch["_source_path"] = ""
    return ch
}

pub fn new_chain_entry() {
    let e = #{}
    e["_record"] = "ChainEntry"
    e["slug"] = ""
    e["file"] = ""
    e["commit"] = ""
    e["verdict"] = ""
    e["prev_index_sha"] = ""
    e["added_at"] = ""
    return e
}

// ── Error record helper (shared by validator) ──────────────────────────────
pub fn new_error(path: string, field: string, rule: string, message: string) {
    let e = #{}
    e["_record"] = "Error"
    e["path"] = path
    e["field"] = field
    e["rule"] = rule
    e["message"] = message
    return e
}
