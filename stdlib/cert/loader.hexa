// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/cert/loader.hexa — cert / state file loaders + sha256 digest
//
//  Mirrors anima cert_gate.hexa's load_cert / load_state fallback cascade.
//  File-absent returns CertScore { present: false, sat: 0.0 } — never
//  raises. Callers are expected to skip `present=false` entries in
//  aggregates to avoid biasing arithmetic means.
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/cert/verdict"
use "stdlib/cert/json_scan"

struct CertScore {
    slug: string,
    verdict: string,
    sat: float,
    present: bool
}

// Load <cert_dir>/<slug>.json and extract verdict via json_str_field_last.
// present = file-exists-on-disk (missing → sat=0.0, verdict="MISSING").
pub fn load_cert(cert_dir, slug) {
    let path = cert_dir + "/" + slug + ".json"
    if !file_exists(path) {
        return CertScore { slug: slug, verdict: "MISSING", sat: 0.0, present: false }
    }
    let body = read_file(path)
    let v = json_str_field_last(body, "verdict")
    let s = verdict_score(v)
    return CertScore { slug: slug, verdict: v, sat: s, present: true }
}

// Load <state_dir>/<fname> with the anima cascade:
//   verdict → closure_verdict → h_star_verdict → verdict_empirical
//    → overall_pass (bool) → pass (bool) → smoke_result → NO_VERDICT
pub fn load_state(state_dir, fname) {
    let path = state_dir + "/" + fname
    if !file_exists(path) {
        return CertScore { slug: fname, verdict: "MISSING", sat: 0.0, present: false }
    }
    let body = read_file(path)

    let v1 = json_str_field_last(body, "verdict")
    if len(v1) > 0 {
        return CertScore { slug: fname, verdict: v1, sat: verdict_score(v1), present: true }
    }
    let v2 = json_str_field_last(body, "closure_verdict")
    if len(v2) > 0 {
        return CertScore { slug: fname, verdict: v2, sat: verdict_score(v2), present: true }
    }
    let v3 = json_str_field_last(body, "h_star_verdict")
    if len(v3) > 0 {
        return CertScore { slug: fname, verdict: v3, sat: verdict_score(v3), present: true }
    }
    let v4 = json_str_field_last(body, "verdict_empirical")
    if len(v4) > 0 {
        return CertScore { slug: fname, verdict: v4, sat: verdict_score(v4), present: true }
    }

    let ob = json_bool_field_first(body, "overall_pass")
    if ob == 1 { return CertScore { slug: fname, verdict: "OVERALL_PASS", sat: 1.0, present: true } }
    if ob == 0 { return CertScore { slug: fname, verdict: "OVERALL_FAIL", sat: 0.0, present: true } }

    let pb = json_bool_field_first(body, "pass")
    if pb == 1 { return CertScore { slug: fname, verdict: "PASS_BOOL", sat: 1.0, present: true } }
    if pb == 0 { return CertScore { slug: fname, verdict: "FAIL_BOOL", sat: 0.0, present: true } }

    let cv = json_str_field_last(body, "smoke_result")
    if len(cv) > 0 {
        return CertScore { slug: fname, verdict: "SMOKE_" + cv.substring(0, 2), sat: 0.8, present: true }
    }

    return CertScore { slug: fname, verdict: "NO_VERDICT", sat: 0.0, present: true }
}

// sha256 of a file via shell. macOS → `shasum -a 256`; linux falls back to
// `sha256sum`. Returns "" if the file is absent (or if neither tool is
// available, in which case the first exec also returns "").
pub fn digest(path) {
    if !file_exists(path) { return "" }
    // Prefer shasum (macOS default, also available on many linuxes).
    let out = exec("shasum -a 256 " + path + " 2>/dev/null | awk '{print $1}'").trim()
    if len(out) > 0 { return out }
    // Fallback: sha256sum (coreutils — most linux distros).
    return exec("sha256sum " + path + " 2>/dev/null | awk '{print $1}'").trim()
}
