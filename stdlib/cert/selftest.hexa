// ═══════════════════════════════════════════════════════════════════════════
//
// @version 0.1.0
// @capabilities [pure]
//
//  stdlib/cert/selftest.hexa — triplet verification + determinism probe
//
//  * verify_triplet   : all slugs load with sat ≥ 0.999 (anima triplet gate)
//  * check_determinism: run a zero-arg thunk twice, compare SHA256 of its
//                       string-coerced result over both runs
//
//  Implementation note: the hex digest is computed by writing the string to
//  a short-lived temp file and shelling out to `shasum -a 256 <tmp>`
//  (macOS) with a fallback to `sha256sum`. This avoids shell-piping the
//  payload through stdin, which the interp interpreter can double-evaluate
//  under certain exec-in-closure patterns.
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/cert/loader"
use "stdlib/cert/verdict"

// All slugs in `slugs` must load (present=true) with sat >= 0.999.
pub fn verify_triplet(cert_dir, slugs) {
    let mut i = 0
    while i < len(slugs) {
        let cs = load_cert(cert_dir, slugs[i])
        if !cs.present { return false }
        if !is_satisfied(cs.sat) { return false }
        i = i + 1
    }
    return true
}

fn _sha_of_string(s) {
    // Stable temp path scoped by PID + nanosecond — collision-free across
    // concurrent runs. File-based digest dodges interp's pipe-stdin quirk.
    let pid = exec("echo $$").trim()
    let ts = exec("date +%s%N 2>/dev/null || date +%s").trim()
    let tmp = "/tmp/hexa_cert_sha_" + pid + "_" + ts + ".txt"
    write_file(tmp, s)
    let h1 = exec("shasum -a 256 " + tmp).trim()
    // parse first whitespace-delimited token (the hash)
    let mut out = ""
    let n = len(h1)
    let mut i = 0
    while i < n {
        let c = h1.substring(i, i + 1)
        if c == " " { break }
        if c == "\t" { break }
        out = out + c
        i = i + 1
    }
    if len(out) == 0 {
        let h2 = exec("sha256sum " + tmp).trim()
        let nn = len(h2)
        let mut j = 0
        while j < nn {
            let c = h2.substring(j, j + 1)
            if c == " " { break }
            if c == "\t" { break }
            out = out + c
            j = j + 1
        }
    }
    exec("rm -f " + tmp)
    return out
}

// Run `thunk` twice, compare SHA256 of the string-coerced results.
// Accepts a zero-arg closure — caller closes over any inputs.
pub fn check_determinism(thunk) {
    let r1 = thunk()
    let r2 = thunk()
    let s1 = _sha_of_string(to_string(r1))
    let s2 = _sha_of_string(to_string(r2))
    if len(s1) == 0 { return false }
    return s1 == s2
}
