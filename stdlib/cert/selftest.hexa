// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/cert/selftest.hexa — triplet verification + determinism probe
//
//  * verify_triplet  : all slugs load with sat ≥ 0.999 (anima triplet gate)
//  * check_determinism: run a named closure twice, SHA256-compare outputs
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/cert/loader"
use "stdlib/cert/verdict"

// All slugs in `slugs` must load (present=true) with sat >= 0.999.
pub fn verify_triplet(cert_dir, slugs) {
    let mut i = 0
    while i < len(slugs) {
        let cs = load_cert(cert_dir, slugs[i])
        if !cs.present { return false }
        if !is_satisfied(cs.sat) { return false }
        i = i + 1
    }
    return true
}

fn _sha_str(s) {
    // Pipe stdin → shasum; safe for arbitrary strings (no shell-escape risk
    // since we use a heredoc-style wrapper: printf '%s' <string>). Anima
    // uses the same pattern in several tools.
    let cmd = "printf %s " + _shell_quote(s) + " | shasum -a 256 | awk '{print $1}'"
    let out = exec(cmd).trim()
    if len(out) > 0 { return out }
    let cmd2 = "printf %s " + _shell_quote(s) + " | sha256sum | awk '{print $1}'"
    return exec(cmd2).trim()
}

fn _shell_quote(s) {
    // Single-quote the string, escaping embedded single quotes as '\''.
    let mut out = "'"
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" {
            out = out + "'\\''"
        } else {
            out = out + c
        }
        i = i + 1
    }
    out = out + "'"
    return out
}

// Run `thunk` twice, compare SHA256 of its string-coerced result.
// Accepts a zero-arg closure — caller closes over any inputs.
pub fn check_determinism(thunk) {
    let r1 = thunk()
    let r2 = thunk()
    let s1 = _sha_str(to_string(r1))
    let s2 = _sha_str(to_string(r2))
    if len(s1) == 0 { return false }
    return s1 == s2
}
