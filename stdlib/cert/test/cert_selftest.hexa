// ═══════════════════════════════════════════════════════════════════════════
//  stdlib/cert/test/cert_selftest.hexa
//
//  Phase-1 selftest: runs the stdlib/cert module against synthetic fixtures
//  under stdlib/cert/_fixtures/ and asserts 8 contract conditions.
//
//  Run:
//      ./hexa run stdlib/cert/test/cert_selftest.hexa
//
//  Exit semantics:
//      * all 8 asserts pass → prints "PASS: cert stdlib selftest 8/8"
//      * any assert fails   → prints FAIL lines and exits 1
// ═══════════════════════════════════════════════════════════════════════════

use "stdlib/cert/verdict"
use "stdlib/cert/loader"
use "stdlib/cert/factor"
use "stdlib/cert/reward"
use "stdlib/cert/selftest"

let FIX = "stdlib/cert/_fixtures"

let mut pass_count = 0
let mut fail_count = 0

fn _check(tag, ok) {
    if ok {
        println("  PASS " + tag)
        pass_count = pass_count + 1
    } else {
        println("  FAIL " + tag)
        fail_count = fail_count + 1
    }
}

fn _approx_eq(a, b) {
    let d = a - b
    let da = if d < 0.0 { 0.0 - d } else { d }
    return da < 0.0000001
}

fn main() {
    println("── stdlib/cert Phase-1 selftest ──")

    // 1. verdict_score("VERIFIED") == 1.0
    _check("verdict_score(VERIFIED)==1.0", _approx_eq(verdict_score("VERIFIED"), 1.0))

    // 2. verdict_score("FAIL") == 0.0
    _check("verdict_score(FAIL)==0.0", _approx_eq(verdict_score("FAIL"), 0.0))

    // 3. is_satisfied(0.9999) == true
    _check("is_satisfied(0.9999)==true", is_satisfied(0.9999))

    // 4. load_cert on fixtures/cert_a → present=true, sat=1.0
    let cs_a = load_cert(FIX, "cert_a")
    _check("load_cert(cert_a).present && sat==1.0",
        cs_a.present && _approx_eq(cs_a.sat, 1.0))

    // 5. load_cert on fixtures/nonexistent → present=false, sat=0.0
    let cs_miss = load_cert(FIX, "nonexistent_xyz")
    _check("load_cert(missing).!present && sat==0.0",
        !cs_miss.present && _approx_eq(cs_miss.sat, 0.0))

    // 6. compute_reward with floor case → reward_mult = 0
    //    Build a factor list whose mean sat < 0.5 (floor).
    let fail_fr = FactorResult { name: "fail", sat: 0.1, n_sources: 1, n_satisfied: 0, detail: [] }
    let zero_aux = FactorResult { name: "aux", sat: 0.0, n_sources: 0, n_satisfied: 0, detail: [] }
    let cfg = default_config()
    let gate_floor = compute_reward([fail_fr], zero_aux, cfg)
    _check("compute_reward(floor).reward_mult==0",
        _approx_eq(gate_floor.reward_mult, 0.0) && !gate_floor.passed)

    // 7. compute_reward linear case → reward_mult ∈ [0.75, 1.25]
    //    core_sat = 1.0, aux = 0.0  →  linear_sat = 1.25, aux_contrib = 0
    let full_fr = FactorResult { name: "full", sat: 1.0, n_sources: 1, n_satisfied: 1, detail: [] }
    let gate_full = compute_reward([full_fr], zero_aux, cfg)
    let in_range = gate_full.reward_mult >= 0.75 && gate_full.reward_mult <= 1.25
    _check("compute_reward(full).reward_mult in [0.75,1.25]", in_range)

    // 8. check_determinism — a pure thunk returns identical hash over 2 runs
    let det_ok = check_determinism(fn() -> float {
        let fr = FactorResult { name: "d", sat: 0.8, n_sources: 1, n_satisfied: 0, detail: [] }
        let g = compute_reward([fr], zero_aux, cfg)
        return g.reward_mult
    })
    _check("check_determinism(compute_reward)", det_ok)

    println("")
    println("  pass=" + to_string(pass_count) + "  fail=" + to_string(fail_count))
    if fail_count == 0 {
        println("PASS: cert stdlib selftest 8/8")
        return 0
    }
    println("FAIL: cert stdlib selftest " + to_string(pass_count) + "/8")
    exit(1)
}

main()
