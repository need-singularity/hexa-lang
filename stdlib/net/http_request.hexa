// HEXA Standard Library — net/http_request
//
// @version 0.1.0
// @capabilities [pure]
//
// HTTP/1.1 요청 파서. self/serve/http_server.hexa (컴파일러 내부)의
// parse_request / parse_query 를 사용자 응용 코드용으로 포팅한 버전.
//
// Request 는 struct 대신 map 으로 표현한다(기존 서버와의 호환). 맵 키:
//   method  : string    ("GET", "POST", ...)
//   path    : string    ("/api/ping")
//   query   : string    (물음표 뒤 전체 raw 문자열)
//   body    : string
//   remote  : string    (상위 계층이 채워넣음; 파서는 "")
//   headers : map       (키 소문자 정규화)

// -- Parse raw HTTP request --

pub fn parse_request(raw) {
    let mut method = "GET"
    let mut path = "/"
    let mut query = ""
    let mut body = ""
    let mut headers = #{}

    // Split header block from body on double CRLF
    let parts = raw.split("\r\n\r\n")
    let header_block = parts[0]
    if len(parts) > 1 {
        body = parts[1]
    }

    // Split header lines
    let lines = header_block.split("\r\n")
    if len(lines) > 0 {
        // Request line: "METHOD /path HTTP/1.1"
        let req_parts = lines[0].split(" ")
        if len(req_parts) >= 2 {
            method = req_parts[0]
            let full_path = req_parts[1]
            let qidx = full_path.index_of("?")
            if qidx >= 0 {
                path = full_path.substring(0, qidx)
                query = full_path.substring(qidx + 1, len(full_path))
            } else {
                path = full_path
            }
        }
    }

    // Parse headers
    let mut i = 1
    while i < len(lines) {
        let line = lines[i]
        let colon = line.index_of(":")
        if colon > 0 {
            let key = line.substring(0, colon).trim().to_lower()
            let val = line.substring(colon + 1, len(line)).trim()
            headers[key] = val
        }
        i = i + 1
    }

    let result = #{}
    result["method"] = method
    result["path"] = path
    result["query"] = query
    result["body"] = body
    result["remote"] = ""
    result["headers"] = headers
    return result
}

// -- Parse query string "a=1&b=2" into map --

pub fn parse_query(qs) {
    let result = #{}
    if len(qs) == 0 { return result }
    let pairs = qs.split("&")
    let mut i = 0
    while i < len(pairs) {
        let kv = pairs[i].split("=")
        if len(kv) >= 2 {
            result[kv[0]] = kv[1]
        } else {
            if len(kv) == 1 {
                result[kv[0]] = ""
            }
        }
        i = i + 1
    }
    return result
}

// -- Helper: get Content-Length header as int (0 if absent or invalid) --

pub fn content_length_of(request) {
    let headers = request["headers"]
    if headers == nil { return 0 }
    let v = headers["content-length"]
    if v == nil { return 0 }
    return to_int(v)
}
