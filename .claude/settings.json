{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "p=$(jq -r '.tool_input.file_path // empty'); case \"$p\" in *.py|*.rs|*.sh) echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\".py/.rs/.sh 파일 생성 금지\"}}';; esac"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "NotebookEdit",
      "Read",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "deny": [
      "Bash(dd if=*)",
      "Bash(git branch -D *)",
      "Bash(git branch --delete --force *)",
      "Bash(git checkout --force*)",
      "Bash(git checkout -f *)",
      "Bash(git checkout -- .*)",
      "Bash(git checkout .)",
      "Bash(git clean -df*)",
      "Bash(git clean -dfx*)",
      "Bash(git clean -f*)",
      "Bash(git clean --force*)",
      "Bash(git push * +*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git push --force*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git restore --worktree .)",
      "Bash(git restore .)",
      "Bash(git stash clear*)",
      "Bash(git stash drop*)",
      "Bash(git switch --discard-changes*)",
      "Bash(git switch --force *)",
      "Bash(git switch -f *)",
      "Bash(git update-ref -d *)",
      "Bash(mkfs*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Edit(**/shared/config/absolute_rules.json)",
      "Edit(**/shared/hooks/**)",
      "Edit(/Users/ghost/.claude/CLAUDE.md)",
      "Edit(/Users/ghost/.claude/agents/**)",
      "Edit(/Users/ghost/.claude/commands/**)",
      "Edit(/Users/ghost/.claude/hooks/**)",
      "Write(**/*.py)",
      "Write(**/*.rs)",
      "Write(**/*.sh)",
      "Write(**/shared/config/absolute_rules.json)",
      "Write(**/shared/config/core-lockdown.json)",
      "Write(**/shared/config/core.json)",
      "Write(**/shared/hooks/**)",
      "Write(/Users/ghost/.claude/CLAUDE.md)",
      "Write(/Users/ghost/.claude/agents/**)",
      "Write(/Users/ghost/.claude/commands/**)",
      "Write(/Users/ghost/.claude/hooks/**)"
    ],
    "additionalDirectories": [
      "/Users/ghost",
      "/Users/ghost/Dev/nexus"
    ],
    "defaultMode": "bypassPermissions"
  },
  "skipDangerousModePermissionPrompt": true,
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  }
}
