#!/usr/bin/env bash
# hexa-build — N2 래퍼: .hexa → .c → 네이티브 바이너리
# 2026-04-13: go-style CLI 전환 대응 (commit 0689460).
#   기본 -O2 경로는 `hexa build` 서브커맨드로 위임 (codegen + clang 일괄 처리).
#   -O0/-O1/-O3 등 비표준 최적화 레벨은 2단계 폴백 경로 (hexa_v2 + clang) 유지.
# 사용: hexa-build examples/sieve_min.hexa [-o out] [-O0|-O1|-O2|-O3]
set -e
HEXA_DIR="$(cd "$(dirname "$0")" && pwd)"
HEXA_BIN="$HEXA_DIR/hexa"
HEXA_V2="$HEXA_DIR/self/native/hexa_v2"

if [ $# -lt 1 ]; then
    echo "사용: hexa-build <input.hexa> [-o output_bin] [-O0|-O1|-O2|-O3]"
    exit 1
fi

INPUT="$1"; shift
NAME="$(basename "$INPUT" .hexa)"
OUT_BIN="$HEXA_DIR/build/$NAME"
OPT="-O2"

while [ $# -gt 0 ]; do
    case "$1" in
        -o) OUT_BIN="$2"; shift 2 ;;
        -O0|-O1|-O2|-O3) OPT="$1"; shift ;;
        *) echo "알 수 없는 플래그: $1"; exit 1 ;;
    esac
done

mkdir -p "$HEXA_DIR/build"

if [ "$OPT" = "-O2" ]; then
    # Fast path: new go-style `hexa build` 서브커맨드 (codegen + clang -O2)
    "$HEXA_BIN" build "$INPUT" -o "$OUT_BIN"
else
    # Fallback: 비표준 -O 레벨은 2단계 수동 파이프라인
    C_FILE="$HEXA_DIR/build/$NAME.c"
    if [ -x "$HEXA_V2" ]; then
        "$HEXA_V2" "$INPUT" "$C_FILE"
    else
        # hexa_v2 네이티브가 없으면 build_c.hexa 인터프리터 경로로 폴백
        "$HEXA_BIN" run "$HEXA_DIR/self/build_c.hexa" "$INPUT" "$C_FILE"
    fi
    clang "$OPT" -Wno-int-conversion -Wno-incompatible-pointer-types -Wno-implicit-function-declaration -I "$HEXA_DIR/self" "$C_FILE" -o "$OUT_BIN"
fi

echo "[hexa-build] $OUT_BIN ($(wc -c < "$OUT_BIN") bytes)"
