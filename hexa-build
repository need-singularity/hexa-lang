#!/usr/bin/env bash
# hexa-build — N2 래퍼: .hexa → .c → 네이티브 바이너리
# 사용: hexa-build examples/sieve_min.hexa  → build/sieve_min (실행파일)
set -e
HEXA_DIR="$(cd "$(dirname "$0")" && pwd)"
HEXA_BIN="$HEXA_DIR/hexa"
BUILDER="$HEXA_DIR/self/build_c.hexa"

if [ $# -lt 1 ]; then
    echo "사용: hexa-build <input.hexa> [-o output_bin] [-O0|-O2|-O3]"
    exit 1
fi

INPUT="$1"; shift
NAME="$(basename "$INPUT" .hexa)"
OUT_BIN="$HEXA_DIR/build/$NAME"
OPT="-O2"

while [ $# -gt 0 ]; do
    case "$1" in
        -o) OUT_BIN="$2"; shift 2 ;;
        -O0|-O1|-O2|-O3) OPT="$1"; shift ;;
        *) echo "알 수 없는 플래그: $1"; exit 1 ;;
    esac
done

mkdir -p "$HEXA_DIR/build"
C_FILE="$HEXA_DIR/build/$NAME.c"

"$HEXA_BIN" "$BUILDER" "$INPUT" "$C_FILE"
clang "$OPT" "$C_FILE" -o "$OUT_BIN"
echo "[hexa-build] $OUT_BIN ($(wc -c < "$OUT_BIN") bytes)"
