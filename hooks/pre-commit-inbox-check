#!/usr/bin/env bash
# Inbox pending-count warn hook.
# Source of truth: hexa-lang/tool/proposal_inbox.hexa via bin/proposal_inbox.
# Non-fatal: prints warning to stderr if own inbox has >= WARN_THRESHOLD
# pending items (default 5). Never blocks a commit.
set -eu
THRESHOLD="${INBOX_WARN_THRESHOLD:-5}"
HEXA_LANG="${HEXA_LANG:-$HOME/core/hexa-lang}"
SHIM="$HEXA_LANG/bin/proposal_inbox"
[ -x "$SHIM" ] || exit 0
REPO_BASENAME="$(basename "$(git rev-parse --show-toplevel 2>/dev/null || pwd)")"
INV="$HOME/core/$REPO_BASENAME/state/proposals/inventory.json"
[ -f "$INV" ] || exit 0
PENDING="$(python3 -c "
import json
d = json.load(open('$INV'))
n = sum(1 for e in d.get('entries', []) if e.get('user_status','pending') == 'pending')
print(n)
" 2>/dev/null || echo 0)"
if [ "$PENDING" -ge "$THRESHOLD" ]; then
  echo "⚠ proposal_inbox ($REPO_BASENAME): $PENDING pending entries (>= $THRESHOLD)" >&2
  echo "  review:  $SHIM list --repo $REPO_BASENAME --status pending" >&2
  echo "  next:    $SHIM next --repo $REPO_BASENAME" >&2
fi
exit 0
