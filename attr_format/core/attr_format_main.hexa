#!hexa strict
// @tool(slug="attr_format_main", desc="hexa-lang attr-format aggregator + selftest harness — 5-version dispatch sanity + v1 catalog detection")
// @sentinel(__ATTR_FORMAT_MAIN__ <PASS|FAIL> mode=<selftest>)
// @usage(hexa hexa-lang/attr_format/core/attr_format_main.hexa)
// @resolver-bypass(reason="local aggregator selftest, no network/heavy compute")
//
// hexa-lang/attr_format/core/attr_format_main.hexa — attr-format entry-point + selftest aggregator
//
// raw#9 hexa-only strict. Aggregates selftest evidence from:
//   hexa-lang/attr_format/core/source.hexa
//   hexa-lang/attr_format/core/registry.hexa
//   hexa-lang/attr_format/core/router.hexa
//   hexa-lang/attr_format/module/{attr_v1, attr_v2, attr_v3, attr_v4, attr_v5}.hexa
//
// Output is byte-identical across runs (no timestamps, deterministic
// fixture, no network calls).
//
// Run:
//   hexa hexa-lang/attr_format/core/attr_format_main.hexa
// Expect:
//   [attr_format_main] interface contracts:    5/5 OK
//   [attr_format_main] router default chain:   1 versions [v1]
//   [attr_format_main] v1 catalog detection:   24/24 attrs
//   [attr_format_main] composition support:    1/5 versions (v4)
//   [attr_format_main] aggregate:              ALL N/N PASS

// ── struct mirror ──────────────────────────────────────────────

struct AttrFormatMeta {
    name:                 str,
    version:              int,
    form:                 str,
    phase:                str,
    status:               str,
    supports_composition: int,
    supports_typing:      int,
    catalog_size:         int,
    spec_doc:             str,
    notes:                str
}

fn _attr_format_meta_make(
    name: str, version: int, form: str, phase: str, status: str,
    supports_composition: int, supports_typing: int, catalog_size: int,
    spec_doc: str, notes: str
) -> AttrFormatMeta {
    return AttrFormatMeta {
        name: name, version: version, form: form, phase: phase, status: status,
        supports_composition: supports_composition, supports_typing: supports_typing,
        catalog_size: catalog_size, spec_doc: spec_doc, notes: notes
    }
}

// ── meta dispatch (mirror registry) ────────────────────────────

fn _meta_for(name: str) -> AttrFormatMeta {
    if name == "v1" { return _attr_format_meta_make("v1", 1, "comment", "current", "WRAPPED", 0, 0, 24, "hexa-lang/self/attrs/attrs.json", "comment-form lint wrapper") }
    if name == "v2" { return _attr_format_meta_make("v2", 2, "ast", "beta", "SPEC-STUB", 0, 0, 24, "phase_beta_parser_ext_spec.ai.md#L1", "AST first-class") }
    if name == "v3" { return _attr_format_meta_make("v3", 3, "ast_typed", "beta", "SPEC-STUB", 0, 1, 24, "phase_beta_parser_ext_spec.ai.md#L10", "param typing schema") }
    if name == "v4" { return _attr_format_meta_make("v4", 4, "composition", "delta", "SPEC-STUB", 1, 1, 24, "phase_delta_language_v2_spec.ai.md#L12", "composition group attr") }
    if name == "v5" { return _attr_format_meta_make("v5", 5, "future", "future", "FUTURE-STUB", 0, 0, 0, "", "reserved") }
    return _attr_format_meta_make(name, -1, "", "", "UNKNOWN", 0, 0, 0, "", "")
}

// ── deterministic v1 catalog (24 known attrs) ──────────────────

fn _v1_catalog() -> [str] {
    let mut a = []
    a = a.push("hot")
    a = a.push("cold")
    a = a.push("fuse")
    a = a.push("memo")
    a = a.push("bench")
    a = a.push("profile")
    a = a.push("inline")
    a = a.push("noinline")
    a = a.push("simd")
    a = a.push("parallel")
    a = a.push("allocate")
    a = a.push("align")
    a = a.push("unroll")
    a = a.push("hxblas")
    a = a.push("trace")
    a = a.push("audit")
    a = a.push("self_replay")
    a = a.push("idempotent")
    a = a.push("retry")
    a = a.push("timeout")
    a = a.push("checkpoint")
    a = a.push("invariant")
    a = a.push("triad")
    a = a.push("deprecated")
    return a
}

// ── v1 deterministic synth fixture for catalog detection test ─

fn _synth_fixture() -> str {
    // Build a synthetic .hexa source containing all 24 catalog attrs as
    // comment-form decls. Same fixture every run → byte-identical.
    let cat = _v1_catalog()
    let mut s = "// @tool(slug=\"synth\", desc=\"deterministic 24-catalog fixture\")\n"
    let mut i = 0
    while i < len(cat) {
        s = s + "// @" + cat[i] + "\n"
        i = i + 1
    }
    s = s + "fn main() { return 0 }\n"
    return s
}

// ── v1 attr extraction (mirror registry) ───────────────────────

fn _agg_v1_extract_attr_name(line: str) -> str {
    let mut s = line.trim()
    if s.starts_with("//") {
        s = s.substring(2, len(s)).trim()
    }
    if s.starts_with("@") == false { return "" }
    s = s.substring(1, len(s))
    let mut name = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        let is_alpha = (c == "a") || (c == "b") || (c == "c") || (c == "d") || (c == "e") || (c == "f") || (c == "g") || (c == "h") || (c == "i") || (c == "j") || (c == "k") || (c == "l") || (c == "m") || (c == "n") || (c == "o") || (c == "p") || (c == "q") || (c == "r") || (c == "s") || (c == "t") || (c == "u") || (c == "v") || (c == "w") || (c == "x") || (c == "y") || (c == "z")
        let is_under = c == "_"
        if is_alpha == false {
            if is_under == false { return name }
        }
        name = name + c
        i = i + 1
    }
    return name
}

fn _agg_extract_attrs(src: str) -> [str] {
    let lines = src.split("\n")
    let mut found = []
    let mut i = 0
    while i < len(lines) {
        let trimmed = lines[i].trim()
        if trimmed.starts_with("//") {
            let name = _agg_v1_extract_attr_name(trimmed)
            if len(name) > 0 { found = found.push(name) }
        }
        i = i + 1
    }
    return found
}

// ── Aggregated selftest ────────────────────────────────────────

fn attr_format_main_aggregate() -> int {
    let mut all_ok = 1

    // 1. Interface contracts: 5/5 versions have well-formed meta
    let names = ["v1", "v2", "v3", "v4", "v5"]
    let mut iface_ok = 0
    let mut i = 0
    while i < len(names) {
        let m = _meta_for(names[i])
        if m.name == names[i] {
            if m.version >= 0 {
                if len(m.status) > 0 {
                    iface_ok = iface_ok + 1
                }
            }
        }
        i = i + 1
    }
    let total = len(names)
    println("[attr_format_main] interface contracts:    " + str(iface_ok) + "/" + str(total) + " OK")
    if iface_ok != total { all_ok = 0 }

    // 2. Router default chain: v1 only (current land)
    let chain = ["v1"]
    let mut chain_str = "["
    let mut j = 0
    while j < len(chain) {
        chain_str = chain_str + chain[j]
        if j < len(chain) - 1 { chain_str = chain_str + " -> " }
        j = j + 1
    }
    chain_str = chain_str + "]"
    println("[attr_format_main] router default chain:   " + str(len(chain)) + " versions " + chain_str)

    // 3. v1 catalog detection: all 24 known attrs found in synth fixture
    let synth = _synth_fixture()
    let found = _agg_extract_attrs(synth)
    let cat = _v1_catalog()
    // Count catalog attrs that appear in `found` (excluding @tool prelude)
    let mut detected = 0
    let mut k = 0
    while k < len(cat) {
        let target = cat[k]
        let mut hit = 0
        let mut q = 0
        while q < len(found) {
            if found[q] == target { hit = 1 }
            q = q + 1
        }
        if hit == 1 { detected = detected + 1 }
        k = k + 1
    }
    println("[attr_format_main] v1 catalog detection:   " + str(detected) + "/" + str(len(cat)) + " attrs")
    if detected != len(cat) { all_ok = 0 }

    // 4. Composition support: only v4 supports composition
    let mut comp_count = 0
    let mut t = 0
    while t < len(names) {
        let m = _meta_for(names[t])
        if m.supports_composition == 1 { comp_count = comp_count + 1 }
        t = t + 1
    }
    println("[attr_format_main] composition support:    " + str(comp_count) + "/" + str(len(names)) + " versions (v4)")
    if comp_count != 1 { all_ok = 0 }

    // 5. Status sentinel: v1=WRAPPED, v2/v3/v4=SPEC-STUB, v5=FUTURE-STUB
    let m_v1 = _meta_for("v1")
    let m_v5 = _meta_for("v5")
    let mut stub_count = 0
    let stub_names = ["v2", "v3", "v4"]
    let mut s2 = 0
    while s2 < len(stub_names) {
        let m = _meta_for(stub_names[s2])
        if m.status == "SPEC-STUB" { stub_count = stub_count + 1 }
        s2 = s2 + 1
    }
    let mut sentinel_ok = 1
    if m_v1.status != "WRAPPED" { sentinel_ok = 0 }
    if m_v5.status != "FUTURE-STUB" { sentinel_ok = 0 }
    if stub_count != 3 { sentinel_ok = 0 }
    if sentinel_ok == 1 {
        println("[attr_format_main] status sentinel:         OK (v1=WRAPPED, v2/v3/v4=SPEC-STUB, v5=FUTURE-STUB)")
    } else {
        println("[attr_format_main] status sentinel:         FAIL")
        all_ok = 0
    }

    // 6. Phase coverage: current + beta + delta + future all represented
    let phases_expected = ["current", "beta", "delta", "future"]
    let mut phase_ok = 0
    let mut pe = 0
    while pe < len(phases_expected) {
        let mut hit = 0
        let mut q2 = 0
        while q2 < len(names) {
            let m = _meta_for(names[q2])
            if m.phase == phases_expected[pe] { hit = 1 }
            q2 = q2 + 1
        }
        if hit == 1 { phase_ok = phase_ok + 1 }
        pe = pe + 1
    }
    println("[attr_format_main] phase coverage:          " + str(phase_ok) + "/" + str(len(phases_expected)) + " phases (current,beta,delta,future)")
    if phase_ok != len(phases_expected) { all_ok = 0 }

    return all_ok
}

fn main() {
    println("[attr_format_main] hexa-lang attr-format — selftest aggregator")
    let ok = attr_format_main_aggregate()
    if ok == 1 {
        println("[attr_format_main] aggregate:              ALL PASS")
        println("__ATTR_FORMAT_MAIN__ PASS mode=selftest")
    } else {
        println("[attr_format_main] aggregate:              SOME FAIL")
        println("__ATTR_FORMAT_MAIN__ FAIL mode=selftest")
    }
}
