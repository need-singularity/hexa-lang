#!/bin/bash
# build/hx_linux — Linux-native interp wrapper (bypass macOS shim)
#
# WHY
#   build/hexa_interp is a bash shim that on Linux tries to exec
#   hexa_interp.real (Mach-O arm64) and fails with "Exec format error".
#   The shim is also periodically overwritten by Mac rebuild processes,
#   so patching it in-place is unreliable on the shared filesystem.
#
# USAGE
#   ./build/hx_linux <hexa_script> [args...]
#
# PREREQUISITE
#   build/hexa_interp.linux must exist — built via:
#     gcc -O2 -I self -o /tmp/hexa_v2_linux self/native/hexa_cc.c -lm
#     /tmp/hexa_v2_linux self/hexa_full.hexa /tmp/hexa_full_linux.c
#     gcc -O2 -D_GNU_SOURCE -std=gnu11 -I self \
#         -o build/hexa_interp.linux /tmp/hexa_full_linux.c -lm -ldl
#
# 2026-04-26 raw#8 stage0→interp rename: previous version targeted
# hexa_stage0.linux (which no longer exists — superseded by hexa_interp.linux)
# making this wrapper silently broken since the e075b3e8 rename batch.
# Repaired in the same commit that adds tool/audit_shim_ssot.hexa.

set -u

DIR="$(cd "$(dirname "$0")" && pwd)"
REAL="$DIR/hexa_interp.linux"

if [ ! -x "$REAL" ]; then
    echo "hx_linux: $REAL not found. Run:" >&2
    echo "  gcc -O2 -I self -o /tmp/hexa_v2_linux self/native/hexa_cc.c -lm" >&2
    echo "  /tmp/hexa_v2_linux self/hexa_full.hexa /tmp/hexa_full_linux.c" >&2
    echo "  gcc -O2 -D_GNU_SOURCE -std=gnu11 -I self \\" >&2
    echo "      -o build/hexa_interp.linux /tmp/hexa_full_linux.c -lm -ldl" >&2
    exit 127
fi

exec "$REAL" "$@"
