#!/bin/bash
# hexa_stage0 shim — serialize + RSS cap (Mac panic 근본 차단)
#
# Layered defense against Mac panic / compressor blowup caused by N parallel
# hexa_stage0 spawns (e.g. ai_native_lint 여러 POC 파일 병렬 컴파일):
#
#   Layer 1  mkdir-lock  → concurrency limit (default 1, override via
#                          HEXA_STAGE0_CONCURRENCY, though only 1 is honored
#                          by the simple lock below — higher values would
#                          need counting semaphore)
#   Layer 2  safe_hexa_launchd  → per-job RSS cap 4GB + jetsam priority 40
#                                 (so WindowServer/Terminal survive OOM)
#
# Without Layer 1, N uncapped hexa_stage0 could sum to N*RSS irrespective of
# the per-job cap in Layer 2 — which is what caused 2026-04-18 13:22 panic +
# 16:23 load=376 + compressor 12.72GB.
#
# Opt-outs (emergency escape):
#   HEXA_LOCAL_NO_CAP=1   full bypass (both layers) — raw binary direct
#   HEXA_LOCAL=1          full bypass (matches hexa dispatch convention)
#   HEXA_STAGE0_NO_CAP=1  alias of HEXA_LOCAL
#   HEXA_NO_LAUNCHD=1     skip launchd re-entry (set by safe_hexa_launchd itself)
#
# Rollback:
#   mv /Users/ghost/Dev/hexa-lang/build/hexa_stage0.real \
#      /Users/ghost/Dev/hexa-lang/build/hexa_stage0
#
# Raw copy preserved at: build/hexa_stage0.bak.20260418

set -u

DIR="$(cd "$(dirname "$0")" && pwd)"
# 2026-04-18: hard-coded REAL path to SSOT — avoids picking up refuse shim
# at /Users/ghost/.hx/bin/build/hexa_stage0.real when this script is invoked
# via symlink (bash `cd $(dirname)` does NOT resolve symlinks, so $DIR stays
# = .hx/bin/build when called through the symlink shim name).
REAL="/Users/ghost/.hx/packages/hexa/build/hexa_stage0.real"
# Fallback for Dev checkout (hexa-lang repo) where SSOT layout absent:
if [ ! -x "$REAL" ] && [ -x "$DIR/hexa_stage0.real" ]; then
    REAL="$DIR/hexa_stage0.real"
fi
WRAPPER="$HOME/Dev/nexus/shared/harness/safe_hexa_launchd.sh"

LOCKDIR="/tmp/hexa_stage0.lock.d"
LOCK_WAIT_SECS="${HEXA_STAGE0_LOCK_WAIT:-300}"   # 5 min default

# ---------------- Built-in watchdog (raw-exec paths only) ----------------
# Used by opt-out + wrapper-absent paths where safe_hexa_launchd.sh's RSS cap
# is NOT in effect. Polls ps RSS every 0.5s; SIGKILLs child if it exceeds cap.
# Default cap 4 GiB (4194304 KB) matches wrapper's setrlimit cap.
watchdog_exec_real() {
    local cap_kb="${HEXA_STAGE0_RSS_CAP_KB:-4194304}"
    "$REAL" "$@" &
    local pid=$!
    (
        while kill -0 "$pid" 2>/dev/null; do
            local rss_kb
            rss_kb=$(ps -o rss= -p "$pid" 2>/dev/null | tr -d ' ')
            if [ -n "$rss_kb" ] && [ "$rss_kb" -gt "$cap_kb" ]; then
                echo "hexa_stage0 watchdog: pid=$pid rss=${rss_kb}KB > ${cap_kb}KB → SIGKILL" >&2
                kill -KILL "$pid" 2>/dev/null
                exit 0
            fi
            sleep 0.5
        done
    ) &
    local watch_pid=$!
    wait "$pid"
    local rc=$?
    kill -KILL "$watch_pid" 2>/dev/null
    return "$rc"
}

# ---------------- Opt-out paths ----------------
# Full bypass — no lock, no launchd, raw binary.
# 2026-04-18 panic 재발 후: Darwin 에서는 bypass 거부 (RSS cap 우회 = Mac panic).
# Linux 에서만 bypass 허용 (setrlimit 전에 wrapper 대체 cap 수단 없음 → 그대로).
if [ "${HEXA_LOCAL_NO_CAP:-}" = "1" ] || \
   [ "${HEXA_LOCAL:-}" = "1" ] || \
   [ "${HEXA_STAGE0_NO_CAP:-}" = "1" ]; then
    if [ "$(uname -s)" = "Darwin" ]; then
        echo "hexa_stage0 shim: Darwin 에서 HEXA_LOCAL/NO_CAP bypass 거부 (panic 재발 방지). wrapper 경유 강제." >&2
        # fall through — 정상 wrapper 경로 계속
    else
        # Linux bypass: no wrapper → use built-in watchdog instead of raw exec.
        watchdog_exec_real "$@"
        exit $?
    fi
fi

# Re-entry from safe_hexa_launchd — wrapper already holds the lock (our parent
# acquired it before calling $WRAPPER). Skip launchd re-entry AND re-locking.
if [ "${HEXA_NO_LAUNCHD:-}" = "1" ]; then
    exec "$REAL" "$@"
fi

# ---------------- Layer 1: serialize via mkdir lock ----------------
# mkdir is atomic on POSIX. macOS has no flock(1) by default, and we refuse
# to depend on Homebrew here. Loop with 0.5s sleep + deadline; stale lock
# (PID no longer alive) is reaped.

acquire_lock() {
    local deadline=$(( $(date +%s) + LOCK_WAIT_SECS ))
    while true; do
        if mkdir "$LOCKDIR" 2>/dev/null; then
            echo "$$" > "$LOCKDIR/pid" 2>/dev/null || true
            return 0
        fi
        # Reap stale lock: holder PID dead?
        if [ -r "$LOCKDIR/pid" ]; then
            local holder
            holder=$(cat "$LOCKDIR/pid" 2>/dev/null)
            if [ -n "$holder" ] && ! kill -0 "$holder" 2>/dev/null; then
                rm -rf "$LOCKDIR" 2>/dev/null
                continue
            fi
        fi
        # Deadline exceeded → fail loud so caller sees the problem.
        if [ "$(date +%s)" -ge "$deadline" ]; then
            echo "hexa_stage0 shim: lock timeout after ${LOCK_WAIT_SECS}s (holder: $(cat $LOCKDIR/pid 2>/dev/null || echo unknown))" >&2
            return 1
        fi
        sleep 0.5
    done
}

release_lock() {
    # Only release if we own it.
    if [ -r "$LOCKDIR/pid" ] && [ "$(cat "$LOCKDIR/pid" 2>/dev/null)" = "$$" ]; then
        rm -rf "$LOCKDIR" 2>/dev/null
    fi
}
trap release_lock EXIT INT TERM

if ! acquire_lock; then
    exit 75   # EX_TEMPFAIL
fi

# ---------------- Layer 2: route through launchd for RSS cap ----------------
# 2026-04-18 panic 재발: Darwin 에서 wrapper 부재 = hard fail (panic 리스크).
# Linux 에서는 경고만 + raw 실행.
if [ ! -x "$WRAPPER" ]; then
    if [ "$(uname -s)" = "Darwin" ]; then
        echo "hexa_stage0 shim: safe_hexa_launchd.sh 부재 — Darwin 에서 RSS cap 없이 실행 거부. 경로: $WRAPPER" >&2
        exit 77   # EX_NOPERM
    fi
    # Linux wrapper-absent: built-in watchdog substitutes for wrapper cap.
    watchdog_exec_real "$@"
    exit $?
fi

HEXA_BIN="$REAL" "$WRAPPER" "$@"
rc=$?
# release_lock via trap
exit "$rc"
