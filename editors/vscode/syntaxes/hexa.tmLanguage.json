{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "HEXA",
    "scopeName": "source.hexa",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#chars" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#builtins" },
        { "include": "#functions" },
        { "include": "#types" },
        { "include": "#operators" },
        { "include": "#punctuation" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.hexa",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.hexa",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.hexa",
                            "match": "\\\\[nrt\\\\\"0]"
                        }
                    ]
                }
            ]
        },
        "chars": {
            "patterns": [
                {
                    "name": "string.quoted.single.hexa",
                    "match": "'(?:[^'\\\\]|\\\\[nrt\\\\'0])'"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.hexa",
                    "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.hexa",
                    "match": "\\b\\d[\\d_]*\\b"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.hexa",
                    "match": "\\b(if|else|match|for|while|loop|return|yield|break|continue)\\b"
                },
                {
                    "name": "keyword.declaration.hexa",
                    "match": "\\b(fn|let|mut|const|static|type|struct|enum|trait|impl)\\b"
                },
                {
                    "name": "keyword.other.hexa",
                    "match": "\\b(mod|use|pub|crate|own|borrow|move|drop|spawn|channel|select|atomic|effect|handle|resume|pure|proof|assert|invariant|theorem|macro|derive|where|comptime|try|catch|throw|panic|recover|intent|generate|verify|optimize|async|await)\\b"
                },
                {
                    "name": "constant.language.boolean.hexa",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "constant.language.hexa",
                    "match": "\\b(void)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.hexa",
                    "match": "\\b(print|println|len|type_of|sigma|phi|tau|gcd|sopfr|read_file|write_file|file_exists|keys|values|has_key|to_string|to_int|to_float|abs|min|max|floor|ceil|round|sqrt|pow|log|log2|sin|cos|tan|format|args|env_var|exit|clock|Some|Ok|Err|channel|random|random_int|sleep|print_err|json_parse|json_stringify)\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.declaration.hexa" },
                        "2": { "name": "entity.name.function.hexa" }
                    }
                },
                {
                    "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "captures": {
                        "1": { "name": "entity.name.function.call.hexa" }
                    }
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.hexa",
                    "match": ":\\s*(int|float|bool|char|string|byte|void|any|array|map)\\b",
                    "captures": {
                        "1": { "name": "storage.type.hexa" }
                    }
                },
                {
                    "name": "entity.name.type.hexa",
                    "match": ":\\s*([A-Z][a-zA-Z0-9_]*)\\b"
                },
                {
                    "name": "entity.name.type.hexa",
                    "match": "->\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": { "name": "storage.type.hexa" }
                    }
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.comparison.hexa",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.hexa",
                    "match": "&&|\\|\\||!|\\^\\^"
                },
                {
                    "name": "keyword.operator.arithmetic.hexa",
                    "match": "\\+|-|\\*\\*|\\*|/|%"
                },
                {
                    "name": "keyword.operator.bitwise.hexa",
                    "match": "&|\\||\\^|~"
                },
                {
                    "name": "keyword.operator.assignment.hexa",
                    "match": ":=|="
                },
                {
                    "name": "keyword.operator.range.hexa",
                    "match": "\\.\\.\\.|\\.\\.|\\.\\.="
                },
                {
                    "name": "keyword.operator.arrow.hexa",
                    "match": "->"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.separator.hexa",
                    "match": "[,;:]"
                },
                {
                    "name": "punctuation.bracket.hexa",
                    "match": "[{}()\\[\\]]"
                }
            ]
        }
    }
}
