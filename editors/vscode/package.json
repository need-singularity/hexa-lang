{
    "name": "hexa-lang",
    "displayName": "HEXA-LANG",
    "description": "The Perfect Number Programming Language",
    "version": "0.1.0",
    "publisher": "need-singularity",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/need-singularity/hexa-lang"
    },
    "contributes": {
        "languages": [
            {
                "id": "hexa",
                "aliases": [
                    "HEXA",
                    "hexa"
                ],
                "extensions": [
                    ".hexa"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "hexa",
                "scopeName": "source.hexa",
                "path": "./syntaxes/hexa.tmLanguage.json"
            }
        ]
    }
}
