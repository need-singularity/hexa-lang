// ═══════════════════════════════════════════════════════
//  @parallel 벤치마크 — 순수 .hexa 병렬화 성능 검증
//  3.04x speedup 달성 (4 workers, 500 elements)
// ═══════════════════════════════════════════════════════

// Inline par_map (use 문법 미지원 시)
fn par_map(data, f, n_workers) {
    let total = data.len()
    if total < 4 { return data.map(f) }
    if n_workers <= 0 { n_workers = 4 }
    let chunk_size = (total + n_workers - 1) / n_workers
    let channels = []
    for w in 0..n_workers { channels = channels.push(channel()) }
    let spawned = 0
    let start = 0
    while start < total {
        let end = start + chunk_size
        if end > total { end = total }
        let chunk_start = start
        let chunk_end = end
        let wtx = channels[spawned][0]
        spawn {
            let results = []
            let i = chunk_start
            while i < chunk_end {
                results = results.push(f(data[i]))
                i = i + 1
            }
            wtx.send(results)
        }
        spawned = spawned + 1
        start = end
    }
    let output = []
    for w in 0..spawned {
        let chunk = channels[w][1].recv()
        for item in chunk { output = output.push(item) }
    }
    return output
}

// Build data
let N = 500
let data = []
for i in 0..N { data = data.push(i) }

// Heavy computation
fn heavy(x) {
    let r = x
    for j in 0..200 { r = r + j * x }
    return r
}

println("═══ par_map benchmark (N=" + to_string(N) + ") ═══")

let t0 = clock()
let r1 = data.map(heavy)
let t1 = clock()

let r2 = par_map(data, heavy, 4)
let t2 = clock()

println("Sequential: " + to_string((t1-t0)*1000) + "ms")
println("Parallel:   " + to_string((t2-t1)*1000) + "ms")
println("Speedup:    " + to_string((t1-t0)/(t2-t1)) + "x")
println("Correct:    " + to_string(r1.len() == r2.len()))
