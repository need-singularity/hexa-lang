<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.airgenome.verdict-watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>cd /Users/ghost/core/hexa-lang &amp;&amp; exec hexa tool/llm_verdict_watcher.hexa --once</string>
    </array>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HEXA_LANG_ROOT</key>
        <string>/Users/ghost/core/hexa-lang</string>
        <key>AIRGENOME_HOOK_ROOT</key>
        <string>/Users/ghost/core/airgenome</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/ghost/Library/Logs/com.airgenome.verdict-watcher.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/ghost/Library/Logs/com.airgenome.verdict-watcher.err.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/ghost/core/hexa-lang</string>

    <key>ProcessType</key>
    <string>Background</string>

    <key>LowPriorityIO</key>
    <true/>

    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
