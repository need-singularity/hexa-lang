<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.airgenome.english-watcher</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>cd /Users/ghost/core/hexa-lang &amp;&amp; exec hexa tool/raw_english_only_watcher.hexa</string>
    </array>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>KeepAlive</key>
    <false/>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HEXA_LANG_ROOT</key>
        <string>/Users/ghost/core/hexa-lang</string>
        <key>CLAUDE_PROJECT_DIR</key>
        <string>/Users/ghost/core/hexa-lang</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/ghost/Library/Logs/com.airgenome.english-watcher.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/ghost/Library/Logs/com.airgenome.english-watcher.err.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/ghost/core/hexa-lang</string>

    <key>ProcessType</key>
    <string>Background</string>

    <key>LowPriorityIO</key>
    <true/>

    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
