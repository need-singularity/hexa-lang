# hexa-lang /.ext — 외부자원 선언 (external resource declarations)
# SSOT — 이 프로젝트가 의존하는 모든 외부 자원 (SSH host, API endpoint, service, submodule, binary) 명시적 선언.
# 포맷 스펙: self/raw_loader.hexa (L0/.raw 와 동일 문법, id namespace 독립)
#
# 포맷:
#   ext <id> <status> "<name>"
#     kind      <ssh|api|service|binary|submodule|pod>
#     <key>     <value...>
#
# status (5 잠금): live warn new deferred convention
# kind whitelist: ssh api service binary submodule pod
#
# 필수 key (kind 별):
#   ssh       : addr use (why)
#   api       : endpoint auth use (rate-limit)
#   service   : url health use
#   binary    : path version use
#   submodule : path commit url
#   pod       : host image use
#
# 표준 key (공통): why proof note deprecated-at

ext 1 live "ubu1 — LAN ubuntu host"
  kind     ssh
  addr     aiden@192.168.50.119
  alias    ubu ubu-ts
  relay    tailscale 100.96.193.56
  use      로컬 LAN 자원 (dev box)
  why      LAN-local 개발/실행 — 무료, 무제한. hetzner 대비 저비용 작업용.

ext 2 live "ubu2 — LAN ubuntu host"
  kind     ssh
  addr     summer@192.168.50.60
  alias    ubu2-relay
  use      로컬 LAN 자원 (dev box 2)
  why      LAN-local 개발/실행 — ubu1 과 병렬 또는 다른 사용자(summer) 워크스페이스.

ext 3 live "hetzner — CPU 장기 실행 server"
  kind     ssh
  addr     root@157.180.8.154
  use      CPU BLAS 25 GFLOPS (BLIS sustained) / blowup math / LLM inference
  alive    ServerAliveInterval=60 ServerAliveCountMax=3
  why      T1/T2 물리천장 측정 서버. SSH 장시간 명령 시 keepalive 필수 (HX_SSH_001).
  proof    scripts/ssh_alive_check.hexa
