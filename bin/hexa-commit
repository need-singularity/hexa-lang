#!/usr/bin/env bash
# bin/hexa-commit — canonical git-commit entry per raw 176 (hive/.raw L6785).
# Idempotency: same invocation on clean tree = no-op (no spurious commit).
# Safety gate INLINE (raw 168 minimum-viable): secret-scan + argv-block + co-author-trailer.
# Bypass: HEXA_SAFETY_ALLOW=<reason> (user-explicit-set only; AI agent MUST NOT auto-set).
# Selftest: hexa-commit --selftest
set -euo pipefail

# ─── argv-level block (raw 176 bans) ───
for arg in "$@"; do
  case "$arg" in
    --no-verify|--no-gpg-sign)
      echo "hexa-commit: BLOCKED argv '$arg' — raw 176 bans (use HEXA_SAFETY_ALLOW=<reason> for explicit user-authorized override)" >&2
      echo "reason=argv-banned-by-raw-176 fix=1) remove '$arg' 2) HEXA_SAFETY_ALLOW='<reason>' hexa-commit ... # explicit only" >&2
      exit 13
      ;;
  esac
done

# ─── secret-scan helper (raw 176 safety gate inline) — string + file content ───
# 외부 의존 0: bash + grep 만 (raw 9 hexa-only 예외 = bin shell-script 표면).
_secret_match() {
  local val="$1"
  if echo "$val" | grep -qE '(AKIA[0-9A-Z]{16}|gh[pousr]_[A-Za-z0-9]{36}|sk-[A-Za-z0-9]{32,}|-----BEGIN.*PRIVATE KEY-----)'; then
    echo "MATCH"; return
  fi
  echo "NO_MATCH"
}

# Scan file content for secret patterns. Returns MATCH on hit, NO_MATCH otherwise.
# Skips binary files (heuristic: file -b detect) — text-only scan.
# Lines containing '@raw176-test-fixture' annotation are EXCLUDED from match
# (allows selftest fake-key fixtures + self-bootstrap of bin/hexa-commit itself).
_secret_scan_file() {
  local path="$1"
  [ ! -f "$path" ] && { echo "NO_MATCH"; return; }
  # binary skip (-I) + exclude lines tagged @raw176-test-fixture
  if grep -IE '(AKIA[0-9A-Z]{16}|gh[pousr]_[A-Za-z0-9]{36}|sk-[A-Za-z0-9]{32,}|-----BEGIN[A-Z ]+PRIVATE KEY-----)' "$path" 2>/dev/null \
      | grep -vqE '@raw176-test-fixture'; then
    # had matches AND at least one wasn't tagged
    if grep -IE '(AKIA[0-9A-Z]{16}|gh[pousr]_[A-Za-z0-9]{36}|sk-[A-Za-z0-9]{32,}|-----BEGIN[A-Z ]+PRIVATE KEY-----)' "$path" 2>/dev/null \
        | grep -vE '@raw176-test-fixture' | grep -qE '.'; then
      echo "MATCH"; return
    fi
  fi
  echo "NO_MATCH"
}

# ─── selftest mode (deterministic, no git ops, no LLM) ───
if [ "${1:-}" = "--selftest" ]; then
  pass=0; fail=0
  # F1-F2: argv block
  if "$0" --no-verify -m "test" 2>/dev/null; then fail=$((fail+1)); else pass=$((pass+1)); fi
  if "$0" --no-gpg-sign -m "test" 2>/dev/null; then fail=$((fail+1)); else pass=$((pass+1)); fi
  # F3: dry-run mode
  if "$0" --dry-run 2>&1 | grep -q "DRY-RUN"; then pass=$((pass+1)); else fail=$((fail+1)); fi
  # F4-F5: secret-string match
  if [ "$(_secret_match 'AKIA1234567890ABCDEF')" = "MATCH" ]; then pass=$((pass+1)); else fail=$((fail+1)); fi  # @raw176-test-fixture
  if [ "$(_secret_match 'plain text no secret')" = "NO_MATCH" ]; then pass=$((pass+1)); else fail=$((fail+1)); fi
  # F6-F9: file-content scan (NEW — A안 fix-A) + bootstrap-paradox-prevention via marker
  TMPDIR_SELF="$(mktemp -d)"
  trap "rm -rf $TMPDIR_SELF" EXIT
  printf 'innocuous content\n' > "$TMPDIR_SELF/clean.txt"
  printf 'AKIAIOSFODNN7EXAMPLE leak\n' > "$TMPDIR_SELF/dirty.txt"  # @raw176-test-fixture
  printf '\x00\x01\x02binary\n' > "$TMPDIR_SELF/binary.bin"
  # @raw176-test-fixture-marker-test (line is tagged so should NOT match)
  printf 'AKIAIOSFODNN7EXAMPLE harmless # @raw176-test-fixture\n' > "$TMPDIR_SELF/marked.txt"
  if [ "$(_secret_scan_file "$TMPDIR_SELF/clean.txt")" = "NO_MATCH" ]; then pass=$((pass+1)); else fail=$((fail+1)); fi
  if [ "$(_secret_scan_file "$TMPDIR_SELF/dirty.txt")" = "MATCH" ]; then pass=$((pass+1)); else fail=$((fail+1)); fi
  if [ "$(_secret_scan_file "$TMPDIR_SELF/binary.bin")" = "NO_MATCH" ]; then pass=$((pass+1)); else fail=$((fail+1)); fi
  if [ "$(_secret_scan_file "$TMPDIR_SELF/marked.txt")" = "NO_MATCH" ]; then pass=$((pass+1)); else fail=$((fail+1)); fi
  rm -rf "$TMPDIR_SELF"; trap - EXIT
  total=$((pass+fail))
  echo "__HEXA_COMMIT_RESULT__ $([ $fail -eq 0 ] && echo PASS || echo FAIL) pass=$pass fail=$fail total=$total"
  [ $fail -eq 0 ] && exit 0 || exit 1
fi

# ─── dry-run mode ───
if [ "${1:-}" = "--dry-run" ]; then
  echo "hexa-commit DRY-RUN: would stage + commit per raw 176"
  git status --short 2>&1 || true
  exit 0
fi

# ─── idempotency: clean tree = no-op ───
if [ -z "$(git status --porcelain 2>/dev/null)" ]; then
  echo "hexa-commit: clean tree — no-op (raw 65 idempotency)"
  exit 0
fi

# ─── auto-stage CHANGED files only (NO git add -A / .) per raw 176 bans ───
# Enumerate modified + untracked, secret-scan each, exclude on match unless HEXA_SAFETY_ALLOW set.
SAFETY_ALLOW="${HEXA_SAFETY_ALLOW:-}"
staged_count=0
excluded_count=0
while IFS= read -r line; do
  [ -z "$line" ] && continue
  status="${line:0:2}"
  path="${line:3}"
  # secret filename heuristic
  base="$(basename "$path")"
  if echo "$base" | grep -qiE '\.(env|pem|key|p12|pfx)$|credential|secret|token|password'; then
    if [ -z "$SAFETY_ALLOW" ]; then
      echo "hexa-commit: EXCLUDED $path (secret-named, set HEXA_SAFETY_ALLOW to include)" >&2
      excluded_count=$((excluded_count+1))
      continue
    fi
  fi
  # secret CONTENT scan (A안 fix-A): file content grep for AWS/GitHub/OpenAI/PEM
  if [ -f "$path" ] && [ "$(_secret_scan_file "$path")" = "MATCH" ]; then
    if [ -z "$SAFETY_ALLOW" ]; then
      echo "hexa-commit: EXCLUDED $path (secret-content matched, set HEXA_SAFETY_ALLOW to include)" >&2
      excluded_count=$((excluded_count+1))
      continue
    fi
  fi
  git add -- "$path" 2>/dev/null && staged_count=$((staged_count+1)) || true
done < <(git status --porcelain 2>/dev/null)

if [ $staged_count -eq 0 ]; then
  echo "hexa-commit: 0 files staged (excluded=$excluded_count) — no-op" >&2
  exit 0
fi

# ─── commit message (use -m "<msg>" if provided, else generate) ───
MSG=""
while [ $# -gt 0 ]; do
  case "$1" in
    -m|--message) MSG="$2"; shift 2;;
    *) shift;;
  esac
done
if [ -z "$MSG" ]; then
  MSG="chore(hexa-commit): auto $(date -u +%Y-%m-%dT%H:%M:%SZ) ($staged_count file)"
fi
TRAILER="Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>"

# ─── audit emit (raw 77 schema) ───
AUDIT="${HEXA_COMMIT_AUDIT:-state/hexa_commit_audit/audit.jsonl}"
mkdir -p "$(dirname "$AUDIT")" 2>/dev/null || true
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
printf '%s\n' "{\"ts\":\"$TS\",\"actor\":\"hexa-commit\",\"staged_count\":$staged_count,\"excluded_count\":$excluded_count,\"safety_allow\":\"${SAFETY_ALLOW:+set}\",\"classifier_version\":\"hexa_commit_canonical.v1\"}" >> "$AUDIT" 2>/dev/null || true

# ─── commit ───
git commit -m "$(printf '%s\n\n%s\n' "$MSG" "$TRAILER")" || exit $?
echo "hexa-commit: ok ($staged_count file, excluded=$excluded_count)"
