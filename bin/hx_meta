#!/usr/bin/env bash
# bin/hx_meta — thin shim for tool/hx_meta.hexa (hexa-lang self meta CLI).
# Spec: docs/hexa_lang_meta_evolution_proposal_20260422.md §Phase 4.
set -eu

HEXA_DIR="$(cd "$(dirname "$0")/.." && pwd)"
HEXA_BIN="$HEXA_DIR/hexa"
TOOL_SRC="$HEXA_DIR/tool/hx_meta.hexa"
AOT_BIN="$HEXA_DIR/bin/hx_meta.native"

if [ -x "$AOT_BIN" ] && [ "$AOT_BIN" -nt "$TOOL_SRC" ]; then
    exec "$AOT_BIN" "$@"
fi

if [ ! -x "$HEXA_BIN" ]; then
    echo "hx_meta: interpreter not executable at $HEXA_BIN" >&2
    exit 2
fi
if [ ! -f "$TOOL_SRC" ]; then
    echo "hx_meta: source missing at $TOOL_SRC" >&2
    exit 3
fi

exec "$HEXA_BIN" "$TOOL_SRC" "$@"
