#!/usr/bin/env bash
# bin/escalate — Claude Code side client for the unsandboxed escalator daemon.
#
# Submits a request to /tmp/hexa_escalate/, waits for the result, prints it.
# The daemon (tool/escalator.hexa + com.hexa-lang.escalator.plist) must be
# bootstrapped once via:
#     launchctl bootstrap gui/$UID \
#         ~/core/hexa-lang/config/launchd/com.hexa-lang.escalator.plist
#
# Afterwards, all sessions (sandboxed or not) can escalate via this tool.
#
# Usage
#   bin/escalate write-file <abs-path>            # content on stdin
#   bin/escalate invoke-tool <tool-abs-path> [args...]
#   bin/escalate launchctl-bootstrap <plist-abs-path>
#
# Exit codes
#   0  = ok                2 = bad args            3 = policy reject
#   4  = malformed req     5 = daemon not running  6 = timeout
set -euo pipefail

QUEUE=/tmp/hexa_escalate
mkdir -p "$QUEUE"

if [ "$#" -lt 1 ]; then
    cat >&2 <<EOF
usage: escalate sh '<any shell command>'               # raw exec, stdout returned
       escalate write-file <abs-path>                  # content on stdin
       escalate invoke-tool <tool-abs-path> [args...]
       escalate launchctl-bootstrap <plist-abs-path>
EOF
    exit 2
fi

op="$1"; shift
ts=$(date +%s)_$$_${RANDOM}
req="$QUEUE/$ts.req"
result="$QUEUE/$ts.result"

# Daemon liveness probe — launchctl list returns rc=0 if loaded, nonzero else.
if ! launchctl print "gui/$(id -u)/com.hexa-lang.escalator" >/dev/null 2>&1; then
    cat >&2 <<'EOF'
escalate: com.hexa-lang.escalator daemon is not loaded.
Run this once in your terminal (outside Claude Code's sandbox):

    launchctl bootstrap gui/$UID \
        ~/core/hexa-lang/config/launchd/com.hexa-lang.escalator.plist

EOF
    exit 5
fi

case "$op" in
    sh)
        [ "$#" -ge 1 ] || { echo "escalate sh: command required" >&2; exit 2; }
        python3 -c "
import json, sys
json.dump({'op':'raw_exec','cmd':sys.argv[1]}, open(sys.argv[2],'w'))
" "$1" "$req"
        ;;
    write-file)
        [ "$#" -ge 1 ] || { echo "escalate write-file: path required" >&2; exit 2; }
        path="$1"
        content_file="$QUEUE/$ts.content"
        cat > "$content_file"
        python3 -c "
import json, sys
json.dump({'op':'write_file','path':sys.argv[1],'content_file':sys.argv[2]}, open(sys.argv[3],'w'))
" "$path" "$content_file" "$req"
        ;;
    invoke-tool)
        [ "$#" -ge 1 ] || { echo "escalate invoke-tool: tool path required" >&2; exit 2; }
        python3 -c "
import json, sys
json.dump({'op':'invoke_tool','argv':sys.argv[1:-1]}, open(sys.argv[-1],'w'))
" "$@" "$req"
        ;;
    launchctl-bootstrap)
        [ "$#" -ge 1 ] || { echo "escalate launchctl-bootstrap: plist path required" >&2; exit 2; }
        python3 -c "
import json, sys
json.dump({'op':'launchctl_bootstrap','plist':sys.argv[1]}, open(sys.argv[2],'w'))
" "$1" "$req"
        ;;
    *)
        echo "escalate: unknown op '$op'" >&2
        exit 2
        ;;
esac

# Wait up to 15 seconds for the result (daemon wakes every 2s via StartInterval).
for _ in $(seq 1 150); do
    [ -f "$result" ] && break
    sleep 0.1
done

if [ ! -f "$result" ]; then
    echo "escalate: timeout waiting for daemon (check /tmp/hexa_escalator.log)" >&2
    exit 6
fi

rc=$(python3 -c "import json; print(json.load(open('$result'))['rc'])")
cat "$result"
rm -f "$result"
exit "$rc"
