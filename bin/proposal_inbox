#!/usr/bin/env bash
# bin/proposal_inbox — shim to tool/proposal_inbox.hexa (cross-repo proposal inbox).
set -eu
HEXA_DIR="$(cd "$(dirname "$0")/.." && pwd)"
HEXA_BIN="$HEXA_DIR/hexa"
TOOL_SRC="$HEXA_DIR/tool/proposal_inbox.hexa"
if [ ! -x "$HEXA_BIN" ]; then
  echo "proposal_inbox: hexa binary missing at $HEXA_BIN" >&2
  exit 127
fi
exec "$HEXA_BIN" "$TOOL_SRC" "$@"
