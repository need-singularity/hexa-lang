#!/usr/bin/env bash
# bin/project-safe-exec — project-entry 강제 wrapper (os-level).
#
# USAGE
#   project-safe-exec [--allow <csv>] <cmd> [args...]
#
#   --allow hexa-lang,nexus  — 진입 허용 repo 쉼표 목록 (hexa-lang 자신 + shared
#                               는 언제나 허용, 별도 명시 불필요)
#
#   DESIGNATED_PROJECTS env var 도 같은 역할. CLI 인자 우선.
#
# 동작 (macOS)
#   1. ALLOW 목록을 `(allow file-read* (subpath "/Users/ghost/core/<X>"))`
#      SBPL 라인으로 변환.
#   2. self/sbpl/project_entry.sb 앞에 append 해 임시 프로파일 생성.
#   3. sandbox-exec -f <tmp_profile> <cmd ...> 으로 실행.
#   4. 지정 외 repo 읽기 → kernel EPERM (Operation not permitted).
#
# OPT-OUT
#   NEXUS_PROJECT_ENTRY_OK=1 — wrapper 스킵 (sandbox 없이 원본 cmd 실행).
#                              명시적 user 승인 경로 외 사용 금지.
#
# RATIONALE
#   raw#<pending> project-entry — AI 가 같은 루트 하위라는 이유만으로 미지정
#   프로젝트 진입 금지. 코드 수준 + OS 수준 동시 enforce.
set -eu

if [ "${NEXUS_PROJECT_ENTRY_OK:-}" = "1" ]; then
  exec "$@"
fi

HEXA_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BASE_PROFILE="$HEXA_DIR/self/sbpl/project_entry.sb"
if [ ! -f "$BASE_PROFILE" ]; then
  echo "project-safe-exec: base profile missing: $BASE_PROFILE" >&2
  exit 2
fi

ALLOW="${DESIGNATED_PROJECTS:-}"
if [ $# -ge 2 ] && [ "$1" = "--allow" ]; then
  ALLOW="$2"
  shift 2
fi

if [ $# -eq 0 ]; then
  echo "usage: project-safe-exec [--allow <csv>] <cmd> [args...]" >&2
  exit 2
fi

# macOS only (sandbox-exec). Linux side delegates to native_gate.so path.
if ! command -v sandbox-exec >/dev/null 2>&1; then
  echo "project-safe-exec: sandbox-exec missing (non-macOS?)." >&2
  echo "  Linux path: set LD_PRELOAD=\$HEXA_LANG/self/native/project_entry.so" >&2
  echo "  emergency bypass: NEXUS_PROJECT_ENTRY_OK=1 ..." >&2
  exit 3
fi

# Build temp profile with allowlist injected.
TMP_PROFILE="$(mktemp -t project_entry_XXXXXX.sb)"
trap 'rm -f "$TMP_PROFILE"' EXIT
cp "$BASE_PROFILE" "$TMP_PROFILE"
if [ -n "$ALLOW" ]; then
  IFS=',' read -r -a REPOS <<< "$ALLOW"
  {
    echo ""
    echo ";; wrapper-injected allowlist"
    for r in "${REPOS[@]}"; do
      r_trim="$(echo "$r" | tr -d '[:space:]')"
      [ -z "$r_trim" ] && continue
      printf '(allow file-read* (subpath "/Users/ghost/core/%s"))\n' "$r_trim"
    done
  } >> "$TMP_PROFILE"
fi

exec sandbox-exec -f "$TMP_PROFILE" "$@"
