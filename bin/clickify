#!/usr/bin/env bash
# bin/clickify — wrap file paths in OSC 8 hyperlinks so cmd+click in Void
# (or any OSC 8 capable terminal) opens them via the system handler.
#
# macOS resolves file:// URLs through `open`, so a clicked .md goes to the
# user's default markdown viewer / editor.
#
# Usage:
#   clickify path/to/file.md                          # one path → wrapped path → stdout
#   clickify path/a path/b                            # space-separated wrapped paths
#   echo path/to/file.md | clickify                   # filter mode (each line wrapped)
#   grep -rl pattern . | clickify                     # pipeline mode

set -eu

esc=$'\033'
bel=$'\007'

emit() {
  local raw="$1"
  # Resolve to absolute path; tolerate non-existing paths by walking up
  # until we find an existing prefix and reattaching the remainder.
  local abs
  if [ -e "$raw" ]; then
    abs="$(cd "$(dirname "$raw")" 2>/dev/null && pwd)/$(basename "$raw")"
  else
    abs="$(pwd)/$raw"
  fi
  printf '%s]8;;file://%s%s%s%s]8;;%s' "$esc" "$abs" "$bel" "$raw" "$esc" "$bel"
}

if [ "$#" -gt 0 ]; then
  sep=""
  for p in "$@"; do
    printf '%s' "$sep"
    emit "$p"
    sep=" "
  done
  printf '\n'
else
  while IFS= read -r line; do
    emit "$line"
    printf '\n'
  done
fi
