#!/usr/bin/env bash
# bin/roadmap_engine — thin shim forwarding to tool/roadmap_engine.hexa.
#
# Canonical query CLI referenced by docs/roadmap_engine_continuous_meta_proposal_20260422.md.
# Prefers the AOT binary at bin/roadmap_engine.native if present and newer than the
# .hexa source; otherwise falls back to the interpreter.
set -eu

HEXA_DIR="$(cd "$(dirname "$0")/.." && pwd)"
HEXA_BIN="$HEXA_DIR/hexa"
TOOL_SRC="$HEXA_DIR/tool/roadmap_engine.hexa"
AOT_BIN="$HEXA_DIR/bin/roadmap_engine.native"

if [ -x "$AOT_BIN" ] && [ "$AOT_BIN" -nt "$TOOL_SRC" ]; then
    exec "$AOT_BIN" "$@"
fi

if [ ! -x "$HEXA_BIN" ]; then
    echo "roadmap_engine: interpreter not executable at $HEXA_BIN" >&2
    exit 2
fi
if [ ! -f "$TOOL_SRC" ]; then
    echo "roadmap_engine: source missing at $TOOL_SRC" >&2
    exit 3
fi

exec "$HEXA_BIN" "$TOOL_SRC" "$@"
