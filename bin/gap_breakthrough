#!/usr/bin/env bash
# bin/gap_breakthrough — Claude CLI 가 직접 gap 감지 + 돌파 시도하는 단일 진입점.
#
# user 원칙 (2026-04-23):
#   "진행 과정, 응답 등에도 gap 감지 자동"
#   "claude code cli 가 직접 돌파 시도할 수 있게 도구 손에 쥐어줘"
#   "airgenome cli hook 으로 처리해도 됨"
#
# USAGE
#   gap_breakthrough detect '<text>'        — 텍스트에서 gap 패턴 감지
#                                              출력: category + title 후보 (JSON line)
#   gap_breakthrough submit <text>          — detect + proposal_inbox submit 자동
#   gap_breakthrough report [--repo <r>]    — 최근 감지/처리 요약
#
# PATTERN MATCHING
#   [Syntax] line N:M           → lang_gap (hexa parser)
#   CODEGEN ERROR               → lang_gap (hexa codegen)
#   unhandled method:           → lang_gap (hexa runtime missing primitive)
#   Exec format error           → resource_gap (arch mismatch — Linux binary)
#   Operation not permitted     → infra_gap (permissions/sandbox)
#   sandbox_apply               → infra_gap (nested sandbox)
#   EPERM                       → infra_gap (일반 permission)
#   ConnectTimeout              → resource_gap (network)
#   SIGKILL                     → resource_gap (OOM)
#   undeclared identifier       → lang_gap (AOT mangling)
#   fast-forward                → infra_gap (git push reject)
#   all_unreachable             → resource_gap (remote down)
#
# 우회: NEXUS_GAP_BREAKTHROUGH_OK=1 (옵션, default 는 항상 가동)
set -eu

HEXA_DIR="$(cd "$(dirname "$0")/.." && pwd)"
INBOX_BIN="$HEXA_DIR/bin/proposal_inbox"

usage() {
  sed -n '/^# USAGE/,/^$/p' "$0" | sed 's/^# \?//'
}

cmd="${1:-}"
shift || true

case "$cmd" in
  detect|detect-text)
    text="${1:-}"
    if [ -z "$text" ]; then
      # stdin 에서 읽기
      text="$(cat)"
    fi
    python3 - <<PY
import re, json, sys
text = """$text"""
patterns = [
    (r'\[Syntax\] line \d+:\d+',                    'lang_gap',     'hexa parser Syntax'),
    (r'CODEGEN ERROR',                               'lang_gap',     'hexa codegen'),
    (r'unhandled method:\s*(\w+)',                   'lang_gap',     'hexa runtime missing primitive'),
    (r'undeclared identifier',                       'lang_gap',     'hexa AOT prefix mangling'),
    (r'Exec format error',                           'resource_gap', 'arch mismatch (Linux binary 등)'),
    (r'sandbox_apply: Operation not permitted',      'infra_gap',    'nested sandbox'),
    (r'Operation not permitted|EPERM',               'infra_gap',    'permission/lock'),
    (r'ConnectTimeout|timed out',                    'resource_gap', 'network timeout'),
    (r'SIGKILL|killed',                              'resource_gap', 'OOM or forced kill'),
    (r'all_unreachable|remote_unavailable',          'resource_gap', 'remote host down'),
    (r'fast-forward|rejected',                       'infra_gap',    'git push reject'),
    (r'no matches found',                            'lang_gap',     'shell glob no-match'),
]
hits = []
for pat, cat, note in patterns:
    m = re.search(pat, text)
    if m:
        hits.append({'category': cat, 'note': note, 'match': m.group(0)[:80]})
if not hits:
    print(json.dumps({'status': 'no_gap_detected'}))
else:
    for h in hits:
        print(json.dumps(h, ensure_ascii=False))
PY
    ;;

  submit)
    text="${1:-}"
    if [ -z "$text" ]; then
      text="$(cat)"
    fi
    detections="$("$0" detect "$text")"
    echo "$detections" | while IFS= read -r line; do
      cat=$(echo "$line" | python3 -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('category',''))" 2>/dev/null)
      note=$(echo "$line" | python3 -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('note',''))" 2>/dev/null)
      match=$(echo "$line" | python3 -c "import json,sys; d=json.loads(sys.stdin.read()); print(d.get('match',''))" 2>/dev/null)
      if [ -n "$cat" ]; then
        title="gap-auto: $note — pattern='$match'"
        echo "  → submit to hexa-lang inbox: $title"
        "$INBOX_BIN" submit --to hexa-lang --from "$(basename "$(pwd)")" \
          --kind cluster --category "$cat" --priority 85 \
          --title "$title" 2>&1 | grep -v 'security warning' | tail -1 || true
      fi
    done
    ;;

  report)
    repo="${2:-hexa-lang}"
    if [ "${1:-}" = "--repo" ]; then
      repo="$2"
    fi
    "$INBOX_BIN" list --repo "$repo" --category lang_gap 2>&1 | grep -v 'security warning' | tail -20
    echo "---"
    "$INBOX_BIN" list --repo "$repo" --category resource_gap 2>&1 | grep -v 'security warning' | tail -20
    ;;

  help|--help|-h|"")
    usage
    ;;

  *)
    echo "gap_breakthrough: unknown subcommand '$cmd'" >&2
    echo "try: gap_breakthrough help" >&2
    exit 2
    ;;
esac
