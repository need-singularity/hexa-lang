#!/usr/bin/env bash
# bin/hexa-push ‚Äî canonical git-push entry per raw 176 (hive/.raw L6785).
# Idempotency: same invocation on synced tree = no-op.
# Safety gate INLINE: ff-only + protected-ref-block + auto pull-rebase 1x retry.
# Bypass: HEXA_SAFETY_ALLOW=<reason> (user-explicit only).
set -euo pipefail

# ‚îÄ‚îÄ‚îÄ argv-level block (raw 176 bans) ‚îÄ‚îÄ‚îÄ
for arg in "$@"; do
  case "$arg" in
    --force|-f|--force-with-lease|--mirror)
      echo "hexa-push: BLOCKED argv '$arg' ‚Äî raw 176 bans force-push" >&2
      echo "reason=argv-banned-by-raw-176 fix=1) remove '$arg' 2) HEXA_SAFETY_ALLOW='<reason>' git push --force # explicit user-only path bypasses hexa-push entirely" >&2
      exit 13
      ;;
  esac
done

# ‚îÄ‚îÄ‚îÄ selftest mode ‚îÄ‚îÄ‚îÄ
if [ "${1:-}" = "--selftest" ]; then
  pass=0; fail=0
  if "$0" --force 2>/dev/null; then fail=$((fail+1)); else pass=$((pass+1)); fi
  if "$0" -f 2>/dev/null; then fail=$((fail+1)); else pass=$((pass+1)); fi
  if "$0" --force-with-lease 2>/dev/null; then fail=$((fail+1)); else pass=$((pass+1)); fi
  if "$0" --mirror 2>/dev/null; then fail=$((fail+1)); else pass=$((pass+1)); fi
  if "$0" --dry-run 2>&1 | grep -q "DRY-RUN"; then pass=$((pass+1)); else fail=$((fail+1)); fi
  total=$((pass+fail))
  echo "__HEXA_PUSH_RESULT__ $([ $fail -eq 0 ] && echo PASS || echo FAIL) pass=$pass fail=$fail total=$total"
  [ $fail -eq 0 ] && exit 0 || exit 1
fi

# ‚îÄ‚îÄ‚îÄ dry-run ‚îÄ‚îÄ‚îÄ
if [ "${1:-}" = "--dry-run" ]; then
  echo "hexa-push DRY-RUN: would push current branch per raw 176"
  git status -sb 2>&1 || true
  exit 0
fi

# ‚îÄ‚îÄ‚îÄ must be on a branch ‚îÄ‚îÄ‚îÄ
BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
if [ -z "$BRANCH" ] || [ "$BRANCH" = "HEAD" ]; then
  echo "hexa-push: detached HEAD or no branch ‚Äî refusing" >&2
  exit 14
fi

# ‚îÄ‚îÄ‚îÄ idempotency: 0 ahead = no-op ‚îÄ‚îÄ‚îÄ
AHEAD="$(git rev-list --count "@{u}..HEAD" 2>/dev/null || echo '?')"
if [ "$AHEAD" = "0" ]; then
  echo "hexa-push: 0 ahead ‚Äî no-op (raw 65 idempotency)"
  exit 0
fi

# ‚îÄ‚îÄ‚îÄ audit emit ‚îÄ‚îÄ‚îÄ
AUDIT="${HEXA_PUSH_AUDIT:-state/hexa_commit_audit/audit.jsonl}"
mkdir -p "$(dirname "$AUDIT")" 2>/dev/null || true
TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
printf '%s\n' "{\"ts\":\"$TS\",\"actor\":\"hexa-push\",\"branch\":\"$BRANCH\",\"ahead\":\"$AHEAD\",\"safety_allow\":\"${HEXA_SAFETY_ALLOW:+set}\",\"classifier_version\":\"hexa_push_canonical.v1\"}" >> "$AUDIT" 2>/dev/null || true

# ‚îÄ‚îÄ‚îÄ push ff-only + auto pull-rebase 1x retry on non-FF ‚îÄ‚îÄ‚îÄ
if git push origin "$BRANCH" 2>&1; then
  echo "hexa-push: ok (branch=$BRANCH ahead=$AHEAD)"
  exit 0
fi
# non-FF retry
echo "hexa-push: non-FF detected ‚Äî auto pull --rebase 1x retry per raw 176" >&2
if git pull --rebase origin "$BRANCH" && git push origin "$BRANCH"; then
  echo "hexa-push: ok-after-rebase (branch=$BRANCH)"
  exit 0
fi
echo "hexa-push: FAIL ‚Äî pull --rebase produced conflict, halt for human resolution" >&2
echo "reason=non-ff-rebase-conflict fix=1) git status # see conflict 2) resolve 3) git rebase --continue && hexa-push" >&2
exit 15
