// 도구/compile.hexa — P4 self-host compiler driver
// Usage: ./hexa run 도구/compile.hexa input.hexa [output.c]
//
// Loads codegen_c2 at runtime, compiles input.hexa → C via codegen_c2_full.
// Standalone driver avoids hexa_v2 transpile issues with interpret/call_user_fn.

use "self/stdlib/law_io"

let av = args()
let mut input = ""
let mut output = ""
let mut i = 2
while i < len(av) {
    let a = av[i]
    if a == "run" {
        i = i + 1
    } else if input == "" {
        input = a
        i = i + 1
    } else if output == "" {
        output = a
        i = i + 1
    } else {
        i = i + 1
    }
}

if input == "" {
    println("Usage: ./hexa run 도구/compile.hexa <input.hexa> [output.c]")
    println("  Compiles input.hexa → C via codegen_c2_full")
}

if output == "" {
    output = input + ".c"
}

// Load codegen_c2
let cg_src = read_file("self/codegen_c2.hexa")
let cg_tokens = tokenize(cg_src)
let cg_ast = parse(cg_tokens)
interpret(cg_ast)

// Compile target
let src = read_file(input)
let tokens = tokenize(src)
let ast = parse(tokens)
let c_code = call_user_fn("codegen_c2_full", [ast])
let c_str = to_string(c_code)
safe_write_file(output, c_str)
println("[compile] " + input + " -> " + output + " (" + to_string(len(c_str)) + " bytes)")
