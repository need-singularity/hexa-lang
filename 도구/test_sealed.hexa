// 도구/test_sealed.hexa — @sealed 동작 검증
use "self/attrs/core"
use "self/attrs/sealed"
use "self/runtime/file_pure"

fn load_lines(path) {
    let raw = read_file_pure(path)
    raw.split("\n")
}

fn print_msgs(label, msgs) {
    println("")
    println("=== " + label + " ===")
    if len(msgs) == 0 {
        println("  (메시지 없음 - 통과)")
        return 0
    }
    for m in msgs {
        println("  " + fmt_msg(m))
    }
    len(msgs)
}

let fixture = "/tmp/sealed_test_fixture.md"
let sidecar = fixture + ".sealed.hash"

// 초기 콘텐츠 재작성 + sidecar 삭제
let init_content = "<!-- @sealed(allowed_via=@domain) -->\n<!-- gold-standard -->\n\n# Test\n\n## IMPACT\n\n<!-- @sealed:begin -->\nprotected\n<!-- @sealed:end -->\n"
write_file_pure(fixture, init_content)
exec("rm -f '" + sidecar + "'")

let lines1 = load_lines(fixture)
let decl = detect_sealed_decls(lines1, fixture)
println("[1] 선언 감지")
println("    file_sealed=" + to_string(decl[0]))
println("    allowed_via=" + decl[1])
println("    section_blocks=" + to_string(len(decl[2])))

let msgs_init = check_sealed(fixture, lines1)
print_msgs("[2] 최초 봉인 (info 기대)", msgs_init)

let lines2 = load_lines(fixture)
let msgs_pass = check_sealed(fixture, lines2)
print_msgs("[3] 변경 없음 - 재검증 (통과 기대)", msgs_pass)

// 수동 편집 시뮬레이션
let tampered = read_file_pure(fixture) + "\n악의적 수정\n"
write_file_pure(fixture, tampered)
let lines3 = load_lines(fixture)
let msgs_tamper = check_sealed(fixture, lines3)
print_msgs("[4] 수동 편집 감지 (error 기대)", msgs_tamper)

// reseal 후 통과
let current = read_file_pure(fixture)
reseal_file(fixture, current)
let lines4 = load_lines(fixture)
let msgs_reseal = check_sealed(fixture, lines4)
print_msgs("[5] reseal 후 재검증 (통과 기대)", msgs_reseal)

// no-op
let plain_path = "/tmp/sealed_plain.md"
write_file_pure(plain_path, "# 평범한 파일\n내용\n")
let lines5 = load_lines(plain_path)
let msgs_noop = check_sealed(plain_path, lines5)
print_msgs("[6] 선언 없는 파일 (no-op 기대)", msgs_noop)

println("")
println("== 테스트 완료 ==")
