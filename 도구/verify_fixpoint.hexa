// 도구/verify_fixpoint.hexa — P7-9 fixpoint verifier
//
// Confirms self-host fixpoint: hexa compiling itself produces the same
// bytes twice in a row. Reports SHA256 of each stage for audit.
//
// Pipeline:
//   seed:   build/hexa_stage0 (historical, frozen)
//   hexa_1 = seed → compile(hexa_full.hexa) → new binary
//   hexa_2 = hexa_1 → compile(hexa_full.hexa) → new binary
//   hexa_3 = hexa_2 → compile(hexa_full.hexa) → new binary
//
// Gate:
//   SHA256(hexa_2) == SHA256(hexa_3) → fixpoint reached
//   Cross-fixpoint: on Mac, also verify that hexa_3 cross-compiled to
//   linux-x86_64 matches ubu's local hexa_3 built from the same source.
//
// Usage:
//   hexa 도구/verify_fixpoint.hexa
//   hexa 도구/verify_fixpoint.hexa --target=linux-x86_64
//
// Output: JSON on stdout + shared/hexa-lang/fixpoint_log.json append.

struct Stage {
    name: string,
    path: string,
    sha256: string,
    size: int
}

fn sha256_of(path: string) -> string {
    let result = exec_with_status("sha256sum " + path + " 2>/dev/null || shasum -a 256 " + path)
    if result[1] != 0 { return "ERROR" }
    return result[0].split(" ")[0].trim()
}

fn compile_with(compiler: string, source: string, output: string, target: string) -> int {
    let cmd = compiler + " 도구/native_build.hexa " + source + " -o " + output
    if target != "" { cmd = cmd + " --target=" + target }
    let result = exec_with_status(cmd)
    if result[1] != 0 {
        eprintln("[fixpoint] compile failed: " + cmd)
        eprintln(result[0])
        return result[1]
    }
    return 0
}

fn verify_stage(name: string, path: string) -> Stage {
    if !file_exists(path) {
        eprintln("[fixpoint] missing: " + path)
        exit(1)
    }
    let sz = file_size(path)
    let hash = sha256_of(path)
    println("[fixpoint] " + name + " = " + hash + " (" + str(sz) + " bytes)")
    return Stage{ name: name, path: path, sha256: hash, size: sz }
}

fn main() {
    let av = argv()
    let mut target = ""
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a.starts_with("--target=") {
            target = a.slice(9, len(a))
        }
        i = i + 1
    }

    let seed = "build/hexa_stage0"
    let src = "self/hexa_full.hexa"
    let out1 = "build/hexa_fix1"
    let out2 = "build/hexa_fix2"
    let out3 = "build/hexa_fix3"

    if !file_exists(seed) {
        eprintln("[fixpoint] seed missing: " + seed)
        exit(1)
    }
    if !file_exists(src) {
        eprintln("[fixpoint] source missing: " + src)
        exit(1)
    }

    println("[fixpoint] === Stage 1: seed → hexa_1 ===")
    if compile_with(seed, src, out1, target) != 0 { exit(1) }
    let s1 = verify_stage("hexa_1", out1)

    println("[fixpoint] === Stage 2: hexa_1 → hexa_2 ===")
    if compile_with(out1, src, out2, target) != 0 { exit(1) }
    let s2 = verify_stage("hexa_2", out2)

    println("[fixpoint] === Stage 3: hexa_2 → hexa_3 ===")
    if compile_with(out2, src, out3, target) != 0 { exit(1) }
    let s3 = verify_stage("hexa_3", out3)

    // ── Fixpoint test: SHA256(hexa_2) == SHA256(hexa_3) ────────────
    let fixpoint_reached = if s2.sha256 == s3.sha256 { 1 } else { 0 }

    println("")
    println("[fixpoint] ================== RESULT ==================")
    println("[fixpoint] target    : " + target)
    println("[fixpoint] hexa_1    : " + s1.sha256)
    println("[fixpoint] hexa_2    : " + s2.sha256)
    println("[fixpoint] hexa_3    : " + s3.sha256)
    println("[fixpoint] converged : " + if fixpoint_reached == 1 { "YES ✓" } else { "NO ✗" })
    println("[fixpoint] ============================================")

    // ── Append to log ──────────────────────────────────────────────
    let ts = str(timestamp())
    let log_entry = "{\"ts\":" + ts + ",\"target\":\"" + target + "\","
        + "\"seed_sha256\":\"" + sha256_of(seed) + "\","
        + "\"hexa_1\":\"" + s1.sha256 + "\","
        + "\"hexa_2\":\"" + s2.sha256 + "\","
        + "\"hexa_3\":\"" + s3.sha256 + "\","
        + "\"converged\":" + str(fixpoint_reached) + "}\n"
    append_file("shared/hexa-lang/fixpoint_log.json", log_entry)

    if fixpoint_reached == 0 { exit(2) }
    exit(0)
}
