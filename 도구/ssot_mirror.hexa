use "self/stdlib/law_io"

// 도구/ssot_mirror.hexa — auto-patch divergent fn bodies between the two
// SSOTs. Companion to 도구/check_ssot_sync.hexa (bt 74).
//
// Strategy (bt 74-A):
//   * Parse each file into a list of (name, start_line, end_line, body_text).
//   * For every (fn_name, authority) pair on the CLI, lift the chosen
//     authority's raw body lines (including fn-signature + closing brace)
//     and splice them over the other file's body lines.
//   * Write the patched file back.
//
// This is a TEXTUAL mirror — we do NOT attempt to re-indent or merge;
// we copy the exact line range. The check_ssot_sync.hexa hash uses
// trim+blank+//-comment normalisation so any cosmetic whitespace change
// is absorbed on the re-verify pass.
//
// Brace-balance identification: `fn NAME(` at the start of a trimmed line
// begins a candidate block; we count `{` / `}` bytes line-by-line until
// depth returns to 0 after having opened at least once (same heuristic as
// check_ssot_sync.hexa — see the caveats there).
//
// Usage:
//   ssot_mirror [--dry-run] [--with-decls n1,n2,...] <target> <source> <fn1> <fn2>...
//
// bt 74-D fixes:
//   Bug 1 (critical): list-index assignment `a[j] = y` is a no-op in hexa
//     (lists are pass-by-value + `a[i]=v` doesn't mutate). The previous
//     bubble-sort used `todo_t_start[bj] = ...` which silently failed,
//     causing splices to execute in ORIGINAL CLI order instead of
//     tail-to-head. When the first processed fn grew in length, all
//     subsequent t_start indices were shifted and pointed into the wrong
//     location — splicing over unrelated lines and producing a corrupt,
//     interleaved target file. Fixed by using selection-via-rebuild:
//     instead of swapping in place, we rebuild the parallel arrays each
//     pass with the max-element moved to position si.
//
//   Bug 2: module-level decls referenced by new fn bodies were not
//     ported. RT 32-B/C/D added __VAL_INT_CACHE, __VAL_FLOAT_*,
//     __VAL_TRUE/FALSE/VOID, call_arg_buf, call_arg_top. Without porting
//     those, the mirrored fn body refs are unresolved. Added
//     `--with-decls` flag which ports named top-level `pub let mut NAME`
//     (or `let mut NAME`, or `fn NAME` for helper fns such as
//     __init_val_int_cache) declarations from source to target. Decls
//     are inserted immediately before the earliest-positioned mirrored
//     fn in target. If the same NAME already exists in target (scanned
//     at any brace-depth-0 position), the port is skipped.
//
// I1 pass-by-value: lists are reassigned via return.
// I2 Ident.name: not applicable (no AST nodes used).
// I3 args() raw[1..]: handled for CLI.
// R1 HEXA-FIRST: pure hexa, builtins only.

fn sm_count_byte(line, target_byte) {
    let bs = line.bytes()
    let n = len(bs)
    let mut c = 0
    let mut i = 0
    while i < n {
        if bs[i] == target_byte { c = c + 1 }
        i = i + 1
    }
    return c
}

fn sm_parse_fn_name(line_trimmed) {
    if !line_trimmed.starts_with("fn ") { return "" }
    let rest = line_trimmed.substring(3, len(line_trimmed))
    let lp = rest.index_of("(")
    if lp < 0 { return "" }
    return rest.substring(0, lp).trim()
}

// Given a source split by "\n", find fn `target` and return [start_idx, end_idx]
// (inclusive both ends). Returns [-1, -1] if not found.
fn sm_find_fn_range(lines, target) {
    let open_b = 123
    let close_b = 125
    let n = len(lines)
    let mut i = 0
    while i < n {
        let t = lines[i].trim()
        if t.starts_with("fn ") {
            let name = sm_parse_fn_name(t)
            if name == target {
                let mut depth = 0
                let mut opened = false
                let mut j = i
                while j < n {
                    let ln = lines[j]
                    let o = sm_count_byte(ln, open_b)
                    let c = sm_count_byte(ln, close_b)
                    depth = depth + o - c
                    if o > 0 { opened = true }
                    if opened {
                        if depth <= 0 {
                            return [i, j]
                        }
                    }
                    j = j + 1
                }
                // Unclosed — skip
                return [-1, -1]
            }
        }
        i = i + 1
    }
    return [-1, -1]
}

// Locate a module-level declaration or helper fn by NAME.
// Recognizes: `pub let mut NAME`, `let mut NAME`, `pub let NAME`, `let NAME`,
// and `fn NAME(` — returns the range [start, end] covering the entire decl
// (for `let` decls: usually 1 line; for `fn` decls: brace-balanced fn body).
//
// Top-level disambiguation: we require the prefix to appear at column 0 of
// the RAW line (not the trimmed line). Nested lets inside fn bodies are
// indented, so this correctly excludes them. We do NOT use a running
// brace-depth counter because source files contain string literals with
// '{' / '}' chars (e.g. grammar strings, regexp snippets) which a naive
// counter miscounts. This heuristic matches self/hexa_full.hexa's project
// convention that every module-level decl sits at column 0.
fn sm_find_decl_range(lines, target) {
    let open_b = 123
    let close_b = 125
    let n = len(lines)
    let mut i = 0
    while i < n {
        let raw = lines[i]
        // Column-0 top-level heuristic (see header note).
        let mut prefix = ""
        if raw.starts_with("pub let mut ") { prefix = "pub let mut " }
        if prefix == "" {
            if raw.starts_with("let mut ") { prefix = "let mut " }
        }
        if prefix == "" {
            if raw.starts_with("pub let ") { prefix = "pub let " }
        }
        if prefix == "" {
            if raw.starts_with("let ") { prefix = "let " }
        }
        if prefix != "" {
            let rest = raw.substring(len(prefix), len(raw))
            // name is up to first space or '=' or ':' or tab
            let mut k = 0
            let mut name = ""
            let rn = len(rest)
            while k < rn {
                let ch = rest.substring(k, k + 1)
                if ch == " " || ch == "=" || ch == ":" || ch == "\t" {
                    name = rest.substring(0, k)
                    k = rn
                } else {
                    k = k + 1
                }
            }
            if name == target {
                // Single-line decl usually; if the raw line has unbalanced
                // braces (multi-line struct literal), walk forward until
                // balanced. NOTE: brace-in-string caveat applies here too
                // but project convention has top-level decls on one line.
                let mut d = sm_count_byte(raw, open_b) - sm_count_byte(raw, close_b)
                let mut j = i
                while d != 0 {
                    j = j + 1
                    if j >= n { return [-1, -1] }
                    d = d + sm_count_byte(lines[j], open_b) - sm_count_byte(lines[j], close_b)
                }
                return [i, j]
            }
        }
        if raw.starts_with("fn ") {
            let fname = sm_parse_fn_name(raw.trim())
            if fname == target {
                // Reuse fn-range logic
                let mut fd = 0
                let mut opened = false
                let mut j = i
                while j < n {
                    let ln = lines[j]
                    let o = sm_count_byte(ln, open_b)
                    let c = sm_count_byte(ln, close_b)
                    fd = fd + o - c
                    if o > 0 { opened = true }
                    if opened && fd <= 0 { return [i, j] }
                    j = j + 1
                }
                return [-1, -1]
            }
        }
        i = i + 1
    }
    return [-1, -1]
}

// Scan target for a top-level ident reference. Returns true if NAME appears
// as a decl or fn at brace-depth 0. Used to skip porting decls that already
// exist in target.
fn sm_target_has_symbol(lines, target) {
    let r = sm_find_decl_range(lines, target)
    if r[0] >= 0 { return true }
    return false
}

// Build a fresh lines list: [0..target_start) + source[src_start..src_end]
// + (target_end+1..n). I1: return the new list.
fn sm_splice(target_lines, t_start, t_end, source_lines, s_start, s_end) {
    let mut out = []
    let tn = len(target_lines)
    let mut i = 0
    while i < t_start {
        out = out.push(target_lines[i])
        i = i + 1
    }
    let mut j = s_start
    while j <= s_end {
        out = out.push(source_lines[j])
        j = j + 1
    }
    let mut k = t_end + 1
    while k < tn {
        out = out.push(target_lines[k])
        k = k + 1
    }
    return out
}

// Insert `block_lines` at `at_idx` (push existing at_idx and beyond down).
fn sm_insert_at(target_lines, at_idx, block_lines) {
    let mut out = []
    let tn = len(target_lines)
    let bn = len(block_lines)
    let mut i = 0
    while i < at_idx {
        out = out.push(target_lines[i])
        i = i + 1
    }
    let mut k = 0
    while k < bn {
        out = out.push(block_lines[k])
        k = k + 1
    }
    let mut j = at_idx
    while j < tn {
        out = out.push(target_lines[j])
        j = j + 1
    }
    return out
}

fn sm_join_lines(lines) {
    let n = len(lines)
    let mut out = ""
    let mut i = 0
    while i < n {
        out = out + lines[i]
        if i < n - 1 { out = out + "\n" }
        i = i + 1
    }
    return out
}

// Split comma-separated ident list (skips empties).
fn sm_split_csv(s) {
    let mut out = []
    let n = len(s)
    let mut i = 0
    let mut cur = ""
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == "," {
            let c2 = cur.trim()
            if len(c2) > 0 { out = out.push(c2) }
            cur = ""
        } else {
            cur = cur + ch
        }
        i = i + 1
    }
    let c3 = cur.trim()
    if len(c3) > 0 { out = out.push(c3) }
    return out
}

// Selection-sort style tail-to-head processing: repeatedly find the max
// t_start among remaining items, process it, remove it. O(n^2) but n is
// small (tens of fns at most). Rebuilds arrays each pass — works around
// hexa list-index assignment being a no-op (bt 74-D bug 1 root cause).
fn sm_pop_max_index(t_start_list) {
    let n = len(t_start_list)
    if n == 0 { return -1 }
    let mut max_i = 0
    let mut max_v = t_start_list[0]
    let mut i = 1
    while i < n {
        if t_start_list[i] > max_v {
            max_v = t_start_list[i]
            max_i = i
        }
        i = i + 1
    }
    return max_i
}

fn sm_remove_at(lst, idx) {
    let n = len(lst)
    let mut out = []
    let mut i = 0
    while i < n {
        if i != idx { out = out.push(lst[i]) }
        i = i + 1
    }
    return out
}

// I3 args() raw[1..] — we use args()[2..] here because under stage0
// the real binary dup is at [0] and the script path at [1]; user args
// start at index 2. Under native hexa the same offset works because the
// native transpiler duplicates argv[0] (see hexa_set_args) — both runtimes
// route target_file to args()[2], source_file to args()[3].
let _args = args()
let _n = len(_args)

// Parse flags. Flags may appear before positional args.
let mut dry_run = false
let mut decls_csv = ""
let mut pos = []
let mut ai0 = 2
while ai0 < _n {
    let a = _args[ai0]
    if a == "--dry-run" {
        dry_run = true
        ai0 = ai0 + 1
    } else {
        if a == "--with-decls" {
            if ai0 + 1 >= _n {
                println("[ssot-mirror] FATAL --with-decls requires a comma-list arg")
                exit(2)
            }
            decls_csv = _args[ai0 + 1]
            ai0 = ai0 + 2
        } else {
            pos = pos.push(a)
            ai0 = ai0 + 1
        }
    }
}

if len(pos) < 3 {
    println("[ssot-mirror] usage: ssot_mirror [--dry-run] [--with-decls n1,n2,...] <target> <source> <fn1> [fn2...]")
    exit(2)
}
let target_path = pos[0]
let source_path = pos[1]

if !file_exists(target_path) {
    println("[ssot-mirror] FATAL target not found: " + target_path)
    exit(2)
}
if !file_exists(source_path) {
    println("[ssot-mirror] FATAL source not found: " + source_path)
    exit(2)
}

println("[ssot-mirror] target = " + target_path)
println("[ssot-mirror] source = " + source_path)
if dry_run { println("[ssot-mirror] mode   = DRY-RUN (no write)") }
if decls_csv != "" { println("[ssot-mirror] decls  = " + decls_csv) }

let target_src = read_file(target_path)
let source_src = read_file(source_path)
let mut target_lines = target_src.split("\n")
let source_lines = source_src.split("\n")

let mut applied = 0
let mut skipped = 0

// Resolve all fn ranges up front.
let mut todo_names = []
let mut todo_t_start = []
let mut todo_t_end = []
let mut todo_s_start = []
let mut todo_s_end = []

let pn = len(pos)
let mut ai = 2
while ai < pn {
    let fn_name = pos[ai]
    let tr = sm_find_fn_range(target_lines, fn_name)
    let sr = sm_find_fn_range(source_lines, fn_name)
    if tr[0] < 0 {
        println("[ssot-mirror] SKIP " + fn_name + " — not found in target")
        skipped = skipped + 1
    } else {
        if sr[0] < 0 {
            println("[ssot-mirror] SKIP " + fn_name + " — not found in source")
            skipped = skipped + 1
        } else {
            todo_names = todo_names.push(fn_name)
            todo_t_start = todo_t_start.push(tr[0])
            todo_t_end = todo_t_end.push(tr[1])
            todo_s_start = todo_s_start.push(sr[0])
            todo_s_end = todo_s_end.push(sr[1])
        }
    }
    ai = ai + 1
}

// bt 74-D bug 1 fix: process tail-to-head by repeatedly popping the max
// t_start. Using selection instead of in-place swap because hexa
// `a[i] = v` on a `let mut a = []` list is a no-op at runtime (see
// feedback_hexa_lists_pbv).
let mut min_t_start = -1
while len(todo_t_start) > 0 {
    let mi = sm_pop_max_index(todo_t_start)
    let fn_name = todo_names[mi]
    let t_start = todo_t_start[mi]
    let t_end = todo_t_end[mi]
    let s_start = todo_s_start[mi]
    let s_end = todo_s_end[mi]
    if min_t_start < 0 || t_start < min_t_start { min_t_start = t_start }
    target_lines = sm_splice(target_lines, t_start, t_end, source_lines, s_start, s_end)
    println("[ssot-mirror] MIRROR " + fn_name + "  target:L" + (t_start + 1) + "-L" + (t_end + 1) + "  <- source:L" + (s_start + 1) + "-L" + (s_end + 1))
    applied = applied + 1
    todo_names = sm_remove_at(todo_names, mi)
    todo_t_start = sm_remove_at(todo_t_start, mi)
    todo_t_end = sm_remove_at(todo_t_end, mi)
    todo_s_start = sm_remove_at(todo_s_start, mi)
    todo_s_end = sm_remove_at(todo_s_end, mi)
}

// bt 74-D bug 2 fix: --with-decls porting. Port named decls/helper fns
// from source to target, inserting them immediately before the earliest
// mirrored fn (min_t_start). Names already present in target at
// brace-depth 0 are skipped.
let decl_names = sm_split_csv(decls_csv)
let dn = len(decl_names)
if dn > 0 {
    let insert_idx_raw = min_t_start
    // If no fns were mirrored (e.g. pure decl-port run), fall back to
    // the first `fn ` occurrence at depth 0 in the current target.
    let mut insert_idx = insert_idx_raw
    if insert_idx < 0 {
        let tln = len(target_lines)
        let mut ii = 0
        while ii < tln {
            let tt = target_lines[ii].trim()
            if tt.starts_with("fn ") { insert_idx = ii; ii = tln } else { ii = ii + 1 }
        }
    }
    if insert_idx < 0 { insert_idx = len(target_lines) }

    // Build a single block of all to-be-inserted decls (preserves order).
    let mut block = []
    let mut di = 0
    while di < dn {
        let dname = decl_names[di]
        if sm_target_has_symbol(target_lines, dname) {
            println("[ssot-mirror] DECL-SKIP " + dname + " — already in target")
        } else {
            let dr = sm_find_decl_range(source_lines, dname)
            if dr[0] < 0 {
                println("[ssot-mirror] DECL-SKIP " + dname + " — not found in source")
                skipped = skipped + 1
            } else {
                println("[ssot-mirror] DECL-PORT " + dname + "  source:L" + (dr[0] + 1) + "-L" + (dr[1] + 1) + "  -> target:L" + (insert_idx + 1))
                let mut k = dr[0]
                while k <= dr[1] {
                    block = block.push(source_lines[k])
                    k = k + 1
                }
                applied = applied + 1
            }
        }
        di = di + 1
    }
    if len(block) > 0 {
        target_lines = sm_insert_at(target_lines, insert_idx, block)
    }
}

let out_src = sm_join_lines(target_lines)
if dry_run {
    println("[ssot-mirror] DRY-RUN — would write " + (len(target_lines)) + " lines to " + target_path)
} else {
    safe_write_file(target_path, out_src)
    println("[ssot-mirror] wrote   = " + target_path)
}

println("")
println("[ssot-mirror] applied = " + (applied))
println("[ssot-mirror] skipped = " + (skipped))

if skipped > 0 { exit(1) }
exit(0)
