// 도구/poc_lint.hexa
//
// Convention linter for self/poc/<cat>/<snake>.hexa handlers.
//
// Rules:
//   R1 filename → fn    Each handler file contains fn `poc_<cat2>_<snake>`
//                       where cat2 = {expr: ex, stmt: st, builtin: bi}
//                       and <snake> = filename minus ".hexa".
//   R2 annotation       Line 2 of the file is a comment declaring the
//                       dispatch key(s):
//                         expr/stmt  →  // @kinds Foo[, Bar, ...]
//                         builtin    →  // @name Foo[, Bar, ...]  OR
//                                        // @method X
//   R3 unique keys      Every @kinds / @name key appears in exactly one
//                       file (across the whole directory tree).
//
// Usage:  hexa 도구/poc_lint.hexa
// Exit:   0 clean, 1 violations.

let CATS = [["expr", "ex"], ["stmt", "st"], ["builtin", "bi"]]

fn strip(s) {
    let mut i = 0
    while i < len(s) && (s[i] == " " || s[i] == "\t") { i = i + 1 }
    let mut j = len(s) - 1
    while j >= i && (s[j] == " " || s[j] == "\t" || s[j] == "\r" || s[j] == "\n") { j = j - 1 }
    if j < i { return "" }
    return s.substring(i, j + 1)
}

// `*_test.hexa` files are co-located handler tests (see 도구/poc_test.hexa).
// They follow a different naming convention (`fn poc_test_<cat2>_<snake>`) and
// carry `@test` annotations instead of `@kinds`/`@name`. The lint contract only
// applies to *handler* files, so skip them here.
fn is_test_file(path) {
    let n = len(path)
    if n < 10 { return false }
    let suf = "_test.hexa"
    let mut k = 0
    while k < 10 {
        if path[n - 10 + k] != suf[k] { return false }
        k = k + 1
    }
    return true
}

fn list_dir_hexa(dir) {
    let raw = exec("ls " + dir + "/*.hexa 2>/dev/null")
    if raw == "" { return [] }
    let lines = raw.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let s = strip(lines[i])
        if s != "" && !is_test_file(s) { out = out.push(s) }
        i = i + 1
    }
    return out
}

fn basename_noext(path) {
    let mut last = -1
    let mut i = 0
    while i < len(path) { if path[i] == "/" { last = i } ; i = i + 1 }
    let start = last + 1
    let out = path.substring(start, len(path))
    // strip ".hexa"
    let n = len(out)
    if n > 5 && out[n - 5] == "." { return out.substring(0, n - 5) }
    return out
}

fn starts_with(s, p) {
    return s.starts_with(p)
}

fn split_by_comma(s) {
    let mut out = []
    let mut start = 0
    let mut i = 0
    while i < len(s) {
        if s[i] == "," {
            out = out.push(strip(s.substring(start, i)))
            start = i + 1
        }
        i = i + 1
    }
    let last = strip(s.substring(start, len(s)))
    if last != "" { out = out.push(last) }
    return out
}

// Extract the annotation value after "// @<tag> " on a trimmed line.
// Returns "" if no match.
fn annot_val(line, tag) {
    let prefix = "// @" + tag
    if !starts_with(line, prefix) { return "" }
    // After prefix, expect space then payload.
    let mut i = len(prefix)
    while i < len(line) && (line[i] == " " || line[i] == "\t") { i = i + 1 }
    return strip(line.substring(i, len(line)))
}

fn extract_fn_name(src) {
    // Find first `fn poc_` at the start of a line.
    let lines = src.split("\n")
    let mut i = 0
    while i < len(lines) {
        let s = lines[i]
        if starts_with(s, "fn poc_") {
            // After "fn ", read identifier until "("
            let mut j = 3
            while j < len(s) && s[j] != "(" && s[j] != " " { j = j + 1 }
            return s.substring(3, j)
        }
        // Also handle attrs line like `@pure fn poc_...`
        if starts_with(s, "@pure fn poc_") {
            let mut j = 9
            while j < len(s) && s[j] != "(" && s[j] != " " { j = j + 1 }
            return s.substring(9, j)
        }
        i = i + 1
    }
    return ""
}

fn main() {
    let mut fail = 0
    let mut kind_owner_keys = []     // "<cat>:<KIND>"  — tracks owner file
    let mut kind_owner_files = []
    let mut c = 0
    while c < len(CATS) {
        let cat = CATS[c][0]
        let prefix = CATS[c][1]
        let dir = "self/poc/" + cat
        let files = list_dir_hexa(dir)
        let mut fi = 0
        while fi < len(files) {
            let path = files[fi]
            let base = basename_noext(path)
            let expected_fn = "poc_" + prefix + "_" + base
            let src = read_file(path)
            if src == "" {
                println("[poc-lint] FAIL read: " + path)
                fail = fail + 1
                fi = fi + 1
                continue
            }
            let got_fn = extract_fn_name(src)
            if got_fn == "" {
                println("[poc-lint] R1 missing fn: " + path + "  (expected " + expected_fn + ")")
                fail = fail + 1
            } else if got_fn != expected_fn {
                println("[poc-lint] R1 name mismatch: " + path)
                println("    expected: " + expected_fn)
                println("    found:    " + got_fn)
                fail = fail + 1
            }

            // R2 annotation on line 2
            let lines = src.split("\n")
            let mut ann = ""
            let mut is_kind = false
            let mut is_method = false
            let mut i = 1
            while i < len(lines) && i < 5 {
                let s = strip(lines[i])
                if s != "" {
                    if cat == "builtin" {
                        let v = annot_val(s, "name")
                        if v != "" { ann = v; break }
                        let m = annot_val(s, "method")
                        if m != "" { ann = m; is_method = true; break }
                    } else {
                        let v = annot_val(s, "kinds")
                        if v != "" { ann = v; is_kind = true; break }
                    }
                }
                i = i + 1
            }
            if ann == "" {
                let tag = if cat == "builtin" { "@name or @method" } else { "@kinds" }
                println("[poc-lint] R2 missing " + tag + ": " + path)
                fail = fail + 1
            } else if !is_method {
                // R3 uniqueness: register each key.
                let keys = split_by_comma(ann)
                let mut ki = 0
                while ki < len(keys) {
                    let k = keys[ki]
                    if k != "" {
                        let full = cat + ":" + k
                        // Search for duplicate.
                        let mut di = 0
                        let mut dup = -1
                        while di < len(kind_owner_keys) {
                            if kind_owner_keys[di] == full { dup = di; break }
                            di = di + 1
                        }
                        if dup >= 0 {
                            println("[poc-lint] R3 duplicate " + full + ":")
                            println("    first:  " + kind_owner_files[dup])
                            println("    second: " + path)
                            fail = fail + 1
                        } else {
                            kind_owner_keys = kind_owner_keys.push(full)
                            kind_owner_files = kind_owner_files.push(path)
                        }
                    }
                    ki = ki + 1
                }
            }
            fi = fi + 1
        }
        c = c + 1
    }
    if fail == 0 {
        println("[poc-lint] OK — " + str(len(kind_owner_keys)) + " keys registered across expr/stmt/builtin")
        exit(0)
    }
    println("[poc-lint] FAIL — " + str(fail) + " violation(s)")
    exit(1)
}
