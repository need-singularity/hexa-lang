// 도구/install_wrapper.hexa — Phase α hexa-native wrapper install 가이드
//
// 목적:
//   `hexa file.hexa` 실행 전에 law_check 자동 호출하는 wrapper alias/function 생성.
//   사용자 shell config (~/.bashrc 또는 ~/.zshrc) 에 직접 삽입 가능한 one-liner 출력.
//
// 원칙:
//   · repo 에 .sh 파일 두지 않음 (edict #7 HEXA-ONLY 준수)
//   · hexa 바이너리 rename 하지 않음 (기존 경로 보존)
//   · 설치/해제 사용자 수동 — 투명성 확보
//
// 사용:
//   hexa 도구/install_wrapper.hexa           — alias 가이드 출력
//   hexa 도구/install_wrapper.hexa --copy    — 클립보드 복사 (macOS pbcopy)
//   hexa 도구/install_wrapper.hexa --verify  — 현재 alias 설치 여부 확인

let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args = cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

fn _pwd() -> string {
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p
}

fn _uname() -> string {
    return to_string(exec("uname 2>/dev/null")).trim()
}

fn _shell() -> string {
    let s = env("SHELL")
    if s != "" { return s }
    return to_string(exec("basename \"$SHELL\" 2>/dev/null || echo bash")).trim()
}

let mut verify_mode = false
let mut copy_mode = false
for a in cli_args {
    if a == "--verify" { verify_mode = true }
    if a == "--copy"   { copy_mode = true }
}

let root = _pwd()

// ─── shell config 경로 감지 ─────────────────────────────────
fn _rc_path() -> string {
    let home = env("HOME")
    let shell = _shell()
    if shell.contains("zsh") { return home + "/.zshrc" }
    return home + "/.bashrc"
}

// ─── alias 출력 대상 function (bash/zsh 호환) ──────────────
fn _hexa_function(project_root: string) -> string {
    return "# hexa-lang wrapper (Phase α) — law_check auto-gate\n" +
           "# installed by: hexa 도구/install_wrapper.hexa\n" +
           "hexa() {\n" +
           "    local proj=\"" + project_root + "\"\n" +
           "    local real=\"${HEXA_REAL:-$proj/hexa}\"\n" +
           "    # 재진입 방지 + hexa 도구/* 자체 호출은 스킵\n" +
           "    if [ -z \"$HEXA_LAW_OK\" ] && [[ \"$*\" != *도구/law_check.hexa* ]] && [[ \"$*\" != *도구/install_wrapper.hexa* ]]; then\n" +
           "        HEXA_LAW_OK=1 \"$real\" \"$proj/도구/law_check.hexa\" --warn-only 2>&1 | grep -qE 'compile 차단|🚫' && {\n" +
           "            echo '🚫 hexa law gate violation — use `HEXA_LAW_OK=1 hexa ...` to force' >&2\n" +
           "            return 1\n" +
           "        }\n" +
           "    fi\n" +
           "    HEXA_LAW_OK=1 \"$real\" \"$@\"\n" +
           "}\n"
}

// ─── verify 모드 ────────────────────────────────────────────
if verify_mode {
    let rc = _rc_path()
    let has_wrap = to_string(exec("grep -c 'hexa-lang wrapper (Phase α)' '" + rc + "' 2>/dev/null || echo 0")).trim()
    println("── wrapper install 상태 ──")
    println("shell RC  : " + rc)
    println("installed : " + (if has_wrap != "0" { "✅" } else { "❌ 미설치" }))
    if has_wrap == "0" {
        println("")
        println("설치 방법: hexa 도구/install_wrapper.hexa")
    }
    exit(0)
}

// ─── 가이드 출력 ────────────────────────────────────────────
let fn_body = _hexa_function(root)

println("── hexa wrapper install (Phase α) ─────────────────────")
println("")
println("방법 1 — shell function (권장, 투명)")
println("")
println("아래 블록을 " + _rc_path() + " 에 추가:")
println("")
println("──────────────────────────────────────")
print(fn_body)
println("──────────────────────────────────────")
println("")
println("방법 2 — 1회 검사 (임시)")
println("")
println("  hexa 도구/law_check.hexa && hexa <file.hexa>")
println("")
println("방법 3 — HEXA_REAL 환경변수 지정 (우회용)")
println("")
println("  export HEXA_REAL=/path/to/hexa_binary")
println("  HEXA_LAW_OK=1 hexa <file.hexa>   # law_check skip")
println("")
println("──────────────────────────────────────")
println("")
println("설치 후:")
println("  source " + _rc_path())
println("")
println("검증:")
println("  hexa 도구/install_wrapper.hexa --verify")
println("")

if copy_mode && _uname() == "Darwin" {
    try {
        exec("printf '%s' '" + fn_body + "' | pbcopy 2>/dev/null")
        println("📋 클립보드 복사 완료 — " + _rc_path() + " 에 paste")
    } catch e {}
}

println("주의:")
println("  · .sh 파일 repo 생성 안 함 (edict #7 HEXA-ONLY 준수)")
println("  · alias 는 사용자 shell config — repo 외부")
println("  · 해제: " + _rc_path() + " 의 함수 블록 수동 삭제")
