// ═══════════════════════════════════════════════════════════════
//  build_linux_x86.hexa — hexa → static ELF linux/x86_64 binary
//
//  Primary path: macOS + x86_64-linux-musl-gcc (Homebrew: musl-cross).
//    musl-gcc bundles its own sysroot + libc → no clang target flag,
//    no LINUX_SYSROOT, produces a fully static ELF out of the box.
//
//  Fallback: native Linux x86_64 (gcc/clang direct).
//
//  Usage:
//    hexa 도구/build_linux_x86.hexa <source.hexa> [-o <out>]
//
//  Env:
//    LINUX_CC      override compiler (default: x86_64-linux-musl-gcc on Darwin,
//                                               cc on Linux)
//    EXTRA_CFLAGS  append to cflags
//    KEEP_TMP=1    keep intermediate /tmp/hx_linx_*
//
//  Pipeline:
//    1. flatten_imports → single .hexa
//    2. hexa_v2 → .c
//    3. musl-gcc -static → ELF x86_64 linux
//    4. file(1) + sha256 report
// ═══════════════════════════════════════════════════════════════

fn run_ok(cmd) {
    let r = exec_with_status(cmd)
    if r[1] != 0 {
        eprintln("FAILED: " + cmd)
        if r[0] != "" { eprintln(r[0]) }
        exit(1)
    }
    r[0]
}

fn main() {
    let args = argv()
    if len(args) < 2 {
        eprintln("Usage: hexa 도구/build_linux_x86.hexa <source.hexa> [-o <out>]")
        exit(1)
    }

    let mut source = ""
    let mut out_path = ""
    let mut ai = 2
    while ai < len(args) {
        let a = args[ai]
        if a == "-o" && (ai + 1) < len(args) {
            ai = ai + 1
            out_path = args[ai]
        } else if source == "" {
            source = a
        }
        ai = ai + 1
    }

    if source == "" || !file_exists(source) {
        eprintln("error: source not found: " + source)
        exit(1)
    }

    // Repo root = dir of this script's parent (도구/../).
    // We resolve from source's absolute path assumptions by using pwd + relative.
    let repo_root = exec_with_status("pwd")[0].trim()
    let uname = exec_with_status("uname -s")[0].trim()

    let base = exec_with_status("basename '" + source + "' .hexa")[0].trim()
    if out_path == "" {
        out_path = repo_root + "/build/" + base + "-linux-x86_64"
    }

    let mut cc = env("LINUX_CC")
    if cc == "" {
        if uname == "Darwin" {
            cc = "x86_64-linux-musl-gcc"
        } else {
            cc = "cc"
        }
    }

    let extra_cflags = env("EXTRA_CFLAGS")
    let keep_tmp = env("KEEP_TMP")

    println("=== hexa → linux/x86_64 (static ELF) ===")
    println("  source : " + source)
    println("  output : " + out_path)
    println("  cc     : " + cc)
    println("  uname  : " + uname)

    // Sanity: compiler exists
    let cc_check = exec_with_status("which " + cc + " 2>/dev/null")
    if cc_check[1] != 0 || cc_check[0].trim() == "" {
        eprintln("error: compiler not found: " + cc)
        eprintln("  install: brew install FiloSottile/musl-cross/musl-cross (macOS)")
        eprintln("           apt install gcc (Linux)")
        exit(1)
    }

    // ── 1. flatten ───────────────────────────────────────────
    println("[1/3] flatten imports")
    let flat = "/tmp/hx_linx_" + base + "_flat.hexa"
    let stage0_real = env("HOME") + "/.hx/packages/hexa/build/hexa_stage0.real"
    let mut runner = ""
    if file_exists(stage0_real) {
        runner = stage0_real
    } else if file_exists(repo_root + "/build/hexa_stage0") {
        runner = repo_root + "/build/hexa_stage0"
    } else {
        eprintln("error: no hexa runner (expected hexa_stage0.real or build/hexa_stage0)")
        exit(1)
    }
    let flatten_script = repo_root + "/도구/flatten_imports.hexa"
    run_ok(runner + " " + flatten_script + " " + source + " " + flat)
    if !file_exists(flat) {
        eprintln("error: flatten output missing: " + flat)
        exit(1)
    }

    // ── 2. hexa_v2 → .c ──────────────────────────────────────
    println("[2/3] transpile → C")
    let hexa_v2 = repo_root + "/self/native/hexa_v2"
    if !file_exists(hexa_v2) {
        eprintln("error: hexa_v2 missing at " + hexa_v2)
        exit(1)
    }
    let src_c = "/tmp/hx_linx_" + base + ".c"
    run_ok(hexa_v2 + " " + flat + " " + src_c)
    if !file_exists(src_c) {
        eprintln("error: C output missing: " + src_c)
        exit(1)
    }

    // runtime.c must sit next to generated src_c (it's #include "runtime.c")
    let runtime_src = repo_root + "/self/runtime.c"
    let c_dir = "/tmp"
    run_ok("cp -f " + runtime_src + " " + c_dir + "/runtime.c")

    // ── 3. compile static ELF ────────────────────────────────
    println("[3/3] compile static ELF")
    run_ok("mkdir -p " + exec_with_status("dirname '" + out_path + "'")[0].trim())

    // musl-gcc: no target flag, -static gives fully static, -I self for headers
    let cflags = "-O2 -std=gnu11 -D_GNU_SOURCE -Wno-trigraphs"
    let libs = "-static -lm"
    let incs = "-I " + repo_root + "/self"
    let cmd = cc + " " + cflags + " " + extra_cflags + " " + incs + " " + src_c + " -o " + out_path + " " + libs
    println("  " + cmd)
    run_ok(cmd)

    // ── report ───────────────────────────────────────────────
    let file_info = exec_with_status("file " + out_path)[0].trim()
    let size = exec_with_status("wc -c < '" + out_path + "' | tr -d ' '")[0].trim()
    let sha = exec_with_status("shasum -a 256 " + out_path + " | awk '{print $1}'")[0].trim()

    println("")
    println("=== BUILD OK ===")
    println("  path   : " + out_path)
    println("  size   : " + size + " bytes")
    println("  sha256 : " + sha)
    println("  file   : " + file_info)

    // Clean up intermediates
    if keep_tmp != "1" {
        exec_with_status("rm -f " + flat + " " + src_c + " " + c_dir + "/runtime.c")
    } else {
        println("  (kept: " + flat + ", " + src_c + ")")
    }

    println("")
    println("Deploy to linux host:")
    println("  scp " + out_path + " user@host:/path/ && ssh user@host ./path/" + base + "-linux-x86_64")
}
