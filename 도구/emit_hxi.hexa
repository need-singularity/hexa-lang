// ═══════════════════════════════════════════════════════════
//  도구/emit_hxi.hexa — Separate Compilation M1
//
//  Standalone .hxi emitter. Reads a .hexa source and writes a
//  line-based module interface (.hxi) listing public decls.
//
//  Usage:
//      hexa run 도구/emit_hxi.hexa <input.hexa> <output.hxi>
//
//  Invocation path (avoids main.hexa rebuild):
//    this script → stage0 → loads lexer/parser/codegen_c2 via
//    read_file → tokenize → parse → emit_hxi → write_file.
//
//  Paired with existing `hexa build <src> -o <out.c> --c-only`:
//      hexa build src/foo.hexa -o build/artifacts/foo.c --c-only
//      hexa run 도구/emit_hxi.hexa src/foo.hexa build/artifacts/foo.hxi
//
//  Schema v0 (frozen; see docs/separate-compilation-design.md):
//      hxi v0
//      src_bytes <N>
//      fn <name>(<pname>:<ptype>,...)-><ret>
//      struct <name>(<fname>:<ftype>,...)
//      enum <name>
//      extern <name>(...)-><ret> [@symbol=...] [@link=...]
//      let <name>:<type>           (type="_" when unresolved)
//      let_mut <name>:<type>
//      comptime <name>
//
//  Exit codes:
//      0 — .hxi written successfully
//      1 — usage error / input file missing
//      2 — parse error
// ═══════════════════════════════════════════════════════════

use "self/stdlib/law_io"

// args() under stage0 `run <script> <A> <B>` returns ["hexa_stage0","run","<script>","<A>","<B>"]
// under direct binary `./hexa run <script> <A> <B>` — same 5-element layout.
// So the payload starts at index 3.
let _argv = args()
let _argc = len(_argv)
// Locate the first arg AFTER the script path. Scan for a trailing .hexa to
// find the script index — robust to front-end (stage0 vs ./hexa vs hexa.real).
let mut _script_idx = -1
let mut _si = 0
while _si < _argc {
    let _sa = to_string(_argv[_si])
    if len(_sa) >= 16 && _sa.ends_with("/emit_hxi.hexa") { _script_idx = _si }
    _si = _si + 1
}
let _payload_start = if _script_idx >= 0 { _script_idx + 1 } else { 1 }
if _argc < _payload_start + 2 {
    println("usage: hexa run 도구/emit_hxi.hexa <input.hexa> <output.hxi>")
    println("  argc=" + to_string(_argc) + " payload_start=" + to_string(_payload_start))
    let mut _di = 0
    while _di < _argc {
        println("  argv[" + to_string(_di) + "]=" + to_string(_argv[_di]))
        _di = _di + 1
    }
    exit(1)
}

let INPUT = to_string(_argv[_payload_start])
let OUTPUT = to_string(_argv[_payload_start + 1])

let _input_exists = exec("test -f '" + INPUT + "' && printf yes || printf no")
if _input_exists != "yes" {
    println("error: input not found: " + INPUT)
    exit(1)
}

// Resolve self/ dir — prefer $HEXA_LANG, fallback to cwd
let _env_hl = env_var("HEXA_LANG")
let _hexa_root = if len(_env_hl) > 0 { _env_hl } else { exec("pwd | tr -d '\\n'") }
let SELF_DIR = _hexa_root + "/self"

// Compose driver: lexer + parser + codegen_c2 (for emit_hxi) + body
let _lexer = read_file(SELF_DIR + "/lexer.hexa")
let _parser = read_file(SELF_DIR + "/parser.hexa")
let _cg = read_file(SELF_DIR + "/codegen_c2.hexa")

if len(_lexer) == 0 || len(_parser) == 0 || len(_cg) == 0 {
    println("error: self/{lexer,parser,codegen_c2}.hexa missing under " + SELF_DIR)
    exit(1)
}

let _b1 = "let __src = read_file(\"" + INPUT + "\")\n"
let _b2 = "let __toks = tokenize(__src)\n"
let _b3 = "let __ast = parse(__toks)\n"
let _b4 = "if len(p_errors) > 0 {\n    let mut __ei = 0\n    while __ei < len(p_errors) {\n        eprintln(\"parse error: \" + to_string(p_errors[__ei]))\n        __ei = __ei + 1\n    }\n    exit(2)\n}\n"
let _b5 = "let __hxi = emit_hxi(__ast, len(__src))\n"
let _b6 = "write_file(\"" + OUTPUT + "\", __hxi)\n"
let _b7 = "println(\"OK: wrote " + OUTPUT + " (\" + to_string(len(__hxi)) + \" bytes, \" + to_string(len(__ast)) + \" top-level decls)\")\n"
let _body = _b1 + _b2 + _b3 + _b4 + _b5 + _b6 + _b7

let _driver_path = exec("printf '/tmp/_emit_hxi_driver.%s.hexa' \"$$\" | tr -d '\\n'")
safe_write_file(_driver_path, _lexer + "\n" + _parser + "\n" + _cg + "\n" + _body)

// Invoke stage0 directly — avoid recursive ./hexa dispatch overhead
let _stage0 = _hexa_root + "/build/hexa_stage0"
let _stage0_ok = exec("test -x '" + _stage0 + "' && printf yes || printf no")
if _stage0_ok != "yes" {
    println("error: stage0 not found at " + _stage0)
    exit(1)
}

let _cmd = "HEXA_LOCAL=1 '" + _stage0 + "' run '" + _driver_path + "' 2>&1"
let _out = exec(_cmd)
println(_out)

let _out_ok = exec("test -f '" + OUTPUT + "' && printf yes || printf no")
if _out_ok != "yes" {
    eprintln("error: .hxi not produced: " + OUTPUT)
    exit(2)
}
