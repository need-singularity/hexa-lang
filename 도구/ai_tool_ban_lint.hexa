// 도구/ai_tool_ban_lint.hexa — raw #11 entry (AI-tool config ban)
//
// usage:
//   hexa 도구/ai_tool_ban_lint.hexa            — staged 파일 scan (git diff --cached), exit 1 on violation
//   hexa 도구/ai_tool_ban_lint.hexa --list     — ban list 출력 (debug 용)
//
// exit code:
//   0 — violation 0 (pass)
//   1 — violation 1+ (block)
//
// rule: .raw#11 — SSOT = .raw/.own 만. AI 도구별 config (CLAUDE.md, cursor, copilot 등) 난립 차단.
// semantics: 기존 파일 grandfather (본 lint 가 삭제하지 않음) — 그러나 staged add/modify 는 전부 block.
//   git diff --cached --diff-filter=ACM 으로 잡히면 = 새로 쓴 것 → 거부.

let _raw_args = args()
let mut cli = []
let mut ai = 2
while ai < len(_raw_args) {
    cli = cli.push(_raw_args[ai])
    ai = ai + 1
}

// ban list — 정확히 매치되어야 하는 파일명 (경로 전체 비교).
let exact_bans = [
    "CLAUDE.md",
    "AGENTS.md",
    "CODEX.md",
    ".cursorrules",
    ".windsurfrules",
    ".aider.conf.yml",
    ".continuerules",
    ".github/copilot-instructions.md",
]

// prefix bans — 디렉토리 전체 금지 (trailing slash 포함 매치).
let prefix_bans = [
    ".cursor/",
    ".claude/",
]

fn is_banned(path) {
    let mut i = 0
    while i < len(exact_bans) {
        if path == exact_bans[i] { return true }
        i = i + 1
    }
    let mut j = 0
    while j < len(prefix_bans) {
        if path.starts_with(prefix_bans[j]) { return true }
        j = j + 1
    }
    return false
}

fn print_bans() {
    println("raw#11 ban list — AI-tool config 금지:")
    println("")
    println("exact (파일명 매치):")
    let mut i = 0
    while i < len(exact_bans) {
        println("  - " + exact_bans[i])
        i = i + 1
    }
    println("")
    println("prefix (디렉토리 전체):")
    let mut j = 0
    while j < len(prefix_bans) {
        println("  - " + prefix_bans[j] + "*")
        j = j + 1
    }
    println("")
    println("대안: .raw (universal) 또는 .own (project-local) 에 규칙 추가")
}

// --list 모드
let mut list_mode = false
let mut li = 0
while li < len(cli) {
    if cli[li] == "--list" { list_mode = true }
    li = li + 1
}

if list_mode {
    print_bans()
    exit(0)
}

// staged scan
let mut paths = []
let out = to_string(exec("git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true")).trim()
if out != "" {
    let parts = split(out, "\n")
    for p in parts {
        let t = p.trim()
        if t != "" { paths = paths.push(t) }
    }
}

if len(paths) == 0 {
    println("raw#11: staged 파일 없음 — pass")
    exit(0)
}

let mut violations = []
let mut vi = 0
while vi < len(paths) {
    let p = paths[vi]
    if is_banned(p) { violations = violations.push(p) }
    vi = vi + 1
}

if len(violations) == 0 {
    println("raw#11: OK — " + to_string(len(paths)) + " staged 파일 scan, 0 violation")
    exit(0)
}

eprintln("🚫 raw#11 AI-tool config 금지 — " + to_string(len(violations)) + " violation (" + to_string(len(paths)) + " staged 파일 scan)")
eprintln("")
let mut wi = 0
while wi < len(violations) {
    let v = violations[wi]
    eprintln("  violation: " + v)
    eprintln("  why:       SSOT = .raw/.own 만. AI 도구 설정 난립 차단.")
    eprintln("  대안:      .raw (universal) 또는 .own (project-local) 에 규칙 추가")
    eprintln("")
    wi = wi + 1
}
eprintln("ref: .raw#11 (AI-tool config 전면 금지, grandfather). --list 로 전체 ban 목록 확인.")
exit(1)
